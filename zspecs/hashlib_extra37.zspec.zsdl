spec: hashlib_extra37
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib_extra36.zspec.zsdl — covers sha3_224/sha3_384 __name__/__module__.__len__(); hashlib.__spec__.__name__/__loader__.__class__.__name__.__len__(); shake_128/shake_256 __qualname__.__len__()."
    - "hashlib_extra33.zspec.zsdl — covers HASH.update/digest/hexdigest/copy __qualname__.__len__() via md5().__class__; HASH.__mro__.__len__()==2; algorithms_guaranteed/__class__/__name__.__len__()==3."
    - "hashlib_extra32.zspec.zsdl — covers sha1/sha512/sha224/sha384/blake2b/blake2s/sha3_256 __module__.__len__(); new/__module__/__name__.__len__(); blake2b/blake2s __name__.__len__()==7."
    - "hashlib_extra31.zspec.zsdl — covers md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__()."
    - "hashlib_extra28.zspec.zsdl — covers sha3_256/sha3_512/blake2b/blake2s __qualname__.__len__()."
  notes:
    - "This spec extends hashlib through hashlib_extra36; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: HASH.update/digest/hexdigest/copy __qualname__.__len__() (extra33 via md5().__class__); blake2b/blake2s __qualname__.__len__()==7 (extra28 covers the class-level __qualname__, not instance method qualnames); blake2b/blake2s __name__.__len__()==7 (extra32); all HASH-backed method qualnames (extra33)."
    - "This spec covers: blake2b instance method __qualname__.__len__() for update/digest/hexdigest/copy (NOVEL — extra33 covers HASH.xxx methods via md5().__class__ but blake2b methods use the 'blake2b.' prefix not 'HASH.'; blake2b.update.__qualname__=='blake2b.update' len 14, blake2b.digest.__qualname__=='blake2b.digest' len 14, blake2b.hexdigest.__qualname__=='blake2b.hexdigest' len 17, blake2b.copy.__qualname__=='blake2b.copy' len 12); blake2s instance method __qualname__.__len__() (NOVEL — same reasoning; blake2s.update/digest/hexdigest/copy all have 'blake2s.' prefix)."
    - "blake2b.update.__qualname__ == 'blake2b.update' (len 14). The blake2b C type uses 'blake2b.' as class prefix in method qualnames, unlike the HASH type used for OpenSSL-backed algorithms. extra33 covers HASH-backed qualnames only. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "blake2b.digest.__qualname__ == 'blake2b.digest' (len 14). Same prefix as update. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "blake2b.hexdigest.__qualname__ == 'blake2b.hexdigest' (len 17). 'blake2b.hexdigest' is longer than 'HASH.hexdigest' (14) due to the longer class name prefix. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "blake2b.copy.__qualname__ == 'blake2b.copy' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "blake2s.update.__qualname__ == 'blake2s.update' (len 14). blake2s methods use 'blake2s.' prefix. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "blake2s.digest.__qualname__ == 'blake2s.digest' (len 14). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "blake2s.hexdigest.__qualname__ == 'blake2s.hexdigest' (len 17). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "blake2s.copy.__qualname__ == 'blake2s.copy' (len 12). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# blake2b instance method __qualname__.__len__()
#
# extra33 covers HASH-type method qualnames (HASH.update==11, HASH.digest==11,
# HASH.hexdigest==14, HASH.copy==9) via md5().__class__. The blake2b C type
# uses 'blake2b.' as its class prefix, not 'HASH.', producing different lengths:
#   blake2b.update   -> 'blake2b.update'   (len 14)
#   blake2b.digest   -> 'blake2b.digest'   (len 14)
#   blake2b.hexdigest -> 'blake2b.hexdigest' (len 17)
#   blake2b.copy     -> 'blake2b.copy'     (len 12)
# No prior spec checks instance method __qualname__.__len__() for blake2b.
# Accessed via blake2b(b'').__class__ to get the raw C type.
# ---------------------------------------------------------------------------

table hashlib_extra37.blake2b_method_qualname_lengths:
  description: "blake2b instance method __qualname__.__len__() — novel; extra33 covers HASH.xxx methods only; blake2b uses 'blake2b.' prefix giving different lengths"
  kind: python_call_eq
  category: function_names
  id_prefix: b2bmql37

  columns: [id, function, args, expected]
  rows:
    - [update,    "blake2b(b'').__class__.update.__qualname__.__len__",    [], 14]
    - [digest,    "blake2b(b'').__class__.digest.__qualname__.__len__",    [], 14]
    - [hexdigest, "blake2b(b'').__class__.hexdigest.__qualname__.__len__", [], 17]
    - [copy,      "blake2b(b'').__class__.copy.__qualname__.__len__",      [], 12]

# ---------------------------------------------------------------------------
# blake2s instance method __qualname__.__len__()
#
# blake2s mirrors blake2b in C type naming: 'blake2s.' prefix in qualnames.
# extra32 covers blake2s.__name__.__len__()==7 but no prior spec checks any
# blake2s instance method qualname length.
#   blake2s.update   -> 'blake2s.update'   (len 14)
#   blake2s.digest   -> 'blake2s.digest'   (len 14)
#   blake2s.hexdigest -> 'blake2s.hexdigest' (len 17)
#   blake2s.copy     -> 'blake2s.copy'     (len 12)
# ---------------------------------------------------------------------------

table hashlib_extra37.blake2s_method_qualname_lengths:
  description: "blake2s instance method __qualname__.__len__() — novel; no prior spec checks blake2s instance method qualname lengths; blake2s uses 'blake2s.' prefix"
  kind: python_call_eq
  category: function_names
  id_prefix: b2smql37

  columns: [id, function, args, expected]
  rows:
    - [update,    "blake2s(b'').__class__.update.__qualname__.__len__",    [], 14]
    - [digest,    "blake2s(b'').__class__.digest.__qualname__.__len__",    [], 14]
    - [hexdigest, "blake2s(b'').__class__.hexdigest.__qualname__.__len__", [], 17]
    - [copy,      "blake2s(b'').__class__.copy.__qualname__.__len__",      [], 12]
