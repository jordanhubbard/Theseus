spec: re_extra86
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra85."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error/__name__; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ values and lengths; PatternError hierarchy; re.compile/__qualname__/__module__; re.match/sub/findall/split __qualname__; Match.start/end class name and qualname; re module function __module__ values; Pattern/Match method __doc__.__class__.__name__; Match method __qualname__ values and lengths; re module function __code__ attributes; Pattern/Match identity (__name__/__module__/__bases__/__mro__); Pattern/Match __dict__.__class__.__name__; Pattern/Match __qualname__ and length; PatternError __name__ and __module__; Pattern/Match method __qualname__ string equality; PatternError/__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); re.error alias; re.IGNORECASE/MULTILINE/DOTALL/__class__.__name__; re.RegexFlag/__name__/__module__."
    - "This spec covers: re.compile.__qualname__ == 'compile' (length 7); re.compile.__module__ == 're'; re.compile.__qualname__.__len__() == 7; re.IGNORECASE.__eq__(2); re.MULTILINE.__eq__(8); re.DOTALL.__eq__(16); re.VERBOSE.__class__.__name__; re.VERBOSE.__eq__(64); re.ASCII.__class__.__name__; re.UNICODE.__class__.__name__; re.RegexFlag.__bases__[0].__name__ == 'IntFlag'; re.RegexFlag.__mro__.__len__() == 7; re.NOFLAG.__class__.__name__ == 'RegexFlag'; re.NOFLAG.__eq__(0)."
    - "re.compile.__qualname__ == 'compile' — length 7; the function name without module prefix."
    - "re.compile.__module__ == 're' — the re module function."
    - "re.compile.__qualname__.__len__() == 7 — len('compile') == 7."
    - "re.IGNORECASE.__eq__(2) == True — IGNORECASE has integer value 2."
    - "re.MULTILINE.__eq__(8) == True — MULTILINE has integer value 8."
    - "re.DOTALL.__eq__(16) == True — DOTALL has integer value 16."
    - "re.VERBOSE.__class__.__name__ == 'RegexFlag' — VERBOSE is a RegexFlag member."
    - "re.VERBOSE.__eq__(64) == True — VERBOSE has integer value 64."
    - "re.ASCII.__class__.__name__ == 'RegexFlag' — ASCII is a RegexFlag member."
    - "re.UNICODE.__class__.__name__ == 'RegexFlag' — UNICODE is a RegexFlag member."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from IntFlag."
    - "re.RegexFlag.__mro__.__len__() == 7 — verified: [RegexFlag, IntFlag, int, ReprEnum, Enum, int, object] — MRO has 7 entries."
    - "re.NOFLAG.__class__.__name__ == 'RegexFlag' — NOFLAG is a RegexFlag member (Python 3.11+)."
    - "re.NOFLAG.__eq__(0) == True — NOFLAG has integer value 0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile function attributes: __qualname__ and __module__
# re.compile is a module-level function; __qualname__ == 'compile' (len 7),
# __module__ == 're'.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra86.compile_attrs:
  description: "re.compile.__qualname__, __module__, __qualname__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: reextra86

  columns: [id, function, args, expected]
  rows:
    - [compile_qualname,     compile.__qualname__.__eq__,     ["compile"], true]
    - [compile_module,       compile.__module__.__eq__,       ["re"],      true]
    - [compile_qualname_len, compile.__qualname__.__len__,    [],          7]

# ---------------------------------------------------------------------------
# re.RegexFlag integer values for IGNORECASE, MULTILINE, DOTALL
# IGNORECASE == 2, MULTILINE == 8, DOTALL == 16.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra86.flag_values_imd:
  description: "re.IGNORECASE.__eq__(2), re.MULTILINE.__eq__(8), re.DOTALL.__eq__(16)"
  kind: python_call_eq
  category: flag_values
  id_prefix: reextra86

  columns: [id, function, args, expected]
  rows:
    - [ignorecase_val, IGNORECASE.__eq__, [2],  true]
    - [multiline_val,  MULTILINE.__eq__,  [8],  true]
    - [dotall_val,     DOTALL.__eq__,     [16], true]

# ---------------------------------------------------------------------------
# re.RegexFlag values and class names for VERBOSE, ASCII, UNICODE
# VERBOSE.__class__.__name__ == 'RegexFlag'; VERBOSE == 64.
# ASCII and UNICODE are also RegexFlag members.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra86.flag_verbose_ascii_unicode:
  description: "re.VERBOSE/__class__.__name__ and value; re.ASCII/UNICODE __class__.__name__"
  kind: python_call_eq
  category: flag_values
  id_prefix: reextra86

  columns: [id, function, args, expected]
  rows:
    - [verbose_cls,  VERBOSE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [verbose_val,  VERBOSE.__eq__,                    [64],          true]
    - [ascii_cls,    ASCII.__class__.__name__.__eq__,   ["RegexFlag"], true]
    - [unicode_cls,  UNICODE.__class__.__name__.__eq__, ["RegexFlag"], true]

# ---------------------------------------------------------------------------
# re.RegexFlag hierarchy: __bases__[0].__name__ and __mro__.__len__()
# RegexFlag inherits from IntFlag; MRO has 7 entries.
# re.NOFLAG is a RegexFlag member (Python 3.11+) with value 0.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra86.RegexFlag_hierarchy_and_noflag:
  description: "re.RegexFlag __bases__[0].__name__, __mro__.__len__(); re.NOFLAG class and value"
  kind: python_call_eq
  category: flag_values
  id_prefix: reextra86

  columns: [id, function, args, expected]
  rows:
    - [rgf_base0,    "RegexFlag.__bases__[0].__name__.__eq__", ["IntFlag"], true]
    - [rgf_mro_len,  RegexFlag.__mro__.__len__,                [],          7]
    - [noflag_cls,   NOFLAG.__class__.__name__.__eq__,         ["RegexFlag"], true]
    - [noflag_val,   NOFLAG.__eq__,                            [0],           true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra86.compile.qualname:
  description: "re.compile.__qualname__ == 'compile' (length 7)"
  category: class_identity
  kind: python_call_eq
  function: compile.__qualname__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra86.IGNORECASE.value:
  description: "re.IGNORECASE.__eq__(2) == True (IGNORECASE has integer value 2)"
  category: flag_values
  kind: python_call_eq
  function: IGNORECASE.__eq__
  args: [2]
  expected: true

invariant re_extra86.VERBOSE.class_name:
  description: "re.VERBOSE.__class__.__name__ == 'RegexFlag' (VERBOSE is a RegexFlag member)"
  category: flag_values
  kind: python_call_eq
  function: VERBOSE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra86.RegexFlag.base_name:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag inherits from IntFlag)"
  category: flag_values
  kind: python_call_eq
  function: "RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

invariant re_extra86.NOFLAG.value:
  description: "re.NOFLAG.__eq__(0) == True (NOFLAG has integer value 0; Python 3.11+)"
  category: flag_values
  kind: python_call_eq
  function: NOFLAG.__eq__
  args: [0]
  expected: true
