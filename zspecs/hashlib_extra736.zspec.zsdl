spec: hashlib_extra736
version: ">=3.9"
backend: python_module(hashlib)
docs: "Behavioral spec covering hashlib module attributes, algorithm sets, and constructor/function docstrings."
error_model: python_exceptions

provenance:
  derived_from:
    - python_stdlib_hashlib
  not_derived_from: []
  notes: "Covers algorithms_available, algorithms_guaranteed, and per-algorithm doc/qualname invariants."
  created_at: "2026-04-12"

table hashlib_extra736.algorithms:
  description: "Verifies hashlib algorithm set attributes and constructor/function metadata."
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: hl736xx
  columns: [id, function, args, expected]
  rows:
    - [hl736xx001, hashlib.algorithms_available.__class__.__name__.__eq__, ["set"], true]
    - [hl736xx002, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["set"], true]
    - [hl736xx003, hashlib.new.__qualname__.__eq__, ["new"], true]
    - [hl736xx004, hashlib.new.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl736xx005, hashlib.sha256.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl736xx006, hashlib.sha512.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl736xx007, hashlib.md5.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl736xx008, hashlib.sha1.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl736xx009, hashlib.sha224.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl736xx010, hashlib.sha384.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl736xx011, hashlib.sha3_256.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl736xx012, hashlib.sha3_512.__doc__.__class__.__name__.__eq__, ["str"], true]
