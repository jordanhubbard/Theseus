spec: uuid_extra901
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid callable __module__ attributes and namespace constant class names"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra901.uuid_callable_modules:
  description: "uuid callable __module__ identity"
  kind: python_call_eq
  category: callable_modules
  id_prefix: uu901cm
  columns: [id, function, args, expected]
  rows:
    - [uu901cm001, uuid.UUID.__module__.__eq__,   ["uuid"], true]
    - [uu901cm002, uuid.uuid1.__module__.__eq__,  ["uuid"], true]
    - [uu901cm003, uuid.uuid3.__module__.__eq__,  ["uuid"], true]
    - [uu901cm004, uuid.uuid4.__module__.__eq__,  ["uuid"], true]
    - [uu901cm005, uuid.uuid5.__module__.__eq__,  ["uuid"], true]

table uuid_extra901.namespace_constant_classes:
  description: "uuid namespace constant __class__.__name__ identity"
  kind: python_call_eq
  category: namespace_class_names
  id_prefix: uu901nc
  columns: [id, function, args, expected]
  rows:
    - [uu901nc001, uuid.NAMESPACE_DNS.__class__.__name__.__eq__,  ["UUID"], true]
    - [uu901nc002, uuid.NAMESPACE_URL.__class__.__name__.__eq__,  ["UUID"], true]
    - [uu901nc003, uuid.NAMESPACE_OID.__class__.__name__.__eq__,  ["UUID"], true]
    - [uu901nc004, uuid.NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true]
    - [uu901nc005, uuid.NAMESPACE_DNS.__class__.__module__.__eq__, ["uuid"], true]

table uuid_extra901.module_level_attrs:
  description: "uuid module-level attribute type identity checks"
  kind: python_call_eq
  category: module_attrs
  id_prefix: uu901ma
  columns: [id, function, args, expected]
  rows:
    - [uu901ma001, uuid.UUID.__module__.__class__.__name__.__eq__,   ["str"], true]
    - [uu901ma002, uuid.uuid1.__module__.__class__.__name__.__eq__,  ["str"], true]
    - [uu901ma003, uuid.uuid3.__module__.__class__.__name__.__eq__,  ["str"], true]
    - [uu901ma004, uuid.uuid4.__module__.__class__.__name__.__eq__,  ["str"], true]
    - [uu901ma005, uuid.uuid5.__module__.__class__.__name__.__eq__,  ["str"], true]
