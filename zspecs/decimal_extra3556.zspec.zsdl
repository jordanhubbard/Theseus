spec: dc3556
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 684 (dc3556): __reduce__, __reduce_ex__, __getstate__ dict-presence checks for decimal types."
    - "decimal.Decimal defines __reduce__ (true): Decimal implements custom pickle support to preserve value exactly."
    - "decimal.Context defines __reduce__ (true): Context implements custom pickle support to preserve all settings."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow: do NOT define __reduce__, __reduce_ex__, or __getstate__ in their own __dict__ (false)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __reduce__ dict-presence — operator.contains(Cls.__dict__, '__reduce__')
#
# decimal.Decimal and decimal.Context both define __reduce__ for pickle support.
# ---------------------------------------------------------------------------

table dc3556.reduce:
  description: "decimal types __reduce__ dict-presence checks; wave 684"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3556
  columns: [id, function, args, expected]
  rows:
    - ["dc3556001", operator.contains, [decimal.Decimal.__dict__,          "__reduce__"], true]
    - ["dc3556002", operator.contains, [decimal.Context.__dict__,          "__reduce__"], true]
    - ["dc3556003", operator.contains, [decimal.DecimalException.__dict__,  "__reduce__"], false]
    - ["dc3556004", operator.contains, [decimal.InvalidOperation.__dict__,  "__reduce__"], false]
    - ["dc3556005", operator.contains, [decimal.Overflow.__dict__,          "__reduce__"], false]

