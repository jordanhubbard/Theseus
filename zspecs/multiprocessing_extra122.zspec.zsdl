spec: multiprocessing_extra122
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "This spec covers: wave 255 theme — multiprocessing.Queue and Pipe function identity and multiprocessing.queues class method qualnames. NEW in extra122: multiprocessing.Queue.__name__=='Queue' (len=5); multiprocessing.Queue.__module__=='multiprocessing.context'; multiprocessing.Queue.__qualname__=='BaseContext.Queue' (len=17); multiprocessing.Queue.__class__.__name__=='method' (Queue is a bound method of the context, not a class); multiprocessing.Pipe.__name__=='Pipe' (len=4); multiprocessing.Pipe.__qualname__=='BaseContext.Pipe' (len=16); multiprocessing.queues.Queue.__name__=='Queue' (len=5); multiprocessing.queues.Queue is a real class (not a bound method); multiprocessing.queues.Queue.__mro__.__len__()==2; multiprocessing.queues.Queue.cancel_join_thread.__qualname__=='Queue.cancel_join_thread' (len=24, longest Queue method qualname); multiprocessing.queues.JoinableQueue.__mro__.__len__()==3; multiprocessing.queues.JoinableQueue.task_done.__qualname__=='JoinableQueue.task_done' (len=23). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Queue is a bound method, not a class. multiprocessing.Queue is a bound method of a BaseContext instance; calling multiprocessing.Queue() creates a multiprocessing.queues.Queue instance; multiprocessing.Queue.__class__.__name__=='method' while multiprocessing.queues.Queue.__class__.__name__=='type'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Queue.__qualname__ == 'BaseContext.Queue' (len=17). The qualname uses the defining class BaseContext rather than the bound context instance. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.queues.Queue.cancel_join_thread.__qualname__.__len__() == 24. 'Queue.cancel_join_thread' is 24 chars: 'Queue.'=6 + 'cancel_join_thread'=18. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Queue and Pipe bound method identity — extra122
#
# Wave 255 theme: multiprocessing.Queue and Pipe are bound methods of BaseContext.
#
# multiprocessing.Queue.__name__     == 'Queue'              (len=5)
# multiprocessing.Queue.__module__   == 'multiprocessing.context'
# multiprocessing.Queue.__qualname__ == 'BaseContext.Queue'  (len=17)
# multiprocessing.Queue.__class__.__name__ == 'method'       (bound method, not class)
# multiprocessing.Pipe.__name__      == 'Pipe'               (len=4)
# multiprocessing.Pipe.__qualname__  == 'BaseContext.Pipe'   (len=16)
# multiprocessing.Pipe.__class__.__name__ == 'method'
# ---------------------------------------------------------------------------

table multiprocessing_extra122.mp_queue_pipe_bound_methods:
  description: "multiprocessing.Queue and multiprocessing.Pipe bound method identity checks in mpqueues122 namespace — wave 255 theme: multiprocessing.Queue is a bound method of a BaseContext instance (not a class), so multiprocessing.Queue.__class__.__name__.__eq__('method')==True (bound method of context object); multiprocessing.Queue.__name__.__eq__('Queue')==True (len=5); multiprocessing.Queue.__name__.__len__()==5; multiprocessing.Queue.__module__.__eq__('multiprocessing.context')==True (defined in context.py on BaseContext); multiprocessing.Queue.__qualname__.__eq__('BaseContext.Queue')==True (len=17: 'BaseContext.'=12+'Queue'=5; qualname uses defining class name); multiprocessing.Queue.__qualname__.__len__()==17; multiprocessing.Pipe.__class__.__name__.__eq__('method')==True (also a bound method); multiprocessing.Pipe.__name__.__eq__('Pipe')==True (len=4, one char shorter than Queue); multiprocessing.Pipe.__qualname__.__eq__('BaseContext.Pipe')==True (len=16: 'BaseContext.'=12+'Pipe'=4, one shorter than Queue's 17); multiprocessing.Pipe.__qualname__.__len__()==16; all context factory functions (Queue, Pipe, Manager, Value, Array, Lock) are bound methods with the same class 'method'; calling multiprocessing.Queue() invokes BaseContext.Queue which returns a multiprocessing.queues.Queue instance; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpqueues122

  columns: [id, function, args, expected, description]
  rows:
    - [q_cls,       multiprocessing.Queue.__class__.__name__.__eq__,    ["method"],                    true, "multiprocessing.Queue.__class__.__name__ == 'method' (bound method of BaseContext, not a class); verified with Python 3.14.3"]
    - [q_name_eq,   multiprocessing.Queue.__name__.__eq__,              ["Queue"],                     true, "multiprocessing.Queue.__name__ == 'Queue' (len=5); verified with Python 3.14.3"]
    - [q_name_len,  multiprocessing.Queue.__name__.__len__,             [],                            5,    "multiprocessing.Queue.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [q_mod_eq,    multiprocessing.Queue.__module__.__eq__,            ["multiprocessing.context"],   true, "multiprocessing.Queue.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [q_qn_eq,     multiprocessing.Queue.__qualname__.__eq__,          ["BaseContext.Queue"],         true, "multiprocessing.Queue.__qualname__ == 'BaseContext.Queue' (len=17, qualname uses defining class); verified with Python 3.14.3"]
    - [q_qn_len,    multiprocessing.Queue.__qualname__.__len__,         [],                            17,   "multiprocessing.Queue.__qualname__.__len__() == 17 ('BaseContext.'=12+'Queue'=5); verified with Python 3.14.3"]
    - [p_cls,       multiprocessing.Pipe.__class__.__name__.__eq__,     ["method"],                    true, "multiprocessing.Pipe.__class__.__name__ == 'method' (also a bound method); verified with Python 3.14.3"]
    - [p_name_eq,   multiprocessing.Pipe.__name__.__eq__,               ["Pipe"],                     true, "multiprocessing.Pipe.__name__ == 'Pipe' (len=4, one char shorter than Queue); verified with Python 3.14.3"]
    - [p_name_len,  multiprocessing.Pipe.__name__.__len__,              [],                            4,    "multiprocessing.Pipe.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [p_qn_eq,     multiprocessing.Pipe.__qualname__.__eq__,           ["BaseContext.Pipe"],          true, "multiprocessing.Pipe.__qualname__ == 'BaseContext.Pipe' (len=16, one shorter than Queue's 17); verified with Python 3.14.3"]
    - [p_qn_len,    multiprocessing.Pipe.__qualname__.__len__,          [],                            16,   "multiprocessing.Pipe.__qualname__.__len__() == 16 ('BaseContext.'=12+'Pipe'=4); verified with Python 3.14.3"]

