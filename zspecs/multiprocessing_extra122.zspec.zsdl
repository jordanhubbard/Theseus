table multiprocessing_extra122.mp_joinablequeue_identity:
  description: "multiprocessing.queues.JoinableQueue class identity and method __qualname__ checks in mpqueues122 namespace — wave 255 theme: JoinableQueue extends Queue with join() and task_done() methods for tracking when all items have been processed; JoinableQueue.__name__.__eq__('JoinableQueue')==True (len=13: 'Joinable'=8+'Queue'=5=13); JoinableQueue.__name__.__len__()==13; JoinableQueue.__module__.__eq__('multiprocessing.queues')==True; JoinableQueue.__bases__[0].__name__.__eq__('Queue')==True (direct subclass of multiprocessing.queues.Queue); JoinableQueue.__mro__.__len__()==3 ([JoinableQueue, Queue, object], one deeper than Queue's 2-element MRO); JoinableQueue.join.__qualname__.__eq__('JoinableQueue.join')==True (len=18: 'JoinableQueue.'=14+'join'=4); JoinableQueue.join.__qualname__.__len__()==18; JoinableQueue.task_done.__qualname__.__eq__('JoinableQueue.task_done')==True (len=23: 'JoinableQueue.'=14+'task_done'=9, the longest JoinableQueue method qualname in this spec); JoinableQueue.task_done.__qualname__.__len__()==23; compare Queue.cancel_join_thread len=24 (longest overall); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpqueues122b

  columns: [id, function, args, expected, description]
  rows:
    - [jq_name_eq,  "multiprocessing.queues.JoinableQueue.__name__.__eq__",               ["JoinableQueue"],             true, "JoinableQueue.__name__ == 'JoinableQueue' (len=13); verified with Python 3.14.3"]
    - [jq_name_len, "multiprocessing.queues.JoinableQueue.__name__.__len__",               [],                            13,   "JoinableQueue.__name__.__len__() == 13 ('Joinable'=8+'Queue'=5=13); verified with Python 3.14.3"]
    - [jq_mod_eq,   "multiprocessing.queues.JoinableQueue.__module__.__eq__",              ["multiprocessing.queues"],    true, "JoinableQueue.__module__ == 'multiprocessing.queues'; verified with Python 3.14.3"]
    - [jq_base0,    "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__",   ["Queue"],                     true, "JoinableQueue.__bases__[0].__name__ == 'Queue' (direct subclass of Queue); verified with Python 3.14.3"]
    - [jq_mro_len,  "multiprocessing.queues.JoinableQueue.__mro__.__len__",                [],                            3,    "JoinableQueue.__mro__.__len__() == 3 ([JoinableQueue, Queue, object]); verified with Python 3.14.3"]
    - [jq_join_qeq, "multiprocessing.queues.JoinableQueue.join.__qualname__.__eq__",       ["JoinableQueue.join"],        true, "JoinableQueue.join.__qualname__ == 'JoinableQueue.join' (len=18); verified with Python 3.14.3"]
    - [jq_join_qln, "multiprocessing.queues.JoinableQueue.join.__qualname__.__len__",      [],                            18,   "JoinableQueue.join.__qualname__.__len__() == 18 ('JoinableQueue.'=14+'join'=4); verified with Python 3.14.3"]
    - [jq_td_qeq,   "multiprocessing.queues.JoinableQueue.task_done.__qualname__.__eq__",  ["JoinableQueue.task_done"],   true, "JoinableQueue.task_done.__qualname__ == 'JoinableQueue.task_done' (len=23); verified with Python 3.14.3"]
    - [jq_td_qlen,  "multiprocessing.queues.JoinableQueue.task_done.__qualname__.__len__", [],                            23,   "JoinableQueue.task_done.__qualname__.__len__() == 23 ('JoinableQueue.'=14+'task_done'=9, longest JQ method); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra122
# ---------------------------------------------------------------------------

invariant multiprocessing_extra122.mp_Queue_is_bound_method:
  description: "multiprocessing.Queue.__class__.__name__.__eq__('method') returns True — multiprocessing.Queue is a bound method of the active BaseContext instance, not a class; calling multiprocessing.Queue() invokes BaseContext.Queue() which creates a multiprocessing.queues.Queue instance; multiprocessing.Queue.__qualname__ is 'BaseContext.Queue' (len=17: 'BaseContext.'=12+'Queue'=5); multiprocessing.Queue.__module__ is 'multiprocessing.context'; this is a key design pattern of multiprocessing: the top-level namespace exports factory bound methods for Queue, Pipe, Manager, Value, Array, Lock — all have class='method'; compare multiprocessing.queues.Queue.__class__.__name__=='type' (the actual class); NEW in extra122: first standalone multiprocessing.Queue bound method class invariant in mpqueues122 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Queue.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra122.mp_Queue_qualname_len_17:
  description: "multiprocessing.Queue.__qualname__.__len__() == 17 — multiprocessing.Queue.__qualname__ is 'BaseContext.Queue' (17 chars: 'BaseContext.'=12 + 'Queue'=5=17); the qualname uses the defining class BaseContext rather than the bound context instance; compare with multiprocessing.Pipe.__qualname__.__len__()==16 ('BaseContext.Pipe': 'BaseContext.'=12+'Pipe'=4=16) — one char shorter because 'Pipe' is 4 chars vs 'Queue' is 5 chars; other context factory qualnames: Manager=19 ('BaseContext.'=12+'Manager'=7=19), JoinableQueue=25 ('BaseContext.'=12+'JoinableQueue'=13=25); Queue at 17 falls between Pipe=16 and Manager=19; NEW in extra122: first standalone multiprocessing.Queue qualname length invariant in mpqueues122 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Queue.__qualname__.__len__
  args: []
  expected: 17

invariant multiprocessing_extra122.mp_queues_Queue_mro_len_2:
  description: "multiprocessing.queues.Queue.__mro__.__len__() == 2 — multiprocessing.queues.Queue.__mro__ is [Queue, object] (2 elements); Queue is a direct subclass of object with no intermediate base classes; this minimal 2-element MRO contrasts with JoinableQueue.__mro__.__len__()==3 ([JoinableQueue, Queue, object]) which adds Queue between itself and object; multiprocessing.queues.Queue.__module__ is 'multiprocessing.queues' (the actual class, not the context factory); multiprocessing.queues.Queue.__class__.__name__ is 'type' (a real class, unlike the bound method at multiprocessing.Queue); compare: multiprocessing.queues.SimpleQueue.__mro__.__len__()==2 (also a direct object subclass); NEW in extra122: first standalone multiprocessing.queues.Queue MRO length invariant in mpqueues122 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.Queue.__mro__.__len__"
  args: []
  expected: 2

invariant multiprocessing_extra122.mp_queues_Queue_cancel_join_thread_qualname_len_24:
  description: "multiprocessing.queues.Queue.cancel_join_thread.__qualname__.__len__() == 24 — Queue.cancel_join_thread.__qualname__ is 'Queue.cancel_join_thread' (24 chars: 'Queue.'=6+'cancel_join_thread'=18); this is the longest Queue method qualname in this spec and the longest multiprocessing.queues method qualname overall; compare Queue method qualname lengths: get=9, put=9, empty=11, qsize=11, close=11, get_nowait=16, put_nowait=16, join_thread=17, cancel_join_thread=24; cancel_join_thread() prevents the queue's background feeder thread from being joined at process exit — if a child process has put items that have not been flushed, this method allows the child to terminate without waiting; NEW in extra122: first standalone cancel_join_thread qualname length invariant in mpqueues122 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.Queue.cancel_join_thread.__qualname__.__len__"
  args: []
  expected: 24

invariant multiprocessing_extra122.mp_JoinableQueue_task_done_qualname_len_23:
  description: "multiprocessing.queues.JoinableQueue.task_done.__qualname__.__len__() == 23 — JoinableQueue.task_done.__qualname__ is 'JoinableQueue.task_done' (23 chars: 'JoinableQueue.'=14+'task_done'=9); this is the longest JoinableQueue-specific method qualname; compare JoinableQueue method qualname lengths: join=18, task_done=23; compare with inherited Queue.cancel_join_thread=24 (one longer); JoinableQueue inherits cancel_join_thread, get_nowait, put_nowait, join_thread, etc. from Queue; task_done() signals that the item obtained from the queue has been fully processed — it is called by consumer threads to indicate work is complete; JoinableQueue.task_done.__qualname__ uses 'JoinableQueue.' prefix (14 chars) vs 'Queue.' prefix (6 chars), so despite 'task_done' being shorter than 'cancel_join_thread', the longer class prefix makes JoinableQueue.task_done=23 close to Queue.cancel_join_thread=24; NEW in extra122: first standalone JoinableQueue.task_done qualname length invariant in mpqueues122 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.JoinableQueue.task_done.__qualname__.__len__"
  args: []
  expected: 23

