# multiprocessing.queues.Queue.get.__qualname__            == 'Queue.get'             (len=9)
# multiprocessing.queues.Queue.put.__qualname__            == 'Queue.put'             (len=9)
# multiprocessing.queues.Queue.join_thread.__qualname__    == 'Queue.join_thread'     (len=17)
# multiprocessing.queues.Queue.cancel_join_thread.__qualname__ == 'Queue.cancel_join_thread' (len=24)
# ---------------------------------------------------------------------------

table multiprocessing_extra122.mp_queues_queue_method_qualnames:
  description: "multiprocessing.queues.Queue class identity and method __qualname__ checks in mpqueues122 namespace — wave 255 theme: multiprocessing.queues.Queue is a real Python class (not a bound method like multiprocessing.Queue factory); multiprocessing.queues.Queue.__class__.__name__.__eq__('type')==True (it is a class); multiprocessing.queues.Queue.__name__.__eq__('Queue')==True (len=5); multiprocessing.queues.Queue.__module__.__eq__('multiprocessing.queues')==True; multiprocessing.queues.Queue.__mro__.__len__()==2 ([Queue, object] — direct subclass of object); Queue.get.__qualname__.__eq__('Queue.get')==True (len=9: 'Queue.'=6+'get'=3, shortest); Queue.put.__qualname__.__eq__('Queue.put')==True (len=9, same as get); Queue.join_thread.__qualname__.__eq__('Queue.join_thread')==True (len=17: 'Queue.'=6+'join_thread'=11); Queue.cancel_join_thread.__qualname__.__eq__('Queue.cancel_join_thread')==True (len=24: 'Queue.'=6+'cancel_join_thread'=18, the longest Queue method qualname — cancel_join_thread prevents the background thread that flushes enqueued data from being joined at exit); all Queue methods have class='function' (pure-Python in queues.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpqueues122a

  columns: [id, function, args, expected, description]
  rows:
    - [qq_cls,      "multiprocessing.queues.Queue.__class__.__name__.__eq__",            ["type"],                      true, "multiprocessing.queues.Queue.__class__.__name__ == 'type' (real Python class, not bound method); verified with Python 3.14.3"]
    - [qq_name_eq,  "multiprocessing.queues.Queue.__name__.__eq__",                      ["Queue"],                     true, "multiprocessing.queues.Queue.__name__ == 'Queue' (len=5); verified with Python 3.14.3"]
    - [qq_mod_eq,   "multiprocessing.queues.Queue.__module__.__eq__",                    ["multiprocessing.queues"],    true, "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues'; verified with Python 3.14.3"]
    - [qq_mro_len,  "multiprocessing.queues.Queue.__mro__.__len__",                      [],                            2,    "multiprocessing.queues.Queue.__mro__.__len__() == 2 ([Queue, object]); verified with Python 3.14.3"]
    - [qq_get_qeq,  "multiprocessing.queues.Queue.get.__qualname__.__eq__",              ["Queue.get"],                 true, "Queue.get.__qualname__ == 'Queue.get' (len=9, shortest method qualname); verified with Python 3.14.3"]
    - [qq_get_qlen, "multiprocessing.queues.Queue.get.__qualname__.__len__",             [],                            9,    "Queue.get.__qualname__.__len__() == 9 ('Queue.'=6+'get'=3); verified with Python 3.14.3"]
    - [qq_put_qeq,  "multiprocessing.queues.Queue.put.__qualname__.__eq__",              ["Queue.put"],                 true, "Queue.put.__qualname__ == 'Queue.put' (len=9, tied with get); verified with Python 3.14.3"]
    - [qq_jt_qeq,   "multiprocessing.queues.Queue.join_thread.__qualname__.__eq__",      ["Queue.join_thread"],         true, "Queue.join_thread.__qualname__ == 'Queue.join_thread' (len=17); verified with Python 3.14.3"]
    - [qq_jt_qlen,  "multiprocessing.queues.Queue.join_thread.__qualname__.__len__",     [],                            17,   "Queue.join_thread.__qualname__.__len__() == 17 ('Queue.'=6+'join_thread'=11); verified with Python 3.14.3"]
    - [qq_cjt_qeq,  "multiprocessing.queues.Queue.cancel_join_thread.__qualname__.__eq__", ["Queue.cancel_join_thread"], true, "Queue.cancel_join_thread.__qualname__ == 'Queue.cancel_join_thread' (len=24, longest Queue method qualname); verified with Python 3.14.3"]
    - [qq_cjt_qlen, "multiprocessing.queues.Queue.cancel_join_thread.__qualname__.__len__", [],                          24,   "Queue.cancel_join_thread.__qualname__.__len__() == 24 ('Queue.'=6+'cancel_join_thread'=18); verified with Python 3.14.3"]

