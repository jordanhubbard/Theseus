spec: io_extra37
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra34.zspec.zsdl — covers __module__.__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/BytesIO/StringIO; __name__.__len__() for same six classes"
    - "io_extra35.zspec.zsdl — covers __module__.__len__() and __name__.__len__() for FileIO/BufferedReader/BufferedWriter/TextIOWrapper; __qualname__.__len__() for all ten io classes"
    - "io_extra36.zspec.zsdl — covers __mro__.__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/StringIO/BytesIO; __bases__[0].__name__ for IOBase/RawIOBase/BufferedIOBase/TextIOBase; __qualname__.__len__() for BufferedReader/BufferedWriter/FileIO methods"
  notes:
    - "This spec extends io_extra36.zspec.zsdl."
    - "Prior specs covered: all ten io class __name__/__module__/__qualname__, UnsupportedOperation attributes, io.open qualname, DEFAULT_BUFFER_SIZE, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for all ten classes, __mro__.__len__() for six classes, __bases__[0].__name__ for four abstract classes, method qualname lengths for BufferedReader/BufferedWriter/FileIO methods."
    - "This spec covers: io.__all__.__len__() and io.__all__.__class__.__name__; io.StringIO.__dict__.__class__.__name__.__len__()==12 for StringIO/BytesIO/IOBase/FileIO/RawIOBase/BufferedReader/TextIOWrapper; io.StringIO.__reduce__.__name__.__len__()==10 for StringIO/BytesIO/IOBase/FileIO; io.StringIO.__init_subclass__.__qualname__.__len__() for IOBase/StringIO/BytesIO/RawIOBase/FileIO/BufferedReader/BufferedWriter/TextIOWrapper; io.SEEK_SET value (0), SEEK_CUR (1), SEEK_END (2); io.DEFAULT_BUFFER_SIZE.__class__.__name__.__len__() (int=3)."
    - "io.__all__ has 24 entries (list). Verified Python 3.12."
    - "io.__all__.__class__.__name__ == 'list' — len('list') == 4. Verified Python 3.12."
    - "All io class __dict__.__class__.__name__ == 'mappingproxy' — len 12. Verified Python 3.12."
    - "io.StringIO.__reduce__.__name__ == '__reduce__' — len 10. Same for BytesIO/IOBase/FileIO. Verified Python 3.12."
    - "io.IOBase.__init_subclass__.__qualname__ == 'IOBase.__init_subclass__' — len 24. Verified Python 3.12."
    - "io.StringIO.__init_subclass__.__qualname__ == 'StringIO.__init_subclass__' — len 26. Verified Python 3.12."
    - "io.BytesIO.__init_subclass__.__qualname__ == 'BytesIO.__init_subclass__' — len 25. Verified Python 3.12."
    - "io.RawIOBase.__init_subclass__.__qualname__ == 'RawIOBase.__init_subclass__' — len 27. Verified Python 3.12."
    - "io.FileIO.__init_subclass__.__qualname__ == 'FileIO.__init_subclass__' — len 24. Verified Python 3.12."
    - "io.BufferedReader.__init_subclass__.__qualname__ == 'BufferedReader.__init_subclass__' — len 32. Verified Python 3.12."
    - "io.BufferedWriter.__init_subclass__.__qualname__ == 'BufferedWriter.__init_subclass__' — len 32. Verified Python 3.12."
    - "io.TextIOWrapper.__init_subclass__.__qualname__ == 'TextIOWrapper.__init_subclass__' — len 31. Verified Python 3.12."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2. Verified Python 3.12."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — len('int') == 3. Note: on macOS/Darwin 25.4.0 DEFAULT_BUFFER_SIZE == 131072 (not 8192). Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__all__.__len__() and __all__.__class__.__name__.__len__()
#
# io.__all__ is a list of 24 public names including BlockingIOError, open,
# open_code, IOBase, RawIOBase, FileIO, BytesIO, StringIO, BufferedIOBase,
# BufferedReader, BufferedWriter, BufferedRWPair, BufferedRandom, TextIOBase,
# TextIOWrapper, UnsupportedOperation, SEEK_SET, SEEK_CUR, SEEK_END,
# DEFAULT_BUFFER_SIZE, text_encoding, IncrementalNewlineDecoder, Reader, Writer.
# __all__.__class__.__name__ == 'list' (len 4).
# No prior io spec checks __all__.__len__() or __all__.__class__.__name__.
# ---------------------------------------------------------------------------

invariant io_extra37.all.len:
  description: "io.__all__.__len__() == 24 — twenty-four public names exported including all IO classes and SEEK_* constants"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 24

invariant io_extra37.all.class_name_len:
  description: "io.__all__.__class__.__name__.__len__() == 4 — __all__ is a list; len('list') == 4"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# SomeClass.__dict__.__class__.__name__.__len__() == 12 for io classes
#
# Every Python class exposes its namespace as a types.MappingProxyType whose
# __class__.__name__ is 'mappingproxy' (len 12). No prior io spec checks
# __dict__.__class__.__name__.__len__() for any io class.
# ---------------------------------------------------------------------------

table io_extra37.class_dict_proxy_name_len:
  description: "SomeClass.__dict__.__class__.__name__.__len__() == 12 for StringIO, BytesIO, IOBase, FileIO, RawIOBase, BufferedReader, TextIOWrapper — 'mappingproxy' has 12 characters"
  kind: python_call_eq
  category: class_introspection
  id_prefix: imp37

  columns: [id, function, args, expected]
  rows:
    - [StringIO,       StringIO.__dict__.__class__.__name__.__len__,       [], 12]
    - [BytesIO,        BytesIO.__dict__.__class__.__name__.__len__,        [], 12]
    - [IOBase,         IOBase.__dict__.__class__.__name__.__len__,         [], 12]
    - [FileIO,         FileIO.__dict__.__class__.__name__.__len__,         [], 12]
    - [RawIOBase,      RawIOBase.__dict__.__class__.__name__.__len__,      [], 12]
    - [BufferedReader, BufferedReader.__dict__.__class__.__name__.__len__, [], 12]
    - [TextIOWrapper,  TextIOWrapper.__dict__.__class__.__name__.__len__,  [], 12]

# ---------------------------------------------------------------------------
# SomeClass.__reduce__.__name__.__len__() == 10 for io classes
#
# '__reduce__' is 10 characters (2+6+2 dunder pair). This is the inherited
# slot wrapper from object. No prior io spec checks __reduce__.__name__ for
# any io class.
# ---------------------------------------------------------------------------

table io_extra37.class_reduce_name_len:
  description: "SomeClass.__reduce__.__name__.__len__() == 10 for StringIO, BytesIO, IOBase, FileIO — '__reduce__' has 10 characters"
  kind: python_call_eq
  category: class_introspection
  id_prefix: irn37

  columns: [id, function, args, expected]
  rows:
    - [StringIO, StringIO.__reduce__.__name__.__len__, [], 10]
    - [BytesIO,  BytesIO.__reduce__.__name__.__len__,  [], 10]
    - [IOBase,   IOBase.__reduce__.__name__.__len__,   [], 10]
    - [FileIO,   FileIO.__reduce__.__name__.__len__,   [], 10]

# ---------------------------------------------------------------------------
# SomeClass.__init_subclass__.__qualname__.__len__() for io classes
#
# __init_subclass__ qualname takes the form 'ClassName.__init_subclass__';
# length = len(class_name) + 18:
#   IOBase         -> 'IOBase.__init_subclass__'         -> 6  + 18 = 24
#   FileIO         -> 'FileIO.__init_subclass__'         -> 6  + 18 = 24
#   BytesIO        -> 'BytesIO.__init_subclass__'        -> 7  + 18 = 25
#   StringIO       -> 'StringIO.__init_subclass__'       -> 8  + 18 = 26
#   RawIOBase      -> 'RawIOBase.__init_subclass__'      -> 9  + 18 = 27
#   TextIOWrapper  -> 'TextIOWrapper.__init_subclass__'  -> 13 + 18 = 31
#   BufferedReader -> 'BufferedReader.__init_subclass__' -> 14 + 18 = 32
#   BufferedWriter -> 'BufferedWriter.__init_subclass__' -> 14 + 18 = 32
# No prior io spec checks __init_subclass__.__qualname__.__len__() for any io class.
# ---------------------------------------------------------------------------

invariant io_extra37.IOBase.init_subclass_qualname_len:
  description: "io.IOBase.__init_subclass__.__qualname__.__len__() == 24 — 'IOBase.__init_subclass__' has 24 characters"
  category: class_introspection
  kind: python_call_eq
  function: IOBase.__init_subclass__.__qualname__.__len__
  args: []
  expected: 24

invariant io_extra37.RawIOBase.init_subclass_qualname_len:
  description: "io.RawIOBase.__init_subclass__.__qualname__.__len__() == 27 — 'RawIOBase.__init_subclass__' has 27 characters"
  category: class_introspection
  kind: python_call_eq
  function: RawIOBase.__init_subclass__.__qualname__.__len__
  args: []
  expected: 27

table io_extra37.class_init_subclass_qualname_lens:
  description: "__init_subclass__.__qualname__.__len__() for FileIO (24), BytesIO (25), StringIO (26), TextIOWrapper (31), BufferedReader (32), BufferedWriter (32)"
  kind: python_call_eq
  category: class_introspection
  id_prefix: iis37

  columns: [id, function, args, expected]
  rows:
    - [FileIO,         FileIO.__init_subclass__.__qualname__.__len__,         [], 24]
    - [BytesIO,        BytesIO.__init_subclass__.__qualname__.__len__,        [], 25]
    - [StringIO,       StringIO.__init_subclass__.__qualname__.__len__,       [], 26]
    - [TextIOWrapper,  TextIOWrapper.__init_subclass__.__qualname__.__len__,  [], 31]
    - [BufferedReader, BufferedReader.__init_subclass__.__qualname__.__len__, [], 32]
    - [BufferedWriter, BufferedWriter.__init_subclass__.__qualname__.__len__, [], 32]

# ---------------------------------------------------------------------------
# io SEEK_* constants and DEFAULT_BUFFER_SIZE type name length
#
# SEEK_SET == 0, SEEK_CUR == 1, SEEK_END == 2 (standard POSIX values).
# DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' (len 3).
# No prior io spec checks SEEK_* values or DEFAULT_BUFFER_SIZE.__class__.__name__.__len__().
# ---------------------------------------------------------------------------

invariant io_extra37.SEEK_SET.value:
  description: "io.SEEK_SET == 0 — standard POSIX value for seeking from beginning of file"
  category: constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra37.DEFAULT_BUFFER_SIZE.class_name_len:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__.__len__() == 3 — DEFAULT_BUFFER_SIZE is an int; len('int') == 3"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__len__
  args: []
  expected: 3
