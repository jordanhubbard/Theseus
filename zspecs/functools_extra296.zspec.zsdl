spec: functools_extra296
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module class and function type descriptors"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py, Modules/_functoolsmodule.c"
  notes:
    - "functools.partial, cached_property, partialmethod, singledispatchmethod are Python types (class objects)"
    - "functools.lru_cache is a plain Python function"
    - "functools.reduce is a C builtin_function_or_method"
    - "functools.__spec__.name is 'functools' and __spec__.origin is a str path"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra296.class_names:
  description: "__class__.__name__ for functools callables and type objects"
  kind: python_call_eq
  category: identity
  id_prefix: fnc296

  columns: [id, function, args, expected, description]
  rows:
    - [fnc296_001, functools.partial.__class__.__name__.__eq__, ["type"], true, "functools.partial is a type"]
    - [fnc296_002, functools.cached_property.__class__.__name__.__eq__, ["type"], true, "functools.cached_property is a type"]
    - [fnc296_003, functools.partialmethod.__class__.__name__.__eq__, ["type"], true, "functools.partialmethod is a type"]
    - [fnc296_004, functools.singledispatchmethod.__class__.__name__.__eq__, ["type"], true, "functools.singledispatchmethod is a type"]
    - [fnc296_005, functools.lru_cache.__class__.__name__.__eq__, ["function"], true, "functools.lru_cache is a plain function"]
    - [fnc296_006, functools.reduce.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "functools.reduce is a C builtin"]

table functools_extra296.spec_attrs:
  description: "functools.__spec__ attribute identity"
  kind: python_call_eq
  category: identity
  id_prefix: fnc296s

  columns: [id, function, args, expected, description]
  rows:
    - [fnc296s_001, functools.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "__spec__ is a ModuleSpec"]
    - [fnc296s_002, functools.__spec__.name.__eq__, ["functools"], true, "__spec__.name is 'functools'"]
    - [fnc296s_003, functools.__spec__.origin.__class__.__name__.__eq__, ["str"], true, "__spec__.origin is a str path"]

invariant functools_extra296.inv_partial_is_type:
  description: "functools.partial.__class__.__name__ equals 'type'"
  category: identity
  kind: python_call_eq
  function: functools.partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra296.inv_lru_cache_is_function:
  description: "functools.lru_cache.__class__.__name__ equals 'function'"
  category: identity
  kind: python_call_eq
  function: functools.lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra296.inv_reduce_is_builtin:
  description: "functools.reduce.__class__.__name__ equals 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: functools.reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra296.inv_spec_name:
  description: "functools.__spec__.name equals 'functools'"
  category: identity
  kind: python_call_eq
  function: functools.__spec__.name.__eq__
  args: ["functools"]
  expected: true
