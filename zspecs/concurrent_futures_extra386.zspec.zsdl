spec: concurrent_futures_extra386
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "concurrent.futures._base.PENDING == 'PENDING'"
    - "concurrent.futures._base.RUNNING == 'RUNNING'"
    - "concurrent.futures._base.CANCELLED == 'CANCELLED'"
    - "concurrent.futures._base.FINISHED == 'FINISHED'"
    - "concurrent.futures._base.Error lives in module concurrent.futures._base and derives from Exception"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra386.state_constants:
  description: "Verify internal state string constants in concurrent.futures._base"
  kind: python_call_eq
  category: identity
  id_prefix: cf386c

  columns: [id, function, args, expected]
  rows:
    - [cf386c001, concurrent.futures._base.PENDING.__eq__, ["PENDING"], true]
    - [cf386c002, concurrent.futures._base.RUNNING.__eq__, ["RUNNING"], true]
    - [cf386c003, concurrent.futures._base.CANCELLED.__eq__, ["CANCELLED"], true]
    - [cf386c004, concurrent.futures._base.FINISHED.__eq__, ["FINISHED"], true]

table concurrent_futures_extra386.error_class_identity:
  description: "Verify __name__ and __module__ of concurrent.futures._base.Error"
  kind: python_call_eq
  category: identity
  id_prefix: cf386e

  columns: [id, function, args, expected]
  rows:
    - [cf386e001, concurrent.futures._base.Error.__name__.__eq__, ["Error"], true]
    - [cf386e002, concurrent.futures._base.Error.__module__.__eq__, ["concurrent.futures._base"], true]
    - ["cf386e003", "concurrent.futures._base.Error.__bases__[0].__name__.__eq__", ["Exception"], true]
