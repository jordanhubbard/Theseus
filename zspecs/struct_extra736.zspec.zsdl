spec: struct_extra736
version: ">=3.9"
backend: python_module(struct)
docs: "Behavioral spec covering struct.Struct method qualnames and top-level function docstrings."
error_model: python_exceptions

provenance:
  derived_from:
    - python_stdlib_struct
  not_derived_from: []
  notes: "Covers Struct class method qualnames and module-level function/exception doc attributes."
  created_at: "2026-04-12"

table struct_extra736.qualnames:
  description: "Verifies struct.Struct method qualnames and top-level struct function/exception docstrings."
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: st736xx
  columns: [id, function, args, expected]
  rows:
    - [st736xx001, struct.Struct.pack.__qualname__.__eq__, ["Struct.pack"], true]
    - [st736xx002, struct.Struct.unpack.__qualname__.__eq__, ["Struct.unpack"], true]
    - [st736xx003, struct.Struct.pack_into.__qualname__.__eq__, ["Struct.pack_into"], true]
    - [st736xx004, struct.Struct.unpack_from.__qualname__.__eq__, ["Struct.unpack_from"], true]
    - [st736xx005, struct.Struct.iter_unpack.__qualname__.__eq__, ["Struct.iter_unpack"], true]
    - [st736xx006, struct.Struct.__init__.__qualname__.__eq__, ["Struct.__init__"], true]
    - [st736xx007, struct.Struct.__repr__.__qualname__.__eq__, ["Struct.__repr__"], true]
    - [st736xx008, struct.Struct.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st736xx009, struct.pack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st736xx010, struct.unpack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st736xx011, struct.calcsize.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st736xx012, struct.error.__doc__.__class__.__name__.__eq__, ["str"], true]
