spec: pathlib_extra1501
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath, PurePosixPath, PureWindowsPath, Path documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "os.path source code"
  notes:
    - "Wave 547 (_extra1501): async protocol method __dict__ presence checks for pathlib module classes."
    - "All pathlib classes are synchronous only. None define __await__, __aiter__, __anext__, __aenter__, or __aexit__ in their own __dict__."
    - "pathlib.PurePath is the abstract base for pure path manipulation; it defines path component properties (name, parent, suffix, stem, parts) but no async protocol dunders."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath are platform-specific pure path subclasses with minimal own __dict__ entries (module, doc, parser, slots) and no async dunders."
    - "pathlib.Path is the concrete path class for file system operations; it defines file system methods (open, exists, stat) but no async protocol dunders."
    - "Async file I/O is available via aiofiles (third-party) or asyncio.to_thread(); neither the sync pathlib classes nor their instances implement the async protocol."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1501.purepath_async_protocol:
  description: "pathlib.PurePath async protocol absence — __await__, __aiter__, __anext__, __aenter__, __aexit__ are all absent from pathlib.PurePath.__dict__; positive anchors show path properties that ARE defined; wave 547; new to extra1501"
  kind: python_call_eq
  category: async_protocol
  id_prefix: pl1501pp
  columns: [id, function, args, expected, description]
  rows:
    - [pl1501pp001,
       pathlib.PurePath.__dict__.__contains__,
       ["__await__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__await__') == False — pathlib.PurePath is a pure path manipulation class; it does not implement the awaitable protocol; __await__ is absent from PurePath.__dict__; verified with Python 3.12"]
    - [pl1501pp002,
       pathlib.PurePath.__dict__.__contains__,
       ["__aiter__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__aiter__') == False — pathlib.PurePath does not implement the async iterator protocol; __aiter__ is absent; paths are not iterable in the async sense; verified with Python 3.12"]
    - [pl1501pp003,
       pathlib.PurePath.__dict__.__contains__,
       ["__anext__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__anext__') == False — pathlib.PurePath does not implement __anext__; async iteration is not part of the PurePath design; verified with Python 3.12"]
    - [pl1501pp004,
       pathlib.PurePath.__dict__.__contains__,
       ["__aenter__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__aenter__') == False — pathlib.PurePath does not implement the async context manager protocol; __aenter__ is absent; PurePath does not implement the sync context manager protocol either, so there is no async variant; verified with Python 3.12"]
    - [pl1501pp005,
       pathlib.PurePath.__dict__.__contains__,
       ["__aexit__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__aexit__') == False — pathlib.PurePath does not implement __aexit__; all five async protocol dunders are absent from PurePath.__dict__; verified with Python 3.12"]
    - [pl1501pp006,
       pathlib.PurePath.__dict__.__contains__,
       ["name"],
       true,
       "pathlib.PurePath.__dict__.__contains__('name') == True — positive anchor: PurePath defines 'name' (the final path component) as a property in its own __dict__; path component properties are present while all five async protocol dunders are absent; verified with Python 3.12"]
    - [pl1501pp007,
       pathlib.PurePath.__dict__.__contains__,
       ["parent"],
       true,
       "pathlib.PurePath.__dict__.__contains__('parent') == True — positive anchor: PurePath defines 'parent' as a property in its own __dict__; path hierarchy navigation is sync-only; no async equivalent exists in pathlib; verified with Python 3.12"]
    - [pl1501pp008,
       pathlib.PurePath.__dict__.__contains__,
       ["suffix"],
       true,
       "pathlib.PurePath.__dict__.__contains__('suffix') == True — positive anchor: PurePath defines 'suffix' (the file extension) as a property in its own __dict__; path extension parsing is a sync-only operation; verified with Python 3.12"]

table pathlib_extra1501.pureposixpath_purewindowspath_async_protocol:
  description: "pathlib.PurePosixPath and pathlib.PureWindowsPath async protocol absence — both platform-specific pure path subclasses lack all five async protocol dunders; wave 547; new to extra1501"
  kind: python_call_eq
  category: async_protocol
  id_prefix: pl1501pw
  columns: [id, function, args, expected, description]
  rows:
    - [pl1501pw001,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__await__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__await__') == False — PurePosixPath is the POSIX-specific pure path class; it does not define __await__ in its own __dict__; PurePosixPath's __dict__ contains only module, doc, parser, and slots metadata; verified with Python 3.12"]
    - [pl1501pw002,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__aiter__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__aiter__') == False — PurePosixPath does not define __aiter__; it is a thin subclass of PurePath adding POSIX-specific behavior; no async iteration support is added; verified with Python 3.12"]
    - [pl1501pw003,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__aenter__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__aenter__') == False — PurePosixPath does not implement the async context manager protocol; __aenter__ is absent from its own __dict__ and is not inherited from PurePath; verified with Python 3.12"]
    - [pl1501pw004,
       pathlib.PureWindowsPath.__dict__.__contains__,
       ["__await__"],
       false,
       "pathlib.PureWindowsPath.__dict__.__contains__('__await__') == False — PureWindowsPath is the Windows-specific pure path class; it does not define __await__ in its own __dict__; its __dict__ mirrors PurePosixPath's minimal set of metadata entries; verified with Python 3.12"]
    - [pl1501pw005,
       pathlib.PureWindowsPath.__dict__.__contains__,
       ["__aiter__"],
       false,
       "pathlib.PureWindowsPath.__dict__.__contains__('__aiter__') == False — PureWindowsPath does not define __aiter__; async path iteration is not provided by any pathlib class; verified with Python 3.12"]
    - [pl1501pw006,
       pathlib.PureWindowsPath.__dict__.__contains__,
       ["__aenter__"],
       false,
       "pathlib.PureWindowsPath.__dict__.__contains__('__aenter__') == False — PureWindowsPath does not implement __aenter__; the async context manager protocol is absent from both platform-specific pure path subclasses; verified with Python 3.12"]
    - [pl1501pw007,
       pathlib.PurePosixPath.__class__.__name__.__eq__,
       ["type"],
       true,
       "pathlib.PurePosixPath.__class__.__name__ == 'type' — positive anchor: PurePosixPath is a proper class object with metaclass type; this confirms it is a real class despite its minimal own __dict__ and absent async protocol; verified with Python 3.12"]
    - [pl1501pw008,
       pathlib.PureWindowsPath.__class__.__name__.__eq__,
       ["type"],
       true,
       "pathlib.PureWindowsPath.__class__.__name__ == 'type' — positive anchor: PureWindowsPath is a proper class object with metaclass type; verified with Python 3.12"]

table pathlib_extra1501.path_async_protocol:
  description: "pathlib.Path async protocol absence — Path defines no __await__, __aiter__, __anext__, __aenter__, or __aexit__ in its own __dict__; positive anchors show file system methods that ARE present; wave 547; new to extra1501"
  kind: python_call_eq
  category: async_protocol
  id_prefix: pl1501pt
  columns: [id, function, args, expected, description]
  rows:
    - [pl1501pt001,
       pathlib.Path.__dict__.__contains__,
       ["__await__"],
       false,
       "pathlib.Path.__dict__.__contains__('__await__') == False — pathlib.Path is the concrete path class for file system operations; despite performing I/O, Path is not awaitable; __await__ is absent from Path.__dict__; verified with Python 3.12"]
    - [pl1501pt002,
       pathlib.Path.__dict__.__contains__,
       ["__aiter__"],
       false,
       "pathlib.Path.__dict__.__contains__('__aiter__') == False — pathlib.Path does not implement __aiter__; Path.iterdir() and Path.glob() return synchronous generators, not async ones; verified with Python 3.12"]
    - [pl1501pt003,
       pathlib.Path.__dict__.__contains__,
       ["__anext__"],
       false,
       "pathlib.Path.__dict__.__contains__('__anext__') == False — pathlib.Path does not implement __anext__; there is no async next-item protocol for Path objects; verified with Python 3.12"]
    - [pl1501pt004,
       pathlib.Path.__dict__.__contains__,
       ["__aenter__"],
       false,
       "pathlib.Path.__dict__.__contains__('__aenter__') == False — pathlib.Path does not implement the async context manager protocol; __aenter__ is absent; 'async with pathlib.Path(...)' would raise AttributeError; async file I/O requires aiofiles or similar; verified with Python 3.12"]
    - [pl1501pt005,
       pathlib.Path.__dict__.__contains__,
       ["__aexit__"],
       false,
       "pathlib.Path.__dict__.__contains__('__aexit__') == False — pathlib.Path does not implement __aexit__; all five async protocol dunders are absent from Path.__dict__; verified with Python 3.12"]
    - [pl1501pt006,
       pathlib.Path.__dict__.__contains__,
       ["open"],
       true,
       "pathlib.Path.__dict__.__contains__('open') == True — positive anchor: Path defines 'open' in its own __dict__; Path.open() returns a sync file object (itself a context manager), but Path itself implements no async protocol; verified with Python 3.12"]
    - [pl1501pt007,
       pathlib.Path.__dict__.__contains__,
       ["exists"],
       true,
       "pathlib.Path.__dict__.__contains__('exists') == True — positive anchor: Path defines 'exists' in its own __dict__; file system query methods are sync-only; there is no async equivalent defined on Path itself; verified with Python 3.12"]
    - [pl1501pt008,
       pathlib.Path.__dict__.__contains__,
       ["stat"],
       true,
       "pathlib.Path.__dict__.__contains__('stat') == True — positive anchor: Path defines 'stat' in its own __dict__; synchronous stat() is defined while all five async protocol dunders (__await__, __aiter__, __anext__, __aenter__, __aexit__) are absent; verified with Python 3.12"]
