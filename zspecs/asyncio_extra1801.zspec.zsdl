spec: asyncio_extra1801
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value and context manager protocol dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra1801.truth_protocol:
  description: "asyncio types __bool__ and __len__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1801

  columns: [id, function, args, expected]
  rows:
    - ["as1801001", "asyncio.Future.__dict__.__contains__", ["__bool__"], false]
    - ["as1801002", "asyncio.Future.__dict__.__contains__", ["__len__"], false]
    - ["as1801003", "asyncio.Task.__dict__.__contains__", ["__bool__"], false]
    - ["as1801004", "asyncio.Task.__dict__.__contains__", ["__len__"], false]
    - ["as1801005", "asyncio.Queue.__dict__.__contains__", ["__bool__"], false]
    - ["as1801006", "asyncio.Queue.__dict__.__contains__", ["__len__"], false]
    - ["as1801007", "asyncio.Lock.__dict__.__contains__", ["__bool__"], false]
    - ["as1801008", "asyncio.Event.__dict__.__contains__", ["__bool__"], false]

table asyncio_extra1801.context_manager_protocol:
  description: "asyncio async context manager protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1801

  columns: [id, function, args, expected]
  rows:
    - ["as1801009", "asyncio.Lock.__dict__.__contains__", ["__aenter__"], true]
    - ["as1801010", "asyncio.Lock.__dict__.__contains__", ["__aexit__"], true]
    - ["as1801011", "asyncio.Lock.__dict__.__contains__", ["__enter__"], false]
    - ["as1801012", "asyncio.Lock.__dict__.__contains__", ["__exit__"], false]
    - ["as1801013", "asyncio.Condition.__dict__.__contains__", ["__aenter__"], true]
    - ["as1801014", "asyncio.Condition.__dict__.__contains__", ["__aexit__"], true]
    - ["as1801015", "asyncio.Semaphore.__dict__.__contains__", ["__aenter__"], true]
    - ["as1801016", "asyncio.Semaphore.__dict__.__contains__", ["__aexit__"], true]
    - ["as1801017", "asyncio.Queue.__dict__.__contains__", ["__aenter__"], false]
    - ["as1801018", "asyncio.Queue.__dict__.__contains__", ["__aexit__"], false]

table asyncio_extra1801.queue_container_protocol:
  description: "asyncio Queue container-like protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1801

  columns: [id, function, args, expected]
  rows:
    - ["as1801019", "asyncio.Queue.__dict__.__contains__", ["__contains__"], false]
    - ["as1801020", "asyncio.Queue.__dict__.__contains__", ["__getitem__"], false]
    - ["as1801021", "asyncio.Queue.__dict__.__contains__", ["__iter__"], false]
    - ["as1801022", "asyncio.Queue.__dict__.__contains__", ["qsize"], true]
    - ["as1801023", "asyncio.Queue.__dict__.__contains__", ["empty"], true]
    - ["as1801024", "asyncio.Queue.__dict__.__contains__", ["full"], true]
    - ["as1801025", "asyncio.Queue.__dict__.__contains__", ["put"], true]
    - ["as1801026", "asyncio.Queue.__dict__.__contains__", ["get"], true]
    - ["as1801027", "asyncio.Queue.__dict__.__contains__", ["put_nowait"], true]
    - ["as1801028", "asyncio.Queue.__dict__.__contains__", ["get_nowait"], true]
