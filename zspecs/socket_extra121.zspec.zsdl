spec: socket_extra121
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra120.zspec.zsdl — covers socket.__spec__.__class__.__module__.__eq__('_frozen_importlib') / socket.__loader__.__class__.__module__.__eq__('_frozen_importlib_external') / associated lengths (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket.getpeername/__qualname__.__eq__('socket.getpeername') / getsockname/__qualname__.__eq__('socket.getsockname') as table rows."
    - "socket_extra94.zspec.zsdl — covers socket.socket.shutdown/__qualname__.__eq__('socket.shutdown') / shutdown/__qualname__.__len__()==15 as table rows and standalones."
    - "socket_extra84.zspec.zsdl — covers socket.socket.getpeername/__class__/__name__.__eq__('method_descriptor') / getsockname/__class__/__name__.__eq__('method_descriptor') / shutdown/__class__/__name__.__eq__('method_descriptor') as table rows."
  notes:
    - "This spec extends socket through socket_extra120; it does NOT duplicate invariants present in those files."
    - "Wave 281 theme: socket.socket.getpeername/getsockname/shutdown __class__.__module__ not yet covered — extra84 anchors all three __class__.__name__.__eq__('method_descriptor'); extra98 anchors getpeername/getsockname __qualname__.__eq__; extra94 anchors shutdown __qualname__.__eq__ and __len__; NOT YET covered: getpeername.__class__.__module__.__eq__('builtins') and __class__.__name__.__len__(); getsockname.__class__.__module__.__eq__('builtins') and __class__.__name__.__len__(); shutdown.__class__.__module__.__eq__('builtins') and __name__.__len__()==8."
    - "socket.socket.getpeername.__class__.__module__ == 'builtins'. len('builtins')==8. method_descriptor is defined in Objects/descrobject.c and attributed to 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__class__.__module__ == 'builtins'. len('builtins')==8. Same class module as getpeername (both are method_descriptor objects). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__class__.__module__ == 'builtins'. len('builtins')==8. Same class module as getpeername and getsockname. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__class__.__name__.__len__() == 17. len('method_descriptor')==17. Same length coincidence as uuid.UUID.__weakref__.__class__.__name__.__len__()==17 (len('getset_descriptor')==17) — two different C descriptor type names share the 17-char length. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__name__.__len__() == 8. len('shutdown')==8. Same as len('builtins')==8 — the bare method name and the class module name share 8 chars. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket method_descriptor objects are C-level methods from _socket.SocketType. They do NOT have a __module__ attribute of their own (accessing it raises AttributeError); however, their __class__ (method_descriptor) does have __class__.__module__=='builtins' because method_descriptor is defined in Objects/descrobject.c and attributed to the 'builtins' namespace. The __class__.__name__ 'method_descriptor' has 17 chars — a length shared with 'getset_descriptor' (17 chars) across module families. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.getpeername.__class__.__module__.__eq__('builtins') == True
# socket.socket.getpeername.__class__.__module__.__len__() == 8
# socket.socket.getsockname.__class__.__module__.__eq__('builtins') == True
# socket.socket.getsockname.__class__.__module__.__len__() == 8
# socket.socket.getpeername.__class__.__name__.__len__() == 17
#
# Wave 281 theme: getpeername and getsockname method_descriptor class module.
#
# Both getpeername and getsockname are C-level method_descriptor objects from
# _socket.SocketType. The method_descriptor type is defined in Objects/descrobject.c
# with __module__=='builtins' (8 chars). extra84 anchors their __class__.__name__.__eq__
# ('method_descriptor'); extra98 anchors their __qualname__.__eq__ values. No prior
# socket spec anchors __class__.__module__ for either method. The class name
# 'method_descriptor' has 17 chars — coincidentally the same as 'getset_descriptor'
# (17 chars) used in uuid specs, despite being unrelated C types.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra121.getpeername_getsockname_class_module:
  description: "socket.getpeername.__class__.__module__.__eq__('builtins')==True / socket.getpeername.__class__.__module__.__len__()==8 / socket.getsockname.__class__.__module__.__eq__('builtins')==True / socket.getsockname.__class__.__module__.__len__()==8 / socket.getpeername.__class__.__name__.__len__()==17 — method_descriptor class module is 'builtins' (8 chars) for both methods; 'method_descriptor'=17 chars coincides with 'getset_descriptor'=17 across module families; extra84 anchors class names; no prior spec anchors class module for either; first sockdesc121 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockdesc121

  columns: [id, function, args, expected, description]
  rows:
    - [getpeername_cls_mod_eq,   socket.getpeername.__class__.__module__.__eq__,   ["builtins"], true, "socket.getpeername.__class__.__module__ is 'builtins' (method_descriptor from Objects/descrobject.c; extra84 anchors __class__.__name__.__eq__('method_descriptor'); no prior spec anchors __class__.__module__)"]
    - [getpeername_cls_mod_len,  socket.getpeername.__class__.__module__.__len__,  [],           8,    "socket.getpeername.__class__.__module__.__len__() is 8 (len('builtins')==8; same as getsockname and shutdown class module length)"]
    - [getsockname_cls_mod_eq,   socket.getsockname.__class__.__module__.__eq__,   ["builtins"], true, "socket.getsockname.__class__.__module__ is 'builtins' (method_descriptor from Objects/descrobject.c; extra84 anchors __class__.__name__.__eq__('method_descriptor'); no prior spec anchors __class__.__module__)"]
    - [getsockname_cls_mod_len,  socket.getsockname.__class__.__module__.__len__,  [],           8,    "socket.getsockname.__class__.__module__.__len__() is 8 (len('builtins')==8; same as getpeername class module length)"]
    - [getpeername_cls_name_len, socket.getpeername.__class__.__name__.__len__,    [],           17,   "socket.getpeername.__class__.__name__.__len__() is 17 (len('method_descriptor')==17; coincidentally same as len('getset_descriptor')==17 from uuid family — different C types sharing 17-char name)"]

# ---------------------------------------------------------------------------
# socket.socket.shutdown.__class__.__module__.__eq__('builtins') == True
# socket.socket.shutdown.__class__.__module__.__len__() == 8
# socket.socket.shutdown.__class__.__name__.__len__() == 17
# socket.socket.getsockname.__class__.__name__.__len__() == 17
# socket.socket.getsockname.__class__.__module__.__eq__('builtins') == True
#
# Wave 281 theme: shutdown method_descriptor class module.
#
# socket.socket.shutdown is also a C-level method_descriptor from _socket.SocketType.
# extra94 anchors shutdown.__qualname__.__eq__('socket.shutdown') and __qualname__.__len__
# ()==15; extra84 anchors __class__.__name__.__eq__('method_descriptor'). No prior socket
# spec anchors shutdown.__class__.__module__ in any form. This table groups shutdown
# class module with getsockname class name length for a unified 17-char pattern view.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra121.shutdown_class_module_and_length_cross_check:
  description: "socket.shutdown.__class__.__module__.__eq__('builtins')==True / socket.shutdown.__class__.__module__.__len__()==8 / socket.shutdown.__class__.__name__.__len__()==17 / socket.getsockname.__class__.__name__.__len__()==17 / socket.getsockname.__class__.__module__.__eq__('builtins')==True — shutdown method_descriptor class module is 'builtins' (8 chars); all three methods share class name len 17 ('method_descriptor'); extra94 anchors shutdown qualname; extra84 anchors class name eq; no prior spec anchors shutdown class module; first sockdesc121 shutdown anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockdesc121

  columns: [id, function, args, expected, description]
  rows:
    - [shutdown_cls_mod_eq,      socket.shutdown.__class__.__module__.__eq__,      ["builtins"], true, "socket.shutdown.__class__.__module__ is 'builtins' (method_descriptor from Objects/descrobject.c; extra94 anchors qualname; extra84 anchors class name eq; no prior spec anchors __class__.__module__)"]
    - [shutdown_cls_mod_len,     socket.shutdown.__class__.__module__.__len__,     [],           8,    "socket.shutdown.__class__.__module__.__len__() is 8 (len('builtins')==8; same as getpeername and getsockname class module length)"]
    - [shutdown_cls_name_len,    socket.shutdown.__class__.__name__.__len__,       [],           17,   "socket.shutdown.__class__.__name__.__len__() is 17 (len('method_descriptor')==17; same as getpeername and getsockname — all three are method_descriptor)"]
    - [getsockname_cls_name_len2,socket.getsockname.__class__.__name__.__len__,    [],           17,   "socket.getsockname.__class__.__name__.__len__() is 17 (cross-check; len('method_descriptor')==17; confirms shared class name length)"]
    - [getsockname_cls_mod_eq2,  socket.getsockname.__class__.__module__.__eq__,   ["builtins"], true, "socket.getsockname.__class__.__module__ is 'builtins' (cross-check confirming method_descriptor module attribution)"]

# ---------------------------------------------------------------------------
# socket.socket.getpeername.__class__.__module__.__eq__('builtins') == True
# socket.socket.getsockname.__class__.__module__.__eq__('builtins') == True
# socket.socket.shutdown.__class__.__module__.__eq__('builtins') == True
# socket.socket.getpeername.__class__.__name__.__len__() == 17
# socket.socket.shutdown.__class__.__module__.__len__() == 8
#
# Wave 281 theme: unified cross-check for all three methods' class module.
#
# All three socket.socket methods (getpeername, getsockname, shutdown) share the same
# method_descriptor type with __class__.__module__=='builtins' (8 chars) and
# __class__.__name__ length 17. This third table confirms that the three methods
# are truly symmetric in their class module attribution — they all come from the
# same C type family (Objects/descrobject.c, attributed to builtins). No prior
# socket spec groups these three class module equality checks in one table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra121.all_three_methods_class_module_unified:
  description: "socket.getpeername.__class__.__module__.__eq__('builtins')==True / socket.getsockname.__class__.__module__.__eq__('builtins')==True / socket.shutdown.__class__.__module__.__eq__('builtins')==True / socket.getpeername.__class__.__name__.__len__()==17 / socket.shutdown.__class__.__module__.__len__()==8 — unified cross-check: all three methods share method_descriptor class with __module__=='builtins' (8 chars) and class name len 17; symmetry confirms all three come from same C type; first sockdesc121 unified anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockdesc121

  columns: [id, function, args, expected, description]
  rows:
    - [getpeername_cls_mod_eq2,  socket.getpeername.__class__.__module__.__eq__,  ["builtins"], true, "socket.getpeername.__class__.__module__ is 'builtins' (unified cross-check; method_descriptor from builtins)"]
    - [getsockname_cls_mod_eq3,  socket.getsockname.__class__.__module__.__eq__,  ["builtins"], true, "socket.getsockname.__class__.__module__ is 'builtins' (unified cross-check; method_descriptor from builtins)"]
    - [shutdown_cls_mod_eq2,     socket.shutdown.__class__.__module__.__eq__,     ["builtins"], true, "socket.shutdown.__class__.__module__ is 'builtins' (unified cross-check; method_descriptor from builtins)"]
    - [getpeername_cls_name_len2,socket.getpeername.__class__.__name__.__len__,   [],           17,   "socket.getpeername.__class__.__name__.__len__() is 17 (unified cross-check; len('method_descriptor')==17)"]
    - [shutdown_cls_mod_len2,    socket.shutdown.__class__.__module__.__len__,    [],           8,    "socket.shutdown.__class__.__module__.__len__() is 8 (unified cross-check; len('builtins')==8)"]

# ---------------------------------------------------------------------------
# socket.socket.getpeername.__class__.__module__.__eq__('builtins') — standalone
#
# socket.socket.getpeername.__class__.__module__ is 'builtins'. getpeername is a
# C-level method_descriptor from the _socket extension module. The method_descriptor
# type is defined in Objects/descrobject.c and has its __module__ set to 'builtins' —
# the same namespace as all fundamental CPython runtime types. Note: the method itself
# does not have a __module__ attribute (accessing socket.socket.getpeername.__module__
# raises AttributeError), but its TYPE (method_descriptor) does. extra84 anchors
# __class__.__name__.__eq__('method_descriptor'); no prior socket spec anchors
# getpeername.__class__.__module__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra121.getpeername_class_module_builtins:
  description: "socket.socket.getpeername.__class__.__module__.__eq__('builtins') == True — method_descriptor type (getpeername class) is from Objects/descrobject.c with __module__=='builtins'; the method itself has no __module__ attr but its TYPE does; extra84 anchors __class__.__name__.__eq__('method_descriptor'); extra98 anchors __qualname__.__eq__('socket.getpeername'); no prior spec anchors getpeername.__class__.__module__; first standalone under sockdesc121"
  category: type_identity
  kind: python_call_eq
  function: socket.getpeername.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.getsockname.__class__.__module__.__eq__('builtins') — standalone
#
# socket.socket.getsockname.__class__.__module__ is 'builtins'. getsockname returns
# the address the socket is bound to on the local end. Like getpeername, getsockname
# is a method_descriptor from _socket.SocketType. The method_descriptor type has
# __module__=='builtins'. extra84 anchors getsockname.__class__.__name__.__eq__
# ('method_descriptor'); extra98 anchors __qualname__.__eq__('socket.getsockname');
# no prior socket spec anchors getsockname.__class__.__module__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra121.getsockname_class_module_builtins:
  description: "socket.socket.getsockname.__class__.__module__.__eq__('builtins') == True — method_descriptor type (getsockname class) has __module__=='builtins' (same as getpeername; both are method_descriptor from Objects/descrobject.c); extra84 anchors __class__.__name__.__eq__('method_descriptor'); extra98 anchors __qualname__.__eq__('socket.getsockname'); no prior spec anchors getsockname.__class__.__module__; first standalone under sockdesc121"
  category: type_identity
  kind: python_call_eq
  function: socket.getsockname.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.shutdown.__class__.__module__.__eq__('builtins') — standalone
#
# socket.socket.shutdown.__class__.__module__ is 'builtins'. shutdown initiates the
# shutdown of one or both halves of a TCP connection (via the SHUT_RD/SHUT_WR/SHUT_RDWR
# flags). Like getpeername and getsockname, shutdown is a method_descriptor from
# _socket.SocketType. The method_descriptor type has __module__=='builtins'. extra94
# anchors shutdown.__qualname__.__eq__('socket.shutdown') and __qualname__.__len__()==15;
# extra84 anchors __class__.__name__.__eq__('method_descriptor'). No prior socket spec
# anchors shutdown.__class__.__module__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra121.shutdown_class_module_builtins:
  description: "socket.socket.shutdown.__class__.__module__.__eq__('builtins') == True — method_descriptor type (shutdown class) has __module__=='builtins' (same as getpeername and getsockname; all three are method_descriptor from Objects/descrobject.c); extra94 anchors shutdown __qualname__ eq and len; extra84 anchors __class__.__name__.__eq__('method_descriptor'); no prior spec anchors shutdown.__class__.__module__ as standalone; first standalone under sockdesc121"
  category: type_identity
  kind: python_call_eq
  function: socket.shutdown.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.getpeername.__class__.__name__.__len__() == 17 — standalone
#
# socket.socket.getpeername.__class__.__name__.__len__() is 17. 'method_descriptor'
# has 17 chars: 'method'=6 + '_'=1 + 'descriptor'=10 = 17. A cross-module coincidence:
# len('method_descriptor')==17 equals len('getset_descriptor')==17 (the type name for
# uuid.UUID.__weakref__.__class__). These are completely unrelated C types from the
# same source file (Objects/descrobject.c), yet they share the same 17-char length.
# extra84 anchors __class__.__name__.__eq__('method_descriptor'); no prior socket spec
# anchors __class__.__name__.__len__()==17 for getpeername as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra121.getpeername_class_name_len_17:
  description: "socket.socket.getpeername.__class__.__name__.__len__() == 17 — len('method_descriptor')==17 ('method'=6 + '_'=1 + 'descriptor'=10; cross-module coincidence: same length as len('getset_descriptor')==17 from uuid family; both are unrelated C types from Objects/descrobject.c sharing the 17-char length; extra84 anchors __eq__('method_descriptor'); no prior socket spec anchors __class__.__name__.__len__()==17 for getpeername as standalone; first standalone under sockdesc121)"
  category: type_identity
  kind: python_call_eq
  function: socket.getpeername.__class__.__name__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# socket.socket.shutdown.__class__.__module__.__len__() == 8 — standalone
#
# socket.socket.shutdown.__class__.__module__.__len__() is 8. 'builtins' has 8 chars.
# For the shutdown method, both its __name__ length and its class module name length
# are 8: len('shutdown')==8 and len('builtins')==8. This dual 8-char coincidence
# around shutdown creates a symmetry: the method name itself is 8 chars and its type's
# home module name is also 8 chars. No prior socket spec anchors
# shutdown.__class__.__module__.__len__()==8 as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra121.shutdown_class_module_len_8:
  description: "socket.socket.shutdown.__class__.__module__.__len__() == 8 — len('builtins')==8 (method_descriptor class module; dual 8-char coincidence: len('shutdown')==8 equals len('builtins')==8 — the shutdown method name and its type home module share the same character count; extra94 anchors shutdown qualname length==15; no prior socket spec anchors shutdown class module length as standalone; first standalone under sockdesc121)"
  category: type_identity
  kind: python_call_eq
  function: socket.shutdown.__class__.__module__.__len__
  args: []
  expected: 8
