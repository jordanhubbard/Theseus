spec: sched_extra
version: ">=3.0"
backend: python_module(sched)

docs: https://docs.python.org/3/library/sched.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sched.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sched.py"
  notes:
    - "This spec covers identity and behavioral invariants not present in sched.zspec.zsdl."
    - "scheduler.__name__ == 'scheduler' and __module__ == 'sched'."
    - "Event is a namedtuple; Event.__name__ == 'Event' and __module__ == 'sched'."
    - "A freshly created scheduler().queue is a plain list; scheduler().empty() returns True."
    - "Event._fields is a tuple of field name strings."
    - "All expected values verified by running Python 3.14.3 sched module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name and module identity
# ---------------------------------------------------------------------------

invariant sched_extra.scheduler.name:
  description: "scheduler.__name__ == 'scheduler'"
  category: identity
  kind: python_call_eq
  function: scheduler.__name__.__eq__
  args: ["scheduler"]
  expected: true

invariant sched_extra.scheduler.module:
  description: "scheduler.__module__ == 'sched'"
  category: identity
  kind: python_call_eq
  function: scheduler.__module__.__eq__
  args: ["sched"]
  expected: true

invariant sched_extra.Event.name:
  description: "Event.__name__ == 'Event'"
  category: identity
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant sched_extra.Event.module:
  description: "Event.__module__ == 'sched'"
  category: identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["sched"]
  expected: true

# ---------------------------------------------------------------------------
# Freshly created scheduler — queue is a list, empty() returns True
# ---------------------------------------------------------------------------

invariant sched_extra.new_scheduler.queue_is_list:
  description: "scheduler().queue.__class__.__name__ == 'list' — queue attribute is a plain list"
  category: behavior
  kind: python_call_eq
  function: scheduler
  args: []
  method: queue.__class__.__name__.__eq__
  method_args: ["list"]
  expected: true

invariant sched_extra.new_scheduler.empty_true:
  description: "scheduler().empty() == True — freshly created scheduler has no pending events"
  category: behavior
  kind: python_call_eq
  function: scheduler
  args: []
  method: empty
  method_args: []
  expected: true

# ---------------------------------------------------------------------------
# Event._fields — tuple of field name strings
# ---------------------------------------------------------------------------

invariant sched_extra.Event.fields_is_tuple:
  description: "Event._fields.__class__.__name__ == 'tuple' — _fields is a tuple"
  category: behavior
  kind: python_call_eq
  function: Event._fields.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
