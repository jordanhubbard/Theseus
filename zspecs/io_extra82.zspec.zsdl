spec: io_extra82
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra81."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__ membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO lengths; BufferedReader/BufferedWriter/TextIOWrapper __dict__.__class__.__name__ and key method membership."
    - "io_extra81 covers BufferedReader/BufferedWriter/TextIOWrapper __dict__.__class__.__name__ == 'mappingproxy' and key method membership."
    - "This spec covers: BytesIO.__dict__.__class__.__name__ == 'mappingproxy'; BytesIO.__dict__.__contains__ for read/write/getvalue/seek; StringIO.__dict__.__class__.__name__ == 'mappingproxy'; StringIO.__dict__.__contains__ for read/write/getvalue; FileIO.__dict__.__class__.__name__ == 'mappingproxy'; FileIO.__dict__.__contains__ for read/readinto."
    - "io.BytesIO.__dict__.__class__.__name__ == 'mappingproxy' — C extension type __dict__ is always a mappingproxy."
    - "io.BytesIO.__dict__.__contains__('read') == True — BytesIO defines read() directly in C (_io extension)."
    - "io.BytesIO.__dict__.__contains__('write') == True — BytesIO defines write() directly in C."
    - "io.BytesIO.__dict__.__contains__('getvalue') == True — BytesIO defines getvalue() directly in C."
    - "io.BytesIO.__dict__.__contains__('seek') == True — BytesIO defines seek() directly in C."
    - "io.StringIO.__dict__.__class__.__name__ == 'mappingproxy' — C extension type __dict__ is always a mappingproxy."
    - "io.StringIO.__dict__.__contains__('read') == True — StringIO defines read() directly in C."
    - "io.StringIO.__dict__.__contains__('write') == True — StringIO defines write() directly in C."
    - "io.StringIO.__dict__.__contains__('getvalue') == True — StringIO defines getvalue() directly in C."
    - "io.FileIO.__dict__.__class__.__name__ == 'mappingproxy' — C extension type __dict__ is always a mappingproxy."
    - "io.FileIO.__dict__.__contains__('read') == True — FileIO defines read() directly in C."
    - "io.FileIO.__dict__.__contains__('readinto') == True — FileIO defines readinto() directly in C."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BytesIO __dict__ class name
# BytesIO is a C extension type; its __dict__ attribute is a mappingproxy.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra82.BytesIO_dict_class:
  description: "BytesIO.__dict__.__class__.__name__ == 'mappingproxy'"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore82

  columns: [id, function, args, expected]
  rows:
    - [bio_dict_cls, BytesIO.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# BytesIO __dict__ membership for key methods
# BytesIO defines read(), write(), getvalue(), and seek() directly in C.
# Verified: each key is present in io.BytesIO.__dict__.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra82.BytesIO_dict_contains:
  description: "BytesIO.__dict__ contains read, write, getvalue, seek"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore82

  columns: [id, function, args, expected]
  rows:
    - [bio_has_read,     "BytesIO.__dict__.__contains__", ["read"],     true]
    - [bio_has_write,    "BytesIO.__dict__.__contains__", ["write"],    true]
    - [bio_has_getvalue, "BytesIO.__dict__.__contains__", ["getvalue"], true]
    - [bio_has_seek,     "BytesIO.__dict__.__contains__", ["seek"],     true]

# ---------------------------------------------------------------------------
# StringIO __dict__ class name and membership
# StringIO is a C extension type; its __dict__ is a mappingproxy.
# read(), write(), and getvalue() are defined directly in the C StringIO type.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra82.StringIO_dict_class_and_contains:
  description: "StringIO.__dict__.__class__.__name__ and key method membership"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore82

  columns: [id, function, args, expected]
  rows:
    - [sio_dict_cls,    StringIO.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [sio_has_read,    "StringIO.__dict__.__contains__",            ["read"],         true]
    - [sio_has_write,   "StringIO.__dict__.__contains__",            ["write"],        true]
    - [sio_has_getvalue,"StringIO.__dict__.__contains__",            ["getvalue"],     true]

# ---------------------------------------------------------------------------
# FileIO __dict__ class name and membership
# FileIO is a C extension type; its __dict__ is a mappingproxy.
# read() and readinto() are defined directly in the C FileIO type.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra82.FileIO_dict_class_and_contains:
  description: "FileIO.__dict__.__class__.__name__ and key method membership"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore82

  columns: [id, function, args, expected]
  rows:
    - [fio_dict_cls,      FileIO.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [fio_has_read,      "FileIO.__dict__.__contains__",            ["read"],         true]
    - [fio_has_readinto,  "FileIO.__dict__.__contains__",            ["readinto"],     true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra82.BytesIO_dict_class:
  description: "io.BytesIO.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: BytesIO.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant io_extra82.BytesIO_dict.has_getvalue:
  description: "io.BytesIO.__dict__.__contains__('getvalue') == True"
  category: class_dict
  kind: python_call_eq
  function: "BytesIO.__dict__.__contains__"
  args: ["getvalue"]
  expected: true

invariant io_extra82.BytesIO_dict.has_seek:
  description: "io.BytesIO.__dict__.__contains__('seek') == True"
  category: class_dict
  kind: python_call_eq
  function: "BytesIO.__dict__.__contains__"
  args: ["seek"]
  expected: true

invariant io_extra82.StringIO_dict_class:
  description: "io.StringIO.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: StringIO.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant io_extra82.FileIO_dict.has_readinto:
  description: "io.FileIO.__dict__.__contains__('readinto') == True"
  category: class_dict
  kind: python_call_eq
  function: "FileIO.__dict__.__contains__"
  args: ["readinto"]
  expected: true
