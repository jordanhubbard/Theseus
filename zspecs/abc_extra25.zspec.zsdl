spec: abc_extra25
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra24.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token, abstractproperty lengths, ABCMeta.register/__name__/__qualname__ lengths, ABCMeta.__new__/__instancecheck__ __qualname__.__len__(), __mro__.__len__() for ABCMeta/ABC, ABC.__slots__.__class__.__name__.__len__() == 5, ABC.__abstractmethods__.__len__() == 0, abstractmethod/__qualname__.__len__() == 14, get_cache_token/__qualname__.__len__() == 15, ABCMeta.__mro__.__len__() == 3, ABC/__ABCMeta __bases__[0].__name__.__len__()."
    - "This spec covers: __dict__.__class__.__name__.__len__() for ABC (mappingproxy=12) and ABCMeta (mappingproxy=12); ABCMeta.__subclasscheck__.__qualname__.__len__() (25); ABCMeta.__qualname__.__len__() and __module__.__len__() and __name__.__len__() as standalones; ABC.__abstractmethods__.__class__.__name__.__len__() (frozenset=9); update_abstractmethods.__qualname__.__len__() (22) and __module__.__len__() (3); abc has no __all__ attribute."
    - "abc has no __all__ — unlike typing/types/weakref, the abc module does not define __all__; dir(abc) shows only 8 public names."
    - "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy' (length 12) — ABC is created via ABCMeta, so its namespace is a mappingproxy."
    - "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' (length 12) — ABCMeta is a C-augmented metaclass."
    - "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (length 25) — same length as ABCMeta.__instancecheck__.__qualname__ (extra24)."
    - "ABC.__abstractmethods__.__class__.__name__ == 'frozenset' (length 9) — the empty frozenset reports its class as 'frozenset'."
    - "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' (length 22) — a Python 3.10+ addition to the abc module."
    - "abc.ABCMeta.__qualname__ == 'ABCMeta' (length 7); abc.ABCMeta.__module__ == 'abc' (length 3)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() for ABC and ABCMeta
#
# Both abc.ABC and abc.ABCMeta carry their class __dict__ as a mappingproxy
# (length 12). ABC is constructed by ABCMeta (so its namespace is a
# mappingproxy), and ABCMeta is itself a C-augmented metaclass that also uses
# mappingproxy for its own class namespace. No prior abc spec records
# __dict__.__class__.__name__.__len__() for either class.
# ---------------------------------------------------------------------------

table abc_extra25.class_dict_type_lens:
  description: "__dict__.__class__.__name__.__len__() for ABC and ABCMeta — both are mappingproxy (12)"
  kind: python_call_eq
  category: dict_type_checks
  id_prefix: dict_class_name_len

  columns: [id, function, args, expected]
  rows:
    - [ABC,    ABC.__dict__.__class__.__name__.__len__,    [], 12]
    - [ABCMeta, ABCMeta.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for ABCMeta identity attributes
#
# ABCMeta.__qualname__ == 'ABCMeta' (length 7) — same as __name__. Extra24
# recorded ABCMeta.__name__.__len__() == 7 as a standalone; this table records
# __qualname__.__len__() and __module__.__len__() alongside it for completeness.
# ABCMeta.__module__ == 'abc' (length 3). No prior abc spec records these two
# as a table row alongside each other.
# ---------------------------------------------------------------------------

table abc_extra25.abcmeta_identity_lens:
  description: "ABCMeta identity attribute lengths — __qualname__ (7) and __module__ (3)"
  kind: python_call_eq
  category: identity_attr_lengths
  id_prefix: identity_len

  columns: [id, function, args, expected]
  rows:
    - [qualname_len, ABCMeta.__qualname__.__len__, [], 7]
    - [module_len,   ABCMeta.__module__.__len__,   [], 3]

# ---------------------------------------------------------------------------
# ABCMeta.__subclasscheck__ and update_abstractmethods qualname lengths
#
# ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (length
# 25): 7 (ABCMeta) + 1 (.) + 17 (__subclasscheck__) = 25. This matches
# ABCMeta.__instancecheck__ (also 25, from extra24). update_abstractmethods is
# a Python 3.10+ function; its __qualname__ == 'update_abstractmethods'
# (length 22). No prior abc spec records either of these qualname lengths.
# ---------------------------------------------------------------------------

table abc_extra25.method_and_function_qualname_lens:
  description: "ABCMeta.__subclasscheck__ qualname length (25) and update_abstractmethods qualname length (22)"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [ABCMeta_subclasscheck,      "ABCMeta.__subclasscheck__.__qualname__.__len__",  [], 25]
    - [update_abstractmethods,     update_abstractmethods.__qualname__.__len__,       [], 22]

# ---------------------------------------------------------------------------
# abc.ABC.__abstractmethods__.__class__.__name__.__len__() == 9 — standalone
#
# abc.ABC.__abstractmethods__ == frozenset() — an empty frozenset. Its class
# name is 'frozenset' (length 9). Extra24 recorded __abstractmethods__.__len__()
# == 0; this invariant adds the class name length, confirming the runtime type
# of the attribute is frozenset (9 characters) rather than set (3) or list (4).
# ---------------------------------------------------------------------------

invariant abc_extra25.ABC.abstractmethods_class_name_len:
  description: "abc.ABC.__abstractmethods__.__class__.__name__.__len__() == 9 — class name 'frozenset' has length 9; empty frozenset is the runtime type of __abstractmethods__"
  category: type_checks
  kind: python_call_eq
  function: ABC.__abstractmethods__.__class__.__name__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 — standalone
#
# 'ABCMeta.__subclasscheck__' has 25 characters: 7 (ABCMeta) + 1 (.) +
# 17 (__subclasscheck__) = 25. This matches ABCMeta.__instancecheck__'s
# qualname length (also 25, from extra24). The two ABCMeta protocol methods
# __instancecheck__ and __subclasscheck__ are symmetric in both structure and
# qualname length.
# ---------------------------------------------------------------------------

invariant abc_extra25.ABCMeta.subclasscheck_qualname_len:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 — 'ABCMeta.__subclasscheck__' is 7 + 1 + 17 = 25 characters; symmetric with __instancecheck__ (also 25)"
  category: method_qualname_lengths
  kind: python_call_eq
  function: "ABCMeta.__subclasscheck__.__qualname__.__len__"
  args: []
  expected: 25

# ---------------------------------------------------------------------------
# abc.update_abstractmethods.__qualname__.__len__() == 22 — standalone
#
# abc.update_abstractmethods is a Python 3.10+ function. Its __qualname__ ==
# 'update_abstractmethods' (length 22). This is the longest qualname among all
# top-level abc names: longer than get_cache_token (15), abstractmethod (14),
# and ABCMeta (7). No prior abc spec records this qualname length.
# ---------------------------------------------------------------------------

invariant abc_extra25.update_abstractmethods.qualname_len:
  description: "abc.update_abstractmethods.__qualname__.__len__() == 22 — 'update_abstractmethods' has length 22; the longest qualname among top-level abc names"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: update_abstractmethods.__qualname__.__len__
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# abc.ABC.__dict__.__class__.__name__.__len__() == 12 — standalone
#
# abc.ABC.__dict__.__class__.__name__ == 'mappingproxy' (length 12). Extra24
# recorded ABC.__slots__.__class__.__name__.__len__() == 5 (the slots tuple
# type); this invariant closes the parallel gap for the class __dict__ type.
# ABC's namespace is a mappingproxy because ABCMeta (a metaclass) constructs it.
# ---------------------------------------------------------------------------

invariant abc_extra25.ABC.dict_class_name_len:
  description: "abc.ABC.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has length 12; ABC's namespace is a mappingproxy (constructed by ABCMeta)"
  category: dict_type_checks
  kind: python_call_eq
  function: ABC.__dict__.__class__.__name__.__len__
  args: []
  expected: 12
