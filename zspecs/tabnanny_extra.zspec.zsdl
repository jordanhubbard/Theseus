spec: tabnanny_extra
version: ">=3.9"
backend: python_module(tabnanny)

docs: https://docs.python.org/3/library/tabnanny.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tabnanny.html — Python tabnanny module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tabnanny.py"
  notes:
    - "This spec extends tabnanny.zspec.zsdl with additional identity and membership invariants not covered there."
    - "tabnanny.check.__name__ == 'check' and tabnanny.process_tokens.__name__ == 'process_tokens'."
    - "tabnanny.NannyNag.__name__ == 'NannyNag' and tabnanny.NannyNag.__module__ == 'tabnanny'."
    - "tabnanny.NannyNag.__bases__[0].__name__ == 'Exception' — NannyNag is a direct subclass of Exception."
    - "tabnanny.verbose is a module-level int (default 0); tabnanny.filename_only is also a module-level int (default 0)."
    - "tabnanny.NannyNag.get_lineno, get_msg, and get_filename are all instance methods of NannyNag."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name attributes
# ---------------------------------------------------------------------------

invariant tabnanny_extra.names.check:
  description: "tabnanny.check.__name__ == 'check'"
  category: names
  kind: python_call_eq
  function: check.__name__.__eq__
  args: ["check"]
  expected: true

invariant tabnanny_extra.names.process_tokens:
  description: "tabnanny.process_tokens.__name__ == 'process_tokens'"
  category: names
  kind: python_call_eq
  function: process_tokens.__name__.__eq__
  args: ["process_tokens"]
  expected: true

# ---------------------------------------------------------------------------
# NannyNag class name and module affiliation
# ---------------------------------------------------------------------------

invariant tabnanny_extra.names.NannyNag:
  description: "tabnanny.NannyNag.__name__ == 'NannyNag'"
  category: names
  kind: python_call_eq
  function: NannyNag.__name__.__eq__
  args: ["NannyNag"]
  expected: true

invariant tabnanny_extra.modules.NannyNag:
  description: "tabnanny.NannyNag.__module__ == 'tabnanny'"
  category: modules
  kind: python_call_eq
  function: NannyNag.__module__.__eq__
  args: ["tabnanny"]
  expected: true

# ---------------------------------------------------------------------------
# NannyNag class hierarchy — base class is Exception
# ---------------------------------------------------------------------------

invariant tabnanny_extra.hierarchy.NannyNag_base:
  description: "tabnanny.NannyNag.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: NannyNag.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Module-level constants — verbose is an int
# ---------------------------------------------------------------------------

invariant tabnanny_extra.constants.verbose_is_int:
  description: "tabnanny.verbose.__class__.__name__ == 'int' — verbose flag is a module-level integer"
  category: constants
  kind: python_call_eq
  function: verbose.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tabnanny_extra.constants.verbose_default:
  description: "tabnanny.verbose == 0 — default verbose value is 0 (off)"
  category: constants
  kind: python_call_eq
  function: verbose.__eq__
  args: [0]
  expected: true

invariant tabnanny_extra.constants.filename_only_is_int:
  description: "tabnanny.filename_only.__class__.__name__ == 'int' — filename_only flag is a module-level integer"
  category: constants
  kind: python_call_eq
  function: filename_only.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tabnanny_extra.constants.filename_only_default:
  description: "tabnanny.filename_only == 0 — default filename_only value is 0 (off)"
  category: constants
  kind: python_call_eq
  function: filename_only.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# NannyNag method names
# ---------------------------------------------------------------------------

invariant tabnanny_extra.method_names.get_lineno:
  description: "tabnanny.NannyNag.get_lineno.__name__ == 'get_lineno'"
  category: method_names
  kind: python_call_eq
  function: NannyNag.get_lineno.__name__.__eq__
  args: ["get_lineno"]
  expected: true

invariant tabnanny_extra.method_names.get_msg:
  description: "tabnanny.NannyNag.get_msg.__name__ == 'get_msg'"
  category: method_names
  kind: python_call_eq
  function: NannyNag.get_msg.__name__.__eq__
  args: ["get_msg"]
  expected: true

invariant tabnanny_extra.method_names.get_filename:
  description: "tabnanny.NannyNag.get_filename.__name__ == 'get_filename'"
  category: method_names
  kind: python_call_eq
  function: NannyNag.get_filename.__name__.__eq__
  args: ["get_filename"]
  expected: true

# ---------------------------------------------------------------------------
# NannyNag is a type (class object)
# ---------------------------------------------------------------------------

invariant tabnanny_extra.names.NannyNag_is_type:
  description: "type(tabnanny.NannyNag).__name__ == 'type' — NannyNag is a class object"
  category: names
  kind: python_call_eq
  function: NannyNag.__class__.__name__.__eq__
  args: ["type"]
  expected: true
