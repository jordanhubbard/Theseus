spec: as3106
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (as3106): __lt__, __le__, __gt__ dict-presence for asyncio types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: asyncio.Task, asyncio.Future, asyncio.Queue, asyncio.Event, asyncio.Semaphore, asyncio.Lock, asyncio.Condition, asyncio.BoundedSemaphore, asyncio.Handle, asyncio.TimerHandle, asyncio.Timeout, asyncio.TaskGroup, asyncio.StreamReader, asyncio.StreamWriter."
    - "Key finding: asyncio.TimerHandle defines __lt__, __le__, and __gt__ in its own __dict__ (all true). These support priority-queue ordering in the event loop: smaller scheduled time = higher priority. Wave 653 (as3091) confirmed TimerHandle also defines __hash__ and __eq__."
    - "All other 13 asyncio classes return false for __lt__, __le__, and __gt__ — none define ordering comparison methods in their own __dict__; they inherit the default (NotImplemented) behavior from object."
    - "asyncio synchronization primitives (Lock, Semaphore, Condition, etc.) are not comparable by design; ordering them would have no meaningful semantics."
    - "asyncio.Task and asyncio.Future represent scheduled work items but are ordered in the event loop by other means (not by __lt__/__le__/__gt__)."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __lt__ dict-presence — operator.contains(Cls.__dict__, '__lt__')
#
# asyncio.TimerHandle: TRUE — defines __lt__ to support ordering of timer
#   callbacks in the event loop's min-heap scheduler. A handle with a smaller
#   scheduled time sorts before one with a larger time, so the earliest
#   callback fires first.
# All other asyncio classes: false — none define __lt__ in their own __dict__;
#   they rely on object's default which raises TypeError for comparisons.
# ---------------------------------------------------------------------------

table as3106.lt:
  description: "asyncio types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3106

  columns: [id, function, args, expected]
  rows:
    - ["as3106001", operator.contains, [asyncio.Task.__dict__,             "__lt__"], false]
    - ["as3106002", operator.contains, [asyncio.Future.__dict__,           "__lt__"], false]
    - ["as3106003", operator.contains, [asyncio.Queue.__dict__,            "__lt__"], false]
    - ["as3106004", operator.contains, [asyncio.Event.__dict__,            "__lt__"], false]
    - ["as3106005", operator.contains, [asyncio.Semaphore.__dict__,        "__lt__"], false]
    - ["as3106006", operator.contains, [asyncio.Lock.__dict__,             "__lt__"], false]
    - ["as3106007", operator.contains, [asyncio.Condition.__dict__,        "__lt__"], false]
    - ["as3106008", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__lt__"], false]
    - ["as3106009", operator.contains, [asyncio.Handle.__dict__,           "__lt__"], false]
    - ["as3106010", operator.contains, [asyncio.TimerHandle.__dict__,      "__lt__"], true]
    - ["as3106011", operator.contains, [asyncio.Timeout.__dict__,          "__lt__"], false]
    - ["as3106012", operator.contains, [asyncio.TaskGroup.__dict__,        "__lt__"], false]
    - ["as3106013", operator.contains, [asyncio.StreamReader.__dict__,     "__lt__"], false]
    - ["as3106014", operator.contains, [asyncio.StreamWriter.__dict__,     "__lt__"], false]

# ---------------------------------------------------------------------------
# __le__ dict-presence — operator.contains(Cls.__dict__, '__le__')
#
# asyncio.TimerHandle: TRUE — defines __le__ alongside __lt__ and __gt__ to
#   provide a complete ordering relation for timer callbacks. Python's heapq
#   module uses __lt__ primarily, but the full rich-comparison set is defined
#   for consistency and correctness.
# All other asyncio classes: false — none define __le__ in their own __dict__.
# ---------------------------------------------------------------------------

