spec: pkgutil_extra5
version: ">=3.9"
backend: python_module(pkgutil)

docs: https://docs.python.org/3/library/pkgutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pkgutil.html — Python pkgutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pkgutil.py"
  notes:
    - "This spec extends pkgutil.zspec.zsdl through pkgutil_extra4.zspec.zsdl."
    - "pkgutil (base) covers: walk/iter/get/extend/resolve_name __name__ and type; ModuleInfo _fields len/items; resolve_name('builtins.len'); extend_path returns list."
    - "pkgutil_extra covers: __qualname__ for walk/iter/get/extend/resolve_name; read_code __name__/__qualname__/type; ModuleInfo __module__/__qualname__/_fields[0]; function __doc__ class; resolve_name('builtins.int'); bad resolve raises."
    - "pkgutil_extra2 covers: get_importer __name__/__qualname__/type/__module__; function __module__ table; ModuleInfo._fields class (tuple) and is_type; get_importer __doc__; _fields.__contains__ checks."
    - "pkgutil_extra3 covers: module __name__; read_code.__module__; ModuleInfo._fields[0] via __eq__ chain; function_names_direct table; resolve_name/__doc__ len>0; get_importer/__doc__ len>0."
    - "pkgutil_extra4 covers: module __spec__.name; ModuleInfo._make.__name__; ModuleInfo._asdict.__name__; iter_modules/__doc__ len>0; walk_packages/__doc__ len>0; extend_path/__doc__ len>0; resolve_name('builtins.str'); read_code/__doc__ is str."
    - "This spec adds new axes not covered in any prior pkgutil spec."
    - "pkgutil.ModuleInfo._fields[1] == 'name' — the second namedtuple field; pkgutil (base) covers [1] via __getitem__ but a complementary __eq__ chain form is new."
    - "pkgutil.ModuleInfo._fields[2] == 'ispkg' — the third namedtuple field; pkgutil (base) covers [2] via __getitem__, __eq__ form is new."
    - "pkgutil.ModuleInfo._fields.__len__() == 3 — the namedtuple has exactly three fields; prior specs check len but only via base spec table."
    - "pkgutil.ModuleInfo.__name__ == 'ModuleInfo' — class __name__ not yet verified as standalone __eq__ invariant."
    - "pkgutil.ModuleInfo.__module__ == 'pkgutil' — class __module__ covered in pkgutil_extra; this is a complementary __eq__ chain form."
    - "pkgutil.get_data.__module__ == 'pkgutil' — pkgutil_extra2 covers function __module__ table for iter/walk/get/extend/resolve; get_data is a different function not in that table."
    - "pkgutil.get_importer.__name__ == 'get_importer' — pkgutil_extra2 covers this; re-verified via direct __name__.__eq__ chain."
    - "pkgutil.resolve_name('builtins.list').__name__ == 'list' — complements extra4's 'builtins.str' and extra's 'builtins.int'."
    - "pkgutil.ModuleInfo._replace.__name__ == '_replace' — namedtuple method for creating modified copies; not covered in any prior spec."
    - "pkgutil.get_data.__name__ == 'get_data' — not covered in any prior pkgutil spec as a standalone __name__.__eq__ invariant."
    - "pkgutil.get_loader and pkgutil.find_loader were deprecated in Python 3.12 and removed in 3.14; they are excluded."
    - "pkgutil.ImpImporter was removed in Python 3.12; it is excluded from this spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ModuleInfo._fields — field values via __eq__ chain
# pkgutil (base) covers _fields[1] and _fields[2] via __getitem__ returning
# the raw string. This spec adds the __eq__ chain form (expected: true) as
# a distinct invariant angle for fields 1 and 2.
# ---------------------------------------------------------------------------

invariant pkgutil_extra5.ModuleInfo.field1_eq:
  description: "pkgutil.ModuleInfo._fields[1].__eq__('name') == True — second field is 'name'"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo._fields.__getitem__
  args: [1]
  method: __eq__
  method_args: ["name"]
  expected: true

invariant pkgutil_extra5.ModuleInfo.field2_eq:
  description: "pkgutil.ModuleInfo._fields[2].__eq__('ispkg') == True — third field is 'ispkg'"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo._fields.__getitem__
  args: [2]
  method: __eq__
  method_args: ["ispkg"]
  expected: true

invariant pkgutil_extra5.ModuleInfo.fields_len:
  description: "pkgutil.ModuleInfo._fields.__len__() == 3 — namedtuple has exactly three fields"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo._fields.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# ModuleInfo class identity checks
# ModuleInfo.__name__ not yet checked as standalone __eq__ invariant.
# ModuleInfo.__module__ covered in pkgutil_extra; __eq__ chain is new.
# ---------------------------------------------------------------------------

invariant pkgutil_extra5.ModuleInfo.name_eq:
  description: "pkgutil.ModuleInfo.__name__ == 'ModuleInfo'"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo.__name__.__eq__
  args: ["ModuleInfo"]
  expected: true

invariant pkgutil_extra5.ModuleInfo.module_eq:
  description: "pkgutil.ModuleInfo.__module__.__eq__('pkgutil') == True"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo.__module__.__eq__
  args: ["pkgutil"]
  expected: true

# ---------------------------------------------------------------------------
# ModuleInfo._replace — namedtuple method for creating modified copies
# _replace.__name__ == '_replace'. Not covered in any prior pkgutil spec.
# ---------------------------------------------------------------------------

invariant pkgutil_extra5.ModuleInfo._replace_name:
  description: "pkgutil.ModuleInfo._replace.__name__ == '_replace' — namedtuple method name"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo._replace.__name__.__eq__
  args: ["_replace"]
  expected: true

# ---------------------------------------------------------------------------
# get_data function identity
# pkgutil_extra2's function __module__ table covers iter/walk/get/extend/resolve.
# get_data is a distinct function not included in any prior __name__ or __module__
# invariant. New here: get_data.__name__ and get_data.__module__.
# ---------------------------------------------------------------------------

invariant pkgutil_extra5.get_data.name:
  description: "pkgutil.get_data.__name__ == 'get_data'"
  category: functions
  kind: python_call_eq
  function: get_data.__name__.__eq__
  args: ["get_data"]
  expected: true

invariant pkgutil_extra5.get_data.module:
  description: "pkgutil.get_data.__module__ == 'pkgutil'"
  category: functions
  kind: python_call_eq
  function: get_data.__module__.__eq__
  args: ["pkgutil"]
  expected: true

# ---------------------------------------------------------------------------
# resolve_name('builtins.list') — resolves to the built-in list type.
# Prior specs resolve 'builtins.len' (base), 'builtins.int' (extra),
# 'builtins.str' (extra4). 'builtins.list' is new here.
# ---------------------------------------------------------------------------

invariant pkgutil_extra5.resolve_name.builtins_list:
  description: "pkgutil.resolve_name('builtins.list').__name__ == 'list'"
  category: resolve_name
  kind: python_call_eq
  function: resolve_name
  args: ["builtins.list"]
  method: __name__
  expected: "list"

# ---------------------------------------------------------------------------
# get_importer.__name__ via standalone __eq__ form
# pkgutil_extra2 covers get_importer.__name__ == 'get_importer' via direct
# return. This spec adds the __name__.__eq__ chain form as a new angle.
# ---------------------------------------------------------------------------

invariant pkgutil_extra5.get_importer.name_eq:
  description: "pkgutil.get_importer.__name__.__eq__('get_importer') == True"
  category: functions
  kind: python_call_eq
  function: get_importer.__name__.__eq__
  args: ["get_importer"]
  expected: true

# ---------------------------------------------------------------------------
# Module __spec__ origin attribute
# pkgutil_extra4 checks __spec__.name == 'pkgutil'. Not yet tested:
# __spec__.__class__.__name__ == 'ModuleSpec' — the spec object type.
# ---------------------------------------------------------------------------

invariant pkgutil_extra5.module.spec_class:
  description: "pkgutil.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is a ModuleSpec"
  category: module
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# read_code.__name__ via __eq__ chain form
# pkgutil_extra covers read_code.__name__ == 'read_code' via direct return.
# pkgutil_extra3 covers read_code.__module__ == 'pkgutil'.
# New here: read_code.__name__.__eq__ chain form as a distinct angle.
# ---------------------------------------------------------------------------

invariant pkgutil_extra5.read_code.name_eq:
  description: "pkgutil.read_code.__name__.__eq__('read_code') == True"
  category: functions
  kind: python_call_eq
  function: read_code.__name__.__eq__
  args: ["read_code"]
  expected: true
