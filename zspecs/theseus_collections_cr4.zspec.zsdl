spec: theseus_collections_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_collections_cr4)
blocks: collections

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html"
  notes:
    - "Clean-room extended collections utilities. Do NOT import collections."
    - "Counter.most_common(n): return n most common elements and their counts."
    - "Counter.update(iterable_or_mapping): add counts from iterable or mapping."
    - "Counter subtraction: Counter(a=3,b=1) - Counter(a=1) keeps positive counts."
    - "collections4_most_common(): Counter('aabbc').most_common(1)[0][0] is 'a' or 'b'."
    - "collections4_counter_update(): c=Counter({'a':2}); c.update({'a':1}); c['a'] == 3."
    - "collections4_counter_sub(): (Counter(a=3,b=1) - Counter(a=1))['a'] == 2."
    - "Zero-arg invariant signatures — def collections4_most_common(): return bool"
    - "most_common returns [(element, count)] sorted by count descending."
    - "Counter subtraction: only keeps elements with positive counts."
    - "Export: Counter, OrderedDict, defaultdict, deque, namedtuple, ChainMap."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_collections_cr4.most_common:
  description: "Counter('aabbc').most_common(1) returns the most frequent element"
  category: most_common
  kind: python_call_eq
  function: collections4_most_common
  args: []
  expected: true

invariant theseus_collections_cr4.counter_update:
  description: "Counter({'a':2}).update({'a':1}) -> c['a'] == 3"
  category: update
  kind: python_call_eq
  function: collections4_counter_update
  args: []
  expected: 3

invariant theseus_collections_cr4.counter_sub:
  description: "(Counter(a=3,b=1) - Counter(a=1))['a'] == 2"
  category: subtraction
  kind: python_call_eq
  function: collections4_counter_sub
  args: []
  expected: 2
