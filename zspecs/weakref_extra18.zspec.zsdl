spec: weakref_extra18
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref_extra17.zspec.zsdl."
    - "Focus: __qualname__.__len__() for weakref classes and functions — no prior weakref spec measures any qualname lengths."
    - "weakref_extra17 covers: WeakMethod __bases__/__len__/__module__/__mro__.__len__ standalone invariants; combined MRO length table for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize; WeakMethod.__name__ and WeakMethod.__qualname__ standalone invariants."
    - "weakref_extra15 covers: __qualname__.__eq__ combined table for ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize; __module__ table; ref.__bases__[0].__name__=='object'; proxy.__name__ standalone."
    - "weakref_extra10 covers __qualname__ for WeakValueDictionary/WeakSet/WeakKeyDictionary/finalize."
    - "weakref_extra5 covers ref.__qualname__ == 'weakref' (old) and proxy.__qualname__."
    - "weakref.ref.__qualname__ == 'ReferenceType' — the C type's internal qualname (13 chars)."
    - "weakref.WeakValueDictionary.__qualname__ == 'WeakValueDictionary' (19 chars)."
    - "weakref.WeakKeyDictionary.__qualname__ == 'WeakKeyDictionary' (17 chars)."
    - "weakref.WeakSet.__qualname__ == 'WeakSet' (7 chars)."
    - "weakref.finalize.__qualname__ == 'finalize' (8 chars)."
    - "weakref.proxy.__qualname__ == 'proxy' (5 chars) — C-level builtin callable."
    - "No prior weakref spec measures __qualname__.__len__() for any weakref class or function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for core weakref class types — table
# (weakref_extra18 namespace)
#
# No prior weakref spec measures __qualname__.__len__() for any weakref class.
# weakref_extra15 covers __qualname__.__eq__ for ref/WeakValueDictionary/
# WeakKeyDictionary/WeakSet/finalize in a combined table.
# This table measures the qualname string lengths for the same group.
#
# weakref.ref.__qualname__ == 'ReferenceType' (len 13)
# weakref.WeakValueDictionary.__qualname__ == 'WeakValueDictionary' (len 19)
# weakref.WeakKeyDictionary.__qualname__ == 'WeakKeyDictionary' (len 17)
# weakref.WeakSet.__qualname__ == 'WeakSet' (len 7)
# weakref.finalize.__qualname__ == 'finalize' (len 8)
# weakref.proxy.__qualname__ == 'proxy' (len 5)
# ---------------------------------------------------------------------------

table weakref_extra18.qualname_lens:
  description: "__qualname__.__len__() for core weakref class types and callables"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: qlen

  columns: [id, function, args, expected]
  rows:
    - [ref,                    ref.__qualname__.__len__,                    [], 13]
    - [WeakValueDictionary,    WeakValueDictionary.__qualname__.__len__,    [], 19]
    - [WeakKeyDictionary,      WeakKeyDictionary.__qualname__.__len__,      [], 17]
    - [WeakSet,                WeakSet.__qualname__.__len__,                [],  7]
    - [finalize,               finalize.__qualname__.__len__,               [],  8]
    - [proxy,                  proxy.__qualname__.__len__,                  [],  5]

# ---------------------------------------------------------------------------
# weakref.ref.__qualname__ == 'ReferenceType' — standalone invariant
# (weakref_extra18 namespace)
#
# weakref_extra15 covers ref.__qualname__.__eq__('ReferenceType') in a combined
# table in the extra15 namespace. Providing a standalone in the extra18 namespace.
# The C-level type is named 'ReferenceType' internally; ref is the Python alias.
# ---------------------------------------------------------------------------

invariant weakref_extra18.ref.qualname:
  description: "weakref.ref.__qualname__ == 'ReferenceType' — C-level type internal name"
  category: class_qualnames
  kind: python_call_eq
  function: ref.__qualname__.__eq__
  args: ["ReferenceType"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.proxy.__qualname__ == 'proxy' — standalone invariant
# (weakref_extra18 namespace)
#
# weakref_extra5 covers proxy.__qualname__ in the extra5 namespace.
# Providing a standalone in the extra18 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra18.proxy.qualname:
  description: "weakref.proxy.__qualname__ == 'proxy' — C-level builtin callable"
  category: class_qualnames
  kind: python_call_eq
  function: proxy.__qualname__.__eq__
  args: ["proxy"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.WeakSet.__qualname__ == 'WeakSet' — standalone invariant
# (weakref_extra18 namespace)
#
# weakref_extra15 covers WeakSet.__qualname__.__eq__ in a combined table.
# Providing a standalone in the extra18 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra18.WeakSet.qualname:
  description: "weakref.WeakSet.__qualname__ == 'WeakSet'"
  category: class_qualnames
  kind: python_call_eq
  function: WeakSet.__qualname__.__eq__
  args: ["WeakSet"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.finalize.__qualname__ == 'finalize' — standalone invariant
# (weakref_extra18 namespace)
#
# weakref_extra15 covers finalize.__qualname__.__eq__ in a combined table.
# Providing a standalone in the extra18 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra18.finalize.qualname:
  description: "weakref.finalize.__qualname__ == 'finalize'"
  category: class_qualnames
  kind: python_call_eq
  function: finalize.__qualname__.__eq__
  args: ["finalize"]
  expected: true
