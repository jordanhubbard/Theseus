spec: re_extra231
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module constant contracts — IGNORECASE, LOCALE, MULTILINE, DOTALL, UNICODE, VERBOSE integer values and alias equivalence."
    - "re.IGNORECASE == 2 — integer value of re.IGNORECASE is 2; RegexFlag enum; verified Python 3.14.3 macOS."
    - "re.LOCALE == 4 — integer value of re.LOCALE is 4; verified Python 3.14.3 macOS."
    - "re.MULTILINE == 8 — integer value of re.MULTILINE is 8; verified Python 3.14.3 macOS."
    - "re.DOTALL == 16 — integer value of re.DOTALL is 16; verified Python 3.14.3 macOS."
    - "re.UNICODE == 32 — integer value of re.UNICODE is 32; verified Python 3.14.3 macOS."
    - "re.VERBOSE == 64 — integer value of re.VERBOSE is 64; verified Python 3.14.3 macOS."
    - "re.I.__eq__(2) == True — re.I is the alias for re.IGNORECASE (value 2); verified Python 3.14.3 macOS."
    - "re.M.__eq__(8) == True — re.M is the alias for re.MULTILINE (value 8); verified Python 3.14.3 macOS."
    - "re.S.__eq__(16) == True — re.S is the alias for re.DOTALL (value 16); verified Python 3.14.3 macOS."
    - "re.X.__eq__(64) == True — re.X is the alias for re.VERBOSE (value 64); verified Python 3.14.3 macOS."
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — all flags are RegexFlag enum members; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module flag integer value contracts
# IGNORECASE=2, LOCALE=4, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64.
# All flags are RegexFlag enum members (IntFlag subclass).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra231.flag_values:
  description: "re module flag integer value contracts — IGNORECASE=2, LOCALE=4, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64; verified with Python 3.14.3"
  kind: python_call_eq
  category: constant
  id_prefix: reflagvals231

  columns: [id, function, args, expected]
  rows:
    - [ignorecase_val, IGNORECASE.__eq__, [2],  true]
    - [locale_val,     LOCALE.__eq__,     [4],  true]
    - [multiline_val,  MULTILINE.__eq__,  [8],  true]
    - [dotall_val,     DOTALL.__eq__,     [16], true]
    - [unicode_val,    UNICODE.__eq__,    [32], true]
    - [verbose_val,    VERBOSE.__eq__,    [64], true]

# ---------------------------------------------------------------------------
# re module short alias equivalence contracts
# re.I == re.IGNORECASE (2), re.M == re.MULTILINE (8),
# re.S == re.DOTALL (16), re.X == re.VERBOSE (64).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra231.flag_aliases:
  description: "re module short flag alias integer value contracts — I=2, M=8, S=16, X=64; verified with Python 3.14.3"
  kind: python_call_eq
  category: constant
  id_prefix: reflagaliases231

  columns: [id, function, args, expected]
  rows:
    - [i_alias_eq_2,  I.__eq__, [2],  true]
    - [m_alias_eq_8,  M.__eq__, [8],  true]
    - [s_alias_eq_16, S.__eq__, [16], true]
    - [x_alias_eq_64, X.__eq__, [64], true]

# ---------------------------------------------------------------------------
# re module flag class name contract
# All re flag constants are instances of RegexFlag (an IntFlag subclass).
# Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra231.IGNORECASE.class_name:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — IGNORECASE is a RegexFlag enum member (IntFlag subclass in Python 3.11+); verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra231.MULTILINE.class_name:
  description: "re.MULTILINE.__class__.__name__ == 'RegexFlag' — MULTILINE is a RegexFlag enum member; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: MULTILINE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra231.DOTALL.class_name:
  description: "re.DOTALL.__class__.__name__ == 'RegexFlag' — DOTALL is a RegexFlag enum member; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: DOTALL.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true
