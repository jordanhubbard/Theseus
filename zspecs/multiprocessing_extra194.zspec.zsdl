  args: ["_ConnectionBase.recv"]
  expected: true

invariant multiprocessing_extra194.mp_Client_name_eq:
  description: "multiprocessing.connection.Client.__name__.__eq__('Client') returns True — Client.__name__=='Client' (len=6: C(1)l(2)i(3)e(4)n(5)t(6)); Client is a module-level factory function — not a class — that creates and returns a Connection to a Listener at the given address; despite the capital-C name suggesting a class, type(Client).__name__ == 'function'; Client.__name__ (6) < Connection.__name__ (10) by 4; Client.__name__ (6) < Connection.__bases__[0].__name__ (15) by 9; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Client
  kind: python_call_eq
  function: multiprocessing.connection.Client.__name__.__eq__
  args: ["Client"]
  expected: true

invariant multiprocessing_extra194.mp_Client_module_eq:
  description: "multiprocessing.connection.Client.__module__.__eq__('multiprocessing.connection') returns True — Client.__module__=='multiprocessing.connection' (len=26); Client is defined in Lib/multiprocessing/connection.py alongside Connection, Listener, and Pipe(); Client.__module__ (26) == Connection.__module__ (26) — both Client and Connection share the same source module; Client.__module__ (26) > Client.__name__ (6) by 20; NEW in mpconnection194: completing 8-invariant coverage for multiprocessing.connection module identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Client
  kind: python_call_eq
