spec: multiprocessing_extra194
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#connection-objects

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#connection-objects — Python multiprocessing connection documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/connection.py"
  notes:
    - "multiprocessing.connection.Connection.__name__ == 'Connection' (len=10); the public Connection class for IPC via send/recv."
    - "multiprocessing.connection.Connection.__module__ == 'multiprocessing.connection' (len=26); defined in the connection submodule."
    - "multiprocessing.connection.Connection.__bases__[0].__name__ == '_ConnectionBase' (len=15); Connection inherits from the private _ConnectionBase class."
    - "multiprocessing.connection.Connection.__init__.__qualname__ == '_ConnectionBase.__init__' (len=24); __init__ is defined on the base class _ConnectionBase."
    - "multiprocessing.connection.Connection.send.__qualname__ == '_ConnectionBase.send' (len=20); send() is defined on _ConnectionBase."
    - "multiprocessing.connection.Connection.recv.__qualname__ == '_ConnectionBase.recv' (len=20); recv() is defined on _ConnectionBase."
    - "multiprocessing.connection.Client.__name__ == 'Client' (len=6); Client is a module-level function (not a class) that returns a Connection."
    - "multiprocessing.connection.Client.__module__ == 'multiprocessing.connection' (len=26); same module as Connection."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

