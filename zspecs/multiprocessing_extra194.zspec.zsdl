invariant multiprocessing_extra194.mp_Connection_name_eq:
  description: "multiprocessing.connection.Connection.__name__.__eq__('Connection') returns True — Connection.__name__=='Connection' (len=10: C(1)o(2)n(3)n(4)e(5)c(6)t(7)i(8)o(9)n(10)); Connection objects represent one endpoint of a bidirectional IPC pipe; they are created by multiprocessing.Pipe(), Listener.accept(), or Client(); Connection objects support sending and receiving Python objects via pickle as well as raw bytes; Connection.__name__ (10) > Client.__name__ (6) by 4; Connection.__name__ (10) < Connection.__bases__[0].__name__ (15: '_ConnectionBase') by 5; NEW in mpconnection194: first standalone Connection.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Connection
  kind: python_call_eq
  function: multiprocessing.connection.Connection.__name__.__eq__
  args: ["Connection"]
  expected: true

invariant multiprocessing_extra194.mp_Connection_module_eq:
  description: "multiprocessing.connection.Connection.__module__.__eq__('multiprocessing.connection') returns True — Connection.__module__=='multiprocessing.connection' (len=26: 'multiprocessing'=15+'.'=1+'connection'=10=26); defined in Lib/multiprocessing/connection.py; Connection.__module__ (26) == Client.__module__ (26) — both the Connection class and the Client function are in the same source file; Connection.__module__ (26) > Connection.__name__ (10) by 16 — the module path is much longer than the class name; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Connection
  kind: python_call_eq
  function: multiprocessing.connection.Connection.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true

invariant multiprocessing_extra194.mp_Connection_base_eq:
  description: "multiprocessing.connection.Connection.__bases__[0].__name__.__eq__('_ConnectionBase') returns True — Connection.__bases__[0].__name__=='_ConnectionBase' (len=15: '_ConnectionBase'=15: '_'=1+'Connection'=10+'Base'=4=15); _ConnectionBase is the private abstract base that implements the full send/recv/poll/fileno/close logic; the public Connection class simply inherits everything from _ConnectionBase; Connection.__bases__[0].__name__ (15) > Connection.__name__ (10) by 5 — the base class name is longer than the subclass name; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Connection
  kind: python_call_eq
  function: "multiprocessing.connection.Connection.__bases__[0].__name__.__eq__"
  args: ["_ConnectionBase"]
  expected: true

invariant multiprocessing_extra194.mp_Connection_init_qualname_eq:
  description: "multiprocessing.connection.Connection.__init__.__qualname__.__eq__('_ConnectionBase.__init__') returns True — Connection.__init__.__qualname__=='_ConnectionBase.__init__' (len=24: '_ConnectionBase'=15+'.'=1+'__init__'=8=24); __init__ is not defined on Connection itself but is inherited from _ConnectionBase; the qualname reflects the defining class, not the accessing class; Connection.__init__.__qualname__ (24) > Connection.send.__qualname__ (20) by 4; Connection.__init__.__qualname__ (24) > Connection.recv.__qualname__ (20) by 4; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Connection
  kind: python_call_eq
  function: multiprocessing.connection.Connection.__init__.__qualname__.__eq__
  args: ["_ConnectionBase.__init__"]
  expected: true

invariant multiprocessing_extra194.mp_Connection_send_qualname_eq:
  description: "multiprocessing.connection.Connection.send.__qualname__.__eq__('_ConnectionBase.send') returns True — Connection.send.__qualname__=='_ConnectionBase.send' (len=20: '_ConnectionBase'=15+'.'=1+'send'=4=20); send() serializes and sends an object to the other end of the connection using pickle; like __init__, send() is defined on _ConnectionBase and inherited; Connection.send.__qualname__ (20) == Connection.recv.__qualname__ (20) — send and recv both have 4-character names, so their qualnames have the same length; Connection.send.__qualname__ (20) < Connection.__init__.__qualname__ (24) by 4; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Connection
