  expected: true

invariant multiprocessing_extra194.mp_Connection_recv_qualname_eq:
  description: "multiprocessing.connection.Connection.recv.__qualname__.__eq__('_ConnectionBase.recv') returns True — Connection.recv.__qualname__=='_ConnectionBase.recv' (len=20: '_ConnectionBase'=15+'.'=1+'recv'=4=20); recv() receives and deserializes a Python object sent by the other end of the connection; like send(), recv() is defined on _ConnectionBase; Connection.recv.__qualname__ (20) == Connection.send.__qualname__ (20) — recv and send are both 4-char names; Connection.recv.__qualname__ (20) < Connection.__init__.__qualname__ (24) by 4; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Connection
