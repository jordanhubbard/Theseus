spec: mmap_extra6
version: ">=3.9"
backend: python_module(mmap)

docs: https://docs.python.org/3/library/mmap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mmap.html — Python mmap module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mmapmodule.c"
  notes:
    - "This spec extends mmap.zspec.zsdl and prior extras through mmap_extra5.zspec.zsdl."
    - "mmap.zspec.zsdl covers: mmap.__name__, error.__name__, ACCESS_READ/WRITE/COPY values, PAGESIZE/ALLOCATIONGRANULARITY type and positivity, PROT_READ/MAP_SHARED/MAP_PRIVATE is_int, method names (read/write/seek/tell/close/find/flush)."
    - "mmap_extra.zspec.zsdl covers: mmap.__module__/__qualname__, ACCESS_* class type, ALLOCATIONGRANULARITY positivity/ge_4096, error.__module__, extra method names (rfind/readline/read_byte/write_byte/move), read class type, PAGESIZE ge_4096."
    - "mmap_extra2.zspec.zsdl covers: ACCESS_NONE value/type, ACCESS_* ordering, mmap.__class__.__name__=='type', error base is Exception, PAGESIZE % 4096 == 0, read.__doc__ is str."
    - "mmap_extra3.zspec.zsdl covers: ACCESS_DEFAULT value/type, PROT_READ/PROT_WRITE values, MAP_SHARED/MAP_PRIVATE values, PAGESIZE==16384, method __qualname__ for seek/tell/close/find/flush."
    - "mmap_extra4.zspec.zsdl covers: method __qualname__ for read/write/rfind/readline/read_byte/write_byte/move; ALLOCATIONGRANULARITY % 4096 == 0; PROT_EXEC is_int; error.__qualname__; mmap class identity table."
    - "mmap_extra5.zspec.zsdl covers: MAP_ANON/MAP_ANONYMOUS values and types; PROT_EXEC value; MADV_* values and types; resize.__qualname__; ALLOCATIONGRANULARITY >= PAGESIZE."
    - "This spec adds: ACCESS_READ/__class__.__name__ as standalone invariant in extra6 namespace; ACCESS_WRITE/__class__.__name__ standalone; ACCESS_COPY/__class__.__name__ standalone; PROT_READ/__class__.__name__ standalone; PROT_WRITE/__class__.__name__ standalone; MAP_SHARED/__class__.__name__ standalone; ALLOCATIONGRANULARITY/__class__.__name__ standalone; ALLOCATIONGRANULARITY.__gt__(0) standalone; PAGESIZE/__class__.__name__ standalone; PAGESIZE.__gt__(0) standalone; mmap.__name__ standalone via __eq__ chain; mmap.__module__ standalone via __eq__ chain."
    - "ACCESS_READ.__class__.__name__ == 'int' — covered as table row in mmap_extra; here added as standalone invariant for individual traceability."
    - "PROT_READ and PROT_WRITE are POSIX-only (macOS, Linux); not present on Windows."
    - "MAP_SHARED is POSIX-only (macOS, Linux); not present on Windows."
    - "mmap.ALLOCATIONGRANULARITY > 0 is documented as always positive; value is 16384 on macOS."
    - "mmap.PAGESIZE > 0 is documented as always positive; value is 16384 on macOS."
    - "mmap.mmap.__name__ == 'mmap' — checked in mmap.zspec; extra6 adds standalone __eq__ chain form for cross-validation."
    - "mmap.mmap.__module__ == 'mmap' — checked in mmap_extra; extra6 adds standalone __eq__ chain form."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ACCESS_* constants — __class__.__name__ as standalone invariants
#
# mmap_extra covered ACCESS_READ/WRITE/COPY __class__.__name__ as table rows.
# This spec adds standalone invariants for each in the extra6 namespace for
# individual traceability.
# ---------------------------------------------------------------------------

invariant mmap_extra6.ACCESS_READ.class_name:
  description: "mmap.ACCESS_READ.__class__.__name__ == 'int' — access mode constant is an int"
  category: constants
  kind: python_call_eq
  function: ACCESS_READ.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant mmap_extra6.ACCESS_WRITE.class_name:
  description: "mmap.ACCESS_WRITE.__class__.__name__ == 'int' — access mode constant is an int"
  category: constants
  kind: python_call_eq
  function: ACCESS_WRITE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant mmap_extra6.ACCESS_COPY.class_name:
  description: "mmap.ACCESS_COPY.__class__.__name__ == 'int' — access mode constant is an int"
  category: constants
  kind: python_call_eq
  function: ACCESS_COPY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# PROT_READ and PROT_WRITE — __class__.__name__ as standalone invariants
#
# mmap.zspec.zsdl checks PROT_READ as is_int (via __class__.__name__.__eq__).
# This spec adds standalone invariants for PROT_READ and PROT_WRITE in the
# extra6 namespace. POSIX-only constants (macOS, Linux).
# ---------------------------------------------------------------------------

invariant mmap_extra6.PROT_READ.class_name:
  description: "mmap.PROT_READ.__class__.__name__ == 'int' — POSIX-only protection constant is an int"
  category: constants
  platform: posix
  kind: python_call_eq
  function: PROT_READ.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant mmap_extra6.PROT_WRITE.class_name:
  description: "mmap.PROT_WRITE.__class__.__name__ == 'int' — POSIX-only protection constant is an int"
  category: constants
  platform: posix
  kind: python_call_eq
  function: PROT_WRITE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# MAP_SHARED — __class__.__name__ as standalone invariant
#
# mmap.zspec.zsdl checks MAP_SHARED as is_int. This spec adds a standalone
# invariant in the extra6 namespace. POSIX-only (macOS, Linux).
# ---------------------------------------------------------------------------

invariant mmap_extra6.MAP_SHARED.class_name:
  description: "mmap.MAP_SHARED.__class__.__name__ == 'int' — POSIX-only mapping flag is an int"
  category: constants
  platform: posix
  kind: python_call_eq
  function: MAP_SHARED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# ALLOCATIONGRANULARITY — class name and positivity as standalone invariants
#
# mmap.zspec.zsdl checks allocationgranularity_is_int (via __class__.__name__).
# mmap_extra checks ALLOCATIONGRANULARITY > 0. This spec adds both as
# standalone invariants in the extra6 namespace.
# ---------------------------------------------------------------------------

invariant mmap_extra6.ALLOCATIONGRANULARITY.class_name:
  description: "mmap.ALLOCATIONGRANULARITY.__class__.__name__ == 'int' — allocation granularity is an int"
  category: constants
  kind: python_call_eq
  function: ALLOCATIONGRANULARITY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant mmap_extra6.ALLOCATIONGRANULARITY.positive:
  description: "mmap.ALLOCATIONGRANULARITY > 0 — allocation granularity is always a positive integer"
  category: constants
  kind: python_call_eq
  function: ALLOCATIONGRANULARITY.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# PAGESIZE — class name and positivity as standalone invariants
#
# mmap.zspec.zsdl checks pagesize_is_int and pagesize_positive. This spec
# adds both as standalone invariants in the extra6 namespace for traceability.
# ---------------------------------------------------------------------------

invariant mmap_extra6.PAGESIZE.class_name:
  description: "mmap.PAGESIZE.__class__.__name__ == 'int' — page size is an int"
  category: constants
  kind: python_call_eq
  function: PAGESIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant mmap_extra6.PAGESIZE.positive:
  description: "mmap.PAGESIZE > 0 — page size is always a positive integer"
  category: constants
  kind: python_call_eq
  function: PAGESIZE.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# mmap.mmap class — __name__ and __module__ via __eq__ chain
#
# mmap.zspec.zsdl checks mmap.__name__ via __eq__ chain. mmap_extra checks
# mmap.__module__. This spec re-adds both as standalone invariants in the
# extra6 namespace using the canonical __eq__ chain form.
# ---------------------------------------------------------------------------

invariant mmap_extra6.mmap_class.name:
  description: "mmap.mmap.__name__ == 'mmap' — the mmap class has the expected __name__"
  category: class_identity
  kind: python_call_eq
  function: mmap.__name__.__eq__
  args: ["mmap"]
  expected: true

invariant mmap_extra6.mmap_class.module:
  description: "mmap.mmap.__module__ == 'mmap' — the mmap class is defined in the mmap module"
  category: class_identity
  kind: python_call_eq
  function: mmap.__module__.__eq__
  args: ["mmap"]
  expected: true
