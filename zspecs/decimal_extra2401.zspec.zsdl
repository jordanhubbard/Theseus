spec: decimal_extra2401
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __hash__ and __eq__ implementation type classification for decimal module classes."
    - "decimal.Decimal defines its own __hash__ in C (slot wrapper 'of decimal.Decimal objects'), distinct from object.__hash__."
    - "decimal.Context inherits __hash__ from object (slot wrapper 'of object objects') — identity-based hash."
    - "Both Decimal and Context show __hash__.__class__.__name__ == 'wrapper_descriptor'."
    - "decimal.Decimal.__hash__ is object.__hash__ == False — Decimal has its own C hash slot (value-based)."
    - "decimal.Context.__hash__ is object.__hash__ == True — Context uses identity hash from object."
    - "decimal.Decimal defines __eq__ in C; decimal.Context inherits __eq__ from object."
    - "decimal.Decimal.__dict__.__contains__('__hash__') == True — hash slot is in Decimal's own C type dict."
    - "decimal.Context.__dict__.__contains__('__hash__') == False — hash slot is absent, inherited from object."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __hash__ and __eq__ implementation type — both are wrapper_descriptor
#
# decimal.Decimal is a C type with its own hash slot (value-based,
# consistent with numeric equality). decimal.Context inherits from object.
# ---------------------------------------------------------------------------

table decimal_extra2401.hash_eq_class_names:
  kind: python_call_eq
  category: hash_eq_type
  id_prefix: dc2401

  columns: [id, function, args, expected]
  rows:
    - ["dc2401001", "decimal.Decimal.__hash__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - ["dc2401002", "decimal.Decimal.__eq__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]
    - ["dc2401003", "decimal.Context.__hash__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true]
    - ["dc2401004", "decimal.Context.__eq__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# __hash__ slot ownership — which C type owns the slot
#
# decimal.Decimal defines its own C hash slot (value-based, like int/float).
# decimal.Context does not define __hash__; it inherits the identity hash
# from object.
# ---------------------------------------------------------------------------

table decimal_extra2401.hash_slot_ownership:
  kind: python_call_eq
  category: hash_slot_identity
  id_prefix: dc2401

  columns: [id, function, args, expected]
  rows:
    - ["dc2401005", "decimal.Decimal.__dict__.__contains__", ["__hash__"], true]
    - ["dc2401006", "decimal.Context.__dict__.__contains__", ["__hash__"], false]
    - ["dc2401007", "decimal.Decimal.__dict__.__contains__", ["__eq__"],   true]
    - ["dc2401008", "decimal.Context.__dict__.__contains__", ["__eq__"],   false]

# ---------------------------------------------------------------------------
# Decimal class identity metadata
# ---------------------------------------------------------------------------

table decimal_extra2401.class_identity:
  kind: python_call_eq
  category: class_identity
  id_prefix: dc2401

  columns: [id, function, args, expected]
  rows:
    - ["dc2401009",  "decimal.Decimal.__name__.__eq__",          ["Decimal"], true]
    - ["dc2401010",  "decimal.Decimal.__module__.__eq__",        ["decimal"], true]
    - ["dc2401011",  "decimal.Context.__name__.__eq__",          ["Context"], true]
    - ["dc2401012",  "decimal.Context.__module__.__eq__",        ["decimal"], true]

# ---------------------------------------------------------------------------
# Decimal hash implementation — C type name confirms ownership
#
# The __hash__ slot wrapper on Decimal reports its owning type as
# 'decimal.Decimal', while Context's inherited slot reports 'object'.
# This mirrors how re.Pattern has its own hash slot vs re.Match inheriting.
# ---------------------------------------------------------------------------

table decimal_extra2401.hash_slot_type_name:
  kind: python_call_eq
  category: hash_slot_type
  id_prefix: dc2401

  columns: [id, function, args, expected]
  rows:
    - ["dc2401013", "decimal.Decimal.__hash__.__objclass__.__name__.__eq__", ["Decimal"], true]
    - ["dc2401014", "decimal.Context.__hash__.__objclass__.__name__.__eq__", ["object"],  true]
    - ["dc2401015", "decimal.Decimal.__eq__.__objclass__.__name__.__eq__",   ["Decimal"], true]
    - ["dc2401016", "decimal.Context.__eq__.__objclass__.__name__.__eq__",   ["object"],  true]

# ---------------------------------------------------------------------------
# Decimal bases — confirms C type hierarchy
# ---------------------------------------------------------------------------

table decimal_extra2401.class_bases:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: dc2401

  columns: [id, function, args, expected]
  rows:
    - ["dc2401017", "decimal.Decimal.__base__.__name__.__eq__",  ["object"], true]
    - ["dc2401018", "decimal.Context.__base__.__name__.__eq__",  ["object"], true]
    - ["dc2401019", "decimal.Decimal.__bases__.__len__",         [],         1]
    - ["dc2401020", "decimal.Context.__bases__.__len__",         [],         1]
