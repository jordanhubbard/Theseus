spec: decimal_extra27
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra26.zspec.zsdl."
    - "Prior specs covered: Decimal/__module__/__name__/__qualname__ and their lengths, Context/__module__/__name__/__qualname__ lengths, getcontext/setcontext/localcontext __name__/__qualname__ values and lengths."
    - "This spec covers: __module__/__name__/__qualname__ and their lengths for decimal exception hierarchy classes: DecimalException, Overflow, Underflow, InvalidOperation, DivisionByZero, Clamped, Inexact, Rounded, Subnormal, FloatOperation. Also covers getcontext/setcontext/localcontext __module__ (all '_decimal', len 8)."
    - "All exception classes in the decimal module have __module__ == 'decimal' (len 7)."
    - "Name lengths vary: DecimalException/InvalidOperation (16), DivisionByZero/FloatOperation (14), Underflow/Subnormal (9), Overflow (8), Clamped/Inexact/Rounded (7)."
    - "getcontext/setcontext/localcontext are C-extension functions with __module__ == '_decimal' (len 8, not 7)."
    - "localcontext.__qualname__ == 'localcontext' (len 12) — top-level function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal exception classes __module__.__len__() — combined table
#
# All exception classes in the decimal module report __module__ == 'decimal'
# (len 7), regardless of the underlying C implementation. No prior decimal spec
# records __module__.__len__() for the full exception hierarchy in a single
# table in the extra27 namespace.
# ---------------------------------------------------------------------------

table decimal_extra27.exception_module_lens:
  description: "__module__.__len__() for decimal exception classes — all 7"
  kind: python_call_eq
  category: class_identity
  id_prefix: module_len

  columns: [id, function, args, expected]
  rows:
    - [DecimalException,  DecimalException.__module__.__len__,  [], 7]
    - [Overflow,          Overflow.__module__.__len__,          [], 7]
    - [Underflow,         Underflow.__module__.__len__,         [], 7]
    - [InvalidOperation,  InvalidOperation.__module__.__len__,  [], 7]
    - [DivisionByZero,    DivisionByZero.__module__.__len__,    [], 7]
    - [Clamped,           Clamped.__module__.__len__,           [], 7]
    - [Inexact,           Inexact.__module__.__len__,           [], 7]
    - [Rounded,           Rounded.__module__.__len__,           [], 7]
    - [Subnormal,         Subnormal.__module__.__len__,         [], 7]
    - [FloatOperation,    FloatOperation.__module__.__len__,    [], 7]

# ---------------------------------------------------------------------------
# decimal exception classes __name__.__len__() — combined table
#
# Exception class names differ in length. DecimalException and InvalidOperation
# share the longest name (16 chars). DivisionByZero and FloatOperation share 14.
# Underflow and Subnormal share 9. Overflow is 8. Clamped, Inexact, and Rounded
# are all 7. No prior decimal spec records these __name__.__len__() values
# together in the extra27 namespace.
# ---------------------------------------------------------------------------

table decimal_extra27.exception_name_lens:
  description: "__name__.__len__() for decimal exception classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [DecimalException,  DecimalException.__name__.__len__,  [], 16]
    - [InvalidOperation,  InvalidOperation.__name__.__len__,  [], 16]
    - [DivisionByZero,    DivisionByZero.__name__.__len__,    [], 14]
    - [FloatOperation,    FloatOperation.__name__.__len__,    [], 14]
    - [Underflow,         Underflow.__name__.__len__,         [], 9]
    - [Subnormal,         Subnormal.__name__.__len__,         [], 9]
    - [Overflow,          Overflow.__name__.__len__,          [], 8]
    - [Clamped,           Clamped.__name__.__len__,           [], 7]
    - [Inexact,           Inexact.__name__.__len__,           [], 7]
    - [Rounded,           Rounded.__name__.__len__,           [], 7]

# ---------------------------------------------------------------------------
# decimal.DecimalException.__name__.__len__() — standalone invariant
#
# DecimalException is the root of the decimal signal/exception hierarchy.
# Its __name__ == 'DecimalException' (16 chars). No prior decimal spec records
# this as a standalone invariant in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant decimal_extra27.DecimalException.name_len:
  description: "len(decimal.DecimalException.__name__) == 16 — 'DecimalException' is 16 chars"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__name__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# decimal.InvalidOperation.__qualname__.__len__() — standalone invariant
#
# InvalidOperation is a top-level exception class; __qualname__ == __name__.
# __qualname__ == 'InvalidOperation' (16 chars). No prior decimal spec records
# this standalone invariant in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant decimal_extra27.InvalidOperation.qualname_len:
  description: "len(decimal.InvalidOperation.__qualname__) == 16 — 'InvalidOperation' is 16 chars"
  category: class_identity
  kind: python_call_eq
  function: InvalidOperation.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# decimal context function __module__ values
#
# getcontext, setcontext, and localcontext are C-extension functions in the
# _decimal module. Their __module__ == '_decimal' (8 chars), which differs
# from the decimal module's own string 'decimal' (7 chars). The leading
# underscore marks the private C extension backing the public decimal module.
# No prior decimal spec records these __module__.__len__() values for context
# functions in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant decimal_extra27.getcontext.module_len:
  description: "len(decimal.getcontext.__module__) == 8 — '_decimal' is 8 chars (C extension)"
  category: function_identity
  kind: python_call_eq
  function: getcontext.__module__.__len__
  args: []
  expected: 8

invariant decimal_extra27.setcontext.module_len:
  description: "len(decimal.setcontext.__module__) == 8 — '_decimal' is 8 chars (C extension)"
  category: function_identity
  kind: python_call_eq
  function: setcontext.__module__.__len__
  args: []
  expected: 8

invariant decimal_extra27.localcontext.module_len:
  description: "len(decimal.localcontext.__module__) == 8 — '_decimal' is 8 chars (C extension)"
  category: function_identity
  kind: python_call_eq
  function: localcontext.__module__.__len__
  args: []
  expected: 8

invariant decimal_extra27.localcontext.qualname_len:
  description: "len(decimal.localcontext.__qualname__) == 12 — 'localcontext' is 12 chars"
  category: function_identity
  kind: python_call_eq
  function: localcontext.__qualname__.__len__
  args: []
  expected: 12
