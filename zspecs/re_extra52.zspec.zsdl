spec: re_extra52
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra51.zspec.zsdl — covers RegexFlag member __class__.__name__/'qualname'/'module' for DOTALL/VERBOSE/ASCII/UNICODE/MULTILINE."
    - "re_extra50.zspec.zsdl — covers re.Pattern/__class__.__qualname__.__eq__('type'); re.Match/__class__.__qualname__.__eq__('type'); re.RegexFlag/__class__.__qualname__.__eq__('EnumType'); re.search/compile/sub/fullmatch/findall.__class__.__qualname__.__eq__('function'); re.error/__class__.__qualname__.__eq__('type')."
    - "re_extra49.zspec.zsdl — covers re.Pattern/__class__.__name__.__eq__('type'); re.Match/__class__.__name__.__eq__('type'); re.RegexFlag/__class__.__name__.__eq__('EnumType'); re.search/compile/sub/__class__.__name__.__eq__('function'); re.error/__class__.__name__.__eq__('type')."
    - "re_extra48.zspec.zsdl — covers re.RegexFlag member ._name_ equality and ._name_.__len__() for IGNORECASE/ASCII/MULTILINE/DOTALL/VERBOSE/UNICODE/LOCALE."
    - "re_extra45.zspec.zsdl — covers RegexFlag._value_ for IGNORECASE/ASCII/LOCALE/UNICODE/DEBUG/NOFLAG; re.A and re.I __class__.__name__=='RegexFlag'."
    - "re_extra33.zspec.zsdl — covers IGNORECASE.__class__.__name__.__len__()==9."
    - "re_extra27.zspec.zsdl — covers IGNORECASE.__class__.__qualname__.__eq__('RegexFlag'); IGNORECASE.__class__.__module__.__eq__('re'); MULTILINE.__class__.__qualname__.__eq__('RegexFlag')."
  notes:
    - "This spec extends re_extra51.zspec.zsdl."
    - "Prior specs collectively covered: RegexFlag member __class__.__name__/__qualname__/__module__ (re_extra27/re_extra51); RegexFlag member _name_ equality and length (re_extra48); RegexFlag _value_ anchors (re_extra45); re.search/compile/sub/fullmatch/findall/__class__.__name__/__qualname__ (re_extra49/re_extra50); re.Pattern/Match/error/__class__.__name__/__qualname__ (re_extra49/re_extra50). NO prior re spec checks the __doc__ attribute of any re function, class, or the re module itself, nor the type (__class__.__name__/__qualname__) of those __doc__ strings."
    - "This spec covers: re.search.__doc__.__class__.__name__.__eq__('str') (NOVEL — no prior re spec checks re.search.__doc__ or its type; novel); re.compile.__doc__.__class__.__name__.__eq__('str') (NOVEL); re.sub.__doc__.__class__.__name__.__eq__('str') (NOVEL); re.findall.__doc__.__class__.__name__.__eq__('str') (NOVEL); re.fullmatch.__doc__.__class__.__name__.__eq__('str') (NOVEL); re.match.__doc__.__class__.__name__.__eq__('str') (NOVEL); re.split.__doc__.__class__.__name__.__eq__('str') (NOVEL); re.subn.__doc__.__class__.__name__.__eq__('str') (NOVEL); re.finditer.__doc__.__class__.__name__.__eq__('str') (NOVEL); re.error.__doc__.__class__.__name__.__eq__('str') (NOVEL); re.Pattern.__doc__.__class__.__name__.__eq__('str') (NOVEL); re.__doc__.__class__.__name__.__eq__('str') (NOVEL — module docstring type; novel); re.search.__doc__.__class__.__qualname__.__eq__('str') (NOVEL — no prior re spec checks __doc__.__class__.__qualname__; novel); re.Pattern.__doc__.__class__.__qualname__.__eq__('str') (NOVEL); re.__doc__.__class__.__qualname__.__eq__('str') (NOVEL)."
    - "re.search.__doc__ is a str instance. re.search is a Python function; its docstring is a plain Python str. Therefore __doc__.__class__.__name__=='str'. No prior re spec checks re.search.__doc__ or its type. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.compile.__doc__.__class__.__name__ == 'str'. re.compile is a Python function; its docstring is a str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.sub.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.findall.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.fullmatch.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.match.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.split.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.subn.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.finditer.__doc__.__class__.__name__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.error.__doc__.__class__.__name__ == 'str'. re.error is an exception class; its docstring is a str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Pattern.__doc__.__class__.__name__ == 'str'. re.Pattern is the compiled regex type; its docstring is a str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.__doc__.__class__.__name__ == 'str'. The re module itself has a docstring; its type is str. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.search.__doc__.__class__.__qualname__ == 'str'. For the builtin str type, __qualname__==__name__=='str'. Novel __qualname__ path anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Pattern.__doc__.__class__.__qualname__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.__doc__.__class__.__qualname__ == 'str'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function and class __doc__.__class__.__name__ equality
#
# Every re module function and class has a docstring attribute (__doc__) that
# is a plain Python str instance. Therefore for any re symbol S:
#
#   S.__doc__.__class__.__name__ == 'str'
#
# This covers core functions, the error exception, Pattern class, and module:
#
#   re.search.__doc__.__class__.__name__   == 'str'
#   re.compile.__doc__.__class__.__name__  == 'str'
#   re.sub.__doc__.__class__.__name__      == 'str'
#   re.findall.__doc__.__class__.__name__  == 'str'
#   re.fullmatch.__doc__.__class__.__name__ == 'str'
#   re.match.__doc__.__class__.__name__    == 'str'
#   re.split.__doc__.__class__.__name__    == 'str'
#   re.subn.__doc__.__class__.__name__     == 'str'
#   re.finditer.__doc__.__class__.__name__ == 'str'
#   re.error.__doc__.__class__.__name__    == 'str'
#   re.Pattern.__doc__.__class__.__name__  == 'str'
#   re.__doc__.__class__.__name__          == 'str'
#
# No prior re spec checks __doc__ or its type for any re symbol.
# All twelve equality anchors are novel in the re_extra52 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra52.symbol_doc_names:
  description: "re module function/class __doc__.__class__.__name__.__eq__('str') for search/compile/sub/findall/fullmatch/match/split/subn/finditer/error/Pattern/re-module — every re function and class docstring is a plain str instance; no prior re spec checks __doc__ or its type for any re symbol; all twelve novel equality anchors in re_extra52 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: redoc52cn

  columns: [id, function, args, expected]
  rows:
    - [search_doc_class_name,   "search.__doc__.__class__.__name__.__eq__",   ["str"], true]
    - [compile_doc_class_name,  "compile.__doc__.__class__.__name__.__eq__",  ["str"], true]
    - [sub_doc_class_name,      "sub.__doc__.__class__.__name__.__eq__",      ["str"], true]
    - [findall_doc_class_name,  "findall.__doc__.__class__.__name__.__eq__",  ["str"], true]
    - [fullmatch_doc_class_name, "fullmatch.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [match_doc_class_name,    "match.__doc__.__class__.__name__.__eq__",    ["str"], true]
    - [split_doc_class_name,    "split.__doc__.__class__.__name__.__eq__",    ["str"], true]
    - [subn_doc_class_name,     "subn.__doc__.__class__.__name__.__eq__",     ["str"], true]
    - [finditer_doc_class_name, "finditer.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [error_doc_class_name,    "error.__doc__.__class__.__name__.__eq__",    ["str"], true]
    - [Pattern_doc_class_name,  "Pattern.__doc__.__class__.__name__.__eq__",  ["str"], true]
    - [module_doc_class_name,   "__doc__.__class__.__name__.__eq__",          ["str"], true]

# ---------------------------------------------------------------------------
# re module __doc__.__class__.__qualname__ equality (selected)
#
# For the builtin str type, __qualname__==__name__=='str'. Therefore:
#
#   re.search.__doc__.__class__.__qualname__  == 'str'
#   re.Pattern.__doc__.__class__.__qualname__ == 'str'
#   re.__doc__.__class__.__qualname__         == 'str'
#
# No prior re spec checks __doc__.__class__.__qualname__ for any re symbol.
# All three equality anchors are novel in the re_extra52 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra52.symbol_doc_qualnames:
  description: "re module __doc__.__class__.__qualname__.__eq__('str') for search/Pattern/re-module — for the builtin str type __qualname__==__name__=='str'; no prior re spec checks __doc__.__class__.__qualname__ for any re symbol; all three novel __qualname__ path anchors in re_extra52 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: redoc52cq

  columns: [id, function, args, expected]
  rows:
    - [search_doc_class_qualname,  "search.__doc__.__class__.__qualname__.__eq__",  ["str"], true]
    - [Pattern_doc_class_qualname, "Pattern.__doc__.__class__.__qualname__.__eq__", ["str"], true]
    - [module_doc_class_qualname,  "__doc__.__class__.__qualname__.__eq__",         ["str"], true]
