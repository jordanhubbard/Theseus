spec: struct_extra128
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra127.zspec.zsdl — covers Struct.__reduce__ and __reduce_ex__ method identity / Struct.__sizeof__ class name and qualname / Struct.__doc__ equality and length / Struct.size and format __objclass__.__name__ and __module__ equality (table + invariants)."
    - "struct_extra126.zspec.zsdl — covers Struct.__init__/__repr__/__sizeof__/__reduce_ex__ qualname string equality and qualname lengths / Struct.__new__.__qualname__ equality and length / Struct.__class__.__name__=='type' (table + invariants)."
    - "struct_extra125.zspec.zsdl — covers struct.__all__ list class name and length (8) / __all__ membership / Struct method __objclass__.__name__ equality (table + invariants)."
    - "struct_extra124.zspec.zsdl — covers Struct.__dict__.__contains__ for several dunder names / error.__dict__.__contains__ (table + invariants)."
    - "struct_extra123.zspec.zsdl — covers Struct.pack/__objclass__/__module__.__eq__('_struct') / Struct.pack/__objclass__/__qualname__.__eq__('Struct') / Struct.pack/__objclass__/__class__.__name__.__eq__('type') (table + invariants)."
    - "struct_extra122.zspec.zsdl — covers struct.error/__name__/__qualname__/__class__.__name__ equality / Struct/__name__/__qualname__/__class__.__name__ equality / Struct.size/format/__name__ equality (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths / Struct.size/__format__ descriptor __doc__ string equality and length / struct module __doc__ length (1278) (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / Struct.size/__format__ qualname/name lengths and __objclass__.__name__ (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__() (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior struct spec files."
    - "Wave 313 theme: Struct.pack/unpack/pack_into/unpack_from method __qualname__ equality / Struct.__init__ wrapper_descriptor __qualname__ and class name / Struct.pack/unpack/pack_into/unpack_from/iter_unpack __name__ equality / qualname string lengths."
    - "struct.Struct.__init__.__class__.__name__ == 'wrapper_descriptor'. Struct.__init__ is a wrapper_descriptor (not method_descriptor), because it wraps the C tp_init slot. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__qualname__ == 'Struct.__init__'. len == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__name__ == '__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__name__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__name__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__name__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__name__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('Struct.__init__') == 15. len('Struct.pack') == 11. len('Struct.unpack') == 13. len('Struct.pack_into') == 16. len('Struct.unpack_from') == 18. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct_extra94 anchors Struct method __qualname__.__len__() at table level; struct_extra93 anchors Struct method __name__ equality at table level. This spec anchors __qualname__.__eq__() method call equivalents and adds __class__.__name__ equality via __eq__ calls and __init__ identity — not covered by prior specs under structmethods128."
    - "Note: Struct.__init__ is a wrapper_descriptor because it wraps the C tp_init slot (PyWrapperDescrObject), while pack/unpack/pack_into/unpack_from/iter_unpack are method_descriptor (PyMethodDescrObject) wrapping C PyMethodDef entries."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__qualname__.__eq__('Struct.__init__')
# struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor')
# struct.Struct.__init__.__name__.__eq__('__init__')
# struct.Struct.pack.__qualname__.__eq__('Struct.pack')
# struct.Struct.unpack.__qualname__.__eq__('Struct.unpack')
#
# Wave 313 theme: Struct.__init__ wrapper_descriptor identity and pack/unpack qualname equality.
#
# Struct.__init__ is a wrapper_descriptor — it wraps the C tp_init slot
# (PyWrapperDescrObject). This distinguishes it from pack/unpack/pack_into/
# unpack_from/iter_unpack which are method_descriptor objects (PyMethodDescrObject).
# struct_extra126 anchors Struct.__init__.__qualname__.__eq__('Struct.__init__')
# at table level; this spec anchors it via __eq__ method calls and adds
# __class__.__name__ and __name__ equality under structmethods128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra128.Struct_init_and_pack_qualnames:
  description: "Struct.__init__/__qualname__.__eq__('Struct.__init__')==True / Struct.__init__/__class__.__name__.__eq__('wrapper_descriptor')==True / Struct.__init__/__name__.__eq__('__init__')==True / Struct.pack/__qualname__.__eq__('Struct.pack')==True / Struct.unpack/__qualname__.__eq__('Struct.unpack')==True — __init__ is a wrapper_descriptor (tp_init slot); pack/unpack are method_descriptors (PyMethodDef); extra126 anchors __init__ qualname at table level; first structmethods128 anchor via __eq__ calls"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmethods128

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname, "Struct.__init__.__qualname__.__eq__",        ["Struct.__init__"],  true, "Struct.__init__.__qualname__ is 'Struct.__init__' (15 chars)"]
    - [init_class,    "Struct.__init__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true, "Struct.__init__ is a wrapper_descriptor (wraps C tp_init slot), not method_descriptor"]
    - [init_name,     "Struct.__init__.__name__.__eq__",            ["__init__"],         true, "Struct.__init__.__name__ is '__init__'"]
    - [pack_qualname, "Struct.pack.__qualname__.__eq__",            ["Struct.pack"],      true, "Struct.pack.__qualname__ is 'Struct.pack' (11 chars)"]
    - [unpack_qualname, "Struct.unpack.__qualname__.__eq__",        ["Struct.unpack"],    true, "Struct.unpack.__qualname__ is 'Struct.unpack' (13 chars)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into')
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from')
# struct.Struct.pack.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.unpack.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.pack_into.__class__.__name__.__eq__('method_descriptor')
#
# Wave 313 theme: pack_into/unpack_from qualname equality and method_descriptor class names.
#
# struct_extra95 anchors pack_into/unpack_from/iter_unpack __qualname__.__len__();
# this spec anchors the qualname strings via __eq__ calls and confirms all five
# core Struct methods (pack/unpack/pack_into/unpack_from/iter_unpack) are
# method_descriptor type under structmethods128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra128.Struct_method_qualnames_and_class_names:
  description: "Struct.pack_into/__qualname__.__eq__('Struct.pack_into')==True / Struct.unpack_from/__qualname__.__eq__('Struct.unpack_from')==True / Struct.pack/__class__.__name__.__eq__('method_descriptor')==True / Struct.unpack/__class__.__name__.__eq__('method_descriptor')==True / Struct.pack_into/__class__.__name__.__eq__('method_descriptor')==True — pack_into/unpack_from qualname equality; pack/unpack/pack_into are all method_descriptor; extra95 anchors qualname lengths; first structmethods128 anchor for qualname string equality and class name via __eq__ calls"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmethods128

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_qualname,  "Struct.pack_into.__qualname__.__eq__",           ["Struct.pack_into"],  true, "Struct.pack_into.__qualname__ is 'Struct.pack_into' (16 chars)"]
    - [unpack_from_qualname, "Struct.unpack_from.__qualname__.__eq__",        ["Struct.unpack_from"], true, "Struct.unpack_from.__qualname__ is 'Struct.unpack_from' (18 chars)"]
    - [pack_class,          "Struct.pack.__class__.__name__.__eq__",          ["method_descriptor"], true, "Struct.pack is a method_descriptor (PyMethodDescrObject wrapping C PyMethodDef)"]
    - [unpack_class,        "Struct.unpack.__class__.__name__.__eq__",        ["method_descriptor"], true, "Struct.unpack is a method_descriptor"]
    - [pack_into_class,     "Struct.pack_into.__class__.__name__.__eq__",     ["method_descriptor"], true, "Struct.pack_into is a method_descriptor"]

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.pack.__name__.__eq__('pack')
# struct.Struct.unpack.__name__.__eq__('unpack')
# struct.Struct.pack_into.__name__.__eq__('pack_into')
# struct.Struct.unpack_from.__name__.__eq__('unpack_from')
#
# Wave 313 theme: unpack_from class name and all four core method __name__ equality.
#
# struct_extra93 anchors Struct method __name__ equality (pack/unpack/pack_into/
# unpack_from/iter_unpack) at table level. This spec anchors __name__ for
# pack/unpack/pack_into/unpack_from via __eq__ method calls under structmethods128,
# plus confirms unpack_from is a method_descriptor. No prior struct spec anchors
# these __name__ values via explicit __eq__ calls.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra128.Struct_method_names:
  description: "Struct.unpack_from/__class__.__name__.__eq__('method_descriptor')==True / Struct.pack/__name__.__eq__('pack')==True / Struct.unpack/__name__.__eq__('unpack')==True / Struct.pack_into/__name__.__eq__('pack_into')==True / Struct.unpack_from/__name__.__eq__('unpack_from')==True — unpack_from is method_descriptor; pack/unpack/pack_into/unpack_from __name__ equality; extra93 anchors __name__ at table level; first structmethods128 anchor for __name__ via __eq__ calls"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmethods128

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_from_class, "Struct.unpack_from.__class__.__name__.__eq__", ["method_descriptor"], true, "Struct.unpack_from is a method_descriptor"]
    - [pack_name,         "Struct.pack.__name__.__eq__",                  ["pack"],              true, "Struct.pack.__name__ is 'pack'"]
    - [unpack_name,       "Struct.unpack.__name__.__eq__",                ["unpack"],            true, "Struct.unpack.__name__ is 'unpack'"]
    - [pack_into_name,    "Struct.pack_into.__name__.__eq__",             ["pack_into"],         true, "Struct.pack_into.__name__ is 'pack_into'"]
    - [unpack_from_name,  "Struct.unpack_from.__name__.__eq__",           ["unpack_from"],       true, "Struct.unpack_from.__name__ is 'unpack_from'"]

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') — standalone
#
# struct.Struct.__init__.__class__.__name__ is 'wrapper_descriptor'. Struct.__init__
# wraps the C tp_init slot (PyWrapperDescrObject), which is created by CPython's
# type machinery for C extension types that define tp_init. This is distinct from
# method_descriptor (PyMethodDescrObject) which wraps PyMethodDef entries like
# pack/unpack. struct_extra126 anchors Struct.__init__.__qualname__ at table level;
# this is the first standalone for Struct.__init__.__class__.__name__.__eq__
# ('wrapper_descriptor') under structmethods128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra128.Struct_init_class_wrapper_descriptor:
  description: "struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — Struct.__init__ wraps the C tp_init slot (PyWrapperDescrObject), distinct from method_descriptor (PyMethodDescrObject) wrapping PyMethodDef entries; extra126 anchors __init__ qualname at table level; first standalone for __init__.__class__.__name__.__eq__ under structmethods128"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__init__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack') — standalone
#
# struct.Struct.pack.__qualname__ is 'Struct.pack' (11 chars). The pack method
# serializes Python values into bytes according to the compiled format string.
# struct_extra94 anchors Struct.pack.__qualname__.__len__()==11 at table level;
# this is the first standalone for Struct.pack.__qualname__.__eq__('Struct.pack')
# under structmethods128. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra128.Struct_pack_qualname:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — pack serializes Python values into bytes per compiled format; qualname is 'Struct.pack' (11 chars); extra94 anchors __qualname__.__len__() at table level; first standalone for Struct.pack.__qualname__.__eq__ under structmethods128"
  category: type_identity
  kind: python_call_eq
  function: "Struct.pack.__qualname__.__eq__"
  args: ["Struct.pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') — standalone
#
# struct.Struct.unpack.__qualname__ is 'Struct.unpack' (13 chars). The unpack
# method deserializes bytes into a tuple of Python values according to the
# compiled format string. struct_extra94 anchors __qualname__.__len__()==13 at
# table level; this is the first standalone for Struct.unpack.__qualname__.__eq__
# ('Struct.unpack') under structmethods128.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra128.Struct_unpack_qualname:
  description: "struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') == True — unpack deserializes bytes into a tuple of Python values per compiled format; qualname is 'Struct.unpack' (13 chars); extra94 anchors __qualname__.__len__() at table level; first standalone for Struct.unpack.__qualname__.__eq__ under structmethods128"
  category: type_identity
  kind: python_call_eq
  function: "Struct.unpack.__qualname__.__eq__"
  args: ["Struct.unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack.__class__.__name__.__eq__('method_descriptor') — standalone
#
# struct.Struct.pack.__class__.__name__ is 'method_descriptor'. All five core
# Struct operation methods (pack, unpack, pack_into, unpack_from, iter_unpack)
# are method_descriptor objects wrapping C PyMethodDef entries in _struct.c.
# This is distinct from Struct.__init__ which is a wrapper_descriptor. No prior
# struct spec anchors Struct.pack.__class__.__name__.__eq__('method_descriptor')
# as a standalone under structmethods128. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra128.Struct_pack_class_method_descriptor:
  description: "struct.Struct.pack.__class__.__name__.__eq__('method_descriptor') == True — pack is a method_descriptor (PyMethodDescrObject wrapping C PyMethodDef in _struct.c); distinct from Struct.__init__ which is a wrapper_descriptor; first standalone for Struct.pack.__class__.__name__.__eq__ under structmethods128"
  category: type_identity
  kind: python_call_eq
  function: "Struct.pack.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') — standalone
#
# struct.Struct.pack_into.__qualname__ is 'Struct.pack_into' (16 chars). The
# pack_into method serializes values directly into a writable buffer at a given
# offset — useful for zero-copy serialization into bytearray or memoryview.
# struct_extra95 anchors pack_into.__qualname__.__len__()==16 at table level;
# this is the first standalone for pack_into.__qualname__.__eq__('Struct.pack_into')
# under structmethods128. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra128.Struct_pack_into_qualname:
  description: "struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') == True — pack_into serializes into a writable buffer at offset; qualname is 'Struct.pack_into' (16 chars); extra95 anchors __qualname__.__len__() at table level; first standalone for Struct.pack_into.__qualname__.__eq__ under structmethods128"
  category: type_identity
  kind: python_call_eq
  function: "Struct.pack_into.__qualname__.__eq__"
  args: ["Struct.pack_into"]
  expected: true
