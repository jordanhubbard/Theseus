spec: threading_extra1561
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 551 theme: numeric type conversion protocol dict-presence checks via __dict__.__contains__ for threading classes."
    - "threading.Thread.__dict__.__contains__ returns False for all numeric dunder methods. Thread is a Python class representing an OS thread; synchronization objects are not numeric types. Verified with Python 3.14."
    - "threading.Semaphore.__dict__.__contains__ returns False for all numeric dunder methods. Semaphore is a Python class implementing a counting semaphore; numeric type conversion protocol dunders are absent from its own __dict__. Verified with Python 3.14."
    - "threading.Barrier.__dict__.__contains__ returns False for all numeric dunder methods. Barrier is a Python class (added in 3.2) for thread synchronization barriers; it defines no numeric conversion operators. Verified with Python 3.14."
    - "threading.Condition.__dict__.__contains__ returns False for all numeric dunder methods. Condition is a Python class providing a condition variable; numeric type conversion is not applicable. Verified with Python 3.14."
    - "Numeric dunders checked: __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, __round__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread — numeric type conversion protocol dict-presence checks
#
# Wave 551 theme: Thread is a Python class (Lib/threading.py). Its own __dict__
# does not define any numeric conversion dunder methods. Thread objects represent
# OS threads; they are not value types and have no numeric conversion semantics.
# ---------------------------------------------------------------------------

table threading_extra1561.thread_numeric_dict_contains:
  description: "threading.Thread.__dict__.__contains__ returns False for all numeric type conversion dunders; wave 551; new to extra1561"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1561th

  columns: [id, function, args, expected, description]
  rows:
    - ["th1561th001",
       "Thread.__dict__.__contains__",
       ["__bool__"],
       false,
       "threading.Thread.__dict__.__contains__('__bool__') == False — Thread is a Python class; its __dict__ does not define __bool__; wave 551; new to extra1561"]
    - ["th1561th002",
       "Thread.__dict__.__contains__",
       ["__int__"],
       false,
       "threading.Thread.__dict__.__contains__('__int__') == False — Thread does not define __int__ in its own class __dict__; wave 551; new to extra1561"]
    - ["th1561th003",
       "Thread.__dict__.__contains__",
       ["__float__"],
       false,
       "threading.Thread.__dict__.__contains__('__float__') == False — Thread does not define __float__ in its own class __dict__; wave 551; new to extra1561"]
    - ["th1561th004",
       "Thread.__dict__.__contains__",
       ["__complex__"],
       false,
       "threading.Thread.__dict__.__contains__('__complex__') == False — Thread does not define __complex__ in its own class __dict__; wave 551; new to extra1561"]
    - ["th1561th005",
       "Thread.__dict__.__contains__",
       ["__index__"],
       false,
       "threading.Thread.__dict__.__contains__('__index__') == False — Thread does not define __index__ in its own class __dict__; wave 551; new to extra1561"]
    - ["th1561th006",
       "Thread.__dict__.__contains__",
       ["__trunc__"],
       false,
       "threading.Thread.__dict__.__contains__('__trunc__') == False — Thread does not define __trunc__ in its own class __dict__; wave 551; new to extra1561"]
    - ["th1561th007",
       "Thread.__dict__.__contains__",
       ["__floor__"],
       false,
       "threading.Thread.__dict__.__contains__('__floor__') == False — Thread does not define __floor__ in its own class __dict__; wave 551; new to extra1561"]
    - ["th1561th008",
       "Thread.__dict__.__contains__",
       ["__ceil__"],
       false,
       "threading.Thread.__dict__.__contains__('__ceil__') == False — Thread does not define __ceil__ in its own class __dict__; wave 551; new to extra1561"]
    - ["th1561th009",
       "Thread.__dict__.__contains__",
       ["__round__"],
       false,
       "threading.Thread.__dict__.__contains__('__round__') == False — Thread does not define __round__ in its own class __dict__; wave 551; new to extra1561"]

