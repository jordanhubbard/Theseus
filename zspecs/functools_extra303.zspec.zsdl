spec: functools_extra303
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# lru_cache identity — type and naming
#
# lru_cache is a Python-level function (not a type, not a C built-in).
# Its __name__ is 'lru_cache' and its __module__ is 'functools'.
# type(lru_cache).__name__ == 'function'
# ---------------------------------------------------------------------------

invariant functools_extra303.lru_cache.name:
  description: "lru_cache.__name__ == 'lru_cache'"
  category: lru_cache
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra303.lru_cache.module:
  description: "lru_cache.__module__ == 'functools'"
  category: lru_cache
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra303.lru_cache.class_name:
  description: "type(lru_cache).__name__ == 'function' — lru_cache is a plain Python function"
  category: lru_cache
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# lru_cache.__doc__ — non-empty docstring starting with 'Least-recently-used'
#
# len(__doc__) == 743 on Python 3.14.3
# __doc__[:5] == 'Least'
# ---------------------------------------------------------------------------

invariant functools_extra303.lru_cache.doc_length:
  description: "len(lru_cache.__doc__) == 743 on Python 3.14.3"
  category: lru_cache
  kind: python_call_eq
  function: lru_cache.__doc__.__len__
  args: []
  expected: 743

invariant functools_extra303.lru_cache.doc_contains_phrase:
  description: "lru_cache.__doc__ contains 'Least-recently-used cache decorator'"
  category: lru_cache
  kind: python_call_eq
  function: lru_cache.__doc__.__contains__
  args: ["Least-recently-used cache decorator"]
  expected: true

# ---------------------------------------------------------------------------
# cached_property identity
#
# cached_property is a type (class). Its single base is object.
# __name__ == 'cached_property', __module__ == 'functools'
# ---------------------------------------------------------------------------

invariant functools_extra303.cached_property.name:
  description: "cached_property.__name__ == 'cached_property'"
  category: cached_property
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra303.cached_property.module:
  description: "cached_property.__module__ == 'functools'"
  category: cached_property
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra303.cached_property.base_is_object:
  description: "cached_property.__bases__[0].__name__ == 'object' — inherits directly from object"
  category: cached_property
  kind: python_call_eq
  function: cached_property.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES class identity
#
# Both are tuples. WRAPPER_UPDATES has exactly 1 element: ('__dict__',)
# ---------------------------------------------------------------------------

invariant functools_extra303.wrapper_assignments.class_name:
  description: "WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'"
  category: wrapper_constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra303.wrapper_updates.class_name:
  description: "WRAPPER_UPDATES.__class__.__name__ == 'tuple'"
  category: wrapper_constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra303.wrapper_updates.length_one:
  description: "len(WRAPPER_UPDATES) == 1 — only '__dict__' is merged by @wraps"
  category: wrapper_constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra303.wrapper_updates.contains_dict:
  description: "WRAPPER_UPDATES contains '__dict__'"
  category: wrapper_constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true

# ---------------------------------------------------------------------------
# reduce module — C extension
#
# functools.reduce is implemented in C (_functools module).
# Its __module__ is '_functools', not 'functools'.
# ---------------------------------------------------------------------------

invariant functools_extra303.reduce.module_is_c_extension:
  description: "reduce.__module__ == '_functools' — reduce is a C-level built-in"
  category: reduce
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true
