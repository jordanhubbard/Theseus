spec: mp3016
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 648 — theme: __iter__, __next__, __reversed__ dict-presence (iterator protocol)."
    - "Tests operator.contains(SomeClass.__dict__, '__iter__') etc. for multiprocessing classes."
    - "Classes covered: Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.ListProxy, managers.SetProxy, managers.DictProxy, managers.BaseListProxy, managers.BaseProxy, managers._BaseDictProxy, managers._BaseSetProxy."
    - "Key finding: user-facing proxy classes (ListProxy, SetProxy, DictProxy) do NOT define __iter__ in their own __dict__; they rely on inheritance."
    - "BaseListProxy.__dict__ does NOT define __iter__ despite defining __reversed__ — it exposes reversal as a proxy call but delegates forward iteration upward."
    - "_BaseDictProxy.__dict__ defines __iter__ (true) and __reversed__ (true) — it is the concrete dict-proxy implementing both directions."
    - "_BaseSetProxy.__dict__ defines __iter__ (true) — sets are iterable but not reversible, so __reversed__ is false."
    - "No multiprocessing class defines __next__ in its own __dict__; none are their own iterators."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# Only _BaseDictProxy and _BaseSetProxy define __iter__ (true).
# User-facing ListProxy, DictProxy, SetProxy do not; they rely on inheritance.
# BaseListProxy, despite implementing sequence-proxy operations, also lacks it.
# ---------------------------------------------------------------------------

table mp3016.iter:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: iter_iter
  id_prefix: it

  columns: [id, function, args, expected]
  rows:
    - ["it_Process",       operator.contains, [multiprocessing.Process.__dict__,                            "__iter__"], false]
    - ["it_Pool",          operator.contains, [multiprocessing.pool.Pool.__dict__,                          "__iter__"], false]
    - ["it_AsyncResult",   operator.contains, [multiprocessing.pool.AsyncResult.__dict__,                   "__iter__"], false]
    - ["it_MapResult",     operator.contains, [multiprocessing.pool.MapResult.__dict__,                     "__iter__"], false]
    - ["it_SyncManager",   operator.contains, [multiprocessing.managers.SyncManager.__dict__,               "__iter__"], false]
    - ["it_ListProxy",     operator.contains, [multiprocessing.managers.ListProxy.__dict__,                 "__iter__"], false]
    - ["it_SetProxy",      operator.contains, [multiprocessing.managers.SetProxy.__dict__,                  "__iter__"], false]
    - ["it_DictProxy",     operator.contains, [multiprocessing.managers.DictProxy.__dict__,                 "__iter__"], false]
    - ["it_BaseListProxy", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,             "__iter__"], false]
    - ["it_BaseProxy",     operator.contains, [multiprocessing.managers.BaseProxy.__dict__,                 "__iter__"], false]
    - ["it_BaseDictProxy", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,            "__iter__"], true]
    - ["it_BaseSetProxy",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,             "__iter__"], true]

# ---------------------------------------------------------------------------
# __next__ dict-presence — operator.contains(Cls.__dict__, '__next__')
#
# No multiprocessing class defines __next__; all results are false.
# Proxy classes are not their own iterators; they return separate iterator objects.
# ---------------------------------------------------------------------------

table mp3016.next:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: iter_next
  id_prefix: nx

  columns: [id, function, args, expected]
  rows:
    - ["nx_Process",       operator.contains, [multiprocessing.Process.__dict__,                            "__next__"], false]
    - ["nx_Pool",          operator.contains, [multiprocessing.pool.Pool.__dict__,                          "__next__"], false]
    - ["nx_AsyncResult",   operator.contains, [multiprocessing.pool.AsyncResult.__dict__,                   "__next__"], false]
    - ["nx_MapResult",     operator.contains, [multiprocessing.pool.MapResult.__dict__,                     "__next__"], false]
    - ["nx_SyncManager",   operator.contains, [multiprocessing.managers.SyncManager.__dict__,               "__next__"], false]
    - ["nx_ListProxy",     operator.contains, [multiprocessing.managers.ListProxy.__dict__,                 "__next__"], false]
    - ["nx_SetProxy",      operator.contains, [multiprocessing.managers.SetProxy.__dict__,                  "__next__"], false]
    - ["nx_DictProxy",     operator.contains, [multiprocessing.managers.DictProxy.__dict__,                 "__next__"], false]
    - ["nx_BaseListProxy", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,             "__next__"], false]
    - ["nx_BaseProxy",     operator.contains, [multiprocessing.managers.BaseProxy.__dict__,                 "__next__"], false]
    - ["nx_BaseDictProxy", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,            "__next__"], false]
    - ["nx_BaseSetProxy",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,             "__next__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — operator.contains(Cls.__dict__, '__reversed__')
#
# BaseListProxy defines __reversed__ (true) — it is a list-proxy that exposes
# reversal as a proxy-forwarded operation.
# _BaseDictProxy defines __reversed__ (true) — dicts are reversible since 3.8.
# All other classes return false.
# ---------------------------------------------------------------------------

table mp3016.reversed:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: iter_reversed
  id_prefix: rv

  columns: [id, function, args, expected]
  rows:
    - ["rv_Process",       operator.contains, [multiprocessing.Process.__dict__,                            "__reversed__"], false]
    - ["rv_Pool",          operator.contains, [multiprocessing.pool.Pool.__dict__,                          "__reversed__"], false]
    - ["rv_AsyncResult",   operator.contains, [multiprocessing.pool.AsyncResult.__dict__,                   "__reversed__"], false]
    - ["rv_MapResult",     operator.contains, [multiprocessing.pool.MapResult.__dict__,                     "__reversed__"], false]
    - ["rv_SyncManager",   operator.contains, [multiprocessing.managers.SyncManager.__dict__,               "__reversed__"], false]
    - ["rv_ListProxy",     operator.contains, [multiprocessing.managers.ListProxy.__dict__,                 "__reversed__"], false]
    - ["rv_SetProxy",      operator.contains, [multiprocessing.managers.SetProxy.__dict__,                  "__reversed__"], false]
    - ["rv_DictProxy",     operator.contains, [multiprocessing.managers.DictProxy.__dict__,                 "__reversed__"], false]
    - ["rv_BaseListProxy", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,             "__reversed__"], true]
    - ["rv_BaseProxy",     operator.contains, [multiprocessing.managers.BaseProxy.__dict__,                 "__reversed__"], false]
    - ["rv_BaseDictProxy", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,            "__reversed__"], true]
    - ["rv_BaseSetProxy",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,             "__reversed__"], false]

# ---------------------------------------------------------------------------
# combined — all three iterator protocol methods across a cross-class sample
#
# Highlights the asymmetry: BaseListProxy has __reversed__ but not __iter__;
# _BaseDictProxy has both __iter__ and __reversed__; _BaseSetProxy has __iter__
# but not __reversed__.  8 representative classes x 3 methods = 24 rows.
# ---------------------------------------------------------------------------

table mp3016.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: iter_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Process_it",       operator.contains, [multiprocessing.Process.__dict__,                         "__iter__"],     false]
    - ["comb_Process_nx",       operator.contains, [multiprocessing.Process.__dict__,                         "__next__"],     false]
    - ["comb_Process_rv",       operator.contains, [multiprocessing.Process.__dict__,                         "__reversed__"], false]
    - ["comb_BaseListProxy_it", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,          "__iter__"],     false]
    - ["comb_BaseListProxy_nx", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,          "__next__"],     false]
    - ["comb_BaseListProxy_rv", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,          "__reversed__"], true]
    - ["comb_BaseDictProxy_it", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,         "__iter__"],     true]
    - ["comb_BaseDictProxy_nx", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,         "__next__"],     false]
    - ["comb_BaseDictProxy_rv", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,         "__reversed__"], true]
    - ["comb_BaseSetProxy_it",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,          "__iter__"],     true]
    - ["comb_BaseSetProxy_nx",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,          "__next__"],     false]
    - ["comb_BaseSetProxy_rv",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,          "__reversed__"], false]
    - ["comb_ListProxy_it",     operator.contains, [multiprocessing.managers.ListProxy.__dict__,              "__iter__"],     false]
    - ["comb_ListProxy_nx",     operator.contains, [multiprocessing.managers.ListProxy.__dict__,              "__next__"],     false]
    - ["comb_ListProxy_rv",     operator.contains, [multiprocessing.managers.ListProxy.__dict__,              "__reversed__"], false]
    - ["comb_DictProxy_it",     operator.contains, [multiprocessing.managers.DictProxy.__dict__,              "__iter__"],     false]
