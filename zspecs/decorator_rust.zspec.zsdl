spec: decorator_rust
version: ">=3.9"
backend: rust_module(decorator_rust)

docs: https://decorator.readthedocs.io/

provenance:
  derived_from:
    - "https://decorator.readthedocs.io/ — decorator library documentation"
  not_derived_from:
    - "decorator source: decorator.py"
  notes:
    - "decorator is a library for creating well-behaved decorators."
    - "@decorator.decorator preserves function signature."
    - "Expose decorated_name(func_name) -> str: decorated fn.__name__ == func_name."
    - "Expose decorated_doc(func_doc) -> str: decorated fn.__doc__ == func_doc."
    - "Expose decorator_getfullargspec_names(fn) -> list: argspec of decorated fn."
    - "A decorated function retains __name__ and __doc__ from the original."
    - "decorator.decorator applied to a function preserves __wrapped__."
    - "Expose is_generator_false(fn) -> bool: decorator.isgeneratorfunction(fn) == False for regular fn."
    - "All test vectors verified against decorator 5.2.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# decorated_name — preserves __name__
table decorator_rust.preserve.name:
  kind: python_call_eq
  category: name
  id_prefix: dec_name
  function: decorated_name

  columns: [id, args, expected]
  rows:
    - [my_func,  ["my_func"],  "my_func"]
    - [add,      ["add"],      "add"]
    - [compute,  ["compute"],  "compute"]

# decorated_doc — preserves __doc__
table decorator_rust.preserve.doc:
  kind: python_call_eq
  category: doc
  id_prefix: dec_doc
  function: decorated_doc

  columns: [id, args, expected]
  rows:
    - [hello_doc, ["Hello World"], "Hello World"]
    - [compute,   ["Computes x"], "Computes x"]

# isgeneratorfunction — regular function is not a generator
invariant decorator_rust.classify.not_generator:
  description: "decorator.isgeneratorfunction(lambda: 1) == False"
  category: classify
  kind: python_call_eq
  function: is_generator_false
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:41:16Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
