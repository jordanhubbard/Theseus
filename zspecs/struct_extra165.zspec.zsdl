table struct_extra165.error_class_identity:
  description: "struct.error.__name__.__eq__('error')==True / error.__bases__[0].__name__.__eq__('Exception')==True / error.__module__.__eq__('struct')==True — error.__name__ is 'error' (5 chars; struct.error is named with a lowercase 'e', unlike most Python exceptions which use CamelCase (e.g. ValueError, OSError, RuntimeError); 'error'(5 chars) is the simple descriptor for packing/unpacking failures; error.__name__(5) < error.__bases__[0].__name__(9) < 'struct_error'(12) — name is shorter than the base class name; struct_extra161 anchors error.__name__=='error' as a table row — this spec uses __eq__ method call syntax); error.__bases__[0].__name__ is 'Exception' (9 chars; struct.error directly subclasses the built-in Exception class; 'Exception'(9 chars) = 'Ex'=2 + 'ception'=7; struct.error is a direct subclass of Exception (not OSError or ValueError or other specific exception class); the MRO is: struct.error → Exception → BaseException → object; struct_extra161 anchors error.__bases__[0].__name__=='Exception'; 'Exception'(9) > 'error'(5) by 4 chars); error.__module__ is 'struct' (6 chars; struct.error is part of the 'struct' module; error.__module__(6) == 'struct'(6) — the module name has the same 6 chars as the word 'struct'; struct_extra161 anchors error.__module__=='struct'; first structinit165 anchor for error class identity)"
  kind: python_call_eq
  category: identity
  id_prefix: structinit165

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_error,          "error.__name__.__eq__",            ["error"],     true, "struct.error.__name__ == 'error' (5 chars; lowercase; struct_extra161 anchors as table row; confirmed via __eq__ here under structinit165)"]
    - [error_base_exception,      "error.__bases__[0].__name__.__eq__", ["Exception"], true, "struct.error.__bases__[0].__name__ == 'Exception' (9 chars; direct subclass of Exception; struct_extra161 anchors; 'Exception'(9) > 'error'(5) by 4)"]
    - [error_module_struct,       "error.__module__.__eq__",          ["struct"],    true, "struct.error.__module__ == 'struct' (6 chars; struct_extra161 anchors as table row; error.__module__(6)=='struct'(6) — same 6 chars)"]

