table struct_extra165.Struct_dunder_name_lengths:
  description: "struct.Struct.__dict__.__contains__('__new__')==True / Struct.__dict__.__contains__('__init__')==True / Struct.__dict__.__contains__('iter_unpack')==True / Struct.__dict__.__len__()==16 — Struct.__dict__.__contains__('__new__') is True (confirmed; '__new__'=7 chars = '__'=2 + 'new'=3 + '__'=2; 'new'(3 chars) is a short word; '__new__'(7) < '__init__'(8) by 1 char — 'new'(3) < 'init'(4) by 1 char; novel anchor: struct_extra163 does not anchor '__new__' membership); Struct.__dict__.__contains__('__init__') is True (confirmed; '__init__'=8 chars = '__'=2 + 'init'=4 + '__'=2; 'init'(4) > 'new'(3) by 1; '__init__'(8) is the longest dunder name in Struct.__dict__ that is alphabetically first among the 9 dunders in terms of 'inner name' length: 'del'=3, 'doc'=3, 'getattribute'=12, 'init'=4, 'module'=6, 'new'=3, 'repr'=4, 'setattr'=7, 'sizeof'=6); Struct.__dict__.__contains__('iter_unpack') is True (confirmed; 'iter_unpack'=11 chars; struct_extra163 anchors; longest non-dunder name in Struct.__dict__ tied with 'unpack_from'=11); Struct.__dict__.__len__() is 16 (confirmed; 16 total keys: 9 dunders + 7 non-dunders; struct_extra160 anchors __len__()==16; 'pack'(4) is the shortest non-dunder name, '__new__'(7) is shorter than '__init__'(8) among dunders; first structinit165 anchor for __new__/__init__ name length comparison)"
  kind: python_call_eq
  category: identity
  id_prefix: structinit165

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_new_b,         "Struct.__dict__.__contains__", ["__new__"],     true, "struct.Struct.__dict__.__contains__('__new__') == True (confirmed; '__new__'=7 chars; '__new__'(7) < '__init__'(8) by 1 char; novel anchor)"]
    - [dict_has_init_b,        "Struct.__dict__.__contains__", ["__init__"],    true, "struct.Struct.__dict__.__contains__('__init__') == True (confirmed; '__init__'=8 chars; '__init__'(8) > '__new__'(7) by 1 char; novel anchor)"]
    - [dict_has_iter_unpack,   "Struct.__dict__.__contains__", ["iter_unpack"], true, "struct.Struct.__dict__.__contains__('iter_unpack') == True (confirmed; 'iter_unpack'=11 chars; tied longest non-dunder; struct_extra163 anchors)"]
    - [dict_len_16_d,          "Struct.__dict__.__len__",       [],              16,  "struct.Struct.__dict__.__len__() is 16 (confirmed; 9 dunders + 7 non-dunders = 16 total; struct_extra160 anchors __len__()==16)"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__init__') — standalone
#
# struct.Struct.__dict__.__contains__('__init__') is True. '__init__' is one of the 9 dunder
# methods in struct.Struct's mappingproxy. Struct.__init__ is called when a Struct(fmt) is
# created and performs the format string parsing and compilation into an internal C state.
# '__init__' (8 chars) = '__'=2 + 'init'=4 + '__'=2. Novel: struct_extra163 does not
# anchor '__init__' membership. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra165.Struct_dict_contains_init:
  description: "struct.Struct.__dict__.__contains__('__init__') == True — '__init__' (8 chars = '__'=2 + 'init'=4 + '__'=2; Struct.__init__ accepts a format string and pre-compiles it; the format string determines the byte layout and Python type correspondence; '__init__'(8) > '__new__'(7) by 1 char — 'init'(4) > 'new'(3) by 1 char; Struct.__dict__ has 16 keys total; struct_extra163 does not anchor '__init__' membership via __contains__ — novel anchor; struct_extra160 anchors Struct.__dict__ membership for non-dunder keys; first structinit165 standalone for Struct.__dict__.__contains__('__init__')"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__new__') — standalone
#
# struct.Struct.__dict__.__contains__('__new__') is True. '__new__' is one of the 9 dunder
# methods in struct.Struct's mappingproxy. Struct.__new__ allocates the Struct object before
# __init__ is called. '__new__' (7 chars) = '__'=2 + 'new'=3 + '__'=2. '__new__'(7) is 1 char
# shorter than '__init__'(8). Novel: struct_extra163 does not anchor '__new__' membership.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra165.Struct_dict_contains_new:
  description: "struct.Struct.__dict__.__contains__('__new__') == True — '__new__' (7 chars = '__'=2 + 'new'=3 + '__'=2; Struct.__new__ allocates the Struct object before __init__ is called; 'new'(3 chars) is the shortest non-dunder-delimiter component: 'new'(3)=='del'(3)=='doc'(3) in inner name length among Struct dunders; '__new__'(7) < '__init__'(8) by 1 char; Struct.__dict__ has 16 keys total; struct_extra163 does not anchor '__new__' membership via __contains__ — novel anchor; first structinit165 standalone for Struct.__dict__.__contains__('__new__')"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__new__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error') — standalone
#
# struct.error.__name__ is 'error' (5 chars). struct.error is the exception class raised
# when packing or unpacking fails (e.g., format string mismatch, buffer too small).
# It is named with a lowercase 'e', which is unusual among Python exceptions. 'error' (5 chars)
# = 'e'=1 + 'rror'=4. struct_extra161 anchors error.__name__=='error' as a table row;
# this standalone uses __eq__ method call syntax under structinit165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra165.error_name_eq_error:
  description: "struct.error.__name__.__eq__('error') == True — 'error' (5 chars; lowercase 'e' — unusual for Python exceptions which typically use CamelCase; struct.error is raised when struct.pack/unpack/pack_into/unpack_from fail due to format mismatch or buffer size issues; 'error'(5) < 'struct'(6) < 'Exception'(9) in length: error name is shorter than its module name and its base class name; struct_extra161 anchors error.__name__=='error' as a table row; first structinit165 standalone for error.__name__.__eq__('error')"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error.__bases__[0].__name__ is 'Exception' (9 chars). struct.error is a direct
# subclass of the built-in Exception class (not OSError, ValueError, or any other specific
# exception). The MRO is: struct.error → Exception → BaseException → object.
# 'Exception' (9 chars) = 'Ex'=2 + 'ception'=7. struct_extra161 anchors this as a table row.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra165.error_base_eq_Exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — 'Exception' (9 chars = 'Ex'=2 + 'ception'=7; struct.error is a direct subclass of Exception; MRO: struct.error → Exception → BaseException → object; 'Exception'(9) > 'error'(5) by 4 chars — the base class name is longer than the exception's own name; 'Exception'(9) > 'struct'(6) by 3; struct_extra161 anchors this as a table row; first structinit165 standalone for error.__bases__[0].__name__.__eq__('Exception')"
  category: identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__module__.__eq__('struct') — standalone
#
# struct.error.__module__ is 'struct' (6 chars). struct.error is defined in the 'struct'
# module. error.__module__ (6 chars) == 'struct'.__len__() (6 chars) — the module name
# is 6 chars, same as the string 'struct' itself. struct_extra161 anchors error.__module__==
# 'struct' as a table row; this standalone uses __eq__ method call syntax under structinit165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra165.error_module_eq_struct:
  description: "struct.error.__module__.__eq__('struct') == True — 'struct' (6 chars; struct.error is defined in the struct module; error.__module__(6)=='struct'(6) — module name and the word 'struct' are the same 6-char string; 'struct'(6) > 'error'(5) by 1 char — module name is 1 char longer than the exception's own name; 'struct'(6) < 'Exception'(9) by 3 chars; struct_extra161 anchors error.__module__=='struct' as a table row; first structinit165 standalone for error.__module__.__eq__('struct')"
  category: identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

