spec: struct_extra165
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra164.zspec.zsdl — covers struct module-level function __name__.__len__() integer values for all six functions: pack(4)/unpack(6)/calcsize(8)/pack_into(9)/unpack_from(11)/iter_unpack(11) and module lengths (table + invariants)."
    - "struct_extra163.zspec.zsdl — covers struct.pack/__unpack class names ('builtin_function_or_method') and struct.Struct.__dict__.__contains__ for pack/unpack/size/format/pack_into/iter_unpack/unpack_from and __len__()==16 (table + invariants)."
    - "struct_extra162.zspec.zsdl — covers struct.pack/__unpack/__pack_into/__unpack_from/__iter_unpack/__calcsize .__name__/__module__ (module-level function identity); pack.__class__.__name__ (table + invariants)."
    - "struct_extra161.zspec.zsdl — covers struct.error/__Struct class identity (__name__/__module__/__bases__) (table + invariants)."
    - "struct_extra160.zspec.zsdl — covers struct.Struct.__dict__ membership and meta-attributes (__len__()==16/__class__.__name__=='mappingproxy') (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra164."
    - "Wave 351 theme: struct.Struct.__dict__ dunder membership (__init__/__new__) and struct.error class identity (__name__/__bases__[0].__name__/__module__). struct_extra163 anchors Struct.__dict__.__contains__ for pack/unpack/pack_into/iter_unpack/unpack_from/size/format — this spec covers __init__ and __new__ which are novel dunder members. struct_extra161 anchors struct.error.__name__=='error' and struct.error.__module__=='struct' as table rows; this spec anchors them via __eq__ method call syntax as the primary novel anchor."
    - "struct.Struct.__dict__.__contains__('pack_into') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. (Confirmed; struct_extra163 anchors this.)"
    - "struct.Struct.__dict__.__contains__('unpack_from') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. (Confirmed; struct_extra163 anchors this.)"
    - "struct.Struct.__dict__.__contains__('iter_unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. (Confirmed; struct_extra163 anchors this.)"
    - "struct.Struct.__dict__.__contains__('__init__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. (Novel anchor — not covered by struct_extra163.)"
    - "struct.Struct.__dict__.__contains__('__new__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. (Novel anchor — not covered by struct_extra163.)"
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__dict__ has 16 keys total: __delattr__/__doc__/__getattribute__/__init__/__module__/__new__/__repr__/__setattr__/__sizeof__ (9 dunders) + format/iter_unpack/pack/pack_into/size/unpack/unpack_from (7 non-dunders). struct_extra163 anchors pack/unpack/pack_into/iter_unpack/unpack_from/size/format membership; this spec adds __init__ and __new__ as novel dunder members."
    - "Note: struct.error.__name__ == 'error' (5 chars; lowercase 'e' — struct.error is a bare lowercase name, unlike OSError/ValueError which are CamelCase). struct.error.__bases__[0].__name__ == 'Exception' (9 chars). struct.error.__module__ == 'struct' (6 chars). struct_extra161 anchors these via table rows; this spec anchors via __eq__ method syntax."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__init__')
# struct.Struct.__dict__.__contains__('__new__')
# struct.Struct.__dict__.__contains__('pack_into')
# struct.Struct.__dict__.__contains__('unpack_from')
#
# Wave 351 theme: Struct.__dict__ dunder membership for __init__ and __new__ (novel).
#
# Struct.__dict__.__contains__('__init__') == True (__init__ customizes Struct initialization).
# Struct.__dict__.__contains__('__new__') == True (__new__ creates a new Struct instance).
# Struct.__dict__.__contains__('pack_into') == True (confirmed; struct_extra163 anchors).
# Struct.__dict__.__contains__('unpack_from') == True (confirmed; struct_extra163 anchors).
# The novel content is __init__ and __new__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra165.Struct_dict_init_new_and_confirmed:
  description: "struct.Struct.__dict__.__contains__('__init__')==True / Struct.__dict__.__contains__('__new__')==True / Struct.__dict__.__contains__('pack_into')==True / Struct.__dict__.__contains__('unpack_from')==True — Struct.__dict__.__contains__('__init__') is True ('__init__' is a key in struct.Struct.__dict__; '__init__' is the instance initialization method called after __new__ creates the object; Struct.__init__ accepts a format string and pre-compiles it into an internal C representation; '__init__'(8 chars) = '__'=2 + 'init'=4 + '__'=2; novel anchor: struct_extra163 does not anchor '__init__' membership via __contains__); Struct.__dict__.__contains__('__new__') is True ('__new__' is a key in struct.Struct.__dict__; '__new__' is the class constructor method that allocates a new Struct instance before __init__ is called; '__new__'(7 chars) = '__'=2 + 'new'=3 + '__'=2; '__new__'(7) < '__init__'(8) by 1 char — 'new'(3) < 'init'(4) by 1 char; novel anchor: struct_extra163 does not anchor '__new__' membership); Struct.__dict__.__contains__('pack_into') is True (confirmed; 'pack_into' is a key in Struct.__dict__; struct_extra163 anchors this membership via __contains__; 'pack_into'(9 chars) is the longest non-dunder method name in Struct.__dict__ along with 'unpack_from'(11) and 'iter_unpack'(11)); Struct.__dict__.__contains__('unpack_from') is True (confirmed; struct_extra163 anchors; 'unpack_from'(11 chars) is tied for longest non-dunder name in Struct.__dict__ with 'iter_unpack'(11); first structinit165 anchor for __init__/__new__ Struct dict membership)"
  kind: python_call_eq
  category: identity
  id_prefix: structinit165

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_init,        "Struct.__dict__.__contains__", ["__init__"],    true, "struct.Struct.__dict__.__contains__('__init__') == True ('__init__'=8 chars; Struct initialization; novel anchor; struct_extra163 does not anchor '__init__' membership)"]
    - [dict_has_new,         "Struct.__dict__.__contains__", ["__new__"],     true, "struct.Struct.__dict__.__contains__('__new__') == True ('__new__'=7 chars; Struct allocation; novel anchor; struct_extra163 does not anchor '__new__' membership)"]
    - [dict_has_pack_into,   "Struct.__dict__.__contains__", ["pack_into"],   true, "struct.Struct.__dict__.__contains__('pack_into') == True (confirmed; 'pack_into'=9 chars; struct_extra163 anchors this membership)"]
    - [dict_has_unpack_from, "Struct.__dict__.__contains__", ["unpack_from"], true, "struct.Struct.__dict__.__contains__('unpack_from') == True (confirmed; 'unpack_from'=11 chars; struct_extra163 anchors this membership)"]

# ---------------------------------------------------------------------------
