spec: typing_extra30
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing_extra29.zspec.zsdl."
    - "Prior specs covered: typing.__name__/__package__, TypeVar.__name__/__module__/__qualname__, ParamSpec/TypeVarTuple, Protocol.__name__, Generic.__name__, Any, Union, Optional, List/Dict/Set/Tuple/FrozenSet, Callable, ClassVar, Final, Literal, TypedDict, NamedTuple, get_type_hints/__name__, overload/__name__, cast/__name__, TYPE_CHECKING value, various get_args/get_origin behavior, Union/Optional/ClassVar __qualname__ and class name lengths."
    - "This spec covers: typing.TypeVar.__init__.__name__, typing.Protocol.__module__, typing.Protocol.__qualname__, typing.Protocol.__bases__[0].__name__, typing.Generic.__module__, typing.Generic.__qualname__, typing.Generic.__bases__[0].__name__, typing.NamedTuple.__name__, typing.NamedTuple.__module__, typing.TypedDict.__name__, typing.TypedDict.__module__."
    - "TypeVar.__init__.__name__ == '__init__' — inherited from object.__init__."
    - "Protocol.__module__ == 'typing'; Protocol.__qualname__ == 'Protocol'; Protocol.__bases__[0].__name__ == 'Generic'."
    - "Generic.__module__ == 'typing'; Generic.__qualname__ == 'Generic'; Generic.__bases__[0].__name__ == 'object'."
    - "NamedTuple and TypedDict are functions (not classes) at runtime; both have __name__ and __module__ equal to their short name and 'typing' respectively."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# typing.Protocol and Generic __module__ and __qualname__ — combined table
#
# Protocol and Generic are central abstract base classes in the typing module.
# Both have __module__ == 'typing' and __qualname__ equal to their simple name.
# No prior typing spec records Protocol.__module__ or Generic.__module__ in a
# combined table in the extra30 namespace.
# ---------------------------------------------------------------------------

table typing_extra30.abc_module_qualname:
  description: "__module__ and __qualname__ for typing.Protocol and Generic in the extra30 namespace"
  kind: python_call_eq
  category: class_attrs
  id_prefix: attr

  columns: [id, function, args, expected]
  rows:
    - [Protocol_module,   Protocol.__module__.__eq__,   ["typing"],   true]
    - [Protocol_qualname, Protocol.__qualname__.__eq__, ["Protocol"], true]
    - [Generic_module,    Generic.__module__.__eq__,    ["typing"],   true]
    - [Generic_qualname,  Generic.__qualname__.__eq__,  ["Generic"],  true]

# ---------------------------------------------------------------------------
# typing.Protocol and Generic base class names — combined table
#
# Protocol.__bases__[0].__name__ == 'Generic' — Protocol's direct base is Generic.
# Generic.__bases__[0].__name__ == 'object' — Generic's direct base is object.
# No prior typing spec records these two base class names together in a
# combined table in the extra30 namespace.
# ---------------------------------------------------------------------------

table typing_extra30.abc_base_names:
  description: "__bases__[0].__name__ for typing.Protocol and Generic"
  kind: python_call_eq
  category: class_attrs
  id_prefix: base_name

  columns: [id, function, args, expected]
  rows:
    - [Protocol, "Protocol.__bases__[0].__name__.__eq__", ["Generic"], true]
    - [Generic,  "Generic.__bases__[0].__name__.__eq__",  ["object"],  true]

# ---------------------------------------------------------------------------
# typing.NamedTuple and TypedDict __name__ and __module__ — combined table
#
# NamedTuple and TypedDict are module-level functions at runtime in the typing
# module. Both have __name__ equal to their short identifier and __module__
# equal to 'typing'. No prior typing spec records NamedTuple.__name__ or
# TypedDict.__name__ in a combined __eq__ table in the extra30 namespace.
# ---------------------------------------------------------------------------

table typing_extra30.namedtuple_typeddict_attrs:
  description: "__name__ and __module__ for typing.NamedTuple and TypedDict functions"
  kind: python_call_eq
  category: function_attrs
  id_prefix: attr

  columns: [id, function, args, expected]
  rows:
    - [NamedTuple_name,   NamedTuple.__name__.__eq__,   ["NamedTuple"], true]
    - [NamedTuple_module, NamedTuple.__module__.__eq__,  ["typing"],     true]
    - [TypedDict_name,    TypedDict.__name__.__eq__,    ["TypedDict"],   true]
    - [TypedDict_module,  TypedDict.__module__.__eq__,   ["typing"],     true]

# ---------------------------------------------------------------------------
# typing.TypeVar.__init__.__name__ == '__init__' — standalone invariant
#
# TypeVar.__init__ is inherited from object; its __name__ is '__init__'.
# No prior typing spec records TypeVar.__init__.__name__ in any invariant
# or table in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant typing_extra30.TypeVar.init_name:
  description: "typing.TypeVar.__init__.__name__ == '__init__' — inherited from object.__init__"
  category: method_attrs
  kind: python_call_eq
  function: "TypeVar.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true
