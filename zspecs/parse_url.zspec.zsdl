spec: parse_url
version: ">=1.0.0"
backend: node(parse-url)

docs: https://www.npmjs.com/package/parse-url

provenance:
  derived_from:
    - "parse-url README — https://www.npmjs.com/package/parse-url"
    - "Test vectors verified with parse-url via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "parse-url source"
  notes:
    - "parse-url is an npm package. Install: npm install parse-url"
    - "parseUrl(str) parses a URL and returns a structured object."
    - "Returns protocols, port, resource, host, user, password, pathname, hash, search, href, query, parse_failed."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns parsed URL object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table parse_url.parse:
  kind: node_module_call_eq
  function: ~
  category: parse
  id_prefix: purl

  columns: [id, args, expected]
  rows:
    - [full, ["https://user:pass@example.com:8080/path?q=1#hash"],
       {"protocols": ["https"], "protocol": "https", "port": "8080",
        "resource": "example.com", "host": "example.com:8080",
        "user": "user", "password": "pass", "pathname": "/path",
        "hash": "hash", "search": "q=1",
        "href": "https://user:pass@example.com:8080/path?q=1#hash",
        "query": {"q": "1"}, "parse_failed": false}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:36:55Z
  iterations: 1
  pass_count: 1
  fail_count: 0
  total_invariants: 1
  notes: Synthesis succeeded in 1 iteration(s). 1 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
