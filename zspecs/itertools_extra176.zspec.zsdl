spec: itertools_extra176
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.starmap and zip_longest identity — itertools.starmap.__name__=='starmap' (len=7); itertools.starmap.__module__=='itertools'; itertools.starmap.__mro__.__len__()==2; itertools.zip_longest.__name__=='zip_longest' (len=11); itertools.zip_longest.__mro__.__len__()==2; itertools.dropwhile.__name__=='dropwhile' (len=9); itertools.takewhile.__name__=='takewhile' (len=9; same as dropwhile); itertools.filterfalse.__name__=='filterfalse' (len=11; same as zip_longest)."
    - "itertools.starmap.__name__ == 'starmap' — starmap is a C extension type in itertoolsmodule.c; it makes an iterator that computes the function using arguments from the iterable; its __name__ is 'starmap', 7 characters. Verified with Python 3.14.3."
    - "itertools.starmap.__module__ == 'itertools' — starmap is defined in the itertools C extension module. Verified with Python 3.14.3."
    - "itertools.starmap.__mro__.__len__() == 2 — starmap is a C extension type inheriting directly from object; its MRO is (starmap, object). Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest' — zip_longest is a C extension type in itertoolsmodule.c that zips iterables and fills missing values with a fillvalue; its __name__ is 'zip_longest', 11 characters. Verified with Python 3.14.3."
    - "itertools.zip_longest.__mro__.__len__() == 2 — zip_longest is a C extension type inheriting directly from object; its MRO is (zip_longest, object). Verified with Python 3.14.3."
    - "itertools.dropwhile.__name__ == 'dropwhile' — dropwhile is a C extension type; its __name__ is 'dropwhile', 9 characters. Verified with Python 3.14.3."
    - "itertools.takewhile.__name__ == 'takewhile' — takewhile is a C extension type; its __name__ is 'takewhile', 9 characters, same length as 'dropwhile'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__name__ == 'filterfalse' — filterfalse is a C extension type; its __name__ is 'filterfalse', 11 characters, same length as 'zip_longest'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.starmap class __name__ and __module__
#
# itertools.starmap.__name__ == 'starmap'
# itertools.starmap.__name__.__len__() == 7
# itertools.starmap.__module__ == 'itertools'
# itertools.starmap.__module__.__len__() == 9
#
# itertools.starmap is a C extension type defined in itertoolsmodule.c that
# computes the function using arguments obtained from each element of the
# iterable (each element is expected to be a tuple). Its __name__ is 'starmap'
# (7 chars) and its __module__ is 'itertools' (9 chars). New to extra176.
# ---------------------------------------------------------------------------

table itertools_extra176.starmap_name_and_module:
  description: "itertools.starmap.__name__ 'starmap' len 7; __module__ 'itertools' len 9; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: iterstarmap176

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_name_eq,
       "starmap.__name__.__eq__",
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — itertools.starmap is a C extension type in itertoolsmodule.c that makes an iterator computing a function using arguments drawn from an iterable of tuples; its __name__ is 'starmap'; str.__eq__('starmap') returns True; new to extra176"]
    - [starmap_name_len_7,
       "starmap.__name__.__len__",
       [],
       7,
       "itertools.starmap.__name__.__len__() == 7 — the name 'starmap' has exactly 7 characters: s-t-a-r-m-a-p; str.__len__() returns 7; new to extra176"]
    - [starmap_module_itertools,
       "starmap.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.starmap.__module__.__eq__('itertools') == True — itertools.starmap is a C extension type defined in the itertools module (itertoolsmodule.c); its __module__ is the string 'itertools'; str.__eq__('itertools') returns True; new to extra176"]
    - [starmap_module_len_9,
       "starmap.__module__.__len__",
       [],
       9,
       "itertools.starmap.__module__.__len__() == 9 — the module name 'itertools' has exactly 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; new to extra176"]

# ---------------------------------------------------------------------------
# Table 2: itertools.starmap __mro__ and itertools.zip_longest __name__
#
# itertools.starmap.__mro__.__len__() == 2
# itertools.starmap.__mro__[0].__name__ == 'starmap'
# itertools.zip_longest.__name__ == 'zip_longest'
# itertools.zip_longest.__name__.__len__() == 11
#
# starmap's MRO is (starmap, object) — it inherits directly from object like
# all itertools C types. zip_longest is another C extension type whose __name__
# is 'zip_longest' (11 chars). New to extra176.
# ---------------------------------------------------------------------------

table itertools_extra176.starmap_mro_and_zip_longest_name:
  description: "itertools.starmap.__mro__ len 2, mro[0] 'starmap'; zip_longest.__name__ 'zip_longest' len 11; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: iterstarmap176

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_mro_len_2,
       "starmap.__mro__.__len__",
       [],
       2,
       "itertools.starmap.__mro__.__len__() == 2 — itertools.starmap is a C extension type defined in itertoolsmodule.c that inherits directly from object with no intermediate base classes; its __mro__ is (starmap, object), a tuple of length 2; tuple.__len__() returns 2; new to extra176"]
    - ["starmap_mro_0_starmap",
       "starmap.__mro__[0].__name__.__eq__",
       ["starmap"],
       true,
       "itertools.starmap.__mro__[0].__name__.__eq__('starmap') == True — the first entry in starmap.__mro__ is the starmap class itself; its __name__ is 'starmap'; str.__eq__('starmap') returns True; new to extra176"]
    - [zip_longest_name_eq,
       "zip_longest.__name__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — itertools.zip_longest is a C extension type in itertoolsmodule.c that aggregates elements from multiple iterables, filling missing values with a fillvalue; its __name__ is 'zip_longest'; str.__eq__('zip_longest') returns True; new to extra176"]
    - [zip_longest_name_len_11,
       "zip_longest.__name__.__len__",
       [],
       11,
       "itertools.zip_longest.__name__.__len__() == 11 — the name 'zip_longest' has exactly 11 characters: z-i-p-_-l-o-n-g-e-s-t; str.__len__() returns 11; new to extra176"]

# ---------------------------------------------------------------------------
# Table 3: itertools.zip_longest __mro__ and itertools.dropwhile __name__
#
# itertools.zip_longest.__mro__.__len__() == 2
# itertools.zip_longest.__mro__[0].__name__ == 'zip_longest'
# itertools.dropwhile.__name__ == 'dropwhile'
# itertools.dropwhile.__name__.__len__() == 9
#
# zip_longest's MRO is (zip_longest, object), length 2. dropwhile is a C
# extension type whose __name__ is 'dropwhile' (9 chars). New to extra176.
# ---------------------------------------------------------------------------

table itertools_extra176.zip_longest_mro_and_dropwhile_name:
  description: "itertools.zip_longest.__mro__ len 2, mro[0] 'zip_longest'; dropwhile.__name__ 'dropwhile' len 9; new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: iterstarmap176

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_mro_len_2,
       "zip_longest.__mro__.__len__",
       [],
       2,
       "itertools.zip_longest.__mro__.__len__() == 2 — itertools.zip_longest is a C extension type defined in itertoolsmodule.c that inherits directly from object with no intermediate base classes; its __mro__ is (zip_longest, object), a tuple of length 2; tuple.__len__() returns 2; new to extra176"]
    - ["zip_longest_mro_0_zip_longest",
       "zip_longest.__mro__[0].__name__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__mro__[0].__name__.__eq__('zip_longest') == True — the first entry in zip_longest.__mro__ is the zip_longest class itself; its __name__ is 'zip_longest'; str.__eq__('zip_longest') returns True; new to extra176"]
    - [dropwhile_name_eq,
       "dropwhile.__name__.__eq__",
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__.__eq__('dropwhile') == True — itertools.dropwhile is a C extension type in itertoolsmodule.c that drops elements from the iterable as long as a predicate is true; it then yields every remaining element; its __name__ is 'dropwhile'; str.__eq__('dropwhile') returns True; new to extra176"]
    - [dropwhile_name_len_9,
       "dropwhile.__name__.__len__",
       [],
       9,
       "itertools.dropwhile.__name__.__len__() == 9 — the name 'dropwhile' has exactly 9 characters: d-r-o-p-w-h-i-l-e; str.__len__() returns 9; new to extra176"]

# ---------------------------------------------------------------------------
# Table 4: itertools.takewhile and itertools.filterfalse __name__
#
# itertools.takewhile.__name__ == 'takewhile'
# itertools.takewhile.__name__.__len__() == 9
# itertools.filterfalse.__name__ == 'filterfalse'
# itertools.filterfalse.__name__.__len__() == 11
#
# takewhile is a C extension type whose __name__ is 'takewhile' (9 chars,
# same length as 'dropwhile'). filterfalse is a C extension type whose __name__
# is 'filterfalse' (11 chars, same length as 'zip_longest'). New to extra176.
# ---------------------------------------------------------------------------

table itertools_extra176.takewhile_and_filterfalse_name:
  description: "itertools.takewhile.__name__ 'takewhile' len 9; filterfalse.__name__ 'filterfalse' len 11 (same as zip_longest); new to extra176"
  kind: python_call_eq
  category: identity
  id_prefix: iterstarmap176

  columns: [id, function, args, expected, description]
  rows:
    - [takewhile_name_eq,
       "takewhile.__name__.__eq__",
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — itertools.takewhile is a C extension type in itertoolsmodule.c that yields elements from the iterable as long as a predicate is true; once the predicate is false it stops; its __name__ is 'takewhile'; str.__eq__('takewhile') returns True; new to extra176"]
    - [takewhile_name_len_9,
       "takewhile.__name__.__len__",
       [],
       9,
       "itertools.takewhile.__name__.__len__() == 9 — the name 'takewhile' has exactly 9 characters: t-a-k-e-w-h-i-l-e; same length as 'dropwhile' (9); str.__len__() returns 9; new to extra176"]
    - [filterfalse_name_eq,
       "filterfalse.__name__.__eq__",
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__.__eq__('filterfalse') == True — itertools.filterfalse is a C extension type in itertoolsmodule.c that makes an iterator yielding elements from the iterable for which a predicate returns False; its __name__ is 'filterfalse'; str.__eq__('filterfalse') returns True; new to extra176"]
    - [filterfalse_name_len_11,
       "filterfalse.__name__.__len__",
       [],
       11,
       "itertools.filterfalse.__name__.__len__() == 11 — the name 'filterfalse' has exactly 11 characters: f-i-l-t-e-r-f-a-l-s-e; same length as 'zip_longest' (11); str.__len__() returns 11; new to extra176"]

