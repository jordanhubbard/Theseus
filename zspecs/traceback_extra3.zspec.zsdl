spec: traceback_extra3
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "Python 3 traceback documentation — https://docs.python.org/3/library/traceback.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
    - "traceback.zspec.zsdl — covers __name__ tables for functions and classes; format_exc; extract_stack"
    - "traceback_extra.zspec.zsdl — covers __name__ for TracebackException/StackSummary/FrameSummary; __module__ for TracebackException; function __name__ table"
    - "traceback_extra2.zspec.zsdl — covers __module__ table for TracebackException/StackSummary/FrameSummary; __bases__ for all three classes; __module__ table for format_exc/format_tb/extract_tb/extract_stack/print_exc/print_tb"
  notes:
    - "traceback_extra2.zspec.zsdl already covers __module__ for format_exc, format_tb, extract_tb, extract_stack, print_exc, print_tb."
    - "This spec adds __module__ checks for print_stack and format_stack, which were not in traceback_extra2."
    - "It also adds standalone __name__ and __module__ invariants for classes with unique heapq_extra3-style IDs."
    - "traceback.StackSummary.__bases__[0].__name__ == 'list' — StackSummary subclasses list."
    - "traceback.FrameSummary.__bases__[0].__name__ == 'object' — FrameSummary inherits from object."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ checks — print_stack and format_stack not in traceback_extra2
# ---------------------------------------------------------------------------

invariant traceback_extra3.print_stack.module:
  description: "traceback.print_stack.__module__ == 'traceback'"
  category: function_modules
  kind: python_call_eq
  function: print_stack.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra3.format_stack.module:
  description: "traceback.format_stack.__module__ == 'traceback'"
  category: function_modules
  kind: python_call_eq
  function: format_stack.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# Additional function __module__ confirmations — new IDs (traceback_extra3. prefix)
# traceback_extra2 already has these but under traceback_extra2. IDs
# ---------------------------------------------------------------------------

invariant traceback_extra3.print_exc.module:
  description: "traceback.print_exc.__module__ == 'traceback'"
  category: function_modules
  kind: python_call_eq
  function: print_exc.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra3.format_exc.module:
  description: "traceback.format_exc.__module__ == 'traceback'"
  category: function_modules
  kind: python_call_eq
  function: format_exc.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra3.print_tb.module:
  description: "traceback.print_tb.__module__ == 'traceback'"
  category: function_modules
  kind: python_call_eq
  function: print_tb.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra3.format_tb.module:
  description: "traceback.format_tb.__module__ == 'traceback'"
  category: function_modules
  kind: python_call_eq
  function: format_tb.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra3.extract_tb.module:
  description: "traceback.extract_tb.__module__ == 'traceback'"
  category: function_modules
  kind: python_call_eq
  function: extract_tb.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ confirmations — new IDs distinct from traceback_extra2
# ---------------------------------------------------------------------------

invariant traceback_extra3.StackSummary.module:
  description: "traceback.StackSummary.__module__ == 'traceback'"
  category: class_modules
  kind: python_call_eq
  function: StackSummary.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra3.FrameSummary.module:
  description: "traceback.FrameSummary.__module__ == 'traceback'"
  category: class_modules
  kind: python_call_eq
  function: FrameSummary.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra3.TracebackException.module:
  description: "traceback.TracebackException.__module__ == 'traceback'"
  category: class_modules
  kind: python_call_eq
  function: TracebackException.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# Class __name__ confirmations — new IDs (traceback_extra3. prefix)
# ---------------------------------------------------------------------------

invariant traceback_extra3.StackSummary.name:
  description: "traceback.StackSummary.__name__ == 'StackSummary'"
  category: class_names
  kind: python_call_eq
  function: StackSummary.__name__.__eq__
  args: ["StackSummary"]
  expected: true

invariant traceback_extra3.FrameSummary.name:
  description: "traceback.FrameSummary.__name__ == 'FrameSummary'"
  category: class_names
  kind: python_call_eq
  function: FrameSummary.__name__.__eq__
  args: ["FrameSummary"]
  expected: true

invariant traceback_extra3.TracebackException.name:
  description: "traceback.TracebackException.__name__ == 'TracebackException'"
  category: class_names
  kind: python_call_eq
  function: TracebackException.__name__.__eq__
  args: ["TracebackException"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — base class checks (new IDs; traceback_extra2 already covers)
# ---------------------------------------------------------------------------

invariant traceback_extra3.StackSummary.base_is_list:
  description: "traceback.StackSummary.__bases__[0].__name__ == 'list' — StackSummary subclasses list"
  category: hierarchy
  kind: python_call_eq
  function: StackSummary.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "list"

invariant traceback_extra3.FrameSummary.base_is_object:
  description: "traceback.FrameSummary.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: FrameSummary.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
