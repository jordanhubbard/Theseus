spec: functools_extra210
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers MRO (method resolution order) of functools classes: partial, partialmethod, cached_property."
    - "functools.partial.__mro__ is a 2-tuple: (partial, object). partial is a C-extension type defined in Modules/_functoolsmodule.c; it inherits directly from object with no intermediate class."
    - "functools.partialmethod.__mro__ is a 2-tuple: (partialmethod, object). partialmethod is a pure-Python class defined in Lib/functools.py; it likewise inherits directly from object."
    - "functools.cached_property.__mro__ is a 2-tuple: (cached_property, object). cached_property is a pure-Python descriptor class in Lib/functools.py that inherits directly from object."
    - "All three classes have MRO length 2, consistent with single-inheritance from object and no mixin classes."
    - "functools.partial.__mro__[0].__name__ == 'partial' — the class itself is always the first entry in its own MRO."
    - "functools.partial.__mro__[1].__name__ == 'object' — object is always the last entry in any Python class MRO."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.partial MRO — type, length, and indexed name checks
#
# functools.partial.__mro__ == (<class 'functools.partial'>, <class 'object'>)
# len == 2, [0].__name__ == 'partial', [1].__name__ == 'object'
# ---------------------------------------------------------------------------

table functools_extra210.partial_mro:
  description: "functools.partial.__mro__ shape and indexed name checks — C-extension type, 2-entry MRO"
  kind: python_call_eq
  category: mro
  id_prefix: functmro210

  columns: [id, function, args, expected, description]
  rows:
    - [partial_mro_is_tuple,  partial.__mro__.__class__.__name__.__eq__,  ["tuple"],   true,    "partial.__mro__.__class__.__name__ == 'tuple'"]
    - [partial_mro_len,       partial.__mro__.__len__,                    [],          2,       "len(partial.__mro__) == 2"]
    - [partial_mro0_name,     "partial.__mro__[0].__name__.__eq__",       ["partial"], true,    "partial.__mro__[0].__name__ == 'partial'"]
    - [partial_mro1_name,     "partial.__mro__[1].__name__.__eq__",       ["object"],  true,    "partial.__mro__[1].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# functools.partialmethod MRO — type, length, and indexed name checks
#
# functools.partialmethod.__mro__ == (<class 'functools.partialmethod'>, <class 'object'>)
# len == 2, [0].__name__ == 'partialmethod', [1].__name__ == 'object'
# ---------------------------------------------------------------------------

table functools_extra210.partialmethod_mro:
  description: "functools.partialmethod.__mro__ shape and indexed name checks — pure-Python class, 2-entry MRO"
  kind: python_call_eq
  category: mro
  id_prefix: functmro210

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_mro_is_tuple,  partialmethod.__mro__.__class__.__name__.__eq__,  ["tuple"],         true,  "partialmethod.__mro__.__class__.__name__ == 'tuple'"]
    - [partialmethod_mro_len,       partialmethod.__mro__.__len__,                    [],                2,     "len(partialmethod.__mro__) == 2"]
    - [partialmethod_mro0_name,     "partialmethod.__mro__[0].__name__.__eq__",       ["partialmethod"], true,  "partialmethod.__mro__[0].__name__ == 'partialmethod'"]
    - [partialmethod_mro1_name,     "partialmethod.__mro__[1].__name__.__eq__",       ["object"],        true,  "partialmethod.__mro__[1].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# functools.cached_property MRO — type, length, and indexed name checks
#
# functools.cached_property.__mro__ == (<class 'functools.cached_property'>, <class 'object'>)
# len == 2, [0].__name__ == 'cached_property', [1].__name__ == 'object'
# ---------------------------------------------------------------------------

table functools_extra210.cached_property_mro:
  description: "functools.cached_property.__mro__ shape and indexed name checks — pure-Python descriptor, 2-entry MRO"
  kind: python_call_eq
  category: mro
  id_prefix: functmro210

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_mro_is_tuple,  cached_property.__mro__.__class__.__name__.__eq__,  ["tuple"],            true,  "cached_property.__mro__.__class__.__name__ == 'tuple'"]
    - [cached_property_mro_len,       cached_property.__mro__.__len__,                    [],                   2,     "len(cached_property.__mro__) == 2"]
    - [cached_property_mro0_name,     "cached_property.__mro__[0].__name__.__eq__",       ["cached_property"],  true,  "cached_property.__mro__[0].__name__ == 'cached_property'"]
    - [cached_property_mro1_name,     "cached_property.__mro__[1].__name__.__eq__",       ["object"],           true,  "cached_property.__mro__[1].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant functools_extra210.partial_mro_is_tuple:
  description: "functools.partial.__mro__.__class__.__name__ == 'tuple' — MRO is always a tuple in CPython"
  category: mro
  kind: python_call_eq
  function: partial.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra210.partial_mro_len_eq_2:
  description: "len(functools.partial.__mro__) == 2 — partial inherits only from object; single-inheritance chain of length 2"
  category: mro
  kind: python_call_eq
  function: partial.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra210.partial_mro0_name:
  description: "functools.partial.__mro__[0].__name__ == 'partial' — first MRO entry is always the class itself"
  category: mro
  kind: python_call_eq
  function: "partial.__mro__[0].__name__.__eq__"
  args: ["partial"]
  expected: true

invariant functools_extra210.partial_mro1_name:
  description: "functools.partial.__mro__[1].__name__ == 'object' — second and final MRO entry is object"
  category: mro
  kind: python_call_eq
  function: "partial.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra210.partialmethod_mro_len_eq_2:
  description: "len(functools.partialmethod.__mro__) == 2 — partialmethod inherits only from object; same depth as partial"
  category: mro
  kind: python_call_eq
  function: partialmethod.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra210.partialmethod_mro0_name:
  description: "functools.partialmethod.__mro__[0].__name__ == 'partialmethod' — first MRO entry is the class itself"
  category: mro
  kind: python_call_eq
  function: "partialmethod.__mro__[0].__name__.__eq__"
  args: ["partialmethod"]
  expected: true

invariant functools_extra210.cached_property_mro_len_eq_2:
  description: "len(functools.cached_property.__mro__) == 2 — cached_property inherits only from object; no mixin classes"
  category: mro
  kind: python_call_eq
  function: cached_property.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra210.cached_property_mro0_name:
  description: "functools.cached_property.__mro__[0].__name__ == 'cached_property' — first MRO entry is the class itself"
  category: mro
  kind: python_call_eq
  function: "cached_property.__mro__[0].__name__.__eq__"
  args: ["cached_property"]
  expected: true
