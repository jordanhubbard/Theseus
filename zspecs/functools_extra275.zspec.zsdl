spec: functools_extra275
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.WRAPPER_ASSIGNMENTS is a 6-element tuple: ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__')."
    - "WRAPPER_ASSIGNMENTS[0]=='__module__'(len=10); [1]=='__name__'(8); [2]=='__qualname__'(12); [3]=='__doc__'(7 shortest); [4]=='__annotate__'(12); [5]=='__type_params__'(15 longest)."
    - "functools.partial.func, partial.args, and partial.keywords are all member_descriptor objects (C-level slot descriptors)."
    - "partial.func.__name__ == 'func' (len=4); partial.args.__name__ == 'args' (len=4); partial.keywords.__name__ == 'keywords' (len=8 longest)."
    - "partial.func.__qualname__ == 'partial.func'; partial.args.__qualname__ == 'partial.args'; partial.keywords.__qualname__ == 'partial.keywords'."
    - "functools.reduce.__doc__ is a non-empty str (len=389); functools.reduce.__doc__.__class__.__name__ == 'str'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.WRAPPER_ASSIGNMENTS elements identity
#
# 6-element tuple; shortest element is '__doc__'(7), longest is '__type_params__'(15).
# Elements in order: '__module__'(10), '__name__'(8), '__qualname__'(12),
#   '__doc__'(7), '__annotate__'(12), '__type_params__'(15).
# ---------------------------------------------------------------------------

table functools_extra275.wrapper_assignments_elements:
  description: "functools.WRAPPER_ASSIGNMENTS 6-element tuple elements — [0]='__module__'(10), [1]='__name__'(8), [2]='__qualname__'(12), [3]='__doc__'(7 shortest), [4]='__annotate__'(12), [5]='__type_params__'(15 longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex275wa

  columns: [id, function, args, expected, description]
  rows:
    - [wa_len,              WRAPPER_ASSIGNMENTS.__len__,                 [],                             6,    "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — tuple has 6 elements; verified with Python 3.14.3"]
    - [wa_cls_eq,           WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__, ["tuple"],                   true, "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [wa0_eq,              WRAPPER_ASSIGNMENTS.__getitem__(0).__eq__,   ["__module__"],                 true, "functools.WRAPPER_ASSIGNMENTS[0] == '__module__' (len=10); verified with Python 3.14.3"]
    - [wa0_len,             WRAPPER_ASSIGNMENTS.__getitem__(0).__len__,  [],                             10,   "functools.WRAPPER_ASSIGNMENTS[0].__len__() == 10 — '__module__' has 10 chars; verified with Python 3.14.3"]
    - [wa1_eq,              WRAPPER_ASSIGNMENTS.__getitem__(1).__eq__,   ["__name__"],                   true, "functools.WRAPPER_ASSIGNMENTS[1] == '__name__' (len=8); verified with Python 3.14.3"]
    - [wa1_len,             WRAPPER_ASSIGNMENTS.__getitem__(1).__len__,  [],                             8,    "functools.WRAPPER_ASSIGNMENTS[1].__len__() == 8 — '__name__' has 8 chars; verified with Python 3.14.3"]
    - [wa2_eq,              WRAPPER_ASSIGNMENTS.__getitem__(2).__eq__,   ["__qualname__"],               true, "functools.WRAPPER_ASSIGNMENTS[2] == '__qualname__' (len=12); verified with Python 3.14.3"]
    - [wa2_len,             WRAPPER_ASSIGNMENTS.__getitem__(2).__len__,  [],                             12,   "functools.WRAPPER_ASSIGNMENTS[2].__len__() == 12 — '__qualname__' has 12 chars; verified with Python 3.14.3"]
    - [wa3_eq,              WRAPPER_ASSIGNMENTS.__getitem__(3).__eq__,   ["__doc__"],                    true, "functools.WRAPPER_ASSIGNMENTS[3] == '__doc__' (len=7 — shortest element); verified with Python 3.14.3"]
    - [wa3_len,             WRAPPER_ASSIGNMENTS.__getitem__(3).__len__,  [],                             7,    "functools.WRAPPER_ASSIGNMENTS[3].__len__() == 7 — '__doc__' is the shortest element; verified with Python 3.14.3"]
    - [wa4_eq,              WRAPPER_ASSIGNMENTS.__getitem__(4).__eq__,   ["__annotate__"],               true, "functools.WRAPPER_ASSIGNMENTS[4] == '__annotate__' (len=12); verified with Python 3.14.3"]
    - [wa4_len,             WRAPPER_ASSIGNMENTS.__getitem__(4).__len__,  [],                             12,   "functools.WRAPPER_ASSIGNMENTS[4].__len__() == 12 — '__annotate__' has 12 chars; verified with Python 3.14.3"]
    - [wa5_eq,              WRAPPER_ASSIGNMENTS.__getitem__(5).__eq__,   ["__type_params__"],            true, "functools.WRAPPER_ASSIGNMENTS[5] == '__type_params__' (len=15 — longest element); verified with Python 3.14.3"]
    - [wa5_len,             WRAPPER_ASSIGNMENTS.__getitem__(5).__len__,  [],                             15,   "functools.WRAPPER_ASSIGNMENTS[5].__len__() == 15 — '__type_params__' is the longest element; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.partial member_descriptor attributes
#
# partial.func, partial.args, partial.keywords are member_descriptor objects.
# func.__name__(4) == args.__name__(4) < keywords.__name__(8 longest).
# All three have __qualname__ == 'partial.<attr>'.
# ---------------------------------------------------------------------------

table functools_extra275.partial_descriptor_attributes:
  description: "functools.partial C-level member_descriptor attributes — func(4), args(4), keywords(8 longest) names; all qualnames start with 'partial.'; all are member_descriptor type; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex275pd

  columns: [id, function, args, expected, description]
  rows:
    - [pf_cls_eq,            partial.func.__class__.__name__.__eq__,     ["member_descriptor"],          true, "type(functools.partial.func).__name__ == 'member_descriptor'; verified with Python 3.14.3"]
    - [pf_name_eq,           partial.func.__name__.__eq__,               ["func"],                       true, "functools.partial.func.__name__ == 'func' (len=4); verified with Python 3.14.3"]
    - [pf_name_len,          partial.func.__name__.__len__,              [],                             4,    "functools.partial.func.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [pf_qn_eq,             partial.func.__qualname__.__eq__,           ["partial.func"],               true, "functools.partial.func.__qualname__ == 'partial.func'; verified with Python 3.14.3"]
    - [pa_cls_eq,            partial.args.__class__.__name__.__eq__,     ["member_descriptor"],          true, "type(functools.partial.args).__name__ == 'member_descriptor'; verified with Python 3.14.3"]
    - [pa_name_eq,           partial.args.__name__.__eq__,               ["args"],                       true, "functools.partial.args.__name__ == 'args' (len=4); verified with Python 3.14.3"]
    - [pa_name_len,          partial.args.__name__.__len__,              [],                             4,    "functools.partial.args.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [pa_qn_eq,             partial.args.__qualname__.__eq__,           ["partial.args"],               true, "functools.partial.args.__qualname__ == 'partial.args'; verified with Python 3.14.3"]
    - [pk_cls_eq,            partial.keywords.__class__.__name__.__eq__, ["member_descriptor"],          true, "type(functools.partial.keywords).__name__ == 'member_descriptor'; verified with Python 3.14.3"]
    - [pk_name_eq,           partial.keywords.__name__.__eq__,           ["keywords"],                   true, "functools.partial.keywords.__name__ == 'keywords' (len=8 — longest); verified with Python 3.14.3"]
    - [pk_name_len,          partial.keywords.__name__.__len__,          [],                             8,    "functools.partial.keywords.__name__.__len__() == 8 — 'keywords' longest descriptor name; verified with Python 3.14.3"]
    - [pk_qn_eq,             partial.keywords.__qualname__.__eq__,       ["partial.keywords"],           true, "functools.partial.keywords.__qualname__ == 'partial.keywords'; verified with Python 3.14.3"]
    - [rd_doc_cls_eq,        reduce.__doc__.__class__.__name__.__eq__,   ["str"],                        true, "functools.reduce.__doc__.__class__.__name__ == 'str' — docstring is a plain str; verified with Python 3.14.3"]
    - [rd_doc_len,           reduce.__doc__.__len__,                     [],                             389,  "functools.reduce.__doc__.__len__() == 389 — non-empty docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra275
# ---------------------------------------------------------------------------

invariant functools_extra275.wrapper_assignments_len_is_six:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — tuple has 6 elements: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra275.wrapper_assignments_first_is_module:
  description: "functools.WRAPPER_ASSIGNMENTS[0] == '__module__' (len=10) — first element of WRAPPER_ASSIGNMENTS tuple"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__(0).__eq__
  args: ["__module__"]
  expected: true

invariant functools_extra275.wrapper_assignments_shortest_is_doc:
  description: "functools.WRAPPER_ASSIGNMENTS[3].__len__() == 7 — '__doc__' is the shortest element (len=7) of the 6-element WRAPPER_ASSIGNMENTS tuple"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__(3).__len__
  args: []
  expected: 7

invariant functools_extra275.wrapper_assignments_longest_is_type_params:
  description: "functools.WRAPPER_ASSIGNMENTS[5].__len__() == 15 — '__type_params__' is the longest element (len=15) of WRAPPER_ASSIGNMENTS"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__(5).__len__
  args: []
  expected: 15

invariant functools_extra275.partial_func_is_member_descriptor:
  description: "functools.partial.func.__class__.__name__ == 'member_descriptor' — func is a C-level member_descriptor slot on partial"
  category: identity
  kind: python_call_eq
  function: partial.func.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra275.partial_keywords_name_len_is_longest:
  description: "functools.partial.keywords.__name__.__len__() == 8 — 'keywords' is the longest of the three partial descriptors (func=4, args=4, keywords=8)"
  category: identity
  kind: python_call_eq
  function: partial.keywords.__name__.__len__
  args: []
  expected: 8

invariant functools_extra275.reduce_doc_is_str:
  description: "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce docstring is a plain str object"
  category: identity
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
