spec: io_extra50
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra49.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader __qualname__.__eq__() (string equality)."
    - "io_extra48.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __mro__.__len__(); FileIO/BytesIO/StringIO __bases__[0].__name__."
    - "io_extra47.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__/__module__/__bases__[0].__name__."
    - "io_extra46.zspec.zsdl — covers BufferedWriter/__name__/__module__; BufferedReader/__name__/__module__."
    - "io_extra36.zspec.zsdl — covers __mro__.__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/StringIO/BytesIO in a table."
  notes:
    - "This spec extends io_extra49.zspec.zsdl."
    - "Prior specs collectively covered: IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader __name__/__module__/__bases__[0].__name__; __mro__.__len__() for most io classes; __qualname__.__eq__() (string equality) for all nine io classes (io_extra49). No prior io spec covers __qualname__.__len__() for any io class."
    - "This spec covers: io.IOBase.__qualname__.__len__()==6 (NOVEL — io_extra49 covers IOBase.__qualname__.__eq__('IOBase'); no prior io spec checks IOBase.__qualname__.__len__(); novel length anchor in io_extra50 namespace); io.RawIOBase.__qualname__.__len__()==9 (NOVEL); io.BufferedIOBase.__qualname__.__len__()==14 (NOVEL); io.TextIOBase.__qualname__.__len__()==10 (NOVEL); io.FileIO.__qualname__.__len__()==6 (NOVEL); io.BytesIO.__qualname__.__len__()==7 (NOVEL); io.StringIO.__qualname__.__len__()==8 (NOVEL); io.BufferedWriter.__qualname__.__len__()==14 (NOVEL); io.BufferedReader.__qualname__.__len__()==14 (NOVEL)."
    - "io.IOBase.__qualname__.__len__() == 6. 'IOBase' has 6 characters. io_extra49 covers the string equality; no prior io spec checks the length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.RawIOBase.__qualname__.__len__() == 9. 'RawIOBase' has 9 characters. Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedIOBase.__qualname__.__len__() == 14. 'BufferedIOBase' has 14 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.TextIOBase.__qualname__.__len__() == 10. 'TextIOBase' has 10 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.__qualname__.__len__() == 6. 'FileIO' has 6 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.__qualname__.__len__() == 7. 'BytesIO' has 7 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.__qualname__.__len__() == 8. 'StringIO' has 8 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.__qualname__.__len__() == 14. 'BufferedWriter' has 14 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedReader.__qualname__.__len__() == 14. 'BufferedReader' has 14 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __qualname__.__len__() attributes
#
# The length of each io class's __qualname__ string equals the length of its
# bare class name, since all public io classes are defined at module scope.
#
#   IOBase.__qualname__.__len__()        == 6   ('IOBase')
#   RawIOBase.__qualname__.__len__()     == 9   ('RawIOBase')
#   BufferedIOBase.__qualname__.__len__()== 14  ('BufferedIOBase')
#   TextIOBase.__qualname__.__len__()    == 10  ('TextIOBase')
#   FileIO.__qualname__.__len__()        == 6   ('FileIO')
#   BytesIO.__qualname__.__len__()       == 7   ('BytesIO')
#   StringIO.__qualname__.__len__()      == 8   ('StringIO')
#   BufferedWriter.__qualname__.__len__()== 14  ('BufferedWriter')
#   BufferedReader.__qualname__.__len__()== 14  ('BufferedReader')
#
# io_extra49 covers __qualname__.__eq__() (string equality) for all nine.
# No prior io spec covers __qualname__.__len__() for any io class.
# All nine are novel length anchors in the io_extra50 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra50.class_qualname_lengths:
  description: "io class __qualname__.__len__() values: IOBase(6)/RawIOBase(9)/BufferedIOBase(14)/TextIOBase(10)/FileIO(6)/BytesIO(7)/StringIO(8)/BufferedWriter(14)/BufferedReader(14) — length of qualname string equals length of bare class name for top-level classes; io_extra49 covers string equality; no prior io spec checks any io class __qualname__.__len__(); all nine novel length anchors in io_extra50 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: icql50

  columns: [id, function, args, expected]
  rows:
    - [IOBase_qualname_len,         "IOBase.__qualname__.__len__",         [], 6]
    - [RawIOBase_qualname_len,      "RawIOBase.__qualname__.__len__",      [], 9]
    - [BufferedIOBase_qualname_len, "BufferedIOBase.__qualname__.__len__", [], 14]
    - [TextIOBase_qualname_len,     "TextIOBase.__qualname__.__len__",     [], 10]
    - [FileIO_qualname_len,         "FileIO.__qualname__.__len__",         [], 6]
    - [BytesIO_qualname_len,        "BytesIO.__qualname__.__len__",        [], 7]
    - [StringIO_qualname_len,       "StringIO.__qualname__.__len__",       [], 8]
    - [BufferedWriter_qualname_len, "BufferedWriter.__qualname__.__len__", [], 14]
    - [BufferedReader_qualname_len, "BufferedReader.__qualname__.__len__", [], 14]
