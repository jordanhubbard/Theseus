spec: repeat_string
version: ">=1.6.1"
backend: node(repeat-string)

docs: https://www.npmjs.com/package/repeat-string

provenance:
  derived_from:
    - "repeat-string README — https://www.npmjs.com/package/repeat-string"
    - "Test vectors verified with repeat-string via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "repeat-string source"
  notes:
    - "repeat-string is an npm package. Install: npm install repeat-string"
    - "The module exports a single function: repeat(str, count) repeats a string n times."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the repeated string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table repeat_string.repeat:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: repstr

  columns: [id, args, expected]
  rows:
    - [two_chars, ["ab", 3], "ababab"]
    - [star,      ["*", 5],  "*****"]
    - [once,      ["hi", 1], "hi"]
