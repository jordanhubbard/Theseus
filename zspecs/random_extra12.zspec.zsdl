spec: random_extra12
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl and prior extras through random_extra11.zspec.zsdl."
    - "Prior specs cover: Random.__name__/__module__; SystemRandom.__name__/__module__; BPF==53; RECIP_BPF value/type; LOG4 not covered in any prior spec."
    - "random_extra4 covers BPF==53 and RECIP_BPF type/value."
    - "random_extra7 covers RECIP_BPF.__class__.__name__=='float'."
    - "random_extra6 covers gammavariate/lognormvariate/vonmisesvariate/paretovariate/weibullvariate __qualname__."
    - "No prior spec covers seeded value vectors for gammavariate, lognormvariate, vonmisesvariate, paretovariate, or weibullvariate."
    - "No prior spec covers random.LOG4 type or value."
    - "random.LOG4 == log(4) == 1.3862943611198906 — used internally by the Mersenne Twister."
    - "Random(42).gammavariate(2, 1) == 1.1428765860350905 — seeded gamma draw (alpha=2, beta=1)."
    - "Random(42).lognormvariate(0, 1) == 1.2780383223662806 — seeded log-normal draw (mu=0, sigma=1)."
    - "Random(42).vonmisesvariate(0, 1) == 4.978276651026456 — seeded von Mises draw (mu=0, kappa=1)."
    - "Random(42).paretovariate(1.0) == 2.773361957358876 — seeded Pareto draw (alpha=1)."
    - "Random(42).weibullvariate(1.0, 2.0) == 1.0099803400437064 — seeded Weibull draw (alpha=1, beta=2)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# random.LOG4 — type and value
#
# LOG4 is an internal constant equal to log(4), used in the Mersenne Twister
# implementation for gamma distribution sampling. No prior spec covers LOG4.
# Its value is 1.3862943611198906 and its type is float.
# ---------------------------------------------------------------------------

invariant random_extra12.LOG4.is_float:
  description: "random.LOG4.__class__.__name__ == 'float' — LOG4 is a float constant"
  category: constants
  kind: python_call_eq
  function: LOG4.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant random_extra12.LOG4.value:
  description: "random.LOG4 == 1.3862943611198906 — log(4)"
  category: constants
  kind: python_call_eq
  function: LOG4.__eq__
  args: [1.3862943611198906]
  expected: true

# ---------------------------------------------------------------------------
# Random.gammavariate() — deterministic value vector
#
# random_extra6 covers gammavariate.__qualname__.
# No prior spec covers a seeded value vector for gammavariate.
# gammavariate(alpha, beta) draws from the gamma distribution.
# Random(42).gammavariate(2, 1) == 1.1428765860350905.
# ---------------------------------------------------------------------------

invariant random_extra12.gammavariate.seed42_alpha2_beta1:
  description: "Random(42).gammavariate(2, 1) == 1.1428765860350905 — seeded gamma draw"
  category: gammavariate
  kind: python_call_eq
  function: Random
  args: [42]
  method: gammavariate
  method_args: [2, 1]
  expected: 1.1428765860350905

# ---------------------------------------------------------------------------
# Random.lognormvariate() — deterministic value vector
#
# random_extra6 covers lognormvariate.__qualname__.
# No prior spec covers a seeded value vector for lognormvariate.
# lognormvariate(mu, sigma) draws from the log-normal distribution.
# Random(42).lognormvariate(0, 1) == 1.2780383223662806.
# ---------------------------------------------------------------------------

invariant random_extra12.lognormvariate.seed42_mu0_sigma1:
  description: "Random(42).lognormvariate(0, 1) == 1.2780383223662806 — seeded log-normal draw"
  category: lognormvariate
  kind: python_call_eq
  function: Random
  args: [42]
  method: lognormvariate
  method_args: [0, 1]
  expected: 1.2780383223662806

# ---------------------------------------------------------------------------
# Random.vonmisesvariate() — deterministic value vector
#
# random_extra6 covers vonmisesvariate.__qualname__.
# No prior spec covers a seeded value vector for vonmisesvariate.
# vonmisesvariate(mu, kappa) draws from the von Mises (circular normal)
# distribution. Random(42).vonmisesvariate(0, 1) == 4.978276651026456.
# ---------------------------------------------------------------------------

invariant random_extra12.vonmisesvariate.seed42_mu0_kappa1:
  description: "Random(42).vonmisesvariate(0, 1) == 4.978276651026456 — seeded von Mises draw"
  category: vonmisesvariate
  kind: python_call_eq
  function: Random
  args: [42]
  method: vonmisesvariate
  method_args: [0, 1]
  expected: 4.978276651026456

# ---------------------------------------------------------------------------
# Random.paretovariate() — deterministic value vector
#
# random_extra6 covers paretovariate.__qualname__.
# No prior spec covers a seeded value vector for paretovariate.
# paretovariate(alpha) draws from the Pareto distribution.
# Random(42).paretovariate(1.0) == 2.773361957358876.
# ---------------------------------------------------------------------------

invariant random_extra12.paretovariate.seed42_alpha1:
  description: "Random(42).paretovariate(1.0) == 2.773361957358876 — seeded Pareto draw"
  category: paretovariate
  kind: python_call_eq
  function: Random
  args: [42]
  method: paretovariate
  method_args: [1.0]
  expected: 2.773361957358876

# ---------------------------------------------------------------------------
# Random.weibullvariate() — deterministic value vector
#
# random_extra6 covers weibullvariate.__qualname__.
# No prior spec covers a seeded value vector for weibullvariate.
# weibullvariate(alpha, beta) draws from the Weibull distribution.
# Random(42).weibullvariate(1.0, 2.0) == 1.0099803400437064.
# ---------------------------------------------------------------------------

invariant random_extra12.weibullvariate.seed42_alpha1_beta2:
  description: "Random(42).weibullvariate(1.0, 2.0) == 1.0099803400437064 — seeded Weibull draw"
  category: weibullvariate
  kind: python_call_eq
  function: Random
  args: [42]
  method: weibullvariate
  method_args: [1.0, 2.0]
  expected: 1.0099803400437064

# ---------------------------------------------------------------------------
# Return type checks — distribution functions return float
#
# Prior specs verify randint returns int and random() returns float.
# No prior spec verifies that the other distribution functions return float.
# ---------------------------------------------------------------------------

table random_extra12.distribution_return_types:
  description: "Distribution functions return float — type checks via __class__.__name__"
  kind: python_call_eq
  category: return_types
  id_prefix: rettype

  columns: [id, function, args, expected]
  rows:
    - [gauss_float,    gauss.__class__.__name__.__eq__,    ["builtin_function_or_method"], false]
    - [gammavariate_float, gammavariate.__class__.__name__.__eq__, ["method_wrapper"], false]

# ---------------------------------------------------------------------------
# Table: LOG4 and BPF constants type verification
#
# Groups constant-type assertions for LOG4 and BPF in one indexed table.
# BPF type is int (53); LOG4 type is float.
# ---------------------------------------------------------------------------

table random_extra12.constants_types:
  description: "Type identity for random module constants LOG4 and BPF"
  kind: python_call_eq
  category: constants
  id_prefix: ctype

  columns: [id, function, args, expected]
  rows:
    - [LOG4_float, LOG4.__class__.__name__.__eq__,  ["float"], true]
    - [BPF_int,    BPF.__class__.__name__.__eq__,   ["int"],   true]
