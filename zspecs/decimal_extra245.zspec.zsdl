spec: decimal_extra245
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal class identity (__name__, __module__, __bases__[0].__name__); decimal.Context class identity; decimal.DecimalException hierarchy (DecimalException, InvalidOperation, DivisionByZero, Overflow, Inexact); decimal rounding mode string constants (ROUND_HALF_EVEN, ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_DOWN, ROUND_UP, ROUND_CEILING, ROUND_FLOOR, ROUND_05UP)."
    - "decimal.Decimal.__module__ == 'decimal' — on Python 3.14.3 the accelerated C implementation is loaded but Decimal's __module__ is 'decimal' (not '_decimal'); this is set explicitly in the C extension to maintain a stable public interface."
    - "decimal rounding mode constants are plain str values whose string value equals their name: decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN', etc. This is intentional API design — they serve as symbolic sentinel strings."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — DecimalException is the root of the decimal exception hierarchy; it subclasses ArithmeticError."
    - "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — Overflow is a subclass of Inexact (not of DecimalException directly), because overflow produces an inexact result."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal class identity
#
# decimal.Decimal.__name__ == 'Decimal'
# decimal.Decimal.__module__ == 'decimal'
# decimal.Decimal.__bases__[0].__name__ == 'object'
# decimal.Context.__name__ == 'Context'
# decimal.Context.__module__ == 'decimal'
# decimal.Context.__bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

table decimal_extra245.decimal_class_identity:
  description: "decimal.Decimal and decimal.Context class identity — __name__, __module__, __bases__[0].__name__; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: decxci245

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_name,
       "Decimal.__name__.__eq__",
       ["Decimal"],
       true,
       "decimal.Decimal.__name__.__eq__('Decimal') == True — Decimal is the arbitrary-precision decimal floating-point class; its unqualified __name__ is 'Decimal'; str.__eq__('Decimal') returns True; new to extra245"]
    - [decimal_module,
       "Decimal.__module__.__eq__",
       ["decimal"],
       true,
       "decimal.Decimal.__module__.__eq__('decimal') == True — on Python 3.14.3 the C-accelerated Decimal class exposes __module__ as 'decimal' (not '_decimal') to maintain a stable public interface; str.__eq__('decimal') returns True; new to extra245"]
    - [decimal_base,
       "Decimal.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "decimal.Decimal.__bases__[0].__name__.__eq__('object') == True — Decimal inherits directly from object; it does not subclass int, float, or any numeric ABC; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra245"]
    - [context_name,
       "Context.__name__.__eq__",
       ["Context"],
       true,
       "decimal.Context.__name__.__eq__('Context') == True — Context encapsulates the arithmetic settings (precision, rounding mode, traps) for Decimal operations; its __name__ is 'Context'; str.__eq__('Context') returns True; new to extra245"]
    - [context_module,
       "Context.__module__.__eq__",
       ["decimal"],
       true,
       "decimal.Context.__module__.__eq__('decimal') == True — Context is defined in the decimal module; its __module__ is 'decimal'; str.__eq__('decimal') returns True; new to extra245"]
    - [context_base,
       "Context.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "decimal.Context.__bases__[0].__name__.__eq__('object') == True — Context inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra245"]

# ---------------------------------------------------------------------------
# Table 2: decimal.DecimalException hierarchy
#
# DecimalException is the root exception for the decimal module hierarchy.
# It subclasses ArithmeticError. InvalidOperation, DivisionByZero subclass
# DecimalException directly. Overflow subclasses Inexact (which subclasses
# DecimalException).
# ---------------------------------------------------------------------------

table decimal_extra245.exception_hierarchy:
  description: "decimal exception hierarchy — DecimalException, InvalidOperation, DivisionByZero, Overflow, Inexact __name__ and __bases__[0].__name__; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: decxeh245

  columns: [id, function, args, expected, description]
  rows:
    - [decimalexception_name,
       "DecimalException.__name__.__eq__",
       ["DecimalException"],
       true,
       "decimal.DecimalException.__name__.__eq__('DecimalException') == True — DecimalException is the base class for all decimal module exceptions; its __name__ is 'DecimalException'; str.__eq__('DecimalException') returns True; new to extra245"]
    - [decimalexception_base,
       "DecimalException.__bases__[0].__name__.__eq__",
       ["ArithmeticError"],
       true,
       "decimal.DecimalException.__bases__[0].__name__.__eq__('ArithmeticError') == True — DecimalException inherits from ArithmeticError (a built-in exception base for numeric errors); __bases__[0].__name__ is 'ArithmeticError'; str.__eq__('ArithmeticError') returns True; new to extra245"]
    - [invalidoperation_name,
       "InvalidOperation.__name__.__eq__",
       ["InvalidOperation"],
       true,
       "decimal.InvalidOperation.__name__.__eq__('InvalidOperation') == True — InvalidOperation is raised for operations with undefined results (e.g. 0/0); its __name__ is 'InvalidOperation'; str.__eq__('InvalidOperation') returns True; new to extra245"]
    - [invalidoperation_base,
       "InvalidOperation.__bases__[0].__name__.__eq__",
       ["DecimalException"],
       true,
       "decimal.InvalidOperation.__bases__[0].__name__.__eq__('DecimalException') == True — InvalidOperation inherits directly from DecimalException; __bases__[0].__name__ is 'DecimalException'; str.__eq__('DecimalException') returns True; new to extra245"]
    - [divisionbyzero_name,
       "DivisionByZero.__name__.__eq__",
       ["DivisionByZero"],
       true,
       "decimal.DivisionByZero.__name__.__eq__('DivisionByZero') == True — DivisionByZero is raised for finite-number division by zero; its __name__ is 'DivisionByZero'; str.__eq__('DivisionByZero') returns True; new to extra245"]
    - [divisionbyzero_base,
       "DivisionByZero.__bases__[0].__name__.__eq__",
       ["DecimalException"],
       true,
       "decimal.DivisionByZero.__bases__[0].__name__.__eq__('DecimalException') == True — DivisionByZero inherits directly from DecimalException; __bases__[0].__name__ is 'DecimalException'; str.__eq__('DecimalException') returns True; new to extra245"]
    - [inexact_name,
       "Inexact.__name__.__eq__",
       ["Inexact"],
       true,
       "decimal.Inexact.__name__.__eq__('Inexact') == True — Inexact is raised when a result is not exact and was rounded; its __name__ is 'Inexact'; str.__eq__('Inexact') returns True; new to extra245"]
    - [inexact_base,
       "Inexact.__bases__[0].__name__.__eq__",
       ["DecimalException"],
       true,
       "decimal.Inexact.__bases__[0].__name__.__eq__('DecimalException') == True — Inexact inherits directly from DecimalException; __bases__[0].__name__ is 'DecimalException'; str.__eq__('DecimalException') returns True; new to extra245"]
    - [overflow_name,
       "Overflow.__name__.__eq__",
       ["Overflow"],
       true,
       "decimal.Overflow.__name__.__eq__('Overflow') == True — Overflow is raised when the exponent exceeds the Emax limit; its __name__ is 'Overflow'; str.__eq__('Overflow') returns True; new to extra245"]
    - [overflow_base,
       "Overflow.__bases__[0].__name__.__eq__",
       ["Inexact"],
       true,
       "decimal.Overflow.__bases__[0].__name__.__eq__('Inexact') == True — Overflow subclasses Inexact (not DecimalException directly) because overflow produces an inexact result; __bases__[0].__name__ is 'Inexact'; str.__eq__('Inexact') returns True; new to extra245"]

# ---------------------------------------------------------------------------
# Table 3: decimal rounding mode constants — string identity
#
# All eight ROUND_* constants are plain str values equal to their own name.
# This is intentional API design: they serve as symbolic sentinel strings.
# Verified: decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN', etc.
# ---------------------------------------------------------------------------

table decimal_extra245.rounding_constants_identity:
  description: "decimal ROUND_* constants are str values equal to their own names; all 8 rounding modes; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: decxrc245

  columns: [id, function, args, expected, description]
  rows:
    - [round_half_even_eq,
       "ROUND_HALF_EVEN.__eq__",
       ["ROUND_HALF_EVEN"],
       true,
       "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True — ROUND_HALF_EVEN is a str constant equal to its own name; it selects 'round to nearest with ties going to nearest even' (IEEE 754 default); str.__eq__('ROUND_HALF_EVEN') returns True; new to extra245"]
    - [round_half_up_eq,
       "ROUND_HALF_UP.__eq__",
       ["ROUND_HALF_UP"],
       true,
       "decimal.ROUND_HALF_UP.__eq__('ROUND_HALF_UP') == True — ROUND_HALF_UP is a str constant equal to its own name; it selects 'round to nearest with ties going away from zero'; str.__eq__('ROUND_HALF_UP') returns True; new to extra245"]
    - [round_half_down_eq,
       "ROUND_HALF_DOWN.__eq__",
       ["ROUND_HALF_DOWN"],
       true,
       "decimal.ROUND_HALF_DOWN.__eq__('ROUND_HALF_DOWN') == True — ROUND_HALF_DOWN is a str constant equal to its own name; it selects 'round to nearest with ties going toward zero'; str.__eq__('ROUND_HALF_DOWN') returns True; new to extra245"]
    - [round_down_eq,
       "ROUND_DOWN.__eq__",
       ["ROUND_DOWN"],
       true,
       "decimal.ROUND_DOWN.__eq__('ROUND_DOWN') == True — ROUND_DOWN is a str constant equal to its own name; it selects 'round toward zero' (truncation); str.__eq__('ROUND_DOWN') returns True; new to extra245"]
    - [round_up_eq,
       "ROUND_UP.__eq__",
       ["ROUND_UP"],
       true,
       "decimal.ROUND_UP.__eq__('ROUND_UP') == True — ROUND_UP is a str constant equal to its own name; it selects 'round away from zero'; str.__eq__('ROUND_UP') returns True; new to extra245"]
    - [round_ceiling_eq,
       "ROUND_CEILING.__eq__",
       ["ROUND_CEILING"],
       true,
       "decimal.ROUND_CEILING.__eq__('ROUND_CEILING') == True — ROUND_CEILING is a str constant equal to its own name; it selects 'round toward positive infinity'; str.__eq__('ROUND_CEILING') returns True; new to extra245"]
    - [round_floor_eq,
       "ROUND_FLOOR.__eq__",
       ["ROUND_FLOOR"],
       true,
       "decimal.ROUND_FLOOR.__eq__('ROUND_FLOOR') == True — ROUND_FLOOR is a str constant equal to its own name; it selects 'round toward negative infinity'; str.__eq__('ROUND_FLOOR') returns True; new to extra245"]
    - [round_05up_eq,
       "ROUND_05UP.__eq__",
       ["ROUND_05UP"],
       true,
       "decimal.ROUND_05UP.__eq__('ROUND_05UP') == True — ROUND_05UP is a str constant equal to its own name; it selects 'round away from zero if last digit is 0 or 5, otherwise toward zero'; str.__eq__('ROUND_05UP') returns True; new to extra245"]

# ---------------------------------------------------------------------------
# Table 4: decimal rounding mode constants — __class__.__name__ == 'str'
#
# All eight ROUND_* constants are plain Python str instances. Their
# __class__.__name__ is 'str'. This confirms they are not an enum or
# special type — just string sentinels.
# ---------------------------------------------------------------------------

table decimal_extra245.rounding_constants_class:
  description: "decimal ROUND_* constants __class__.__name__ == 'str' — all 8 rounding modes are plain str; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: decxrcc245

  columns: [id, function, args, expected, description]
  rows:
    - [round_half_even_class,
       "ROUND_HALF_EVEN.__class__.__name__.__eq__",
       ["str"],
       true,
       "decimal.ROUND_HALF_EVEN.__class__.__name__.__eq__('str') == True — ROUND_HALF_EVEN is a plain Python str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra245"]
    - [round_half_up_class,
       "ROUND_HALF_UP.__class__.__name__.__eq__",
       ["str"],
       true,
       "decimal.ROUND_HALF_UP.__class__.__name__.__eq__('str') == True — ROUND_HALF_UP is a plain Python str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra245"]
    - [round_half_down_class,
       "ROUND_HALF_DOWN.__class__.__name__.__eq__",
       ["str"],
       true,
       "decimal.ROUND_HALF_DOWN.__class__.__name__.__eq__('str') == True — ROUND_HALF_DOWN is a plain Python str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra245"]
    - [round_down_class,
       "ROUND_DOWN.__class__.__name__.__eq__",
       ["str"],
       true,
       "decimal.ROUND_DOWN.__class__.__name__.__eq__('str') == True — ROUND_DOWN is a plain Python str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra245"]
    - [round_up_class,
       "ROUND_UP.__class__.__name__.__eq__",
       ["str"],
       true,
       "decimal.ROUND_UP.__class__.__name__.__eq__('str') == True — ROUND_UP is a plain Python str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra245"]
    - [round_ceiling_class,
       "ROUND_CEILING.__class__.__name__.__eq__",
       ["str"],
       true,
       "decimal.ROUND_CEILING.__class__.__name__.__eq__('str') == True — ROUND_CEILING is a plain Python str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra245"]
    - [round_floor_class,
       "ROUND_FLOOR.__class__.__name__.__eq__",
       ["str"],
       true,
       "decimal.ROUND_FLOOR.__class__.__name__.__eq__('str') == True — ROUND_FLOOR is a plain Python str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra245"]
    - [round_05up_class,
       "ROUND_05UP.__class__.__name__.__eq__",
       ["str"],
       true,
       "decimal.ROUND_05UP.__class__.__name__.__eq__('str') == True — ROUND_05UP is a plain Python str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra245"]

# ---------------------------------------------------------------------------
# Standalone invariants — decimal_extra245
# ---------------------------------------------------------------------------

invariant decimal_extra245.decimal_name:
  description: "decimal.Decimal.__name__ == 'Decimal' — Decimal is the arbitrary-precision decimal class; new to extra245"
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra245.decimal_module:
  description: "decimal.Decimal.__module__ == 'decimal' — Decimal exposes __module__ as 'decimal' not '_decimal'; new to extra245"
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra245.decimal_base_object:
  description: "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal inherits directly from object; new to extra245"
  kind: python_call_eq
  function: "Decimal.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra245.decimalexception_base_arithmeticerror:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — DecimalException is rooted in ArithmeticError; new to extra245"
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra245.round_half_even_is_str:
  description: "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' — rounding mode constants are plain str sentinels; new to extra245"
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra245.overflow_base_inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — Overflow subclasses Inexact because overflow produces an inexact result; new to extra245"
  kind: python_call_eq
  function: "Overflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true
