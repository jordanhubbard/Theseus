spec: re_extra283
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re_extra282 covers re.escape() output values and re.purge/__escape function identity."
    - "This spec focuses on re.compile() with named groups — groupindex type, values, and re.NOFLAG."
    - "re.compile(r'(?P<year>\\d{4})').groupindex type is 'mappingproxy' — not a plain dict."
    - "re.compile(r'(?P<year>\\d{4})').groupindex['year'] == 1 — the first named group gets index 1."
    - "re.compile(r'(?P<year>\\d{4})-(?P<month>\\d{2})-(?P<day>\\d{2})').groupindex['day'] == 3 — groups numbered left to right from 1."
    - "len(groupindex) equals the number of named groups — unnamed groups do not appear in groupindex."
    - "re.NOFLAG == 0 — the no-flags sentinel is numerically zero (added in Python 3.11)."
    - "type(re.NOFLAG).__name__ == 'RegexFlag' — NOFLAG is a RegexFlag enum member, not a plain int."
    - "re.compile(r'x').__class__.__name__ == 'Pattern' — compile() returns a re.Pattern instance."
    - "re.compile(r'x').__class__.__module__ == 're' — Pattern is in the re module namespace."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile() with named groups — groupindex type and values
# groupindex is a mappingproxy (read-only view), not a mutable dict.
# Named groups are numbered from 1, left to right in the pattern.
# ---------------------------------------------------------------------------

table re_extra283.groupindex_values:
  description: "groupindex maps named group names to their 1-based integer positions; type is mappingproxy"
  kind: python_call_eq
  category: named_groups
  id_prefix: grpidx283

  columns: [id, function, args, expected, description]
  rows:
    - [type_name,    "compile('(?P<year>\\d{4})').groupindex.__class__.__name__.__eq__",               ["mappingproxy"], true, "groupindex.__class__.__name__ == 'mappingproxy'"]
    - [year_idx,     "compile('(?P<year>\\d{4})').groupindex.__getitem__",                             ["year"],         1,    "groupindex['year'] == 1 — first named group is index 1"]
    - [len_one,      "compile('(?P<year>\\d{4})').groupindex.__len__",                                 [],               1,    "len(groupindex) == 1 for a single named group"]
    - [month_idx,    "compile('(?P<year>\\d{4})-(?P<month>\\d{2})').groupindex.__getitem__",           ["month"],        2,    "groupindex['month'] == 2 — second named group is index 2"]
    - [day_idx,      "compile('(?P<year>\\d{4})-(?P<month>\\d{2})-(?P<day>\\d{2})').groupindex.__getitem__", ["day"],   3,    "groupindex['day'] == 3 — third named group is index 3"]
    - [len_three,    "compile('(?P<year>\\d{4})-(?P<month>\\d{2})-(?P<day>\\d{2})').groupindex.__len__", [],            3,    "len(groupindex) == 3 for a three-named-group pattern"]
    - [not_dict,     "compile('(?P<year>\\d{4})').groupindex.__class__.__name__.__eq__",               ["dict"],         false,"groupindex is not a plain mutable dict"]

# ---------------------------------------------------------------------------
# re.NOFLAG — the zero-value flag sentinel and re.compile() result type
# re.NOFLAG is a RegexFlag enum member with integer value 0 (Python 3.11+).
# re.compile() returns a re.Pattern instance.
# ---------------------------------------------------------------------------

table re_extra283.noflag_and_pattern_type:
  description: "re.NOFLAG == 0 with type RegexFlag; re.compile() returns a Pattern"
  kind: python_call_eq
  category: flag_and_pattern
  id_prefix: noflag283

  columns: [id, function, args, expected, description]
  rows:
    - [noflag_eq_zero,   NOFLAG.__eq__,                              [0],         true,      "re.NOFLAG == 0 — numerically zero"]
    - [noflag_type,      NOFLAG.__class__.__name__.__eq__,           ["RegexFlag"],true,      "type(re.NOFLAG).__name__ == 'RegexFlag' — NOFLAG is a RegexFlag enum member"]
    - [noflag_not_int,   NOFLAG.__class__.__name__.__eq__,           ["int"],      false,     "type(re.NOFLAG).__name__ != 'int' — it is a RegexFlag, not a bare int"]
    - [pattern_class,    "compile('x').__class__.__name__.__eq__",   ["Pattern"],  true,      "re.compile('x').__class__.__name__ == 'Pattern'"]
    - [pattern_module,   "compile('x').__class__.__module__.__eq__", ["re"],       true,      "re.compile('x').__class__.__module__ == 're'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra283.groupindex.type_is_mappingproxy:
  description: "re.compile(r'(?P<year>\\d{4})').groupindex.__class__.__name__ == 'mappingproxy' — groupindex is a read-only mapping proxy, not a mutable dict"
  category: named_groups
  kind: python_call_eq
  function: "compile('(?P<year>\\d{4})').groupindex.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant re_extra283.groupindex.year_is_one:
  description: "groupindex['year'] == 1 — the first named group in a pattern receives index 1 (groups are 1-indexed, not 0-indexed)"
  category: named_groups
  kind: python_call_eq
  function: "compile('(?P<year>\\d{4})').groupindex.__getitem__"
  args: ["year"]
  expected: 1

invariant re_extra283.groupindex.month_is_two:
  description: "groupindex['month'] == 2 — the second named group gets index 2; named groups are numbered left to right"
  category: named_groups
  kind: python_call_eq
  function: "compile('(?P<year>\\d{4})-(?P<month>\\d{2})').groupindex.__getitem__"
  args: ["month"]
  expected: 2

invariant re_extra283.groupindex.day_is_three:
  description: "groupindex['day'] == 3 — the third named group gets index 3 in a three-group pattern"
  category: named_groups
  kind: python_call_eq
  function: "compile('(?P<year>\\d{4})-(?P<month>\\d{2})-(?P<day>\\d{2})').groupindex.__getitem__"
  args: ["day"]
  expected: 3

invariant re_extra283.NOFLAG.equals_zero:
  description: "re.NOFLAG == 0 — the no-flags sentinel is numerically zero; introduced in Python 3.11 as a typed alternative to passing 0"
  category: flag_and_pattern
  kind: python_call_eq
  function: NOFLAG.__eq__
  args: [0]
  expected: true

invariant re_extra283.NOFLAG.type_is_RegexFlag:
  description: "type(re.NOFLAG).__name__ == 'RegexFlag' — NOFLAG is an instance of the RegexFlag enum, not a plain int"
  category: flag_and_pattern
  kind: python_call_eq
  function: NOFLAG.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra283.compile.returns_Pattern:
  description: "re.compile('x').__class__.__name__ == 'Pattern' — re.compile() always returns a re.Pattern object"
  category: flag_and_pattern
  kind: python_call_eq
  function: "compile('x').__class__.__name__.__eq__"
  args: ["Pattern"]
  expected: true
