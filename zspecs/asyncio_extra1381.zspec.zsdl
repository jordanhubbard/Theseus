spec: asyncio_extra1381
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio: Asynchronous I/O"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ frozenset checks and __isabstractmethod__ boolean checks."
    - "In Python 3.14, asyncio classes do NOT use ABCMeta; none have __abstractmethods__ in their __dict__."
    - "asyncio.Queue, asyncio.Barrier, asyncio.Future, asyncio.Task, asyncio.Lock, asyncio.AbstractEventLoop all lack __abstractmethods__."
    - "Properties (descriptors) on asyncio classes carry __isabstractmethod__ = False (bool) when not declared abstract."
    - "asyncio.Barrier.parties, .n_waiting, .broken are properties with __isabstractmethod__ = False."
    - "asyncio.Queue.maxsize and asyncio.Server.sockets are properties with __isabstractmethod__ = False."
    - "asyncio.StreamWriter.transport is a property with __isabstractmethod__ = False."
    - "Property __isabstractmethod__ is accessible via class attribute (descriptor object), confirming bool type."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1381.abstractmethods_absent_in_dict:
  description: "asyncio classes do not have __abstractmethods__ in their __dict__ — they are not ABCMeta-based"
  kind: python_call_eq
  category: abstractmethods_dict_check
  id_prefix: as1381aa
  columns: [id, function, args, expected]
  rows:
    - [as1381aa001, asyncio.Queue.__dict__.__contains__,             ["__abstractmethods__"], false]
    - [as1381aa002, asyncio.Barrier.__dict__.__contains__,           ["__abstractmethods__"], false]
    - [as1381aa003, asyncio.Future.__dict__.__contains__,            ["__abstractmethods__"], false]
    - [as1381aa004, asyncio.Task.__dict__.__contains__,              ["__abstractmethods__"], false]
    - [as1381aa005, asyncio.Lock.__dict__.__contains__,              ["__abstractmethods__"], false]
    - [as1381aa006, asyncio.AbstractEventLoop.__dict__.__contains__,  ["__abstractmethods__"], false]

table asyncio_extra1381.barrier_property_isabstractmethod_type:
  description: "asyncio.Barrier property descriptors carry __isabstractmethod__ whose type is bool"
  kind: python_call_eq
  category: isabstractmethod_bool_check
  id_prefix: as1381bp
  columns: [id, function, args, expected]
  rows:
    - [as1381bp001, asyncio.Barrier.parties.__isabstractmethod__.__class__.__name__.__eq__,   ["bool"], true]
    - [as1381bp002, asyncio.Barrier.n_waiting.__isabstractmethod__.__class__.__name__.__eq__, ["bool"], true]
    - [as1381bp003, asyncio.Barrier.broken.__isabstractmethod__.__class__.__name__.__eq__,    ["bool"], true]
    - [as1381bp004, asyncio.Barrier.parties.__isabstractmethod__.__eq__,                      [false],  true]
    - [as1381bp005, asyncio.Barrier.n_waiting.__isabstractmethod__.__eq__,                    [false],  true]
    - [as1381bp006, asyncio.Barrier.broken.__isabstractmethod__.__eq__,                       [false],  true]

table asyncio_extra1381.queue_server_writer_isabstractmethod_type:
  description: "asyncio.Queue, asyncio.Server, and asyncio.StreamWriter property __isabstractmethod__ is bool False"
  kind: python_call_eq
  category: isabstractmethod_bool_check
  id_prefix: as1381qs
  columns: [id, function, args, expected]
  rows:
    - [as1381qs001, asyncio.Queue.maxsize.__isabstractmethod__.__class__.__name__.__eq__,       ["bool"], true]
    - [as1381qs002, asyncio.Queue.maxsize.__isabstractmethod__.__eq__,                          [false],  true]
    - [as1381qs003, asyncio.Server.sockets.__isabstractmethod__.__class__.__name__.__eq__,      ["bool"], true]
    - [as1381qs004, asyncio.Server.sockets.__isabstractmethod__.__eq__,                         [false],  true]
    - [as1381qs005, asyncio.StreamWriter.transport.__isabstractmethod__.__class__.__name__.__eq__, ["bool"], true]
    - [as1381qs006, asyncio.StreamWriter.transport.__isabstractmethod__.__eq__,                 [false],  true]
