spec: multiprocessing_extra486
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing.Process method and property identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers method name identity and property class identity for multiprocessing.Process"
    - "Properties such as name, pid, exitcode, authkey, daemon, and sentinel are exposed as property descriptors"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra486.process_method_identity:
  description: "multiprocessing.Process method name identity"
  kind: python_call_eq
  category: identity
  id_prefix: PRM

  columns: [id, function, args, expected]
  rows:
    - [PRM001, multiprocessing.Process.start.__name__.__eq__, ["start"], true]
    - [PRM002, multiprocessing.Process.run.__name__.__eq__, ["run"], true]
    - [PRM003, multiprocessing.Process.join.__name__.__eq__, ["join"], true]
    - [PRM004, multiprocessing.Process.is_alive.__name__.__eq__, ["is_alive"], true]
    - [PRM005, multiprocessing.Process.terminate.__name__.__eq__, ["terminate"], true]
    - [PRM006, multiprocessing.Process.kill.__name__.__eq__, ["kill"], true]
    - [PRM007, multiprocessing.Process.close.__name__.__eq__, ["close"], true]

table multiprocessing_extra486.process_property_identity:
  description: "multiprocessing.Process property descriptor class identity"
  kind: python_call_eq
  category: identity
  id_prefix: PRP

  columns: [id, function, args, expected]
  rows:
    - [PRP001, multiprocessing.Process.name.__class__.__name__.__eq__, ["property"], true]
    - [PRP002, multiprocessing.Process.pid.__class__.__name__.__eq__, ["property"], true]
    - [PRP003, multiprocessing.Process.exitcode.__class__.__name__.__eq__, ["property"], true]
    - [PRP004, multiprocessing.Process.authkey.__class__.__name__.__eq__, ["property"], true]
    - [PRP005, multiprocessing.Process.daemon.__class__.__name__.__eq__, ["property"], true]
    - [PRP006, multiprocessing.Process.sentinel.__class__.__name__.__eq__, ["property"], true]
