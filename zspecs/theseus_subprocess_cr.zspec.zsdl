spec: theseus_subprocess_cr
version: ">=3.8"
backend: python_cleanroom(theseus_subprocess_cr)
blocks: subprocess

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/subprocess.html"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
  notes:
    - "Clean-room subprocess module. Do NOT import subprocess."

error_model: python_exceptions

invariant theseus_subprocess_cr.subprocess2_run:
  description: "run() executes a command and returns CompletedProcess"
  category: behavior
  kind: python_call_eq
  function: subprocess2_run
  args: []
  expected: true

invariant theseus_subprocess_cr.subprocess2_check_output:
  description: "check_output() captures stdout from a command"
  category: behavior
  kind: python_call_eq
  function: subprocess2_check_output
  args: []
  expected: true

invariant theseus_subprocess_cr.subprocess2_pipe:
  description: "PIPE constant exists and Popen accepts it"
  category: behavior
  kind: python_call_eq
  function: subprocess2_pipe
  args: []
  expected: true
