spec: http_client_extra12
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client_extra2.zspec.zsdl — covers __qualname__.__eq__ for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected/InvalidURL; __module__.__eq__ for HTTPException/HTTPResponse/NotConnected/InvalidURL."
    - "http_client_extra9.zspec.zsdl — covers __name__.__len__() for HTTPSConnection/HTTPResponse/HTTPConnection/BadStatusLine/LineTooLong; __bases__[0].__name__ for HTTPSConnection/HTTPResponse/LineTooLong."
    - "http_client_extra10.zspec.zsdl — covers __qualname__.__len__() for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected; __module__.__len__()==11 for HTTPConnection/HTTPSConnection/HTTPException."
    - "http_client_extra11.zspec.zsdl — covers __qualname__.__eq__ and __qualname__.__len__() for HTTPConnection.request/getresponse/connect/close and HTTPResponse.read/getheader."
  notes:
    - "This spec extends the http.client chain through http_client_extra11; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) __qualname__.__eq__ for additional HTTPResponse methods (getheaders, geturl, info) not covered by extra11; (2) __qualname__.__eq__ for HTTPSConnection.connect — extra2 covers HTTPSConnection class qualname but not its methods; (3) __bases__[0].__name__ for HTTPException == 'Exception'; (4) cross-namespace anchors for HTTPSConnection, NotConnected, InvalidURL class qualnames."
    - "http.client.HTTPResponse.getheaders.__qualname__ == 'HTTPResponse.getheaders' — len 23. extra11 covers read/getheader but not getheaders. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.geturl.__qualname__ == 'HTTPResponse.geturl' — len 19. No prior spec checks this method. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.info.__qualname__ == 'HTTPResponse.info' — len 17. No prior spec checks this method. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPSConnection.__qualname__ == 'HTTPSConnection' — len 15. extra2 covers this; cross-namespace anchor from extra12 namespace provided."
    - "http.client.HTTPSConnection.connect.__qualname__ == 'HTTPSConnection.connect' — len 23. extra11 covers HTTPConnection.connect but not HTTPSConnection.connect. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPException.__bases__[0].__name__ == 'Exception' — len 9. extra9 covers __bases__[0].__name__ for HTTPSConnection/HTTPResponse/LineTooLong but not HTTPException. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.NotConnected.__qualname__ == 'NotConnected' — len 12. extra2 covers this; cross-namespace anchor from extra12 namespace provided."
    - "http.client.InvalidURL.__qualname__ == 'InvalidURL' — len 10. extra2 covers this; cross-namespace anchor from extra12 namespace provided."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTTPResponse additional method __qualname__.__eq__ checks
#
# http_client_extra11 covers HTTPResponse.read and HTTPResponse.getheader.
# This spec adds getheaders, geturl, and info — all commonly-used response
# inspection methods not covered by any prior spec.
# Qualnames: 'HTTPResponse.getheaders' (len 23), 'HTTPResponse.geturl' (len 19),
# 'HTTPResponse.info' (len 17).
# ---------------------------------------------------------------------------

table http_client_extra12.http_response_extra_method_qualnames:
  description: "__qualname__.__eq__ for additional HTTPResponse instance methods"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: hremqn12

  columns: [id, function, args, expected]
  rows:
    - [getheaders, HTTPResponse.getheaders.__qualname__.__eq__, ["HTTPResponse.getheaders"], true]
    - [geturl,     HTTPResponse.geturl.__qualname__.__eq__,     ["HTTPResponse.geturl"],     true]
    - [info,       HTTPResponse.info.__qualname__.__eq__,       ["HTTPResponse.info"],       true]

# ---------------------------------------------------------------------------
# HTTPResponse additional method __qualname__.__len__() checks
#
# No prior spec checks __qualname__.__len__() for getheaders, geturl, or info.
# 'HTTPResponse.getheaders'==23, 'HTTPResponse.geturl'==19,
# 'HTTPResponse.info'==17.
# ---------------------------------------------------------------------------

table http_client_extra12.http_response_extra_method_qualname_lengths:
  description: "Length of __qualname__ strings for additional HTTPResponse methods"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: hremqlen12

  columns: [id, function, args, expected]
  rows:
    - [getheaders, HTTPResponse.getheaders.__qualname__.__len__, [], 23]
    - [geturl,     HTTPResponse.geturl.__qualname__.__len__,     [], 19]
    - [info,       HTTPResponse.info.__qualname__.__len__,       [], 17]

# ---------------------------------------------------------------------------
# HTTPSConnection.connect __qualname__.__eq__ and __len__()
#
# http_client_extra11 covers HTTPConnection.connect.__qualname__ ==
# 'HTTPConnection.connect'. No prior spec checks HTTPSConnection.connect.
# HTTPSConnection overrides connect with its own TLS setup; its qualname
# is 'HTTPSConnection.connect' (len 23).
# ---------------------------------------------------------------------------

invariant http_client_extra12.HTTPSConnection.connect_qualname_eq:
  description: "http.client.HTTPSConnection.connect.__qualname__ == 'HTTPSConnection.connect' — extra11 covers HTTPConnection.connect but not HTTPSConnection.connect"
  category: class_qualnames
  kind: python_call_eq
  function: HTTPSConnection.connect.__qualname__.__eq__
  args: ["HTTPSConnection.connect"]
  expected: true

invariant http_client_extra12.HTTPSConnection.connect_qualname_len:
  description: "len(http.client.HTTPSConnection.connect.__qualname__) == 23 — len('HTTPSConnection.connect') == 23"
  category: class_qualnames
  kind: python_call_eq
  function: HTTPSConnection.connect.__qualname__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# HTTPException.__bases__[0].__name__ == 'Exception'
#
# http_client_extra9 covers __bases__[0].__name__ for HTTPSConnection
# (inherits from HTTPConnection), HTTPResponse (inherits from io.BufferedIOBase),
# and LineTooLong (inherits from HTTPException). It does NOT check the base
# class of HTTPException itself. HTTPException inherits directly from Exception.
# ---------------------------------------------------------------------------

invariant http_client_extra12.HTTPException.bases0_name:
  description: "http.client.HTTPException.__bases__[0].__name__ == 'Exception' — HTTPException inherits directly from Exception; extra9 checks bases for HTTPSConnection/HTTPResponse/LineTooLong but not HTTPException"
  category: class_hierarchy
  kind: python_call_eq
  "function": "HTTPException.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Cross-namespace anchors for HTTPSConnection, NotConnected, InvalidURL
#
# http_client_extra2 covers these class qualnames in its __qualname__.__eq__
# table. The standalone invariants below anchor them from the extra12 namespace
# as cross-namespace regression checkpoints.
# HTTPSConnection.__qualname__ == 'HTTPSConnection' (len 15).
# NotConnected.__qualname__ == 'NotConnected' (len 12).
# InvalidURL.__qualname__ == 'InvalidURL' (len 10).
# ---------------------------------------------------------------------------

invariant http_client_extra12.HTTPSConnection.qualname_eq:
  description: "http.client.HTTPSConnection.__qualname__ == 'HTTPSConnection' — cross-namespace anchor (extra2 covers in table)"
  category: class_qualnames
  kind: python_call_eq
  function: HTTPSConnection.__qualname__.__eq__
  args: ["HTTPSConnection"]
  expected: true

invariant http_client_extra12.NotConnected.qualname_eq:
  description: "http.client.NotConnected.__qualname__ == 'NotConnected' — cross-namespace anchor (extra2 covers in table)"
  category: class_qualnames
  kind: python_call_eq
  function: NotConnected.__qualname__.__eq__
  args: ["NotConnected"]
  expected: true

invariant http_client_extra12.InvalidURL.qualname_eq:
  description: "http.client.InvalidURL.__qualname__ == 'InvalidURL' — cross-namespace anchor (extra2 covers in table)"
  category: class_qualnames
  kind: python_call_eq
  function: InvalidURL.__qualname__.__eq__
  args: ["InvalidURL"]
  expected: true
