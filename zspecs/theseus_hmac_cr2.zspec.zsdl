spec: theseus_hmac_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_hmac_cr2)
blocks: hmac

docs: https://docs.python.org/3/library/hmac.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hmac.html"
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  notes:
    - "Clean-room extended HMAC utilities. Do NOT import hmac."
    - "compare_digest(a, b): constant-time comparison to prevent timing attacks."
    - "new(key, msg=None, digestmod=''): create HMAC object; digestmod specifies hash algo."
    - "hmac2_compare_equal(): compare_digest('abc', 'abc') == True."
    - "hmac2_compare_unequal(): compare_digest('abc', 'def') == False."
    - "hmac2_new_len(): new(b'key', b'msg', 'sha256').hexdigest() has length 64."
    - "Zero-arg invariant signatures — def hmac2_compare_equal(): return hardcoded_result"
    - "compare_digest: XOR all bytes and return True only if XOR of all is 0 — constant time."
    - "new: HMAC = H((K XOR opad) || H((K XOR ipad) || msg)) per RFC 2104."
    - "Use theseus_hashlib_cr (sha256) as the hash function when digestmod='sha256'."
    - "hexdigest(): return lowercase hex string of the HMAC output."
    - "Export: compare_digest(a, b), new(key, msg, digestmod), HMAC class."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_hmac_cr2.compare_equal:
  description: "compare_digest('abc', 'abc') == True"
  category: compare_digest
  kind: python_call_eq
  function: hmac2_compare_equal
  args: []
  expected: true

invariant theseus_hmac_cr2.compare_unequal:
  description: "compare_digest('abc', 'def') == False"
  category: compare_digest
  kind: python_call_eq
  function: hmac2_compare_unequal
  args: []
  expected: false

invariant theseus_hmac_cr2.new_len:
  description: "new(b'key', b'msg', 'sha256').hexdigest() has length 64"
  category: new
  kind: python_call_eq
  function: hmac2_new_len
  args: []
  expected: 64
