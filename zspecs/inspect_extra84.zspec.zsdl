spec: inspect_extra84
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra83

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra83.zspec.zsdl."
    - "This spec covers: inspect Signature/Parameter/BoundArguments __dict__ membership (Wave 248)."
    - "inspect.Signature.__dict__.__contains__('__init__') == True — Signature defines __init__. Verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__contains__('bind') == True — Signature defines bind(). Verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__contains__('bind_partial') == True — Signature defines bind_partial(). Verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__contains__('replace') == True — Signature defines replace(). Verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__contains__('from_callable') == True — Signature defines from_callable(). Verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__contains__('parameters') == True — Signature defines parameters property. Verified with Python 3.14.3."
    - "inspect.Signature.__dict__.__class__.__name__ == 'mappingproxy' — Signature.__dict__ is a mappingproxy. Verified with Python 3.14.3."
    - "inspect.Parameter.__dict__.__contains__('__init__') == True — Parameter defines __init__. Verified with Python 3.14.3."
    - "inspect.Parameter.__dict__.__contains__('replace') == True — Parameter defines replace(). Verified with Python 3.14.3."
    - "inspect.Parameter.__dict__.__contains__('kind') == True — Parameter defines kind property. Verified with Python 3.14.3."
    - "inspect.Parameter.__dict__.__class__.__name__ == 'mappingproxy' — Parameter.__dict__ is a mappingproxy. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__dict__.__contains__('__init__') == True — BoundArguments defines __init__. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__dict__.__contains__('args') == True — BoundArguments defines args property. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__dict__.__contains__('kwargs') == True — BoundArguments defines kwargs property. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Signature.__dict__ membership — __init__/bind/bind_partial/replace — extra84
#
# Wave 248 theme: inspect.Signature __dict__ membership.
#
# inspect.Signature.__dict__.__contains__('__init__')    == True
# inspect.Signature.__dict__.__contains__('bind')        == True
# inspect.Signature.__dict__.__contains__('bind_partial') == True
# inspect.Signature.__dict__.__contains__('replace')     == True
#
# No prior inspect spec checks Signature.__dict__.__contains__ for these members via inspectextra84. New to extra84.
# ---------------------------------------------------------------------------

table inspect_extra84.Signature_dict_group1:
  description: "Signature.__dict__.__contains__ for __init__/bind/bind_partial/replace; wave 248 inspect Signature __dict__ membership; new to extra84"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra84

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_dict_contains_init,
       Signature.__dict__.__contains__,
       ["__init__"],
       true,
       "inspect.Signature.__dict__.__contains__('__init__') == True — Signature is a pure-Python class defined in Lib/inspect.py; it defines __init__ in its own namespace to initialize signature objects; __dict__.__contains__('__init__') returns True; no prior inspect spec checks Signature.__dict__.__contains__('__init__') via inspectextra84; new to extra84"]
    - [Signature_dict_contains_bind,
       Signature.__dict__.__contains__,
       ["bind"],
       true,
       "inspect.Signature.__dict__.__contains__('bind') == True — Signature defines bind() in its own namespace; bind() creates a BoundArguments from positional and keyword arguments; __dict__.__contains__('bind') returns True; no prior inspect spec checks Signature.__dict__.__contains__('bind') via inspectextra84; new to extra84"]
    - [Signature_dict_contains_bind_partial,
       Signature.__dict__.__contains__,
       ["bind_partial"],
       true,
       "inspect.Signature.__dict__.__contains__('bind_partial') == True — Signature defines bind_partial() in its own namespace; bind_partial() works like bind() but allows missing arguments; __dict__.__contains__('bind_partial') returns True; no prior inspect spec checks Signature.__dict__.__contains__('bind_partial') via inspectextra84; new to extra84"]
    - [Signature_dict_contains_replace,
       Signature.__dict__.__contains__,
       ["replace"],
       true,
       "inspect.Signature.__dict__.__contains__('replace') == True — Signature defines replace() in its own namespace; replace() creates a modified copy with altered parameters or return annotation; __dict__.__contains__('replace') returns True; no prior inspect spec checks Signature.__dict__.__contains__('replace') via inspectextra84; new to extra84"]

# ---------------------------------------------------------------------------
# inspect.Signature.__dict__ membership — from_callable/parameters + class name — extra84
#
# Wave 248 theme: inspect.Signature __dict__ additional membership.
#
# inspect.Signature.__dict__.__contains__('from_callable')  == True
# inspect.Signature.__dict__.__contains__('parameters')     == True
# inspect.Signature.__dict__.__class__.__name__             == 'mappingproxy'
# inspect.Parameter.__dict__.__contains__('__init__')       == True
#
# No prior inspect spec checks these via inspectextra84. New to extra84.
# ---------------------------------------------------------------------------

table inspect_extra84.Signature_dict_group2:
  description: "Signature.__dict__ contains from_callable/parameters; Signature.__dict__ class name is mappingproxy; Parameter.__dict__ contains __init__; wave 248; new to extra84"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra84

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_dict_contains_from_callable,
       Signature.__dict__.__contains__,
       ["from_callable"],
       true,
       "inspect.Signature.__dict__.__contains__('from_callable') == True — Signature defines from_callable() as a classmethod in its own namespace; from_callable() is the preferred alternative to inspect.signature(); __dict__.__contains__('from_callable') returns True; no prior inspect spec checks Signature.__dict__.__contains__('from_callable') via inspectextra84; new to extra84"]
    - [Signature_dict_contains_parameters,
       Signature.__dict__.__contains__,
       ["parameters"],
       true,
       "inspect.Signature.__dict__.__contains__('parameters') == True — Signature defines parameters as a property in its own namespace; parameters is an OrderedDict mapping parameter names to Parameter objects; __dict__.__contains__('parameters') returns True; no prior inspect spec checks Signature.__dict__.__contains__('parameters') via inspectextra84; new to extra84"]
    - [Signature_dict_class_name_eq_mappingproxy,
       Signature.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "inspect.Signature.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Signature.__dict__ is a types.MappingProxyType (mappingproxy) wrapping the class namespace; its __class__.__name__ is 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior inspect spec checks Signature.__dict__.__class__.__name__ via inspectextra84; new to extra84"]
    - [Parameter_dict_contains_init,
       Parameter.__dict__.__contains__,
       ["__init__"],
       true,
       "inspect.Parameter.__dict__.__contains__('__init__') == True — Parameter is a pure-Python class defined in Lib/inspect.py; it defines __init__ in its own namespace to initialize Parameter objects; __dict__.__contains__('__init__') returns True; no prior inspect spec checks Parameter.__dict__.__contains__('__init__') via inspectextra84; new to extra84"]

# ---------------------------------------------------------------------------
# inspect.Parameter.__dict__ membership — replace/kind + class name — extra84
#
# Wave 248 theme: inspect.Parameter __dict__ membership.
#
# inspect.Parameter.__dict__.__contains__('replace')       == True
# inspect.Parameter.__dict__.__contains__('kind')          == True
# inspect.Parameter.__dict__.__class__.__name__            == 'mappingproxy'
# inspect.BoundArguments.__dict__.__contains__('__init__') == True
#
# No prior inspect spec checks these via inspectextra84. New to extra84.
# ---------------------------------------------------------------------------

table inspect_extra84.Parameter_dict_and_BoundArguments_init:
  description: "Parameter.__dict__ contains replace/kind; Parameter.__dict__ class name mappingproxy; BoundArguments.__dict__ contains __init__; wave 248; new to extra84"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra84

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_dict_contains_replace,
       Parameter.__dict__.__contains__,
       ["replace"],
       true,
       "inspect.Parameter.__dict__.__contains__('replace') == True — Parameter defines replace() in its own namespace; replace() creates a modified copy of a Parameter with altered attributes; __dict__.__contains__('replace') returns True; no prior inspect spec checks Parameter.__dict__.__contains__('replace') via inspectextra84; new to extra84"]
    - [Parameter_dict_contains_kind,
       Parameter.__dict__.__contains__,
       ["kind"],
       true,
       "inspect.Parameter.__dict__.__contains__('kind') == True — Parameter defines kind as a property in its own namespace; kind describes the parameter-passing mechanism (POSITIONAL_ONLY, KEYWORD_ONLY, etc.); __dict__.__contains__('kind') returns True; no prior inspect spec checks Parameter.__dict__.__contains__('kind') via inspectextra84; new to extra84"]
    - [Parameter_dict_class_name_eq_mappingproxy,
       Parameter.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "inspect.Parameter.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Parameter.__dict__ is a types.MappingProxyType (mappingproxy) wrapping the class namespace; its __class__.__name__ is 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior inspect spec checks Parameter.__dict__.__class__.__name__ via inspectextra84; new to extra84"]
    - [BoundArguments_dict_contains_init,
       BoundArguments.__dict__.__contains__,
       ["__init__"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('__init__') == True — BoundArguments is a pure-Python class defined in Lib/inspect.py; it defines __init__ in its own namespace; __dict__.__contains__('__init__') returns True; no prior inspect spec checks BoundArguments.__dict__.__contains__('__init__') via inspectextra84; new to extra84"]

# ---------------------------------------------------------------------------
# inspect.BoundArguments.__dict__ membership — args/kwargs — extra84
#
# Wave 248 theme: inspect.BoundArguments __dict__ membership.
#
# inspect.BoundArguments.__dict__.__contains__('args')   == True
# inspect.BoundArguments.__dict__.__contains__('kwargs') == True
#
# No prior inspect spec checks BoundArguments.__dict__.__contains__('args'/'kwargs') via inspectextra84. New to extra84.
# ---------------------------------------------------------------------------

table inspect_extra84.BoundArguments_dict_args_kwargs:
  description: "BoundArguments.__dict__ contains args/kwargs; BoundArguments.__dict__ class name mappingproxy; wave 248; new to extra84"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra84

  columns: [id, function, args, expected, description]
  rows:
    - [BoundArguments_dict_contains_args,
       BoundArguments.__dict__.__contains__,
       ["args"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('args') == True — BoundArguments defines args as a property in its own namespace; args returns a tuple of positional arguments values; __dict__.__contains__('args') returns True; no prior inspect spec checks BoundArguments.__dict__.__contains__('args') via inspectextra84; new to extra84"]
    - [BoundArguments_dict_contains_kwargs,
       BoundArguments.__dict__.__contains__,
       ["kwargs"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('kwargs') == True — BoundArguments defines kwargs as a property in its own namespace; kwargs returns a dict of keyword arguments values; __dict__.__contains__('kwargs') returns True; no prior inspect spec checks BoundArguments.__dict__.__contains__('kwargs') via inspectextra84; new to extra84"]
    - [BoundArguments_dict_class_name_eq_mappingproxy,
       BoundArguments.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "inspect.BoundArguments.__dict__.__class__.__name__.__eq__('mappingproxy') == True — BoundArguments.__dict__ is a types.MappingProxyType (mappingproxy) wrapping the class namespace; its __class__.__name__ is 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior inspect spec checks BoundArguments.__dict__.__class__.__name__ via inspectextra84; new to extra84"]
    - [Signature_dict_class_name_len_eq_12,
       Signature.__dict__.__class__.__name__.__len__,
       [],
       12,
       "inspect.Signature.__dict__.__class__.__name__.__len__() == 12 — the string 'mappingproxy' has 12 characters: m,a,p,p,i,n,g,p,r,o,x,y; str.__len__() returns 12; verifies the class name length; no prior inspect spec checks this length via inspectextra84; new to extra84"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra84
# ---------------------------------------------------------------------------

invariant inspect_extra84.Signature_dict_contains_bind:
  description: "inspect.Signature.__dict__.__contains__('bind') == True — Signature defines bind() in its own namespace; wave 248; new to extra84"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["bind"]
  expected: true

invariant inspect_extra84.Signature_dict_contains_from_callable:
  description: "inspect.Signature.__dict__.__contains__('from_callable') == True — Signature defines from_callable() in its own namespace; wave 248; new to extra84"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["from_callable"]
  expected: true

invariant inspect_extra84.Parameter_dict_contains_replace:
  description: "inspect.Parameter.__dict__.__contains__('replace') == True — Parameter defines replace() in its own namespace; wave 248; new to extra84"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["replace"]
  expected: true

invariant inspect_extra84.BoundArguments_dict_contains_args:
  description: "inspect.BoundArguments.__dict__.__contains__('args') == True — BoundArguments defines args property in its own namespace; wave 248; new to extra84"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["args"]
  expected: true

invariant inspect_extra84.BoundArguments_dict_contains_kwargs:
  description: "inspect.BoundArguments.__dict__.__contains__('kwargs') == True — BoundArguments defines kwargs property in its own namespace; wave 248; new to extra84"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["kwargs"]
  expected: true
