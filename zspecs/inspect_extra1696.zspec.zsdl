spec: inspect_extra1696
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python inspect documentation — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect.zspec.zsdl — covers isfunction, isbuiltin, isclass, ismodule, isroutine, signature, getmembers, getdoc, Parameter kind values and names, CO_* flag constants"
    - "inspect_extra.zspec.zsdl — covers __name__ and __module__ tables, isclass/isbuiltin true/false cases, Parameter/Signature classnames"
    - "inspect_extra1681.zspec.zsdl — covers __call__ callable protocol, __slots__ presence, and key method presence for Parameter/Signature/BoundArguments"
  notes:
    - "Wave 560 (_extra1696): pickling protocol — which stdlib types define __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__ in their own __dict__."
    - "inspect.Parameter defines __reduce__ and __setstate__ in its __dict__ (confirmed in inspect_extra1681 slots_and_protocol_attrs table)."
    - "inspect.Parameter does NOT define __getstate__, __getnewargs__, or __getnewargs_ex__ — it uses a custom __reduce__/__setstate__ pair."
    - "inspect.BoundArguments defines __getstate__ and __setstate__ in its __dict__ (confirmed in inspect_extra1681 slots_and_protocol_attrs table)."
    - "inspect.BoundArguments does NOT define __reduce__, __getnewargs__, or __getnewargs_ex__."
    - "inspect.Signature does NOT define any pickling protocol methods in its __dict__ — it is not designed for pickling."
    - "None of the three inspect classes define __copy__ or __deepcopy__ in their __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: pickling_protocol
#
# Records which of the five pickling protocol methods are present in the
# __dict__ of inspect.Parameter, inspect.Signature, and inspect.BoundArguments.
#
# Parameter:      __reduce__ → True, __setstate__ → True, others → False.
# BoundArguments: __getstate__ → True, __setstate__ → True, others → False.
# Signature:      all five → False.
# ---------------------------------------------------------------------------

table inspect_extra1696.pickling_protocol:
  description: "inspect classes pickling protocol dict-presence checks"
  kind: python_call_eq
  category: pickling_protocol
  id_prefix: in1696

  columns: [id, function, args, expected]
  rows:
    - ["in1696001", "inspect.Parameter.__dict__.__contains__",      ["__reduce__"],       true]
    - ["in1696002", "inspect.Parameter.__dict__.__contains__",      ["__setstate__"],     true]
    - ["in1696003", "inspect.Parameter.__dict__.__contains__",      ["__getstate__"],     false]
    - ["in1696004", "inspect.Parameter.__dict__.__contains__",      ["__getnewargs__"],   false]
    - ["in1696005", "inspect.Parameter.__dict__.__contains__",      ["__getnewargs_ex__"], false]
    - ["in1696006", "inspect.Signature.__dict__.__contains__",      ["__reduce__"],       false]
    - ["in1696007", "inspect.Signature.__dict__.__contains__",      ["__getstate__"],     false]
    - ["in1696008", "inspect.Signature.__dict__.__contains__",      ["__setstate__"],     false]
    - ["in1696009", "inspect.Signature.__dict__.__contains__",      ["__getnewargs__"],   false]
    - ["in1696010", "inspect.Signature.__dict__.__contains__",      ["__getnewargs_ex__"], false]
    - ["in1696011", "inspect.BoundArguments.__dict__.__contains__", ["__getstate__"],     true]
    - ["in1696012", "inspect.BoundArguments.__dict__.__contains__", ["__setstate__"],     true]
    - ["in1696013", "inspect.BoundArguments.__dict__.__contains__", ["__reduce__"],       false]
    - ["in1696014", "inspect.BoundArguments.__dict__.__contains__", ["__getnewargs__"],   false]
    - ["in1696015", "inspect.BoundArguments.__dict__.__contains__", ["__getnewargs_ex__"], false]

# ---------------------------------------------------------------------------
# Table 2: copy_protocol_absent
#
# Verifies that __copy__ and __deepcopy__ are absent from the __dict__ of
# all three inspect classes.  None define custom copy protocol methods.
# ---------------------------------------------------------------------------

table inspect_extra1696.copy_protocol_absent:
  description: "inspect classes do not define __copy__ or __deepcopy__ in their __dict__"
  kind: python_call_eq
  category: copy_protocol_absent
  id_prefix: in1696

  columns: [id, function, args, expected]
  rows:
    - ["in1696020", "inspect.Parameter.__dict__.__contains__",      ["__copy__"],     false]
    - ["in1696021", "inspect.Parameter.__dict__.__contains__",      ["__deepcopy__"], false]
    - ["in1696022", "inspect.Signature.__dict__.__contains__",      ["__copy__"],     false]
    - ["in1696023", "inspect.Signature.__dict__.__contains__",      ["__deepcopy__"], false]
    - ["in1696024", "inspect.BoundArguments.__dict__.__contains__", ["__copy__"],     false]
    - ["in1696025", "inspect.BoundArguments.__dict__.__contains__", ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: pickling_context
#
# Contrasts the pickling dunder methods with adjacent structural attributes
# to confirm the exact split between Parameter (uses __reduce__/__setstate__)
# and BoundArguments (uses __getstate__/__setstate__), and that Signature
# defines neither.
# ---------------------------------------------------------------------------

table inspect_extra1696.pickling_context:
  description: "inspect pickling protocol attrs in context of other structural attrs"
  kind: python_call_eq
  category: pickling_context
  id_prefix: in1696

  columns: [id, function, args, expected]
  rows:
    - ["in1696030", "inspect.Parameter.__dict__.__contains__",      ["__reduce__"],    true]
    - ["in1696031", "inspect.Parameter.__dict__.__contains__",      ["__setstate__"],  true]
    - ["in1696032", "inspect.Parameter.__dict__.__contains__",      ["__slots__"],     true]
    - ["in1696033", "inspect.Parameter.__dict__.__contains__",      ["__init__"],      true]
    - ["in1696034", "inspect.Parameter.__dict__.__contains__",      ["__repr__"],      true]
    - ["in1696035", "inspect.Parameter.__dict__.__contains__",      ["replace"],       true]
    - ["in1696036", "inspect.BoundArguments.__dict__.__contains__", ["__getstate__"],  true]
    - ["in1696037", "inspect.BoundArguments.__dict__.__contains__", ["__setstate__"],  true]
    - ["in1696038", "inspect.BoundArguments.__dict__.__contains__", ["__reduce__"],    false]
    - ["in1696039", "inspect.BoundArguments.__dict__.__contains__", ["__slots__"],     true]
    - ["in1696040", "inspect.BoundArguments.__dict__.__contains__", ["apply_defaults"], true]
    - ["in1696041", "inspect.Signature.__dict__.__contains__",      ["__reduce__"],    false]
    - ["in1696042", "inspect.Signature.__dict__.__contains__",      ["__getstate__"],  false]
    - ["in1696043", "inspect.Signature.__dict__.__contains__",      ["__setstate__"],  false]
    - ["in1696044", "inspect.Signature.__dict__.__contains__",      ["__slots__"],     true]
    - ["in1696045", "inspect.Signature.__dict__.__contains__",      ["bind"],          true]
