spec: struct_extra370
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct.pack.__name__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__name__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__name__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__name__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All five struct functions (pack, unpack, pack_into, unpack_from, iter_unpack) are C builtins defined in the _struct C extension (Modules/_struct.c); their __module__ is '_struct' for all."
    - "Note: struct.py re-exports these functions from _struct into the struct namespace; the __module__ attribute reflects the origin C extension, not the re-exporting Python module."
    - "Note: pack packs values into bytes; unpack extracts values from bytes; pack_into writes into a writable buffer; unpack_from reads from a buffer at offset; iter_unpack yields repeated structs from a buffer."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__name__ / struct.pack.__module__
# struct.unpack.__name__ / struct.unpack.__module__
# struct.pack_into.__name__ / struct.pack_into.__module__
# struct.unpack_from.__name__ / struct.unpack_from.__module__
# struct.iter_unpack.__name__ / struct.iter_unpack.__module__
#
# Wave 370 theme: struct module function identity.
#
# All five core struct functions are C builtins defined in Modules/_struct.c.
# They are re-exported from _struct into the struct namespace by Lib/struct.py.
# Despite the re-export, all five report __module__ == '_struct' because their
# function objects originate in the C extension.
#
# pack: Packs values into a bytes object according to a format string.
# unpack: Unpacks bytes into a tuple of values according to a format string.
# pack_into: Packs values directly into a writable buffer (bytearray, etc.)
#            at a given offset, avoiding allocation of a new bytes object.
# unpack_from: Unpacks values from a buffer starting at a given offset,
#              without requiring the buffer to be exactly the right size.
# iter_unpack: Returns an iterator that repeatedly unpacks fixed-size chunks
#              from a buffer; useful for parsing repeated records.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra370.function_dunder_name:
  description: "struct function __name__ identity — pack/unpack/pack_into/unpack_from/iter_unpack are all C builtins in _struct extension; __name__ matches the public function name exactly; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: structfnid370

  columns: [id, function, args, expected]
  rows:
    - [pack_name,        pack.__name__.__eq__,        ["pack"],        true]
    - [unpack_name,      unpack.__name__.__eq__,      ["unpack"],      true]
    - [pack_into_name,   pack_into.__name__.__eq__,   ["pack_into"],   true]
    - [unpack_from_name, unpack_from.__name__.__eq__, ["unpack_from"], true]
    - [iter_unpack_name, iter_unpack.__name__.__eq__, ["iter_unpack"], true]

table struct_extra370.function_dunder_module:
  description: "struct function __module__ identity — pack/unpack/pack_into/unpack_from/iter_unpack all report __module__=='_struct'; all are C builtins from Modules/_struct.c re-exported into struct namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: structfnid370

  columns: [id, function, args, expected]
  rows:
    - [pack_module,        pack.__module__.__eq__,        ["_struct"], true]
    - [unpack_module,      unpack.__module__.__eq__,      ["_struct"], true]
    - [pack_into_module,   pack_into.__module__.__eq__,   ["_struct"], true]
    - [unpack_from_module, unpack_from.__module__.__eq__, ["_struct"], true]
    - [iter_unpack_module, iter_unpack.__module__.__eq__, ["_struct"], true]

# ---------------------------------------------------------------------------
# struct.pack.__module__ == '_struct' — standalone
#
# struct.pack is a C builtin defined in Modules/_struct.c. It packs one or
# more values into a bytes object according to a format string. Despite being
# accessible as struct.pack (re-exported by Lib/struct.py), its __module__
# is '_struct' because the function object originates in the C extension.
# struct format strings use characters like 'i' (int), 'f' (float), 'c'
# (char), '>' (big-endian), '<' (little-endian), etc. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra370.pack_module:
  description: "struct.pack.__module__.__eq__('_struct') == True — pack is a C builtin in Modules/_struct.c; packs values into bytes per format string; __module__ is '_struct' despite re-export via Lib/struct.py; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: pack.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.iter_unpack.__name__ == 'iter_unpack' — standalone
#
# struct.iter_unpack returns an iterator of tuples, each unpacked from a
# fixed-size chunk of the buffer according to the format string. Unlike
# unpack_from, it processes the entire buffer without needing to specify an
# offset manually. It was added in Python 3.4. Like all struct functions, it
# is implemented in C (_struct extension). Its __name__ is 'iter_unpack'
# and __module__ is '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra370.iter_unpack_name:
  description: "struct.iter_unpack.__name__.__eq__('iter_unpack') == True — iter_unpack is a C builtin in _struct; yields repeated fixed-size struct records from a buffer; added Python 3.4; __name__ is 'iter_unpack'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: iter_unpack.__name__.__eq__
  args: ["iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack_from.__module__ == '_struct' — standalone
#
# struct.unpack_from unpacks values from a buffer starting at a given byte
# offset. Unlike unpack, the buffer may be larger than the struct size —
# only the relevant slice is read. It is useful for parsing binary data
# streams or file formats where multiple records appear consecutively.
# It is a C builtin in _struct with __module__ == '_struct'. Verified
# Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra370.unpack_from_module:
  description: "struct.unpack_from.__module__.__eq__('_struct') == True — unpack_from is a C builtin in _struct; unpacks from buffer at given offset; buffer may exceed struct size; __module__ is '_struct'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: unpack_from.__module__.__eq__
  args: ["_struct"]
  expected: true
