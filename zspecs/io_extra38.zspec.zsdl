spec: io_extra38
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra37.zspec.zsdl — covers __all__.__len__()==24, __all__.__class__.__name__.__len__()==4; __dict__.__class__.__name__.__len__()==12 for StringIO/BytesIO/IOBase/FileIO/RawIOBase/BufferedReader/TextIOWrapper; __reduce__.__name__.__len__()==10 for StringIO/BytesIO/IOBase/FileIO; __init_subclass__.__qualname__.__len__() for all eight io classes; SEEK_SET value (0); DEFAULT_BUFFER_SIZE.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends io_extra37.zspec.zsdl."
    - "Prior specs collectively covered: __name__/__module__/__qualname__/__dict__.__class__.__name__/__reduce__.__name__/__init_subclass__.__qualname__ for all ten io classes; __mro__.__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/StringIO/BytesIO; __bases__[0].__name__ for IOBase/RawIOBase/BufferedIOBase/TextIOBase; SEEK_* values; DEFAULT_BUFFER_SIZE; __all__.__len__()==24."
    - "This spec covers NEW angles: io.StringIO.__mro__.__len__()==4 and io.BytesIO.__mro__.__len__()==4; io.BufferedWriter.__mro__.__len__()==4; io.TextIOWrapper.__mro__.__len__()==4; io.BufferedRWPair.__mro__.__len__()==4; io.BufferedRandom.__mro__.__len__()==4; io.StringIO.__bases__[0].__name__.__len__()==11 ('_TextIOBase'); io.BytesIO.__bases__[0].__name__.__len__()==15 ('_BufferedIOBase'); io.BufferedWriter.__bases__[0].__name__.__len__()==15; io.TextIOWrapper.__bases__[0].__name__.__len__()==11; io.SEEK_CUR.__class__.__name__.__len__()==3; io.SEEK_END.__class__.__name__.__len__()==3; StringIO method __qualname__.__len__() (read=13, write=14, getvalue=17, seek=13); BytesIO method __qualname__.__len__() (read=12, write=13, getvalue=16, seek=12); TextIOWrapper method __qualname__.__len__() (read=18, write=19, readline=22, seek=18)."
    - "io.StringIO.__mro__ = [StringIO, _TextIOBase, _IOBase, object] — len 4. Verified Python 3.12."
    - "io.BytesIO.__mro__ = [BytesIO, _BufferedIOBase, _IOBase, object] — len 4. Verified Python 3.12."
    - "io.BufferedWriter.__mro__ = [BufferedWriter, _BufferedIOBase, _IOBase, object] — len 4. Verified Python 3.12."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — len 11. Verified Python 3.12."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — len 15. Verified Python 3.12."
    - "io.SEEK_CUR.__class__.__name__ == 'int' — len 3. io.SEEK_END.__class__.__name__ == 'int' — len 3. Verified Python 3.12."
    - "io.StringIO.read.__qualname__ == 'StringIO.read' (13), write (14), getvalue (17), seek (13). Verified Python 3.12."
    - "io.BytesIO.read.__qualname__ == 'BytesIO.read' (12), write (13), getvalue (16), seek (12). Verified Python 3.12."
    - "io.TextIOWrapper.read.__qualname__ == 'TextIOWrapper.read' (18), write (19), readline (22), seek (18). Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StringIO, BytesIO, BufferedWriter, TextIOWrapper, BufferedRWPair,
# BufferedRandom __mro__.__len__() — all 4
#
# These concrete io classes have MRO depth 4:
#   StringIO     -> _TextIOBase    -> _IOBase -> object
#   BytesIO      -> _BufferedIOBase -> _IOBase -> object
#   BufferedWriter -> _BufferedIOBase -> _IOBase -> object
#   TextIOWrapper -> _TextIOBase   -> _IOBase -> object
#   BufferedRWPair -> _BufferedIOBase -> _IOBase -> object
#   BufferedRandom -> _BufferedIOBase -> _IOBase -> object
# No prior io spec checks __mro__.__len__() for any of these six classes.
# ---------------------------------------------------------------------------

table io_extra38.concrete_class_mro_len:
  description: "io concrete class __mro__.__len__() == 4 — StringIO/BytesIO/BufferedWriter/TextIOWrapper/BufferedRWPair/BufferedRandom all have MRO depth 4"
  kind: python_call_eq
  category: class_introspection
  id_prefix: icm38

  columns: [id, function, args, expected]
  rows:
    - [StringIO,       StringIO.__mro__.__len__,       [], 4]
    - [BytesIO,        BytesIO.__mro__.__len__,        [], 4]
    - [BufferedWriter, BufferedWriter.__mro__.__len__,  [], 4]
    - [TextIOWrapper,  TextIOWrapper.__mro__.__len__,   [], 4]
    - [BufferedRWPair, BufferedRWPair.__mro__.__len__,  [], 4]
    - [BufferedRandom, BufferedRandom.__mro__.__len__,  [], 4]

# ---------------------------------------------------------------------------
# io class __bases__[0].__name__.__len__() for concrete classes
#
# StringIO and TextIOWrapper inherit from _TextIOBase (len 11).
# BytesIO, BufferedWriter, BufferedRWPair, BufferedRandom inherit from
# _BufferedIOBase (len 15). No prior io spec checks __bases__[0].__name__.__len__()
# for any of these six concrete classes (only abstract classes were covered).
# ---------------------------------------------------------------------------

invariant io_extra38.StringIO.bases_name_len:
  description: "io.StringIO.__bases__[0].__name__.__len__() == 11 — '_TextIOBase' has 11 characters"
  category: class_introspection
  kind: python_call_eq
  function: "StringIO.__bases__[0].__name__.__len__"
  args: []
  expected: 11

invariant io_extra38.TextIOWrapper.bases_name_len:
  description: "io.TextIOWrapper.__bases__[0].__name__.__len__() == 11 — '_TextIOBase' has 11 characters"
  category: class_introspection
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__len__"
  args: []
  expected: 11

table io_extra38.buffered_class_bases_name_len:
  description: "io buffered class __bases__[0].__name__.__len__() == 15 for BytesIO/BufferedWriter/BufferedRWPair/BufferedRandom — '_BufferedIOBase' has 15 characters"
  kind: python_call_eq
  category: class_introspection
  id_prefix: ibb38

  columns: [id, function, args, expected]
  rows:
    - [BytesIO,        "BytesIO.__bases__[0].__name__.__len__",        [], 15]
    - [BufferedWriter, "BufferedWriter.__bases__[0].__name__.__len__",  [], 15]
    - [BufferedRWPair, "BufferedRWPair.__bases__[0].__name__.__len__",  [], 15]
    - [BufferedRandom, "BufferedRandom.__bases__[0].__name__.__len__",  [], 15]

# ---------------------------------------------------------------------------
# io.SEEK_CUR and SEEK_END __class__.__name__.__len__()
#
# io_extra37 checked SEEK_SET value (0) and DEFAULT_BUFFER_SIZE __class__.__name__.__len__().
# This spec adds the __class__.__name__.__len__() check for SEEK_CUR (1) and SEEK_END (2).
# Both are plain Python int instances; len('int') == 3.
# ---------------------------------------------------------------------------

invariant io_extra38.SEEK_CUR.class_name_len:
  description: "io.SEEK_CUR.__class__.__name__.__len__() == 3 — SEEK_CUR is an int; len('int') == 3"
  category: constants
  kind: python_call_eq
  function: SEEK_CUR.__class__.__name__.__len__
  args: []
  expected: 3

invariant io_extra38.SEEK_END.class_name_len:
  description: "io.SEEK_END.__class__.__name__.__len__() == 3 — SEEK_END is an int; len('int') == 3"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__class__.__name__.__len__
  args: []
  expected: 3

