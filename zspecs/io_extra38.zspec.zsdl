# StringIO.getvalue -> 'StringIO.getvalue' -> 17
# StringIO.seek   -> 'StringIO.seek'   -> 13
# No prior io spec checks __qualname__.__len__() for any StringIO method.
# ---------------------------------------------------------------------------

