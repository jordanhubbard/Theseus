spec: abc_extra198
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers abc.__spec__ deeper attributes: name, has_location, parent, __class__.__name__, origin."
    - "abc.__spec__.name == 'abc' — the ModuleSpec's name attribute matches the module name. Verified with Python 3.14.3."
    - "abc.__spec__.has_location == False — abc is a frozen module (FrozenImporter); frozen modules have no file location; has_location is False. Verified with Python 3.14.3."
    - "abc.__spec__.parent == '' — abc is a top-level single-file (frozen) module; it is not a package; __spec__.parent is an empty string. Verified with Python 3.14.3."
    - "abc.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "abc.__spec__.origin == 'frozen' — abc is loaded by FrozenImporter; the origin is the string 'frozen'. Verified with Python 3.14.3."
    - "abc.__spec__.has_location.__class__.__name__ == 'bool' — has_location is a plain Python bool even when False. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.__spec__.name identity
#
# abc.__spec__.name == 'abc' (len 3)
# abc is a frozen top-level module; its ModuleSpec.name is 'abc'.
# New to abc_extra198.
# ---------------------------------------------------------------------------

table abc_extra198.spec_name:
  description: "abc.__spec__.name == 'abc' and its length is 3; new to abc_extra198"
  kind: python_call_eq
  category: spec_attrs
  id_prefix: abcspec198

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       "__spec__.name.__eq__",
       ["abc"],
       true,
       "abc.__spec__.name.__eq__('abc') == True — ModuleSpec.name equals 'abc'; new to abc_extra198"]
    - [spec_name_len_eq_3,
       "__spec__.name.__len__",
       [],
       3,
       "abc.__spec__.name.__len__() == 3 — 'abc' has 3 characters; new to abc_extra198"]
    - [spec_name_class_eq,
       "__spec__.name.__class__.__name__.__eq__",
       ["str"],
       true,
       "abc.__spec__.name.__class__.__name__.__eq__('str') == True — ModuleSpec.name is a str; new to abc_extra198"]
    - [spec_name_contains_abc,
       "__spec__.name.__contains__",
       ["abc"],
       true,
       "abc.__spec__.name.__contains__('abc') == True — name contains 'abc'; new to abc_extra198"]

# ---------------------------------------------------------------------------
# Table 2: abc.__spec__.has_location and abc.__spec__.parent
#
# abc.__spec__.has_location == False — frozen module; no file location
# abc.__spec__.parent == '' — not a package; parent is empty string
# New to abc_extra198.
# ---------------------------------------------------------------------------

table abc_extra198.spec_has_location_parent:
  description: "abc.__spec__.has_location == False (frozen module); abc.__spec__.parent == '' (not a package); new to abc_extra198"
  kind: python_call_eq
  category: spec_attrs
  id_prefix: abcspec198

  columns: [id, function, args, expected, description]
  rows:
    - [spec_hasloc_eq_false,
       "__spec__.has_location.__eq__",
       [false],
       true,
       "abc.__spec__.has_location.__eq__(False) == True — abc is a frozen module; has_location is False; new to abc_extra198"]
    - [spec_hasloc_class_eq_bool,
       "__spec__.has_location.__class__.__name__.__eq__",
       ["bool"],
       true,
       "abc.__spec__.has_location.__class__.__name__.__eq__('bool') == True — has_location is a bool even when False; new to abc_extra198"]
    - [spec_parent_eq_empty,
       "__spec__.parent.__eq__",
       [""],
       true,
       "abc.__spec__.parent.__eq__('') == True — abc is not a package; parent is the empty string; new to abc_extra198"]
    - [spec_parent_len_eq_0,
       "__spec__.parent.__len__",
       [],
       0,
       "abc.__spec__.parent.__len__() == 0 — parent is the empty string with length 0; new to abc_extra198"]

# ---------------------------------------------------------------------------
# Table 3: abc.__spec__.__class__.__name__ and abc.__spec__.origin
#
# abc.__spec__.__class__.__name__ == 'ModuleSpec' (len 10)
# abc.__spec__.origin == 'frozen' (len 6)
#
# abc is a frozen module loaded by FrozenImporter; the spec's origin
# attribute is the string 'frozen'. New to abc_extra198.
# ---------------------------------------------------------------------------

table abc_extra198.spec_class_and_origin:
  description: "abc.__spec__.__class__.__name__ == 'ModuleSpec'; abc.__spec__.origin == 'frozen'; new to abc_extra198"
  kind: python_call_eq
  category: spec_attrs
  id_prefix: abcspec198

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "abc.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — spec is a ModuleSpec instance; new to abc_extra198"]
    - [spec_class_name_len_eq_10,
       "__spec__.__class__.__name__.__len__",
       [],
       10,
       "abc.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters; new to abc_extra198"]
    - [spec_origin_eq_frozen,
       "__spec__.origin.__eq__",
       ["frozen"],
       true,
       "abc.__spec__.origin.__eq__('frozen') == True — abc is a frozen module; origin is 'frozen'; new to abc_extra198"]
    - [spec_origin_len_eq_6,
       "__spec__.origin.__len__",
       [],
       6,
       "abc.__spec__.origin.__len__() == 6 — 'frozen' has 6 characters; new to abc_extra198"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra198
# ---------------------------------------------------------------------------

invariant abc_extra198.spec_name_eq:
  description: "abc.__spec__.name == 'abc' — the ModuleSpec name attribute equals the canonical module name; new to abc_extra198; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra198.spec_has_location_false:
  description: "abc.__spec__.has_location == False — abc is a frozen module (loaded by FrozenImporter); frozen modules have no file-system location; has_location is False; new to abc_extra198; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [false]
  expected: true

invariant abc_extra198.spec_parent_empty:
  description: "abc.__spec__.parent == '' — abc is not a package; it is a frozen single-file module; __spec__.parent is the empty string; new to abc_extra198; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: [""]
  expected: true

invariant abc_extra198.spec_class_name_eq:
  description: "abc.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance; new to abc_extra198; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant abc_extra198.spec_origin_frozen:
  description: "abc.__spec__.origin == 'frozen' — abc is loaded by FrozenImporter; the origin attribute of the ModuleSpec is the string 'frozen'; new to abc_extra198; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["frozen"]
  expected: true

invariant abc_extra198.spec_has_location_class_eq:
  description: "abc.__spec__.has_location.__class__.__name__ == 'bool' — has_location is a plain Python bool even when its value is False; new to abc_extra198; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.has_location.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

invariant abc_extra198.spec_name_len_eq_3:
  description: "abc.__spec__.name.__len__() == 3 — 'abc' has 3 characters; new to abc_extra198; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.name.__len__
  args: []
  expected: 3

invariant abc_extra198.spec_origin_len_eq_6:
  description: "abc.__spec__.origin.__len__() == 6 — 'frozen' has 6 characters; new to abc_extra198; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.origin.__len__
  args: []
  expected: 6
