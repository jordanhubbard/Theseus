spec: collections_extra17
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections.zspec.zsdl and prior extras through collections_extra16.zspec.zsdl."
    - "collections_extra16 covers: __qualname__ for OrderedDict, defaultdict, Counter, ChainMap, deque, namedtuple, UserDict, UserList, UserString; collections.abc.__name__; qualname len checks."
    - "No prior collections spec covers __module__ for OrderedDict, ChainMap, namedtuple, defaultdict, Counter, deque, UserDict, UserList, or UserString."
    - "All top-level collections classes and the namedtuple factory have __module__ == 'collections'."
    - "deque and defaultdict are C-level types but are re-exported through the collections module, so __module__ == 'collections'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections class and function __module__ attributes
#
# No prior collections spec covers __module__ for any of these names.
# All are defined or re-exported at module scope so __module__ == 'collections'.
# ---------------------------------------------------------------------------

invariant collections_extra17.OrderedDict.module:
  description: "collections.OrderedDict.__module__ == 'collections' — registered module"
  category: module_attrs
  kind: python_call_eq
  function: OrderedDict.__module__.__eq__
  args: ["collections"]
  expected: true

invariant collections_extra17.ChainMap.module:
  description: "collections.ChainMap.__module__ == 'collections' — pure-Python class"
  category: module_attrs
  kind: python_call_eq
  function: ChainMap.__module__.__eq__
  args: ["collections"]
  expected: true

invariant collections_extra17.namedtuple.module:
  description: "collections.namedtuple.__module__ == 'collections' — factory function"
  category: module_attrs
  kind: python_call_eq
  function: namedtuple.__module__.__eq__
  args: ["collections"]
  expected: true

invariant collections_extra17.defaultdict.module:
  description: "collections.defaultdict.__module__ == 'collections' — C-level type re-exported"
  category: module_attrs
  kind: python_call_eq
  function: defaultdict.__module__.__eq__
  args: ["collections"]
  expected: true

invariant collections_extra17.Counter.module:
  description: "collections.Counter.__module__ == 'collections' — dict subclass"
  category: module_attrs
  kind: python_call_eq
  function: Counter.__module__.__eq__
  args: ["collections"]
  expected: true

invariant collections_extra17.deque.module:
  description: "collections.deque.__module__ == 'collections' — C-level type re-exported"
  category: module_attrs
  kind: python_call_eq
  function: deque.__module__.__eq__
  args: ["collections"]
  expected: true

invariant collections_extra17.UserDict.module:
  description: "collections.UserDict.__module__ == 'collections' — pure-Python wrapper"
  category: module_attrs
  kind: python_call_eq
  function: UserDict.__module__.__eq__
  args: ["collections"]
  expected: true

invariant collections_extra17.UserList.module:
  description: "collections.UserList.__module__ == 'collections' — pure-Python wrapper"
  category: module_attrs
  kind: python_call_eq
  function: UserList.__module__.__eq__
  args: ["collections"]
  expected: true

invariant collections_extra17.UserString.module:
  description: "collections.UserString.__module__ == 'collections' — pure-Python wrapper"
  category: module_attrs
  kind: python_call_eq
  function: UserString.__module__.__eq__
  args: ["collections"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ length cross-checks
#
# 'collections' has 11 characters. These complement the equality checks above
# with a second behavioral axis: string length rather than string content.
# ---------------------------------------------------------------------------

invariant collections_extra17.OrderedDict.module_len:
  description: "collections.OrderedDict.__module__.__len__() == 11 — len('collections')"
  category: module_attr_lengths
  kind: python_call_eq
  function: OrderedDict.__module__.__len__
  args: []
  expected: 11

invariant collections_extra17.namedtuple.module_len:
  description: "collections.namedtuple.__module__.__len__() == 11 — len('collections')"
  category: module_attr_lengths
  kind: python_call_eq
  function: namedtuple.__module__.__len__
  args: []
  expected: 11

invariant collections_extra17.UserString.module_len:
  description: "collections.UserString.__module__.__len__() == 11 — len('collections')"
  category: module_attr_lengths
  kind: python_call_eq
  function: UserString.__module__.__len__
  args: []
  expected: 11
