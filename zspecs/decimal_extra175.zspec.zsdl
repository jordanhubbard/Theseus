docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal conversion method names — __int__, __float__, __bool__, __format__, __repr__, __str__, __round__, __trunc__."
    - "decimal.Decimal.__int__.__name__ == '__int__' (len=7); decimal.Decimal.__float__.__name__ == '__float__' (len=9)."
    - "decimal.Decimal.__bool__.__name__ == '__bool__' (len=8); decimal.Decimal.__format__.__name__ == '__format__' (len=10)."
    - "decimal.Decimal.__repr__.__name__ == '__repr__' (len=8); decimal.Decimal.__str__.__name__ == '__str__' (len=7)."
    - "decimal.Decimal.__round__.__name__ == '__round__' (len=9); decimal.Decimal.__trunc__.__name__ == '__trunc__' (len=9)."
    - "__int__ (7) == __str__ (7): a 2-way tie at length 7."
    - "__bool__ (8) == __repr__ (8): a 2-way tie at length 8."
    - "__float__ (9) == __round__ (9) == __trunc__ (9): a 3-way tie at length 9."
    - "__format__ (10) is the longest covered dunder name."
    - "Length ordering: __int__==__str__ (7) < __bool__==__repr__ (8) < __float__==__round__==__trunc__ (9) < __format__ (10)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

