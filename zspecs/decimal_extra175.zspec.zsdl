table decimal_extra175.short_conversion_names:
  description: "decimal.Decimal short conversion dunder names: __int__.__name__=='__int__' (len=7); __str__.__name__=='__str__' (len=7); __int__==__str__ (7): a 2-way tie at length 7; both shorter than __bool__==__repr__ (8)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalconv175

  columns: [id, function, args, expected, description]
  rows:
    - [int_name,      "Decimal.__int__.__name__.__eq__",      ["__int__"],  true, "decimal.Decimal.__int__.__name__ == '__int__' — __int__ implements int() conversion for Decimal; '__int__' has 7 characters: _(1)_(2)i(3)n(4)t(5)_(6)_(7); __int__ (7) == __str__ (7): a 2-way tie at length 7; __int__==__str__ (7) < __bool__==__repr__ (8): the length-7 group is shorter than the length-8 group; confirmed Python 3.14.3 macOS"]
    - [int_name_len,  "Decimal.__int__.__name__.__len__",     [],           7,    "decimal.Decimal.__int__.__name__.__len__() == 7 — '__int__' has 7 characters; __int__ (7) == __str__ (7): a 2-way tie; __int__==__str__ (7) < __bool__==__repr__ (8) < __float__==__round__==__trunc__ (9) < __format__ (10): the full length ordering; confirmed Python 3.14.3 macOS"]
    - [str_name,      "Decimal.__str__.__name__.__eq__",      ["__str__"],  true, "decimal.Decimal.__str__.__name__ == '__str__' — __str__ implements str() conversion for Decimal; '__str__' has 7 characters: _(1)_(2)s(3)t(4)r(5)_(6)_(7); __str__ (7) == __int__ (7): both conversion dunders share length 7; confirmed Python 3.14.3 macOS"]
    - [str_name_len,  "Decimal.__str__.__name__.__len__",     [],           7,    "decimal.Decimal.__str__.__name__.__len__() == 7 — '__str__' has 7 characters; __str__ (7) == __int__ (7): both share length 7 — a 2-way tie; __str__==__int__ (7) < __bool__==__repr__ (8): the length-7 group is the minimum in the full ordering; confirmed Python 3.14.3 macOS"]
    - [int_class,     "Decimal.__int__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "decimal.Decimal.__int__.__class__.__name__ == 'wrapper_descriptor' — Decimal is a C extension type so its special methods are wrapper_descriptor objects; this holds for all conversion dunders covered; confirmed Python 3.14.3 macOS"]
    - [str_class,     "Decimal.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "decimal.Decimal.__str__.__class__.__name__ == 'wrapper_descriptor' — __str__ is a C wrapper_descriptor like __int__; both share the wrapper_descriptor class and length 7; confirmed Python 3.14.3 macOS"]

