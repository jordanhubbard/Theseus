spec: imaplib
version: ">=3.9"
backend: python_module(imaplib)

docs: https://docs.python.org/3/library/imaplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/imaplib.html"
    - "RFC 3501 — INTERNET MESSAGE ACCESS PROTOCOL - VERSION 4rev1"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/imaplib.py internal socket and SSL handling"
  notes:
    - "imaplib.IMAP4 is the core IMAP4 client class; IMAP4_SSL extends it with TLS support."
    - "IMAP4.port is a class-level attribute set to 143 (the standard IMAP port)."
    - "IMAP4_SSL.port is a class-level attribute set to 993 (the standard IMAPS port)."
    - "imaplib.error is the base IMAP exception; abort and readonly are subclasses of error."
    - "abort signals a connection abort; readonly signals a mailbox opened read-only when r/w expected."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table imaplib.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [imap4,        IMAP4.__name__.__eq__,        ["IMAP4"],        true]
    - [imap4_ssl,    IMAP4_SSL.__name__.__eq__,    ["IMAP4_SSL"],    true]
    - [imap4_stream, IMAP4_stream.__name__.__eq__, ["IMAP4_stream"], true]
    - [error,        error.__name__.__eq__,        ["error"],        true]
    - [abort,        abort.__name__.__eq__,        ["abort"],        true]
    - [readonly,     readonly.__name__.__eq__,     ["readonly"],     true]

# ---------------------------------------------------------------------------
# Module check
# ---------------------------------------------------------------------------

invariant imaplib.module.IMAP4:
  description: "imaplib.IMAP4.__module__ == 'imaplib'"
  category: module
  kind: python_call_eq
  function: IMAP4.__module__.__eq__
  args: ["imaplib"]
  expected: true

# ---------------------------------------------------------------------------
# Class attributes: port numbers
# ---------------------------------------------------------------------------

invariant imaplib.port.imap4:
  description: "imaplib.IMAP4.port == 143 — standard IMAP port"
  category: constants
  kind: python_call_eq
  function: IMAP4.port.__eq__
  args: [143]
  expected: true

invariant imaplib.port.imap4_ssl:
  description: "imaplib.IMAP4_SSL.port == 993 — standard IMAPS port"
  category: constants
  kind: python_call_eq
  function: IMAP4_SSL.port.__eq__
  args: [993]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy
# ---------------------------------------------------------------------------

invariant imaplib.hierarchy.abort_base:
  description: "imaplib.abort.__bases__[0].__name__ == 'error'"
  category: exceptions
  kind: python_call_eq
  function: abort.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "error"

invariant imaplib.hierarchy.readonly_base:
  description: "imaplib.readonly.__bases__[0].__name__ == 'abort'"
  category: exceptions
  kind: python_call_eq
  function: readonly.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "abort"

# ---------------------------------------------------------------------------
# IMAP4 method name checks
# ---------------------------------------------------------------------------

table imaplib.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [login,  IMAP4.login.__name__.__eq__,  ["login"],  true]
    - [logout, IMAP4.logout.__name__.__eq__, ["logout"], true]
    - [select, IMAP4.select.__name__.__eq__, ["select"], true]
    - [search, IMAP4.search.__name__.__eq__, ["search"], true]
