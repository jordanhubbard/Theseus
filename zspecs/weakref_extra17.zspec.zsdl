spec: weakref_extra17
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
    - "weakref_extra16.zspec.zsdl — covers __name__ standalone invariants and table for WeakSet/WeakKeyDictionary/WeakValueDictionary/finalize/proxy/getweakrefcount/getweakrefs"
    - "weakref_extra15.zspec.zsdl — covers __qualname__ table; __module__ table; proxy/__name__; getweakrefcount/__name__; ref/__bases__[0].__name__=='object'"
    - "weakref_extra13.zspec.zsdl — covers getweakrefcount/getweakrefs __qualname__; ref/__mro__[0].__name__; finalize/__mro__[0,1].__name__; WeakSet/__mro__[1].__name__; WeakSet/__bases__.__len__(); WeakKeyDictionary/__bases__.__len__() and __bases__[0].__name__=='MutableMapping'; WeakValueDictionary/__bases__.__len__() and __bases__[0].__name__=='MutableMapping'"
  notes:
    - "This spec extends weakref.zspec.zsdl through weakref_extra16.zspec.zsdl."
    - "Focus: WeakMethod class hierarchy and MRO; MRO length table for all five core weakref classes."
    - "weakref.WeakMethod.__bases__[0].__name__ == 'ReferenceType' — WeakMethod inherits from weakref.ref (whose __name__ is 'ReferenceType')."
    - "weakref.WeakMethod.__mro__.__len__() == 3 — MRO is [WeakMethod, ReferenceType, object]."
    - "weakref.WeakMethod.__module__ == 'weakref' — defined in the weakref module."
    - "weakref.WeakMethod.__bases__.__len__() == 1 — single direct base (ref/ReferenceType)."
    - "weakref.ref.__mro__.__len__() == 2 — MRO is [ReferenceType, object]."
    - "weakref.WeakSet.__mro__.__len__() == 2 — MRO is [WeakSet, object]."
    - "weakref.finalize.__mro__.__len__() == 2 — MRO is [finalize, object]."
    - "weakref.WeakValueDictionary.__mro__.__len__() == 8 — deep MutableMapping ABC chain."
    - "weakref.WeakKeyDictionary.__mro__.__len__() == 8 — deep MutableMapping ABC chain."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# WeakMethod class hierarchy — __bases__[0].__name__ and __bases__.__len__()
#
# weakref_extra12 covers WeakMethod.__bases__[0].__name__ == 'ReferenceType'.
# No prior spec covers WeakMethod.__bases__.__len__() or WeakMethod.__module__
# or WeakMethod.__mro__.__len__() as standalone invariants in the extra17 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra17.WeakMethod.bases0.name:
  description: "weakref.WeakMethod.__bases__[0].__name__ == 'ReferenceType' — WeakMethod inherits from ref"
  category: class_hierarchy
  kind: python_call_eq
  function: WeakMethod.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ReferenceType"

invariant weakref_extra17.WeakMethod.bases_len:
  description: "weakref.WeakMethod.__bases__.__len__() == 1 — single direct base (ref/ReferenceType)"
  category: class_hierarchy
  kind: python_call_eq
  function: WeakMethod.__bases__.__len__
  args: []
  expected: 1

invariant weakref_extra17.WeakMethod.module:
  description: "weakref.WeakMethod.__module__ == 'weakref' — defined in the weakref module"
  category: module_attrs
  kind: python_call_eq
  function: WeakMethod.__module__.__eq__
  args: ["weakref"]
  expected: true

invariant weakref_extra17.WeakMethod.mro_len:
  description: "weakref.WeakMethod.__mro__.__len__() == 3 — MRO is [WeakMethod, ReferenceType, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: WeakMethod.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# MRO length table — all five core weakref class types
#
# weakref_extra8 covers mro_len for WeakSet/finalize/WeakMethod via standalone
# invariants. weakref_extra12 covers mro_len for WeakValueDictionary/WeakKeyDictionary.
# weakref_extra11 covers ref.__mro__.__len__()==2.
# No prior spec collects MRO lengths for all five core classes (ref,
# WeakValueDictionary, WeakKeyDictionary, WeakSet, finalize) in a single table.
# ---------------------------------------------------------------------------

table weakref_extra17.mro_lengths:
  description: "__mro__.__len__() for core weakref class types"
  kind: python_call_eq
  category: mro_lengths
  id_prefix: mrolen

  columns: [id, function, args, expected]
  rows:
    - [ref,                    ref.__mro__.__len__,                    [], 2]
    - [WeakSet,                WeakSet.__mro__.__len__,                [], 2]
    - [finalize,               finalize.__mro__.__len__,               [], 2]
    - [WeakValueDictionary,    WeakValueDictionary.__mro__.__len__,    [], 8]
    - [WeakKeyDictionary,      WeakKeyDictionary.__mro__.__len__,      [], 8]

# ---------------------------------------------------------------------------
# WeakMethod __name__ and __qualname__ — standalone invariants
#
# weakref_extra10 covers __qualname__ for WeakValueDictionary/WeakSet/
# WeakKeyDictionary/finalize. weakref_extra15 covers the same group plus ref.
# No prior spec covers WeakMethod.__name__ or WeakMethod.__qualname__ as
# standalone invariants in the extra17 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra17.WeakMethod.name:
  description: "weakref.WeakMethod.__name__ == 'WeakMethod' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: WeakMethod.__name__.__eq__
  args: ["WeakMethod"]
  expected: true

invariant weakref_extra17.WeakMethod.qualname:
  description: "weakref.WeakMethod.__qualname__ == 'WeakMethod' — class qualname attribute"
  category: class_attrs
  kind: python_call_eq
  function: WeakMethod.__qualname__.__eq__
  args: ["WeakMethod"]
  expected: true
