spec: pathlib_extra261
version: ">=3.10"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers additional pathlib.Path method identity (chmod, symlink_to, hardlink_to, readlink, expanduser, resolve, absolute, touch, open)."
    - "All listed methods are plain Python functions (function class), not C builtins."
    - "pathlib.Path.chmod.__name__ == 'chmod', __qualname__ == 'Path.chmod'."
    - "pathlib.Path.symlink_to.__name__ == 'symlink_to', __qualname__ == 'Path.symlink_to'."
    - "pathlib.Path.hardlink_to.__name__ == 'hardlink_to' — added in Python 3.10."
    - "pathlib.Path.readlink.__name__ == 'readlink' — added in Python 3.9."
    - "pathlib.Path.expanduser.__name__ == 'expanduser'."
    - "pathlib.Path.resolve.__name__ == 'resolve'."
    - "pathlib.Path.absolute.__name__ == 'absolute'."
    - "pathlib.Path.touch.__name__ == 'touch'."
    - "pathlib.Path.open.__name__ == 'open', __qualname__ == 'Path.open'."
    - "All __class__.__name__ values are 'function' — these are pure-Python methods defined in pathlib."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path filesystem-modification method identity
#
# chmod, symlink_to, hardlink_to, readlink, and touch are the five
# filesystem-modification methods on Path. All are plain Python functions.
# __name__, __qualname__, and __class__.__name__ are verified for each.
# ---------------------------------------------------------------------------

table pathlib_extra261.path_fs_method_identity:
  description: "pathlib.Path filesystem-modification method identity — __name__, __qualname__, and class kind; new to extra261"
  kind: python_call_eq
  category: identity
  id_prefix: plxpfm261

  columns: [id, function, args, expected, description]
  rows:
    - [chmod_name,
       "Path.chmod.__name__.__eq__",
       ["chmod"],
       true,
       "pathlib.Path.chmod.__name__.__eq__('chmod') == True — chmod changes the file mode and permissions of the path; its __name__ is 'chmod'; str.__eq__('chmod') returns True; new to extra261"]
    - [chmod_qualname,
       "Path.chmod.__qualname__.__eq__",
       ["Path.chmod"],
       true,
       "pathlib.Path.chmod.__qualname__.__eq__('Path.chmod') == True — the qualified name is 'Path.chmod', reflecting it is defined in the Path class body; str.__eq__('Path.chmod') returns True; new to extra261"]
    - [chmod_class,
       "Path.chmod.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.chmod.__class__.__name__.__eq__('function') == True — chmod is a pure-Python method; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra261"]
    - [symlink_to_name,
       "Path.symlink_to.__name__.__eq__",
       ["symlink_to"],
       true,
       "pathlib.Path.symlink_to.__name__.__eq__('symlink_to') == True — symlink_to makes the path a symbolic link pointing to a target; its __name__ is 'symlink_to'; str.__eq__('symlink_to') returns True; new to extra261"]
    - [symlink_to_qualname,
       "Path.symlink_to.__qualname__.__eq__",
       ["Path.symlink_to"],
       true,
       "pathlib.Path.symlink_to.__qualname__.__eq__('Path.symlink_to') == True — the qualified name is 'Path.symlink_to'; str.__eq__('Path.symlink_to') returns True; new to extra261"]
    - [hardlink_to_name,
       "Path.hardlink_to.__name__.__eq__",
       ["hardlink_to"],
       true,
       "pathlib.Path.hardlink_to.__name__.__eq__('hardlink_to') == True — hardlink_to (added in Python 3.10) makes the path a hard link pointing to a target; its __name__ is 'hardlink_to'; str.__eq__('hardlink_to') returns True; new to extra261"]
    - [hardlink_to_qualname,
       "Path.hardlink_to.__qualname__.__eq__",
       ["Path.hardlink_to"],
       true,
       "pathlib.Path.hardlink_to.__qualname__.__eq__('Path.hardlink_to') == True — the qualified name is 'Path.hardlink_to'; str.__eq__('Path.hardlink_to') returns True; new to extra261"]
    - [readlink_name,
       "Path.readlink.__name__.__eq__",
       ["readlink"],
       true,
       "pathlib.Path.readlink.__name__.__eq__('readlink') == True — readlink (added in Python 3.9) returns the path to which a symbolic link points; its __name__ is 'readlink'; str.__eq__('readlink') returns True; new to extra261"]
    - [touch_name,
       "Path.touch.__name__.__eq__",
       ["touch"],
       true,
       "pathlib.Path.touch.__name__.__eq__('touch') == True — touch creates the file if it does not exist, or updates its modification time if it does; its __name__ is 'touch'; str.__eq__('touch') returns True; new to extra261"]
    - [touch_qualname,
       "Path.touch.__qualname__.__eq__",
       ["Path.touch"],
       true,
       "pathlib.Path.touch.__qualname__.__eq__('Path.touch') == True — the qualified name is 'Path.touch'; str.__eq__('Path.touch') returns True; new to extra261"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path path-resolution and open method identity
#
# expanduser, resolve, absolute, and open are path-resolution and I/O methods.
# All are plain Python functions defined in the Path class.
# ---------------------------------------------------------------------------

table pathlib_extra261.path_resolution_method_identity:
  description: "pathlib.Path resolution and open method identity — __name__, __qualname__, and class kind; new to extra261"
  kind: python_call_eq
  category: identity
  id_prefix: plxprm261

  columns: [id, function, args, expected, description]
  rows:
    - [expanduser_name,
       "Path.expanduser.__name__.__eq__",
       ["expanduser"],
       true,
       "pathlib.Path.expanduser.__name__.__eq__('expanduser') == True — expanduser expands a leading ~ or ~user component in the path; its __name__ is 'expanduser'; str.__eq__('expanduser') returns True; new to extra261"]
    - [expanduser_qualname,
       "Path.expanduser.__qualname__.__eq__",
       ["Path.expanduser"],
       true,
       "pathlib.Path.expanduser.__qualname__.__eq__('Path.expanduser') == True — the qualified name is 'Path.expanduser'; str.__eq__('Path.expanduser') returns True; new to extra261"]
    - [expanduser_class,
       "Path.expanduser.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.expanduser.__class__.__name__.__eq__('function') == True — expanduser is a pure-Python method; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra261"]
    - [resolve_name,
       "Path.resolve.__name__.__eq__",
       ["resolve"],
       true,
       "pathlib.Path.resolve.__name__.__eq__('resolve') == True — resolve returns the path with symlinks resolved and made absolute; its __name__ is 'resolve'; str.__eq__('resolve') returns True; new to extra261"]
    - [resolve_qualname,
       "Path.resolve.__qualname__.__eq__",
       ["Path.resolve"],
       true,
       "pathlib.Path.resolve.__qualname__.__eq__('Path.resolve') == True — the qualified name is 'Path.resolve'; str.__eq__('Path.resolve') returns True; new to extra261"]
    - [absolute_name,
       "Path.absolute.__name__.__eq__",
       ["absolute"],
       true,
       "pathlib.Path.absolute.__name__.__eq__('absolute') == True — absolute returns the path made absolute without resolving symlinks; its __name__ is 'absolute'; str.__eq__('absolute') returns True; new to extra261"]
    - [absolute_qualname,
       "Path.absolute.__qualname__.__eq__",
       ["Path.absolute"],
       true,
       "pathlib.Path.absolute.__qualname__.__eq__('Path.absolute') == True — the qualified name is 'Path.absolute'; str.__eq__('Path.absolute') returns True; new to extra261"]
    - [open_name,
       "Path.open.__name__.__eq__",
       ["open"],
       true,
       "pathlib.Path.open.__name__.__eq__('open') == True — open opens the file pointed to by the path, analogous to the built-in open(); its __name__ is 'open'; str.__eq__('open') returns True; new to extra261"]
    - [open_qualname,
       "Path.open.__qualname__.__eq__",
       ["Path.open"],
       true,
       "pathlib.Path.open.__qualname__.__eq__('Path.open') == True — the qualified name is 'Path.open'; str.__eq__('Path.open') returns True; new to extra261"]
    - [open_class,
       "Path.open.__class__.__name__.__eq__",
       ["function"],
       true,
       "pathlib.Path.open.__class__.__name__.__eq__('function') == True — Path.open is a pure-Python method; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra261"]

# ---------------------------------------------------------------------------
# Standalone invariants — pathlib_extra261
# ---------------------------------------------------------------------------

invariant pathlib_extra261.chmod_name:
  description: "pathlib.Path.chmod.__name__ == 'chmod' — the method changes file permissions; new to extra261"
  kind: python_call_eq
  function: Path.chmod.__name__.__eq__
  args: ["chmod"]
  expected: true

invariant pathlib_extra261.chmod_qualname:
  description: "pathlib.Path.chmod.__qualname__ == 'Path.chmod' — qualified name includes the class; new to extra261"
  kind: python_call_eq
  function: Path.chmod.__qualname__.__eq__
  args: ["Path.chmod"]
  expected: true

invariant pathlib_extra261.chmod_is_function:
  description: "pathlib.Path.chmod.__class__.__name__ == 'function' — chmod is a pure-Python method; new to extra261"
  kind: python_call_eq
  function: Path.chmod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra261.symlink_to_name:
  description: "pathlib.Path.symlink_to.__name__ == 'symlink_to' — creates a symbolic link to a target; new to extra261"
  kind: python_call_eq
  function: Path.symlink_to.__name__.__eq__
  args: ["symlink_to"]
  expected: true

invariant pathlib_extra261.hardlink_to_name:
  description: "pathlib.Path.hardlink_to.__name__ == 'hardlink_to' — creates a hard link to a target (Python 3.10+); new to extra261"
  kind: python_call_eq
  function: Path.hardlink_to.__name__.__eq__
  args: ["hardlink_to"]
  expected: true

invariant pathlib_extra261.readlink_name:
  description: "pathlib.Path.readlink.__name__ == 'readlink' — returns the path a symlink points to (Python 3.9+); new to extra261"
  kind: python_call_eq
  function: Path.readlink.__name__.__eq__
  args: ["readlink"]
  expected: true

invariant pathlib_extra261.expanduser_name:
  description: "pathlib.Path.expanduser.__name__ == 'expanduser' — expands the ~ home directory component; new to extra261"
  kind: python_call_eq
  function: Path.expanduser.__name__.__eq__
  args: ["expanduser"]
  expected: true

invariant pathlib_extra261.resolve_name:
  description: "pathlib.Path.resolve.__name__ == 'resolve' — resolves symlinks and makes the path absolute; new to extra261"
  kind: python_call_eq
  function: Path.resolve.__name__.__eq__
  args: ["resolve"]
  expected: true

invariant pathlib_extra261.absolute_name:
  description: "pathlib.Path.absolute.__name__ == 'absolute' — makes the path absolute without resolving symlinks; new to extra261"
  kind: python_call_eq
  function: Path.absolute.__name__.__eq__
  args: ["absolute"]
  expected: true

invariant pathlib_extra261.touch_name:
  description: "pathlib.Path.touch.__name__ == 'touch' — creates the file or updates its modification time; new to extra261"
  kind: python_call_eq
  function: Path.touch.__name__.__eq__
  args: ["touch"]
  expected: true

invariant pathlib_extra261.open_name:
  description: "pathlib.Path.open.__name__ == 'open' — opens the file; new to extra261"
  kind: python_call_eq
  function: Path.open.__name__.__eq__
  args: ["open"]
  expected: true

invariant pathlib_extra261.open_qualname:
  description: "pathlib.Path.open.__qualname__ == 'Path.open' — qualified name distinguishes it from built-in open(); new to extra261"
  kind: python_call_eq
  function: Path.open.__qualname__.__eq__
  args: ["Path.open"]
  expected: true

invariant pathlib_extra261.open_is_function:
  description: "pathlib.Path.open.__class__.__name__ == 'function' — Path.open is a pure-Python method; new to extra261"
  kind: python_call_eq
  function: Path.open.__class__.__name__.__eq__
  args: ["function"]
  expected: true
