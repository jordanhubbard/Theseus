spec: sunau_extra3
version: ">=3.9,<3.13"
backend: python_module(sunau)

docs: https://docs.python.org/3/library/sunau.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sunau.html — Python sunau module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sunau.py"
    - "sunau.zspec.zsdl — covers Au_read/__name__, Au_write/__name__, Error/__name__, Error base, open/__name__, AUDIO_FILE_MAGIC value/type, encoding constants"
    - "sunau_extra.zspec.zsdl — covers open/__name__/__module__, Error/__name__/__module__/base/bases_len, Au_read/__name__/__module__, Au_write/__name__/__module__, AUDIO_FILE_MAGIC value/type, openfp class name"
    - "sunau_extra2.zspec.zsdl — covers __qualname__ for open, Au_read, Au_write, Error"
  notes:
    - "This spec extends sunau.zspec.zsdl, sunau_extra.zspec.zsdl, and sunau_extra2.zspec.zsdl."
    - "Deprecated since Python 3.11; removed in Python 3.13. Version constraint: >=3.9,<3.13."
    - "Focus: type-identity checks for Au_read, Au_write, and open; __bases__.__len__ for Au_read and Au_write."
    - "Au_read and Au_write are top-level class objects, so their __class__.__name__ == 'type'."
    - "open is a plain Python function defined in Lib/sunau.py, so open.__class__.__name__ == 'function'."
    - "Au_read and Au_write each inherit directly from object (one base class each)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Type-identity checks — Au_read and Au_write are class objects (type)
# No prior spec checks Au_read.__class__.__name__ or Au_write.__class__.__name__.
# ---------------------------------------------------------------------------

invariant sunau_extra3.Au_read.is_type:
  description: "sunau.Au_read.__class__.__name__ == 'type' — Au_read is a class object"
  category: class_identity
  kind: python_call_eq
  function: Au_read.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant sunau_extra3.Au_write.is_type:
  description: "sunau.Au_write.__class__.__name__ == 'type' — Au_write is a class object"
  category: class_identity
  kind: python_call_eq
  function: Au_write.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Type-identity check — open is a plain Python function
# sunau_extra covers open.__module__; no prior spec checks open.__class__.__name__.
# ---------------------------------------------------------------------------

invariant sunau_extra3.open.is_function:
  description: "sunau.open.__class__.__name__ == 'function' — open is a plain Python function"
  category: function_identity
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# __bases__.__len__ checks for Au_read and Au_write
# sunau_extra covers Error.__bases__.__len__; Au_read and Au_write are not yet covered.
# Both Au_read and Au_write inherit directly from object — one base class each.
# ---------------------------------------------------------------------------

invariant sunau_extra3.Au_read.bases_len:
  description: "len(sunau.Au_read.__bases__) == 1 — Au_read has exactly one direct base class (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Au_read.__bases__.__len__
  args: []
  expected: 1

invariant sunau_extra3.Au_write.bases_len:
  description: "len(sunau.Au_write.__bases__) == 1 — Au_write has exactly one direct base class (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Au_write.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Base class name checks for Au_read and Au_write
# No prior spec checks Au_read.__bases__[0].__name__ or Au_write.__bases__[0].__name__.
# Both inherit directly from object.
# ---------------------------------------------------------------------------

invariant sunau_extra3.Au_read.base_is_object:
  description: "sunau.Au_read.__bases__[0].__name__ == 'object' — Au_read inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Au_read.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant sunau_extra3.Au_write.base_is_object:
  description: "sunau.Au_write.__bases__[0].__name__ == 'object' — Au_write inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Au_write.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"
