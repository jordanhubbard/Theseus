spec: pprint_extra12
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint_extra11.zspec.zsdl."
    - "pprint_extra11 covers: func_names table (pprint/pformat/isreadable/isrecursive/saferepr/PrettyPrinter __name__); pprint/pformat/PrettyPrinter __module__ standalone; pformat_values table (42/'hello'/[]/{}/ True); isreadable(42)/isrecursive(42) standalone."
    - "pprint_extra10 covers: pformat(0)/pformat(2.5)/pformat([1,[2,3]]); saferepr(42)/saferepr(None)/saferepr(True); isreadable([]); length checks for pformat.__qualname__/PrettyPrinter.__name__/saferepr.__name__."
    - "pprint_extra8 covers: name_attrs table (pformat/isreadable/isrecursive/PrettyPrinter/pprint/saferepr/pp); pformat(True)/pformat(None); isrecursive(42); isreadable(False)."
    - "pprint_extra5 covers: PrettyPrinter.__bases__[0].__name__=='object'; isreadable(True/3.14); isrecursive(42/'hello')."
    - "This spec covers: __name__ standalone invariants for pprint/pformat/isreadable/isrecursive/saferepr; PrettyPrinter.__qualname__; __module__ table for pprint/pformat/isreadable/isrecursive/saferepr; pformat(42)=='42' and pformat('hello')==\"'hello'\"; isreadable(42)==True; isrecursive([])==False."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ standalone invariants
#
# pprint_extra11 covers these in a table. This spec re-anchors each as a
# standalone invariant under the extra12 namespace for independent coverage.
# ---------------------------------------------------------------------------

invariant pprint_extra12.pprint.name:
  description: "pprint.pprint.__name__ == 'pprint' — module-level pprint function name"
  category: function_attrs
  kind: python_call_eq
  function: pprint.__name__.__eq__
  args: ["pprint"]
  expected: true

invariant pprint_extra12.pformat.name:
  description: "pprint.pformat.__name__ == 'pformat' — module-level pformat function name"
  category: function_attrs
  kind: python_call_eq
  function: pformat.__name__.__eq__
  args: ["pformat"]
  expected: true

invariant pprint_extra12.isreadable.name:
  description: "pprint.isreadable.__name__ == 'isreadable' — function name"
  category: function_attrs
  kind: python_call_eq
  function: isreadable.__name__.__eq__
  args: ["isreadable"]
  expected: true

invariant pprint_extra12.isrecursive.name:
  description: "pprint.isrecursive.__name__ == 'isrecursive' — function name"
  category: function_attrs
  kind: python_call_eq
  function: isrecursive.__name__.__eq__
  args: ["isrecursive"]
  expected: true

invariant pprint_extra12.saferepr.name:
  description: "pprint.saferepr.__name__ == 'saferepr' — function name"
  category: function_attrs
  kind: python_call_eq
  function: saferepr.__name__.__eq__
  args: ["saferepr"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter.__qualname__
#
# pprint_extra3 and prior specs cover PrettyPrinter.__name__. No prior spec
# verifies PrettyPrinter.__qualname__ as a standalone invariant. For a
# top-level class, __qualname__ == __name__ == 'PrettyPrinter'.
# ---------------------------------------------------------------------------

invariant pprint_extra12.PrettyPrinter.qualname:
  description: "pprint.PrettyPrinter.__qualname__ == 'PrettyPrinter' — top-level class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: PrettyPrinter.__qualname__.__eq__
  args: ["PrettyPrinter"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — five module-level functions
#
# pprint_extra11 covers pprint/pformat/PrettyPrinter __module__ as standalone
# invariants. This table collects all five functions under the extra12 namespace,
# adding isreadable and isrecursive (not covered by any prior __module__ check).
# All five are defined in the 'pprint' module.
# ---------------------------------------------------------------------------

table pprint_extra12.modules:
  kind: python_call_eq
  category: module_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [pprint_extra12.modules.pprint_module,
       pprint.__module__.__eq__,
       ["pprint"],
       true,
       "pprint.pprint.__module__ == 'pprint'"]
    - [pprint_extra12.modules.pformat_module,
       pformat.__module__.__eq__,
       ["pprint"],
       true,
       "pprint.pformat.__module__ == 'pprint'"]
    - [pprint_extra12.modules.isreadable_module,
       isreadable.__module__.__eq__,
       ["pprint"],
       true,
       "pprint.isreadable.__module__ == 'pprint'"]
    - [pprint_extra12.modules.isrecursive_module,
       isrecursive.__module__.__eq__,
       ["pprint"],
       true,
       "pprint.isrecursive.__module__ == 'pprint'"]
    - [pprint_extra12.modules.saferepr_module,
       saferepr.__module__.__eq__,
       ["pprint"],
       true,
       "pprint.saferepr.__module__ == 'pprint'"]

# ---------------------------------------------------------------------------
# pformat return value checks
#
# pprint_extra11 covers pformat(42) and pformat('hello') in a table.
# These standalone invariants re-anchor both under the extra12 namespace.
# pformat(42) == '42': integer formatted without quotes.
# pformat('hello') == "'hello'": string formatted with enclosing single quotes.
# ---------------------------------------------------------------------------

invariant pprint_extra12.pformat.int_42:
  description: "pprint.pformat(42) == '42' — integer 42 formatted as bare digits"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [42]
  expected: "42"

invariant pprint_extra12.pformat.str_hello:
  description: "pprint.pformat('hello') == \"'hello'\" — short string formatted with single quotes"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: ["hello"]
  expected: "'hello'"

# ---------------------------------------------------------------------------
# isreadable and isrecursive — standalone value checks
#
# pprint_extra8/9/10/11 cover various isreadable/isrecursive combinations.
# These re-anchor the two simplest canonical cases under the extra12 namespace.
# isreadable(42) == True: integer 42 has a readable repr.
# isrecursive([]) == False: empty list is not recursive.
# ---------------------------------------------------------------------------

invariant pprint_extra12.isreadable.int_42:
  description: "pprint.isreadable(42) == True — integer 42 has a readable repr"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [42]
  expected: true

invariant pprint_extra12.isrecursive.empty_list:
  description: "pprint.isrecursive([]) == False — empty list is not recursive"
  category: isrecursive
  kind: python_call_eq
  function: isrecursive
  args: [[]]
  expected: false
