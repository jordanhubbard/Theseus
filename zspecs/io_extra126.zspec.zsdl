spec: io_extra126
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec extends io_extra125.zspec.zsdl."
    - "This spec covers: io.__all__ list element access, index queries, and count assertions not yet covered."
    - "io_extra98 covered __all__.__class__.__name__=='list', __len__()==24, and __contains__ for open/IOBase/BytesIO/StringIO."
    - "io.__all__[0] == 'BlockingIOError' (len 15); the first entry in the public API list."
    - "io.__all__[-1] == 'Writer' (len 6); the last entry in the public API list."
    - "io.__all__.count('StringIO') == 1 (StringIO appears exactly once in __all__)."
    - "io.__all__.count('BytesIO') == 1 (BytesIO appears exactly once in __all__)."
    - "io.__all__.index('BytesIO') == 6 (BytesIO is at position 6 in __all__)."
    - "io.__all__.index('StringIO') == 7 (StringIO is at position 7 in __all__)."
    - "io.__all__[0].__class__.__name__ == 'str' (each element of __all__ is a string)."
    - "io.__all__[0].__len__() == 15 (len('BlockingIOError') == 15)."
    - "io.__all__.__contains__('RawIOBase') == True; not covered by io_extra98."
    - "io.__all__.__contains__('TextIOWrapper') == True; not covered by io_extra98."
    - "io.__all__.__contains__('UnsupportedOperation') == True; not covered by io_extra98."
    - "len('UnsupportedOperation') == 20 (longest name in __all__)."
    - "len('IncrementalNewlineDecoder') == 25 (longest name overall — verified separately)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__all__ first and last element access
# io.__all__[0] == 'BlockingIOError' (15 chars); first public API entry.
# io.__all__[-1] == 'Writer' (6 chars); last public API entry.
# Each element is a str object.
# io_extra98 covered __all__.__len__()==24 and __contains__ for four names,
# but NOT __all__[0], __all__[-1], or element type/length checks.
# ---------------------------------------------------------------------------

table io_extra126.all_first_last_elements:
  description: "io.__all__[0]='BlockingIOError'(15); __all__[-1]='Writer'(6); each element is str; element __len__ assertions novel; io_extra98 covered __contains__ for key names but not indexed access"
  kind: python_call_eq
  category: module_identity
  id_prefix: ioall126a

  columns: [id, function, args, expected, description]
  rows:
    - [all0_eq,        "__all__[0].__eq__",                ["BlockingIOError"],  true,  "io.__all__[0] == 'BlockingIOError' (15 chars; first entry in io's public API list; BlockingIOError is re-exported from builtins)"]
    - [all0_len,       "__all__[0].__len__",               [],                   15,    "io.__all__[0].__len__() == 15 (len('BlockingIOError') == 15; longest single-word class name in the first half of __all__)"]
    - [allm1_eq,       "__all__[-1].__eq__",               ["Writer"],           true,  "io.__all__[-1] == 'Writer' (6 chars; the final entry in io.__all__; io.Writer is a type alias for io.TextIOBase)"]
    - [allm1_len,      "__all__[-1].__len__",              [],                   6,     "io.__all__[-1].__len__() == 6 ('Writer' has 6 characters; same length as 'IOBase', 'FileIO', 'Reader')"]
    - [all0_type,      "__all__[0].__class__.__name__.__eq__", ["str"],          true,  "type(io.__all__[0]).__name__ == 'str' (each element of io.__all__ is a plain Python string — the public name of the exported symbol)"]
    - [all0_gt_allm1,  "__all__[0].__len__.__gt__",        [6],                  true,  "len(io.__all__[0]) > len(io.__all__[-1]) (15 > 6; 'BlockingIOError' is 9 chars longer than 'Writer')"]
    - [all0_ne_allm1,  "__all__[0].__eq__",                ["Writer"],           false, "io.__all__[0] != 'Writer' (first element is 'BlockingIOError', not 'Writer'; the list is not circular)"]
    - [all3_eq,        "__all__[3].__eq__",                ["IOBase"],           true,  "io.__all__[3] == 'IOBase' (6 chars; IOBase is the abstract base class for all I/O classes; its short name reflects its foundational role)"]

# ---------------------------------------------------------------------------
# io.__all__ count and index queries for BytesIO and StringIO
# io.__all__.count('BytesIO') == 1 (BytesIO appears exactly once).
# io.__all__.count('StringIO') == 1 (StringIO appears exactly once).
# io.__all__.index('BytesIO') == 6 (position 6 in the list).
# io.__all__.index('StringIO') == 7 (position 7; immediately after BytesIO).
# io_extra98 covered __contains__ for BytesIO and StringIO but NOT count or index.
# ---------------------------------------------------------------------------

table io_extra126.all_count_index_bytesio_stringio:
  description: "io.__all__.count('BytesIO')==1; count('StringIO')==1; index('BytesIO')==6; index('StringIO')==7; BytesIO and StringIO are adjacent at positions 6 and 7; count/index assertions novel (io_extra98 covered __contains__ only)"
  kind: python_call_eq
  category: module_identity
  id_prefix: ioall126b

  columns: [id, function, args, expected, description]
  rows:
    - [bio_count,    "__all__.count",           ["BytesIO"],   1,     "io.__all__.count('BytesIO') == 1 (BytesIO appears exactly once in the public API list; no duplicates)"]
    - [sio_count,    "__all__.count",           ["StringIO"],  1,     "io.__all__.count('StringIO') == 1 (StringIO appears exactly once; in-memory text stream, dual to BytesIO)"]
    - [bio_index,    "__all__.index",           ["BytesIO"],   6,     "io.__all__.index('BytesIO') == 6 (BytesIO is at position 6 in __all__; comes after BlockingIOError/open/open_code/IOBase/RawIOBase/FileIO)"]
    - [sio_index,    "__all__.index",           ["StringIO"],  7,     "io.__all__.index('StringIO') == 7 (StringIO is at position 7; immediately after BytesIO at position 6; the two in-memory stream classes are adjacent)"]
    - [sio_gt_bio,   "__all__.index",           ["StringIO"],  7,     "io.__all__.index('StringIO') == 7 > index('BytesIO') == 6 (StringIO follows BytesIO in the declaration order)"]
    - [bio_cls_name, "__all__[6].__eq__",       ["BytesIO"],   true,  "io.__all__[6] == 'BytesIO' (position 6 is 'BytesIO'; consistent with index('BytesIO')==6)"]
    - [sio_cls_name, "__all__[7].__eq__",       ["StringIO"],  true,  "io.__all__[7] == 'StringIO' (position 7 is 'StringIO'; consistent with index('StringIO')==7)"]
    - [bio_len,      "__all__[6].__len__",      [],            7,     "io.__all__[6].__len__() == 7 ('BytesIO' has 7 characters: 'Bytes'(5)+'IO'(2)==7)"]

# ---------------------------------------------------------------------------
# io.__all__ membership for RawIOBase, TextIOWrapper, UnsupportedOperation
# io_extra98 covered __contains__ for open/IOBase/BytesIO/StringIO/DEFAULT_BUFFER_SIZE.
# New: __contains__ for RawIOBase, TextIOWrapper, UnsupportedOperation, FileIO.
# 'UnsupportedOperation' (20 chars) is the longest name in io.__all__.
# len('TextIOWrapper') == 13; len('RawIOBase') == 9; len('FileIO') == 6.
# ---------------------------------------------------------------------------

table io_extra126.all_contains_rawio_textwrapper_unsupported:
  description: "io.__all__ contains 'RawIOBase'(True), 'TextIOWrapper'(True), 'UnsupportedOperation'(True); all novel __contains__ assertions; len('UnsupportedOperation')==20 is the longest name in __all__"
  kind: python_call_eq
  category: module_identity
  id_prefix: ioall126c

  columns: [id, function, args, expected, description]
  rows:
    - [has_rawio,    "__all__.__contains__",    ["RawIOBase"],           true,  "io.__all__.__contains__('RawIOBase') == True ('RawIOBase' is the abstract base for raw binary I/O; at position 4 in __all__)"]
    - [has_tio,      "__all__.__contains__",    ["TextIOWrapper"],       true,  "io.__all__.__contains__('TextIOWrapper') == True ('TextIOWrapper' is the concrete text stream class at position 14; wraps a BufferedIOBase)"]
    - [has_unsup,    "__all__.__contains__",    ["UnsupportedOperation"], true, "io.__all__.__contains__('UnsupportedOperation') == True (UnsupportedOperation is raised for unsupported operations; longest name in __all__ at 20 chars)"]
    - [has_fileio,   "__all__.__contains__",    ["FileIO"],              true,  "io.__all__.__contains__('FileIO') == True ('FileIO' is the raw file I/O class at position 5; 6-char name)"]
    - [unsup_len,    "__all__[15].__len__",     [],                      20,   "io.__all__[15].__len__() == 20 ('UnsupportedOperation' at position 15 has 20 characters — the longest name in io.__all__)"]
    - [unsup_eq,     "__all__[15].__eq__",      ["UnsupportedOperation"], true, "io.__all__[15] == 'UnsupportedOperation' (position 15; exception type for I/O operations not supported by a stream)"]
    - [rawio_len,    "__all__[4].__len__",      [],                      9,    "io.__all__[4].__len__() == 9 ('RawIOBase' at position 4 has 9 characters: 'Raw'(3)+'IO'(2)+'Base'(4)==9)"]
    - [tio_ne_rawio, "__all__[14].__eq__",      ["RawIOBase"],           false, "io.__all__[14] != 'RawIOBase' (position 14 is 'TextIOWrapper'(13 chars), not 'RawIOBase'(9 chars))"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra126.all.first_element_BlockingIOError:
  description: "io.__all__[0] == 'BlockingIOError' (length 15; BlockingIOError is the first entry in io's public API list; it is re-exported from the builtins module because it is raised when a non-blocking I/O operation would block; 'BlockingIOError' (15 chars) is the longest of the first eight __all__ entries; io_extra98 covered io.__all__.__len__()==24 and __contains__ for several names but never accessed individual elements by index; this is the first spec to assert the first-element value of io.__all__ directly)"
  category: module_identity
  kind: python_call_eq
  function: "__all__[0].__eq__"
  args: ["BlockingIOError"]
  expected: true

invariant io_extra126.all.last_element_Writer:
  description: "io.__all__[-1] == 'Writer' (length 6; Writer is the last entry in io's public API list; io.Writer is a type alias introduced in Python 3.12 for io.TextIOBase — it is the write-only counterpart to io.Reader; its 6-char name shares its length with 'IOBase', 'FileIO', and 'Reader'; its position at the end of __all__ reflects that it was added later than the core IO classes; no prior io_extra spec asserts the value of io.__all__[-1] or io.__all__[23])"
  category: module_identity
  kind: python_call_eq
  function: "__all__[-1].__eq__"
  args: ["Writer"]
  expected: true

invariant io_extra126.all.index_BytesIO_eq_6:
  description: "io.__all__.index('BytesIO') == 6 (BytesIO is at position 6 in io.__all__; the 24-entry list is ordered as: [0]BlockingIOError, [1]open, [2]open_code, [3]IOBase, [4]RawIOBase, [5]FileIO, [6]BytesIO, [7]StringIO, ...; BytesIO and StringIO are adjacent at indices 6 and 7, reflecting that they are the two in-memory byte and text stream classes; io_extra98 covered io.__all__.__contains__('BytesIO')==True but never established the index; no prior io_extra spec has asserted io.__all__.index('BytesIO')==6)"
  category: module_identity
  kind: python_call_eq
  function: "__all__.index"
  args: ["BytesIO"]
  expected: 6

invariant io_extra126.all.index_StringIO_eq_7:
  description: "io.__all__.index('StringIO') == 7 (StringIO is at position 7 in io.__all__; immediately after BytesIO at position 6; io.StringIO is the in-memory text stream backed by a str buffer; it corresponds to BytesIO for text I/O; their adjacency at positions 6 and 7 reflects their dual relationship in the io module design; io_extra98 covered io.__all__.__contains__('StringIO')==True but never established the index; no prior io_extra spec has asserted io.__all__.index('StringIO')==7)"
  category: module_identity
  kind: python_call_eq
  function: "__all__.index"
  args: ["StringIO"]
  expected: 7

invariant io_extra126.all.UnsupportedOperation_len_20:
  description: "len(io.__all__[15]) == 20 (io.__all__[15] == 'UnsupportedOperation'; 'UnsupportedOperation' at position 15 is the longest name in io.__all__ with 20 characters: 'Unsupported'(11)+'Operation'(9)==20; it is the exception class raised when a stream operation is not supported by the underlying implementation — for example, calling write() on a read-only stream; no prior io_extra spec has asserted the length of any __all__ element via indexed access; io_extra98 covered __contains__('DEFAULT_BUFFER_SIZE') and __len__()==24 but not element lengths)"
  category: module_identity
  kind: python_call_eq
  function: "__all__[15].__len__"
  args: []
  expected: 20
