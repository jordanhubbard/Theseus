spec: gzip_extra11
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip documentation"
    - "RFC 1952 — GZIP file format specification version 4.3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
    - "gzip_extra10.zspec.zsdl — covers compress/__name__ standalone; decompress/__name__ standalone; open/__name__ standalone; GzipFile/__name__ standalone; BadGzipFile/__name__ standalone; BadGzipFile.__bases__[0].__name__ bool-form; compress(b'hello') returns bytes (!ascii); decompress(pre-computed-hello) returns bytes (!hex)."
    - "gzip_extra9.zspec.zsdl — covers GzipFile.__mro__[5].__name__; BadGzipFile MRO depths 1/2/3; compress(b'') length==20; FTEXT/FNAME bool-form eq; compress(b'hello', 1)[8]==4 (XFL fastest)."
    - "gzip_extra8.zspec.zsdl — covers GzipFile.__mro__[4].__name__=='IOBase'; compress(b'hello')[3]==0 (FLG); compress(b'hello',9)[8]==2 (XFL); compress(b'hello',9)[9]==255 (OS); compress(b'hello',9).__len__()==25."
    - "gzip_extra7.zspec.zsdl — covers GzipFile/BadGzipFile __class__.__name__=='type'; open/compress/decompress __class__.__name__=='function'; FEXTRA/FCOMMENT class names; GzipFile.__mro__[3]; BadGzipFile.__module__ bool form; compress(b'a') len==21; compress(b'hello')[2]==8; decompress raises on truncated."
    - "gzip_extra6.zspec.zsdl — covers FTEXT/FHCRC/FEXTRA/FNAME/FCOMMENT constants; compress magic bytes [0] and [1]; GzipFile.__bases__[0].__module__; GzipFile.__mro__[2].__name__."
    - "gzip_extra3.zspec.zsdl — covers GzipFile/__name__ and BadGzipFile/__name__ in a class_names table; compress/decompress/open __name__ in a function_names table; GzipFile/__module__; BadGzipFile.__bases__[0].__name__ (string form via getitem+method); compress returns bytes; compress header magic byte[0]."
  notes:
    - "This spec extends gzip through gzip_extra10; it does NOT duplicate invariants present in those files."
    - "Focus: GzipFile.__bases__[0].__name__ == 'BaseStream' (bool-form, extra11 namespace); BadGzipFile.__bases__[0].__name__ == 'OSError' (string-form via __getitem__, extra11 namespace); open/__module__ standalone (extra11); compress/__module__ standalone (extra11); decompress/__module__ standalone (extra11); function __module__ table (extra11)."
    - "GzipFile.__bases__[0].__name__ == 'BaseStream': GzipFile inherits from _compression.BaseStream on Python 3.12. Verified 2026-04-09."
    - "BadGzipFile.__bases__[0].__name__ == 'OSError': BadGzipFile is a subclass of OSError. Verified 2026-04-09."
    - "gzip_extra3 covers GzipFile/__module__ from extra3. The open/__module__, compress/__module__, decompress/__module__ standalone invariants are new from extra11 namespace."
    - "gzip_extra6 covers GzipFile.__bases__[0].__module__ from extra6. This spec covers GzipFile.__bases__[0].__name__ (the name, not the module) — a distinct axis."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GzipFile.__bases__[0].__name__ == 'BaseStream' — bool form
#
# gzip_extra6 covers GzipFile.__bases__[0].__module__ from extra6 (the module).
# No prior gzip spec checks GzipFile.__bases__[0].__name__ as a bool-form eq.
# The base is _compression.BaseStream on Python 3.12.
# ---------------------------------------------------------------------------

invariant gzip_extra11.GzipFile.base_name_bool:
  description: "gzip.GzipFile.__bases__[0].__name__ == 'BaseStream' — GzipFile inherits from BaseStream (bool-form, extra11)"
  category: class_hierarchy
  kind: python_call_eq
  function: GzipFile.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["BaseStream"]
  expected: true

# ---------------------------------------------------------------------------
# BadGzipFile.__bases__[0].__name__ == 'OSError' — string form via __getitem__
#
# gzip_extra10 covers BadGzipFile.__bases__[0].__name__ via bool-form __eq__
# from extra10 namespace. gzip_extra3 covers it as a string-form result from
# extra3. This invariant re-anchors the string form from extra11 namespace.
# ---------------------------------------------------------------------------

invariant gzip_extra11.BadGzipFile.base_name_str:
  description: "gzip.BadGzipFile.__bases__[0].__name__ == 'OSError' — base class name (string form, extra11 anchor)"
  category: class_hierarchy
  kind: python_call_eq
  function: BadGzipFile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# Function __module__ attributes — open, compress, decompress (standalone)
#
# gzip_extra3 covers GzipFile/__module__ from extra3. No prior gzip spec checks
# open/__module__, compress/__module__, or decompress/__module__ as standalone
# invariants in the extra11 namespace.
# ---------------------------------------------------------------------------

invariant gzip_extra11.open.module:
  description: "gzip.open.__module__ == 'gzip' — open is defined in the gzip module (extra11 anchor)"
  category: function_modules
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["gzip"]
  expected: true

invariant gzip_extra11.compress.module:
  description: "gzip.compress.__module__ == 'gzip' — compress is defined in the gzip module (extra11 anchor)"
  category: function_modules
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["gzip"]
  expected: true

invariant gzip_extra11.decompress.module:
  description: "gzip.decompress.__module__ == 'gzip' — decompress is defined in the gzip module (extra11 anchor)"
  category: function_modules
  kind: python_call_eq
  function: decompress.__module__.__eq__
  args: ["gzip"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ table — open, compress, decompress (extra11)
#
# No prior gzip spec presents open/compress/decompress __module__ together in
# a single table. This table anchors all three from the extra11 namespace.
# ---------------------------------------------------------------------------

table gzip_extra11.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod11

  columns: [id, function, args, expected]
  rows:
    - [open,       open.__module__.__eq__,       ["gzip"], true]
    - [compress,   compress.__module__.__eq__,   ["gzip"], true]
    - [decompress, decompress.__module__.__eq__, ["gzip"], true]
