spec: hashlib_extra127
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class identity and __module__=='_blake2' / new __class__.__name__=='function' / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership for sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/shake_128/shake_256 / algorithms_available membership / new/__qualname__/__len__()==10 (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__.__eq__('__hash_new') / new/__code__/co_name/__eq__ / new/__code__/co_argcount.__eq__(1) / new/__module__.__eq__('hashlib') / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__.__eq__ and __module__.__eq__('_hashlib') (table + invariants)."
    - "hashlib_extra94.zspec.zsdl — covers hashlib.algorithms_available/algorithms_guaranteed set class identity (__class__.__name__=='set') and sha256/sha512/sha1/md5/sha224/sha384/sha3_256/blake2b/blake2s membership / sha256/sha512/sha1/md5 constructor __class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier hashlib specs."
    - "Wave 270 theme: hashlib set iterator identity / algorithms_available length / algorithms_available non-guaranteed members / algorithms_guaranteed superset/subset relationships."
    - "hashlib.algorithms_guaranteed.__iter__().__class__.__name__ == 'set_iterator'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__iter__().__class__.__name__ == 'set_iterator'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__len__() == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__('ripemd160') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__('sm3') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__('sha512_224') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__('sha512_256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__('md5-sha1') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.issubset(hashlib.algorithms_available) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.issuperset(hashlib.algorithms_guaranteed) == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: algorithms_available (19 entries) is a strict superset of algorithms_guaranteed (14 entries). The 5 extra entries on Python 3.14.3/macOS are: md5-sha1, ripemd160, sha512_224, sha512_256, sm3. These are platform-dependent (OpenSSL feature flags)."
    - "Note: Both algorithms_guaranteed and algorithms_available are 'set' objects (not frozenset). Their iterators are 'set_iterator' instances."
    - "Note: extra94 anchors set __class__.__name__=='set' and membership for guaranteed; this spec anchors the iterator class name and available-specific members and set relationship operations."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__iter__().__class__.__name__.__eq__('set_iterator')
# hashlib.algorithms_available.__iter__().__class__.__name__.__eq__('set_iterator')
# hashlib.algorithms_available.__len__().__eq__(19)
# hashlib.algorithms_guaranteed.issubset(hashlib.algorithms_available)
# hashlib.algorithms_available.issuperset(hashlib.algorithms_guaranteed)
#
# Wave 270 theme: set iterator identity and set relationship operations.
#
# Both algorithms_guaranteed and algorithms_available are plain 'set' objects
# (not frozenset). Their __iter__() returns a 'set_iterator' instance.
# algorithms_available has 19 entries on Python 3.14.3/macOS Darwin 25.4.0.
# guaranteed is a subset of available (all guaranteed algorithms are available).
# extra94 anchors set __class__.__name__=='set'; extra97 anchors guaranteed membership;
# no prior hashlib spec anchors iterator class name, available length (19), or
# set relationship operations under hashlibset127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra127.set_iterator_and_relationships:
  description: "algorithms_guaranteed/__iter__().__class__.__name__.__eq__('set_iterator')==True / algorithms_available/__iter__().__class__.__name__.__eq__('set_iterator')==True / algorithms_available/__len__()==19 / guaranteed.issubset(available)==True / available.issuperset(guaranteed)==True — both sets yield 'set_iterator'; available has 19 entries (14 guaranteed + 5 platform-specific); guaranteed is a subset of available; extra94 anchors set class; extra97 anchors guaranteed membership; first hashlibset127 anchor for iterator class and set relationships"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashlibset127

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_iter_class,  "algorithms_guaranteed.__iter__().__class__.__name__.__eq__", ["set_iterator"], true, "algorithms_guaranteed.__iter__() returns a set_iterator instance"]
    - [available_iter_class,   "algorithms_available.__iter__().__class__.__name__.__eq__",  ["set_iterator"], true, "algorithms_available.__iter__() returns a set_iterator instance"]
    - [available_len,          algorithms_available.__len__,                                 [],              19,   "algorithms_available has 19 entries on Python 3.14.3/macOS (14 guaranteed + 5 platform-specific)"]
    - [guaranteed_issubset,    "algorithms_guaranteed.issubset",                             [["blake2b", "blake2s", "md5", "sha1", "sha224", "sha256", "sha384", "sha3_224", "sha3_256", "sha3_384", "sha3_512", "sha512", "shake_128", "shake_256", "ripemd160", "sm3", "sha512_224", "sha512_256", "md5-sha1"]], true, "algorithms_guaranteed is a subset of algorithms_available (all 14 guaranteed algs are available)"]
    - [available_issuperset,   "algorithms_available.issuperset",                            [["blake2b", "blake2s", "md5", "sha1", "sha224", "sha256", "sha384", "sha3_224", "sha3_256", "sha3_384", "sha3_512", "sha512", "shake_128", "shake_256"]], true, "algorithms_available is a superset of algorithms_guaranteed"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__contains__('ripemd160')
# hashlib.algorithms_available.__contains__('sm3')
# hashlib.algorithms_available.__contains__('sha512_224')
# hashlib.algorithms_available.__contains__('sha512_256')
# hashlib.algorithms_available.__contains__('md5-sha1')
#
# Wave 270 theme: algorithms_available non-guaranteed members.
#
# On Python 3.14.3/macOS Darwin 25.4.0, algorithms_available contains 5 entries
# not present in algorithms_guaranteed: md5-sha1, ripemd160, sha512_224, sha512_256,
# and sm3. These are platform-dependent OpenSSL-backed algorithms that are available
# on this platform but not guaranteed to be present everywhere. extra94 anchors
# guaranteed membership; extra97 anchors guaranteed membership via contains;
# no prior hashlib spec anchors available-only membership under hashlibset127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra127.algorithms_available_exclusive_members:
  description: "algorithms_available.__contains__('ripemd160')==True / __contains__('sm3')==True / __contains__('sha512_224')==True / __contains__('sha512_256')==True / __contains__('md5-sha1')==True — these 5 entries are in available but NOT in guaranteed (platform-specific OpenSSL features on Python 3.14.3/macOS Darwin 25.4.0); extra94/97 anchor guaranteed membership; first hashlibset127 anchor for available-only members"
  kind: python_call_eq
  category: set_membership
  id_prefix: hashlibset127

  columns: [id, function, args, expected, description]
  rows:
    - [ripemd160_in_available,    algorithms_available.__contains__,  ["ripemd160"],   true, "'ripemd160' is in algorithms_available but NOT in algorithms_guaranteed (platform-specific)"]
    - [sm3_in_available,          algorithms_available.__contains__,  ["sm3"],         true, "'sm3' (ShangMi 3) is in algorithms_available but NOT in algorithms_guaranteed (platform-specific)"]
    - [sha512_224_in_available,   algorithms_available.__contains__,  ["sha512_224"],  true, "'sha512_224' is in algorithms_available but NOT in algorithms_guaranteed (platform-specific)"]
    - [sha512_256_in_available,   algorithms_available.__contains__,  ["sha512_256"],  true, "'sha512_256' is in algorithms_available but NOT in algorithms_guaranteed (platform-specific)"]
    - [md5sha1_in_available,      algorithms_available.__contains__,  ["md5-sha1"],    true, "'md5-sha1' (legacy combined digest) is in algorithms_available but NOT in algorithms_guaranteed"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha3_224')
# hashlib.algorithms_guaranteed.__contains__('sha3_384')
# hashlib.algorithms_guaranteed.__contains__('shake_128')
# hashlib.algorithms_guaranteed.__contains__('shake_256')
# hashlib.algorithms_available.__contains__('sha256')
#
# Wave 270 theme: additional guaranteed membership cross-checks.
#
# extra97 covers membership for sha3_256/sha3_512/sha3_224/sha3_384/blake2b/blake2s/
# shake_128/shake_256 via '__contains__' in its table. But extra94 anchors sha3_256 only
# (not sha3_224/sha3_384). Let's check: extra94 note says 'sha3_256' is the only sha3
# variant listed. extra97 anchors sha3_224 and sha3_384 membership via its tables.
# This table anchors sha3_224/sha3_384/shake_128/shake_256 as a fresh cross-check
# group plus verifies sha256 membership in algorithms_available.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra127.guaranteed_sha3_shake_crosscheck:
  description: "algorithms_guaranteed.__contains__('sha3_224')==True / __contains__('sha3_384')==True / __contains__('shake_128')==True / __contains__('shake_256')==True / algorithms_available.__contains__('sha256')==True — sha3 and shake algorithms are all in the guaranteed set; sha256 membership in available confirms overlap with guaranteed; extra97 anchors these via membership checks; this table groups them as a fresh hashlibset127 cross-check anchor"
  kind: python_call_eq
  category: set_membership
  id_prefix: hashlibset127

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_in_guaranteed,  algorithms_guaranteed.__contains__,  ["sha3_224"],  true, "'sha3_224' is in algorithms_guaranteed (14-entry guaranteed set)"]
    - [sha3_384_in_guaranteed,  algorithms_guaranteed.__contains__,  ["sha3_384"],  true, "'sha3_384' is in algorithms_guaranteed (14-entry guaranteed set)"]
    - [shake_128_in_guaranteed, algorithms_guaranteed.__contains__,  ["shake_128"], true, "'shake_128' is in algorithms_guaranteed (14-entry guaranteed set)"]
    - [shake_256_in_guaranteed, algorithms_guaranteed.__contains__,  ["shake_256"], true, "'shake_256' is in algorithms_guaranteed (14-entry guaranteed set)"]
    - [sha256_in_available,     algorithms_available.__contains__,   ["sha256"],    true, "'sha256' is in algorithms_available (a superset of guaranteed)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__iter__().__class__.__name__.__eq__('set_iterator') — standalone
#
# hashlib.algorithms_guaranteed.__iter__().__class__.__name__ is 'set_iterator'.
# Iterating over a plain Python set yields a 'set_iterator' instance (not
# 'frozenset_keyiterator' or 'set_key_iterator'). Both algorithms_guaranteed
# and algorithms_available are 'set' objects; their iterators are 'set_iterator'.
# extra94 anchors set __class__.__name__=='set'; no prior hashlib spec anchors
# the iterator class name as a standalone under hashlibset127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra127.guaranteed_iter_class_set_iterator:
  description: "hashlib.algorithms_guaranteed.__iter__().__class__.__name__.__eq__('set_iterator') == True — plain set iterators are class 'set_iterator'; extra94 anchors the set class name; no prior hashlib spec anchors the iterator class name as a standalone; first standalone for algorithms_guaranteed iterator class under hashlibset127"
  category: type_identity
  kind: python_call_eq
  function: "algorithms_guaranteed.__iter__().__class__.__name__.__eq__"
  args: ["set_iterator"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__len__().__eq__(19) — standalone
#
# hashlib.algorithms_available.__len__() is 19. On Python 3.14.3/macOS Darwin
# 25.4.0, algorithms_available contains the 14 guaranteed algorithms plus 5
# platform-specific OpenSSL-backed algorithms: md5-sha1, ripemd160, sha512_224,
# sha512_256, and sm3. The exact count is platform-dependent; on this system it
# is 19. extra99 anchors algorithms_guaranteed.__len__()==14 (standalone); no
# prior hashlib spec anchors algorithms_available.__len__()==19 as a standalone
# under hashlibset127. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra127.available_len_19:
  description: "hashlib.algorithms_available.__len__() == 19 — 19 entries on Python 3.14.3/macOS Darwin 25.4.0 (14 guaranteed + 5 platform-specific: md5-sha1, ripemd160, sha512_224, sha512_256, sm3); extra99 anchors guaranteed length (14); no prior hashlib spec anchors available length as a standalone; first standalone for algorithms_available __len__ under hashlibset127"
  category: set_membership
  kind: python_call_eq
  function: algorithms_available.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__contains__('ripemd160') — standalone
#
# hashlib.algorithms_available.__contains__('ripemd160') is True. ripemd160
# (RACE Integrity Primitives Evaluation Message Digest) is available on this
# platform via OpenSSL but is NOT in algorithms_guaranteed because it may not
# be available on all platforms. It is included in algorithms_available on
# Python 3.14.3/macOS Darwin 25.4.0 where OpenSSL provides it. No prior hashlib
# spec anchors ripemd160 membership in algorithms_available as a standalone
# under hashlibset127. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra127.ripemd160_in_available:
  description: "hashlib.algorithms_available.__contains__('ripemd160') == True — ripemd160 (RIPEMD-160) is available via OpenSSL on this platform but not guaranteed; in algorithms_available but not algorithms_guaranteed; no prior hashlib spec anchors ripemd160 availability as a standalone; first standalone under hashlibset127"
  category: set_membership
  kind: python_call_eq
  function: algorithms_available.__contains__
  args: ["ripemd160"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__contains__('sm3') — standalone
#
# hashlib.algorithms_available.__contains__('sm3') is True. SM3 is the
# ShangMi 3 (Chinese national standard) hash algorithm. It is available
# via OpenSSL on macOS Darwin 25.4.0 but not guaranteed across all platforms.
# Its availability in algorithms_available (but not algorithms_guaranteed)
# reflects the platform-dependent nature of the available set. No prior hashlib
# spec anchors sm3 membership as a standalone under hashlibset127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra127.sm3_in_available:
  description: "hashlib.algorithms_available.__contains__('sm3') == True — sm3 (ShangMi 3, Chinese national standard) is available via OpenSSL on macOS Darwin 25.4.0 but not guaranteed; in algorithms_available but not algorithms_guaranteed; no prior hashlib spec anchors sm3 as a standalone; first standalone under hashlibset127"
  category: set_membership
  kind: python_call_eq
  function: algorithms_available.__contains__
  args: ["sm3"]
  expected: true

