spec: itertools_extra2326
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 602 (_extra2326): numeric constants and fixed-size attribute checks."
    - "itertools has no numeric constants; this file checks module __name__ and iterator type __name__ attributes."
    - "All 15 iterator types checked: chain, cycle, count, combinations, permutations, product, islice, repeat, groupby, compress, takewhile, dropwhile, starmap, zip_longest, accumulate."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: itertools module identity
# ---------------------------------------------------------------------------

table itertools_extra2326.module_identity:
  description: "itertools module-level __name__ attribute"
  kind: python_call_eq
  category: constants
  id_prefix: it2326

  columns: [id, function, args, expected]
  rows:
    - ["it2326001", "itertools.__name__", [], "itertools"]

# ---------------------------------------------------------------------------
# Table 2: iterator type __name__ attributes — combining / selecting types
#
# Each entry checks that the C-level iterator type's __name__ attribute
# matches the expected class name string.
# ---------------------------------------------------------------------------

table itertools_extra2326.combining_type_names:
  description: "itertools combining and grouping iterator type __name__ attributes"
  kind: python_call_eq
  category: constants
  id_prefix: it2326

  columns: [id, function, args, expected]
  rows:
    - ["it2326002", "itertools.chain.__name__",        [], "chain"]
    - ["it2326003", "itertools.product.__name__",      [], "product"]
    - ["it2326004", "itertools.combinations.__name__", [], "combinations"]
    - ["it2326005", "itertools.permutations.__name__", [], "permutations"]
    - ["it2326006", "itertools.groupby.__name__",      [], "groupby"]
    - ["it2326007", "itertools.zip_longest.__name__",  [], "zip_longest"]

# ---------------------------------------------------------------------------
# Table 3: iterator type __name__ attributes — infinite and filtering types
# ---------------------------------------------------------------------------

table itertools_extra2326.infinite_filter_type_names:
  description: "itertools infinite and filtering iterator type __name__ attributes"
  kind: python_call_eq
  category: constants
  id_prefix: it2326

  columns: [id, function, args, expected]
  rows:
    - ["it2326008",  "itertools.cycle.__name__",     [], "cycle"]
    - ["it2326009",  "itertools.count.__name__",     [], "count"]
    - ["it2326010",  "itertools.repeat.__name__",    [], "repeat"]
    - ["it2326011",  "itertools.islice.__name__",    [], "islice"]
    - ["it2326012",  "itertools.compress.__name__",  [], "compress"]
    - ["it2326013",  "itertools.takewhile.__name__", [], "takewhile"]
    - ["it2326014",  "itertools.dropwhile.__name__", [], "dropwhile"]

# ---------------------------------------------------------------------------
# Table 4: iterator type __name__ attributes — mapping types
# ---------------------------------------------------------------------------

table itertools_extra2326.mapping_type_names:
  description: "itertools mapping and accumulation iterator type __name__ attributes"
  kind: python_call_eq
  category: constants
  id_prefix: it2326

  columns: [id, function, args, expected]
  rows:
    - ["it2326015", "itertools.starmap.__name__",    [], "starmap"]
    - ["it2326016", "itertools.accumulate.__name__", [], "accumulate"]

# ---------------------------------------------------------------------------
# Table 5: iterator type __module__ attributes
#
# All itertools C-level types report their __module__ as "itertools".
# ---------------------------------------------------------------------------

table itertools_extra2326.type_modules:
  description: "itertools iterator type __module__ attributes — all equal 'itertools'"
  kind: python_call_eq
  category: constants
  id_prefix: it2326

  columns: [id, function, args, expected]
  rows:
    - ["it2326017", "itertools.chain.__module__",        [], "itertools"]
    - ["it2326018", "itertools.cycle.__module__",        [], "itertools"]
    - ["it2326019", "itertools.count.__module__",        [], "itertools"]
    - ["it2326020", "itertools.combinations.__module__", [], "itertools"]
    - ["it2326021", "itertools.permutations.__module__", [], "itertools"]
    - ["it2326022", "itertools.product.__module__",      [], "itertools"]
