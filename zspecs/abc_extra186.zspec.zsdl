spec: abc_extra186
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABCMeta.__name__ == 'ABCMeta' (len=7: A(1)B(2)C(3)M(4)e(5)t(6)a(7))."
    - "abc.ABCMeta.__module__ == 'abc' (len=3: a(1)b(2)c(3)); ABCMeta is defined directly in the abc module."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta inherits from 'type' (the metaclass of all classes)."
    - "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16)."
    - "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25: 'ABCMeta'=7+'.'=1+'__subclasscheck__'=17=25)."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25: same as __subclasscheck__; a 2-way tie at 25)."
    - "abc.ABCMeta.__init__.__qualname__ == 'type.__init__' (len=13: 'type'=4+'.'=1+'__init__'=8=13); ABCMeta inherits __init__ from 'type' without overriding it."
    - "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15)."
    - "Length ordering: abc(3) < ABCMeta(7) < __init__(type.__init__=13) < __new__(15) < register(16) < __subclasscheck__==__instancecheck__(25)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

