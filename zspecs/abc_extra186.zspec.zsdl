table abc_extra186.abc_abcmeta_check_qualnames:
  description: "abc.ABCMeta register, __subclasscheck__, __instancecheck__ qualname identity in abcabcmeta186 namespace — ABCMeta.register.__qualname__=='ABCMeta.register' (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16; register(cls) adds cls to the virtual subclass registry so isinstance/issubclass checks return True for cls against the ABC without cls inheriting from it); ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25: 'ABCMeta'=7+'.'=1+'__subclasscheck__'=17=25; overrides type.__subclasscheck__ to consult the ABC registry; called by issubclass()); ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25: same length; overrides type.__instancecheck__ to consult the ABC registry; called by isinstance()); __subclasscheck__==__instancecheck__ at 25 — a 2-way tie; register(16) < __subclasscheck__==__instancecheck__(25) by 9; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmeta186

  columns: [id, function, args, expected, description]
  rows:
    - [register_qualname_eq,       ABCMeta.register.__qualname__.__eq__,            ["ABCMeta.register"],            true, "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16; adds virtual subclasses to ABC registry); verified Python 3.14.3"]
    - [register_qualname_len,      ABCMeta.register.__qualname__.__len__,           [],                             16,   "abc.ABCMeta.register.__qualname__.__len__() == 16 ('ABCMeta.register'=16: 'ABCMeta'=7+'.'=1+'register'=8=16); register(16) < __subclasscheck__==__instancecheck__(25); verified Python 3.14.3"]
    - ["subclass_qualname_eq",     "ABCMeta.__subclasscheck__.__qualname__.__eq__", ["ABCMeta.__subclasscheck__"],   true, "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25; overrides issubclass() dispatch); verified Python 3.14.3"]
    - ["subclass_qualname_len",    "ABCMeta.__subclasscheck__.__qualname__.__len__",[],                             25,   "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 ('ABCMeta.__subclasscheck__'=25; ties with __instancecheck__); verified Python 3.14.3"]
    - ["instance_qualname_eq",     "ABCMeta.__instancecheck__.__qualname__.__eq__", ["ABCMeta.__instancecheck__"],   true, "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25; overrides isinstance() dispatch); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABCMeta __init__ and __new__ qualnames
#
# ABCMeta.__init__.__qualname__ == 'type.__init__' (len=13 — inherited from type)
# ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15)
