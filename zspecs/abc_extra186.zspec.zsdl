# ABCMeta.__module__ == 'abc' (len=3)
# ABCMeta.__bases__[0].__name__ == 'type'
# ---------------------------------------------------------------------------

table abc_extra186.abc_abcmeta_class_identity:
  description: "abc.ABCMeta class identity checks in abcabcmeta186 namespace — ABCMeta.__name__=='ABCMeta' (len=7: A(1)B(2)C(3)M(4)e(5)t(6)a(7); 'ABCMeta' compounds 'ABC'=3 and 'Meta'=4=7); ABCMeta.__module__=='abc' (len=3: the shortest module path in this spec series — abc(3) < asyncio.queues(14) < multiprocessing.queues(22)); ABCMeta.__bases__[0].__name__=='type' (len=4: ABCMeta is a metaclass that inherits from the built-in 'type'; this makes ABCMeta itself a class whose instances are also classes — ABCMeta is the metaclass behind all Abstract Base Classes); ABCMeta.__name__.__len__()==7; ABCMeta.__module__.__len__()==3; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmeta186

  columns: [id, function, args, expected, description]
  rows:
    - [meta_name_eq,    ABCMeta.__name__.__eq__,    ["ABCMeta"], true, "abc.ABCMeta.__name__ == 'ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7; ABCMeta is the metaclass for abstract base classes); verified Python 3.14.3"]
    - [meta_name_len,   ABCMeta.__name__.__len__,   [],          7,    "abc.ABCMeta.__name__.__len__() == 7 ('ABCMeta'=7); register qualname(16) > ABCMeta name(7) by 9; verified Python 3.14.3"]
    - [meta_module_eq,  ABCMeta.__module__.__eq__,  ["abc"],     true, "abc.ABCMeta.__module__ == 'abc' (len=3; shortest module path in this spec; ABCMeta is defined directly in abc module); verified Python 3.14.3"]
    - [meta_module_len, ABCMeta.__module__.__len__, [],          3,    "abc.ABCMeta.__module__.__len__() == 3 ('abc'=3: a(1)b(2)c(3)); abc(3) is the shortest module path across all 4 specs in this group; verified Python 3.14.3"]
    - ["meta_base_eq",  "ABCMeta.__bases__[0].__name__.__eq__",  ["type"], true, "abc.ABCMeta.__bases__[0].__name__ == 'type' (ABCMeta inherits from type — it is a metaclass); verified Python 3.14.3"]

