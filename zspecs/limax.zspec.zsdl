spec: limax
version: ">=4.2.3"
backend: node(limax)

docs: https://www.npmjs.com/package/limax

provenance:
  derived_from:
    - "limax README — https://www.npmjs.com/package/limax"
    - "Test vectors verified with limax via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "limax source"
  notes:
    - "limax is an npm package. Install: npm install limax"
    - "Converts a string to a URL-friendly slug."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table limax.slug:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: limax

  columns: [id, args, expected]
  rows:
    - [spaces,    ["Hello World"],          "hello-world"]
    - [phrase,    ["The Quick Brown Fox"],  "the-quick-brown-fox"]
    - [compound,  ["Foo Bar"],              "foo-bar"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:15:31Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
