spec: io_extra199
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/fileio.c"
  notes:
    - "This spec extends io_extra198.zspec.zsdl."
    - "This spec covers io.FileIO class identity — __name__, __module__, __bases__[0].__name__, __class__.__name__, __init__.__qualname__, read.__qualname__, write.__qualname__, and readall.__qualname__."
    - "io.FileIO.__name__ == 'FileIO' (len=6); confirmed Python 3.14.3 macOS."
    - "io.FileIO.__module__ == '_io' (len=3); FileIO is implemented in the _io C extension, not the pure-Python io wrapper; confirmed Python 3.14.3 macOS."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' (len=10); the direct base is the C-level _RawIOBase, not the pure-Python RawIOBase; confirmed Python 3.14.3 macOS."
    - "io.FileIO.__class__.__name__ == 'type' — FileIO uses the plain type metaclass; confirmed Python 3.14.3 macOS."
    - "io.FileIO.__init__.__qualname__ == 'FileIO.__init__' (len=15: 'FileIO.'=7+'__init__'=8=15); confirmed Python 3.14.3 macOS."
    - "io.FileIO.read.__qualname__ == 'FileIO.read' (len=11: 'FileIO.'=7+'read'=4=11); confirmed Python 3.14.3 macOS."
    - "io.FileIO.write.__qualname__ == 'FileIO.write' (len=12: 'FileIO.'=7+'write'=5=12); confirmed Python 3.14.3 macOS."
    - "io.FileIO.readall.__qualname__ == 'FileIO.readall' (len=14: 'FileIO.'=7+'readall'=7=14); confirmed Python 3.14.3 macOS."
    - "Qualname length ordering: read(11) < write(12) < readall(14) < __init__(15); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.FileIO method __qualname__ equality
# read(11), write(12), readall(14), __init__(15)
# ---------------------------------------------------------------------------

table io_extra199.fileio_method_qualnames:
  description: "io.FileIO method __qualname__ values: read='FileIO.read'(11), write='FileIO.write'(12), readall='FileIO.readall'(14), __init__='FileIO.__init__'(15, longest)"
  kind: python_call_eq
  category: identity
  id_prefix: iofileio199

  columns: [id, function, args, expected, description]
  rows:
    - [read_qn_eq,    io.FileIO.read.__qualname__.__eq__,    ["FileIO.read"],    true, "io.FileIO.read.__qualname__ == 'FileIO.read' (len=11); confirmed Python 3.14.3 macOS"]
    - [write_qn_eq,   io.FileIO.write.__qualname__.__eq__,   ["FileIO.write"],   true, "io.FileIO.write.__qualname__ == 'FileIO.write' (len=12); confirmed Python 3.14.3 macOS"]
    - [readall_qn_eq, io.FileIO.readall.__qualname__.__eq__, ["FileIO.readall"], true, "io.FileIO.readall.__qualname__ == 'FileIO.readall' (len=14); confirmed Python 3.14.3 macOS"]
    - [init_qn_eq,    io.FileIO.__init__.__qualname__.__eq__, ["FileIO.__init__"], true, "io.FileIO.__init__.__qualname__ == 'FileIO.__init__' (len=15, longest in spec); confirmed Python 3.14.3 macOS"]
    - [read_qn_len,   io.FileIO.read.__qualname__.__len__,   [], 11, "io.FileIO.read.__qualname__.__len__() == 11 ('FileIO.'=7+'read'=4); shortest qualname in spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.FileIO method __qualname__ lengths
# read(11) < write(12) < readall(14) < __init__(15)
# ---------------------------------------------------------------------------

table io_extra199.fileio_method_qualname_lengths:
  description: "io.FileIO method __qualname__ lengths: read=11, write=12, readall=14, __init__=15; length ordering read < write < readall < __init__"
  kind: python_call_eq
  category: identity
  id_prefix: iofileio199

  columns: [id, function, args, expected, description]
  rows:
    - [read_qn_len,    io.FileIO.read.__qualname__.__len__,    [], 11, "io.FileIO.read.__qualname__.__len__() == 11 ('FileIO.'=7+'read'=4); shortest in spec; confirmed Python 3.14.3 macOS"]
    - [write_qn_len,   io.FileIO.write.__qualname__.__len__,   [], 12, "io.FileIO.write.__qualname__.__len__() == 12 ('FileIO.'=7+'write'=5); confirmed Python 3.14.3 macOS"]
    - [readall_qn_len, io.FileIO.readall.__qualname__.__len__, [], 14, "io.FileIO.readall.__qualname__.__len__() == 14 ('FileIO.'=7+'readall'=7); confirmed Python 3.14.3 macOS"]
    - [init_qn_len,    io.FileIO.__init__.__qualname__.__len__, [], 15, "io.FileIO.__init__.__qualname__.__len__() == 15 ('FileIO.'=7+'__init__'=8); longest in spec; confirmed Python 3.14.3 macOS"]
    - [module_len,     io.FileIO.__module__.__len__,            [], 3,  "io.FileIO.__module__.__len__() == 3 — _io (underscore+i+o); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.FileIO class-level identity attributes
# __name__(FileIO,6), __module__(_io,3), __bases__[0].__name__(_RawIOBase,10), __class__(type)
# ---------------------------------------------------------------------------

table io_extra199.fileio_class_identity:
  description: "io.FileIO class-level identity: __name__='FileIO'(6), __module__='_io'(3), __bases__[0].__name__='_RawIOBase'(10), __class__.__name__='type'"
  kind: python_call_eq
  category: identity
  id_prefix: iofileio199

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       io.FileIO.__name__.__eq__,                          ["FileIO"],     true, "io.FileIO.__name__ == 'FileIO' (len=6); confirmed Python 3.14.3 macOS"]
    - [module_eq,     io.FileIO.__module__.__eq__,                        ["_io"],        true, "io.FileIO.__module__ == '_io' (C extension, len=3); confirmed Python 3.14.3 macOS"]
    - [base_eq,       "io.FileIO.__bases__[0].__name__.__eq__",           ["_RawIOBase"], true, "io.FileIO.__bases__[0].__name__ == '_RawIOBase' (len=10); the C-level raw IO base class; confirmed Python 3.14.3 macOS"]
    - [class_name_eq, io.FileIO.__class__.__name__.__eq__,                ["type"],       true, "io.FileIO.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS"]
    - [name_len,      io.FileIO.__name__.__len__,                         [],             6,    "io.FileIO.__name__.__len__() == 6 — F(1)i(2)l(3)e(4)I(5)O(6); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra199.fileio_name_eq:
  description: "io.FileIO.__name__ == 'FileIO' — class name string length 6 ('FileIO'); io.FileIO is the raw file I/O class that wraps OS-level file descriptors; its __name__ attribute returns the plain class name as a string; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra199.fileio_module_eq:
  description: "io.FileIO.__module__ == '_io' — FileIO is implemented in the _io C extension (len=3); although accessed as io.FileIO, the class itself lives in the C extension module _io; this is consistent with other io classes such as BufferedReader and BufferedWriter; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra199.fileio_base_name_eq:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — the direct base class of FileIO is _RawIOBase (len=10), which is the internal C-level raw IO base class; FileIO is the only concrete raw file class and it inherits directly from the C-level _RawIOBase; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.FileIO.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra199.fileio_class_name_type:
  description: "io.FileIO.__class__.__name__ == 'type' — FileIO's metaclass is the plain 'type' (not ABCMeta); FileIO is a C-level extension type and uses the standard type metaclass; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.FileIO.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra199.fileio_init_qualname_eq:
  description: "io.FileIO.__init__.__qualname__ == 'FileIO.__init__' — the qualified name of the __init__ method is 'FileIO.__init__' (len=15: 'FileIO.'=7 + '__init__'=8 = 15); this is the longest qualname in the spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.FileIO.__init__.__qualname__.__eq__
  args: ["FileIO.__init__"]
  expected: true

invariant io_extra199.fileio_read_qualname_eq:
  description: "io.FileIO.read.__qualname__ == 'FileIO.read' — the qualified name of the read method is 'FileIO.read' (len=11: 'FileIO.'=7 + 'read'=4 = 11); this is the shortest qualname in the spec; read reads up to size bytes from the file; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.FileIO.read.__qualname__.__eq__
  args: ["FileIO.read"]
  expected: true

invariant io_extra199.fileio_write_qualname_eq:
  description: "io.FileIO.write.__qualname__ == 'FileIO.write' — the qualified name of the write method is 'FileIO.write' (len=12: 'FileIO.'=7 + 'write'=5 = 12); write writes bytes to the file and returns the number written; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.FileIO.write.__qualname__.__eq__
  args: ["FileIO.write"]
  expected: true

invariant io_extra199.fileio_readall_qualname_eq:
  description: "io.FileIO.readall.__qualname__ == 'FileIO.readall' — the qualified name of the readall method is 'FileIO.readall' (len=14: 'FileIO.'=7 + 'readall'=7 = 14); readall reads and returns all bytes from the file until EOF; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.FileIO.readall.__qualname__.__eq__
  args: ["FileIO.readall"]
  expected: true
