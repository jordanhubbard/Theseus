spec: io_extra101
version: ">=3.9"
backend: python_module(io)
extends: io_extra100

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/fileio.c"
    - "CPython source: Modules/_io/textio.c"
  notes:
    - "This spec extends io_extra100.zspec.zsdl."
    - "This spec covers: io.FileIO method class names + io.TextIOWrapper class identity + io abstract base class MRO lengths."
    - "io.FileIO is a C extension type from _io. Its regular methods (read, write, seek, etc.) are 'method_descriptor' when accessed on the class."
    - "io.FileIO.__init__ and __repr__ are 'wrapper_descriptor' (slot wrappers on C extension types)."
    - "io.FileIO.mode is a 'getset_descriptor' (a C-level property descriptor, not a plain attribute)."
    - "io.TextIOWrapper.__module__ = '_io' — TextIOWrapper is defined in the C extension _io, not in pure Python io."
    - "io.TextIOWrapper.__bases__[0].__name__ = '_TextIOBase' — TextIOWrapper extends _TextIOBase (a C internal base)."
    - "io.TextIOWrapper.__mro__.__len__() = 4 — MRO: [TextIOWrapper, _TextIOBase, _IOBase, object]."
    - "io.IOBase.__mro__.__len__() = 3 — MRO: [IOBase, _IOBase, object]."
    - "io.RawIOBase.__mro__.__len__() = 5 — MRO: [RawIOBase, _RawIOBase, IOBase, _IOBase, object]."
    - "io.BufferedIOBase.__mro__.__len__() = 5 — same pattern as RawIOBase."
    - "io.TextIOBase.__mro__.__len__() = 5 — same pattern as RawIOBase."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.FileIO core method class names: read, write, seek, tell, close
# All are method_descriptor (C extension methods accessed on the class).
# ---------------------------------------------------------------------------

table io_extra101.FileIO_core_methods_classname:
  description: "io.FileIO core methods (read, write, seek, tell, close) __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iofileiotextwrapper101

  columns: [id, function, args, expected]
  rows:
    - [fileio_read_cls,   FileIO.read.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [fileio_write_cls,  FileIO.write.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [fileio_seek_cls,   FileIO.seek.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [fileio_tell_cls,   FileIO.tell.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [fileio_close_cls,  FileIO.close.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [fileio_read_not_wrapper, FileIO.read.__class__.__name__.__eq__, ["wrapper_descriptor"], false]

# ---------------------------------------------------------------------------
# io.FileIO predicate and dunder method class names
# readable, writable, seekable, readinto, readall, fileno -> method_descriptor
# __init__, __repr__ -> wrapper_descriptor (slot wrappers on C extension types)
# mode -> getset_descriptor (a C-level property/getter-setter descriptor)
# ---------------------------------------------------------------------------

table io_extra101.FileIO_predicate_dunder_classname:
  description: "io.FileIO predicate methods (readable, writable, seekable, readinto, readall, fileno) and dunders (__init__, __repr__) and mode descriptor class names"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iofileiotextwrapper101

  columns: [id, function, args, expected]
  rows:
    - [fileio_readable_cls,  FileIO.readable.__class__.__name__.__eq__,  ["method_descriptor"],  true]
    - [fileio_writable_cls,  FileIO.writable.__class__.__name__.__eq__,  ["method_descriptor"],  true]
    - [fileio_seekable_cls,  FileIO.seekable.__class__.__name__.__eq__,  ["method_descriptor"],  true]
    - [fileio_readinto_cls,  FileIO.readinto.__class__.__name__.__eq__,  ["method_descriptor"],  true]
    - [fileio_readall_cls,   FileIO.readall.__class__.__name__.__eq__,   ["method_descriptor"],  true]
    - [fileio_fileno_cls,    FileIO.fileno.__class__.__name__.__eq__,    ["method_descriptor"],  true]
    - [fileio_init_cls,      FileIO.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [fileio_repr_cls,      FileIO.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [fileio_mode_cls,      FileIO.mode.__class__.__name__.__eq__,      ["getset_descriptor"],  true]
    - [fileio_init_not_meth, FileIO.__init__.__class__.__name__.__eq__,  ["method_descriptor"],  false]

# ---------------------------------------------------------------------------
# io.TextIOWrapper class identity
# __module__ == '_io' (C extension, not pure Python io).
# __name__ == 'TextIOWrapper'.
# __bases__[0].__name__ == '_TextIOBase' (internal C base class).
# __mro__.__len__() == 4: [TextIOWrapper, _TextIOBase, _IOBase, object].
# ---------------------------------------------------------------------------

table io_extra101.TextIOWrapper_class_identity:
  description: "io.TextIOWrapper class identity: __module__, __name__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: iofileiotextwrapper101

  columns: [id, function, args, expected]
  rows:
    - [tiow_module_eq,     TextIOWrapper.__module__.__eq__,                    ["_io"],           true]
    - [tiow_module_not_io, TextIOWrapper.__module__.__eq__,                    ["io"],            false]
    - [tiow_name_eq,       TextIOWrapper.__name__.__eq__,                      ["TextIOWrapper"], true]
    - [tiow_base_eq,       "TextIOWrapper.__bases__[0].__name__.__eq__",        ["_TextIOBase"],   true]
    - [tiow_base_not_tib,  "TextIOWrapper.__bases__[0].__name__.__eq__",        ["TextIOBase"],    false]
    - [tiow_mro_len,       TextIOWrapper.__mro__.__len__,                      [],                4]

# ---------------------------------------------------------------------------
# io module abstract base class __mro__.__len__() values
# IOBase: 3 ([IOBase, _IOBase, object])
# RawIOBase: 5 ([RawIOBase, _RawIOBase, IOBase, _IOBase, object])
# BufferedIOBase: 5 (same pattern)
# TextIOBase: 5 (same pattern)
# ---------------------------------------------------------------------------

table io_extra101.abc_mro_lengths:
  description: "io abstract base class __mro__.__len__() values: IOBase=3, RawIOBase=5, BufferedIOBase=5, TextIOBase=5"
  kind: python_call_eq
  category: class_identity
  id_prefix: iofileiotextwrapper101

  columns: [id, function, args, expected]
  rows:
    - [iobase_mro_len,     IOBase.__mro__.__len__,       [], 3]
    - [rawiobase_mro_len,  RawIOBase.__mro__.__len__,    [], 5]
    - [bufiobase_mro_len,  BufferedIOBase.__mro__.__len__, [], 5]
    - [textiobase_mro_len, TextIOBase.__mro__.__len__,   [], 5]
    - [iobase_mro_not_2,   IOBase.__mro__.__len__,       [], 3]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra101.FileIO.read_is_method_descriptor:
  description: "io.FileIO.read.__class__.__name__ == 'method_descriptor' (FileIO is a C extension type; its regular methods are method_descriptor when accessed on the class)"
  category: method_descriptor
  kind: python_call_eq
  function: FileIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra101.FileIO.init_is_wrapper_descriptor:
  description: "io.FileIO.__init__.__class__.__name__ == 'wrapper_descriptor' (slot wrappers on C extension types are wrapper_descriptor, not method_descriptor)"
  category: method_descriptor
  kind: python_call_eq
  function: FileIO.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant io_extra101.FileIO.mode_is_getset_descriptor:
  description: "io.FileIO.mode.__class__.__name__ == 'getset_descriptor' (mode is exposed as a C-level getter/setter descriptor, not a plain attribute)"
  category: method_descriptor
  kind: python_call_eq
  function: FileIO.mode.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant io_extra101.TextIOWrapper.module_is_underscore_io:
  description: "io.TextIOWrapper.__module__ == '_io' (TextIOWrapper is implemented in the C extension _io, not in the pure Python io wrapper module)"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra101.IOBase.mro_len_3:
  description: "io.IOBase.__mro__.__len__() == 3 (MRO is [IOBase, _IOBase, object]; the public ABC wraps the C internal base)"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__mro__.__len__
  args: []
  expected: 3
