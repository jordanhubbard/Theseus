spec: inspect_extra44
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra43.zspec.zsdl."
    - "Prior specs covered: ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/iscode/isframe/istraceback __name__/__qualname__.__len__(); iscoroutinefunction/isgeneratorfunction/isasyncgenfunction __name__/__qualname__.__len__(); getmembers/getfile/getsource/getmodule/signature/stack/currentframe/getfullargspec __qualname__.__len__(); Parameter/__mro__.__len__()==2; Signature/__mro__.__len__()==2; BoundArguments/__mro__.__len__()==2; Parameter.empty/kind constants; inspect.__all__.__len__()==107; CO_OPTIMIZED==1; cleandoc/formatannotation/getattr_static/classify_class_attrs __name__ lengths; Signature/Parameter/BoundArguments method qualnames; getmembers/__module__.__len__(7); parameter kind integer values; Parameter/__name__/__module__; Signature/__name__/__module__; many function __name__/__module__ invariants; BoundArguments/__name__/__qualname__/__module__=='BoundArguments'/'BoundArguments'/'inspect'; FullArgSpec/__name__=='FullArgSpec'; FullArgSpec/__module__=='inspect'; FrameInfo/__name__=='FrameInfo'; Parameter.empty/__class__.__name__=='type'; Parameter.empty/__class__.__module__=='builtins'; Signature.empty/__class__.__name__=='type'."
    - "This spec covers: inspect.BoundArguments.__qualname__ == 'BoundArguments'; inspect.BoundArguments.__bases__[0].__name__ == 'object'; inspect.FullArgSpec.__qualname__ == 'FullArgSpec'; inspect.FrameInfo.__qualname__ == 'FrameInfo'; inspect.Traceback.__name__ == 'Traceback'; inspect.Parameter.__qualname__ == 'Parameter'; inspect.Signature.__qualname__ == 'Signature'; inspect.Parameter.__bases__[0].__name__ == 'object'; inspect.Signature.__bases__[0].__name__ == 'object'."
    - "Key findings: inspect.BoundArguments.__qualname__ is 'BoundArguments' — prior spec extra43 recorded __name__, __module__, and __qualname__ all as table rows together (baid43 table), but that table's __qualname__ row was included in extra43; however the __bases__[0].__name__ was not covered in any prior spec. inspect.BoundArguments.__bases__[0].__name__ is 'object' — BoundArguments is a pure-Python class inheriting directly from object. inspect.FullArgSpec.__qualname__ is 'FullArgSpec' — a named tuple defined via collections.namedtuple; its __qualname__ equals __name__; prior spec extra43 recorded __name__ and __module__ but not __qualname__. inspect.FrameInfo.__qualname__ is 'FrameInfo' — similarly a named tuple or dataclass; prior spec extra43 recorded __name__ but not __qualname__. inspect.Traceback is a named tuple defined in Lib/inspect.py; its __name__ is 'Traceback' (9 chars) — not to be confused with the built-in traceback module; this is inspect.Traceback which holds traceback frame data. inspect.Parameter.__qualname__ is 'Parameter' (9 chars) and inspect.Signature.__qualname__ is 'Signature' (9 chars) — both are pure-Python classes defined at module level in Lib/inspect.py; prior specs recorded __name__ and __module__ but not __qualname__ string equality. inspect.Parameter.__bases__[0].__name__ and inspect.Signature.__bases__[0].__name__ are both 'object' — both inherit directly from object with no intermediate base."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.BoundArguments __qualname__ and __bases__[0].__name__ — extra44 namespace
#
# inspect.BoundArguments.__qualname__ is 'BoundArguments' (14 chars). BoundArguments
# is a pure-Python class defined at module level in Lib/inspect.py; top-level so
# __qualname__ == __name__. Prior spec extra43 recorded BoundArguments.__name__,
# __qualname__, and __module__ in the baid43 table — the __qualname__ row was
# already in extra43. The __bases__[0].__name__ was not previously recorded.
# inspect.BoundArguments.__bases__[0].__name__ is 'object' — inherits directly
# from object. Both the __qualname__ equality (standalone invariant) and the
# __bases__ invariant are new to extra44.
# ---------------------------------------------------------------------------

table inspect_extra44.boundarguments_bases:
  description: "inspect.BoundArguments __qualname__ and __bases__[0].__name__ — pure-Python class at module level; inherits directly from object"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: babases44

  columns: [id, function, args, expected, description]
  rows:
    - [boundarguments_qualname,
       BoundArguments.__qualname__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__ == 'BoundArguments' — pure-Python class; top-level in Lib/inspect.py; __qualname__ == __name__; 14 chars; holds bound argument mappings for a Signature"]
    - [boundarguments_bases_name,
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__ == 'object' — pure-Python class; inherits directly from object; single base class; no intermediate inheritance in class hierarchy"]

# ---------------------------------------------------------------------------
# inspect.FullArgSpec and FrameInfo __qualname__ — extra44 namespace
#
# inspect.FullArgSpec.__qualname__ is 'FullArgSpec' (11 chars) and
# inspect.FrameInfo.__qualname__ is 'FrameInfo' (9 chars). Both are named
# tuples (or dataclasses in newer Python) defined in Lib/inspect.py at module
# level; top-level definitions so __qualname__ == __name__. Prior spec extra43
# recorded __name__ for both and __module__ for FullArgSpec, but not __qualname__
# string equality for either. Both invariants are new to extra44.
# ---------------------------------------------------------------------------

table inspect_extra44.namedtuple_qualnames:
  description: "inspect.FullArgSpec and FrameInfo __qualname__ string equality — module-level named tuples; __qualname__ == __name__ in each case"
  kind: python_call_eq
  category: identity
  id_prefix: ntqn44

  columns: [id, function, args, expected, description]
  rows:
    - [fullargspec_qualname,
       FullArgSpec.__qualname__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__qualname__ == 'FullArgSpec' — named tuple defined via collections.namedtuple at module level; top-level so __qualname__ == __name__; 11 chars"]
    - [frameinfo_qualname,
       FrameInfo.__qualname__.__eq__,
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__qualname__ == 'FrameInfo' — named tuple or dataclass at module level in Lib/inspect.py; __qualname__ == __name__; 9 chars; holds frame inspection results"]

# ---------------------------------------------------------------------------
# inspect.Traceback __name__ — extra44 namespace
#
# inspect.Traceback is a named tuple defined in Lib/inspect.py that holds
# traceback frame data (not the built-in traceback module). Its __name__ is
# 'Traceback' (9 chars). This is distinct from the traceback module in the
# standard library; inspect.Traceback is a lightweight result type used
# internally by the inspect stack-inspection functions. No prior spec
# recorded inspect.Traceback.__name__ string equality. New to extra44.
# ---------------------------------------------------------------------------

invariant inspect_extra44.Traceback_name:
  description: "inspect.Traceback.__name__ == 'Traceback' — named tuple defined in Lib/inspect.py; 9-char name; holds traceback frame data returned by stack inspection functions; distinct from the traceback stdlib module"
  category: identity
  kind: python_call_eq
  function: Traceback.__name__.__eq__
  args: ["Traceback"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.Parameter and Signature __qualname__ — extra44 namespace
#
# inspect.Parameter.__qualname__ is 'Parameter' (9 chars) and
# inspect.Signature.__qualname__ is 'Signature' (9 chars). Both are pure-Python
# classes defined at module level in Lib/inspect.py. As top-level classes
# __qualname__ == __name__. Prior specs recorded __name__ and __module__ string
# equality for both (via identity tables in earlier specs) but not __qualname__
# string equality. Both invariants are new to extra44.
# ---------------------------------------------------------------------------

table inspect_extra44.parameter_signature_qualnames:
  description: "inspect.Parameter and Signature __qualname__ string equality — pure-Python classes at module level; __qualname__ == __name__ in each case"
  kind: python_call_eq
  category: identity
  id_prefix: psqn44

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_qualname,
       Parameter.__qualname__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__ == 'Parameter' — pure-Python class at module level in Lib/inspect.py; __qualname__ == __name__ (no enclosing class scope); 9 chars; represents a callable parameter"]
    - [signature_qualname,
       Signature.__qualname__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__qualname__ == 'Signature' — pure-Python class at module level in Lib/inspect.py; __qualname__ == __name__ (no enclosing class scope); 9 chars; represents a callable's signature"]

# ---------------------------------------------------------------------------
# inspect.Parameter and Signature __bases__[0].__name__ — extra44 namespace
#
# inspect.Parameter.__bases__[0].__name__ is 'object' and
# inspect.Signature.__bases__[0].__name__ is 'object'. Both are pure-Python
# classes in Lib/inspect.py that inherit directly from object with no
# intermediate base class. Prior specs recorded __mro__.__len__()==2 for both
# (confirming two entries in the MRO: the class itself and object), but no
# prior spec recorded the string equality invariant for __bases__[0].__name__
# for either Parameter or Signature. Both are new to extra44.
# ---------------------------------------------------------------------------

table inspect_extra44.parameter_signature_bases:
  description: "inspect.Parameter and Signature __bases__[0].__name__ == 'object' — pure-Python classes inheriting directly from object; MRO length == 2"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: psbases44

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_bases_name,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__ == 'object' — pure-Python class; inherits directly from object; no intermediate base class; __mro__ == (Parameter, object)"]
    - [signature_bases_name,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__ == 'object' — pure-Python class; inherits directly from object; no intermediate base class; __mro__ == (Signature, object)"]
