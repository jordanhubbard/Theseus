spec: uuid_extra811
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - uuid module CPython source
    - Python documentation for uuid
  not_derived_from:
    - any third-party uuid library
  notes:
    - covers qualname and module identity for uuid1, uuid3, uuid4, uuid5, and UUID class
    - includes doc string class name checks for uuid1 and uuid4
  created_at: "2026-04-12"

table uuid_extra811.qualnames_and_modules:
  description: uuid module function qualnames and uuid.UUID class identity
  kind: python_call_eq
  category: identity
  id_prefix: uu811xx
  columns: [id, function, args, expected]
  rows:
    - [uu811xx001, uuid.uuid1.__qualname__.__eq__, ["uuid1"], true]
    - [uu811xx002, uuid.uuid1.__module__.__eq__, ["uuid"], true]
    - [uu811xx003, uuid.uuid3.__qualname__.__eq__, ["uuid3"], true]
    - [uu811xx004, uuid.uuid3.__module__.__eq__, ["uuid"], true]
    - [uu811xx005, uuid.uuid4.__qualname__.__eq__, ["uuid4"], true]
    - [uu811xx006, uuid.uuid4.__module__.__eq__, ["uuid"], true]
    - [uu811xx007, uuid.uuid5.__qualname__.__eq__, ["uuid5"], true]
    - [uu811xx008, uuid.uuid5.__module__.__eq__, ["uuid"], true]
    - [uu811xx009, uuid.uuid1.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu811xx010, uuid.uuid4.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu811xx011, uuid.UUID.__qualname__.__eq__, ["UUID"], true]
    - [uu811xx012, uuid.UUID.__module__.__eq__, ["uuid"], true]
