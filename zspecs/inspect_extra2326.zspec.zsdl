spec: inspect_extra2326
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 602 (_extra2326): numeric constants and fixed-size attribute checks."
    - "Code object flag constants: CO_OPTIMIZED=1, CO_NEWLOCALS=2, CO_VARARGS=4, CO_VARKEYWORDS=8, CO_NESTED=16, CO_GENERATOR=32, CO_NOFREE=64."
    - "inspect.Parameter.POSITIONAL_ONLY is a _ParameterKind enum member."
    - "inspect.Parameter.empty.__class__.__name__ is 'type' (it is a sentinel class, not an instance)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: code object flag integer constants
#
# These bitmask constants are defined in inspect and mirror CPython's
# code object co_flags field.  Values are powers of two.
# ---------------------------------------------------------------------------

table inspect_extra2326.co_flag_constants:
  description: "inspect code object flag constants — integer bitmask values"
  kind: python_call_eq
  category: constants
  id_prefix: in2326

  columns: [id, function, args, expected]
  rows:
    - ["in2326001", "inspect.CO_OPTIMIZED",   [], 1]
    - ["in2326002", "inspect.CO_NEWLOCALS",   [], 2]
    - ["in2326003", "inspect.CO_VARARGS",     [], 4]
    - ["in2326004", "inspect.CO_VARKEYWORDS", [], 8]
    - ["in2326005", "inspect.CO_NESTED",      [], 16]
    - ["in2326006", "inspect.CO_GENERATOR",   [], 32]
    - ["in2326007", "inspect.CO_NOFREE",      [], 64]

# ---------------------------------------------------------------------------
# Table 2: code object flag constants — class name checks
#
# Each flag constant is a plain Python int; verify its type name.
# ---------------------------------------------------------------------------

table inspect_extra2326.co_flag_types:
  description: "inspect code object flag constants — each is an int"
  kind: python_call_eq
  category: constants
  id_prefix: in2326

  columns: [id, function, args, expected]
  rows:
    - ["in2326008", "inspect.CO_OPTIMIZED.__class__.__name__",   [], "int"]
    - ["in2326009", "inspect.CO_NEWLOCALS.__class__.__name__",   [], "int"]
    - ["in2326010", "inspect.CO_VARARGS.__class__.__name__",     [], "int"]
    - ["in2326011", "inspect.CO_VARKEYWORDS.__class__.__name__", [], "int"]
    - ["in2326012", "inspect.CO_NESTED.__class__.__name__",      [], "int"]
    - ["in2326013", "inspect.CO_GENERATOR.__class__.__name__",   [], "int"]
    - ["in2326014", "inspect.CO_NOFREE.__class__.__name__",      [], "int"]

# ---------------------------------------------------------------------------
# Table 3: Parameter kind and sentinel class names
# ---------------------------------------------------------------------------

table inspect_extra2326.parameter_class_names:
  description: "inspect.Parameter special attribute class names"
  kind: python_call_eq
  category: constants
  id_prefix: in2326

  columns: [id, function, args, expected]
  rows:
    - ["in2326015", "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__",    [], "_ParameterKind"]
    - ["in2326016", "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__", [], "_ParameterKind"]
    - ["in2326017", "inspect.Parameter.VAR_POSITIONAL.__class__.__name__",     [], "_ParameterKind"]
    - ["in2326018", "inspect.Parameter.KEYWORD_ONLY.__class__.__name__",       [], "_ParameterKind"]
    - ["in2326019", "inspect.Parameter.VAR_KEYWORD.__class__.__name__",        [], "_ParameterKind"]
    - ["in2326020", "inspect.Parameter.empty.__class__.__name__",              [], "type"]

# ---------------------------------------------------------------------------
# Table 4: code object flag bitmask addition sanity checks
#
# Spot-checks that combining two flags yields the expected integer sum,
# confirming they are ordinary integers and not overloaded types.
# ---------------------------------------------------------------------------

table inspect_extra2326.co_flag_arithmetic:
  description: "inspect code object flag constants — pairwise sum sanity checks"
  kind: python_call_eq
  category: constants
  id_prefix: in2326

  columns: [id, function, args, expected]
  rows:
    - ["in2326021", "inspect.CO_OPTIMIZED.__add__",   [2],  3]
    - ["in2326022", "inspect.CO_VARARGS.__add__",     [8],  12]
    - ["in2326023", "inspect.CO_NESTED.__add__",      [32], 48]
