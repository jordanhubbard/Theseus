spec: struct_extra146
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra145.zspec.zsdl — covers struct.__dict__.__len__()==18 / struct.__dict__.__class__.__name__.__eq__('dict') / struct.Struct.__dict__.__len__()==16 / struct.error.__dict__.__len__()==3 / struct.error.__dict__.__class__.__name__.__eq__('mappingproxy') / error.__dict__.__contains__('__module__'/'__doc__'/'__weakref__') (table + invariants)."
    - "struct_extra144.zspec.zsdl — covers struct.__dict__.__contains__('pack'/'Struct'/'error'/'calcsize'/'unpack'/'pack_into'/'unpack_from'/'iter_unpack') / Struct.__dict__.__contains__('__init__'/'__sizeof__'/'__new__'/'__doc__') (table + invariants)."
    - "struct_extra143.zspec.zsdl — covers struct.Struct.__dict__.__contains__('pack'/'unpack'/'pack_into'/'format'/'size'/'iter_unpack'/'unpack_from'/'__repr__') / Struct.__dict__.__len__()==16 / struct.pack.__module__.__eq__('_struct') / struct.__package__.__eq__('') (table + invariants)."
    - "struct_extra142.zspec.zsdl — covers struct.__all__/__class__.__name__.__eq__('list') / __all__.__len__()==8 / __all__.__contains__('Struct'/'error'/'pack'/'calcsize') / __spec__.name.__eq__('struct') / __loader__.__class__.__name__.__eq__('SourceFileLoader') / Struct.__init__.__qualname__.__eq__('Struct.__init__') (table + invariants)."
    - "struct_extra141.zspec.zsdl — covers struct.Struct.__module__.__eq__('_struct') / Struct.__qualname__.__eq__('Struct') / Struct.__bases__[0].__name__.__eq__('object') / Struct.__mro__.__len__()==2 / Struct.__doc__.__len__()==40 / Struct.__dict__.__class__.__name__.__eq__('mappingproxy') / error.__qualname__.__eq__('error') (table + invariants)."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra145."
    - "Wave 331 theme: _struct C extension module namespace — _struct.__dict__.__len__()==15 / _struct.__dict__.__class__.__name__.__eq__('dict') / _struct.__dict__.__contains__('Struct') / _struct.__dict__.__contains__('pack') / _struct.__dict__.__contains__('error') / _struct.__dict__.__contains__('calcsize') / _struct.__dict__.__contains__('unpack'). Also size comparison: struct(18) vs _struct(15) — the public wrapper has exactly 3 more entries than the C extension."
    - "_struct.__dict__.__len__() == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_struct.__dict__.__class__.__name__ == 'dict'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_struct.__dict__.__contains__('Struct') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_struct.__dict__.__contains__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_struct.__dict__.__contains__('error') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_struct.__dict__.__contains__('calcsize') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_struct.__dict__.__contains__('unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: _struct.__dict__.__len__() == 15. The 15 C extension entries are: Struct (class), error (exception), __doc__, __file__, __loader__, __name__, __package__, __spec__ (7 metadata), _clearcache (1 private helper), calcsize, iter_unpack, pack, pack_into, unpack, unpack_from (6 functions). The public struct module dict (18) has exactly 3 more entries than _struct (15): the 3 additional entries are __all__ (the exported name list), __cached__ (the cached .pyc path), and __builtins__ (the builtins reference added when the module is executed). These 3 entries are Python-level module infrastructure that only exist in the pure-Python wrapper, not in the C extension."
    - "Note: _struct.__dict__.__class__.__name__ == 'dict' (4 chars). Like all module __dict__ objects, the _struct C extension dict is a plain mutable dict. This is the same type as the public struct module dict. This is distinct from struct.Struct.__dict__ which is a 'mappingproxy' (12 chars, anchored in extra141)."
    - "Note: Comparing struct vs _struct dict sizes: struct(18) = _struct(15) + 3. The 3 extra entries in struct (not in _struct) are __all__, __cached__, and __builtins__. All 6 functions (calcsize/iter_unpack/pack/pack_into/unpack/unpack_from) and both classes (Struct/error) present in struct.__dict__ are also present in _struct.__dict__. The structs are the same objects imported into the struct namespace from _struct."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _struct.__dict__.__len__()==15
# _struct.__dict__.__class__.__name__.__eq__('dict')
# struct.__dict__.__len__()==18
#
# Wave 331 theme: _struct C extension namespace size vs public struct size.
#
# The _struct C extension dict (15 entries) is exactly 3 entries smaller than the
# public struct module dict (18 entries). The 3-entry difference arises from __all__,
# __cached__, and __builtins__ — Python-level infrastructure present in struct but not
# in _struct. Both dicts are plain 'dict' (4 chars), not mappingproxy. extra145 anchors
# struct.__dict__.__len__()==18 as a table; no prior struct spec anchors
# _struct.__dict__.__len__()==15 or the comparison as a table under structc146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra146.struct_vs_struct_c_dict_sizes:
  description: "_struct.__dict__.__len__()==15 / _struct.__dict__.__class__.__name__.__eq__('dict')==True / struct.__dict__.__len__()==18 — _struct C extension dict (15) is exactly 3 entries smaller than public struct dict (18); the 3-entry difference: __all__ + __cached__ + __builtins__ (Python wrapper infrastructure not in C extension); both are plain 'dict' (4 chars); extra145 anchors struct dict len; first structc146 anchor for _struct dict len and comparison"
  kind: python_call_eq
  category: identity
  id_prefix: structc146

  columns: [id, function, args, expected, description]
  rows:
    - [struct_c_dict_len_15,   "_struct.__dict__.__len__",                    [],       15,   "_struct.__dict__.__len__() is 15 (C extension dict; 3 fewer than struct's 18 entries)"]
    - [struct_c_dict_class,    "_struct.__dict__.__class__.__name__.__eq__",  ["dict"],  true, "_struct.__dict__.__class__.__name__ == 'dict' (4 chars; plain mutable module dict, same as struct)"]
    - [struct_dict_len_18,     "__dict__.__len__",                            [],       18,   "struct.__dict__.__len__() is 18 (public wrapper; 3 more than _struct: __all__ + __cached__ + __builtins__)"]

# ---------------------------------------------------------------------------
# _struct.__dict__.__contains__('Struct')
# _struct.__dict__.__contains__('pack')
# _struct.__dict__.__contains__('error')
# _struct.__dict__.__contains__('calcsize')
#
# Wave 331 theme: _struct C extension dict contains the core public names.
#
# Struct (class), pack (function), error (exception), and calcsize (function) are
# four of the core public names in _struct.__dict__. These are the same objects that
# are imported into the struct namespace. extra144 anchors struct.__dict__.__contains__
# for these same names (module-level); no prior struct spec anchors _struct.__dict__
# .__contains__ for any name as a table under structc146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra146.struct_c_dict_contains_core_names:
  description: "_struct.__dict__.__contains__('Struct')==True / __dict__.__contains__('pack')==True / __dict__.__contains__('error')==True / __dict__.__contains__('calcsize')==True — Struct/pack/error/calcsize are the same objects imported into struct namespace; all 6 functions + both classes present in both struct and _struct dicts; extra144 anchors struct.__dict__.__contains__ for these same names; first structc146 anchor for _struct.__dict__.__contains__ membership checks"
  kind: python_call_eq
  category: identity
  id_prefix: structc146

  columns: [id, function, args, expected, description]
  rows:
    - [struct_c_Struct,    "_struct.__dict__.__contains__",  ["Struct"],   true, "_struct.__dict__.__contains__('Struct') == True (the compiled Struct class; same object as struct.Struct)"]
    - [struct_c_pack,      "_struct.__dict__.__contains__",  ["pack"],     true, "_struct.__dict__.__contains__('pack') == True (builtin_function_or_method; same object as struct.pack)"]
    - [struct_c_error,     "_struct.__dict__.__contains__",  ["error"],    true, "_struct.__dict__.__contains__('error') == True (exception class; same object as struct.error)"]
    - [struct_c_calcsize,  "_struct.__dict__.__contains__",  ["calcsize"], true, "_struct.__dict__.__contains__('calcsize') == True (builtin_function_or_method; same object as struct.calcsize)"]

# ---------------------------------------------------------------------------
# _struct.__dict__.__contains__('unpack')
# _struct.__dict__.__contains__('pack_into')
# _struct.__dict__.__contains__('iter_unpack')
# _struct.__dict__.__contains__('_clearcache')
#
# Wave 331 theme: _struct C extension dict contains remaining functions and private helper.
#
# unpack, pack_into, and iter_unpack are three of the six module-level functions in
# _struct. _clearcache is a private helper function present in _struct (and imported
# into struct) that clears the internal format-string cache. No prior struct spec
# anchors _struct.__dict__.__contains__ for these four names as a table under structc146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra146.struct_c_dict_contains_remaining_functions:
  description: "_struct.__dict__.__contains__('unpack')==True / __dict__.__contains__('pack_into')==True / __dict__.__contains__('iter_unpack')==True / __dict__.__contains__('_clearcache')==True — completing the six C-level functions (calcsize/pack/unpack/pack_into/unpack_from/iter_unpack); _clearcache is a private helper that clears the format-string cache; all seven (_clearcache + 6 functions) are builtin_function_or_method from the C extension; first structc146 anchor for these four names"
  kind: python_call_eq
  category: identity
  id_prefix: structc146

  columns: [id, function, args, expected, description]
  rows:
    - [struct_c_unpack,      "_struct.__dict__.__contains__",  ["unpack"],      true, "_struct.__dict__.__contains__('unpack') == True (builtin_function_or_method; same object as struct.unpack)"]
    - [struct_c_pack_into,   "_struct.__dict__.__contains__",  ["pack_into"],   true, "_struct.__dict__.__contains__('pack_into') == True (builtin_function_or_method; packs into an existing buffer)"]
    - [struct_c_iter_unpack, "_struct.__dict__.__contains__",  ["iter_unpack"], true, "_struct.__dict__.__contains__('iter_unpack') == True (builtin_function_or_method; yields successive tuples from buffer)"]
    - [struct_c_clearcache,  "_struct.__dict__.__contains__",  ["_clearcache"], true, "_struct.__dict__.__contains__('_clearcache') == True (private helper; clears the internal format-string cache)"]

# ---------------------------------------------------------------------------
# _struct.__dict__.__len__()==15 — standalone
#
# _struct.__dict__.__len__() is 15. The 15 C extension entries are: Struct (class),
# error (exception class), __doc__, __file__, __loader__, __name__, __package__, __spec__
# (6 standard C extension metadata), _clearcache (private helper), and the 6 public
# functions: calcsize, iter_unpack, pack, pack_into, unpack, unpack_from. The public
# struct module (18) = _struct (15) + 3 Python-level infrastructure entries (__all__,
# __cached__, __builtins__). Comparing C extension dict sizes: _struct(15) < _hashlib(32)
# << _socket(235). No prior struct spec anchors _struct.__dict__.__len__()==15 as a
# standalone under structc146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra146.struct_c_dict_len_15:
  description: "_struct.__dict__.__len__() == 15 — 15 C extension entries: Struct + error (2 types) + 6 metadata (__doc__/__file__/__loader__/__name__/__package__/__spec__) + _clearcache (1 private) + 6 functions (calcsize/iter_unpack/pack/pack_into/unpack/unpack_from); struct(18) = _struct(15) + 3 (__all__/__cached__/__builtins__); C extension dict sizes: _struct(15) < _hashlib(32) << _socket(235); no prior struct spec anchors this as a standalone; first standalone under structc146"
  category: identity
  kind: python_call_eq
  function: "_struct.__dict__.__len__"
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# _struct.__dict__.__class__.__name__.__eq__('dict') — standalone
#
# _struct.__dict__.__class__.__name__ is 'dict' (4 chars). C extension module dicts
# are plain mutable dicts, same as pure-Python module dicts. This is consistent with
# the pattern observed across all six module dicts in the series: struct(dict),
# hashlib(dict), _hashlib(dict), uuid(dict), socket(dict), _socket(dict) — all are
# 'dict' (4 chars). Class dicts (struct.Struct, struct.error, socket.socket, etc.)
# are always 'mappingproxy' (12 chars). No prior struct spec anchors
# _struct.__dict__.__class__.__name__.__eq__('dict') as a standalone under structc146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra146.struct_c_dict_class_dict:
  description: "_struct.__dict__.__class__.__name__.__eq__('dict') == True — 'dict' (4 chars); C extension module dicts are plain mutable dicts, same as pure-Python module dicts; all six module dicts in the series (struct/_struct/hashlib/_hashlib/uuid/socket/_socket) are 'dict'; class dicts (Struct/error/socket.socket/UUID) are 'mappingproxy' (12 chars); no prior struct spec anchors this as a standalone; first standalone under structc146"
  category: identity
  kind: python_call_eq
  function: "_struct.__dict__.__class__.__name__.__eq__"
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# _struct.__dict__.__contains__('Struct') — standalone
#
# _struct.__dict__.__contains__('Struct') is True. _struct.Struct is the compiled
# C extension type implementing the Struct class. When struct.py is loaded, it imports
# Struct from _struct into the struct namespace, making struct.Struct the same object
# as _struct.Struct. The Struct class compiles a format string at construction time
# and provides pack/unpack/pack_into/unpack_from/iter_unpack methods for efficient
# repeated binary packing/unpacking. extra141 anchors struct.Struct.__module__.__eq__
# ('_struct'), confirming its C extension origin; no prior struct spec anchors
# _struct.__dict__.__contains__('Struct') as a standalone under structc146.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra146.struct_c_dict_contains_Struct:
  description: "_struct.__dict__.__contains__('Struct') == True — _struct.Struct is the compiled C extension type; struct.Struct is the same object as _struct.Struct (imported by struct.py); compiles format string once for efficient repeated pack/unpack; extra141 anchors Struct.__module__=='_struct' confirming C origin; no prior struct spec anchors this as a standalone; first standalone under structc146"
  category: identity
  kind: python_call_eq
  function: "_struct.__dict__.__contains__"
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# _struct.__dict__.__contains__('_clearcache') — standalone
#
# _struct.__dict__.__contains__('_clearcache') is True. _struct._clearcache is a
# private builtin_function_or_method that clears the internal format-string cache
# maintained by the _struct C extension. The cache stores compiled format objects
# so that repeated calls with the same format string do not require re-compilation.
# _clearcache is also imported into the struct namespace (struct._clearcache is the
# same object). It is prefixed with an underscore indicating it is a private API not
# part of the public struct interface (__all__ does not include '_clearcache').
# No prior struct spec anchors _struct.__dict__.__contains__('_clearcache') as a
# standalone under structc146. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra146.struct_c_dict_contains_clearcache:
  description: "_struct.__dict__.__contains__('_clearcache') == True — private builtin_function_or_method; clears internal format-string cache maintained by _struct C extension; struct._clearcache is the same object; not in __all__ (private API); extra142 anchors __all__.__len__()==8 (does not include _clearcache); no prior struct spec anchors this as a standalone; first standalone under structc146"
  category: identity
  kind: python_call_eq
  function: "_struct.__dict__.__contains__"
  args: ["_clearcache"]
  expected: true
