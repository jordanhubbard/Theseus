spec: lodash_countby
version: ">=4.0.0"
backend: node(lodash.countby)

docs: https://lodash.com/docs/#countBy

provenance:
  derived_from:
    - "lodash.countby README — https://www.npmjs.com/package/lodash.countby"
    - "Test vectors verified with lodash.countby@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.countby exports the _.countBy function directly as module.exports."
    - "countBy(collection, iteratee) creates an object of counts keyed by iteratee result."
    - "String iteratee accesses the named property on each element."
    - "Keys in the result object are always strings (JS object key coercion)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object mapping group keys to counts."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_countby.countby:
  kind: node_module_call_eq
  function: ~
  category: countby
  id_prefix: lcby

  columns: [id, args, expected]
  rows:
    - [by_name,  [[{"n": "a"}, {"n": "b"}, {"n": "a"}], "n"],
       {"a": 2, "b": 1}]
    - [by_type,  [[{"t": "x"}, {"t": "y"}, {"t": "x"}, {"t": "x"}], "t"],
       {"x": 3, "y": 1}]

