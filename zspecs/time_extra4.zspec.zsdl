spec: time_extra4
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time.zspec.zsdl — covers gmtime/strptime/strftime/mktime/sleep __name__ (table), struct_time.__name__, gmtime epoch, strptime vectors, error cases"
    - "time_extra.zspec.zsdl — covers struct_time.__module__, time/monotonic/perf_counter/process_time return types (float), gmtime/localtime return types (struct_time), timezone/altzone class names"
    - "time_extra2.zspec.zsdl — covers struct_time.__name__/__module__, timezone/altzone/daylight class names, gmtime(0) epoch fields, time/__name__, sleep/__name__, function_names table"
    - "time_extra3.zspec.zsdl — covers struct_time._fields, altzone/daylight/timezone/tzname class names, gmtime/localtime/mktime/strftime/strptime __name__ (table)"
  notes:
    - "This spec extends the time chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: __qualname__ attributes for time module functions and the struct_time class."
    - "For C builtin functions (time, sleep, monotonic, perf_counter, process_time) and the struct_time type, __qualname__ equals __name__ — both are simply the unqualified name."
    - "time.time.__qualname__ == 'time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.sleep.__qualname__ == 'sleep' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.monotonic.__qualname__ == 'monotonic' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.perf_counter.__qualname__ == 'perf_counter' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.process_time.__qualname__ == 'process_time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.gmtime.__qualname__ == 'gmtime' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.localtime.__qualname__ == 'localtime' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.mktime.__qualname__ == 'mktime' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.strftime.__qualname__ == 'strftime' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.strptime.__qualname__ == 'strptime' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "time.struct_time.__qualname__ == 'struct_time' — verified on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for time module functions and struct_time
#
# No prior spec in the time chain covers __qualname__ — all prior specs use
# __name__. This table is entirely new coverage.
# ---------------------------------------------------------------------------

table time_extra4.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [time,          time.__qualname__.__eq__,          ["time"],          true]
    - [sleep,         sleep.__qualname__.__eq__,         ["sleep"],         true]
    - [monotonic,     monotonic.__qualname__.__eq__,     ["monotonic"],     true]
    - [perf_counter,  perf_counter.__qualname__.__eq__,  ["perf_counter"],  true]
    - [process_time,  process_time.__qualname__.__eq__,  ["process_time"],  true]
    - [gmtime,        gmtime.__qualname__.__eq__,        ["gmtime"],        true]
    - [localtime,     localtime.__qualname__.__eq__,     ["localtime"],     true]
    - [mktime,        mktime.__qualname__.__eq__,        ["mktime"],        true]
    - [strftime,      strftime.__qualname__.__eq__,      ["strftime"],      true]
    - [strptime,      strptime.__qualname__.__eq__,      ["strptime"],      true]
    - [struct_time,   struct_time.__qualname__.__eq__,   ["struct_time"],   true]
