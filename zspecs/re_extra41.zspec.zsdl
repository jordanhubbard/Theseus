spec: re_extra41
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra40.zspec.zsdl — covers re.__name__/__package__/__file__ type lengths; re.subn behavioral; compiled Pattern.findall/search behavioral results; re.sub with backreference."
    - "re_extra39.zspec.zsdl — covers compile(IGNORECASE|MULTILINE).flags==42; error.__static_attributes__; match three-group .groups().__len__()==3."
    - "re_extra38.zspec.zsdl — covers compile(IGNORECASE).flags==34/compile(MULTILINE).flags==40/compile(DOTALL).flags==48; split with capturing group; findall two groups; search lastgroup; escape dot+star."
    - "re_extra37.zspec.zsdl — covers Pattern/Match member_descriptor attribute __qualname__.__len__() for pattern/flags/groups/groupindex and string/re/pos/endpos/lastindex/lastgroup."
    - "re_extra34.zspec.zsdl — covers module-level function __qualname__.__len__() for compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge."
    - "re_extra33.zspec.zsdl — covers re.__all__.__len__()==31; IGNORECASE.__class__.__name__.__len__()==9; int(IGNORECASE)==2, int(MULTILINE)==8, int(DOTALL)==16."
    - "re_extra27.zspec.zsdl — covers IGNORECASE.__class__.__qualname__.__eq__('RegexFlag'); MULTILINE.__class__.__qualname__.__eq__('RegexFlag'); IGNORECASE.__class__.__module__.__eq__('re'); RegexFlag.__module__.__eq__('re')."
    - "re_extra14.zspec.zsdl — covers RegexFlag.__module__.__eq__('re') standalone."
    - "re_extra.zspec.zsdl — covers IGNORECASE==2, MULTILINE==8, DOTALL==16, VERBOSE==64, ASCII==256 via __eq__."
    - "re_extra10.zspec.zsdl — covers RegexFlag.LOCALE.value==4; RegexFlag.UNICODE.value==32; LOCALE.__class__.__name__.__eq__('RegexFlag')."
  notes:
    - "This spec extends re_extra40.zspec.zsdl."
    - "Prior specs collectively covered: all Pattern/Match/__name__/__module__/__qualname__ and their lengths; all public function __name__/__module__/__qualname__/__qualname__.__len__(); error/__name__/__module__/__qualname__/__bases__; RegexFlag attributes; IGNORECASE/MULTILINE/DOTALL/VERBOSE values via __eq__ (re_extra); int(IGNORECASE)/int(MULTILINE)/int(DOTALL) via re_extra33; IGNORECASE/MULTILINE __class__.__qualname__/__module__ via re_extra27; LOCALE/__class__.__name__ via re_extra10; Pattern/Match method __qualname__.__len__(); compiled .flags with single/paired flags; subn/findall/search/sub behavioral tests."
    - "This spec covers: re.VERBOSE.__class__.__name__.__eq__('RegexFlag') (NOVEL — re_extra33 checks IGNORECASE.__class__.__name__.__len__()==9 but NOT equality; re_extra2/8/21 check IGNORECASE.__class__.__name__.__eq__('RegexFlag') but NOT VERBOSE; no prior re spec checks VERBOSE.__class__.__name__ via equality); re.DOTALL.__class__.__qualname__.__eq__('RegexFlag') (NOVEL — re_extra27 checks IGNORECASE/MULTILINE.__class__.__qualname__.__eq__ but NOT DOTALL or VERBOSE; no prior re spec checks DOTALL.__class__.__qualname__); re.VERBOSE.__class__.__qualname__.__eq__('RegexFlag') (NOVEL — same gap as DOTALL; VERBOSE never had __class__.__qualname__ checked); re.DOTALL.__class__.__module__.__eq__('re') (NOVEL — re_extra27 covers IGNORECASE.__class__.__module__ but NOT DOTALL or VERBOSE; DOTALL.__class__.__module__ is 're'; no prior spec checks this); re.VERBOSE.__class__.__module__.__eq__('re') (NOVEL); re.VERBOSE._value_ == 64 (NOVEL — no prior re spec uses the ._value_ attribute access; re_extra covers VERBOSE via __eq__(64) and re_extra7 covers RegexFlag.VERBOSE.value but no spec checks VERBOSE._value_ directly); re.MULTILINE._value_ == 8 (NOVEL — same gap for _value_ attribute)."
    - "re.VERBOSE.__class__.__name__ == 'RegexFlag'. re_extra33 checks IGNORECASE.__class__.__name__.__len__()==9 (length); re_extra2/8/21 check IGNORECASE.__class__.__name__.__eq__('RegexFlag') (equality for IGNORECASE only). No prior re spec checks VERBOSE.__class__.__name__ in any form. Novel equality check. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.DOTALL.__class__.__qualname__ == 'RegexFlag'. re_extra27 checks IGNORECASE and MULTILINE __class__.__qualname__ but NOT DOTALL. re_extra3/19/21 check DOTALL.__class__.__name__ (not qualname). __qualname__ and __name__ are equal for RegexFlag since it is module-level, but this is a different attribute. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.VERBOSE.__class__.__qualname__ == 'RegexFlag'. No prior re spec checks any flag's __class__.__qualname__ for VERBOSE. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.DOTALL.__class__.__module__ == 're'. re_extra27 covers IGNORECASE.__class__.__module__.__eq__('re') but NOT DOTALL or VERBOSE. DOTALL is a RegexFlag member; RegexFlag is defined in the re module. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.VERBOSE.__class__.__module__ == 're'. Same gap for VERBOSE. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.VERBOSE._value_ == 64. No prior re spec accesses the ._value_ attribute. re_extra covers VERBOSE via __eq__(64); re_extra7 covers RegexFlag.VERBOSE.value==64; but no spec uses VERBOSE._value_. _value_ is the underlying integer stored in the IntFlag. Novel attribute access. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.MULTILINE._value_ == 8. Same gap for ._value_ on MULTILINE. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.VERBOSE and re.DOTALL class identity via __class__.__name__ and __qualname__
#
# RegexFlag is an IntFlag (integer enum) so its instances (IGNORECASE, MULTILINE,
# DOTALL, VERBOSE, etc.) all report __class__.__name__ == 'RegexFlag' and
# __class__.__qualname__ == 'RegexFlag' (since RegexFlag is a module-level class).
#
# Prior coverage gaps:
#   __class__.__name__.__eq__: IGNORECASE (extra2/8/21), DOTALL (extra3/19/21),
#                              MULTILINE (extra21), LOCALE (extra10)
#                              — VERBOSE has NEVER had __class__.__name__.__eq__ checked
#   __class__.__qualname__.__eq__: IGNORECASE (extra27), MULTILINE (extra27)
#                              — DOTALL and VERBOSE have NEVER had __qualname__ checked
#
# This table covers VERBOSE.__class__.__name__ and both DOTALL/VERBOSE qualnames:
#   VERBOSE.__class__.__name__    == 'RegexFlag'  (novel equality)
#   DOTALL.__class__.__qualname__ == 'RegexFlag'  (novel)
#   VERBOSE.__class__.__qualname__ == 'RegexFlag' (novel)
#
# All three novel. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra41.flag_class_identity:
  description: "re flag __class__.__name__ and __qualname__ identity — VERBOSE.__class__.__name__(novel), DOTALL/__qualname__(novel), VERBOSE/__qualname__(novel); prior specs cover IGNORECASE/MULTILINE these attributes but not DOTALL or VERBOSE in these forms"
  kind: python_call_eq
  category: flag_identity
  id_prefix: rfci41

  columns: [id, function, args, expected]
  rows:
    - [verbose_class_name,     VERBOSE.__class__.__name__.__eq__,     ["RegexFlag"], true]
    - [dotall_class_qualname,  DOTALL.__class__.__qualname__.__eq__,  ["RegexFlag"], true]
    - [verbose_class_qualname, VERBOSE.__class__.__qualname__.__eq__, ["RegexFlag"], true]

# ---------------------------------------------------------------------------
# re.DOTALL and re.VERBOSE class __module__
#
# All RegexFlag members have __class__.__module__ == 're' because RegexFlag
# is defined in the re module.
#
# Prior coverage: re_extra27 checks IGNORECASE.__class__.__module__.__eq__('re')
# but no prior re spec checks DOTALL or VERBOSE __class__.__module__.
#
#   DOTALL.__class__.__module__  == 're'  (novel)
#   VERBOSE.__class__.__module__ == 're'  (novel)
#
# Both novel. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra41.DOTALL_class_module:
  description: "re.DOTALL.__class__.__module__ == 're' — DOTALL is a RegexFlag member; RegexFlag is defined in re; re_extra27 covers IGNORECASE.__class__.__module__ but not DOTALL; novel"
  category: flag_identity
  kind: python_call_eq
  function: DOTALL.__class__.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra41.VERBOSE_class_module:
  description: "re.VERBOSE.__class__.__module__ == 're' — VERBOSE is a RegexFlag member; RegexFlag defined in re; no prior re spec checks VERBOSE.__class__.__module__; novel"
  category: flag_identity
  kind: python_call_eq
  function: VERBOSE.__class__.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.VERBOSE._value_ and re.MULTILINE._value_
#
# IntFlag members store their underlying integer in the ._value_ attribute.
# Prior re specs access flag integer values via:
#   __eq__()             — re_extra (IGNORECASE/MULTILINE/DOTALL/VERBOSE via __eq__)
#   RegexFlag.X.value    — re_extra7 (all flags via .value attribute on class member)
#   int(flag)            — re_extra33 (IGNORECASE/MULTILINE/DOTALL via int())
#
# No prior re spec accesses the ._value_ attribute directly on a flag instance.
# This is a different attribute path: VERBOSE._value_ vs VERBOSE.__eq__(64)
# vs RegexFlag.VERBOSE.value.
#
#   VERBOSE._value_  == 64  (novel ._value_ access)
#   MULTILINE._value_ == 8  (novel ._value_ access)
#
# Both novel. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra41.VERBOSE_value_attr:
  description: "re.VERBOSE._value_ == 64 — ._value_ is the underlying IntFlag integer; no prior re spec accesses ._value_ attribute; re_extra covers VERBOSE via __eq__(64); re_extra7 covers RegexFlag.VERBOSE.value; both differ from ._value_ on the flag instance itself; novel"
  category: flag_identity
  kind: python_call_eq
  function: VERBOSE._value_.__eq__
  args: [64]
  expected: true

invariant re_extra41.MULTILINE_value_attr:
  description: "re.MULTILINE._value_ == 8 — same ._value_ attribute access for MULTILINE; no prior re spec uses ._value_ directly on any flag instance; novel"
  category: flag_identity
  kind: python_call_eq
  function: MULTILINE._value_.__eq__
  args: [8]
  expected: true
