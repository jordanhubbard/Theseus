spec: struct_extra112
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra111.zspec.zsdl — covers struct.__spec__ and __loader__ class module/qualname identity and lengths (table + invariants)."
    - "struct_extra110.zspec.zsdl — covers iter_unpack/unpack_from __name__/__module__ equality / module function type identity / Struct instance method __name__ equality / error __qualname__/__module__ equality (table + invariants)."
    - "struct_extra109.zspec.zsdl — covers Struct method_descriptor __objclass__.__name__ equality / module-level function __name__ equality / Struct class __module__/__qualname__ equality (table + invariants)."
    - "struct_extra106.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack qualname equality / Struct.__init__ qualname and wrapper_descriptor type / all five methods are method_descriptor (table + invariants)."
    - "struct_extra104.zspec.zsdl — covers Struct.size/format getset_descriptor qualnames and __objclass__ / module-level function qualname equality (table + invariants)."
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths / Struct class-level method_descriptor type names (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra111; it does NOT duplicate invariants present in those files."
    - "Wave 276 theme: Struct class dunder method qualnames not yet covered — struct_extra106 anchors Struct.__init__.__qualname__=='Struct.__init__'; not yet covered: Struct.__new__.__qualname__, Struct.__repr__.__qualname__, Struct.__sizeof__.__qualname__, Struct.__reduce_ex__.__qualname__, Struct.__reduce__.__qualname__, plus their qualname lengths and type names."
    - "struct.Struct.__new__.__qualname__ == 'Struct.__new__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__qualname__ == 'Struct.__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__reduce_ex__.__qualname__ == 'object.__reduce_ex__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__reduce__.__qualname__ == 'object.__reduce__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('Struct.__new__') == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('Struct.__repr__') == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('Struct.__sizeof__') == 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('object.__reduce_ex__') == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('object.__reduce__') == 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.__new__).__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.__repr__).__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.__sizeof__).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.__reduce_ex__).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.__reduce__).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__new__ is a builtin_function_or_method (C-level __new__); Struct.__repr__ is a wrapper_descriptor (C-level slot implementation); Struct.__sizeof__ and Struct.__reduce_ex__ and Struct.__reduce__ are method_descriptor. __reduce_ex__ and __reduce__ have 'object.' qualname prefix (inherited from object; not overridden by Struct). struct_extra106 anchors Struct.__init__.__qualname__; this spec anchors __new__/__repr__/__sizeof__/__reduce_ex__/__reduce__ qualnames."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__new__.__qualname__.__eq__('Struct.__new__')
# struct.Struct.__repr__.__qualname__.__eq__('Struct.__repr__')
# struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__')
# struct.Struct.__reduce_ex__.__qualname__.__eq__('object.__reduce_ex__')
# struct.Struct.__reduce__.__qualname__.__eq__('object.__reduce__')
#
# Wave 276 theme: Struct class dunder method qualname equality.
#
# struct_extra106 anchors Struct.__init__.__qualname__=='Struct.__init__'. This
# spec anchors the remaining dunder method qualnames. __new__, __repr__, and
# __sizeof__ have 'Struct.' prefix (defined on Struct). __reduce_ex__ and
# __reduce__ have 'object.' prefix (inherited from object; not overridden).
# No prior struct spec anchors these five qualnames as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra112.Struct_dunder_qualname_equality:
  description: "Struct.__new__.__qualname__.__eq__('Struct.__new__')==True / Struct.__repr__.__qualname__.__eq__('Struct.__repr__')==True / Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__')==True / Struct.__reduce_ex__.__qualname__.__eq__('object.__reduce_ex__')==True / Struct.__reduce__.__qualname__.__eq__('object.__reduce__')==True — __new__/__repr__/__sizeof__ are Struct-defined (qualname has 'Struct.' prefix); __reduce_ex__/__reduce__ are inherited from object (qualname has 'object.' prefix); extra106 anchors Struct.__init__ qualname; first structdunder112 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: structdunder112

  columns: [id, function, args, expected, description]
  rows:
    - [new_qualname_eq,       "Struct.__new__.__qualname__.__eq__",       ["Struct.__new__"],       true, "struct.Struct.__new__.__qualname__ is 'Struct.__new__' (Struct-defined __new__; allocates new Struct instance)"]
    - [repr_qualname_eq,      "Struct.__repr__.__qualname__.__eq__",      ["Struct.__repr__"],      true, "struct.Struct.__repr__.__qualname__ is 'Struct.__repr__' (Struct-defined repr showing format string)"]
    - [sizeof_qualname_eq,    "Struct.__sizeof__.__qualname__.__eq__",    ["Struct.__sizeof__"],    true, "struct.Struct.__sizeof__.__qualname__ is 'Struct.__sizeof__' (Struct-defined; returns internal size in bytes)"]
    - [reduce_ex_qualname_eq, "Struct.__reduce_ex__.__qualname__.__eq__", ["object.__reduce_ex__"], true, "struct.Struct.__reduce_ex__.__qualname__ is 'object.__reduce_ex__' (inherited from object; not overridden by Struct)"]
    - [reduce_qualname_eq,    "Struct.__reduce__.__qualname__.__eq__",    ["object.__reduce__"],    true, "struct.Struct.__reduce__.__qualname__ is 'object.__reduce__' (inherited from object; pickle support from base class)"]

# ---------------------------------------------------------------------------
# struct.Struct.__new__.__qualname__.__len__() == 14
# struct.Struct.__repr__.__qualname__.__len__() == 15
# struct.Struct.__sizeof__.__qualname__.__len__() == 17
# struct.Struct.__reduce_ex__.__qualname__.__len__() == 20
# struct.Struct.__reduce__.__qualname__.__len__() == 17
#
# Wave 276 theme: Struct dunder method qualname lengths.
#
# 'Struct.__new__' is 14 chars; 'Struct.__repr__' is 15; 'Struct.__sizeof__' is 17;
# 'object.__reduce_ex__' is 20; 'object.__reduce__' is 17. The two inherited methods
# (__reduce_ex__ and __reduce__) differ in that __reduce_ex__ (20 chars) is 3 chars
# longer than __reduce__ (17 chars) due to the '_ex' suffix. No prior struct spec
# anchors these qualname lengths as a grouped table. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table struct_extra112.Struct_dunder_qualname_lengths:
  description: "Struct.__new__.__qualname__.__len__()==14 / Struct.__repr__.__qualname__.__len__()==15 / Struct.__sizeof__.__qualname__.__len__()==17 / Struct.__reduce_ex__.__qualname__.__len__()==20 / Struct.__reduce__.__qualname__.__len__()==17 — 'Struct.__new__'=14, 'Struct.__repr__'=15, 'Struct.__sizeof__'=17, 'object.__reduce_ex__'=20 (longest), 'object.__reduce__'=17; __reduce__ and __sizeof__ share length 17; __reduce_ex__ is 3 chars longer than __reduce__ ('_ex'=3); no prior struct spec anchors these lengths; first structdunder112 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: structdunder112

  columns: [id, function, args, expected, description]
  rows:
    - [new_qualname_len,       "Struct.__new__.__qualname__.__len__",       [], 14, "struct.Struct.__new__.__qualname__.__len__() is 14 (len('Struct.__new__')==14)"]
    - [repr_qualname_len,      "Struct.__repr__.__qualname__.__len__",      [], 15, "struct.Struct.__repr__.__qualname__.__len__() is 15 (len('Struct.__repr__')==15)"]
    - [sizeof_qualname_len,    "Struct.__sizeof__.__qualname__.__len__",    [], 17, "struct.Struct.__sizeof__.__qualname__.__len__() is 17 (len('Struct.__sizeof__')==17; same length as __reduce__)"]
    - [reduce_ex_qualname_len, "Struct.__reduce_ex__.__qualname__.__len__", [], 20, "struct.Struct.__reduce_ex__.__qualname__.__len__() is 20 (len('object.__reduce_ex__')==20; longest dunder qualname here)"]
    - [reduce_qualname_len,    "Struct.__reduce__.__qualname__.__len__",    [], 17, "struct.Struct.__reduce__.__qualname__.__len__() is 17 (len('object.__reduce__')==17; same length as __sizeof__)"]

# ---------------------------------------------------------------------------
# type(struct.Struct.__new__).__name__.__eq__('builtin_function_or_method')
# type(struct.Struct.__repr__).__name__.__eq__('wrapper_descriptor')
# type(struct.Struct.__sizeof__).__name__.__eq__('method_descriptor')
# type(struct.Struct.__reduce_ex__).__name__.__eq__('method_descriptor')
# type(struct.Struct.__reduce__).__name__.__eq__('method_descriptor')
#
# Wave 276 theme: Struct dunder method type identity.
#
# Struct.__new__ is a builtin_function_or_method (C-level __new__ allocator).
# Struct.__repr__ is a wrapper_descriptor (wraps a C slot tp_repr implementation).
# Struct.__sizeof__, __reduce_ex__, and __reduce__ are method_descriptor (C-level
# methods callable on instances). No prior struct spec anchors the type identities
# for these five dunder methods as a grouped table. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table struct_extra112.Struct_dunder_type_identity:
  description: "Struct.__new__.__class__.__name__.__eq__('builtin_function_or_method')==True / Struct.__repr__.__class__.__name__.__eq__('wrapper_descriptor')==True / Struct.__sizeof__.__class__.__name__.__eq__('method_descriptor')==True / Struct.__reduce_ex__.__class__.__name__.__eq__('method_descriptor')==True / Struct.__reduce__.__class__.__name__.__eq__('method_descriptor')==True — __new__ is builtin_function_or_method (C allocator); __repr__ is wrapper_descriptor (wraps C slot); __sizeof__/__reduce_ex__/__reduce__ are method_descriptor (C methods); no prior spec anchors these type identities; first structdunder112 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdunder112

  columns: [id, function, args, expected, description]
  rows:
    - [new_type_eq,        "Struct.__new__.__class__.__name__.__eq__",       ["builtin_function_or_method"], true, "struct.Struct.__new__.__class__.__name__ is 'builtin_function_or_method' (C-level __new__ allocator)"]
    - [repr_type_eq,       "Struct.__repr__.__class__.__name__.__eq__",      ["wrapper_descriptor"],         true, "struct.Struct.__repr__.__class__.__name__ is 'wrapper_descriptor' (wraps C slot tp_repr; different from method_descriptor)"]
    - [sizeof_type_eq,     "Struct.__sizeof__.__class__.__name__.__eq__",    ["method_descriptor"],          true, "struct.Struct.__sizeof__.__class__.__name__ is 'method_descriptor' (C-level method returning internal size)"]
    - [reduce_ex_type_eq,  "Struct.__reduce_ex__.__class__.__name__.__eq__", ["method_descriptor"],          true, "struct.Struct.__reduce_ex__.__class__.__name__ is 'method_descriptor' (inherited from object; pickle protocol method)"]
    - [reduce_type_eq,     "Struct.__reduce__.__class__.__name__.__eq__",    ["method_descriptor"],          true, "struct.Struct.__reduce__.__class__.__name__ is 'method_descriptor' (inherited from object; basic pickle support)"]

# ---------------------------------------------------------------------------
# struct.Struct.__new__.__qualname__.__eq__('Struct.__new__') — standalone
#
# struct.Struct.__new__.__qualname__ is 'Struct.__new__'. Struct defines its
# own __new__ to control instance allocation (it uses C-level tp_new). The
# qualname 'Struct.__new__' (14 chars) has the 'Struct.' prefix, confirming
# it is overridden in Struct rather than inherited from object. By contrast,
# __reduce_ex__ and __reduce__ inherit from object (qualname 'object.*').
# struct_extra106 anchors Struct.__init__.__qualname__=='Struct.__init__'; no
# prior struct spec anchors Struct.__new__.__qualname__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra112.Struct_new_qualname_eq:
  description: "struct.Struct.__new__.__qualname__.__eq__('Struct.__new__') == True — qualname is 'Struct.__new__' (14 chars; Struct-defined C allocator; not inherited from object); contrasts with __reduce_ex__.__qualname__=='object.__reduce_ex__' (inherited); extra106 anchors Struct.__init__ qualname; no prior spec anchors Struct.__new__ qualname as standalone; first standalone under structdunder112"
  category: function_identity
  kind: python_call_eq
  function: Struct.__new__.__qualname__.__eq__
  args: ["Struct.__new__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__repr__.__qualname__.__len__() == 15 — standalone
#
# struct.Struct.__repr__.__qualname__.__len__() is 15. 'Struct.__repr__' has
# 15 chars: 'Struct.' (7) + '__repr__' (8) = 15. Struct.__repr__ is a
# wrapper_descriptor (it wraps the C slot tp_repr). The qualname length 15 is
# 1 more than Struct.__new__ (14) and 2 less than Struct.__sizeof__ (17).
# No prior struct spec anchors Struct.__repr__.__qualname__.__len__() as a
# standalone under structdunder112. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra112.Struct_repr_qualname_len_15:
  description: "struct.Struct.__repr__.__qualname__.__len__() == 15 — len('Struct.__repr__')==15 ('Struct.'=7+'__repr__'=8=15); one more than __new__ qualname (14); wrapper_descriptor type (wraps C slot tp_repr); no prior spec anchors Struct.__repr__ qualname length as standalone; first standalone under structdunder112"
  category: function_identity
  kind: python_call_eq
  function: Struct.__repr__.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') — standalone
#
# struct.Struct.__sizeof__.__qualname__ is 'Struct.__sizeof__'. __sizeof__ is a
# method that returns the internal memory footprint (in bytes) of the Struct
# instance, not including any referenced objects. It is used by sys.getsizeof().
# Struct defines its own __sizeof__ (qualname has 'Struct.' prefix). It is a
# method_descriptor. No prior struct spec anchors Struct.__sizeof__.__qualname__
# as a standalone under structdunder112. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra112.Struct_sizeof_qualname_eq:
  description: "struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__') == True — qualname is 'Struct.__sizeof__' (17 chars; Struct-defined; returns internal byte size; used by sys.getsizeof()); method_descriptor type; no prior spec anchors Struct.__sizeof__ qualname as standalone; first standalone under structdunder112"
  category: function_identity
  kind: python_call_eq
  function: Struct.__sizeof__.__qualname__.__eq__
  args: ["Struct.__sizeof__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') — standalone
#
# struct.Struct.__reduce_ex__.__class__.__name__ is 'method_descriptor'. __reduce_ex__
# is a pickle protocol method defined on object and inherited by all classes.
# On Struct, it is not overridden, so its qualname is 'object.__reduce_ex__' (20 chars).
# It is a method_descriptor — the same type as Struct.__sizeof__. This contrasts
# with Struct.__repr__ which is a wrapper_descriptor (different C dispatch mechanism).
# No prior struct spec anchors Struct.__reduce_ex__ class name as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra112.Struct_reduce_ex_type_method_descriptor:
  description: "struct.Struct.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — __reduce_ex__ is method_descriptor (inherited from object; not overridden by Struct); qualname is 'object.__reduce_ex__' (20 chars; longest dunder qualname here); contrasts with __repr__ which is wrapper_descriptor; no prior spec anchors this type as standalone; first standalone under structdunder112"
  category: type_identity
  kind: python_call_eq
  function: Struct.__reduce_ex__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__new__.__qualname__.__len__() == 14 — standalone
#
# struct.Struct.__new__.__qualname__.__len__() is 14. 'Struct.__new__' has
# 14 chars: 'Struct.' (7) + '__new__' (7) = 14. This is the shortest of the
# five qualnames in this spec. Struct.__new__ is a builtin_function_or_method
# (unlike the other four which are wrapper_descriptor or method_descriptor).
# No prior struct spec anchors Struct.__new__.__qualname__.__len__() as a
# standalone under structdunder112. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra112.Struct_new_qualname_len_14:
  description: "struct.Struct.__new__.__qualname__.__len__() == 14 — len('Struct.__new__')==14 ('Struct.'=7+'__new__'=7=14); shortest of the five dunder qualnames here; builtin_function_or_method type (C allocator); contrasts with __repr__=15, __sizeof__=17, __reduce__=17, __reduce_ex__=20; no prior spec anchors this length as standalone; first standalone under structdunder112"
  category: function_identity
  kind: python_call_eq
  function: Struct.__new__.__qualname__.__len__
  args: []
  expected: 14
