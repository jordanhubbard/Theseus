spec: abc_extra97
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra96

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra96.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc module __name__, __package__, __spec__ and __loader__ attrs. NEW in extra97: abc.__name__=='abc' (len=3); abc.__package__=='' (empty string — abc is not a package; __package__ is '' for single modules); abc.__spec__.__class__.__name__=='ModuleSpec'; abc.__spec__.name=='abc'; abc.__spec__.has_location==False (abc is a frozen module; origin='frozen'); abc.__loader__.__class__.__name__=='type' (abc is loaded by FrozenImporter, whose class is type); abc.__loader__.__name__=='FrozenImporter'; abc.__file__.__class__.__name__=='str' (abc.__file__ is a str path despite being a frozen module — points to the source .py file); abc.ABCMeta.__module__.__len__()==3 (module 'abc'); abc.abstractmethod.__module__.__len__()==3 (module 'abc'); abc.get_cache_token.__module__.__len__()==4 (module '_abc', C extension); abc.abstractmethod.__name__.__len__()==14; abc.get_cache_token.__name__.__len__()==15. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__package__ == '' (empty string). abc is a single-file module (not a package); for single-file modules, __package__ is '' (empty string), not None. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__spec__.has_location == False. abc is a frozen module (origin='frozen'); frozen modules have has_location=False even though abc.__file__ still points to the source .py file. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__loader__.__class__.__name__ == 'type'. abc is loaded by FrozenImporter; FrozenImporter is a class (not an instance), so its __class__.__name__ is 'type'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__module__ == '_abc'. get_cache_token is a C builtin from Modules/_abc.c (the C extension module '_abc', with underscore prefix), unlike abc.ABCMeta and abc.abstractmethod which have module='abc'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module identity — extra97
#
# Wave 254 theme: abc module __name__, __package__, __spec__ and __loader__ attrs.
#
# abc.__name__                          == 'abc'              (len=3)
# abc.__package__                       == ''                 (empty, not a package)
# abc.__spec__.__class__.__name__       == 'ModuleSpec'
# abc.__spec__.name                     == 'abc'
# abc.__spec__.has_location             == False              (frozen module)
# abc.__loader__.__class__.__name__     == 'type'             (FrozenImporter is a class)
# abc.__loader__.__name__               == 'FrozenImporter'
# abc.__file__.__class__.__name__       == 'str'
# ---------------------------------------------------------------------------

table abc_extra97.abc_module_identity:
  description: "abc module __name__, __package__, __spec__, and __loader__ identity checks in abcmodident97 namespace — wave 254 theme: abc is a frozen module (not a regular file-based module and not a package); abc.__name__.__eq__('abc')==True (len=3: the shortest module name in this spec series); abc.__name__.__len__()==3; abc.__package__.__eq__('')==True (empty string — for single-file modules __package__=='' not None); abc.__package__.__len__()==0 (the package name length is zero for non-package modules); abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (spec is a ModuleSpec instance even for frozen modules); abc.__spec__.name.__eq__('abc')==True; abc.__spec__.has_location.__eq__(False)==True (frozen module — origin='frozen'; abc has no filesystem location despite having __file__); abc.__loader__.__class__.__name__.__eq__('type')==True (FrozenImporter is a class, not an instance; its __class__ is 'type'); abc.__file__.__class__.__name__.__eq__('str')==True (points to source abc.py even though module is frozen); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: abcmodident97

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       abc.__name__.__eq__,                          ["abc"],          true,  "abc.__name__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [name_len,      abc.__name__.__len__,                         [],               3,     "abc.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [pkg_eq,        abc.__package__.__eq__,                       [""],             true,  "abc.__package__ == '' (empty string — abc is a single-file module, not a package); verified with Python 3.14.3"]
    - [pkg_len,       abc.__package__.__len__,                      [],               0,     "abc.__package__.__len__() == 0 (empty string, zero length); verified with Python 3.14.3"]
    - [spec_cls,      abc.__spec__.__class__.__name__.__eq__,       ["ModuleSpec"],   true,  "abc.__spec__.__class__.__name__ == 'ModuleSpec'; verified with Python 3.14.3"]
    - [spec_name,     abc.__spec__.name.__eq__,                     ["abc"],          true,  "abc.__spec__.name == 'abc'; verified with Python 3.14.3"]
    - [has_loc,       abc.__spec__.has_location.__eq__,             [false],          true,  "abc.__spec__.has_location == False (frozen module, origin='frozen'); verified with Python 3.14.3"]
    - [loader_cls,    abc.__loader__.__class__.__name__.__eq__,     ["type"],         true,  "abc.__loader__.__class__.__name__ == 'type' (FrozenImporter is a class, metaclass is type); verified with Python 3.14.3"]
    - [loader_name,   abc.__loader__.__name__.__eq__,               ["FrozenImporter"], true, "abc.__loader__.__name__ == 'FrozenImporter'; verified with Python 3.14.3"]
    - [file_cls,      abc.__file__.__class__.__name__.__eq__,       ["str"],          true,  "abc.__file__.__class__.__name__ == 'str' (str path to source abc.py despite frozen origin); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module-level name lengths — extra97
#
# abc.ABCMeta.__module__       == 'abc'   (len=3)
# abc.abstractmethod.__module__ == 'abc'   (len=3)
# abc.get_cache_token.__module__ == '_abc' (len=4, C extension)
# abc.abstractmethod.__name__   == 'abstractmethod'  (len=14)
# abc.get_cache_token.__name__  == 'get_cache_token'  (len=15)
# abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'
# abc.abstractmethod.__class__.__name__ == 'function'
# abc.ABC.__mro__.__len__()     == 2
# ---------------------------------------------------------------------------

table abc_extra97.abc_member_modules:
  description: "abc module-level member __module__ and __name__ checks in abcmodident97 namespace — wave 254 theme: abc module members have two distinct __module__ values: 'abc' for pure-Python members and '_abc' for C-extension members; abc.ABCMeta.__module__.__eq__('abc')==True (len=3: ABCMeta is defined in Lib/abc.py); abc.ABCMeta.__module__.__len__()==3; abc.abstractmethod.__module__.__eq__('abc')==True (len=3: abstractmethod is a Python class in Lib/abc.py); abc.get_cache_token.__module__.__eq__('_abc')==True (len=4: get_cache_token is a C builtin from Modules/_abc.c; the C extension module '_abc' has underscore prefix like asyncio's '_asyncio'); abc.get_cache_token.__module__.__len__()==4; abc.abstractmethod.__name__.__eq__('abstractmethod')==True (len=14); abc.abstractmethod.__name__.__len__()==14; abc.get_cache_token.__name__.__eq__('get_cache_token')==True (len=15: 'get_cache_token' is 15 chars); abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method')==True (C builtin); abc.abstractmethod.__class__.__name__.__eq__('function')==True (Python class descriptor implemented as a function); abc.ABC.__mro__.__len__()==2 ([ABC, object]); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: abcmodident97a

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_mod_eq,   abc.ABCMeta.__module__.__eq__,                       ["abc"],  true, "abc.ABCMeta.__module__ == 'abc' (len=3, defined in Lib/abc.py); verified with Python 3.14.3"]
    - [abcmeta_mod_len,  abc.ABCMeta.__module__.__len__,                      [],       3,    "abc.ABCMeta.__module__.__len__() == 3; verified with Python 3.14.3"]
    - [absmeth_mod_eq,   abc.abstractmethod.__module__.__eq__,                ["abc"],  true, "abc.abstractmethod.__module__ == 'abc' (len=3, Python class in Lib/abc.py); verified with Python 3.14.3"]
    - [absmeth_name_eq,  abc.abstractmethod.__name__.__eq__,                  ["abstractmethod"], true, "abc.abstractmethod.__name__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [absmeth_name_len, abc.abstractmethod.__name__.__len__,                 [],       14,   "abc.abstractmethod.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [absmeth_cls,      abc.abstractmethod.__class__.__name__.__eq__,        ["function"], true, "abc.abstractmethod.__class__.__name__ == 'function' — Python function decorator; verified with Python 3.14.3"]
    - [gct_mod_eq,       abc.get_cache_token.__module__.__eq__,               ["_abc"], true, "abc.get_cache_token.__module__ == '_abc' (len=4, C extension from Modules/_abc.c); verified with Python 3.14.3"]
    - [gct_mod_len,      abc.get_cache_token.__module__.__len__,              [],       4,    "abc.get_cache_token.__module__.__len__() == 4 ('_abc' C extension module); verified with Python 3.14.3"]
    - [gct_name_eq,      abc.get_cache_token.__name__.__eq__,                 ["get_cache_token"], true, "abc.get_cache_token.__name__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]
    - [gct_name_len,     abc.get_cache_token.__name__.__len__,                [],       15,   "abc.get_cache_token.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [gct_cls,          abc.get_cache_token.__class__.__name__.__eq__,       ["builtin_function_or_method"], true, "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — C builtin; verified with Python 3.14.3"]
    - [abc_mro_len,      abc.ABC.__mro__.__len__,                             [],       2,    "abc.ABC.__mro__.__len__() == 2 — [ABC, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra97
# ---------------------------------------------------------------------------

invariant abc_extra97.abc_package_is_empty_string:
  description: "abc.__package__.__eq__('') returns True — abc.__package__ is '' (empty string); for single-file modules (modules that are not packages), __package__ is '' (empty string, length=0), not None; this contrasts with package modules like asyncio, multiprocessing, and concurrent.futures where __package__ equals __name__; abc is a single-file module (not a directory package) loaded as a frozen module (origin='frozen'); abc.__package__.__len__()==0; abc.__spec__.submodule_search_locations is None (no submodule search paths for single-file modules); this pattern of empty __package__ contrasts with abc.ABCMeta.__module__=='abc' (len=3) and abc.get_cache_token.__module__=='_abc' (len=4); NEW in extra97: first standalone abc.__package__ empty string invariant in abcmodident97 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: abc.__package__.__eq__
  args: [""]
  expected: true

invariant abc_extra97.abc_spec_has_location_false:
  description: "abc.__spec__.has_location.__eq__(False) returns True — abc is a frozen module (abc.__spec__.origin=='frozen'); frozen modules have has_location=False because they are embedded in the CPython interpreter binary rather than loaded from the filesystem at import time; this contrasts with regular packages like asyncio, multiprocessing, and concurrent.futures which all have has_location=True; despite has_location=False, abc.__file__ still returns a str path pointing to the source abc.py file on disk (for debugging purposes); abc.__loader__.__name__ is 'FrozenImporter' (the loader class for frozen modules); abc.__loader__.__class__.__name__ is 'type' (FrozenImporter is a class, not an instance); NEW in extra97: first standalone abc.__spec__.has_location invariant in abcmodident97 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: abc.__spec__.has_location.__eq__
  args: [false]
  expected: true

invariant abc_extra97.abc_loader_name_is_FrozenImporter:
  description: "abc.__loader__.__name__.__eq__('FrozenImporter') returns True — abc.__loader__ is the FrozenImporter class (not an instance); abc is loaded by FrozenImporter because abc is a frozen module (embedded in the CPython binary); abc.__loader__.__class__.__name__ is 'type' (FrozenImporter is a type/class); abc.__loader__.__name__ is 'FrozenImporter' (the class name); this is categorically different from file-based modules which use SourceFileLoader (whose __class__.__name__ is 'SourceFileLoader'); the frozen module system allows abc to be imported before the filesystem is fully available during interpreter startup; abc.__spec__.origin is 'frozen'; abc.__spec__.has_location is False; NEW in extra97: first standalone abc.__loader__.__name__ invariant in abcmodident97 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: abc.__loader__.__name__.__eq__
  args: ["FrozenImporter"]
  expected: true

invariant abc_extra97.abc_get_cache_token_module_is_underscore_abc:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — abc.get_cache_token is a C-level builtin_function_or_method from CPython's Modules/_abc.c; the C extension module is named '_abc' (with underscore prefix, same naming pattern as '_asyncio' for asyncio.Task and asyncio.Future); this contrasts with abc.ABCMeta.__module__=='abc' and abc.abstractmethod.__module__=='abc' (both pure Python); abc.get_cache_token.__module__.__len__()==4 vs abc.ABCMeta.__module__.__len__()==3 (the underscore adds one extra char); abc.get_cache_token returns the current ABC cache token (an opaque object that changes each time a new virtual subclass is registered); abc.get_cache_token.__class__.__name__ is 'builtin_function_or_method'; abc.get_cache_token.__name__.__len__() is 15; NEW in extra97: first standalone abc.get_cache_token module invariant in abcmodident97 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra97.abc_abstractmethod_name_len_is_14:
  description: "abc.abstractmethod.__name__.__len__() == 14 — abc.abstractmethod.__name__ is 'abstractmethod' (14 characters); abc.abstractmethod is a Python function (decorator) that marks methods as abstract; abstractmethod.__class__.__name__ is 'function' (pure Python, unlike abc.get_cache_token which is 'builtin_function_or_method'); abstractmethod.__module__ is 'abc' (len=3); compare: abc.get_cache_token.__name__.__len__()==15 (one longer than abstractmethod); abc.abstractmethod.__qualname__ is 'abstractmethod' (len=14, module-level function so qualname equals name); abc.abstractmethod.__qualname__.__len__()==14; abc.ABCMeta.__module__.__len__()==3 (same 'abc' module as abstractmethod); NEW in extra97: first standalone abc.abstractmethod name length invariant in abcmodident97 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: abc.abstractmethod.__name__.__len__
  args: []
  expected: 14
