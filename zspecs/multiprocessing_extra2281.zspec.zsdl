spec: multiprocessing_extra2281
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count."
    - "Covers multiprocessing.Process, pool.Pool, queues.Queue, queues.SimpleQueue, managers.BaseManager, synchronize.Lock, synchronize.Event, synchronize.Semaphore."
    - "multiprocessing.synchronize.Lock and Semaphore inherit from SemLock (mro=3). Event, SimpleQueue, Queue, Pool, BaseManager are flat (mro=2)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2281.process_pool_mro:
  description: "multiprocessing.Process and pool.Pool MRO and base class metrics"
  kind: python_call_eq
  category: mro_depth
  id_prefix: mp2281

  columns: [id, function, args, expected]
  rows:
    - ["mp2281001", "multiprocessing.Process.__mro__.__len__", [], 3]
    - ["mp2281002", "multiprocessing.Process.__bases__.__len__", [], 1]
    - ["mp2281003", "multiprocessing.pool.Pool.__mro__.__len__", [], 2]
    - ["mp2281004", "multiprocessing.pool.Pool.__bases__.__len__", [], 1]

