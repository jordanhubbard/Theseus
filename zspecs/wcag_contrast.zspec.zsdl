spec: wcag_contrast
version: ">=3.0.0"
backend: node(wcag-contrast)

docs: https://www.npmjs.com/package/wcag-contrast

provenance:
  derived_from:
    - "wcag-contrast README — https://www.npmjs.com/package/wcag-contrast"
    - "Test vectors verified with wcag-contrast via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "wcag-contrast source"
  notes:
    - "wcag-contrast is an npm package. Install: npm install wcag-contrast"
    - "Returns the WCAG 2.0 contrast ratio between two hex colors. White-on-black is 21 (max)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number representing the contrast ratio."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table wcag_contrast.hex:
  kind: node_module_call_eq
  function: hex
  category: color
  id_prefix: wcag

  columns: [id, args, expected]
  rows:
    - [white_black,  ["#ffffff", "#000000"],  21]
    - [white_red,    ["#ffffff", "#ff0000"],  3.9984767707539985]
    - [same_color,   ["#000000", "#000000"],  1]

