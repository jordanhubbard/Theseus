spec: is_email
version: ">=1.0.2"
backend: node(is-email)

docs: https://www.npmjs.com/package/is-email

provenance:
  derived_from:
    - "is-email README — https://www.npmjs.com/package/is-email"
    - "Test vectors verified with is-email via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-email source"
  notes:
    - "is-email is an npm package. Install: npm install is-email"
    - "The module exports a single function that returns true if the string is a valid email address."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_email.isEmail:
  kind: node_module_call_eq
  function: ~
  category: validate
  id_prefix: isemail

  columns: [id, args, expected]
  rows:
    - [valid,    ["foo@bar.com"],  true]
    - [invalid,  ["not-email"],    false]
    - [no_at,    ["foobar.com"],   false]
