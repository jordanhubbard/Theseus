spec: concurrent_futures_extra469
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures wait, as_completed, and Future method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __name__ and __module__ identity for top-level wait and as_completed functions, and __name__ identity for key Future instance methods"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra469.top_level_names:
  description: "concurrent.futures top-level function __name__ identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: tlname

  columns: [id, function, args, expected]
  rows:
    - [tlname001, concurrent.futures.wait.__name__.__eq__, ["wait"], true]
    - [tlname002, concurrent.futures.as_completed.__name__.__eq__, ["as_completed"], true]

table concurrent_futures_extra469.top_level_modules:
  description: "concurrent.futures top-level function __module__ identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: tlmod

  columns: [id, function, args, expected]
  rows:
    - [tlmod001, concurrent.futures.wait.__module__.__eq__, ["concurrent.futures._base"], true]
    - [tlmod002, concurrent.futures.as_completed.__module__.__eq__, ["concurrent.futures._base"], true]

table concurrent_futures_extra469.future_method_names:
  description: "concurrent.futures.Future method __name__ identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: fmname

  columns: [id, function, args, expected]
  rows:
    - [fmname001, concurrent.futures.Future.cancel.__name__.__eq__, ["cancel"], true]
    - [fmname002, concurrent.futures.Future.result.__name__.__eq__, ["result"], true]
    - [fmname003, concurrent.futures.Future.exception.__name__.__eq__, ["exception"], true]
    - [fmname004, concurrent.futures.Future.add_done_callback.__name__.__eq__, ["add_done_callback"], true]
    - [fmname005, concurrent.futures.Future.running.__name__.__eq__, ["running"], true]
    - [fmname006, concurrent.futures.Future.done.__name__.__eq__, ["done"], true]
    - [fmname007, concurrent.futures.Future.cancelled.__name__.__eq__, ["cancelled"], true]
