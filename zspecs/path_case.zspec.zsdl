spec: path_case
version: ">=3.0.0"
backend: node(path-case)

docs: https://www.npmjs.com/package/path-case

provenance:
  derived_from:
    - "path-case README — https://www.npmjs.com/package/path-case"
    - "Test vectors verified with path-case@3.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "path-case source"
  notes:
    - "path-case exports {pathCase} named function."
    - "pathCase converts string to path/case using slash separators."
    - "Handles camelCase, PascalCase, snake_case, and space-separated inputs."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns path/cased string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table path_case.path_case:
  kind: node_module_call_eq
  function: pathCase
  category: pathCase
  id_prefix: pathcase

  columns: [id, args, expected]
  rows:
    - [camel,   ["fooBar"],     "foo/bar"]
    - [pascal,  ["FooBar"],     "foo/bar"]
    - [space,   ["foo bar"],    "foo/bar"]
    - [snake,   ["foo_bar"],    "foo/bar"]
