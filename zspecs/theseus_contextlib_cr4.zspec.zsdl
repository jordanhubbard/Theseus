spec: theseus_contextlib_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_contextlib_cr4)
blocks: contextlib

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html"
  notes:
    - "Clean-room extended contextlib utilities. Do NOT import contextlib."
    - "closing(thing): context manager that calls thing.close() on exit."
    - "redirect_stdout(new_target): context manager redirecting sys.stdout."
    - "suppress(*exceptions): context manager suppressing specified exceptions."
    - "contextlib4_closing(): closing(io.StringIO()) closes stream on exit — returns True."
    - "contextlib4_redirect_stdout(): captured output contains expected string — returns True."
    - "contextlib4_suppress(): suppress(ValueError) swallows ValueError — returns True."
    - "Zero-arg invariant signatures — def contextlib4_closing(): return bool"
    - "closing: calls .close() on __exit__; use with StringIO, file objects, etc."
    - "redirect_stdout: save sys.stdout, replace with new_target, restore on exit."
    - "suppress: catch listed exceptions in __exit__ and return True to suppress."
    - "Export: contextmanager, closing, redirect_stdout, redirect_stderr, suppress, nullcontext."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_contextlib_cr4.closing:
  description: "closing() calls .close() on the wrapped object"
  category: closing
  kind: python_call_eq
  function: contextlib4_closing
  args: []
  expected: true

invariant theseus_contextlib_cr4.redirect_stdout:
  description: "redirect_stdout captures print output"
  category: redirect_stdout
  kind: python_call_eq
  function: contextlib4_redirect_stdout
  args: []
  expected: true

invariant theseus_contextlib_cr4.suppress:
  description: "suppress(ValueError) swallows ValueError without re-raising"
  category: suppress
  kind: python_call_eq
  function: contextlib4_suppress
  args: []
  expected: true
