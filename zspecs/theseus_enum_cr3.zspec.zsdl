spec: theseus_enum_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_enum_cr3)
blocks: enum

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html"
  notes:
    - "Clean-room extended enum utilities. Do NOT import enum."
    - "StrEnum: enum where member values are strings and members behave as strings."
    - "IntFlag: enum supporting bitwise operations (|, &, ^, ~)."
    - "auto(): automatically assign incrementing integer values."
    - "enum3_strenum(): class Color(StrEnum): RED='red'; Color.RED == 'red'."
    - "enum3_intflag(): class Perm(IntFlag): R=4, W=2; (Perm.R | Perm.W).value == 6."
    - "enum3_auto(): class Dir(Enum): NORTH=auto(); SOUTH=auto(); Dir.SOUTH.value == 2."
    - "StrEnum members: class inherits from str, member.value is a string."
    - "IntFlag members: bitwise OR/AND produces combined flag, value is int."
    - "auto() returns AutoValue objects that resolve to 1, 2, 3... via __new__."
    - "Export: StrEnum, IntFlag, auto (extending enum cr and cr2 implementations)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_enum_cr3.strenum:
  description: "StrEnum member value equals string and == comparison works"
  category: strenum
  kind: python_call_eq
  function: enum3_strenum
  args: []
  expected: true

invariant theseus_enum_cr3.intflag:
  description: "(Perm.R | Perm.W).value == 6"
  category: intflag
  kind: python_call_eq
  function: enum3_intflag
  args: []
  expected: 6

invariant theseus_enum_cr3.auto:
  description: "auto() assigns sequential values starting at 1"
  category: auto
  kind: python_call_eq
  function: enum3_auto
  args: []
  expected: 2
