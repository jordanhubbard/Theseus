spec: itertools_extra1876
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "itertools module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party itertools extensions"
  notes:
    - "itertools types are implemented in C and do not override attr access protocol methods"
    - "groupby and zip_longest expose __iter__ and __next__ in their type dicts"
  created_at: "2026-04-12"

