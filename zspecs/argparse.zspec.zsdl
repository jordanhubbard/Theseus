spec: argparse
version: ">=3.2"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/argparse.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "argparse source: argparse.py (PSF; source inspection permitted)"
  not_derived_from:
    - "argparse source: internal _ActionsContainer and _ArgumentGroup implementation details"
  notes:
    - "argparse.OPTIONAL='?', ZERO_OR_MORE='*', ONE_OR_MORE='+' are nargs sentinel strings."
    - "argparse.SUPPRESS='==SUPPRESS==' is used to suppress default values or help text."
    - "argparse.REMAINDER='...' collects all remaining arguments unconsumed by other actions."
    - "argparse.PARSER='A...' is an internal sentinel for subparser nargs; verified on Python 3.12."
    - "ArgumentParser().parse_args([]) returns a Namespace object with no attributes set."
    - "Namespace(x=1).x == 1 — Namespace stores keyword arguments as attributes."
    - "BooleanOptionalAction was added in Python 3.9."
    - "All expected values verified by running Python 3.14.3 argparse module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "ArgumentParser.parse_args() calls sys.exit(2) on parse errors (does not raise in normal usage). ArgumentError is raised internally and converted to a usage error. ArgumentTypeError is raised by type-conversion functions."
  stderr: "null"
  stickiness: "N/A — each parser instance is independent."
  codes: {}

# ---------------------------------------------------------------------------
# Class name metadata — core classes exposed by argparse
# ---------------------------------------------------------------------------

table argparse.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [argumentparser,                ArgumentParser.__name__.__eq__,                ["ArgumentParser"],                true]
    - [namespace,                     Namespace.__name__.__eq__,                     ["Namespace"],                     true]
    - [action,                        Action.__name__.__eq__,                        ["Action"],                        true]
    - [argumenterror,                 ArgumentError.__name__.__eq__,                 ["ArgumentError"],                 true]
    - [argumenttypeerror,             ArgumentTypeError.__name__.__eq__,             ["ArgumentTypeError"],             true]
    - [helpformatter,                 HelpFormatter.__name__.__eq__,                 ["HelpFormatter"],                 true]
    - [rawdescriptionhelpformatter,   RawDescriptionHelpFormatter.__name__.__eq__,   ["RawDescriptionHelpFormatter"],   true]
    - [rawtexthelpformatter,          RawTextHelpFormatter.__name__.__eq__,          ["RawTextHelpFormatter"],          true]
    - [argumentdefaultshelpformatter, ArgumentDefaultsHelpFormatter.__name__.__eq__, ["ArgumentDefaultsHelpFormatter"], true]
    - [metavartypehelpformatter,      MetavarTypeHelpFormatter.__name__.__eq__,      ["MetavarTypeHelpFormatter"],      true]
    - [filetype,                      FileType.__name__.__eq__,                      ["FileType"],                      true]
    - [booleanoptionalaction,         BooleanOptionalAction.__name__.__eq__,         ["BooleanOptionalAction"],         true]

# ---------------------------------------------------------------------------
# nargs sentinel constants
# ---------------------------------------------------------------------------

table argparse.nargs_constants:
  kind: python_call_eq
  category: constants
  id_prefix: nargs

  columns: [id, function, args, expected]
  rows:
    - [optional,      OPTIONAL.__eq__,     ["?"], true]
    - [zero_or_more,  ZERO_OR_MORE.__eq__,  ["*"], true]
    - [one_or_more,   ONE_OR_MORE.__eq__,   ["+"], true]

# ---------------------------------------------------------------------------
# SUPPRESS constant
# ---------------------------------------------------------------------------

invariant argparse.suppress_value:
  description: "argparse.SUPPRESS == '==SUPPRESS==' — the sentinel string used to suppress defaults and help"
  category: constants
  kind: python_call_eq
  function: SUPPRESS.__eq__
  args: ["==SUPPRESS=="]
  expected: true

invariant argparse.remainder_value:
  description: "argparse.REMAINDER == '...' — the sentinel string used to collect all remaining args"
  category: constants
  kind: python_call_eq
  function: REMAINDER.__eq__
  args: ["..."]
  expected: true

# ---------------------------------------------------------------------------
# ArgumentParser — empty parse_args returns a Namespace with no unexpected attrs
# ---------------------------------------------------------------------------

invariant argparse.parse_args_empty_vars:
  description: "vars(ArgumentParser().parse_args([])) == {} — empty parser, empty namespace"
  category: parse_args
  kind: python_call_eq
  function: ArgumentParser
  args: []
  method: parse_args
  method_args: [[]]
  method_chain: __dict__
  expected: {}

# ---------------------------------------------------------------------------
# Namespace — stores keyword arguments as attributes
# ---------------------------------------------------------------------------

invariant argparse.namespace_attr_x:
  description: "argparse.Namespace(x=1).x == 1 — Namespace stores kwargs as attributes"
  category: namespace
  kind: python_call_eq
  function: Namespace
  kwargs: {x: 1}
  method: x
  expected: 1

invariant argparse.namespace_attr_str:
  description: "argparse.Namespace(name='hello').name == 'hello'"
  category: namespace
  kind: python_call_eq
  function: Namespace
  kwargs: {name: "hello"}
  method: name
  expected: "hello"

# ---------------------------------------------------------------------------
# Exception hierarchy — ArgumentError and ArgumentTypeError inherit from Exception
# ---------------------------------------------------------------------------

invariant argparse.argumenterror_mro:
  description: "ArgumentError.__mro__[1].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: ArgumentError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Exception"

invariant argparse.argumenttypeerror_mro:
  description: "ArgumentTypeError.__mro__[1].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: ArgumentTypeError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Exception"

