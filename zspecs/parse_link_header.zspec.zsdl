spec: parse_link_header
version: ">=2.0.0"
backend: node(parse-link-header)

docs: https://github.com/thlorenz/parse-link-header#readme

provenance:
  derived_from:
    - "parse-link-header README — https://github.com/thlorenz/parse-link-header#readme"
    - "RFC 8288 — Web Linking (Link header)"
    - "Test vectors verified with parse-link-header via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "parse-link-header source"
  notes:
    - "Parse an HTTP Link header into a {rel: {url, ...params}} map (e.g. for paginated GitHub APIs)."
    - "Install: npm install parse-link-header"
    - "v2 CJS; module export IS the function. Returns null for null/empty input."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Returns null on null/empty/unparseable input rather than throwing."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant parse_link_header.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant parse_link_header.module_arity:
  description: "Module function takes 1 arg"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant parse_link_header.null_returns_null:
  description: "null input returns null"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [null]
  chain: []
  expected: null

invariant parse_link_header.empty_returns_null:
  description: "Empty string returns null"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [""]
  chain: []
  expected: null

invariant parse_link_header.parse_next_url:
  description: "Extracts .next.url from a typical paginated Link header"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: ["<https://api.example.com/users?page=2>; rel=\"next\", <https://api.example.com/users?page=5>; rel=\"last\""]
  chain:
    - {get: "next.url"}
  expected: "https://api.example.com/users?page=2"

invariant parse_link_header.parse_last_url:
  description: "Extracts .last.url from the same Link header"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: ["<https://api.example.com/users?page=2>; rel=\"next\", <https://api.example.com/users?page=5>; rel=\"last\""]
  chain:
    - {get: "last.url"}
  expected: "https://api.example.com/users?page=5"

invariant parse_link_header.preserves_query_param:
  description: "Query params from the URL appear as keys on the rel entry"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: ["<https://api.example.com/users?page=2>; rel=\"next\""]
  chain:
    - {get: "next.page"}
  expected: "2"

invariant parse_link_header.rel_recorded:
  description: ".rel field is preserved on the entry"
  category: parse
  kind: node_chain_eq
  entry: module
  entry_args: ["<https://api.example.com/users?page=2>; rel=\"next\""]
  chain:
    - {get: "next.rel"}
  expected: "next"

