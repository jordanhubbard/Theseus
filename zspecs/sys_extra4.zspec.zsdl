spec: sys_extra4
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "Extends sys.zspec.zsdl, sys_extra.zspec.zsdl, sys_extra2.zspec.zsdl, sys_extra3.zspec.zsdl."
    - "sys.zspec.zsdl covers: version_info.major==3, hexversion>=50397424, api_version==1013, maxsize>=2147483647, getdefaultencoding=='utf-8', getfilesystemencoding non-empty, getrecursionlimit>=1000, builtin_module_names contains 'sys'/'builtins' and is tuple, function names table, version/copyright/platform strings."
    - "sys_extra.zspec.zsdl covers: version_info.major>=3, version_info.minor>=0, flags class name, implementation.name=='cpython', maxsize/maxunicode/byteorder class names, float_info/int_info/hash_info class names, builtin_module_names class name."
    - "sys_extra2.zspec.zsdl covers: version/platform/maxsize/maxunicode/byteorder/builtin_module_names class names, maxunicode==1114111, getrecursionlimit/setrecursionlimit/getdefaultencoding __name__."
    - "sys_extra3.zspec.zsdl covers: flags class name + debug/optimize field type checks, float_info class name + max/min/epsilon type checks + max>0, int_info class name + bits_per_digit/sizeof_digit type checks, hash_info class name + width/modulus type checks, implementation.name is str."
    - "This spec adds NEW invariants: getdefaultencoding()==utf-8 (standalone named), getfilesystemencoding().__class__.__name__=='str', getrecursionlimit()>=100, getswitchinterval().__class__.__name__=='float', hash_info/__class__/__name__=='hash_info' (standalone), int_info/__class__/__name__=='int_info' (standalone), float_info class name (standalone), thread_info/__class__/__name__=='thread_info', implementation.name class name (standalone), flags class name (standalone), abiflags/__class__/__name__=='str', prefix/__class__/__name__=='str', exec_prefix/__class__/__name__=='str', base_prefix/__class__/__name__=='str', builtin_module_names/__class__/__name__=='tuple' (standalone)."
    - "sys.getswitchinterval() returns the thread switch interval as a float (Python 3.2+)."
    - "sys.thread_info.__class__.__name__ == 'thread_info' — named tuple with thread implementation details."
    - "sys.abiflags is a string (e.g., '' or 'm') on POSIX platforms — available on Python 3.8+ on POSIX."
    - "sys.prefix, sys.exec_prefix, sys.base_prefix are all str objects giving installation prefix paths."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getdefaultencoding — standalone named invariant
#
# sys.zspec.zsdl covers this; this provides an additional named anchor
# in the sys_extra4 namespace.
# ---------------------------------------------------------------------------

invariant sys_extra4.getdefaultencoding.value:
  description: "sys.getdefaultencoding() == 'utf-8' — default string encoding on all modern Python 3"
  category: encoding
  kind: python_call_eq
  function: getdefaultencoding
  args: []
  expected: "utf-8"

# ---------------------------------------------------------------------------
# getfilesystemencoding — return type check
# ---------------------------------------------------------------------------

invariant sys_extra4.getfilesystemencoding.return_type:
  description: "sys.getfilesystemencoding().__class__.__name__ == 'str' — always returns a str"
  category: encoding
  kind: python_call_eq
  function: getfilesystemencoding
  args: []
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# getrecursionlimit — minimum bound
#
# sys_extra.zspec.zsdl and sys.zspec.zsdl check >= 1000.
# This spec verifies a looser lower bound of >= 100 that holds universally.
# ---------------------------------------------------------------------------

invariant sys_extra4.getrecursionlimit.ge_100:
  description: "sys.getrecursionlimit() >= 100 — recursion limit is always at least 100"
  category: runtime
  kind: python_call_eq
  function: getrecursionlimit
  args: []
  method: __ge__
  method_args: [100]
  expected: true

# ---------------------------------------------------------------------------
# getswitchinterval — return type
#
# sys.getswitchinterval() returns the interval (in seconds) for the interpreter
# to switch between threads. The return type is always float.
# ---------------------------------------------------------------------------

invariant sys_extra4.getswitchinterval.return_type:
  description: "sys.getswitchinterval().__class__.__name__ == 'float' — switch interval is a float"
  category: threading
  kind: python_call_eq
  function: getswitchinterval
  args: []
  method: __class__.__name__.__eq__
  method_args: ["float"]
  expected: true

invariant sys_extra4.getswitchinterval.positive:
  description: "sys.getswitchinterval() > 0 — thread switch interval is always positive"
  category: threading
  kind: python_call_eq
  function: getswitchinterval
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# hash_info — class name (standalone anchor in sys_extra4 namespace)
# ---------------------------------------------------------------------------

invariant sys_extra4.hash_info.class_name:
  description: "sys.hash_info.__class__.__name__ == 'hash_info'"
  category: hash_info
  kind: python_call_eq
  function: hash_info.__class__.__name__.__eq__
  args: ["hash_info"]
  expected: true

# ---------------------------------------------------------------------------
# int_info — class name (standalone anchor in sys_extra4 namespace)
# ---------------------------------------------------------------------------

invariant sys_extra4.int_info.class_name:
  description: "sys.int_info.__class__.__name__ == 'int_info'"
  category: int_info
  kind: python_call_eq
  function: int_info.__class__.__name__.__eq__
  args: ["int_info"]
  expected: true

# ---------------------------------------------------------------------------
# float_info — class name (standalone anchor in sys_extra4 namespace)
# ---------------------------------------------------------------------------

invariant sys_extra4.float_info.class_name:
  description: "sys.float_info.__class__.__name__ == 'float_info'"
  category: float_info
  kind: python_call_eq
  function: float_info.__class__.__name__.__eq__
  args: ["float_info"]
  expected: true

# ---------------------------------------------------------------------------
# thread_info — class name
#
# sys.thread_info is a named tuple containing the thread implementation
# details (name, lock, version). Available on Python 3.3+.
# ---------------------------------------------------------------------------

invariant sys_extra4.thread_info.class_name:
  description: "sys.thread_info.__class__.__name__ == 'thread_info'"
  category: thread_info
  kind: python_call_eq
  function: thread_info.__class__.__name__.__eq__
  args: ["thread_info"]
  expected: true

# ---------------------------------------------------------------------------
# implementation.name — class name (standalone anchor in sys_extra4 namespace)
# ---------------------------------------------------------------------------

invariant sys_extra4.implementation.name.class_name:
  description: "sys.implementation.name.__class__.__name__ == 'str'"
  category: implementation
  kind: python_call_eq
  function: implementation.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# flags — class name (standalone anchor in sys_extra4 namespace)
# ---------------------------------------------------------------------------

invariant sys_extra4.flags.class_name:
  description: "sys.flags.__class__.__name__ == 'flags'"
  category: flags
  kind: python_call_eq
  function: flags.__class__.__name__.__eq__
  args: ["flags"]
  expected: true

# ---------------------------------------------------------------------------
# abiflags — type check
#
# sys.abiflags is a POSIX-specific attribute containing ABI flag characters
# (e.g., '' or 'm'). It is always a str on Python 3.8+.
# ---------------------------------------------------------------------------

invariant sys_extra4.abiflags.class_name:
  description: "sys.abiflags.__class__.__name__ == 'str' — ABI flags string on POSIX"
  category: metadata
  kind: python_call_eq
  function: abiflags.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# prefix, exec_prefix, base_prefix — type checks
#
# These three attributes hold installation prefix paths and are always str.
# ---------------------------------------------------------------------------

invariant sys_extra4.prefix.class_name:
  description: "sys.prefix.__class__.__name__ == 'str' — installation prefix is a str"
  category: metadata
  kind: python_call_eq
  function: prefix.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sys_extra4.exec_prefix.class_name:
  description: "sys.exec_prefix.__class__.__name__ == 'str' — exec prefix is a str"
  category: metadata
  kind: python_call_eq
  function: exec_prefix.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sys_extra4.base_prefix.class_name:
  description: "sys.base_prefix.__class__.__name__ == 'str' — base prefix is a str"
  category: metadata
  kind: python_call_eq
  function: base_prefix.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# builtin_module_names — class name (standalone anchor in sys_extra4 namespace)
# ---------------------------------------------------------------------------

invariant sys_extra4.builtin_module_names.class_name:
  description: "sys.builtin_module_names.__class__.__name__ == 'tuple'"
  category: modules
  kind: python_call_eq
  function: builtin_module_names.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
