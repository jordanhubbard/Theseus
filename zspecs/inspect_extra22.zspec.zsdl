spec: inspect_extra22
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra21.zspec.zsdl."
    - "Focus: __qualname__.__len__() for inspect functions and classes — no prior inspect spec measures any qualname lengths."
    - "inspect_extra21 covers: source-retrieval function __qualname__.__eq__ table (getfile/getmodule/getsourcefile/getsourcelines); async/generator predicate __qualname__.__eq__ table; getsourcefile/__qualname__.__len__==13 and getsourcelines/__qualname__.__len__==14 standalone invariants."
    - "inspect_extra19 covers: predicate __qualname__.__eq__ table for ismodule/isclass/isfunction/ismethod/isbuiltin; getmembers/__qualname__.__eq__ and signature/__qualname__.__eq__ standalone invariants."
    - "inspect_extra15 covers: __qualname__ table for isfunction/isbuiltin/isclass/ismodule/ismethod/ismethoddescriptor."
    - "inspect_extra7 covers: Parameter/__qualname__.__eq__ and Signature/__qualname__.__eq__ and BoundArguments/__qualname__.__eq__ standalone invariants."
    - "inspect_extra12 and inspect_extra14 cover Parameter/__qualname__.__eq__ and Signature/__qualname__.__eq__."
    - "No prior inspect spec collects __qualname__.__len__() for isfunction/ismethod/isclass/ismodule/getmembers/getsource/signature/Parameter/Signature in any combined table."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for inspect predicate and utility functions — table
# (inspect_extra22 namespace)
#
# No prior inspect spec measures __qualname__.__len__() for any inspect
# function. This table covers the five functions mentioned in the task spec:
# isfunction (10), ismethod (8), isclass (7), ismodule (8), getmembers (10),
# getsource (9), signature (9).
# ---------------------------------------------------------------------------

table inspect_extra22.function_qualname_lens:
  description: "__qualname__.__len__() for inspect predicate and utility functions"
  kind: python_call_eq
  category: function_qualname_lengths
  id_prefix: qlen

  columns: [id, function, args, expected]
  rows:
    - [isfunction,  isfunction.__qualname__.__len__,  [], 10]
    - [ismethod,    ismethod.__qualname__.__len__,    [],  8]
    - [isclass,     isclass.__qualname__.__len__,     [],  7]
    - [ismodule,    ismodule.__qualname__.__len__,    [],  8]
    - [getmembers,  getmembers.__qualname__.__len__,  [], 10]
    - [getsource,   getsource.__qualname__.__len__,   [],  9]
    - [signature,   signature.__qualname__.__len__,   [],  9]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for inspect class types — table
# (inspect_extra22 namespace)
#
# inspect_extra7 covers Parameter.__qualname__.__eq__ and Signature.__qualname__.__eq__
# as standalone invariants. No prior inspect spec measures their qualname lengths.
# Parameter.__qualname__ == 'Parameter' (9 chars).
# Signature.__qualname__ == 'Signature' (9 chars).
# ---------------------------------------------------------------------------

table inspect_extra22.class_qualname_lens:
  description: "__qualname__.__len__() for inspect class types"
  kind: python_call_eq
  category: class_qualname_lengths
  id_prefix: clsqlen

  columns: [id, function, args, expected]
  rows:
    - [Parameter, Parameter.__qualname__.__len__, [], 9]
    - [Signature, Signature.__qualname__.__len__, [], 9]

# ---------------------------------------------------------------------------
# inspect.isfunction.__qualname__ == 'isfunction' — standalone invariant
# (inspect_extra22 namespace)
#
# inspect_extra15 and inspect_extra19 cover isfunction/__qualname__.__eq__ in
# combined tables. Providing a standalone in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra22.isfunction.qualname:
  description: "inspect.isfunction.__qualname__ == 'isfunction'"
  category: function_qualnames
  kind: python_call_eq
  function: isfunction.__qualname__.__eq__
  args: ["isfunction"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.isclass.__qualname__ == 'isclass' — standalone invariant
# (inspect_extra22 namespace)
#
# inspect_extra15 and inspect_extra19 cover isclass/__qualname__.__eq__ in tables.
# Providing a standalone in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra22.isclass.qualname:
  description: "inspect.isclass.__qualname__ == 'isclass'"
  category: function_qualnames
  kind: python_call_eq
  function: isclass.__qualname__.__eq__
  args: ["isclass"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.Parameter.__qualname__ == 'Parameter' — standalone invariant
# (inspect_extra22 namespace)
#
# inspect_extra7 covers Parameter.__qualname__.__eq__ standalone in the extra7
# namespace. Providing a standalone in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra22.Parameter.qualname:
  description: "inspect.Parameter.__qualname__ == 'Parameter' — top-level class in inspect"
  category: class_qualnames
  kind: python_call_eq
  function: Parameter.__qualname__.__eq__
  args: ["Parameter"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.Signature.__qualname__ == 'Signature' — standalone invariant
# (inspect_extra22 namespace)
#
# inspect_extra7 covers Signature.__qualname__.__eq__ standalone in the extra7
# namespace. Providing a standalone in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant inspect_extra22.Signature.qualname:
  description: "inspect.Signature.__qualname__ == 'Signature' — top-level class in inspect"
  category: class_qualnames
  kind: python_call_eq
  function: Signature.__qualname__.__eq__
  args: ["Signature"]
  expected: true
