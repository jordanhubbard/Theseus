spec: sift
version: ">=17.0.0"
backend: node(sift)

docs: https://github.com/crcn/sift.js#readme

provenance:
  derived_from:
    - "sift README — https://github.com/crcn/sift.js#readme"
    - "MongoDB query operator reference — https://www.mongodb.com/docs/manual/reference/operator/query/"
    - "Test vectors verified with sift via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "sift source"
  notes:
    - "MongoDB-style query language as a JS predicate factory — useful for filtering arrays in memory."
    - "Install: npm install sift"
    - "v17 CJS; default export is the predicate factory (sift(query) → fn); named exports include each $-operator constant."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factory; never throws on valid queries."
  stderr: "null"
  stickiness: "N/A — each predicate independent."
  codes: {}

# sift({eq}) returns a predicate
invariant sift.eq_match:
  description: "sift({a: 2})({a: 2}) is true"
  category: equality
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{a: 2}]
  chain:
    - {call: [{a: 2}]}
  expected: true

invariant sift.eq_no_match:
  description: "sift({a: 2})({a: 3}) is false"
  category: equality
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{a: 2}]
  chain:
    - {call: [{a: 3}]}
  expected: false

# $gt
invariant sift.gt_match:
  description: "sift({a: {$gt: 1}})({a: 2}) is true"
  category: comparison
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{a: {$gt: 1}}]
  chain:
    - {call: [{a: 2}]}
  expected: true

invariant sift.gt_no_match:
  description: "sift({a: {$gt: 5}})({a: 2}) is false"
  category: comparison
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{a: {$gt: 5}}]
  chain:
    - {call: [{a: 2}]}
  expected: false

# $in
invariant sift.in_match:
  description: "sift({a: {$in: [1, 3]}})({a: 1}) is true"
  category: in
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{a: {$in: [1, 3]}}]
  chain:
    - {call: [{a: 1}]}
  expected: true

invariant sift.in_no_match:
  description: "sift({a: {$in: [1, 3]}})({a: 2}) is false"
  category: in
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{a: {$in: [1, 3]}}]
  chain:
    - {call: [{a: 2}]}
  expected: false

# $or
invariant sift.or_match_first:
  description: "sift({$or:[{a:1},{a:3}]})({a: 1}) is true"
  category: or
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{$or: [{a: 1}, {a: 3}]}]
  chain:
    - {call: [{a: 1}]}
  expected: true

invariant sift.or_match_third:
  description: "sift({$or:[{a:1},{a:3}]})({a: 3}) is true"
  category: or
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{$or: [{a: 1}, {a: 3}]}]
  chain:
    - {call: [{a: 3}]}
  expected: true

invariant sift.or_no_match:
  description: "sift({$or:[{a:1},{a:3}]})({a: 2}) is false"
  category: or
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{$or: [{a: 1}, {a: 3}]}]
  chain:
    - {call: [{a: 2}]}
  expected: false

# $and (range)
invariant sift.gte_lte_range:
  description: "sift({a: {$gte:2, $lte:2}})({a: 2}) is true"
  category: comparison
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{a: {$gte: 2, $lte: 2}}]
  chain:
    - {call: [{a: 2}]}
  expected: true

# $ne
invariant sift.ne_match:
  description: "sift({a: {$ne: 1}})({a: 2}) is true"
  category: ne
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: [{a: {$ne: 1}}]
  chain:
    - {call: [{a: 2}]}
  expected: true
