spec: asyncio_extra2371
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "All expected values verified interactively with Python 3.14.4 on macOS/Darwin 25.4.0."
    - "asyncio.Task, Future, Event, Lock, Queue, Semaphore are classes — __class__.__name__ == 'type'."
    - "asyncio.run, create_task, sleep, wait, gather, shield are plain functions — __class__.__name__ == 'function'."
    - "asyncio.get_event_loop is a C-level builtin — __class__.__name__ == 'builtin_function_or_method'."
    - "asyncio.timeout is a plain Python function in Python 3.11+ (not the class Timeout) — __class__.__name__ == 'function'."
    - "asyncio.CancelledError, TimeoutError, InvalidStateError are exception classes — __class__.__name__ == 'type'."
    - "The pattern function: Name.__class__.__name__.__eq__ with args: ['expected'] and expected: true is the canonical ZSDL idiom for attribute equality checks."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level classes: __class__.__name__ == "type"
# ---------------------------------------------------------------------------

table asyncio_extra2371.object_types:
  kind: python_call_eq
  category: object_types

  columns: [id, function, args, expected]
  rows:
    - ["as2371001", "Task.__class__.__name__.__eq__",             ["type"],     true]
    - ["as2371002", "Future.__class__.__name__.__eq__",           ["type"],     true]
    - ["as2371003", "Event.__class__.__name__.__eq__",            ["type"],     true]
    - ["as2371004", "Lock.__class__.__name__.__eq__",             ["type"],     true]
    - ["as2371005", "Queue.__class__.__name__.__eq__",            ["type"],     true]
    - ["as2371006", "Semaphore.__class__.__name__.__eq__",        ["type"],     true]
    - ["as2371007", "CancelledError.__class__.__name__.__eq__",   ["type"],     true]
    - ["as2371008", "TimeoutError.__class__.__name__.__eq__",     ["type"],     true]
    - ["as2371009", "InvalidStateError.__class__.__name__.__eq__", ["type"],    true]

# ---------------------------------------------------------------------------
# Module-level plain functions: __class__.__name__ == "function"
# ---------------------------------------------------------------------------

table asyncio_extra2371.function_types:
  kind: python_call_eq
  category: object_types

  columns: [id, function, args, expected]
  rows:
    - ["as2371010", "run.__class__.__name__.__eq__",         ["function"], true]
    - ["as2371011", "create_task.__class__.__name__.__eq__", ["function"], true]
    - ["as2371012", "sleep.__class__.__name__.__eq__",       ["function"], true]
    - ["as2371013", "wait.__class__.__name__.__eq__",        ["function"], true]
    - ["as2371014", "gather.__class__.__name__.__eq__",      ["function"], true]
    - ["as2371015", "shield.__class__.__name__.__eq__",      ["function"], true]
    - ["as2371016", "timeout.__class__.__name__.__eq__",     ["function"], true]

# ---------------------------------------------------------------------------
# Module-level C builtins: __class__.__name__ == "builtin_function_or_method"
# ---------------------------------------------------------------------------

table asyncio_extra2371.builtin_types:
  kind: python_call_eq
  category: object_types

  columns: [id, function, args, expected]
  rows:
    - ["as2371017", "get_event_loop.__class__.__name__.__eq__", ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# Cross-checks: class names match their own __name__ attribute
# ---------------------------------------------------------------------------

table asyncio_extra2371.class_names:
  kind: python_call_eq
  category: class_names

  columns: [id, function, args, expected]
  rows:
    - ["as2371018", "Task.__name__.__eq__",            ["Task"],            true]
    - ["as2371019", "Future.__name__.__eq__",          ["Future"],          true]
    - ["as2371020", "CancelledError.__name__.__eq__",  ["CancelledError"],  true]
    - ["as2371021", "TimeoutError.__name__.__eq__",    ["TimeoutError"],    true]
    - ["as2371022", "InvalidStateError.__name__.__eq__", ["InvalidStateError"], true]
