spec: decimal_extra55
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra54.zspec.zsdl — covers decimal.__package__.__eq__(''); Decimal/Context __doc__.__class__.__name__.__len__()==3; decimal.__spec__.__class__.__name__.__eq__('ModuleSpec'); decimal.__spec__.name.__eq__('decimal') and __len__()==7."
    - "decimal_extra53.zspec.zsdl — covers decimal has no __all__; Decimal/Context/DecimalException/InvalidOperation __eq__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "decimal_extra34.zspec.zsdl — covers decimal.__name__.__len__()==7; decimal.__file__.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends decimal_extra54.zspec.zsdl."
    - "Wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__/__cached__ class name checks."
    - "IMPORTANT: On Python 3.14.3 (this machine), 'import decimal' loads decimal.py (the pure Python implementation) with a SourceFileLoader. The underlying C extension _decimal is available separately as '_decimal'. Therefore decimal.__loader__.__class__.__name__ == 'SourceFileLoader', NOT 'ExtensionFileLoader'. The task note about C extension applies to _decimal, not decimal. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — decimal.py is a pure Python module loaded by SourceFileLoader. __loader__.__class__.__name__ is 'SourceFileLoader' (16 characters). No prior decimal spec checks __loader__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters. This is a length anchor complementing the equality anchor above. No prior decimal spec checks __loader__.__class__.__name__.__len__(). Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__file__.__class__.__name__.__eq__('str') == True — decimal_extra34 covers __file__.__class__.__name__.__len__()==3 (length). The equality anchor __file__.__class__.__name__.__eq__('str') is distinct and novel in the decload55 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__cached__.__class__.__name__.__eq__('str') == True — decimal has a __cached__ attribute pointing to the compiled .pyc bytecode. Its type is str. No prior decimal spec checks __cached__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note on decimal_extra54: __spec__.__class__.__name__.__eq__('ModuleSpec') was already covered there. This spec does NOT re-cover it."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.__loader__.__class__.__name__ identity
#
# On Python 3.14.3, 'import decimal' loads decimal.py (the pure Python
# implementation) using SourceFileLoader. The loader is a SourceFileLoader
# instance, so:
#
#   decimal.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True
#   decimal.__loader__.__class__.__name__.__len__()                  == 16
#
# Note: the underlying C extension is '_decimal' (a separate module). When
# imported directly, _decimal.__loader__.__class__.__name__ == 'ExtensionFileLoader'.
# But 'decimal' itself is the Python wrapper with SourceFileLoader.
#
# No prior decimal spec checks __loader__.__class__.__name__ or its length.
# Both anchors are novel in the decload55 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra55.loader_class_name:
  description: "decimal.__loader__.__class__.__name__ identity — decimal.py is loaded by SourceFileLoader; __loader__.__class__.__name__=='SourceFileLoader' (16 chars); no prior decimal spec checks __loader__.__class__.__name__; NOTE: the C extension '_decimal' uses ExtensionFileLoader but 'decimal' itself is the Python wrapper with SourceFileLoader; both equality and length anchors novel in decload55 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: decload55ldr

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_SourceFileLoader, __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [loader_class_name_len_16,           __loader__.__class__.__name__.__len__, [],                  16  ]

# ---------------------------------------------------------------------------
# decimal.__file__.__class__.__name__.__eq__('str')
# decimal.__cached__.__class__.__name__.__eq__('str')
#
# decimal.py is a pure Python module with both __file__ (path to decimal.py)
# and __cached__ (path to the compiled .pyc bytecode). Both are str.
#
#   decimal.__file__.__class__.__name__.__eq__('str')    == True
#   decimal.__cached__.__class__.__name__.__eq__('str')  == True
#
# decimal_extra34 covers __file__.__class__.__name__.__len__()==3 (length).
# The equality anchor __file__.__class__.__name__.__eq__('str') is distinct.
# No prior decimal spec checks __cached__.__class__.__name__. Both novel.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra55.file_cached_class_names:
  description: "decimal.__file__/__cached__.__class__.__name__.__eq__('str') — decimal.py is pure Python with both __file__ (path to decimal.py) and __cached__ (path to .pyc bytecode); both are str; decimal_extra34 covers __file__.__class__.__name__.__len__()==3 (length) but not __eq__('str') equality; no prior decimal spec checks __cached__.__class__.__name__; both novel anchors in decload55 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: decload55files

  columns: [id, function, args, expected]
  rows:
    - [file_class_name_eq_str,   __file__.__class__.__name__.__eq__,   ["str"], true]
    - [cached_class_name_eq_str, __cached__.__class__.__name__.__eq__, ["str"], true]

invariant decimal_extra55.loader_class_name_SourceFileLoader:
  description: "decimal.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — decimal.py is a pure Python module loaded by SourceFileLoader; the underlying C extension '_decimal' uses ExtensionFileLoader but 'decimal' itself uses SourceFileLoader; no prior decimal spec checks __loader__.__class__.__name__; novel anchor in decload55 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant decimal_extra55.loader_class_name_len_16:
  description: "decimal.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; no prior decimal spec checks __loader__.__class__.__name__.__len__(); novel length anchor in decload55 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16

invariant decimal_extra55.file_class_name_eq_str:
  description: "decimal.__file__.__class__.__name__.__eq__('str') == True — decimal.__file__ is a str path to decimal.py; decimal_extra34 covers the length (3) but not the equality; this equality anchor is novel in decload55 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra55.cached_class_name_eq_str:
  description: "decimal.__cached__.__class__.__name__.__eq__('str') == True — decimal.__cached__ is a str path to the compiled .pyc bytecode; no prior decimal spec checks __cached__.__class__.__name__; novel anchor in decload55 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __cached__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
