spec: email_extra2
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "Python 3 email package documentation — https://docs.python.org/3/library/email.html"
    - "Python 3 email.policy documentation — https://docs.python.org/3/library/email.policy.html"
    - "Python 3 email.errors documentation — https://docs.python.org/3/library/email.errors.html"
    - "Python 3 email.contentmanager documentation — https://docs.python.org/3/library/email.contentmanager.html"
    - "Python 3 email.generator documentation — https://docs.python.org/3/library/email.generator.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/__init__.py"
    - "CPython source: Lib/email/policy.py"
    - "CPython source: Lib/email/errors.py"
    - "CPython source: Lib/email/contentmanager.py"
    - "CPython source: Lib/email/generator.py"
    - "email.zspec.zsdl — covers message.Message, mime.text.MIMEText, mime.multipart.MIMEMultipart, header.Header class names, message_from_string/bytes/file function names, encoders module function names"
    - "email_extra.zspec.zsdl — covers email.utils function names (parseaddr, formataddr, parsedate, formatdate, make_msgid), email.mime.base.MIMEBase class name, email.header.decode_header function name"
    - "email_policy.zspec.zsdl — covers Policy, EmailPolicy, Compat32 class names and module checks, SMTP/SMTPUTF8/HTTP/default/compat32 policy instance class checks"
    - "email_errors.zspec.zsdl — covers MessageError, MessageParseError, HeaderParseError, BoundaryError, HeaderDefect class names and inheritance chain"
    - "email_generator.zspec.zsdl — not yet written; this spec seeds generator class name coverage"
  notes:
    - "Focus: email.policy instance __name__ checks (EmailPolicy.__name__, SMTP.__name__), email.errors class names (HeaderParseError, MessageError, MessageDefect), email.contentmanager.get_content_manager function name, email.generator class names."
    - "email.policy.EmailPolicy.__name__ == 'EmailPolicy' — the modern policy class for Python 3.6+."
    - "email.policy.SMTP is an EmailPolicy instance; its __class__.__name__ == 'EmailPolicy'."
    - "email.policy.SMTPUTF8 is an EmailPolicy instance with utf8=True."
    - "email.policy.HTTP is an EmailPolicy instance with linesep='\\r\\n' and max_line_length=None."
    - "email.errors.HeaderParseError.__name__ == 'HeaderParseError' — raised on malformed header values."
    - "email.errors.MessageError.__name__ == 'MessageError' — root exception in email.errors hierarchy."
    - "email.errors.MessageDefect.__name__ == 'MessageDefect' — base class for non-fatal defects."
    - "email.contentmanager module exposes get_content_manager function."
    - "email.generator.Generator.__name__ == 'Generator' — text output generator class."
    - "email.generator.BytesGenerator.__name__ == 'BytesGenerator' — binary output generator class."
    - "email.generator.Generator.__module__ == 'email.generator' — module location confirmed."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email.policy — class __name__ checks (via email module subpackage)
#
# These verify the __name__ of policy classes and the __class__.__name__ of
# module-level policy singletons accessed through the email.policy submodule.
# email_policy.zspec.zsdl already covers Policy/EmailPolicy/Compat32 class
# names from the email.policy backend; this spec accesses them via email.policy
# as a submodule attribute chain within the email backend.
# ---------------------------------------------------------------------------

invariant email_extra2.policy.EmailPolicy.class_name:
  description: "email.policy.EmailPolicy.__name__ == 'EmailPolicy'"
  category: policy
  kind: python_call_eq
  function: policy.EmailPolicy.__name__.__eq__
  args: ["EmailPolicy"]
  expected: true

invariant email_extra2.policy.SMTP.instance_class:
  description: "email.policy.SMTP.__class__.__name__ == 'EmailPolicy'"
  category: policy
  kind: python_call_eq
  function: policy.SMTP.__class__.__name__.__eq__
  args: ["EmailPolicy"]
  expected: true

invariant email_extra2.policy.SMTPUTF8.instance_class:
  description: "email.policy.SMTPUTF8.__class__.__name__ == 'EmailPolicy'"
  category: policy
  kind: python_call_eq
  function: policy.SMTPUTF8.__class__.__name__.__eq__
  args: ["EmailPolicy"]
  expected: true

invariant email_extra2.policy.HTTP.instance_class:
  description: "email.policy.HTTP.__class__.__name__ == 'EmailPolicy'"
  category: policy
  kind: python_call_eq
  function: policy.HTTP.__class__.__name__.__eq__
  args: ["EmailPolicy"]
  expected: true

# ---------------------------------------------------------------------------
# email.errors — class __name__ checks (via email.errors submodule)
#
# email_errors.zspec.zsdl covers these from python_module(email.errors);
# this spec verifies the same names are reachable via the email package
# attribute chain (email.errors.HeaderParseError, etc.).
# ---------------------------------------------------------------------------

invariant email_extra2.errors.HeaderParseError.class_name:
  description: "email.errors.HeaderParseError.__name__ == 'HeaderParseError'"
  category: errors
  kind: python_call_eq
  function: errors.HeaderParseError.__name__.__eq__
  args: ["HeaderParseError"]
  expected: true

invariant email_extra2.errors.MessageError.class_name:
  description: "email.errors.MessageError.__name__ == 'MessageError'"
  category: errors
  kind: python_call_eq
  function: errors.MessageError.__name__.__eq__
  args: ["MessageError"]
  expected: true

invariant email_extra2.errors.MessageDefect.class_name:
  description: "email.errors.MessageDefect.__name__ == 'MessageDefect'"
  category: errors
  kind: python_call_eq
  function: errors.MessageDefect.__name__.__eq__
  args: ["MessageDefect"]
  expected: true

# ---------------------------------------------------------------------------
# email.contentmanager — get_content_manager function name
# ---------------------------------------------------------------------------

invariant email_extra2.contentmanager.get_content_manager.name:
  description: "email.contentmanager.get_content_manager.__name__ == 'get_content_manager'"
  category: contentmanager
  kind: python_call_eq
  function: contentmanager.get_content_manager.__name__.__eq__
  args: ["get_content_manager"]
  expected: true

# ---------------------------------------------------------------------------
# email.generator — Generator and BytesGenerator class names and module
# ---------------------------------------------------------------------------

invariant email_extra2.generator.Generator.class_name:
  description: "email.generator.Generator.__name__ == 'Generator'"
  category: generator
  kind: python_call_eq
  function: generator.Generator.__name__.__eq__
  args: ["Generator"]
  expected: true

invariant email_extra2.generator.BytesGenerator.class_name:
  description: "email.generator.BytesGenerator.__name__ == 'BytesGenerator'"
  category: generator
  kind: python_call_eq
  function: generator.BytesGenerator.__name__.__eq__
  args: ["BytesGenerator"]
  expected: true

invariant email_extra2.generator.Generator.module:
  description: "email.generator.Generator.__module__ == 'email.generator'"
  category: generator
  kind: python_call_eq
  function: generator.Generator.__module__.__eq__
  args: ["email.generator"]
  expected: true

invariant email_extra2.generator.BytesGenerator.module:
  description: "email.generator.BytesGenerator.__module__ == 'email.generator'"
  category: generator
  kind: python_call_eq
  function: generator.BytesGenerator.__module__.__eq__
  args: ["email.generator"]
  expected: true

# ---------------------------------------------------------------------------
# email.policy — SMTPUTF8 utf8 attribute and SMTP linesep attribute
# ---------------------------------------------------------------------------

invariant email_extra2.policy.SMTPUTF8.utf8:
  description: "email.policy.SMTPUTF8.utf8 == True — SMTPUTF8 policy enables UTF-8 headers"
  category: policy
  kind: python_call_eq
  function: policy.SMTPUTF8.utf8.__eq__
  args: [true]
  expected: true

invariant email_extra2.policy.SMTP.linesep:
  description: "email.policy.SMTP.linesep == '\\r\\n' — SMTP policy uses CRLF line endings"
  category: policy
  kind: python_call_eq
  function: policy.SMTP.linesep.__eq__
  args: ["\r\n"]
  expected: true
