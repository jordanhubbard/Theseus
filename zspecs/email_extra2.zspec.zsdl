spec: email_extra2
version: ">=3.0"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "Python 3 email package documentation — https://docs.python.org/3/library/email.html"
    - "Python 3 email.generator documentation — https://docs.python.org/3/library/email.generator.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/__init__.py"
    - "CPython source: Lib/email/generator.py"
    - "email_extra.zspec.zsdl — covers top-level convenience functions and message_from_string parsing"
    - "email_message.zspec.zsdl — covers email.message.Message and EmailMessage class behavior"
    - "email_generator.zspec.zsdl — not yet written; this spec seeds generator class name coverage"
  notes:
    - "email.message_from_string.__name__ == 'message_from_string' — convenience function name."
    - "email.message_from_bytes.__name__ == 'message_from_bytes' — convenience function name."
    - "email.message_from_file.__name__ == 'message_from_file' — convenience function name."
    - "email.__name__.__class__.__name__ == 'str' — the package __name__ attribute is always a str."
    - "Note: email.__version__ does not exist in Python 3.12+; email.__name__ is used to verify str type."
    - "email.generator.Generator.__name__ == 'Generator' — text output generator class."
    - "email.generator.BytesGenerator.__name__ == 'BytesGenerator' — binary output generator class."
    - "email.generator.Generator.__module__ == 'email.generator' — module location."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Convenience function name checks
# ---------------------------------------------------------------------------

table email_extra2.function_names:
  description: "email top-level convenience functions have correct __name__ attributes"
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [message_from_string, message_from_string.__name__.__eq__, ["message_from_string"], true]
    - [message_from_bytes,  message_from_bytes.__name__.__eq__,  ["message_from_bytes"],  true]
    - [message_from_file,   message_from_file.__name__.__eq__,   ["message_from_file"],   true]

# ---------------------------------------------------------------------------
# Package __name__ is a str
#
# email.__version__ does not exist in Python 3.12+. Instead we confirm that
# the package __name__ attribute (always present) is a str instance.
# ---------------------------------------------------------------------------

invariant email_extra2.package.name_is_str:
  description: "email.__name__.__class__.__name__ == 'str'"
  category: package
  kind: python_call_eq
  function: __name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# email.generator — Generator and BytesGenerator class names
# ---------------------------------------------------------------------------

invariant email_extra2.generator.Generator.class_name:
  description: "email.generator.Generator.__name__ == 'Generator'"
  category: generator
  kind: python_call_eq
  function: generator.Generator.__name__.__eq__
  args: ["Generator"]
  expected: true

invariant email_extra2.generator.BytesGenerator.class_name:
  description: "email.generator.BytesGenerator.__name__ == 'BytesGenerator'"
  category: generator
  kind: python_call_eq
  function: generator.BytesGenerator.__name__.__eq__
  args: ["BytesGenerator"]
  expected: true
