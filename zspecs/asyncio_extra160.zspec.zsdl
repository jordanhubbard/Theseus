spec: asyncio_extra160
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec covers: asyncio.Queue, asyncio.PriorityQueue, and asyncio.LifoQueue class identity. asyncio.Queue.__name__=='Queue' (len=5); asyncio.Queue.__module__=='asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14; Python-implemented queue classes live in the asyncio.queues submodule, NOT in '_asyncio' the C extension — contrasting with asyncio.Future and asyncio.Task which are C-accelerated with __module__=='_asyncio'); asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (len=15; Queue inherits from _LoopBoundMixin, not from object directly — the mixin binds the queue to the running event loop); asyncio.PriorityQueue.__name__=='PriorityQueue' (len=13); asyncio.PriorityQueue.__module__=='asyncio.queues' (same submodule as Queue); asyncio.PriorityQueue.__bases__[0].__name__=='Queue' (PriorityQueue inherits from Queue, adding min-heap ordering); asyncio.LifoQueue.__bases__[0].__name__=='Queue' (LifoQueue also inherits from Queue, adding stack/LIFO ordering). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.__module__=='asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14; NOT '_asyncio') — asyncio.Queue is a pure Python class defined in Lib/asyncio/queues.py; this is the opposite of asyncio.Future and asyncio.Task which are C-accelerated (module='_asyncio'); asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (len=15: '_'=1+'LoopBoundMixin'=14=15; '_LoopBoundMixin' is a private mixin that makes the queue raise RuntimeError if used outside the running event loop); compare: asyncio.Lock.__bases__[0].__name__=='_ContextManagerMixin' (established in extra158). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.PriorityQueue.__bases__[0].__name__=='Queue' and asyncio.LifoQueue.__bases__[0].__name__=='Queue' — both PriorityQueue and LifoQueue inherit from asyncio.Queue; PriorityQueue uses a min-heap (heapq) internally so items are retrieved in lowest-first order; LifoQueue uses a list as a stack so the last item put() is the first item get(); compare: asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (Queue is the root queue class, inheriting from the loop mixin) while PriorityQueue and LifoQueue both inherit from Queue (one level deeper). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue class identity — extra160
#
# asyncio.Queue.__name__.__eq__('Queue')                              == True
# asyncio.Queue.__module__.__eq__('asyncio.queues')                   == True
# asyncio.Queue.__bases__[0].__name__.__eq__('_LoopBoundMixin')       == True
# ---------------------------------------------------------------------------

table asyncio_extra160.asyncio_queue_identity:
  description: "asyncio.Queue class identity checks in asyncioq160 namespace — asyncio.Queue.__name__=='Queue' (len=5: 'Q'+'u'+'e'+'u'+'e'=5; the asyncio coroutine-safe FIFO queue; supports put(), get(), put_nowait(), get_nowait(), empty(), full(), qsize(), join(), and task_done()); asyncio.Queue.__module__=='asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14; defined in Lib/asyncio/queues.py — NOT the C extension '_asyncio'; contrast: asyncio.Future.__module__=='_asyncio' (len=8; C-accelerated), asyncio.Queue.__module__=='asyncio.queues' (len=14; pure Python)); asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (len=15: '_'=1+'LoopBoundMixin'=14=15; Queue inherits from the private _LoopBoundMixin that binds queue operations to the currently running event loop — it raises RuntimeError if no loop is running); Queue.__name__.__len__()==5; compare: asyncio.PriorityQueue.__name__.__len__()==13 (8 longer); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioq160

  columns: [id, function, args, expected, description]
  rows:
    - [queue_name_eq,   asyncio.Queue.__name__.__eq__,                          ["Queue"],           true,  "asyncio.Queue.__name__ == 'Queue' (len=5; asyncio FIFO coroutine-safe queue); verified with Python 3.14.3"]
    - [queue_mod_eq,    asyncio.Queue.__module__.__eq__,                         ["asyncio.queues"],  true,  "asyncio.Queue.__module__ == 'asyncio.queues' (len=14; pure Python, NOT C extension '_asyncio'); verified with Python 3.14.3"]
    - [queue_base_eq,   "asyncio.Queue.__bases__[0].__name__.__eq__",            ["_LoopBoundMixin"], true,  "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' (private loop-binding mixin, not object); verified with Python 3.14.3"]
    - [queue_name_len,  asyncio.Queue.__name__.__len__,                          [],                  5,     "asyncio.Queue.__name__.__len__() == 5 ('Queue'; shorter than PriorityQueue=13 and LifoQueue=9); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.PriorityQueue class identity — extra160
#
# asyncio.PriorityQueue.__name__.__eq__('PriorityQueue')             == True
# asyncio.PriorityQueue.__module__.__eq__('asyncio.queues')          == True
# asyncio.PriorityQueue.__bases__[0].__name__.__eq__('Queue')        == True
# ---------------------------------------------------------------------------

table asyncio_extra160.asyncio_priority_queue_identity:
  description: "asyncio.PriorityQueue class identity checks in asynciopq160 namespace — asyncio.PriorityQueue.__name__=='PriorityQueue' (len=13: 'Priority'=8+'Queue'=5=13; the asyncio priority queue that retrieves items in lowest-first order using a min-heap; items must be comparable — typically (priority, item) tuples); asyncio.PriorityQueue.__module__=='asyncio.queues' (len=14; same submodule as Queue and LifoQueue — all three queue classes live in Lib/asyncio/queues.py); asyncio.PriorityQueue.__bases__[0].__name__=='Queue' (len=5; PriorityQueue inherits from Queue — it IS-A Queue that overrides _get() to use heapq.heappop() and _put() to use heapq.heappush()); PriorityQueue.__name__.__len__()==13 (longest of the three asyncio queue class names); compare: Queue(5) < LifoQueue(9) < PriorityQueue(13); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciopq160

  columns: [id, function, args, expected, description]
  rows:
    - [pq_name_eq,   asyncio.PriorityQueue.__name__.__eq__,                ["PriorityQueue"],   true,  "asyncio.PriorityQueue.__name__ == 'PriorityQueue' (len=13; min-heap priority queue); verified with Python 3.14.3"]
    - [pq_mod_eq,    asyncio.PriorityQueue.__module__.__eq__,               ["asyncio.queues"],  true,  "asyncio.PriorityQueue.__module__ == 'asyncio.queues' (len=14; same module as Queue and LifoQueue); verified with Python 3.14.3"]
    - [pq_base_eq,   "asyncio.PriorityQueue.__bases__[0].__name__.__eq__",  ["Queue"],           true,  "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue' (inherits from Queue, adds heapq ordering); verified with Python 3.14.3"]
    - [pq_name_len,  asyncio.PriorityQueue.__name__.__len__,                [],                  13,    "asyncio.PriorityQueue.__name__.__len__() == 13 ('PriorityQueue'; longest queue class name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.LifoQueue base and asyncio.Queue module length — extra160
#
# asyncio.LifoQueue.__bases__[0].__name__.__eq__('Queue')            == True
# asyncio.LifoQueue.__module__.__eq__('asyncio.queues')              == True
# asyncio.Queue.__module__.__len__()                                 == 14
# ---------------------------------------------------------------------------

table asyncio_extra160.asyncio_lifo_queue_and_module:
  description: "asyncio.LifoQueue base identity and module length checks in asynciolq160 namespace — asyncio.LifoQueue.__bases__[0].__name__=='Queue' (len=5; LifoQueue inherits from Queue — it IS-A Queue that overrides _get() to use list.pop() for LIFO/stack ordering instead of list.pop(0) for FIFO; last in, first out); asyncio.LifoQueue.__module__=='asyncio.queues' (len=14; same module as Queue and PriorityQueue); asyncio.Queue.__module__.__len__()==14 ('asyncio.queues'=14: 'asyncio'=7+'.'=1+'queues'=6=14); LifoQueue.__name__.__len__()==9 ('LifoQueue'=9: 'Lifo'=4+'Queue'=5=9); name length ordering: Queue(5) < LifoQueue(9) < PriorityQueue(13); all three asyncio queue classes share __module__=='asyncio.queues'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolq160

  columns: [id, function, args, expected, description]
  rows:
    - [lq_base_eq,   "asyncio.LifoQueue.__bases__[0].__name__.__eq__",  ["Queue"],           true,  "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue' (LIFO stack queue inherits from Queue); verified with Python 3.14.3"]
    - [lq_mod_eq,    asyncio.LifoQueue.__module__.__eq__,                ["asyncio.queues"],  true,  "asyncio.LifoQueue.__module__ == 'asyncio.queues' (len=14; same module as Queue and PriorityQueue); verified with Python 3.14.3"]
    - [q_mod_len,    asyncio.Queue.__module__.__len__,                   [],                  14,    "asyncio.Queue.__module__.__len__() == 14 ('asyncio.queues'); verified with Python 3.14.3"]
    - [lq_name_len,  asyncio.LifoQueue.__name__.__len__,                 [],                  9,     "asyncio.LifoQueue.__name__.__len__() == 9 ('LifoQueue'; between Queue=5 and PriorityQueue=13); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra160
# ---------------------------------------------------------------------------

invariant asyncio_extra160.asyncio_Queue_name_eq:
  description: "asyncio.Queue.__name__.__eq__('Queue') returns True — asyncio.Queue is the pure-Python asyncio FIFO queue class; Queue.__name__=='Queue' (len=5: 'Q'+'u'+'e'+'u'+'e'=5); asyncio.Queue supports put(item), get(), put_nowait(item), get_nowait(), empty(), full(), qsize(), task_done(), and join(); it is coroutine-safe and designed for producer-consumer patterns in async code; Queue.__module__=='asyncio.queues' (len=14: NOT '_asyncio' — this distinguishes asyncio.Queue from asyncio.Future and asyncio.Task which are C-accelerated with __module__=='_asyncio' (len=8)); Queue.__bases__[0].__name__=='_LoopBoundMixin' (Queue inherits from _LoopBoundMixin, the private loop-binding mixin — NOT from object directly); compare: asyncio.PriorityQueue.__name__=='PriorityQueue' (len=13; inherits from Queue); asyncio.LifoQueue.__name__=='LifoQueue' (len=9; also inherits from Queue); NEW in extra160: first standalone asyncio.Queue.__name__ identity invariant in asyncioq160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant asyncio_extra160.asyncio_Queue_module_eq:
  description: "asyncio.Queue.__module__.__eq__('asyncio.queues') returns True — asyncio.Queue is defined in Lib/asyncio/queues.py; its __module__ is 'asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14); this is a key distinction from asyncio.Future and asyncio.Task which have __module__=='_asyncio' (len=8; the C extension module); asyncio.Queue is pure Python while Future and Task are C-accelerated; all three asyncio queue classes (Queue, PriorityQueue, LifoQueue) share __module__=='asyncio.queues'; compare module lengths: '_asyncio' (len=8) < 'asyncio.queues' (len=14) < 'asyncio.locks' (len=13)... wait: 'asyncio.locks'==13 < 'asyncio.queues'==14; asyncio.queues (14) is 1 char longer than asyncio.locks (13) because 'queues'=6 > 'locks'=5; NEW in extra160: first standalone asyncio.Queue.__module__ identity invariant in asyncioq160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra160.asyncio_Queue_base_is_LoopBoundMixin:
  description: "asyncio.Queue.__bases__[0].__name__.__eq__('_LoopBoundMixin') returns True — asyncio.Queue inherits from _LoopBoundMixin (a private mixin class defined in Lib/asyncio/queues.py); __bases__[0].__name__=='_LoopBoundMixin' (len=15: '_'=1+'Loop'=4+'Bound'=5+'Mixin'=5=15); _LoopBoundMixin ensures the queue raises RuntimeError if used when no event loop is running; this is a different base than asyncio.Lock which inherits from '_ContextManagerMixin' (established in extra158); Queue does NOT inherit from _ContextManagerMixin because queues use await put()/get() rather than async with; compare: asyncio.PriorityQueue.__bases__[0].__name__=='Queue' and asyncio.LifoQueue.__bases__[0].__name__=='Queue' (both subqueues inherit from Queue, not from _LoopBoundMixin directly); NEW in extra160: first standalone asyncio.Queue.__bases__[0].__name__ identity invariant in asyncioq160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Queue.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra160.asyncio_PriorityQueue_base_is_Queue:
  description: "asyncio.PriorityQueue.__bases__[0].__name__.__eq__('Queue') returns True — asyncio.PriorityQueue inherits from asyncio.Queue; __bases__[0].__name__=='Queue' (len=5); PriorityQueue is a Queue subclass that stores items in a min-heap so the smallest item is retrieved first; items should be comparable (tuples like (priority_number, data) work well); PriorityQueue overrides _get() to use heapq.heappop() and _put() to use heapq.heappush(); because it inherits from Queue, PriorityQueue supports all Queue methods (put, get, empty, full, qsize, task_done, join); compare: asyncio.LifoQueue.__bases__[0].__name__=='Queue' (LifoQueue also inherits from Queue — same pattern); both PriorityQueue and LifoQueue are Queue subclasses while Queue itself inherits from _LoopBoundMixin; NEW in extra160: first standalone asyncio.PriorityQueue.__bases__[0].__name__ identity invariant in asynciopq160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.PriorityQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant asyncio_extra160.asyncio_LifoQueue_base_is_Queue:
  description: "asyncio.LifoQueue.__bases__[0].__name__.__eq__('Queue') returns True — asyncio.LifoQueue inherits from asyncio.Queue; __bases__[0].__name__=='Queue' (len=5); LifoQueue is a Queue subclass that stores items in a list and retrieves the most recently added item first (last-in, first-out / stack ordering); LifoQueue overrides _get() to use list.pop() (removes and returns the last element) instead of list.pop(0) (FIFO); LifoQueue.__name__=='LifoQueue' (len=9: 'Lifo'=4+'Queue'=5=9); name length ordering: Queue(5) < LifoQueue(9) < PriorityQueue(13); both LifoQueue and PriorityQueue share Queue as their first base, making them siblings in the asyncio queue hierarchy; NEW in extra160: first standalone asyncio.LifoQueue.__bases__[0].__name__ identity invariant in asynciolq160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.LifoQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true
