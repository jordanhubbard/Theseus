spec: tokenize
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tokenize.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "tokenize source: Lib/tokenize.py (PSF; source inspection permitted)"
  not_derived_from:
    - "tokenize source: internal CPython grammar/parser implementation details"
  notes:
    - "tokenize re-exports core token constants from the 'token' module (NAME, NUMBER, STRING, NEWLINE, INDENT, DEDENT, OP, NL) and adds its own (COMMENT, ENCODING)."
    - "Specific integer values for COMMENT and ENCODING differ across Python versions and are NOT tested here. Only __class__.__name__ == 'int' is verified."
    - "tokenize.tokenize() and tokenize.generate_tokens() are generator functions that accept a readline callable; they are not called here."
    - "tokenize.detect_encoding() accepts a readline callable and returns an (encoding, bom_list) tuple; it is not called here."
    - "All class name checks use __class__.__name__.__eq__('int') because the token constants are plain Python ints."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "tokenize raises tokenize.TokenError for unterminated string or multi-line construct, and IndentationError for bad indentation."
  stderr: "null"
  stickiness: "N/A — all tested invariants are stateless attribute reads."
  codes: {}

# ---------------------------------------------------------------------------
# Token type constants — all are plain ints.
# Specific values are version-dependent; only the type is checked.
# ---------------------------------------------------------------------------

table tokenize.core_token_types:
  kind: python_call_eq
  category: constants
  id_prefix: toktype

  columns: [id, function, args, expected]
  rows:
    - [name,    NAME.__class__.__name__.__eq__,    ["int"], true]
    - [number,  NUMBER.__class__.__name__.__eq__,  ["int"], true]
    - [string,  STRING.__class__.__name__.__eq__,  ["int"], true]
    - [newline, NEWLINE.__class__.__name__.__eq__,  ["int"], true]
    - [indent,  INDENT.__class__.__name__.__eq__,   ["int"], true]
    - [dedent,  DEDENT.__class__.__name__.__eq__,   ["int"], true]
    - [op,      OP.__class__.__name__.__eq__,        ["int"], true]

table tokenize.extended_token_types:
  kind: python_call_eq
  category: constants
  id_prefix: xtoktype

  columns: [id, function, args, expected]
  rows:
    - [comment,  COMMENT.__class__.__name__.__eq__,  ["int"], true]
    - [encoding, ENCODING.__class__.__name__.__eq__, ["int"], true]
    - [nl,       NL.__class__.__name__.__eq__,        ["int"], true]

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table tokenize.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fnname

  columns: [id, function, args, expected]
  rows:
    - [tokenize,        tokenize.__name__.__eq__,        ["tokenize"],        true]
    - [generate_tokens, generate_tokens.__name__.__eq__,  ["generate_tokens"], true]
    - [detect_encoding, detect_encoding.__name__.__eq__,  ["detect_encoding"], true]
