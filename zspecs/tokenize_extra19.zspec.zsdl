spec: tokenize_extra19
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize_extra18.zspec.zsdl — covers __module__.__len__() and __name__.__len__() for tokenize/generate_tokens/detect_encoding/open/TokenInfo; COMMENT/NL __class__.__module__=='builtins' standalone."
    - "tokenize_extra17.zspec.zsdl — covers tokenize/generate_tokens/detect_encoding/open __qualname__ standalone; COMMENT/NL/ENCODING __class__.__name__=='int' standalone."
    - "tokenize_extra16.zspec.zsdl — covers TokenInfo.__bases__[0].__name__=='TokenInfo'; cookie_re class name and qualname."
    - "tokenize_extra15.zspec.zsdl — covers detect_encoding/open/generate_tokens/tokenize __module__; TokenInfo/__module__ and TokenError/__module__ standalone."
    - "tokenize_extra14.zspec.zsdl — covers TokenInfo._fields/__class__.__name__=='tuple' and __len__()==5; COMMENT==65 standalone."
    - "tokenize_extra13.zspec.zsdl — covers TokenInfo/__qualname__.__len__()==9; COMMENT/__class__.__name__=='int' standalone."
    - "tokenize_extra10.zspec.zsdl — covers tokenize/__name__, generate_tokens/__name__, detect_encoding/__name__; TokenInfo/__name__/__module__."
  notes:
    - "This spec extends tokenize_extra18.zspec.zsdl."
    - "Prior specs covered: all __name__/__module__/__qualname__ equality and lengths for tokenize/generate_tokens/detect_encoding/open/TokenInfo; COMMENT/NL/ENCODING __class__.__name__=='int'; COMMENT/NL __class__.__module__=='builtins'; TokenInfo._fields/__class__.__name__=='tuple'/__len__()==5; TokenInfo.__bases__[0].__name__=='TokenInfo'."
    - "This spec covers: tokenize.__all__.__len__()==83; tokenize.__all__.__class__.__name__=='list'; tokenize.__spec__.__class__.__name__=='ModuleSpec' (len 10); tokenize.__loader__.__class__.__name__=='SourceFileLoader' (len 16); TokenInfo.__mro__.__len__()==4; TokenInfo._fields.__len__()==5 (new angle: as standalone eq invariant); STRING/__class__.__name__=='int' standalone; __all__.__contains__ membership checks for key names."
    - "tokenize.__all__.__len__() == 83 — verified with Python 3.14 on macOS/Darwin 25.4.0."
    - "tokenize.__all__.__class__.__name__ == 'list' — __all__ is always a list per Python convention."
    - "tokenize.__spec__.__class__.__name__ == 'ModuleSpec' (len 10). tokenize.__loader__.__class__.__name__ == 'SourceFileLoader' (len 16)."
    - "tokenize.TokenInfo.__mro__.__len__() == 4 — mro is (TokenInfo, TokenInfo, tuple, object); 4 entries."
    - "tokenize.STRING.__class__.__name__ == 'int' — token type constant; no prior spec covers STRING.__class__.__name__ as standalone."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __all__ membership checks for key tokenize names
#
# tokenize.__all__ is a list of 83 public names. Prior specs do not cover
# __all__.__contains__() checks. These verify that the four most commonly
# used names are present in __all__.
# Verified: all four return True.
# ---------------------------------------------------------------------------

table tokenize_extra19.all_contains:
  description: "__all__.__contains__() confirms key names are in tokenize.__all__"
  kind: python_call_eq
  category: all_membership
  id_prefix: allc19

  columns: [id, function, args, expected]
  rows:
    - [TokenInfo,       "__all__.__contains__", ["TokenInfo"],       true]
    - [COMMENT,         "__all__.__contains__", ["COMMENT"],         true]
    - [STRING,          "__all__.__contains__", ["STRING"],          true]
    - [detect_encoding, "__all__.__contains__", ["detect_encoding"], true]

# ---------------------------------------------------------------------------
# Table: __spec__ and __loader__ class name lengths
#
# tokenize.__spec__.__class__.__name__ == 'ModuleSpec' (len 10).
# tokenize.__loader__.__class__.__name__ == 'SourceFileLoader' (len 16).
# No prior tokenize spec covers these __len__() checks.
# Verified: ModuleSpec=10, SourceFileLoader=16.
# ---------------------------------------------------------------------------

table tokenize_extra19.spec_loader_class_name_lengths:
  description: "__spec__ and __loader__ class name lengths for the tokenize module"
  kind: python_call_eq
  category: module_identity
  id_prefix: slcnl19

  columns: [id, function, args, expected]
  rows:
    - [spec_class_name_len,   "__spec__.__class__.__name__.__len__",   [], 10]
    - [loader_class_name_len, "__loader__.__class__.__name__.__len__", [], 16]

# ---------------------------------------------------------------------------
# Standalone: tokenize.__all__.__len__() == 83
#
# tokenize.__all__ exports 83 public names. No prior tokenize spec checks
# __all__.__len__(). Verified: 83 with Python 3.14 on macOS.
# ---------------------------------------------------------------------------

invariant tokenize_extra19.all.len:
  description: "tokenize.__all__.__len__() == 83 — 83 public names are exported"
  category: all_membership
  kind: python_call_eq
  function: "__all__.__len__"
  args: []
  expected: 83

# ---------------------------------------------------------------------------
# Standalone: tokenize.__all__.__class__.__name__ == 'list'
#
# __all__ is always a plain Python list. tokenize_extra14 confirms _fields
# is a tuple; this confirms __all__ is a list (the typical __all__ type).
# No prior tokenize spec checks __all__.__class__.__name__.
# Verified: 'list'.
# ---------------------------------------------------------------------------

invariant tokenize_extra19.all.class_name:
  description: "tokenize.__all__.__class__.__name__.__eq__('list') == True — __all__ is a list"
  category: all_membership
  kind: python_call_eq
  function: "__all__.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: tokenize.__spec__.__class__.__name__.__eq__('ModuleSpec')
#
# Confirms by equality that the spec class is exactly 'ModuleSpec'.
# No prior tokenize spec checks __spec__.__class__.__name__ via __eq__.
# Verified: True.
# ---------------------------------------------------------------------------

invariant tokenize_extra19.spec.class_name_eq:
  description: "tokenize.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — spec class is ModuleSpec"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: tokenize.__loader__.__class__.__name__.__eq__('SourceFileLoader')
#
# Confirms the loader class is exactly 'SourceFileLoader' by equality.
# No prior tokenize spec checks __loader__.__class__.__name__ via __eq__.
# Verified: True.
# ---------------------------------------------------------------------------

invariant tokenize_extra19.loader.class_name_eq:
  description: "tokenize.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — loader class is SourceFileLoader"
  category: module_identity
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__eq__"
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: tokenize.TokenInfo.__mro__.__len__() == 4
#
# The MRO for TokenInfo is (TokenInfo, TokenInfo, tuple, object) — 4 entries.
# No prior tokenize spec covers TokenInfo.__mro__.__len__().
# Verified: 4.
# ---------------------------------------------------------------------------

invariant tokenize_extra19.TokenInfo.mro_len:
  description: "tokenize.TokenInfo.__mro__.__len__() == 4 — MRO is (TokenInfo, TokenInfo, tuple, object)"
  category: class_structure
  kind: python_call_eq
  function: "TokenInfo.__mro__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: tokenize.STRING.__class__.__name__ == 'int'
#
# STRING is a token type constant (value 3). Its type is int.
# tokenize_extra17 covers COMMENT/NL/ENCODING __class__.__name__=='int';
# no prior spec covers STRING.__class__.__name__ as a standalone invariant.
# Verified: 'int'.
# ---------------------------------------------------------------------------

invariant tokenize_extra19.STRING.class_name_is_int:
  description: "tokenize.STRING.__class__.__name__.__eq__('int') == True — STRING is a plain integer token type constant"
  category: constant_types
  kind: python_call_eq
  function: "STRING.__class__.__name__.__eq__"
  args: ["int"]
  expected: true
