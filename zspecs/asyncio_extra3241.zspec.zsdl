    - ["as3241023", operator.contains, [asyncio.Event.__dict__,            "__rmod__"], false]
    - ["as3241024", operator.contains, [asyncio.Lock.__dict__,             "__rmod__"], false]
    - ["as3241025", operator.contains, [asyncio.Semaphore.__dict__,        "__rmod__"], false]
    - ["as3241026", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__rmod__"], false]
    - ["as3241027", operator.contains, [asyncio.Condition.__dict__,        "__rmod__"], false]
    - ["as3241028", operator.contains, [asyncio.Queue.__dict__,            "__rmod__"], false]
    - ["as3241029", operator.contains, [asyncio.PriorityQueue.__dict__,    "__rmod__"], false]
    - ["as3241030", operator.contains, [asyncio.LifoQueue.__dict__,        "__rmod__"], false]

# ---------------------------------------------------------------------------
# combined — __rtruediv__, __rfloordiv__, __rmod__ across all 10 asyncio subjects
#
# Covers the full matrix: 10 classes x 3 methods = 30 rows.
# __rtruediv__: false for all 10 — reflected true division is not defined.
# __rfloordiv__: false for all 10 — reflected floor division is not defined.
# __rmod__: false for all 10 — reflected modulo is not defined.
# All 30 values are false.
# asyncio types are designed for coroutine-based concurrency — their entire
#   API surface is expressed through await, async with, async for, and
#   explicit method calls. Neither forward nor reflected division/modulo
#   operators appear anywhere in the asyncio type hierarchy.
# asyncio.Queue note: Queue is an ordered item store. It does not support
#   format-string % interpolation (__rmod__) like str, nor does it support
#   true division or floor division from either side.
# asyncio.Semaphore note: the permit counter is a positive integer, but it is
#   fully encapsulated. Reflected division/modulo on the semaphore itself is
#   not exposed through any part of the API.
# This wave continues the unbroken all-false run from wave 656 (__call__/
#   __len__/__getitem__) through wave 663 (__rtruediv__/__rfloordiv__/__rmod__)
#   — eight consecutive waves of 100% false results for asyncio types.
# ---------------------------------------------------------------------------

