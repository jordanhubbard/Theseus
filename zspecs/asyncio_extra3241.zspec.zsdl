    - ["as3241007", operator.contains, [asyncio.Condition.__dict__,        "__rtruediv__"], false]
    - ["as3241008", operator.contains, [asyncio.Queue.__dict__,            "__rtruediv__"], false]
    - ["as3241009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__rtruediv__"], false]
    - ["as3241010", operator.contains, [asyncio.LifoQueue.__dict__,        "__rtruediv__"], false]

# ---------------------------------------------------------------------------
# __rfloordiv__ dict-presence — operator.contains(Cls.__dict__, '__rfloordiv__')
#
# All 10 asyncio classes return false for __rfloordiv__.
# Reflected floor division (__rfloordiv__) is the mirror of __floordiv__; it
#   is invoked when the left operand's __floordiv__ returns NotImplemented.
# asyncio types define no __floordiv__ (confirmed false in wave 659), so
#   __rfloordiv__ is also absent.
# asyncio.Event/Lock/Condition/Semaphore/BoundedSemaphore: synchronization
#   primitives with no arithmetic semantics.
# asyncio.Task/Future: pending coroutine results; floor division is undefined
#   from either side of the operator.
# asyncio.Queue/PriorityQueue/LifoQueue: ordered stores with no numeric
#   or floor-division data model.
# ---------------------------------------------------------------------------

