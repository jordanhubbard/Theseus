spec: threading_extra68
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra67.zspec.zsdl."
    - "Wave 233 theme: __defaults__ for threading functions + Event/Condition/BoundedSemaphore identity."
    - "Thread.__init__.__defaults__.__class__.__name__ == 'tuple' — Thread.__init__(self, group=None, target=None, name=None, args=(), kwargs=None, *, daemon=None) has 5 positional defaults (group/target/name/args/kwargs); __defaults__ is a 5-element tuple. Verified with Python 3.14.3."
    - "Thread.__init__.__defaults__.__len__() == 5 — the five positional defaults are None, None, None, (), None. Verified with Python 3.14.3."
    - "Thread.start.__defaults__ is None — def start(self) has no default values; __defaults__ is None → 'NoneType'. Verified with Python 3.14.3."
    - "Thread.run.__defaults__ is None — def run(self) has no default values; __defaults__ is None → 'NoneType'. Verified with Python 3.14.3."
    - "current_thread.__defaults__ is None — def current_thread() has no parameters at all; __defaults__ is None → 'NoneType'. Verified with Python 3.14.3."
    - "Event.__class__.__name__ == 'type' — Event is a pure-Python class in Lib/threading.py; its metaclass is the built-in type. Verified with Python 3.14.3."
    - "Event.__module__ == 'threading' — Event is defined in and exported from the threading module. Verified with Python 3.14.3."
    - "Event.__qualname__ == 'Event' — Event is a top-level class so its qualname equals its simple name. Verified with Python 3.14.3."
    - "Condition.__class__.__name__ == 'type' — Condition is a pure-Python class in Lib/threading.py; its metaclass is type. Verified with Python 3.14.3."
    - "Condition.__module__ == 'threading' — Condition is defined in the threading module. Verified with Python 3.14.3."
    - "BoundedSemaphore.__class__.__name__ == 'type' — BoundedSemaphore is a pure-Python class in Lib/threading.py; its metaclass is type. Verified with Python 3.14.3."
    - "Prior threading_extra67 covered co_consts/co_nlocals/co_stacksize for Thread.__init__/start/current_thread and Thread.__doc__ content."
    - "No prior threading spec checks __defaults__ for Thread.__init__/start/run/current_thread, or checks Event/Condition/BoundedSemaphore class identity attributes. All checks in this spec are new to extra68."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread.__init__.__defaults__ — extra68
#
# Wave 233 theme: __defaults__ for Thread.__init__.
#
# Thread.__init__ signature:
#   def __init__(self, group=None, target=None, name=None, args=(), kwargs=None,
#                *, daemon=None)
#
# The keyword-only parameter 'daemon' (after the bare *) is in __kwdefaults__,
# not __defaults__. The positional parameters with defaults are:
#   group=None, target=None, name=None, args=(), kwargs=None → 5 defaults
#
# Therefore:
#   Thread.__init__.__defaults__.__class__.__name__ == 'tuple'
#   Thread.__init__.__defaults__.__len__() == 5
#
# No prior threading spec checks Thread.__init__.__defaults__. New to extra68.
# ---------------------------------------------------------------------------

table threading_extra68.Thread_defaults:
  description: "Thread.__init__.__defaults__ is a 5-element tuple; __class__.__name__=='tuple', __len__()==5; wave 233 __defaults__ checks; new to extra68"
  kind: python_call_eq
  category: defaults_type
  id_prefix: thrddef68

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_init_defaults_class_name_eq_tuple,
       Thread.__init__.__defaults__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "threading.Thread.__init__.__defaults__.__class__.__name__.__eq__('tuple') == True — Thread.__init__ is a pure-Python method (Lib/threading.py) with signature __init__(self, group=None, target=None, name=None, args=(), kwargs=None, *, daemon=None); the five positional parameters group/target/name/args/kwargs all have default values, so __defaults__ is a 5-element tuple (None, None, None, (), None); tuple.__name__ == 'tuple' (5 chars); __eq__ returns True; no prior threading spec checks Thread.__init__.__defaults__.__class__.__name__; new to extra68"]
    - [Thread_init_defaults_len_eq_5,
       Thread.__init__.__defaults__.__len__,
       [],
       5,
       "threading.Thread.__init__.__defaults__.__len__() == 5 — Thread.__init__(self, group=None, target=None, name=None, args=(), kwargs=None, *, daemon=None) has 5 positional parameters with defaults (daemon is keyword-only and excluded from __defaults__); __defaults__ == (None, None, None, (), None), a 5-element tuple; tuple.__len__() returns 5; no prior threading spec checks Thread.__init__.__defaults__.__len__(); new to extra68"]

# ---------------------------------------------------------------------------
# Threading functions with no positional defaults — extra68
#
# Wave 233 theme: __defaults__ is None for Thread.start/Thread.run/current_thread.
#
# Python functions with no positional defaults have __defaults__ == None.
# For these threading functions, None.__class__.__name__ == 'NoneType'.
#
# Thread.start    — def start(self) → no defaults → __defaults__ is None
# Thread.run      — def run(self) → no defaults → __defaults__ is None
# current_thread  — def current_thread() → no parameters → __defaults__ is None
#
# No prior threading spec checks __defaults__ for any of these. New to extra68.
# ---------------------------------------------------------------------------

table threading_extra68.none_defaults:
  description: "Thread.start/Thread.run/current_thread __defaults__.__class__.__name__=='NoneType' — no positional defaults so __defaults__ is None; wave 233 __defaults__ checks; new to extra68"
  kind: python_call_eq
  category: defaults_type
  id_prefix: thrddef68

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_start_defaults_class_name_eq_NoneType,
       Thread.start.__defaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "threading.Thread.start.__defaults__.__class__.__name__.__eq__('NoneType') == True — Thread.start is a pure-Python method (Lib/threading.py) with signature start(self); it has only the implicit 'self' parameter and no default values; therefore __defaults__ is None; None.__class__ is the NoneType type and NoneType.__name__ == 'NoneType' (8 chars); __eq__ returns True; no prior threading spec checks Thread.start.__defaults__.__class__.__name__; new to extra68"]
    - [Thread_run_defaults_class_name_eq_NoneType,
       Thread.run.__defaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "threading.Thread.run.__defaults__.__class__.__name__.__eq__('NoneType') == True — Thread.run is a pure-Python method (Lib/threading.py) with signature run(self); no default values so __defaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior threading spec checks Thread.run.__defaults__.__class__.__name__; new to extra68"]
    - [current_thread_defaults_class_name_eq_NoneType,
       current_thread.__defaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "threading.current_thread.__defaults__.__class__.__name__.__eq__('NoneType') == True — current_thread is a pure-Python module-level function (Lib/threading.py) with signature current_thread(); it takes no parameters at all; therefore __defaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior threading spec checks current_thread.__defaults__.__class__.__name__; new to extra68"]

# ---------------------------------------------------------------------------
# threading.Event class identity — extra68
#
# Wave 233 theme: Event is a pure-Python class in Lib/threading.py.
#
# Event.__class__.__name__ == 'type'   (metaclass is the built-in type)
# Event.__module__         == 'threading'
# Event.__qualname__       == 'Event'
#
# Event is a top-level class (no enclosing class or function), so its
# __qualname__ equals its simple name. It is defined in and belongs to the
# threading module.
#
# No prior threading spec checks these Event identity attributes. New to extra68.
# ---------------------------------------------------------------------------

table threading_extra68.Event_identity:
  description: "Event class identity: __class__.__name__=='type', __module__=='threading', __qualname__=='Event'; wave 233 Event identity; new to extra68"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrddef68

  columns: [id, function, args, expected, description]
  rows:
    - [Event_class_name_eq_type,
       Event.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Event.__class__.__name__.__eq__('type') == True — Event is a pure-Python class defined in Lib/threading.py; its metaclass is the built-in type (the default metaclass for classes that do not explicitly specify a different metaclass); type.__name__ == 'type' (4 chars); __eq__ returns True; no prior threading spec checks Event.__class__.__name__; new to extra68"]
    - [Event_module_eq_threading,
       Event.__module__.__eq__,
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is a pure-Python class defined in Lib/threading.py; its __module__ attribute is set to 'threading' when the module is imported; __eq__ on the str 'threading' returns True; no prior threading spec checks Event.__module__; new to extra68"]
    - [Event_qualname_eq_Event,
       Event.__qualname__.__eq__,
       ["Event"],
       true,
       "threading.Event.__qualname__.__eq__('Event') == True — Event is a top-level (non-nested) class in the threading module; its __qualname__ is therefore equal to its simple name 'Event' (5 chars); no intermediate class or function scope appears in the qualified name; __eq__ returns True; no prior threading spec checks Event.__qualname__; new to extra68"]

# ---------------------------------------------------------------------------
# threading.Condition and BoundedSemaphore identity — extra68
#
# Wave 233 theme: Condition and BoundedSemaphore are pure-Python classes.
#
# Condition.__class__.__name__         == 'type'
# Condition.__module__                 == 'threading'
# BoundedSemaphore.__class__.__name__  == 'type'
#
# Both Condition and BoundedSemaphore are pure-Python classes defined in
# Lib/threading.py, so their metaclass is the built-in type. Condition is
# a synchronization primitive (a re-entrant lock with wait/notify).
# BoundedSemaphore is a semaphore with an upper bound on the count.
#
# No prior threading spec checks these class identity attributes. New to extra68.
# ---------------------------------------------------------------------------

table threading_extra68.Condition_BoundedSemaphore_identity:
  description: "Condition/BoundedSemaphore class identity attributes; wave 233 class identity; new to extra68"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrddef68

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_class_name_eq_type,
       Condition.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Condition.__class__.__name__.__eq__('type') == True — Condition is a pure-Python class defined in Lib/threading.py that implements a condition variable (a synchronization primitive combining a lock with wait/notify); its metaclass is the built-in type; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior threading spec checks Condition.__class__.__name__; new to extra68"]
    - [Condition_module_eq_threading,
       Condition.__module__.__eq__,
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — Condition is a pure-Python class defined in Lib/threading.py; its __module__ attribute is set to 'threading'; __eq__ on the str 'threading' returns True; no prior threading spec checks Condition.__module__; new to extra68"]
    - [BoundedSemaphore_class_name_eq_type,
       BoundedSemaphore.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.BoundedSemaphore.__class__.__name__.__eq__('type') == True — BoundedSemaphore is a pure-Python class defined in Lib/threading.py that implements a semaphore with an upper bound preventing releases above the initial value; its metaclass is the built-in type; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior threading spec checks BoundedSemaphore.__class__.__name__; new to extra68"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra68
# ---------------------------------------------------------------------------

invariant threading_extra68.Thread_init_defaults_tuple:
  description: "threading.Thread.__init__.__defaults__.__class__.__name__.__eq__('tuple') == True — Thread.__init__ has 5 positional defaults; __defaults__ is a tuple; wave 233 __defaults__ checks; new to extra68"
  kind: python_call_eq
  function: Thread.__init__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant threading_extra68.Thread_init_defaults_len_5:
  description: "threading.Thread.__init__.__defaults__.__len__() == 5 — Thread.__init__ has exactly 5 positional defaults (group/target/name/args/kwargs); wave 233 __defaults__ length; new to extra68"
  kind: python_call_eq
  function: Thread.__init__.__defaults__.__len__
  args: []
  expected: 5

invariant threading_extra68.Thread_start_defaults_NoneType:
  description: "threading.Thread.start.__defaults__.__class__.__name__.__eq__('NoneType') == True — Thread.start(self) has no positional defaults; __defaults__ is None; wave 233 __defaults__ checks; new to extra68"
  kind: python_call_eq
  function: Thread.start.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant threading_extra68.Event_class_type:
  description: "threading.Event.__class__.__name__.__eq__('type') == True — Event is a pure-Python class whose metaclass is the built-in type; wave 233 Event identity; new to extra68"
  kind: python_call_eq
  function: Event.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra68.Event_module_threading:
  description: "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; wave 233 Event identity; new to extra68"
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true
