spec: threading_extra278
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Thread is a pure-Python class: __module__ == 'threading', __class__.__name__ == 'type'."
    - "Thread.start, Thread.join, Thread.run, Thread.is_alive are all pure-Python methods: __class__.__name__ == 'function'."
    - "Thread.start.__qualname__ == 'Thread.start' (12 chars); __module__ == 'threading'."
    - "Thread.join.__qualname__ == 'Thread.join' (11 chars); __module__ == 'threading'."
    - "Thread.run.__qualname__ == 'Thread.run' (10 chars); __module__ == 'threading'."
    - "Thread.is_alive.__qualname__ == 'Thread.is_alive' (15 chars); __module__ == 'threading'."
    - "Thread.daemon is a property: Thread.daemon.__class__.__name__ == 'property'."
    - "Thread.name is a property: Thread.name.__class__.__name__ == 'property'."
    - "Thread.__name__ == 'Thread' (6 chars); Thread.__module__ == 'threading'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Thread method qualnames — start, join, run, is_alive
#
# All four are pure-Python instance methods defined in threading.Thread.
# Thread.start.__qualname__ == 'Thread.start' (12 chars).
# Thread.join.__qualname__ == 'Thread.join' (11 chars).
# Thread.run.__qualname__ == 'Thread.run' (10 chars).
# Thread.is_alive.__qualname__ == 'Thread.is_alive' (15 chars).
# ---------------------------------------------------------------------------

table threading_extra278.thread_method_qualnames:
  description: "threading.Thread method qualnames — start, join, run, is_alive; qualname lengths; all pure-Python functions in threading; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex278tmq

  columns: [id, function, args, expected, description]
  rows:
    - [st_qn_eq,  Thread.start.__qualname__.__eq__,     ["Thread.start"],    true, "threading.Thread.start.__qualname__ == 'Thread.start'; verified with Python 3.14.3"]
    - [st_qn_len, Thread.start.__qualname__.__len__,     [],                  12,   "threading.Thread.start.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [st_mod_eq, Thread.start.__module__.__eq__,        ["threading"],       true, "threading.Thread.start.__module__ == 'threading'; verified with Python 3.14.3"]
    - [jo_qn_eq,  Thread.join.__qualname__.__eq__,       ["Thread.join"],     true, "threading.Thread.join.__qualname__ == 'Thread.join'; verified with Python 3.14.3"]
    - [jo_qn_len, Thread.join.__qualname__.__len__,       [],                  11,   "threading.Thread.join.__qualname__.__len__() == 11; verified with Python 3.14.3"]
    - [jo_mod_eq, Thread.join.__module__.__eq__,          ["threading"],       true, "threading.Thread.join.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ru_qn_eq,  Thread.run.__qualname__.__eq__,         ["Thread.run"],      true, "threading.Thread.run.__qualname__ == 'Thread.run'; verified with Python 3.14.3"]
    - [ru_qn_len, Thread.run.__qualname__.__len__,         [],                  10,   "threading.Thread.run.__qualname__.__len__() == 10; verified with Python 3.14.3"]
    - [ru_mod_eq, Thread.run.__module__.__eq__,            ["threading"],       true, "threading.Thread.run.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ia_qn_eq,  Thread.is_alive.__qualname__.__eq__,    ["Thread.is_alive"], true, "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive'; verified with Python 3.14.3"]
    - [ia_qn_len, Thread.is_alive.__qualname__.__len__,    [],                  15,   "threading.Thread.is_alive.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [ia_mod_eq, Thread.is_alive.__module__.__eq__,       ["threading"],       true, "threading.Thread.is_alive.__module__ == 'threading'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.Thread.daemon and Thread.name — property type identity
#
# Thread.daemon is a property descriptor: __class__.__name__ == 'property'.
# Thread.name is a property descriptor: __class__.__name__ == 'property'.
# Thread.__name__ == 'Thread' (6 chars); Thread.__module__ == 'threading'.
# ---------------------------------------------------------------------------

table threading_extra278.thread_daemon_name_identity:
  description: "threading.Thread.daemon and Thread.name property type identity; Thread class __name__ and __module__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex278tdn

  columns: [id, function, args, expected, description]
  rows:
    - [dm_cls_eq,  Thread.daemon.__class__.__name__.__eq__,  ["property"],   true, "threading.Thread.daemon.__class__.__name__ == 'property' — daemon is a property descriptor; verified with Python 3.14.3"]
    - [nm_cls_eq,  Thread.name.__class__.__name__.__eq__,    ["property"],   true, "threading.Thread.name.__class__.__name__ == 'property' — name is a property descriptor; verified with Python 3.14.3"]
    - [th_nm_eq,   Thread.__name__.__eq__,                   ["Thread"],     true, "threading.Thread.__name__ == 'Thread'; verified with Python 3.14.3"]
    - [th_nm_len,  Thread.__name__.__len__,                   [],             6,    "threading.Thread.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [th_mod_eq,  Thread.__module__.__eq__,                  ["threading"],  true, "threading.Thread.__module__ == 'threading'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra278
# ---------------------------------------------------------------------------

invariant threading_extra278.thread_start_qualname:
  description: "threading.Thread.start.__qualname__ == 'Thread.start' — the method's qualified name encodes the owning class"
  category: identity
  kind: python_call_eq
  function: Thread.start.__qualname__.__eq__
  args: ["Thread.start"]
  expected: true

invariant threading_extra278.thread_join_qualname:
  description: "threading.Thread.join.__qualname__ == 'Thread.join' — the method's qualified name encodes the owning class"
  category: identity
  kind: python_call_eq
  function: Thread.join.__qualname__.__eq__
  args: ["Thread.join"]
  expected: true

invariant threading_extra278.thread_run_qualname:
  description: "threading.Thread.run.__qualname__ == 'Thread.run' — the method's qualified name encodes the owning class"
  category: identity
  kind: python_call_eq
  function: Thread.run.__qualname__.__eq__
  args: ["Thread.run"]
  expected: true

invariant threading_extra278.thread_is_alive_qualname:
  description: "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' — the method's qualified name encodes the owning class"
  category: identity
  kind: python_call_eq
  function: Thread.is_alive.__qualname__.__eq__
  args: ["Thread.is_alive"]
  expected: true

invariant threading_extra278.thread_is_alive_qualname_length_is_15:
  description: "threading.Thread.is_alive.__qualname__.__len__() == 15 — 'Thread.is_alive' has 15 characters"
  category: identity
  kind: python_call_eq
  function: Thread.is_alive.__qualname__.__len__
  args: []
  expected: 15

invariant threading_extra278.thread_daemon_is_property:
  description: "threading.Thread.daemon.__class__.__name__ == 'property' — daemon is a property descriptor, not a plain attribute"
  category: identity
  kind: python_call_eq
  function: Thread.daemon.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra278.thread_name_is_property:
  description: "threading.Thread.name.__class__.__name__ == 'property' — name is a property descriptor, not a plain string attribute"
  category: identity
  kind: python_call_eq
  function: Thread.name.__class__.__name__.__eq__
  args: ["property"]
  expected: true
