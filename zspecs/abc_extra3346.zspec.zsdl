spec: ab3346
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (ab3346): __neg__, __pos__, __abs__ dict-presence (unary -x, +x, abs(x)) for abc module types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "Key finding (__neg__): all 3 abc subjects return false for __neg__. Unary negation (__neg__, -x) belongs to the numeric data model. abc types implement no numeric protocol. abc.ABC is a plain abstract base class convenience wrapper with no numeric semantics — -ABC is not a defined Python expression. abc.ABCMeta is a metaclass responsible for abstract method tracking and virtual subclass registration (__subclasshook__, register(), __abstractmethods__); negating a metaclass is not defined. The function type (type(abc.abstractmethod(lambda: None)) is <class 'function'>) does not define __neg__ — functions are callables and descriptors, not numeric types. -f is not a valid Python expression for function objects."
    - "Key finding (__pos__): all 3 abc subjects return false for __pos__. Unary plus (__pos__, +x) mirrors __neg__ in the numeric data model. abc types define no numeric protocol of any kind — confirmed false across waves 658–669 for all arithmetic, bitwise, reflected, and in-place augmented assignment operators. +ABC, +ABCMeta, +function are not valid Python expressions for these types. The function type is tightly scoped to its role as a callable descriptor with a display representation; no numeric unary protocol is defined."
    - "Key finding (__abs__): all 3 abc subjects return false for __abs__. The abs() built-in delegates to __abs__, which is part of the numeric data model (numbers.Number). abc types implement no numeric magnitude. abs(ABC) is not a meaningful operation — ABC is a pure abstract base class helper with no state beyond what ABCMeta provides. abs(ABCMeta) is not defined — ABCMeta's entire capability is in class-hierarchy machinery, not numeric computations. abs(function) is not defined — the function type has no numeric magnitude; function objects are callable descriptors, not numbers."
    - "All 9 values in this wave are false — continuing the all-false pattern from wave 669 (__iand__/__ior__/__ixor__)."
    - "The function type profile across all waves: true only for __get__ (wave 652), __repr__ (wave 655), and __call__ (wave 656). All other dunders tested — including this wave's __neg__/__pos__/__abs__ — are false."
    - "abc.ABCMeta has now returned false for every arithmetic, bitwise, reflected, in-place augmented assignment, and unary numeric dunder tested across 19 consecutive waves (652–670). Its entire capability is expressed through class-hierarchy machinery, not operator overloading."
    - "Cross-wave summary for abc subjects:"
    - "  Wave 652 (ab3076): __get__ true for function type; __set__/__delete__ false."
    - "  Wave 653 (ab3091): __hash__/__eq__/__bool__ all false for all 3."
    - "  Wave 654 (ab3106): __lt__/__le__/__gt__ all false for all 3."
    - "  Wave 655 (ab3121): __ge__ false; __repr__ true for function type only; __str__ false."
    - "  Wave 656 (ab3136): __call__ true for function type only; __len__/__getitem__ false."
    - "  Wave 657 (ab3151): __setitem__/__delitem__/__contains__ — all false for all 3."
    - "  Wave 658 (ab3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (ab3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (ab3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (ab3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (ab3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (ab3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (ab3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (ab3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (ab3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (ab3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (ab3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (ab3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (ab3346): __neg__/__pos__/__abs__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — operator.contains(Cls.__dict__, '__neg__')
#
# All 3 abc subjects return false for __neg__.
# Unary negation (__neg__, -x) is a numeric data model method.
# abc.ABC: a plain abstract base class convenience wrapper with no bitwise
#   or numeric semantics. -ABC is not a defined Python expression.
# abc.ABCMeta: a metaclass for abstract method tracking and virtual subclass
#   registration. Unary negation has no role in ABCMeta's responsibilities
#   (__subclasshook__, register(), __abstractmethods__). -ABCMeta is not valid.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __neg__. -f is not a valid Python expression for
#   callable objects. Functions are callables and descriptors with no numeric
#   data model.
# ---------------------------------------------------------------------------

table ab3346.neg:
  description: "abc types __neg__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3346

  columns: [id, function, args, expected]
  rows:
    - ["ab3346001", operator.contains, [abc.ABC.__dict__,                                 "__neg__"], false]
    - ["ab3346002", operator.contains, [abc.ABCMeta.__dict__,                             "__neg__"], false]
    - ["ab3346003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — operator.contains(Cls.__dict__, '__pos__')
#
# All 3 abc subjects return false for __pos__.
# Unary plus (__pos__, +x) mirrors __neg__ and belongs to the same numeric
#   data model. abc types define no numeric protocol of any kind — confirmed
#   false across waves 658–669 for all arithmetic and bitwise operators.
# abc.ABC: no bitwise or numeric data model; +ABC is not a defined Python
#   expression. abc.ABC is a pure abstract base class helper with no state
#   of its own beyond what ABCMeta provides.
# abc.ABCMeta: does not define __pos__. ABCMeta's API surface
#   (__subclasshook__, register(), __abstractmethods__) has no arithmetic,
#   bitwise, or unary numeric component. +ABCMeta is not valid.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __pos__. +f is not a valid Python expression
#   for callable objects. The function type is tightly scoped to its role
#   as a callable descriptor with a display representation.
# ---------------------------------------------------------------------------

table ab3346.pos:
  description: "abc types __pos__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3346

  columns: [id, function, args, expected]
  rows:
    - ["ab3346004", operator.contains, [abc.ABC.__dict__,                                 "__pos__"], false]
    - ["ab3346005", operator.contains, [abc.ABCMeta.__dict__,                             "__pos__"], false]
    - ["ab3346006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — operator.contains(Cls.__dict__, '__abs__')
#
# All 3 abc subjects return false for __abs__.
# The abs() built-in delegates to __abs__, part of the numeric data model
#   (numbers.Number). abc types implement no numeric magnitude.
# abc.ABC: a pure abstract base class helper with no numeric or integer
#   data model. abs(ABC) is not a meaningful Python operation.
# abc.ABCMeta: a powerful metaclass, but its entire power lies in class-
#   hierarchy machinery — not in numeric computations. abs(ABCMeta) is not
#   a valid Python operation. ABCMeta's responsibilities are entirely in the
#   domain of class creation and abstract method enforcement.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __abs__. Unlike numbers (int, float, complex),
#   which use __abs__ for magnitude, CPython's built-in function type has no
#   __abs__. abs(f) is not a valid Python expression for callable objects.
#   Function objects have no numeric magnitude to compute.
# ---------------------------------------------------------------------------

table ab3346.abs_:
  description: "abc types __abs__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
