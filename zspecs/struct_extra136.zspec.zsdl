# ---------------------------------------------------------------------------

invariant struct_extra136.iter_unpack_doc_len_239:
  description: "struct.iter_unpack.__doc__.__len__() == 239 — module-level iter_unpack docstring (239 chars); 43 chars longer than Struct.iter_unpack (196); both describe iterator yielding unpacked tuples but module version is more verbose; no prior struct spec anchors this as a standalone; first standalone under structdoc136"
  category: doc_lengths
