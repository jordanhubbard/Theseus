# ---------------------------------------------------------------------------

invariant struct_extra136.Struct_pack_doc_len_175:
  description: "struct.Struct.pack.__doc__.__len__() == 175 — shortest Struct method docstring; 1 char shorter than module-level struct.pack (176); uses S.format instead of accepting format arg; no prior struct spec anchors this as a standalone; first standalone under structdoc136"
  category: doc_lengths
  kind: python_call_eq
  function: Struct.pack.__doc__.__len__
  args: []
  expected: 175

# ---------------------------------------------------------------------------
# struct.iter_unpack.__doc__.__len__()==239 — standalone
#
# struct.iter_unpack.__doc__.__len__() is 239. The module-level iter_unpack
# (239) is 43 chars longer than Struct.iter_unpack (196). The module version
