invariant struct_extra136.Struct_unpack_from_doc_len_243:
  description: "struct.Struct.unpack_from.__doc__.__len__() == 243 — second-longest Struct method docstring; 55 chars longer than module-level unpack_from (188) because it describes offset relative to Struct.size; no prior struct spec anchors this as a standalone; first standalone under structdoc136"
  category: doc_lengths
  kind: python_call_eq
  function: Struct.unpack_from.__doc__.__len__
  args: []
  expected: 243

# ---------------------------------------------------------------------------
# struct.Struct.pack.__doc__.__len__()==175 — standalone
#
# struct.Struct.pack.__doc__.__len__() is 175. The Struct.pack method docstring
# is 1 char shorter than the module-level pack (176). Both describe packing
# values according to a format string, but the Struct method uses 'S.format'
