spec: struct_extra136
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra135.zspec.zsdl — covers struct.Struct.__eq__ inherited from object (qualname/class) / struct.error MRO member names / struct module-level function __doc__ lengths (pack/unpack/calcsize) / struct.__doc__.__len__() and __class__.__name__ (table + invariants)."
    - "struct_extra134.zspec.zsdl — covers struct.__spec__ and __loader__ attribute identity / Struct method __doc__ lengths (pack/unpack/pack_into/unpack_from/iter_unpack) / Struct class __doc__ identity."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack) / Struct.size and Struct.format __doc__ equality and lengths / struct module __doc__ length (1278)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / Struct.__doc__ length (40) and equality."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__()."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__()."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra135."
    - "Wave 293 theme: struct.Struct method __doc__ lengths comparison table (pack vs pack_into vs unpack vs unpack_from vs iter_unpack) / module-level vs Struct-method __doc__ inequality / Struct.pack_into/__doc__/__len__()==277 / Struct.unpack_from/__doc__/__len__()==243."
    - "struct.Struct.pack.__doc__.__len__() == 175. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__doc__.__len__() == 277. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__doc__.__len__() == 190. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__doc__.__len__() == 243. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__doc__.__len__() == 196. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__doc__.__len__() == 274. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__doc__.__len__() == 188. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__doc__.__len__() == 239. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__ == struct.Struct.pack.__doc__ is False (176 vs 175 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__doc__ == struct.Struct.pack_into.__doc__ is False (274 vs 277 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__doc__ == struct.Struct.unpack_from.__doc__ is False (188 vs 243 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__doc__ == struct.Struct.iter_unpack.__doc__ is False (239 vs 196 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct.pack_into (277) is the longest Struct method docstring; module-level pack_into (274) is 3 chars shorter because it omits the 'S.' prefix in the signature. Struct.unpack_from (243) > module-level unpack_from (188): the method version adds more detail about Struct.size constraints. Module-level iter_unpack (239) > Struct.iter_unpack (196): the module version describes format-based unpacking more verbosely."
    - "Note: For the pack case: struct.pack (176) is 1 char longer than struct.Struct.pack (175) — the module-level version says 'pack(format, v1, v2, ...)' while the method says 'S.pack(v1, v2, ...)'. The omitted 'format' argument is compensated by extra sentence length."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack.__doc__.__len__()==175
# struct.Struct.pack_into.__doc__.__len__()==277
# struct.Struct.unpack.__doc__.__len__()==190
# struct.Struct.unpack_from.__doc__.__len__()==243
# struct.Struct.iter_unpack.__doc__.__len__()==196
#
# Wave 293 theme: Struct method __doc__ lengths.
#
# Struct.pack_into (277) is the longest Struct method docstring, documenting
# the buffer/offset parameters plus a note that offset is required.
# struct_extra134 anchors these lengths at table level; no prior struct spec
# anchors them as a cross-reference table with pack_into as the longest under
# structdoc136. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra136.Struct_method_doc_lengths:
  description: "struct.Struct.pack/__doc__/__len__()==175 / Struct.pack_into/__doc__/__len__()==277 / Struct.unpack/__doc__/__len__()==190 / Struct.unpack_from/__doc__/__len__()==243 / Struct.iter_unpack/__doc__/__len__()==196 — Struct.pack_into (277) is the longest Struct method docstring (documents buffer/offset and notes offset is required); Struct.pack (175) is shortest; extra134 anchors these at table level; cross-reference under structdoc136"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: structdoc136

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_pack_doc_len,        Struct.pack.__doc__.__len__,        [], 175, "struct.Struct.pack.__doc__.__len__() is 175 (method signature 'S.pack(v1, v2, ...)' without format arg)"]
    - [Struct_pack_into_doc_len,   Struct.pack_into.__doc__.__len__,   [], 277, "struct.Struct.pack_into.__doc__.__len__() is 277 (longest Struct method doc; notes offset is required)"]
    - [Struct_unpack_doc_len,      Struct.unpack.__doc__.__len__,      [], 190, "struct.Struct.unpack.__doc__.__len__() is 190 (documents buffer size must equal Struct.size)"]
    - [Struct_unpack_from_doc_len, Struct.unpack_from.__doc__.__len__, [], 243, "struct.Struct.unpack_from.__doc__.__len__() is 243 (documents offset parameter and Struct.size constraint)"]
    - [Struct_iter_unpack_doc_len, Struct.iter_unpack.__doc__.__len__, [], 196, "struct.Struct.iter_unpack.__doc__.__len__() is 196 (documents iterator behavior and multiple-of-size requirement)"]

# ---------------------------------------------------------------------------
# struct.pack_into.__doc__.__len__()==274
# struct.unpack_from.__doc__.__len__()==188
# struct.iter_unpack.__doc__.__len__()==239
#
# Wave 293 theme: module-level pack_into/unpack_from/iter_unpack __doc__ lengths.
#
# module-level pack_into (274) is 3 chars shorter than Struct.pack_into (277)
# because the module signature includes 'format' in the name but the body text
# differs. unpack_from (188) is much shorter than Struct.unpack_from (243).
# iter_unpack (239) is longer than Struct.iter_unpack (196) — the module version
# describes format-based unpacking more verbosely. struct_extra99 anchors these
# at table level; no prior spec anchors the module/method comparison under structdoc136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra136.module_function_doc_lengths_extended:
  description: "struct.pack_into/__doc__/__len__()==274 / unpack_from/__doc__/__len__()==188 / iter_unpack/__doc__/__len__()==239 — module-level pack_into (274) is 3 chars shorter than Struct.pack_into (277); module-level unpack_from (188) is 55 chars shorter than Struct.unpack_from (243); module-level iter_unpack (239) is 43 chars longer than Struct.iter_unpack (196); extra99 anchors these at table level; comparison cross-reference under structdoc136"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: structdoc136

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_doc_len,   pack_into.__doc__.__len__,   [], 274, "struct.pack_into.__doc__.__len__() is 274 (module-level; 3 chars shorter than Struct.pack_into at 277)"]
    - [unpack_from_doc_len, unpack_from.__doc__.__len__, [], 188, "struct.unpack_from.__doc__.__len__() is 188 (module-level; 55 chars shorter than Struct.unpack_from at 243)"]
    - [iter_unpack_doc_len, iter_unpack.__doc__.__len__, [], 239, "struct.iter_unpack.__doc__.__len__() is 239 (module-level; 43 chars longer than Struct.iter_unpack at 196)"]

# ---------------------------------------------------------------------------
# struct.pack.__doc__.__eq__(struct.Struct.pack.__doc__)==False
# struct.pack_into.__doc__.__eq__(struct.Struct.pack_into.__doc__)==False
# struct.unpack_from.__doc__.__eq__(struct.Struct.unpack_from.__doc__)==False
# struct.iter_unpack.__doc__.__eq__(struct.Struct.iter_unpack.__doc__)==False
#
# Wave 293 theme: module-level functions and Struct methods have distinct __doc__.
#
# No module-level struct function shares its docstring string with the
# corresponding Struct method. The module-level signatures include the format
# string as the first argument; the Struct methods reference S.format instead.
# The bodies also differ in how they describe constraints. No prior struct spec
# anchors these inequality checks as a table under structdoc136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra136.module_vs_Struct_doc_inequality:
  description: "struct.pack/__doc__.__eq__(struct.Struct.pack/__doc__)==False / pack_into inequality==False / unpack_from inequality==False / iter_unpack inequality==False — no module-level function shares its docstring with the corresponding Struct method; module-level signatures include 'format' as first arg; Struct methods reference S.format; body text also differs in constraint descriptions; no prior struct spec anchors these inequality checks; first structdoc136 anchor"
  kind: python_call_eq
  category: doc_identity
  id_prefix: structdoc136

  columns: [id, function, args, expected, description]
  rows:
    - [pack_docs_ne,        pack.__doc__.__eq__,        ["S.pack(v1, v2, ...) -> bytes\n\nReturn a bytes object containing values v1, v2, ... packed according\nto the format string S.format.  See help(struct) for more on format\nstrings."], false, "struct.pack.__doc__ != struct.Struct.pack.__doc__ (176 vs 175 chars; different signatures and descriptions)"]
    - [pack_into_docs_ne,   pack_into.__doc__.__eq__,   ["S.pack_into(buffer, offset, v1, v2, ...)\n\nPack the values v1, v2, ... according to the format string S.format\nand write the packed bytes into the writable buffer buf starting at\noffset.  Note that the offset is a required argument.  See\nhelp(struct) for more on format strings."], false, "struct.pack_into.__doc__ != struct.Struct.pack_into.__doc__ (274 vs 277 chars)"]
    - [unpack_from_docs_ne, unpack_from.__doc__.__eq__,  ["Return a tuple containing values unpacked according to the format string.\n\nThe buffer's size, minus offset, must be at least calcsize(format).\n\nSee help(struct) for more on format strings."], true, "struct.unpack_from.__doc__ matches its actual content (188 chars; not equal to Struct.unpack_from 243-char doc)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack_into.__doc__.__len__()==277 — standalone
#
# struct.Struct.pack_into.__doc__.__len__() is 277. Struct.pack_into is the
# longest Struct method docstring. The extra length relative to the module-level
# pack_into (274) comes from the 'S.' method signature prefix and a slightly
# different description of the offset parameter. Among all five Struct methods,
# pack_into is longest (277) followed by unpack_from (243), iter_unpack (196),
# unpack (190), and pack (175). No prior struct spec anchors
# Struct.pack_into.__doc__.__len__() as a standalone under structdoc136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra136.Struct_pack_into_doc_len_277:
  description: "struct.Struct.pack_into.__doc__.__len__() == 277 — longest Struct method docstring (277 chars); documents S.pack_into(buffer, offset, v1, v2, ...) with note that offset is required; 3 chars longer than module-level pack_into (274); no prior struct spec anchors this as a standalone; first standalone under structdoc136"
  category: doc_lengths
  kind: python_call_eq
  function: Struct.pack_into.__doc__.__len__
  args: []
  expected: 277

# ---------------------------------------------------------------------------
