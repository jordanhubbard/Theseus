spec: re_extra105
version: ">=3.9"
backend: python_module(re)
extends: re_extra104

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra104.zspec.zsdl."
    - "This spec covers: re.Pattern and re.Match method __name__ string values."
    - "re.Pattern.match.__name__ = 'match' (length 5)."
    - "re.Pattern.search.__name__ = 'search' (length 6)."
    - "re.Pattern.findall.__name__ = 'findall' (length 7)."
    - "re.Pattern.finditer.__name__ = 'finditer' (length 8)."
    - "re.Pattern.fullmatch.__name__ = 'fullmatch' (length 9)."
    - "re.Pattern.sub.__name__ = 'sub' (length 3)."
    - "re.Pattern.subn.__name__ = 'subn' (length 4)."
    - "re.Pattern.split.__name__ = 'split' (length 5)."
    - "re.Match.group.__name__ = 'group' (length 5)."
    - "re.Match.groups.__name__ = 'groups' (length 6)."
    - "re.Match.start.__name__ = 'start' (length 5)."
    - "re.Match.end.__name__ = 'end' (length 3)."
    - "re.Match.span.__name__ = 'span' (length 4)."
    - "re.Match.groupdict.__name__ = 'groupdict' (length 9)."
    - "re.Match.expand.__name__ = 'expand' (length 6)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern method __name__ values
# Pattern.match.__name__ = 'match', Pattern.search.__name__ = 'search',
# Pattern.findall.__name__ = 'findall', Pattern.finditer.__name__ = 'finditer',
# Pattern.fullmatch.__name__ = 'fullmatch', Pattern.sub.__name__ = 'sub',
# Pattern.subn.__name__ = 'subn', Pattern.split.__name__ = 'split'.
# ---------------------------------------------------------------------------

table re_extra105.Pattern_method_names:
  description: "re.Pattern method __name__ values: match='match'(5), search='search'(6), findall='findall'(7), finditer='finditer'(8), fullmatch='fullmatch'(9), sub='sub'(3), subn='subn'(4), split='split'(5)"
  kind: python_call_eq
  category: class_names
  id_prefix: repatmatch105

  columns: [id, function, args, expected, description]
  rows:
    - [pat_match_name,     Pattern.match.__name__.__eq__,     ["match"],     true,  "re.Pattern.match.__name__ == 'match'"]
    - [pat_search_name,    Pattern.search.__name__.__eq__,    ["search"],    true,  "re.Pattern.search.__name__ == 'search'"]
    - [pat_findall_name,   Pattern.findall.__name__.__eq__,   ["findall"],   true,  "re.Pattern.findall.__name__ == 'findall'"]
    - [pat_finditer_name,  Pattern.finditer.__name__.__eq__,  ["finditer"],  true,  "re.Pattern.finditer.__name__ == 'finditer'"]
    - [pat_fullmatch_name, Pattern.fullmatch.__name__.__eq__, ["fullmatch"], true,  "re.Pattern.fullmatch.__name__ == 'fullmatch'"]
    - [pat_sub_name,       Pattern.sub.__name__.__eq__,       ["sub"],       true,  "re.Pattern.sub.__name__ == 'sub'"]
    - [pat_subn_name,      Pattern.subn.__name__.__eq__,      ["subn"],      true,  "re.Pattern.subn.__name__ == 'subn'"]
    - [pat_split_name,     Pattern.split.__name__.__eq__,     ["split"],     true,  "re.Pattern.split.__name__ == 'split'"]
    - [pat_match_not_re,   Pattern.match.__name__.__eq__,     ["re"],        false, "re.Pattern.match.__name__ != 're' (method names are short bare names, not module-qualified)"]

# ---------------------------------------------------------------------------
# re.Match method __name__ values
# Match.group.__name__ = 'group', Match.groups.__name__ = 'groups',
# Match.start.__name__ = 'start', Match.end.__name__ = 'end',
# Match.span.__name__ = 'span', Match.groupdict.__name__ = 'groupdict',
# Match.expand.__name__ = 'expand'.
# ---------------------------------------------------------------------------

table re_extra105.Match_method_names:
  description: "re.Match method __name__ values: group='group'(5), groups='groups'(6), start='start'(5), end='end'(3), span='span'(4), groupdict='groupdict'(9), expand='expand'(6)"
  kind: python_call_eq
  category: class_names
  id_prefix: repatmatch105

  columns: [id, function, args, expected, description]
  rows:
    - [match_group_name,     Match.group.__name__.__eq__,     ["group"],     true,  "re.Match.group.__name__ == 'group'"]
    - [match_groups_name,    Match.groups.__name__.__eq__,    ["groups"],    true,  "re.Match.groups.__name__ == 'groups'"]
    - [match_start_name,     Match.start.__name__.__eq__,     ["start"],     true,  "re.Match.start.__name__ == 'start'"]
    - [match_end_name,       Match.end.__name__.__eq__,       ["end"],       true,  "re.Match.end.__name__ == 'end'"]
    - [match_span_name,      Match.span.__name__.__eq__,      ["span"],      true,  "re.Match.span.__name__ == 'span'"]
    - [match_groupdict_name, Match.groupdict.__name__.__eq__, ["groupdict"], true,  "re.Match.groupdict.__name__ == 'groupdict'"]
    - [match_expand_name,    Match.expand.__name__.__eq__,    ["expand"],    true,  "re.Match.expand.__name__ == 'expand'"]
    - [match_group_not_grp,  Match.group.__name__.__eq__,     ["grp"],       false, "re.Match.group.__name__ != 'grp' (the method name is the full word 'group')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra105.Pattern.match_name_is_match:
  description: "re.Pattern.match.__name__ == 'match' (method __name__ is the bare method name, not the qualified 'Pattern.match')"
  category: class_names
  kind: python_call_eq
  function: Pattern.match.__name__.__eq__
  args: ["match"]
  expected: true

invariant re_extra105.Pattern.fullmatch_name_is_fullmatch:
  description: "re.Pattern.fullmatch.__name__ == 'fullmatch' (length 9, the longest __name__ among Pattern's regex-matching methods)"
  category: class_names
  kind: python_call_eq
  function: Pattern.fullmatch.__name__.__eq__
  args: ["fullmatch"]
  expected: true

invariant re_extra105.Match.group_name_is_group:
  description: "re.Match.group.__name__ == 'group' (the primary Match result accessor method)"
  category: class_names
  kind: python_call_eq
  function: Match.group.__name__.__eq__
  args: ["group"]
  expected: true

invariant re_extra105.Match.groupdict_name_is_groupdict:
  description: "re.Match.groupdict.__name__ == 'groupdict' (length 9, the longest __name__ among Match's accessor methods)"
  category: class_names
  kind: python_call_eq
  function: Match.groupdict.__name__.__eq__
  args: ["groupdict"]
  expected: true

invariant re_extra105.Pattern.sub_name_is_sub:
  description: "re.Pattern.sub.__name__ == 'sub' (length 3, the shortest __name__ among Pattern's methods)"
  category: class_names
  kind: python_call_eq
  function: Pattern.sub.__name__.__eq__
  args: ["sub"]
  expected: true
