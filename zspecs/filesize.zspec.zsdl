spec: filesize
version: ">=10.0.0"
backend: node(filesize)

docs: https://github.com/avoidwork/filesize.js#readme

provenance:
  derived_from:
    - "filesize README — https://github.com/avoidwork/filesize.js#readme"
    - "Test vectors verified with filesize@10.1.6 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "filesize source: src/filesize.js"
  notes:
    - "filesize exports { filesize } as a named export."
    - "filesize(bytes) returns a human-readable file size string using SI units (base-10)."
    - "0 bytes → '0 B'; 1024 → '1.02 kB'; 1048576 → '1.05 MB'."
    - "Uses SI (base-10) units by default; 1024 bytes ≈ 1.02 kB."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a human-readable string. No errors for numeric inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table filesize.basic:
  kind: node_module_call_eq
  function: filesize
  category: basic
  id_prefix: fs

  columns: [id, args, expected]
  rows:
    - [zero,    [0],        "0 B"]
    - [one_kb,  [1024],     "1.02 kB"]
    - [one_mb,  [1048576],  "1.05 MB"]
