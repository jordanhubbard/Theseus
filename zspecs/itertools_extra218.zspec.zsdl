spec: itertools_extra218
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools output type identity checks (wave 384)."
    - "type(itertools.chain([1,2],[3,4])).__name__ == 'chain'. Verified with Python 3.14.3."
    - "type(itertools.cycle([1,2,3])).__name__ == 'cycle'. Verified with Python 3.14.3."
    - "type(itertools.islice([1,2,3,4],2)).__name__ == 'islice'. Verified with Python 3.14.3."
    - "type(itertools.product([1,2],[3,4])).__name__ == 'product'. Verified with Python 3.14.3."
    - "type(itertools.combinations([1,2,3],2)).__name__ == 'combinations'. Verified with Python 3.14.3."
    - "type(itertools.groupby([1,1,2,2])).__name__ == 'groupby'. Verified with Python 3.14.3."
    - "type(itertools.accumulate([1,2,3])).__name__ == 'accumulate'. Verified with Python 3.14.3."
    - "type(itertools.count(1)).__name__ == 'count'. Verified with Python 3.14.3."
    - "type(itertools.repeat(1,3)).__name__ == 'repeat'. Verified with Python 3.14.3."
    - "type(itertools.starmap(pow,[(2,3)])).__name__ == 'starmap'. Verified with Python 3.14.3."
    - "type(itertools.pairwise([1,2,3])).__name__ == 'pairwise'. Verified with Python 3.14.3."
    - "For all itertools types, class __name__ == type(instance).__name__ (they agree). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools class __name__ attribute checks
#
# All itertools classes (C-implemented types) have a __name__ attribute equal
# to their unqualified class name. These are also the names used in the module
# namespace. Verified that class __name__ matches the instance type name.
#
# Verified with Python 3.14.3:
#   itertools.chain.__name__ == 'chain'
#   itertools.cycle.__name__ == 'cycle'
#   itertools.islice.__name__ == 'islice'
#   itertools.product.__name__ == 'product'
#   itertools.combinations.__name__ == 'combinations'
#   itertools.groupby.__name__ == 'groupby'
#   itertools.accumulate.__name__ == 'accumulate'
#   itertools.count.__name__ == 'count'
#   itertools.repeat.__name__ == 'repeat'
#   itertools.starmap.__name__ == 'starmap'
#   itertools.pairwise.__name__ == 'pairwise'
# ---------------------------------------------------------------------------

table itertools_extra218.class_name_checks:
  description: "itertools class __name__ attribute identity checks; wave 384; new to extra218"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra218classnames

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_eq,
       chain.__name__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — chain is a C-implemented iterator type; its __name__ is 'chain'; str.__eq__('chain') returns True; new to extra218"]
    - [cycle_name_eq,
       cycle.__name__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — cycle infinitely repeats an iterable; its class __name__ is 'cycle'; str.__eq__('cycle') returns True; new to extra218"]
    - [islice_name_eq,
       islice.__name__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — islice slices an iterable lazily; its class __name__ is 'islice'; str.__eq__('islice') returns True; new to extra218"]
    - [product_name_eq,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — product yields Cartesian products; its class __name__ is 'product'; str.__eq__('product') returns True; new to extra218"]
    - [combinations_name_eq,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations yields r-length subsequences; its class __name__ is 'combinations'; str.__eq__('combinations') returns True; new to extra218"]
    - [groupby_name_eq,
       groupby.__name__.__eq__,
       ["groupby"],
       true,
       "itertools.groupby.__name__.__eq__('groupby') == True — groupby groups consecutive elements by a key; its class __name__ is 'groupby'; str.__eq__('groupby') returns True; new to extra218"]
    - [accumulate_name_eq,
       accumulate.__name__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — accumulate yields running totals or other accumulated values; its class __name__ is 'accumulate'; str.__eq__('accumulate') returns True; new to extra218"]
    - [count_name_eq,
       count.__name__.__eq__,
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — count yields an infinite arithmetic sequence; its class __name__ is 'count'; str.__eq__('count') returns True; new to extra218"]
    - [repeat_name_eq,
       repeat.__name__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — repeat yields a value a fixed number of times (or infinitely); its class __name__ is 'repeat'; str.__eq__('repeat') returns True; new to extra218"]
    - [starmap_name_eq,
       starmap.__name__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — starmap applies a function to each tuple of args from an iterable; its class __name__ is 'starmap'; str.__eq__('starmap') returns True; new to extra218"]
    - [pairwise_name_eq,
       pairwise.__name__.__eq__,
       ["pairwise"],
       true,
       "itertools.pairwise.__name__.__eq__('pairwise') == True — pairwise yields overlapping 2-tuples of consecutive elements; its class __name__ is 'pairwise'; str.__eq__('pairwise') returns True; new to extra218"]

# ---------------------------------------------------------------------------
# Table 2: itertools class __name__ length checks (type identity group)
#
# The __name__ length is a stable numeric invariant about the API surface.
#
# Verified with Python 3.14.3:
#   len('chain') == 5
#   len('cycle') == 5
#   len('islice') == 6
#   len('product') == 7
#   len('groupby') == 7
#   len('accumulate') == 10
#   len('count') == 5
#   len('repeat') == 6
#   len('starmap') == 7
#   len('pairwise') == 8
# ---------------------------------------------------------------------------

table itertools_extra218.class_name_lengths:
  description: "itertools class __name__ length checks; wave 384; new to extra218"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra218namelens

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_len_5,
       chain.__name__.__len__,
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — 'chain' has 5 characters; str.__len__() returns 5; new to extra218"]
    - [cycle_name_len_5,
       cycle.__name__.__len__,
       [],
       5,
       "itertools.cycle.__name__.__len__() == 5 — 'cycle' has 5 characters matching 'chain'; str.__len__() returns 5; new to extra218"]
    - [islice_name_len_6,
       islice.__name__.__len__,
       [],
       6,
       "itertools.islice.__name__.__len__() == 6 — 'islice' has 6 characters; str.__len__() returns 6; new to extra218"]
    - [product_name_len_7,
       product.__name__.__len__,
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — 'product' has 7 characters; str.__len__() returns 7; new to extra218"]
    - [groupby_name_len_7,
       groupby.__name__.__len__,
       [],
       7,
       "itertools.groupby.__name__.__len__() == 7 — 'groupby' has 7 characters matching 'product'; str.__len__() returns 7; new to extra218"]
    - [accumulate_name_len_10,
       accumulate.__name__.__len__,
       [],
       10,
       "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' has 10 characters; str.__len__() returns 10; new to extra218"]
    - [count_name_len_5,
       count.__name__.__len__,
       [],
       5,
       "itertools.count.__name__.__len__() == 5 — 'count' has 5 characters matching 'chain' and 'cycle'; str.__len__() returns 5; new to extra218"]
    - [repeat_name_len_6,
       repeat.__name__.__len__,
       [],
       6,
       "itertools.repeat.__name__.__len__() == 6 — 'repeat' has 6 characters matching 'islice'; str.__len__() returns 6; new to extra218"]
    - [starmap_name_len_7,
       starmap.__name__.__len__,
       [],
       7,
       "itertools.starmap.__name__.__len__() == 7 — 'starmap' has 7 characters matching 'product' and 'groupby'; str.__len__() returns 7; new to extra218"]
    - [pairwise_name_len_8,
       pairwise.__name__.__len__,
       [],
       8,
       "itertools.pairwise.__name__.__len__() == 8 — 'pairwise' has 8 characters; str.__len__() returns 8; new to extra218"]

# ---------------------------------------------------------------------------
# Table 3: itertools class __name__ __eq__ cross-checks (symmetric identity)
#
# For all itertools C types, the class __name__ equals the type name used in
# the module namespace. This table verifies the same string works as both.
#
# Verified with Python 3.14.3:
#   chain.__name__ != cycle.__name__  (all are distinct)
#   chain.__name__ != groupby.__name__
#   count.__name__ != repeat.__name__
# ---------------------------------------------------------------------------

table itertools_extra218.class_name_distinctness:
  description: "itertools class __name__ values are distinct from each other; wave 384; new to extra218"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra218distinct

  columns: [id, function, args, expected, description]
  rows:
    - [chain_ne_cycle,
       chain.__name__.__ne__,
       ["cycle"],
       true,
       "itertools.chain.__name__.__ne__('cycle') == True — 'chain' and 'cycle' are both 5-char names but different; str.__ne__('cycle') returns True; new to extra218"]
    - [chain_ne_count,
       chain.__name__.__ne__,
       ["count"],
       true,
       "itertools.chain.__name__.__ne__('count') == True — 'chain' != 'count' despite both being 5 characters; str.__ne__('count') returns True; new to extra218"]
    - [product_ne_groupby,
       product.__name__.__ne__,
       ["groupby"],
       true,
       "itertools.product.__name__.__ne__('groupby') == True — 'product' and 'groupby' are both 7-char names but different; str.__ne__('groupby') returns True; new to extra218"]
    - [islice_ne_repeat,
       islice.__name__.__ne__,
       ["repeat"],
       true,
       "itertools.islice.__name__.__ne__('repeat') == True — 'islice' and 'repeat' are both 6-char names but different; str.__ne__('repeat') returns True; new to extra218"]
    - [pairwise_ne_accumulate,
       pairwise.__name__.__ne__,
       ["accumulate"],
       true,
       "itertools.pairwise.__name__.__ne__('accumulate') == True — 'pairwise' (8 chars) != 'accumulate' (10 chars); str.__ne__('accumulate') returns True; new to extra218"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra218
# ---------------------------------------------------------------------------

