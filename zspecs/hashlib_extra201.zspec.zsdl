spec: hashlib_extra201
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "hashlib.__name__ == 'hashlib' (len=7) — the module's own __name__ attribute."
    - "hashlib.md5.__name__ == 'openssl_md5' (len=11) — OpenSSL-backed MD5 constructor."
    - "hashlib.sha1.__name__ == 'openssl_sha1' (len=12) — OpenSSL-backed SHA-1 constructor; len=12 not 11."
    - "hashlib.sha256.__name__ == 'openssl_sha256' (len=14) — OpenSSL-backed SHA-256 constructor."
    - "hashlib.blake2b.__name__ == 'blake2b' (len=7) — BLAKE2b constructor; same length as hashlib.__name__."
    - "hashlib.blake2s.__name__ == 'blake2s' (len=7) — BLAKE2s constructor; same length as blake2b.__name__."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' (len=11) — same length as openssl_md5.__name__."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' (len=3) — algorithms_guaranteed is a plain Python set."
    - "Name length ordering: set(3) < blake2b/blake2s(7) == hashlib(7) < md5/pbkdf2_hmac(11) < sha1(12) < sha256(14)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module and constructor name lengths — group A
# hashlib.__name__, hashlib.md5.__name__, hashlib.sha1.__name__
# ---------------------------------------------------------------------------

table hashlibnamelens3201.module_and_openssl_names_a:
  kind: python_call_eq
  category: name_lengths
  id_prefix: hashlibnamelens3201

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_len,   __name__.__len__,              [], 7,  "hashlib.__name__.__len__() == 7 ('hashlib' has 7 characters)"]
    - [md5_name_len,      md5.__name__.__len__,          [], 11, "hashlib.md5.__name__.__len__() == 11 ('openssl_md5' has 11 characters)"]
    - [sha1_name_len,     sha1.__name__.__len__,         [], 12, "hashlib.sha1.__name__.__len__() == 12 ('openssl_sha1' has 12 characters)"]

# ---------------------------------------------------------------------------
# hashlib constructor name lengths — group B
# hashlib.sha256.__name__, hashlib.blake2b.__name__, hashlib.blake2s.__name__
# ---------------------------------------------------------------------------

table hashlibnamelens3201.openssl_and_blake2_names_b:
  kind: python_call_eq
  category: name_lengths
  id_prefix: hashlibnamelens3201

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name_len,   sha256.__name__.__len__,       [], 14, "hashlib.sha256.__name__.__len__() == 14 ('openssl_sha256' has 14 characters)"]
    - [blake2b_name_len,  blake2b.__name__.__len__,      [], 7,  "hashlib.blake2b.__name__.__len__() == 7 ('blake2b' has 7 characters, same length as 'hashlib')"]
    - [blake2s_name_len,  blake2s.__name__.__len__,      [], 7,  "hashlib.blake2s.__name__.__len__() == 7 ('blake2s' has 7 characters, same length as blake2b.__name__)"]

# ---------------------------------------------------------------------------
# hashlib pbkdf2_hmac and algorithms_guaranteed class name lengths — group C
# hashlib.pbkdf2_hmac.__name__, hashlib.algorithms_guaranteed.__class__.__name__
# ---------------------------------------------------------------------------

table hashlibnamelens3201.pbkdf2_and_set_names_c:
  kind: python_call_eq
  category: name_lengths
  id_prefix: hashlibnamelens3201

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_name_len,   pbkdf2_hmac.__name__.__len__,                        [], 11, "hashlib.pbkdf2_hmac.__name__.__len__() == 11 ('pbkdf2_hmac' has 11 characters, same length as 'openssl_md5')"]
    - [algos_class_len,   algorithms_guaranteed.__class__.__name__.__len__,    [], 3,  "hashlib.algorithms_guaranteed.__class__.__name__.__len__() == 3 ('set' has 3 characters)"]
    - [module_name_eq,    __name__.__eq__,                                     ["hashlib"], true, "hashlib.__name__ == 'hashlib' (the module's canonical name)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlibnamelens3201.hashlib_module_name_len:
  description: "hashlib.__name__.__len__() == 7 — 'hashlib' has exactly 7 characters"
  category: name_lengths
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 7

invariant hashlibnamelens3201.md5_name_len:
  description: "hashlib.md5.__name__.__len__() == 11 — 'openssl_md5' has 11 characters; OpenSSL-backed MD5 constructor on macOS/Darwin"
  category: name_lengths
  kind: python_call_eq
  function: md5.__name__.__len__
  args: []
  expected: 11

invariant hashlibnamelens3201.sha1_name_len:
  description: "hashlib.sha1.__name__.__len__() == 12 — 'openssl_sha1' has 12 characters; OpenSSL-backed SHA-1 constructor on macOS/Darwin"
  category: name_lengths
  kind: python_call_eq
  function: sha1.__name__.__len__
  args: []
  expected: 12

invariant hashlibnamelens3201.sha256_name_len:
  description: "hashlib.sha256.__name__.__len__() == 14 — 'openssl_sha256' has 14 characters; the longest name among the constructors covered here"
  category: name_lengths
  kind: python_call_eq
  function: sha256.__name__.__len__
  args: []
  expected: 14

invariant hashlibnamelens3201.blake2b_name_len:
  description: "hashlib.blake2b.__name__.__len__() == 7 — 'blake2b' has 7 characters, same length as hashlib.__name__"
  category: name_lengths
  kind: python_call_eq
  function: blake2b.__name__.__len__
  args: []
  expected: 7

invariant hashlibnamelens3201.blake2s_name_len:
  description: "hashlib.blake2s.__name__.__len__() == 7 — 'blake2s' has 7 characters, same length as blake2b.__name__ and hashlib.__name__"
  category: name_lengths
  kind: python_call_eq
  function: blake2s.__name__.__len__
  args: []
  expected: 7

invariant hashlibnamelens3201.pbkdf2_hmac_name_len:
  description: "hashlib.pbkdf2_hmac.__name__.__len__() == 11 — 'pbkdf2_hmac' has 11 characters, same length as 'openssl_md5'"
  category: name_lengths
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__len__
  args: []
  expected: 11

invariant hashlibnamelens3201.algorithms_guaranteed_class_name_len:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__len__() == 3 — 'set' has 3 characters; algorithms_guaranteed is a plain Python set"
  category: name_lengths
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__len__
  args: []
  expected: 3
