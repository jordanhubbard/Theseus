spec: heapq_extra_rust
version: ">=3.9"
backend: rust_module(heapq_extra_rust)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/heapq.html — heapq stdlib"
  notes:
    - "heapq provides heap queue algorithm."
    - "heapq.heappush/heappop implements a min-heap."
    - "heapq.nlargest([3,1,4,1,5],3) == [5,4,3]."
    - "heapq.nsmallest([3,1,4,1,5],3) == [1,1,3]."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant heapq_extra_rust.nlargest_3:
  description: "heapq.nlargest(3, [3,1,4,1,5]) == [5,4,3]"
  category: nlargest
  kind: python_call_eq
  function: heapq_extra_nlargest_3
  args: []
  expected: [5, 4, 3]

invariant heapq_extra_rust.nsmallest_3:
  description: "heapq.nsmallest(3, [3,1,4,1,5]) == [1,1,3]"
  category: nsmallest
  kind: python_call_eq
  function: heapq_extra_nsmallest_3
  args: []
  expected: [1, 1, 3]

invariant heapq_extra_rust.heap_min:
  description: "after heappush of [5,3,1], heappop returns 1"
  category: heap
  kind: python_call_eq
  function: heapq_extra_heap_min
  args: []
  expected: 1

