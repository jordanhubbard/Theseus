spec: asyncio_extra961
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio exception class __name__, __module__, and __qualname__ attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra961.invalid_state_error_attrs:
  description: "asyncio.InvalidStateError name, module, and qualname identity"
  kind: python_call_eq
  category: exception_attrs
  id_prefix: as961is
  columns: [id, function, args, expected]
  rows:
    - [as961is001, asyncio.InvalidStateError.__name__.__eq__,     ["InvalidStateError"],         true]
    - [as961is002, asyncio.InvalidStateError.__module__.__eq__,   ["asyncio.exceptions"],        true]
    - [as961is003, asyncio.InvalidStateError.__qualname__.__eq__,  ["InvalidStateError"],        true]

table asyncio_extra961.cancelled_and_timeout_error_attrs:
  description: "asyncio.CancelledError and asyncio.TimeoutError name and module identity"
  kind: python_call_eq
  category: exception_attrs
  id_prefix: as961ct
  columns: [id, function, args, expected]
  rows:
    - [as961ct001, asyncio.CancelledError.__name__.__eq__,    ["CancelledError"],  true]
    - [as961ct002, asyncio.CancelledError.__module__.__eq__,  ["builtins"],        true]
    - [as961ct003, asyncio.TimeoutError.__name__.__eq__,      ["TimeoutError"],    true]
    - [as961ct004, asyncio.TimeoutError.__module__.__eq__,    ["builtins"],        true]

table asyncio_extra961.queue_exception_attrs:
  description: "asyncio.QueueEmpty and asyncio.QueueFull name and module identity"
  kind: python_call_eq
  category: exception_attrs
  id_prefix: as961qe
  columns: [id, function, args, expected]
  rows:
    - [as961qe001, asyncio.QueueEmpty.__name__.__eq__,    ["QueueEmpty"],           true]
    - [as961qe002, asyncio.QueueEmpty.__module__.__eq__,  ["asyncio.queues"],       true]
    - [as961qe003, asyncio.QueueFull.__name__.__eq__,     ["QueueFull"],            true]
    - [as961qe004, asyncio.QueueFull.__module__.__eq__,   ["asyncio.queues"],       true]

table asyncio_extra961.incomplete_read_error_attrs:
  description: "asyncio.IncompleteReadError name and module identity"
  kind: python_call_eq
  category: exception_attrs
  id_prefix: as961ir
  columns: [id, function, args, expected]
  rows:
    - [as961ir001, asyncio.IncompleteReadError.__name__.__eq__,    ["IncompleteReadError"],       true]
    - [as961ir002, asyncio.IncompleteReadError.__module__.__eq__,  ["asyncio.exceptions"],        true]
    - [as961ir003, asyncio.IncompleteReadError.__qualname__.__eq__, ["IncompleteReadError"],       true]
    - [as961ir004, asyncio.SendfileNotAvailableError.__name__.__eq__,   ["SendfileNotAvailableError"], true]
    - [as961ir005, asyncio.SendfileNotAvailableError.__module__.__eq__,  ["asyncio.exceptions"],       true]
