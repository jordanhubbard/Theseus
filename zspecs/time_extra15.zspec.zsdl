spec: time_extra15
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time_extra4.zspec.zsdl — covers __qualname__ table for time/sleep/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime/strptime/struct_time"
    - "time_extra10.zspec.zsdl — covers __qualname__ standalone invariants for sleep/monotonic/perf_counter; __module__ table"
    - "time_extra11.zspec.zsdl — covers __qualname__ for time_ns/monotonic_ns/perf_counter_ns"
    - "time_extra12.zspec.zsdl — covers __qualname__ standalone invariants for time/sleep/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime/strptime"
    - "time_extra13.zspec.zsdl — covers struct_time.__qualname__/__new__.__qualname__; clock_gettime/clock_settime/clock_gettime_ns/monotonic_ns/perf_counter_ns/process_time_ns/time_ns __qualname__"
    - "time_extra14.zspec.zsdl — covers struct_time.__module__/n_fields; timezone/altzone/daylight/tzname class names; CLOCK_REALTIME/CLOCK_MONOTONIC class names and values"
  notes:
    - "This spec extends time.zspec.zsdl and prior extras through time_extra14.zspec.zsdl."
    - "NEW in extra15 — Axis 1: __module__ for sleep/time/monotonic/perf_counter/process_time as standalone extra15-namespace invariants (prior __module__ coverage was in table rows in time_extra10, not as standalone invariants in a dedicated axis)."
    - "NEW in extra15 — Axis 2: __module__ for gmtime/localtime/mktime/strftime as standalone invariants — these functions are C-level builtins registered under module 'time'."
    - "NEW in extra15 — Axis 3: CLOCK_THREAD_CPUTIME_ID and CLOCK_PROCESS_CPUTIME_ID — class names and macOS-specific values (16 and 12 respectively)."
    - "time.sleep.__module__ == 'time' — verified Python 3.12."
    - "time.time.__module__ == 'time' — verified Python 3.12."
    - "time.monotonic.__module__ == 'time' — verified Python 3.12."
    - "time.perf_counter.__module__ == 'time' — verified Python 3.12."
    - "time.process_time.__module__ == 'time' — verified Python 3.12."
    - "time.gmtime.__module__ == 'time' — verified Python 3.12."
    - "time.localtime.__module__ == 'time' — verified Python 3.12."
    - "time.mktime.__module__ == 'time' — verified Python 3.12."
    - "time.strftime.__module__ == 'time' — verified Python 3.12."
    - "time.CLOCK_THREAD_CPUTIME_ID.__class__.__name__ == 'int' — macOS clock id 16."
    - "time.CLOCK_PROCESS_CPUTIME_ID.__class__.__name__ == 'int' — macOS clock id 12."
    - "time.CLOCK_THREAD_CPUTIME_ID == 16 — macOS assigns id 16 to CLOCK_THREAD_CPUTIME_ID."
    - "time.CLOCK_PROCESS_CPUTIME_ID == 12 — macOS assigns id 12 to CLOCK_PROCESS_CPUTIME_ID."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for core timing functions — standalone extra15-namespace invariants
#
# time_extra10 covers __module__ values in a table row set but not as
# standalone invariants namespaced to extra15. These five functions are
# C-level builtins all registered under the 'time' module namespace.
# ---------------------------------------------------------------------------

table time_extra15.timing_function_modules:
  description: "__module__ for core timing functions: sleep, time, monotonic, perf_counter, process_time"
  kind: python_call_eq
  category: function_identity
  id_prefix: tfm15

  columns: [id, function, args, expected]
  rows:
    - [sleep,        sleep.__module__.__eq__,        ["time"], true]
    - [time,         time.__module__.__eq__,         ["time"], true]
    - [monotonic,    monotonic.__module__.__eq__,    ["time"], true]
    - [perf_counter, perf_counter.__module__.__eq__, ["time"], true]
    - [process_time, process_time.__module__.__eq__, ["time"], true]

# ---------------------------------------------------------------------------
# __module__ for time conversion functions
#
# gmtime, localtime, mktime, and strftime are C-level functions registered
# under the 'time' module. No prior spec anchors their __module__ values as
# standalone extra15-namespace invariants. They complement the __qualname__
# coverage in time_extra4 and time_extra12.
# ---------------------------------------------------------------------------

table time_extra15.conversion_function_modules:
  description: "__module__ for time conversion functions: gmtime, localtime, mktime, strftime"
  kind: python_call_eq
  category: function_identity
  id_prefix: cfm15

  columns: [id, function, args, expected]
  rows:
    - [gmtime,   gmtime.__module__.__eq__,   ["time"], true]
    - [localtime, localtime.__module__.__eq__, ["time"], true]
    - [mktime,   mktime.__module__.__eq__,   ["time"], true]
    - [strftime, strftime.__module__.__eq__, ["time"], true]

# ---------------------------------------------------------------------------
# CLOCK_THREAD_CPUTIME_ID and CLOCK_PROCESS_CPUTIME_ID — class names and values
#
# These POSIX clock ids are used with clock_gettime/clock_settime to measure
# per-thread and per-process CPU time. On macOS they are plain ints with
# values 16 and 12 respectively. No prior time spec checks these constants.
# ---------------------------------------------------------------------------

table time_extra15.cpu_clock_id_class:
  description: "__class__.__name__ for CPU-time POSIX clock id constants"
  kind: python_call_eq
  category: constant_types
  id_prefix: cci15

  columns: [id, function, args, expected]
  rows:
    - [CLOCK_THREAD_CPUTIME_ID,  CLOCK_THREAD_CPUTIME_ID.__class__.__name__.__eq__,  ["int"], true]
    - [CLOCK_PROCESS_CPUTIME_ID, CLOCK_PROCESS_CPUTIME_ID.__class__.__name__.__eq__, ["int"], true]

invariant time_extra15.CLOCK_THREAD_CPUTIME_ID.value:
  description: "time.CLOCK_THREAD_CPUTIME_ID == 16 — macOS assigns clock id 16 to the per-thread CPU-time clock"
  category: constant_values
  kind: python_call_eq
  function: CLOCK_THREAD_CPUTIME_ID.__eq__
  args: [16]
  expected: true

invariant time_extra15.CLOCK_PROCESS_CPUTIME_ID.value:
  description: "time.CLOCK_PROCESS_CPUTIME_ID == 12 — macOS assigns clock id 12 to the per-process CPU-time clock"
  category: constant_values
  kind: python_call_eq
  function: CLOCK_PROCESS_CPUTIME_ID.__eq__
  args: [12]
  expected: true
