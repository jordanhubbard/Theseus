provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct: Interpret bytes as packed binary data"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 644 (st2956): __invert__, __round__, __trunc__ dict-presence checks for struct types."
    - "struct.Struct is a C extension type for packing/unpacking binary data; struct.error is an exception subclass — neither defines bitwise invert, round, or truncate operators."
    - "Verified types: struct.Struct, struct.error."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

