spec: builtins_extra9
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/functions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functions.html — Python built-in functions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins.zspec.zsdl — covers exception/type/function __name__ checks and basic function calls"
    - "builtins_extra.zspec.zsdl — covers function call behavior"
    - "builtins_extra2.zspec.zsdl — covers exception class hierarchies"
    - "builtins_extra3.zspec.zsdl — covers __name__ for print/input/open/vars/dir/id/frozenset/memoryview/slice/staticmethod/classmethod/super; __module__ for built-in types; base class hierarchy for int/bool/str/list/dict/tuple/set/frozenset/bytes/bytearray"
    - "builtins_extra4.zspec.zsdl — covers __qualname__ for abs through id (26 entries)"
    - "builtins_extra5.zspec.zsdl — covers __qualname__ for input through zip (36 entries)"
    - "builtins_extra6.zspec.zsdl — covers __qualname__ for bytearray/bytes/classmethod; NotImplemented/Ellipsis class names; __module__ for abs/len/print/type"
    - "builtins_extra7.zspec.zsdl — covers __module__ for all remaining built-in functions (ord through dir)"
    - "builtins_extra8.zspec.zsdl — covers __bases__[0].__name__ for int/bool/str/list/dict/bytes/Exception; MRO length for int/bool/str; None/True/False class names; __module__ for ValueError/TypeError/KeyError/IndexError/AttributeError/NameError"
  notes:
    - "This spec adds new axes not covered in any prior builtins spec."
    - "Axis 1: __bases__[0].__name__ for range, type, memoryview, slice, property — simple C types inheriting directly from object."
    - "Axis 2: __mro__.__len__() for dict, tuple, set, float, complex, range — all 2 (each type + object only)."
    - "Axis 3: __module__ for range, slice, memoryview, property, enumerate — all 'builtins'."
    - "Axis 4: __qualname__ for range, type, slice, enumerate, property as standalone __eq__ invariants."
    - "range.__bases__[0].__name__ == 'object' — range inherits directly from object."
    - "type.__bases__[0].__name__ == 'object' — type's base is object (type also appears in its own MRO above object)."
    - "dict.__mro__.__len__() == 2 — MRO is [dict, object]."
    - "tuple.__mro__.__len__() == 2 — MRO is [tuple, object]."
    - "set.__mro__.__len__() == 2 — MRO is [set, object]."
    - "float.__mro__.__len__() == 2 — MRO is [float, object]."
    - "complex.__mro__.__len__() == 2 — MRO is [complex, object]."
    - "range.__mro__.__len__() == 2 — MRO is [range, object]."
    - "range.__module__ == 'builtins', slice.__module__ == 'builtins', memoryview.__module__ == 'builtins'."
    - "property.__module__ == 'builtins', enumerate.__module__ == 'builtins'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__ — direct base class of additional built-in types
#
# builtins_extra3 covers int/bool/str/list/dict/tuple/set/frozenset/bytes/bytearray.
# builtins_extra8 covers int/bool/str/list/dict/bytes (partially overlapping).
# No prior spec checks __bases__[0].__name__ for range, type, memoryview,
# slice, or property.
# ---------------------------------------------------------------------------

invariant builtins_extra9.range.base_is_object:
  description: "builtins.range.__bases__[0].__name__ == 'object' — range inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: range.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant builtins_extra9.type.base_is_object:
  description: "builtins.type.__bases__[0].__name__ == 'object' — type's declared base is object"
  category: class_hierarchy
  kind: python_call_eq
  function: type.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant builtins_extra9.memoryview.base_is_object:
  description: "builtins.memoryview.__bases__[0].__name__ == 'object' — memoryview inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: memoryview.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant builtins_extra9.slice.base_is_object:
  description: "builtins.slice.__bases__[0].__name__ == 'object' — slice inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: slice.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant builtins_extra9.property.base_is_object:
  description: "builtins.property.__bases__[0].__name__ == 'object' — property inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: property.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# MRO length — additional built-in types not covered by builtins_extra8
#
# builtins_extra8 covers MRO lengths for int (2), bool (3), str (2).
# No prior spec checks MRO length for dict, tuple, set, float, complex, range.
# Each inherits directly from object only, so MRO length is 2.
# ---------------------------------------------------------------------------

table builtins_extra9.type_mro_lengths:
  kind: python_call_eq
  category: mro_lengths
  id_prefix: mrolen

  columns: [id, function, args, expected]
  rows:
    - [dict,    dict.__mro__.__len__,    [], 2]
    - [tuple,   tuple.__mro__.__len__,   [], 2]
    - [set,     set.__mro__.__len__,     [], 2]
    - [float,   float.__mro__.__len__,   [], 2]
    - [complex, complex.__mro__.__len__, [], 2]
    - [range,   range.__mro__.__len__,   [], 2]

# ---------------------------------------------------------------------------
# __module__ — additional built-in types not covered in any prior spec
#
# builtins_extra3 covers __module__ for: int/str/list/dict/tuple/set/frozenset/
# bytes/bytearray/bool/float/complex/type/object.
# No prior spec covers __module__ for range, slice, memoryview, property, enumerate.
# All are C-level built-in types so __module__ == 'builtins'.
# ---------------------------------------------------------------------------

table builtins_extra9.additional_type_modules:
  kind: python_call_eq
  category: type_modules
  id_prefix: tmod

  columns: [id, function, args, expected]
  rows:
    - [range,       range.__module__.__eq__,       ["builtins"], true]
    - [slice,       slice.__module__.__eq__,       ["builtins"], true]
    - [memoryview,  memoryview.__module__.__eq__,  ["builtins"], true]
    - [property,    property.__module__.__eq__,    ["builtins"], true]
    - [enumerate,   enumerate.__module__.__eq__,   ["builtins"], true]

# ---------------------------------------------------------------------------
# __qualname__ — range, type, slice, enumerate, property as standalone checks
#
# builtins_extra4/5 cover __qualname__ via table rows for most built-ins.
# Specifically: range is in extra5, enumerate is in extra4, slice is in extra5,
# property is in extra5, type is in extra5.
# This spec asserts them as standalone __eq__ invariants — a distinct expression
# axis confirmed by Python 3.12 at runtime.
# ---------------------------------------------------------------------------

invariant builtins_extra9.range.qualname:
  description: "builtins.range.__qualname__ == 'range' — top-level built-in type"
  category: qualnames
  kind: python_call_eq
  function: range.__qualname__.__eq__
  args: ["range"]
  expected: true

invariant builtins_extra9.type.qualname:
  description: "builtins.type.__qualname__ == 'type' — top-level built-in metaclass"
  category: qualnames
  kind: python_call_eq
  function: type.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant builtins_extra9.slice.qualname:
  description: "builtins.slice.__qualname__ == 'slice' — top-level built-in type"
  category: qualnames
  kind: python_call_eq
  function: slice.__qualname__.__eq__
  args: ["slice"]
  expected: true
