provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5 — parameters are (self, max_workers, thread_name_prefix, initializer, initargs); verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_name == '__init__' — method name in code object; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' — qualified name includes owning class; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount == 5 — parameters are (self, max_workers, mp_context, initializer, initargs); verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_name == '__init__' — method name in code object; verified with Python 3.14.3."
    - "concurrent.futures.Future.__init__.__code__.co_argcount == 1 — only parameter is self; verified with Python 3.14.3."
    - "concurrent.futures.Future.__init__.__code__.co_name == '__init__' — method name in code object; verified with Python 3.14.3."
    - "concurrent.futures.Future.__init__.__qualname__ == 'Future.__init__' — qualified name includes owning class; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

