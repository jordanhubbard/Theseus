spec: enum_extra3
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "Python enum documentation — https://docs.python.org/3/library/enum.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "enum.IntEnum.__name__ == 'IntEnum'."
    - "enum.IntFlag.__name__ == 'IntFlag'."
    - "enum.StrEnum.__name__ == 'StrEnum' — available from Python 3.11+."
    - "enum.auto.__name__ == 'auto'."
    - "enum.unique.__name__ == 'unique'."
    - "enum.IntEnum.__bases__[0].__name__ == 'int' — IntEnum inherits from int."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name identity
# ---------------------------------------------------------------------------

invariant enum_extra3.IntEnum.dunder_name:
  description: "enum.IntEnum.__name__ == 'IntEnum'"
  category: class_identity
  kind: python_call_eq
  function: IntEnum.__name__.__eq__
  args: ["IntEnum"]
  expected: true

invariant enum_extra3.IntFlag.dunder_name:
  description: "enum.IntFlag.__name__ == 'IntFlag'"
  category: class_identity
  kind: python_call_eq
  function: IntFlag.__name__.__eq__
  args: ["IntFlag"]
  expected: true

invariant enum_extra3.StrEnum.dunder_name:
  description: "enum.StrEnum.__name__ == 'StrEnum' (Python 3.11+)"
  category: class_identity
  kind: python_call_eq
  function: StrEnum.__name__.__eq__
  args: ["StrEnum"]
  expected: true

invariant enum_extra3.auto.dunder_name:
  description: "enum.auto.__name__ == 'auto'"
  category: class_identity
  kind: python_call_eq
  function: auto.__name__.__eq__
  args: ["auto"]
  expected: true

invariant enum_extra3.unique.dunder_name:
  description: "enum.unique.__name__ == 'unique'"
  category: function_identity
  kind: python_call_eq
  function: unique.__name__.__eq__
  args: ["unique"]
  expected: true

# ---------------------------------------------------------------------------
# IntEnum inherits from int
# ---------------------------------------------------------------------------

invariant enum_extra3.IntEnum.base_is_int:
  description: "enum.IntEnum.__bases__[0].__name__ == 'int'"
  category: inheritance
  kind: python_call_eq
  function: IntEnum.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "int"
