# ---------------------------------------------------------------------------
# Table 1: itertools.chain.from_iterable identity
#
# Wave 261 theme: itertools.chain.from_iterable is an alternative constructor
# for chain that accepts a single iterable of iterables. Despite being called
# a classmethod in the documentation, at the C level it is exposed as a
# builtin_function_or_method (a C slot, not a Python classmethod descriptor).
# It has no __func__ attribute (which Python classmethod descriptors have),
# and its __qualname__ is 'chain.from_iterable' — the dotted form indicating
# it belongs to the chain class.
#
# type(itertools.chain.from_iterable).__name__ == 'builtin_function_or_method'
# itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable'
# hasattr(itertools.chain.from_iterable, '__func__') == False
# type(itertools.chain.from_iterable.__doc__).__name__ == 'str'
#
# New to extra108.
# ---------------------------------------------------------------------------

table itertools_extra108.chain_from_iterable_identity:
  description: "itertools.chain.from_iterable is a builtin_function_or_method; __qualname__ is 'chain.from_iterable'; no __func__ attribute; __doc__ type is 'str'; wave 261; new to extra108"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolscfi108

  columns: [id, function, args, expected, description]
  rows:
    - ["chain_from_iterable_type_builtin",
       "chain.from_iterable.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — chain.from_iterable is exposed at the C level as a builtin_function_or_method (a C-level slot), not as a Python classmethod descriptor; despite being documented as a classmethod, it does not have a __func__ attribute; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra108"]
    - ["chain_from_iterable_qualname",
       "chain.from_iterable.__qualname__.__eq__",
       ["chain.from_iterable"],
       true,
       "itertools.chain.from_iterable.__qualname__.__eq__('chain.from_iterable') == True — chain.from_iterable is defined as part of the chain class; its __qualname__ uses the dotted 'ClassName.method_name' form 'chain.from_iterable'; this is how C-level methods on a type expose their qualified name; str.__eq__('chain.from_iterable') returns True; new to extra108"]
    - ["chain_from_iterable_doc_type_str",
       "chain.from_iterable.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.from_iterable.__doc__.__class__.__name__.__eq__('str') == True — chain.from_iterable has a string docstring (not None); C-extension builtin methods store their docstrings as plain Python str objects; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra108"]
    - [chain_name_eq,
       "chain.__name__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — itertools.chain is the C-extension iterator type that chains iterables together; its __name__ is 'chain'; from_iterable is an attribute of this type; str.__eq__('chain') returns True; new to extra108"]

# ---------------------------------------------------------------------------
# Table 2: itertools type __doc__ attribute type — group 1
#
# Wave 261 theme: all itertools C-extension types store their docstrings as
# plain Python str objects (type.__name__ == 'str'). This is consistent
# across the entire module. This table verifies the __doc__ attribute type
# for count, cycle, repeat, chain, compress.
#
# type(itertools.count.__doc__).__name__ == 'str'
# type(itertools.cycle.__doc__).__name__ == 'str'
# type(itertools.repeat.__doc__).__name__ == 'str'
# type(itertools.chain.__doc__).__name__ == 'str'
# type(itertools.compress.__doc__).__name__ == 'str'
#
# New to extra108.
# ---------------------------------------------------------------------------

