       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — itertools.count is a C-extension type; its __doc__ docstring is stored as a plain Python str object; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra108"]
    - [cycle_doc_type_str,
       "cycle.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.cycle.__doc__.__class__.__name__.__eq__('str') == True — itertools.cycle is a C-extension type; its __doc__ is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra108"]
    - [repeat_doc_type_str,
