spec: itertools_extra89
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra88

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra88.zspec.zsdl."
    - "This spec covers: itertools C-type __qualname__ string equality for all iterator types (Wave 250)."
    - "For C types defined at module level, __qualname__ equals __name__ (no containing class or function)."
    - "itertools.chain.__qualname__ == 'chain' — C type in itertoolsmodule.c; __qualname__ is 'chain'. Verified with Python 3.14.3."
    - "itertools.product.__qualname__ == 'product' — C type; __qualname__ is 'product'. Verified with Python 3.14.3."
    - "itertools.combinations.__qualname__ == 'combinations' — C type; __qualname__ is 'combinations'. Verified with Python 3.14.3."
    - "itertools.permutations.__qualname__ == 'permutations' — C type; __qualname__ is 'permutations'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement' — C type; __qualname__ is 'combinations_with_replacement'. Verified with Python 3.14.3."
    - "itertools.accumulate.__qualname__ == 'accumulate' — C type; __qualname__ is 'accumulate'. Verified with Python 3.14.3."
    - "itertools.groupby.__qualname__ == 'groupby' — C type; __qualname__ is 'groupby'. Verified with Python 3.14.3."
    - "itertools.islice.__qualname__ == 'islice' — C type; __qualname__ is 'islice'. Verified with Python 3.14.3."
    - "itertools.starmap.__qualname__ == 'starmap' — C type; __qualname__ is 'starmap'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__qualname__ == 'filterfalse' — C type; __qualname__ is 'filterfalse'. Verified with Python 3.14.3."
    - "itertools.takewhile.__qualname__ == 'takewhile' — C type; __qualname__ is 'takewhile'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__qualname__ == 'dropwhile' — C type; __qualname__ is 'dropwhile'. Verified with Python 3.14.3."
    - "itertools.count.__qualname__ == 'count' — C type; __qualname__ is 'count'. Verified with Python 3.14.3."
    - "itertools.cycle.__qualname__ == 'cycle' — C type; __qualname__ is 'cycle'. Verified with Python 3.14.3."
    - "itertools.repeat.__qualname__ == 'repeat' — C type; __qualname__ is 'repeat'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__qualname__ == 'zip_longest' — C type; __qualname__ is 'zip_longest'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: chain, product, combinations, permutations __qualname__ strings
#
# Wave 250 theme: itertools C-type __qualname__ string equality — group 1.
#
# itertools.chain.__qualname__.__eq__('chain')               == True
# itertools.product.__qualname__.__eq__('product')           == True
# itertools.combinations.__qualname__.__eq__('combinations') == True
# itertools.permutations.__qualname__.__eq__('permutations') == True
#
# Prior spec extra88 checked __name__. This spec (extra89) checks __qualname__. New to extra89.
# ---------------------------------------------------------------------------

table itertools_extra89.qualnames_group1:
  description: "chain/product/combinations/permutations __qualname__ strings; all C types in itertoolsmodule.c; wave 250; new to extra89"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsquals89

  columns: [id, function, args, expected, description]
  rows:
    - [chain_qualname_eq_chain,
       chain.__qualname__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — chain is a C extension type in Modules/itertoolsmodule.c; as a module-level type __qualname__ equals __name__; __qualname__ is 'chain' (5 chars); str.__eq__('chain') returns True; prior spec extra88 checked chain.__name__.__eq__; this spec (extra89) checks __qualname__; new to extra89"]
    - [product_qualname_eq_product,
       product.__qualname__.__eq__,
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — product is a C extension type in Modules/itertoolsmodule.c; as a module-level type __qualname__ equals __name__; __qualname__ is 'product' (7 chars); str.__eq__('product') returns True; prior spec extra88 checked product.__name__.__eq__; this spec (extra89) checks __qualname__; new to extra89"]
    - [combinations_qualname_eq_combinations,
       combinations.__qualname__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__('combinations') == True — combinations is a C extension type in Modules/itertoolsmodule.c; as a module-level type __qualname__ equals __name__; __qualname__ is 'combinations' (12 chars); str.__eq__('combinations') returns True; prior spec extra88 checked combinations.__name__.__eq__; this spec (extra89) checks __qualname__; new to extra89"]
    - [permutations_qualname_eq_permutations,
       permutations.__qualname__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — permutations is a C extension type in Modules/itertoolsmodule.c; as a module-level type __qualname__ equals __name__; __qualname__ is 'permutations' (12 chars); str.__eq__('permutations') returns True; prior spec extra88 checked permutations.__name__.__eq__; this spec (extra89) checks __qualname__; new to extra89"]

