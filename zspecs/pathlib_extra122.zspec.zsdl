spec: pathlib_extra122
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec extends pathlib_extra121.zspec.zsdl."
    - "This spec covers: pathlib.WindowsPath and pathlib.PosixPath MRO slot names via double-quoted bracket-path notation."
    - "WindowsPath.__mro__ has 5 entries: (WindowsPath, Path, PureWindowsPath, PurePath, object)."
    - "PosixPath.__mro__ has 5 entries: (PosixPath, Path, PurePosixPath, PurePath, object)."
    - "Both WindowsPath and PosixPath inherit directly from Path at MRO slot 1."
    - "WindowsPath.__mro__[2].__name__ == 'PureWindowsPath' (len 15); PosixPath.__mro__[2].__name__ == 'PurePosixPath' (len 13)."
    - "Both share 'PurePath' at MRO slot 3 and 'object' at MRO slot 4."
    - "WindowsPath.__name__ has length 11; PosixPath.__name__ has length 9."
    - "Both concrete platform path classes have __module__ == 'pathlib' and metaclass 'type'."
    - "pathlib_extra112 covered __mro__.__len__()==5 and __bases__[0].__name__=='Path' for both."
    - "pathlib_extra121 covered MRO slot names for PurePosixPath and PureWindowsPath (3-entry MROs)."
    - "No prior pathlib_extra spec has indexed into individual MRO slots for WindowsPath or PosixPath."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.WindowsPath MRO slot names
# WindowsPath.__mro__ == (WindowsPath, Path, PureWindowsPath, PurePath, object) — 5 entries.
# WindowsPath is the concrete path class for Windows path semantics.
# It inherits from Path at slot 1 (the abstract concrete base), and from
# PureWindowsPath at slot 2 (the pure path counterpart providing parsing logic).
# PurePath at slot 3 is the root pure path type; object terminates the chain.
# pathlib_extra112 covered __mro__.__len__()==5 and __bases__[0].__name__=='Path';
# no prior spec has indexed individual MRO slots for WindowsPath by bracket notation.
# ---------------------------------------------------------------------------

table pathlib_extra122.WindowsPath_mro_slot_names:
  description: "pathlib.WindowsPath.__mro__ slot names: [0]='WindowsPath'(11),[1]='Path'(4),[2]='PureWindowsPath'(15),[3]='PurePath'(8),[4]='object'(6); 5-entry MRO; Windows-flavour concrete path class"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pathlibwpmro122a

  columns: [id, function, args, expected, description]
  rows:
    - [wp_mro0_name,  "WindowsPath.__mro__[0].__name__.__eq__",  ["WindowsPath"],       true,  "pathlib.WindowsPath.__mro__[0].__name__ == 'WindowsPath' (the class itself is first in its own MRO; Windows-flavour concrete path type)"]
    - [wp_mro1_name,  "WindowsPath.__mro__[1].__name__.__eq__",  ["Path"],              true,  "pathlib.WindowsPath.__mro__[1].__name__ == 'Path' (direct parent; abstract concrete base for all platform-specific concrete path types)"]
    - [wp_mro2_name,  "WindowsPath.__mro__[2].__name__.__eq__",  ["PureWindowsPath"],   true,  "pathlib.WindowsPath.__mro__[2].__name__ == 'PureWindowsPath' (pure Windows path mixin; provides Windows-flavour parsing rules at MRO slot 2)"]
    - [wp_mro3_name,  "WindowsPath.__mro__[3].__name__.__eq__",  ["PurePath"],          true,  "pathlib.WindowsPath.__mro__[3].__name__ == 'PurePath' (root pure path base; provides all platform-independent path operations at MRO slot 3)"]
    - [wp_mro4_name,  "WindowsPath.__mro__[4].__name__.__eq__",  ["object"],            true,  "pathlib.WindowsPath.__mro__[4].__name__ == 'object' (universal Python base class terminates the 5-entry MRO at slot 4)"]
    - [wp_mro1_ne_0,  "WindowsPath.__mro__[1].__name__.__eq__",  ["WindowsPath"],       false, "pathlib.WindowsPath.__mro__[1].__name__ != 'WindowsPath' (slot 1 is the parent 'Path', not the class itself)"]
    - [wp_mro2_len,   "WindowsPath.__mro__[2].__name__.__len__", [],                    15,    "pathlib.WindowsPath.__mro__[2].__name__.__len__() == 15 ('PureWindowsPath' has 15 characters; the pure Windows path class name)"]

# ---------------------------------------------------------------------------
# pathlib.PosixPath MRO slot names
# PosixPath.__mro__ == (PosixPath, Path, PurePosixPath, PurePath, object) — 5 entries.
# PosixPath is the concrete path class for POSIX path semantics (Unix/macOS).
# Its MRO mirrors WindowsPath's structure exactly, differing only at slots 0 and 2:
# slot 0 is PosixPath (9 chars) vs WindowsPath (11 chars), and slot 2 is
# PurePosixPath (13 chars) vs PureWindowsPath (15 chars).
# Both share Path at slot 1, PurePath at slot 3, and object at slot 4.
# No prior pathlib_extra spec has indexed individual MRO slots for PosixPath.
# ---------------------------------------------------------------------------

table pathlib_extra122.PosixPath_mro_slot_names:
  description: "pathlib.PosixPath.__mro__ slot names: [0]='PosixPath'(9),[1]='Path'(4),[2]='PurePosixPath'(13),[3]='PurePath'(8),[4]='object'(6); 5-entry MRO; POSIX-flavour concrete path class"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pathlibppmro122b

  columns: [id, function, args, expected, description]
  rows:
    - [pp_mro0_name,  "PosixPath.__mro__[0].__name__.__eq__",  ["PosixPath"],      true,  "pathlib.PosixPath.__mro__[0].__name__ == 'PosixPath' (the class itself is first in its own MRO; POSIX-flavour concrete path type)"]
    - [pp_mro1_name,  "PosixPath.__mro__[1].__name__.__eq__",  ["Path"],           true,  "pathlib.PosixPath.__mro__[1].__name__ == 'Path' (direct parent; same Path object as WindowsPath.__mro__[1] — the shared concrete base)"]
    - [pp_mro2_name,  "PosixPath.__mro__[2].__name__.__eq__",  ["PurePosixPath"],  true,  "pathlib.PosixPath.__mro__[2].__name__ == 'PurePosixPath' (pure POSIX path mixin; provides case-sensitive, forward-slash parsing rules at MRO slot 2)"]
    - [pp_mro3_name,  "PosixPath.__mro__[3].__name__.__eq__",  ["PurePath"],       true,  "pathlib.PosixPath.__mro__[3].__name__ == 'PurePath' (root pure path base; same PurePath object as WindowsPath.__mro__[3])"]
    - [pp_mro4_name,  "PosixPath.__mro__[4].__name__.__eq__",  ["object"],         true,  "pathlib.PosixPath.__mro__[4].__name__ == 'object' (universal Python base class; same terminal slot as WindowsPath.__mro__[4])"]
    - [pp_mro2_ne_wp, "PosixPath.__mro__[2].__name__.__eq__",  ["PureWindowsPath"], false, "pathlib.PosixPath.__mro__[2].__name__ != 'PureWindowsPath' (slot 2 is 'PurePosixPath', not 'PureWindowsPath'; the two concrete path classes diverge at MRO slot 2)"]
    - [pp_mro2_len,   "PosixPath.__mro__[2].__name__.__len__", [],                 13,    "pathlib.PosixPath.__mro__[2].__name__.__len__() == 13 ('PurePosixPath' has 13 characters; 2 shorter than 'PureWindowsPath'(15) at WindowsPath.__mro__[2])"]

# ---------------------------------------------------------------------------
# WindowsPath and PosixPath name lengths, module, and cross-comparisons
# WindowsPath.__name__ has 11 chars; PosixPath.__name__ has 9 chars.
# Both have __module__ == 'pathlib' and metaclass 'type'.
# Their MROs are structurally identical (5 entries; same Path, PurePath, object)
# but diverge at slots 0 and 2 (class name and pure path mixin).
# MRO slot 1 'Path' (4 chars) is shared; slot 2 pure-path names differ by 2 chars
# (PurePosixPath=13 vs PureWindowsPath=15).
# ---------------------------------------------------------------------------

table pathlib_extra122.WindowsPath_PosixPath_name_lengths_and_module:
  description: "pathlib.WindowsPath.__name__ len=11; PosixPath.__name__ len=9; both __module__=='pathlib'; MRO slot 1 is 'Path'(4) for both; slot 2 differs: PureWindowsPath(15) vs PurePosixPath(13); both metaclass 'type'"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pathlibwppp122c

  columns: [id, function, args, expected, description]
  rows:
    - [wp_name_len,    "WindowsPath.__name__.__len__",                         [],          11,    "pathlib.WindowsPath.__name__.__len__() == 11 ('WindowsPath' has 11 characters: 'Windows'(7)+'Path'(4)==11)"]
    - [pp_name_len,    "PosixPath.__name__.__len__",                           [],          9,     "pathlib.PosixPath.__name__.__len__() == 9 ('PosixPath' has 9 characters: 'Posix'(5)+'Path'(4)==9)"]
    - [wp_gt_pp,       "WindowsPath.__name__.__len__.__gt__",                  [9],         true,  "len('WindowsPath') > len('PosixPath') (11 > 9; WindowsPath is 2 chars longer due to 'Windows'(7) vs 'Posix'(5))"]
    - [wp_mod_eq,      "WindowsPath.__module__.__eq__",                        ["pathlib"], true,  "pathlib.WindowsPath.__module__ == 'pathlib' (pure Python class; not a C extension; defined in Lib/pathlib/_local.py)"]
    - [pp_mod_eq,      "PosixPath.__module__.__eq__",                          ["pathlib"], true,  "pathlib.PosixPath.__module__ == 'pathlib' (pure Python class; same module as WindowsPath)"]
    - [wp_cls_type,    "WindowsPath.__class__.__name__.__eq__",                ["type"],    true,  "type(pathlib.WindowsPath).__name__ == 'type' (plain Python class created with ordinary 'type' metaclass)"]
    - [pp_cls_type,    "PosixPath.__class__.__name__.__eq__",                  ["type"],    true,  "type(pathlib.PosixPath).__name__ == 'type' (plain Python class created with ordinary 'type' metaclass like WindowsPath)"]
    - [wp_mro1_len,    "WindowsPath.__mro__[1].__name__.__len__",              [],          4,     "pathlib.WindowsPath.__mro__[1].__name__.__len__() == 4 ('Path' has 4 characters; shared with PosixPath.__mro__[1])"]
    - [pp_mro1_len,    "PosixPath.__mro__[1].__name__.__len__",                [],          4,     "pathlib.PosixPath.__mro__[1].__name__.__len__() == 4 ('Path' has 4 characters; same as WindowsPath.__mro__[1].__name__.__len__())"]
    - [wp_slot2_gt_pp, "WindowsPath.__mro__[2].__name__.__len__.__gt__",       [13],        true,  "len(pathlib.WindowsPath.__mro__[2].__name__) > len(pathlib.PosixPath.__mro__[2].__name__) (15 > 13; 'PureWindowsPath' is 2 chars longer than 'PurePosixPath')"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra122.WindowsPath.mro_slot1_is_Path:
  description: "pathlib.WindowsPath.__mro__[1].__name__ == 'Path' (length 4; WindowsPath is the concrete platform path class for Windows; its MRO is (WindowsPath, Path, PureWindowsPath, PurePath, object) — a 5-entry chain; Path at MRO slot 1 is the shared abstract concrete base class that WindowsPath and PosixPath both inherit directly from; Path adds file-system operations (stat, open, mkdir, etc.) on top of the pure path parsing in PurePath; pathlib_extra112 covered WindowsPath.__mro__.__len__()==5 and __bases__[0].__name__=='Path'; this spec is the first to index into individual MRO slots for WindowsPath via double-quoted bracket-path notation)"
  category: class_hierarchy
  kind: python_call_eq
  function: "WindowsPath.__mro__[1].__name__.__eq__"
  args: ["Path"]
  expected: true

invariant pathlib_extra122.PosixPath.mro_slot1_is_Path:
  description: "pathlib.PosixPath.__mro__[1].__name__ == 'Path' (length 4; PosixPath is the concrete platform path class for POSIX systems; its MRO is (PosixPath, Path, PurePosixPath, PurePath, object) — a 5-entry chain structurally identical to WindowsPath's except at slots 0 and 2; Path at MRO slot 1 is the same Path object shared by both PosixPath and WindowsPath; pathlib_extra112 covered PosixPath.__mro__.__len__()==5 and __bases__[0].__name__=='Path'; this spec is the first to index individual MRO slots for PosixPath)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PosixPath.__mro__[1].__name__.__eq__"
  args: ["Path"]
  expected: true

invariant pathlib_extra122.WindowsPath.mro_slot2_is_PureWindowsPath:
  description: "pathlib.WindowsPath.__mro__[2].__name__ == 'PureWindowsPath' (length 15; PureWindowsPath is the pure path mixin that appears at MRO slot 2 for WindowsPath; it provides Windows-flavour path parsing: case-insensitive comparisons, backslash and forward-slash as separators, and drive-letter and UNC path recognition; PureWindowsPath.__mro__ has 3 entries (PureWindowsPath, PurePath, object) — it appears as a complete sub-hierarchy within WindowsPath's 5-entry MRO; no prior pathlib_extra spec has indexed WindowsPath.__mro__[2])"
  category: class_hierarchy
  kind: python_call_eq
  function: "WindowsPath.__mro__[2].__name__.__eq__"
  args: ["PureWindowsPath"]
  expected: true

invariant pathlib_extra122.PosixPath.mro_slot2_is_PurePosixPath:
  description: "pathlib.PosixPath.__mro__[2].__name__ == 'PurePosixPath' (length 13; PurePosixPath is the pure path mixin that appears at MRO slot 2 for PosixPath; it provides POSIX-flavour path parsing: case-sensitive comparisons, forward-slash separator only, and no drive-letter concept; PurePosixPath.__mro__ has 3 entries (PurePosixPath, PurePath, object) — it appears as a complete sub-hierarchy within PosixPath's 5-entry MRO; no prior pathlib_extra spec has indexed PosixPath.__mro__[2]; 'PurePosixPath'(13) is 2 chars shorter than 'PureWindowsPath'(15) at WindowsPath.__mro__[2])"
  category: class_hierarchy
  kind: python_call_eq
  function: "PosixPath.__mro__[2].__name__.__eq__"
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra122.WindowsPath.name_longer_than_PosixPath:
  description: "pathlib.WindowsPath.__name__.__len__() == 11 > 9 == pathlib.PosixPath.__name__.__len__() (WindowsPath is 2 characters longer than PosixPath because 'Windows' is 7 chars while 'Posix' is 5 chars; both share the 'Path'(4) suffix; the same length difference appears at MRO slot 2: 'PureWindowsPath'(15) > 'PurePosixPath'(13) by 2 chars; the 2-char pattern reflects the consistent difference between 'Windows'(7) and 'Posix'(5) across the pathlib name hierarchy)"
  category: class_hierarchy
  kind: python_call_eq
  function: "WindowsPath.__name__.__len__.__gt__"
  args: [9]
  expected: true
