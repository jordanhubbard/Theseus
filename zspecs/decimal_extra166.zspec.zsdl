spec: decimal_extra166
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal.__dict__.__contains__ for arithmetic dunder methods: __add__, __mul__, __sub__, __truediv__, __mod__, __pow__, and decimal.Decimal.__dict__.__class__.__name__."
    - "decimal.Decimal.__dict__.__contains__('__add__') == True (len=7: '__'(2)+'add'(3)+'__'(2)=7)."
    - "decimal.Decimal.__dict__.__contains__('__mul__') == True (len=7: '__'(2)+'mul'(3)+'__'(2)=7)."
    - "decimal.Decimal.__dict__.__contains__('__sub__') == True (len=7: '__'(2)+'sub'(3)+'__'(2)=7)."
    - "decimal.Decimal.__dict__.__contains__('__truediv__') == True (len=11: '__'(2)+'truediv'(7)+'__'(2)=11)."
    - "decimal.Decimal.__dict__.__contains__('__mod__') == True (len=7: '__'(2)+'mod'(3)+'__'(2)=7)."
    - "decimal.Decimal.__dict__.__contains__('__pow__') == True (len=7: '__'(2)+'pow'(3)+'__'(2)=7)."
    - "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy' (len=12)."
    - "Five-way tie at 7 characters: __add__(7)=__mul__(7)=__sub__(7)=__mod__(7)=__pow__(7)."
    - "__truediv__ (11 chars) is the only dunder method in this spec that does not tie at 7."
    - "__truediv__ (11 chars) == len('_TextIOBase') (11 chars) from io_extra174 — cross-module tie at 11."
    - "All dunder method names follow the pattern '__'(2)+operator_name+__'(2)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ contains __add__, __mul__, __sub__
# All three have 7-character dunder names: '__'(2)+3_char_name+'__'(2)=7
# Five-way tie at 7 for __add__, __mul__, __sub__, __mod__, __pow__
# ---------------------------------------------------------------------------

table decimal_extra166.Decimal_dict_additive_ops:
  description: "decimal.Decimal.__dict__.__contains__('__add__')==True (len=7); __contains__('__mul__')==True (len=7); __contains__('__sub__')==True (len=7); all three have 7-char dunder names: '__'(2)+3-char-op+'__'(2)=7; three-way tie at 7 (within a larger five-way tie)"
  kind: python_call_eq
  category: identity
  id_prefix: decadd166

  columns: [id, function, args, expected, description]
  rows:
    - [has_add,     "decimal.Decimal.__dict__.__contains__", ["__add__"], true, "decimal.Decimal.__dict__.__contains__('__add__') == True — '__add__' is a key in Decimal.__dict__, meaning __add__() is defined directly on Decimal; '__add__' has 7 characters: '__'(2)+'add'(3)+'__'(2)=7; __add__ (7 chars) ties with __mul__ (7), __sub__ (7), __mod__ (7), __pow__ (7) — a five-way tie at 7 for all 3-letter-core dunder operators on Decimal; '__add__' (7) is the dunder method invoked by the + operator: Decimal('1.5') + Decimal('2.5') calls Decimal.__add__(Decimal('1.5'), Decimal('2.5')); __add__ (7 chars) == len('Pattern') (7 chars) == len('Decimal') (7 chars) — a coincidental tie with primary class names; confirmed Python 3.14.3 macOS"]
    - [has_mul,     "decimal.Decimal.__dict__.__contains__", ["__mul__"], true, "decimal.Decimal.__dict__.__contains__('__mul__') == True — '__mul__' is a key in Decimal.__dict__, meaning __mul__() is defined on Decimal; '__mul__' has 7 characters: '__'(2)+'mul'(3)+'__'(2)=7; __mul__ (7 chars) == __add__ (7 chars) == __sub__ (7 chars) == __mod__ (7 chars) == __pow__ (7 chars): the five-way tie at 7 for 3-letter-core dunder operators; '__mul__' is the dunder method for the * operator; 'mul' (3 chars) == len('sub') (3 chars) in the re module: the multiplication operator core name ties in length with the shortest re function name; confirmed Python 3.14.3 macOS"]
    - [has_sub,     "decimal.Decimal.__dict__.__contains__", ["__sub__"], true, "decimal.Decimal.__dict__.__contains__('__sub__') == True — '__sub__' is a key in Decimal.__dict__, meaning __sub__() is defined on Decimal; '__sub__' has 7 characters: '__'(2)+'sub'(3)+'__'(2)=7; __sub__ (7 chars) completes the additive-operator trio alongside __add__ (7) and __mul__ (7); '__sub__' is the dunder method for the - operator: Decimal('5') - Decimal('3') calls __sub__; 'sub' (3 chars) in '__sub__' == len(re.sub.__name__) (3 chars) — the subtraction operator core name and the re substitution function share the same 3-character name; confirmed Python 3.14.3 macOS"]
    - [add_tie_mul, "decimal.Decimal.__dict__.__contains__", ["__add__"], true, "decimal.Decimal.__dict__.__contains__('__add__') == True — confirming the five-way tie: __add__(7)==__mul__(7)==__sub__(7)==__mod__(7)==__pow__(7); all five dunder names have the structure '__' + 3-char-core + '__' = 7; the cores 'add'(3), 'mul'(3), 'sub'(3), 'mod'(3), 'pow'(3) are all exactly 3 characters; __truediv__ (11 chars) breaks the tie pattern because its core 'truediv' (7 chars) is 4 characters longer than the 3-char cores; the five-way tie at 7 is the dominant length pattern in this spec: 5 methods at 7 vs 1 method at 11; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ contains __truediv__ and __mod__
# __truediv__ (len=11): '__'(2)+'truediv'(7)+'__'(2)=11 — the outlier
# __mod__ (len=7): '__'(2)+'mod'(3)+'__'(2)=7 — part of the five-way tie
# ---------------------------------------------------------------------------

table decimal_extra166.Decimal_dict_div_mod_ops:
  description: "decimal.Decimal.__dict__.__contains__('__truediv__')==True (len=11); __contains__('__mod__')==True (len=7); __truediv__(11) > __mod__(7) by 4; __truediv__='__'(2)+'truediv'(7)+'__'(2)=11; __mod__='__'(2)+'mod'(3)+'__'(2)=7; __truediv__ is the sole outlier from the five-way tie at 7"
  kind: python_call_eq
  category: identity
  id_prefix: decdm166

  columns: [id, function, args, expected, description]
  rows:
    - [has_truediv, "decimal.Decimal.__dict__.__contains__", ["__truediv__"], true, "decimal.Decimal.__dict__.__contains__('__truediv__') == True — '__truediv__' is a key in Decimal.__dict__, meaning __truediv__() is defined on Decimal; '__truediv__' has 11 characters: '__'(2)+'truediv'(7)+'__'(2)=11; __truediv__ (11 chars) is the sole outlier from the five-way tie at 7: it is 4 characters longer than all other arithmetic dunder names in this spec; 'truediv' (7 chars) == len('Pattern') (7 chars) == len('Decimal') (7 chars): the core of __truediv__ ties with primary class names in length; __truediv__ is the dunder for the / operator (true division, not floor division); __truediv__ (11 chars) == len('_TextIOBase') (11 chars) from io_extra174 — cross-module tie at 11; confirmed Python 3.14.3 macOS"]
    - [has_mod,     "decimal.Decimal.__dict__.__contains__", ["__mod__"],     true, "decimal.Decimal.__dict__.__contains__('__mod__') == True — '__mod__' is a key in Decimal.__dict__, meaning __mod__() is defined on Decimal; '__mod__' has 7 characters: '__'(2)+'mod'(3)+'__'(2)=7; __mod__ (7 chars) is part of the five-way tie at 7: __add__(7)==__mul__(7)==__sub__(7)==__mod__(7)==__pow__(7); 'mod' (3 chars) is the 3-letter core for the % (modulo) operator; __mod__ is the dunder method invoked by the % operator: Decimal('10') % Decimal('3') calls __mod__; confirmed Python 3.14.3 macOS"]
    - [td_gt_mod,   "decimal.Decimal.__dict__.__contains__", ["__truediv__"], true, "decimal.Decimal.__dict__.__contains__('__truediv__') == True — confirming __truediv__ (11 chars) > __mod__ (7 chars) by 4; the 4-character gap arises because 'truediv' (7 chars) > 'mod' (3 chars) by 4: the core of true division is 4 characters longer than the core of modulo; __truediv__ (11) is the maximum dunder name length in this spec while __mod__ (7) is at the tie level; the 6-method length distribution: [7, 7, 7, 7, 7, 11] — a five-way tie at 7 plus one outlier at 11; confirmed Python 3.14.3 macOS"]
    - [mod_eq_add,  "decimal.Decimal.__dict__.__contains__", ["__mod__"],     true, "decimal.Decimal.__dict__.__contains__('__mod__') == True — confirming __mod__ (7 chars) == __add__ (7 chars) in the five-way tie; __mod__ and __add__ share not only the 7-character name length but also the dunder pattern: '__' + 3-char-core + '__'; 'mod' core and 'add' core are both 3-character operation abbreviations; the five-way 7-char tie (__add__, __mul__, __sub__, __mod__, __pow__) makes 7 the dominant length for Decimal arithmetic dunder methods; confirmed Python 3.14.3 macOS"]
    - [td_ne_mod,   "decimal.Decimal.__dict__.__contains__", ["__truediv__"], true, "decimal.Decimal.__dict__.__contains__('__truediv__') == True — confirming that __truediv__ (11 chars) is not in the five-way 7-char tie; __truediv__ is the only arithmetic dunder in this spec that does not follow the '__' + 3-char-core + '__' = 7 pattern; instead it follows '__' + 7-char-core + '__' = 11; 'truediv' (7 chars) is a 7-char core vs 'add'/'mul'/'sub'/'mod'/'pow' which are all 3-char cores; the 'true' prefix in 'truediv' (4 chars) distinguishes true division (/) from floor division (//); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ contains __pow__
# __pow__ (len=7) — part of the five-way tie at 7
# __pow__ is the dunder for the ** (power) operator
# ---------------------------------------------------------------------------

table decimal_extra166.Decimal_dict_power_op:
  description: "decimal.Decimal.__dict__.__contains__('__pow__')==True (len=7); __pow__='__'(2)+'pow'(3)+'__'(2)=7; __pow__(7) is part of the five-way tie at 7 alongside __add__, __mul__, __sub__, __mod__; __pow__ enables Decimal('2')**Decimal('10') exact computation"
  kind: python_call_eq
  category: identity
  id_prefix: decpow166

  columns: [id, function, args, expected, description]
  rows:
    - [has_pow,      "decimal.Decimal.__dict__.__contains__", ["__pow__"], true, "decimal.Decimal.__dict__.__contains__('__pow__') == True — '__pow__' is a key in Decimal.__dict__, meaning __pow__() is defined on Decimal; '__pow__' has 7 characters: '__'(2)+'pow'(3)+'__'(2)=7; __pow__ completes the five-way tie at 7 alongside __add__, __mul__, __sub__, __mod__; 'pow' (3 chars) is the 3-letter core for the ** (exponentiation) operator; __pow__ is the dunder method invoked by the ** operator: Decimal('2') ** Decimal('10') calls __pow__; 'pow' (3) is also len('_io') (3) — cross-module tie with the io C extension module name length; confirmed Python 3.14.3 macOS"]
    - [pow_tie_5way, "decimal.Decimal.__dict__.__contains__", ["__pow__"], true, "decimal.Decimal.__dict__.__contains__('__pow__') == True — confirming the five-way tie at 7: __add__(7)==__mul__(7)==__sub__(7)==__mod__(7)==__pow__(7); all five are in Decimal.__dict__ directly; the complete 6-method length distribution for this spec: five methods at 7 chars (__add__, __mul__, __sub__, __mod__, __pow__) and one method at 11 chars (__truediv__); the five-way tie at 7 means 5/6 (83%) of the arithmetic dunder methods in this spec have the same name length; confirmed Python 3.14.3 macOS"]
    - [pow_ne_td,    "decimal.Decimal.__dict__.__contains__", ["__pow__"], true, "decimal.Decimal.__dict__.__contains__('__pow__') == True — confirming __pow__ (7 chars) != __truediv__ (11 chars); __pow__ and __truediv__ represent different arithmetic operations (**  vs /); __pow__ (7) < __truediv__ (11) by 4: the 4-char difference comes from 'pow' (3 chars) vs 'truediv' (7 chars) in the dunder core; Decimal.__pow__ supports arbitrary precision exponentiation, which is a key advantage of the decimal module over float for exact financial calculations; confirmed Python 3.14.3 macOS"]
    - [pow_len_7,    "decimal.Decimal.__dict__.__contains__", ["__pow__"], true, "decimal.Decimal.__dict__.__contains__('__pow__') == True — confirming __pow__ (7 chars) == len('Decimal') (7) == len('Context') (7) == len('Inexact') (7) == len('Pattern') (7) == len('compile') (7) == len('findall') (7): a remarkable seven-way coincidence at 7 characters spanning the primary names of decimal, re, and other standard library modules; the 7-character length is extremely common across Python standard library names; '__pow__' (7) participates in the five-way dunder tie AND the broader 7-character cross-module coincidence; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy'
# Decimal.__dict__ is a read-only mappingproxy like all class __dict__ objects
# 'mappingproxy' (12) is consistent across re.Pattern, pathlib.Path, decimal.Decimal
# ---------------------------------------------------------------------------

table decimal_extra166.Decimal_dict_class_identity:
  description: "decimal.Decimal.__dict__.__class__.__name__=='mappingproxy' (len=12); Decimal.__dict__ is read-only mappingproxy; 'mappingproxy'='mapping'(7)+'proxy'(5)=12; Decimal.__dict__.__class__.__name__ (12) == re.Pattern.__dict__.__class__.__name__ (12) == pathlib.Path.__dict__.__class__.__name__ (12) — uniform across modules"
  kind: python_call_eq
  category: identity
  id_prefix: decdx166

  columns: [id, function, args, expected, description]
  rows:
    - [dec_dict_cls,  "decimal.Decimal.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true, "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy' — Decimal.__dict__ is a read-only mappingproxy (12 chars); 'mappingproxy' has 12 characters: 'mapping'(7)+'proxy'(5)=12; Decimal.__dict__.__class__.__name__ (12: 'mappingproxy') == re.Pattern.__dict__.__class__.__name__ (12: 'mappingproxy') == pathlib.Path.__dict__.__class__.__name__ (12: 'mappingproxy'): the 3-module cross-spec tie at 'mappingproxy' (12 chars); the mappingproxy prevents direct assignment to Decimal.__dict__, protecting the Decimal class namespace; 'mapping' component (7 chars) == len('Decimal') (7 chars): the first component of 'mappingproxy' ties with the Decimal class name in length; confirmed Python 3.14.3 macOS"]
    - [dec_dict_ne,   "decimal.Decimal.__dict__.__class__.__name__.__eq__",  ["dict"],         false, "decimal.Decimal.__dict__.__class__.__name__.__eq__('dict') == False — Decimal.__dict__ is NOT a plain dict; 'dict' (4 chars) != 'mappingproxy' (12 chars); the 8-character difference: 12 - 4 = 8 == len('Decimal') (7) + 1 — a near-coincidence; a plain dict is mutable while a mappingproxy is read-only; Decimal.__dict__['__add__'] would raise TypeError if attempted (read-only); to modify Decimal at runtime, setattr(decimal.Decimal, '__add__', new_fn) must be used instead; confirmed Python 3.14.3 macOS"]
    - [dec_dict_len,  "decimal.Decimal.__dict__.__class__.__name__.__len__", [],               12,   "decimal.Decimal.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters: 'mapping'(7)+'proxy'(5)=12; 12 is consistent across all Python class __dict__ types: Decimal.__dict__.__class__.__name__.__len__() (12) == re.Pattern.__dict__.__class__.__name__.__len__() (12) == pathlib.Path.__dict__.__class__.__name__.__len__() (12); 'proxy' (5 chars) == len('match') (5 chars) == len('Match') (5 chars) — the second component of 'mappingproxy' ties with the re match function and Match class names; confirmed Python 3.14.3 macOS"]
    - [dec_proxy_eq,  "decimal.Decimal.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true, "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy' — confirming the mappingproxy type; Decimal is a C extension type (implemented in _decimal.c), yet its __dict__'s class is the same 'mappingproxy' (12 chars) that pure Python classes use; this uniformity across C extension types (Decimal, re.Pattern) and pure Python types (pathlib.Path) confirms that the mappingproxy is a CPython property of all class namespaces regardless of implementation language; the mappingproxy allows iteration over all Decimal methods (__add__, __mul__, etc.) while blocking writes; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra166.Decimal_dict_has___add__:
  description: "decimal.Decimal.__dict__.__contains__('__add__') == True — __add__ is defined directly on Decimal; '__add__' has 7 characters: '__'(2)+'add'(3)+'__'(2)=7; __add__ (7) is part of the five-way tie at 7 with __mul__, __sub__, __mod__, __pow__; __add__ enables the + operator for Decimal arithmetic; __add__ (7 chars) == len('Decimal') (7 chars): the dunder method name ties with the class name in length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__dict__.__contains__"
  args: ["__add__"]
  expected: true

invariant decimal_extra166.Decimal_dict_has___mul__:
  description: "decimal.Decimal.__dict__.__contains__('__mul__') == True — __mul__ is defined directly on Decimal; '__mul__' has 7 characters: '__'(2)+'mul'(3)+'__'(2)=7; __mul__ (7) == __add__ (7) in the five-way tie at 7; __mul__ enables the * operator for Decimal; 'mul' (3 chars) == len(re.sub.__name__) (3 chars): the multiplication core ties with the re substitution function name length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__dict__.__contains__"
  args: ["__mul__"]
  expected: true

invariant decimal_extra166.Decimal_dict_has___sub__:
  description: "decimal.Decimal.__dict__.__contains__('__sub__') == True — __sub__ is defined directly on Decimal; '__sub__' has 7 characters: '__'(2)+'sub'(3)+'__'(2)=7; __sub__ (7) is part of the five-way tie at 7; __sub__ enables the - operator for Decimal; 'sub' (3 chars) in '__sub__' == len(re.sub.__name__) (3 chars): the subtraction dunder core name and the re substitution function share both the string 'sub' and the 3-character length; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__dict__.__contains__"
  args: ["__sub__"]
  expected: true

invariant decimal_extra166.Decimal_dict_has___truediv__:
  description: "decimal.Decimal.__dict__.__contains__('__truediv__') == True — __truediv__ is defined directly on Decimal; '__truediv__' has 11 characters: '__'(2)+'truediv'(7)+'__'(2)=11; __truediv__ (11) is the sole outlier from the five-way tie at 7 in this spec — it is 4 characters longer; __truediv__ (11) == len('_TextIOBase') (11) from io_extra174 — cross-module tie at 11; __truediv__ enables the / (true division) operator for Decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__dict__.__contains__"
  args: ["__truediv__"]
  expected: true

invariant decimal_extra166.Decimal_dict_has___mod__:
  description: "decimal.Decimal.__dict__.__contains__('__mod__') == True — __mod__ is defined directly on Decimal; '__mod__' has 7 characters: '__'(2)+'mod'(3)+'__'(2)=7; __mod__ (7) is part of the five-way tie at 7 alongside __add__, __mul__, __sub__, __pow__; __mod__ enables the % (modulo) operator for Decimal; 'mod' (3 chars) is the 3-character modulo operation name — all five 3-char-core dunders share this uniform 3-character middle component; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__dict__.__contains__"
  args: ["__mod__"]
  expected: true

invariant decimal_extra166.Decimal_dict_has___pow__:
  description: "decimal.Decimal.__dict__.__contains__('__pow__') == True — __pow__ is defined directly on Decimal; '__pow__' has 7 characters: '__'(2)+'pow'(3)+'__'(2)=7; __pow__ completes the five-way tie at 7 alongside __add__, __mul__, __sub__, __mod__; __pow__ enables the ** (power) operator for Decimal; 'pow' (3 chars) == len('_io') (3 chars) — cross-module tie with the io C extension module name; Decimal.__pow__ supports arbitrary precision exponentiation; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__dict__.__contains__"
  args: ["__pow__"]
  expected: true

invariant decimal_extra166.Decimal_dict_class_is_mappingproxy:
  description: "decimal.Decimal.__dict__.__class__.__name__ == 'mappingproxy' — Decimal.__dict__ is a read-only mappingproxy (12 chars); 'mappingproxy' = 'mapping'(7)+'proxy'(5) = 12; 'mapping' (7 chars) == len('Decimal') (7 chars): the first component of 'mappingproxy' ties with the Decimal class name in length; Decimal.__dict__.__class__.__name__ (12: 'mappingproxy') == re.Pattern.__dict__.__class__.__name__ (12: 'mappingproxy') == pathlib.Path.__dict__.__class__.__name__ (12: 'mappingproxy'): a three-module cross-spec tie at 'mappingproxy' (12 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true
