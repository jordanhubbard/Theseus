spec: io_extra74
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra73.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__.__eq__; FileIO/BytesIO/StringIO/TextIOWrapper __name__.__eq__; IOBase/RawIOBase/BufferedIOBase/TextIOBase __module__.__contains__('io'); IOBase/FileIO/BytesIO/StringIO __qualname__.__eq__."
    - "io_extra72.zspec.zsdl — covers RawIOBase/BufferedIOBase/TextIOBase __bases__[0].__name__.__eq__('IOBase'); FileIO/__bases__[0].__name__.__eq__('RawIOBase'); BufferedReader/__bases__[0].__name__.__eq__('BufferedIOBase'); TextIOWrapper/__bases__[0].__name__.__eq__('TextIOBase'); RawIOBase/BufferedIOBase/TextIOBase __mro__.__len__()==3; FileIO/BufferedReader/TextIOWrapper __mro__.__len__()==4."
    - "io_extra71.zspec.zsdl — covers io.open/__doc__.__contains__; FileIO/BytesIO/StringIO/DEFAULT_BUFFER_SIZE doc/class checks."
  notes:
    - "This spec extends io_extra73.zspec.zsdl."
    - "Theme: io module-level constants and open() function identity — open.__class__.__name__, open.__module__, open.__doc__ checks; SEEK_SET/SEEK_CUR/SEEK_END class and value checks; UnsupportedOperation identity and hierarchy."
    - "io.open is the same object as the builtin open() function — it is a C builtin. open.__class__.__name__ == 'builtin_function_or_method'. No prior io spec checks open.__class__.__name__ in ioconst74 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "open.__module__ == 'io' — the public module name for the open builtin. No prior io spec checks open.__module__.__eq__('io') in ioconst74 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "open.__doc__.__class__.__name__ == 'str' — io.open has a docstring; its type is always str. No prior io spec checks open.__doc__.__class__.__name__ in ioconst74 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "open.__doc__.__contains__('mode') == True — the open() docstring describes the mode parameter. No prior io spec checks open.__doc__.__contains__('mode') in ioconst74 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — seek whence constants defined in the io module. All three are plain ints. No prior io spec checks SEEK_SET/SEEK_CUR/SEEK_END class name or value in ioconst74 namespace. Novel anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.UnsupportedOperation.__class__.__name__ == 'type' — UnsupportedOperation is an exception class (a type). No prior io spec checks UnsupportedOperation.__class__.__name__ in ioconst74 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.UnsupportedOperation.__module__.__contains__('io') == True — module is 'io' or '_io'; both contain 'io'. No prior io spec checks UnsupportedOperation.__module__.__contains__('io') in ioconst74 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — UnsupportedOperation inherits from both OSError and ValueError; __bases__[0] is OSError. No prior io spec checks UnsupportedOperation.__bases__[0].__name__ in ioconst74 namespace. Function value contains '[' so it is double-quoted. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Table row function values containing '[' must be double-quoted per ZSDL rules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.open() identity: __class__.__name__, __module__, __doc__ checks
#
# io.open is the same object as the builtin open() — it is a C builtin
# function. Its class name is 'builtin_function_or_method'. Its __module__
# attribute records the public module name 'io'. Its docstring exists and
# contains the word 'mode':
#   open.__class__.__name__       == 'builtin_function_or_method'
#   open.__module__               == 'io'
#   open.__doc__.__contains__('mode') == True
#
# No prior io spec checks any of these in ioconst74 namespace.
# Novel open() identity anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra74.open_identity:
  description: "open/__class__.__name__=='builtin_function_or_method'; open/__module__.__eq__('io')==True; open/__doc__.__contains__('mode')==True — io.open is a C builtin; __class__.__name__ is 'builtin_function_or_method'; __module__ is 'io'; docstring contains 'mode'; no prior io spec checks these in ioconst74 namespace; novel open() identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: ioconst74open

  columns: [id, function, args, expected]
  rows:
    - [open_class_builtin,   open.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [open_module_io,       open.__module__.__eq__,          ["io"],                         true]
    - [open_doc_mode,        open.__doc__.__contains__,       ["mode"],                       true]

# ---------------------------------------------------------------------------
# io seek constants: SEEK_SET, SEEK_CUR, SEEK_END class and value
#
# The io module exposes three POSIX seek whence constants as plain integers:
#   io.SEEK_SET == 0  (seek from beginning of file)
#   io.SEEK_CUR == 1  (seek from current position)
#   io.SEEK_END == 2  (seek from end of file)
#
# All three are instances of int, verified by __class__.__name__ == 'int'.
# Their __eq__ values confirm the exact integer value for each constant.
#
# No prior io spec checks SEEK_SET/SEEK_CUR/SEEK_END __class__.__name__ or
# __eq__ value in ioconst74 namespace. Novel constant anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra74.seek_constants:
  description: "SEEK_SET/SEEK_CUR/SEEK_END __class__.__name__=='int'; SEEK_SET.__eq__(0)==True; SEEK_CUR.__eq__(1)==True; SEEK_END.__eq__(2)==True — io module seek whence constants are plain integers with values 0, 1, 2 respectively; no prior io spec checks these in ioconst74 namespace; novel seek constant anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_constants
  id_prefix: ioconst74seek

  columns: [id, function, args, expected]
  rows:
    - [seek_set_class_int,    SEEK_SET.__class__.__name__.__eq__,  ["int"], true]
    - [seek_cur_class_int,    SEEK_CUR.__class__.__name__.__eq__,  ["int"], true]
    - [seek_end_class_int,    SEEK_END.__class__.__name__.__eq__,  ["int"], true]
    - [seek_set_eq_0,         SEEK_SET.__eq__,                     [0],     true]
    - [seek_cur_eq_1,         SEEK_CUR.__eq__,                     [1],     true]
    - [seek_end_eq_2,         SEEK_END.__eq__,                     [2],     true]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation class identity: __class__.__name__ and __module__
#
# io.UnsupportedOperation is an exception class (a type object) defined in
# the io module. Its __class__.__name__ is 'type' (it is a class). Its
# __module__ contains the substring 'io':
#   UnsupportedOperation.__class__.__name__       == 'type'
#   UnsupportedOperation.__module__.__contains__('io') == True
#
# No prior io spec checks UnsupportedOperation identity in ioconst74 namespace.
# Novel identity anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra74.UnsupportedOperation_identity:
  description: "UnsupportedOperation/__class__.__name__=='type'; UnsupportedOperation/__module__.__contains__('io')==True — io.UnsupportedOperation is an exception class (type object); __module__ is 'io' or '_io'; both contain 'io'; no prior io spec checks UnsupportedOperation identity in ioconst74 namespace; novel exception class identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioconst74unsupported

  columns: [id, function, args, expected]
  rows:
    - [unsupported_class_type,      UnsupportedOperation.__class__.__name__.__eq__,  ["type"], true]
    - [unsupported_module_io,       UnsupportedOperation.__module__.__contains__,    ["io"],   true]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation class hierarchy: __bases__[0].__name__
#
# io.UnsupportedOperation inherits from both OSError and ValueError:
#   UnsupportedOperation.__bases__ == (OSError, ValueError)
#   UnsupportedOperation.__bases__[0].__name__ == 'OSError'
#
# __bases__[0] is OSError — the first (leftmost) base class.
# Function value contains '[' so it must be double-quoted in the table row.
#
# No prior io spec checks UnsupportedOperation.__bases__[0].__name__ in
# ioconst74 namespace. Novel hierarchy anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra74.UnsupportedOperation_hierarchy:
  description: "UnsupportedOperation/__bases__[0].__name__=='OSError' — io.UnsupportedOperation inherits from both OSError and ValueError; __bases__[0] is OSError (the first/leftmost base); no prior io spec checks UnsupportedOperation.__bases__[0].__name__ in ioconst74 namespace; function value with '[' is double-quoted; novel hierarchy anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: ioconst74hier

  columns: [id, function, args, expected]
  rows:
    - [unsupported_bases_oserror,  "UnsupportedOperation.__bases__[0].__name__.__eq__",  ["OSError"], true]

invariant io_extra74.open_class_builtin:
  description: "open.__class__.__name__.__eq__('builtin_function_or_method') == True — io.open is the same object as the builtin open(); it is a C builtin function; __class__.__name__ is 'builtin_function_or_method'; no prior io spec checks open.__class__.__name__ in ioconst74 namespace; novel open() class identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant io_extra74.SEEK_SET_int:
  description: "SEEK_SET.__class__.__name__.__eq__('int') == True — io.SEEK_SET is a plain Python integer (value 0); __class__.__name__ is 'int'; no prior io spec checks SEEK_SET.__class__.__name__ in ioconst74 namespace; novel seek constant class-name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_constants
  kind: python_call_eq
  function: SEEK_SET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra74.SEEK_SET_eq_0:
  description: "SEEK_SET.__eq__(0) == True — io.SEEK_SET has value 0 (seek from beginning of file); this is the POSIX SEEK_SET constant; no prior io spec checks SEEK_SET.__eq__(0) in ioconst74 namespace; novel seek constant value anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra74.SEEK_CUR_eq_1:
  description: "SEEK_CUR.__eq__(1) == True — io.SEEK_CUR has value 1 (seek from current position); this is the POSIX SEEK_CUR constant; no prior io spec checks SEEK_CUR.__eq__(1) in ioconst74 namespace; novel seek constant value anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_constants
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant io_extra74.SEEK_END_eq_2:
  description: "SEEK_END.__eq__(2) == True — io.SEEK_END has value 2 (seek from end of file); this is the POSIX SEEK_END constant; no prior io spec checks SEEK_END.__eq__(2) in ioconst74 namespace; novel seek constant value anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true
