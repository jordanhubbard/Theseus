spec: decimal_extra52
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra51.zspec.zsdl — covers Decimal/Context __class__.__module__.__eq__('builtins'); DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Clamped __class__.__module__.__eq__('builtins')."
    - "decimal_extra50.zspec.zsdl — covers Decimal/Context/DecimalException/InvalidOperation/DivisionByZero __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); decimal module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "decimal_extra49.zspec.zsdl — covers all 8 decimal exception __module__=='decimal' equality and __module__.__class__.__name__=='str'."
    - "decimal_extra45.zspec.zsdl — covers ROUND_HALF_DOWN/ROUND_HALF_EVEN/ROUND_UP/ROUND_DOWN/ROUND_05UP __class__.__module__=='builtins'."
    - "decimal_extra43.zspec.zsdl — covers Decimal/__class__.__name__.__eq__('type'); Context/__class__.__name__.__eq__('type')."
    - "decimal_extra29.zspec.zsdl — covers Decimal/Context/DecimalException __dict__.__class__.__name__.__len__()==12."
  notes:
    - "This spec extends decimal_extra51.zspec.zsdl."
    - "Prior specs collectively covered: decimal_extra43 covers Decimal/__class__.__name__.__eq__('type') and Context/__class__.__name__.__eq__('type'); decimal_extra51 covers __class__.__module__=='builtins' for Decimal/Context and all decimal exceptions. NOT YET COVERED: Decimal/__repr__.__class__.__name__.__eq__('wrapper_descriptor') — Decimal is a C-extension type that defines __repr__ in its own __dict__ as a wrapper_descriptor; no prior decimal spec checks __repr__.__class__.__name__ for any decimal class; novel; Context/__repr__.__class__.__name__.__eq__('wrapper_descriptor') (novel); DecimalException/__repr__.__class__.__name__.__eq__('wrapper_descriptor') — inherits from BaseException; novel; InvalidOperation/__repr__.__class__.__name__.__eq__('wrapper_descriptor') — inherits from BaseException via DecimalException; novel; Decimal/__hash__.__class__.__name__.__eq__('wrapper_descriptor') — Decimal defines __hash__ in its own __dict__ as a wrapper_descriptor; Decimal is hashable (defines both __eq__ and __hash__); no prior decimal spec checks __hash__.__class__.__name__; novel; Context/__hash__.__class__.__name__.__eq__('wrapper_descriptor') — Context inherits __hash__ from object; novel."
    - "This spec covers: decimal.Decimal.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — Decimal is a C-extension type from _decimal; __repr__ is in Decimal.__dict__ as a wrapper_descriptor for 'decimal.Decimal' objects; no prior decimal spec checks __repr__.__class__.__name__; novel in decrepr52 namespace); decimal.Context.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — Context defines __repr__ in its own __dict__ as a wrapper_descriptor for 'decimal.Context' objects; novel); decimal.DecimalException.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — DecimalException inherits __repr__ from BaseException as a wrapper_descriptor; novel); decimal.InvalidOperation.__repr__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — InvalidOperation inherits from BaseException via DecimalException; same wrapper_descriptor; novel); decimal.Decimal.__hash__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — Decimal defines __hash__ in its own __dict__ as a wrapper_descriptor; Decimal is hashable (defines both __eq__ and __hash__); no prior decimal spec checks __hash__.__class__.__name__; novel in decrepr52 namespace); decimal.Context.__hash__.__class__.__name__.__eq__('wrapper_descriptor') (NOVEL — Context inherits __hash__ from object; object.__hash__ is a wrapper_descriptor; novel)."
    - "decimal.Decimal.__repr__.__class__.__name__ == 'wrapper_descriptor'. Decimal is implemented in the _decimal C extension. __repr__ is defined in Decimal.__dict__ as a slot wrapper for 'decimal.Decimal' objects. In Python 3.14.3, the class name is 'wrapper_descriptor'. No prior decimal spec checks __repr__.__class__.__name__ for any decimal class. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Context.__repr__.__class__.__name__ == 'wrapper_descriptor'. Context is also from the _decimal C extension. __repr__ is defined in Context.__dict__ as a wrapper_descriptor for 'decimal.Context' objects. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.DecimalException.__repr__.__class__.__name__ == 'wrapper_descriptor'. DecimalException is a pure-Python ArithmeticError/Exception subclass. It does NOT define __repr__ in its own __dict__; it inherits BaseException.__repr__, which is a wrapper_descriptor. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.InvalidOperation.__repr__.__class__.__name__ == 'wrapper_descriptor'. InvalidOperation is a DecimalException subclass. Same inheritance chain from BaseException. Same wrapper_descriptor. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor'. Decimal defines __hash__ in its own __dict__ as a wrapper_descriptor for 'decimal.Decimal' objects. Decimal defines both __eq__ and __hash__, so it is hashable. No prior decimal spec checks __hash__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.Context.__hash__.__class__.__name__ == 'wrapper_descriptor'. Context does NOT define __hash__ in its own __dict__; it inherits object.__hash__, which is a wrapper_descriptor. Context is hashable. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal Decimal/Context __repr__.__class__.__name__ == 'wrapper_descriptor'
#
# Decimal and Context are C-extension types from the _decimal module. Both
# define __repr__ in their own __dict__ as slot wrappers (wrapper_descriptor)
# for their respective types. In Python 3.14.3, the class name is
# 'wrapper_descriptor', not 'slot_wrapper'.
#
#   Decimal.__repr__.__class__.__name__ == 'wrapper_descriptor'
#   Context.__repr__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior decimal spec checks __repr__.__class__.__name__ for any decimal class.
# Both anchors are novel in the decrepr52 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra52.cext_repr_class_name_eq:
  description: "decimal Decimal/Context __repr__.__class__.__name__.__eq__('wrapper_descriptor') — both are C-extension types from _decimal that define __repr__ in their own __dict__; in Python 3.14.3 the class name is 'wrapper_descriptor'; no prior decimal spec checks __repr__.__class__.__name__; both novel anchors in decrepr52 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decrepr52cext

  columns: [id, function, args, expected]
  rows:
    - [Decimal_repr_class_name, "Decimal.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - [Context_repr_class_name, "Context.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# decimal exception __repr__.__class__.__name__ == 'wrapper_descriptor'
#
# DecimalException is a pure-Python ArithmeticError/Exception subclass.
# InvalidOperation is a DecimalException subclass. Neither defines __repr__
# in its own __dict__; both inherit BaseException.__repr__, which is a
# wrapper_descriptor. All decimal exception classes share this behavior.
#
#   DecimalException.__repr__.__class__.__name__ == 'wrapper_descriptor'
#   InvalidOperation.__repr__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior decimal spec checks __repr__.__class__.__name__ for exception classes.
# Both anchors are novel in the decrepr52 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra52.exception_repr_class_name_eq:
  description: "decimal exception __repr__.__class__.__name__.__eq__('wrapper_descriptor') for DecimalException/InvalidOperation — these exception classes inherit __repr__ from BaseException as a wrapper_descriptor; they do not define their own __repr__; no prior decimal spec checks __repr__.__class__.__name__ for decimal exception classes; both novel anchors in decrepr52 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decrepr52exc

  columns: [id, function, args, expected]
  rows:
    - [DecimalException_repr_class_name, "DecimalException.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - [InvalidOperation_repr_class_name, "InvalidOperation.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# decimal Decimal/Context __hash__.__class__.__name__ == 'wrapper_descriptor'
#
# Decimal defines __hash__ in its own __dict__ as a wrapper_descriptor for
# 'decimal.Decimal' objects. Decimal defines both __eq__ and __hash__, so it
# is hashable (unlike classes that only define __eq__, which would have
# __hash__ set to None). Context does NOT define __hash__ in its own __dict__;
# it inherits object.__hash__, which is also a wrapper_descriptor.
#
#   Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor'
#   Context.__hash__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior decimal spec checks __hash__.__class__.__name__ for any decimal class.
# Both anchors are novel in the decrepr52 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra52.hash_class_name_eq:
  description: "decimal Decimal/Context __hash__.__class__.__name__.__eq__('wrapper_descriptor') — Decimal defines __hash__ in its own __dict__ as a wrapper_descriptor (Decimal is hashable, defining both __eq__ and __hash__); Context inherits object.__hash__ which is also a wrapper_descriptor; no prior decimal spec checks __hash__.__class__.__name__; both novel anchors in decrepr52 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decrepr52hash

  columns: [id, function, args, expected]
  rows:
    - [Decimal_hash_class_name, "Decimal.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - [Context_hash_class_name, "Context.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

invariant decimal_extra52.Decimal_repr_class_name_wrapper_descriptor:
  description: "decimal.Decimal.__repr__.__class__.__name__ == 'wrapper_descriptor' — Decimal is a C-extension type from _decimal; __repr__ is defined in Decimal.__dict__ as a slot wrapper for 'decimal.Decimal' objects; in Python 3.14.3 the class name is 'wrapper_descriptor' (not 'slot_wrapper'); no prior decimal spec checks __repr__.__class__.__name__; novel anchor in decrepr52 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra52.DecimalException_repr_class_name_wrapper_descriptor:
  description: "decimal.DecimalException.__repr__.__class__.__name__ == 'wrapper_descriptor' — DecimalException is a pure-Python ArithmeticError subclass that inherits __repr__ from BaseException; BaseException.__repr__ is a wrapper_descriptor; no prior decimal spec checks __repr__.__class__.__name__ for decimal exception classes; novel anchor in decrepr52 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra52.Decimal_hash_class_name_wrapper_descriptor:
  description: "decimal.Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor' — Decimal defines __hash__ in its own __dict__ as a wrapper_descriptor for 'decimal.Decimal' objects; Decimal is hashable because it explicitly defines both __eq__ and __hash__; no prior decimal spec checks __hash__.__class__.__name__; novel anchor in decrepr52 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__hash__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
