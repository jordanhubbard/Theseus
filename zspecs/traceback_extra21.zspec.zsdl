spec: traceback_extra21
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends prior traceback specs through traceback_extra20.zspec.zsdl."
    - "traceback_extra18 covers: module-level function __qualname__ values (format_exc, format_tb, format_stack, print_exc, print_tb, extract_tb, extract_stack) and class __qualname__ for TracebackException and StackSummary."
    - "traceback_extra19 covers: class-bound method __qualname__ for TracebackException.from_exception/format/format_exception_only, StackSummary.extract/from_list/format, and FrameSummary class __qualname__."
    - "traceback_extra20 covers: __module__ attributes for TracebackException/StackSummary/FrameSummary classes, print_exc/format_exc/print_tb function __module__, and FrameSummary.__init__.__qualname__."
    - "Focus: __module__ attributes for TracebackException class-bound methods (from_exception, format, format_exception_only) and StackSummary class-bound methods (extract, format); __module__ for format_exception and extract_stack module-level functions."
    - "traceback.TracebackException.from_exception.__module__ == 'traceback' — method defined in the traceback module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.TracebackException.format.__module__ == 'traceback' — method defined in the traceback module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.TracebackException.format_exception_only.__module__ == 'traceback' — method defined in the traceback module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.StackSummary.extract.__module__ == 'traceback' — classmethod defined in the traceback module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.StackSummary.format.__module__ == 'traceback' — method defined in the traceback module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.format_exception.__module__ == 'traceback' — module-level function; __module__ equals the module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.extract_stack.__module__ == 'traceback' — module-level function; __module__ equals the module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TracebackException class-bound method __module__ values
#
# traceback_extra19 records __qualname__ for TracebackException.from_exception,
# TracebackException.format, and TracebackException.format_exception_only.
# No prior traceback spec records __module__ for these class-bound methods.
# All three are defined in the traceback module, so __module__ == 'traceback'.
# ---------------------------------------------------------------------------

invariant traceback_extra21.TracebackException.from_exception.module:
  description: "traceback.TracebackException.from_exception.__module__ == 'traceback' — method defined in the traceback module"
  category: method_module
  kind: python_call_eq
  function: TracebackException.from_exception.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra21.TracebackException.format.module:
  description: "traceback.TracebackException.format.__module__ == 'traceback' — method defined in the traceback module"
  category: method_module
  kind: python_call_eq
  function: TracebackException.format.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra21.TracebackException.format_exception_only.module:
  description: "traceback.TracebackException.format_exception_only.__module__ == 'traceback' — method defined in the traceback module"
  category: method_module
  kind: python_call_eq
  function: TracebackException.format_exception_only.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# StackSummary class-bound method __module__ values
#
# traceback_extra19 records __qualname__ for StackSummary.extract and
# StackSummary.format. No prior traceback spec records __module__ for these
# StackSummary methods. Both are defined in the traceback module.
# ---------------------------------------------------------------------------

invariant traceback_extra21.StackSummary.extract.module:
  description: "traceback.StackSummary.extract.__module__ == 'traceback' — classmethod defined in the traceback module"
  category: method_module
  kind: python_call_eq
  function: StackSummary.extract.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra21.StackSummary.format.module:
  description: "traceback.StackSummary.format.__module__ == 'traceback' — method defined in the traceback module"
  category: method_module
  kind: python_call_eq
  function: StackSummary.format.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# format_exception and extract_stack module-level function __module__
#
# traceback_extra3 covers format_tb and extract_tb __module__. traceback_extra20
# covers print_exc, format_exc, and print_tb __module__. No prior traceback spec
# records __module__ for format_exception or extract_stack.
# ---------------------------------------------------------------------------

invariant traceback_extra21.format_exception.module:
  description: "traceback.format_exception.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: format_exception.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra21.extract_stack.module:
  description: "traceback.extract_stack.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: extract_stack.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all seven method and function __module__ checks
#
# Covers TracebackException method __module__ (3), StackSummary method
# __module__ (2), and module-level function __module__ (2).
# ---------------------------------------------------------------------------

table traceback_extra21.method_and_function_modules:
  description: "__module__ values for TracebackException/StackSummary methods and remaining module-level functions"
  kind: python_call_eq
  category: method_module

  columns: [id, function, args, expected]
  rows:
    - [TracebackException_from_exception_module, TracebackException.from_exception.__module__.__eq__,      ["traceback"], true]
    - [TracebackException_format_module,         TracebackException.format.__module__.__eq__,              ["traceback"], true]
    - [TracebackException_format_exc_only_module, TracebackException.format_exception_only.__module__.__eq__, ["traceback"], true]
    - [StackSummary_extract_module,              StackSummary.extract.__module__.__eq__,                   ["traceback"], true]
    - [StackSummary_format_module,               StackSummary.format.__module__.__eq__,                    ["traceback"], true]
    - [format_exception_module,                  format_exception.__module__.__eq__,                       ["traceback"], true]
    - [extract_stack_module,                     extract_stack.__module__.__eq__,                          ["traceback"], true]
