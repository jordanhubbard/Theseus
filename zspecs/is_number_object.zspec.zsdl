spec: is_number_object
version: ">=1.1.1"
backend: node(is-number-object)

docs: https://www.npmjs.com/package/is-number-object

provenance:
  derived_from:
    - "is-number-object README — https://www.npmjs.com/package/is-number-object"
    - "Test vectors verified with is-number-object via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-number-object source"
  notes:
    - "is-number-object is an npm package. Install: npm install is-number-object"
    - "Returns true for numeric primitives and Number objects."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_number_object.isNumberObject:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: isnumobj

  columns: [id, args, expected]
  rows:
    - [number,  [42],     true]
    - [float,   [3.14],   true]
    - [string,  ["42"],   false]
    - [bool,    [true],   false]
    - [null_v,  [null],   false]
