spec: cf3301
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 667 (cf3301): __itruediv__, __ifloordiv__, __imod__ dict-presence (in-place /=, //=, %=) for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__itruediv__): all 3 concurrent.futures classes return false for __itruediv__. In-place true division (__itruediv__, /=) is the augmented assignment variant of __truediv__. concurrent.futures types define no __truediv__ (confirmed false in wave 659), so __itruediv__ is equally absent. concurrent.futures.Future is a result handle with a PENDING/RUNNING/CANCELLED/FINISHED state machine — not a numeric or collection type; future /= n is not a defined Python expression. ThreadPoolExecutor and ProcessPoolExecutor manage worker pools via submit()/map()/shutdown(); in-place division is not defined for executor objects."
    - "Key finding (__ifloordiv__): all 3 concurrent.futures classes return false for __ifloordiv__. In-place floor division (__ifloordiv__, //=) is the augmented assignment variant of __floordiv__. concurrent.futures types define no __floordiv__ (confirmed false in wave 659), so __ifloordiv__ is equally absent. concurrent.futures.Future: a state-machine result handle; future //= n is not a valid Python expression. ThreadPoolExecutor/ProcessPoolExecutor: worker-pool managers with an entirely method-based API; //= is not defined for executor objects."
    - "Key finding (__imod__): all 3 concurrent.futures classes return false for __imod__. In-place modulo (__imod__, %=) is the augmented assignment variant of __mod__. concurrent.futures types define no __mod__ (confirmed false in wave 659), so __imod__ is equally absent. Note: str defines __mod__ for % string formatting, but concurrent.futures types are not str subclasses and implement no formatting protocol. concurrent.futures.Future is a state-machine result handle, not a string type; future %= n is not a valid Python expression. ThreadPoolExecutor/ProcessPoolExecutor: executor types with no in-place modulo semantics."
    - "All 9 values in this wave are false. concurrent.futures is a high-level parallel execution API operating entirely through method calls — submit(), map(), result(), cancel(), add_done_callback(), shutdown() — with no arithmetic, in-place augmented assignment, or operator overloading of any kind."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (cf3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __itruediv__ dict-presence — operator.contains(Cls.__dict__, '__itruediv__')
#
# All 3 concurrent.futures classes return false for __itruediv__.
# In-place true division (__itruediv__, /=) is the augmented assignment variant
#   of __truediv__. concurrent.futures types define no __truediv__ (wave 659),
#   so __itruediv__ is equally absent.
# concurrent.futures.Future: a result-handle with PENDING/RUNNING/CANCELLED/
#   FINISHED states; future /= n is not a valid Python expression.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool managers with an
#   entirely method-based API; in-place division is not defined for pools.
# ---------------------------------------------------------------------------

table cf3301.itruediv:
  description: "concurrent.futures types __itruediv__ dict-presence checks; wave 667"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3301

  columns: [id, function, args, expected]
  rows:
    - ["cf3301001", operator.contains, [concurrent.futures.Future.__dict__,              "__itruediv__"], false]
    - ["cf3301002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__itruediv__"], false]
    - ["cf3301003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__itruediv__"], false]

# ---------------------------------------------------------------------------
# __ifloordiv__ dict-presence — operator.contains(Cls.__dict__, '__ifloordiv__')
#
# All 3 concurrent.futures classes return false for __ifloordiv__.
# In-place floor division (__ifloordiv__, //=) is the augmented assignment
#   variant of __floordiv__. concurrent.futures types define no __floordiv__
#   (wave 659), so __ifloordiv__ is equally absent.
# concurrent.futures.Future: a state-machine result handle; future //= n is
#   not a valid Python expression. Future manages asynchronous results through
#   callbacks and state transitions, not arithmetic operators.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers;
#   in-place floor division is entirely absent from their API.
# ---------------------------------------------------------------------------

table cf3301.ifloordiv:
  description: "concurrent.futures types __ifloordiv__ dict-presence checks; wave 667"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3301

  columns: [id, function, args, expected]
  rows:
    - ["cf3301004", operator.contains, [concurrent.futures.Future.__dict__,              "__ifloordiv__"], false]
    - ["cf3301005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ifloordiv__"], false]
    - ["cf3301006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ifloordiv__"], false]

# ---------------------------------------------------------------------------
# __imod__ dict-presence — operator.contains(Cls.__dict__, '__imod__')
#
# All 3 concurrent.futures classes return false for __imod__.
# In-place modulo (__imod__, %=) is the augmented assignment variant of __mod__.
# concurrent.futures types define no __mod__ (wave 659), so __imod__ is
#   equally absent.
# Note: str defines __mod__ for % string formatting, but concurrent.futures
#   types are not str subclasses and implement no formatting protocol.
# concurrent.futures.Future: a state-machine result handle, not a string type;
#   future %= n is not a valid Python expression.
# ThreadPoolExecutor/ProcessPoolExecutor: pool managers; executor %= n is
#   not a defined Python operation.
# ---------------------------------------------------------------------------

table cf3301.imod:
  description: "concurrent.futures types __imod__ dict-presence checks; wave 667"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3301

  columns: [id, function, args, expected]
  rows:
    - ["cf3301007", operator.contains, [concurrent.futures.Future.__dict__,              "__imod__"], false]
    - ["cf3301008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__imod__"], false]
    - ["cf3301009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__imod__"], false]

# ---------------------------------------------------------------------------
# combined — __itruediv__, __ifloordiv__, __imod__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __itruediv__: false for all 3 — no in-place true division defined.
# __ifloordiv__: false for all 3 — no in-place floor division defined.
# __imod__: false for all 3 — no in-place modulo defined.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire
#   public surface is method-based: submit(), map(), result(), cancel(),
#   done(), running(), cancelled(), add_done_callback(), shutdown().
#   Neither forward division/modulo operators (wave 659) nor their in-place
#   augmented assignment variants appear anywhere in the concurrent.futures
#   type hierarchy.
# concurrent.futures.Future note: despite the name, Future is a state-machine
#   result handle — not a numeric or string type. __itruediv__, __ifloordiv__,
#   and __imod__ are all absent from its __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate
#   a pool of worker threads or processes; they expose only lifecycle and
#   dispatch methods. No in-place augmented assignment operator overloads
#   are defined.
# str.__mod__ distinction: Python's built-in str defines __mod__ to implement
#   the % string formatting operator. concurrent.futures types are not str
#   subclasses and do not inherit or implement this protocol.
# ---------------------------------------------------------------------------

table cf3301.combined:
  description: "concurrent.futures types combined __itruediv__/__ifloordiv__/__imod__; wave 667"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3301

  columns: [id, function, args, expected]
  rows:
    - ["cf3301010", operator.contains, [concurrent.futures.Future.__dict__,              "__itruediv__"], false]
    - ["cf3301011", operator.contains, [concurrent.futures.Future.__dict__,              "__ifloordiv__"], false]
    - ["cf3301012", operator.contains, [concurrent.futures.Future.__dict__,              "__imod__"], false]
    - ["cf3301013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__itruediv__"], false]
    - ["cf3301014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ifloordiv__"], false]
    - ["cf3301015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__imod__"], false]
    - ["cf3301016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__itruediv__"], false]
    - ["cf3301017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ifloordiv__"], false]
    - ["cf3301018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__imod__"], false]
