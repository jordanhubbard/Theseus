spec: io_extra1666
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io.zspec.zsdl — covers io module base coverage"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* constants, TextIOWrapper/BufferedRandom/UnsupportedOperation class identity"
    - "_io_extra.zspec.zsdl — covers _io C module class names and is_type checks"
  notes:
    - "Theme: __new__ object construction protocol — which io classes define custom __new__."
    - "C extension stream classes StringIO, BytesIO, and FileIO each define their own __new__ in their tp_new slot, exposed as __new__ in __dict__."
    - "TextIOWrapper, BufferedReader, BufferedWriter do NOT define __new__ in their own __dict__; they rely on object.__new__ via the MRO."
    - "Abstract base classes IOBase, RawIOBase, BufferedIOBase, TextIOBase do NOT define __new__ or __init__ in their own __dict__."
    - "StringIO and BytesIO define __init__ to accept an optional initial value and newline/encoding args."
    - "FileIO defines __init__ to accept the file path and mode."
    - "UnsupportedOperation (a Python-level exception subclass) defines neither __new__ nor __init__ in its own __dict__."
    - "BufferedReader and BufferedWriter define __init__ but not __new__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table io_extra1666.new_init_checks
# Contains/has-__new__ and has-__init__ checks for all major io concrete classes.
# Verifies the construction protocol for each class.
# ---------------------------------------------------------------------------

table io_extra1666.new_init_checks:
  kind: python_call_eq
  category: construction_protocol
  id_prefix: io1666

  columns: [id, function, args, expected]
  rows:
    - ["io1666.StringIO.has_new",         StringIO.__dict__.__contains__,         ["__new__"],  true  ]
    - ["io1666.StringIO.has_init",         StringIO.__dict__.__contains__,         ["__init__"], true  ]
    - ["io1666.BytesIO.has_new",          BytesIO.__dict__.__contains__,          ["__new__"],  true  ]
    - ["io1666.BytesIO.has_init",         BytesIO.__dict__.__contains__,          ["__init__"], true  ]
    - ["io1666.FileIO.has_new",           FileIO.__dict__.__contains__,           ["__new__"],  true  ]
    - ["io1666.FileIO.has_init",          FileIO.__dict__.__contains__,           ["__init__"], true  ]
    - ["io1666.TextIOWrapper.has_new",    TextIOWrapper.__dict__.__contains__,    ["__new__"],  false ]
    - ["io1666.TextIOWrapper.has_init",   TextIOWrapper.__dict__.__contains__,    ["__init__"], true  ]
    - ["io1666.BufferedReader.has_new",   BufferedReader.__dict__.__contains__,   ["__new__"],  false ]
    - ["io1666.BufferedReader.has_init",  BufferedReader.__dict__.__contains__,   ["__init__"], true  ]
    - ["io1666.BufferedWriter.has_new",   BufferedWriter.__dict__.__contains__,   ["__new__"],  false ]
    - ["io1666.BufferedWriter.has_init",  BufferedWriter.__dict__.__contains__,   ["__init__"], true  ]

# ---------------------------------------------------------------------------
# Table io_extra1666.stream_init_presence
# Checks that concrete stream classes correctly expose __init__ for setup,
# while exception and abstract types do not add their own __init__.
# ---------------------------------------------------------------------------

table io_extra1666.stream_init_presence:
  kind: python_call_eq
  category: construction_protocol
  id_prefix: io1666

  columns: [id, function, args, expected]
  rows:
    - ["io1666.StringIO.init_present",          StringIO.__dict__.__contains__,          ["__init__"], true  ]
    - ["io1666.BytesIO.init_present",           BytesIO.__dict__.__contains__,           ["__init__"], true  ]
    - ["io1666.FileIO.init_present",            FileIO.__dict__.__contains__,            ["__init__"], true  ]
    - ["io1666.TextIOWrapper.init_present",     TextIOWrapper.__dict__.__contains__,     ["__init__"], true  ]
    - ["io1666.BufferedReader.init_present",    BufferedReader.__dict__.__contains__,    ["__init__"], true  ]
    - ["io1666.BufferedWriter.init_present",    BufferedWriter.__dict__.__contains__,    ["__init__"], true  ]
    - ["io1666.UnsupportedOp.init_absent",      UnsupportedOperation.__dict__.__contains__, ["__init__"], false ]
    - ["io1666.UnsupportedOp.new_absent",       UnsupportedOperation.__dict__.__contains__, ["__new__"],  false ]

# ---------------------------------------------------------------------------
# Table io_extra1666.abstract_base_new
# Abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase)
# define neither __new__ nor __init__ in their own __dict__; they rely on
# the C type machinery without exposing Python-level construction hooks.
# ---------------------------------------------------------------------------

table io_extra1666.abstract_base_new:
  kind: python_call_eq
  category: construction_protocol
  id_prefix: io1666

  columns: [id, function, args, expected]
  rows:
    - ["io1666.IOBase.has_new",          IOBase.__dict__.__contains__,          ["__new__"],  false ]
    - ["io1666.IOBase.has_init",         IOBase.__dict__.__contains__,          ["__init__"], false ]
    - ["io1666.RawIOBase.has_new",       RawIOBase.__dict__.__contains__,       ["__new__"],  false ]
    - ["io1666.RawIOBase.has_init",      RawIOBase.__dict__.__contains__,       ["__init__"], false ]
    - ["io1666.BufferedIOBase.has_new",  BufferedIOBase.__dict__.__contains__,  ["__new__"],  false ]
    - ["io1666.BufferedIOBase.has_init", BufferedIOBase.__dict__.__contains__,  ["__init__"], false ]
    - ["io1666.TextIOBase.has_new",      TextIOBase.__dict__.__contains__,      ["__new__"],  false ]
    - ["io1666.TextIOBase.has_init",     TextIOBase.__dict__.__contains__,      ["__init__"], false ]
    - ["io1666.StringIO.new_is_callable",    StringIO.__new__.__class__.__name__.__eq__, ["builtin_function_or_method"], true ]
    - ["io1666.BytesIO.new_is_callable",     BytesIO.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true ]
    - ["io1666.FileIO.new_is_callable",      FileIO.__new__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true ]
