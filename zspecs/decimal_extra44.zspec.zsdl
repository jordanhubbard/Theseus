spec: decimal_extra44
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra43.zspec.zsdl — covers Decimal.__class__.__name__.__len__()==4; Decimal.__class__.__qualname__.__eq__('type') (ALREADY COVERED — skipped in this spec); Context.__class__.__name__.__len__()==4; Context.__class__.__qualname__.__eq__('type') (ALREADY COVERED — skipped in this spec); DecimalException.__class__.__name__.__len__()==4; getcontext/setcontext/localcontext.__class__.__name__.__eq__('builtin_function_or_method')."
    - "decimal_extra42.zspec.zsdl — covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_05UP.__class__.__qualname__.__eq__('str') (ROUND_HALF_UP already covered — skipped in this spec); MIN_ETINY.__class__.__name__/__qualname__.__eq__('int')."
    - "decimal_extra29.zspec.zsdl — covers Decimal.__class__.__name__.__eq__('type')."
    - "decimal_extra17.zspec.zsdl — covers DecimalException.__name__/__qualname__/__module__/__mro__/__bases__ identity."
    - "decimal_extra6.zspec.zsdl — covers getcontext/__name__/__qualname__/__module__ equality."
  notes:
    - "This spec extends decimal_extra43.zspec.zsdl."
    - "IMPORTANT: decimal_extra43 already covers Decimal.__class__.__qualname__.__eq__('type') and Context.__class__.__qualname__.__eq__('type') — both are skipped here to avoid duplication. decimal_extra42 already covers ROUND_HALF_UP.__class__.__qualname__.__eq__('str') — also skipped here."
    - "Prior specs collectively covered: Decimal/__class__.__name__.__eq__('type') (decimal_extra29); Decimal/__class__.__qualname__.__eq__('type') (decimal_extra43 — already covered, not repeated); Context/__class__.__qualname__.__eq__('type') (decimal_extra43 — already covered, not repeated); DecimalException/__class__.__name__.__len__()==4 (decimal_extra43); getcontext/setcontext/localcontext/__class__.__name__.__eq__('builtin_function_or_method') (decimal_extra43); ROUND_HALF_UP/__class__.__qualname__.__eq__('str') (decimal_extra42 — already covered, not repeated). NO prior decimal spec checks DecimalException.__class__.__qualname__. NO prior decimal spec checks InvalidOperation/__class__.__qualname__, DivisionByZero/__class__.__qualname__, or Overflow/__class__.__qualname__. NO prior decimal spec checks getcontext/setcontext/localcontext/__class__.__qualname__. NO prior decimal spec checks ROUND_HALF_UP.__class__.__qualname__ via this spec (already covered in extra42)."
    - "This spec covers: decimal.DecimalException.__class__.__qualname__.__eq__('type') (NOVEL — decimal_extra43 checks DecimalException.__class__.__name__.__len__()==4 but not __class__.__qualname__; decimal_extra17 covers DecimalException identity attributes but not __class__.__qualname__; novel __qualname__ path anchor in decimal_extra44 namespace); decimal.InvalidOperation.__class__.__qualname__.__eq__('type') (NOVEL — InvalidOperation is a subclass of DecimalException; its metaclass is 'type'; no prior decimal spec checks InvalidOperation.__class__.__qualname__ at all; novel); decimal.DivisionByZero.__class__.__qualname__.__eq__('type') (NOVEL — same reasoning; no prior decimal spec checks DivisionByZero.__class__.__qualname__; novel); decimal.Overflow.__class__.__qualname__.__eq__('type') (NOVEL — no prior decimal spec checks Overflow.__class__.__qualname__; novel); decimal.getcontext.__class__.__qualname__.__eq__('builtin_function_or_method') (NOVEL — decimal_extra43 anchors getcontext.__class__.__name__ via __name__ path; no prior decimal spec checks getcontext.__class__.__qualname__; novel __qualname__ path anchor); decimal.setcontext.__class__.__qualname__.__eq__('builtin_function_or_method') (NOVEL); decimal.localcontext.__class__.__qualname__.__eq__('builtin_function_or_method') (NOVEL)."
    - "decimal.DecimalException.__class__.__qualname__ == 'type'. DecimalException is the base exception class for decimal errors; its metaclass is 'type'. For top-level builtin types __qualname__==__name__=='type'. decimal_extra43 checks __class__.__name__.__len__() but not __class__.__qualname__. Novel __qualname__ path anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.InvalidOperation.__class__.__qualname__ == 'type'. InvalidOperation is a subclass of DecimalException and a regular exception class. Its metaclass is 'type'. No prior decimal spec checks InvalidOperation.__class__.__qualname__ or InvalidOperation.__class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DivisionByZero.__class__.__qualname__ == 'type'. DivisionByZero is a subclass of DecimalException; its metaclass is 'type'. No prior decimal spec checks DivisionByZero.__class__.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Overflow.__class__.__qualname__ == 'type'. Overflow is a subclass of DecimalException; its metaclass is 'type'. No prior decimal spec checks Overflow.__class__.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.getcontext.__class__.__qualname__ == 'builtin_function_or_method'. getcontext is a C-level function from _decimal; its type is builtin_function_or_method; __qualname__==__name__ for top-level builtin types. decimal_extra43 anchors via __class__.__name__ path; no prior decimal spec checks getcontext.__class__.__qualname__. Novel __qualname__ path anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal exception class __class__.__qualname__
#
# DecimalException and its subclasses are regular exception classes whose
# metaclass is the standard 'type'. For top-level builtin types,
# __qualname__==__name__=='type':
#
#   DecimalException.__class__.__qualname__  == 'type'
#   InvalidOperation.__class__.__qualname__  == 'type'
#   DivisionByZero.__class__.__qualname__    == 'type'
#   Overflow.__class__.__qualname__          == 'type'
#
# decimal_extra43 checks DecimalException.__class__.__name__.__len__()==4 but
# does not access __class__.__qualname__ for DecimalException. No prior decimal
# spec checks __class__.__qualname__ for InvalidOperation, DivisionByZero, or
# Overflow. All four anchors are novel in the decimal_extra44 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra44.exception_class_qualnames:
  description: "decimal exception class __class__.__qualname__.__eq__('type') for DecimalException/InvalidOperation/DivisionByZero/Overflow — all are regular exception classes with 'type' metaclass; for top-level builtin types __qualname__==__name__=='type'; decimal_extra43 anchors DecimalException via __name__ path (len only); no prior decimal spec checks __class__.__qualname__ for any of these exception classes; all four novel __qualname__ path anchors in decimal_extra44 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decclsqual44

  columns: [id, function, args, expected]
  rows:
    - [DecimalException_class_qualname, DecimalException.__class__.__qualname__.__eq__, ["type"], true]
    - [InvalidOperation_class_qualname, InvalidOperation.__class__.__qualname__.__eq__, ["type"], true]
    - [DivisionByZero_class_qualname,   DivisionByZero.__class__.__qualname__.__eq__,   ["type"], true]
    - [Overflow_class_qualname,         Overflow.__class__.__qualname__.__eq__,         ["type"], true]

# ---------------------------------------------------------------------------
# decimal context function __class__.__qualname__
#
# getcontext, setcontext, and localcontext are C-level functions from the
# _decimal module. Their type is builtin_function_or_method, whose
# __qualname__=='builtin_function_or_method'==__name__:
#
#   getcontext.__class__.__qualname__   == 'builtin_function_or_method'
#   setcontext.__class__.__qualname__   == 'builtin_function_or_method'
#   localcontext.__class__.__qualname__ == 'builtin_function_or_method'
#
# decimal_extra43 anchors these via __class__.__name__ (__name__ path).
# No prior decimal spec checks __class__.__qualname__ for any of these
# functions. All three anchors are novel in the decimal_extra44 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra44.context_functions_class_qualnames:
  description: "decimal context function __class__.__qualname__.__eq__('builtin_function_or_method') for getcontext/setcontext/localcontext — all are C-level functions from _decimal module; for top-level builtin types __qualname__==__name__; decimal_extra43 anchors via __class__.__name__ path; no prior decimal spec checks __class__.__qualname__ for any of these functions; all three novel __qualname__ path anchors in decimal_extra44 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: decclsqual44fn

  columns: [id, function, args, expected]
  rows:
    - [getcontext_class_qualname,   getcontext.__class__.__qualname__.__eq__,   ["builtin_function_or_method"], true]
    - [setcontext_class_qualname,   setcontext.__class__.__qualname__.__eq__,   ["builtin_function_or_method"], true]
    - [localcontext_class_qualname, localcontext.__class__.__qualname__.__eq__, ["builtin_function_or_method"], true]
