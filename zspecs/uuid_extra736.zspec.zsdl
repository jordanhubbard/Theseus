spec: uuid_extra736
version: ">=3.9"
backend: python_module(uuid)
docs: "Behavioral spec covering uuid module namespace constants, SafeUUID identity, and UUID class attribute qualnames."
error_model: python_exceptions

provenance:
  derived_from:
    - python_stdlib_uuid
  not_derived_from: []
  notes: "Covers NAMESPACE_* constants, SafeUUID enum identity, and UUID property qualnames."
  created_at: "2026-04-12"

table uuid_extra736.constants:
  description: "Verifies uuid module namespace constants, SafeUUID enum identity, and UUID class property qualnames."
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: uu736xx
  columns: [id, function, args, expected]
  rows:
    - [uu736xx001, uuid.NAMESPACE_DNS.__class__.__name__.__eq__, ["UUID"], true]
    - [uu736xx002, uuid.NAMESPACE_URL.__class__.__name__.__eq__, ["UUID"], true]
    - [uu736xx003, uuid.NAMESPACE_OID.__class__.__name__.__eq__, ["UUID"], true]
    - [uu736xx004, uuid.NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true]
    - [uu736xx005, uuid.SafeUUID.__qualname__.__eq__, ["SafeUUID"], true]
    - [uu736xx006, uuid.SafeUUID.__module__.__eq__, ["uuid"], true]
    - [uu736xx007, uuid.UUID.int.__qualname__.__eq__, ["UUID.int"], true]
    - [uu736xx008, uuid.UUID.hex.__qualname__.__eq__, ["UUID.hex"], true]
    - [uu736xx009, uuid.UUID.urn.__qualname__.__eq__, ["UUID.urn"], true]
    - [uu736xx010, uuid.UUID.variant.__qualname__.__eq__, ["UUID.variant"], true]
    - [uu736xx011, uuid.UUID.is_safe.__qualname__.__eq__, ["UUID.is_safe"], true]
    - [uu736xx012, uuid.UUID.__qualname__.__eq__, ["UUID"], true]
