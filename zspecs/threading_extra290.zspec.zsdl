spec: threading_extra290
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module __all__ membership"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.__all__ has 28 entries on Python 3.14.3 (macOS)"
    - "__all__ is a plain list"
    - "Verified members: get_ident, active_count, Condition, current_thread, enumerate, main_thread, TIMEOUT_MAX, Event, Lock, RLock, Semaphore, BoundedSemaphore, Thread, Barrier, BrokenBarrierError, Timer, ThreadError, setprofile, settrace, local, stack_size, excepthook, ExceptHookArgs, gettrace, getprofile, setprofile_all_threads, settrace_all_threads, get_native_id"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra290.contains_core:
  description: "threading.__all__ contains core synchronization and thread classes"
  kind: python_call_eq
  category: identity
  id_prefix: the290c

  columns: [id, function, args, expected, description]
  rows:
    - [the290c001, threading.__all__.__contains__, ["Thread"], true, "__all__ contains Thread"]
    - [the290c002, threading.__all__.__contains__, ["Lock"], true, "__all__ contains Lock"]
    - [the290c003, threading.__all__.__contains__, ["RLock"], true, "__all__ contains RLock"]
    - [the290c004, threading.__all__.__contains__, ["Condition"], true, "__all__ contains Condition"]
    - [the290c005, threading.__all__.__contains__, ["Semaphore"], true, "__all__ contains Semaphore"]
    - [the290c006, threading.__all__.__contains__, ["BoundedSemaphore"], true, "__all__ contains BoundedSemaphore"]
    - [the290c007, threading.__all__.__contains__, ["Event"], true, "__all__ contains Event"]
    - [the290c008, threading.__all__.__contains__, ["Timer"], true, "__all__ contains Timer"]
    - [the290c009, threading.__all__.__contains__, ["Barrier"], true, "__all__ contains Barrier"]
    - [the290c010, threading.__all__.__contains__, ["current_thread"], true, "__all__ contains current_thread"]

table threading_extra290.contains_extras:
  description: "threading.__all__ contains utility functions and metadata"
  kind: python_call_eq
  category: identity
  id_prefix: the290e

  columns: [id, function, args, expected, description]
  rows:
    - [the290e001, threading.__all__.__contains__, ["main_thread"], true, "__all__ contains main_thread"]
    - [the290e002, threading.__all__.__contains__, ["active_count"], true, "__all__ contains active_count"]
    - [the290e003, threading.__all__.__contains__, ["enumerate"], true, "__all__ contains enumerate"]
    - [the290e004, threading.__all__.__contains__, ["settrace"], true, "__all__ contains settrace"]
    - [the290e005, threading.__all__.__contains__, ["local"], true, "__all__ contains local"]
    - [the290e006, threading.__all__.__contains__, ["stack_size"], true, "__all__ contains stack_size"]
    - [the290e007, threading.__all__.__contains__, ["excepthook"], true, "__all__ contains excepthook"]
    - [the290e008, threading.__all__.__contains__, ["get_ident"], true, "__all__ contains get_ident"]
    - [the290e009, threading.__all__.__class__.__name__.__eq__, ["list"], true, "__all__ is a list"]
    - [the290e010, threading.__all__.__len__, [], 28, "__all__ has 28 entries on CPython 3.14"]

invariant threading_extra290.all_is_list:
  description: "threading.__all__ is a plain list"
  category: identity
  kind: python_call_eq
  function: threading.__all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant threading_extra290.all_len:
  description: "threading.__all__ has 28 entries"
  category: identity
  kind: python_call_eq
  function: threading.__all__.__len__
  args: []
  expected: 28

invariant threading_extra290.thread_in_all:
  description: "Thread is in threading.__all__"
  category: identity
  kind: python_call_eq
  function: threading.__all__.__contains__
  args: ["Thread"]
  expected: true

invariant threading_extra290.lock_in_all:
  description: "Lock is in threading.__all__"
  category: identity
  kind: python_call_eq
  function: threading.__all__.__contains__
  args: ["Lock"]
  expected: true

invariant threading_extra290.barrier_in_all:
  description: "Barrier is in threading.__all__"
  category: identity
  kind: python_call_eq
  function: threading.__all__.__contains__
  args: ["Barrier"]
  expected: true
