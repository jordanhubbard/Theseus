spec: socket_extra1426
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra142.zspec.zsdl — covers socket.AF_INET/AF_INET6 .name values and lengths / SOCK_STREAM/SOCK_DGRAM .name values and lengths / AddressFamily/__name__/__len__()==13 / SocketKind/__name__/__len__()==10 / socket.error/__name__/__len__() / socket.timeout/__name__/__len__() / timeout.__bases__[0].__name__=='OSError' (table + invariants)."
    - "socket_extra141.zspec.zsdl — covers socket.socket/__doc__/__len__()==58 / gethostname/__doc__/__len__()==54 / gethostbyname/__doc__/__len__()==106 / getaddrinfo/__doc__/__len__()==658 / setdefaulttimeout/__doc__/__len__()==224 / getdefaulttimeout/__doc__/__len__()==232 (table + invariants)."
    - "socket_extra139.zspec.zsdl — covers socket.socket.__eq__/__hash__ qualnames / socket.socket.family and type as property descriptors / socket.socket class __name__/__module__/__mro__."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in any prior socket spec."
    - "Wave 542 theme: __format__ and __dir__ method type and dict-presence checks for socket.socket, socket.error (OSError alias), and socket.timeout (TimeoutError alias)."
    - "socket.socket.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dir__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__format__ in socket.socket.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__dir__ in socket.socket.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error is OSError (a builtins alias). socket.error.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout is TimeoutError (a builtins alias). socket.timeout.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__format__ in socket.error.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__format__ in socket.timeout.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__dir__ in socket.error.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__dir__ in socket.timeout.__dict__ == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All socket exception classes (error, timeout, gaierror, herror) inherit __format__ and __dir__ from object via their exception MRO without overriding them. All report 'method_descriptor'. socket.socket is a Python class (Lib/socket.py) wrapping a C-level socket type; it also does not override __format__ or __dir__, so both are 'method_descriptor' from object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__format__.__class__.__name__ == 'method_descriptor'
# socket.socket.__dir__.__class__.__name__ == 'method_descriptor'
#
# Wave 542 theme: __format__ and __dir__ type checks on socket.socket.
#
# socket.socket is defined in Lib/socket.py as a Python class. It wraps a C-level
# socket object but is itself a Python class. Its __format__ and __dir__ are not
# overridden, so both are C-level method_descriptor inherited from object.
# No prior socket spec anchors socket.__format__.__class__.__name__ or
# socket.__dir__.__class__.__name__ under sk1426sk. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra1426.socket_format_dir_type:
  description: "socket.socket.__format__.__class__.__name__=='method_descriptor' / socket.__dir__.__class__.__name__=='method_descriptor' — socket.socket is a Python class in Lib/socket.py; neither __format__ nor __dir__ is overridden; both are C-level method_descriptor from object; __format__ and __dir__ absent from socket.__dict__; no prior socket spec anchors these; first sk1426sk anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1426sk

  columns: [id, function, args, expected, description]
  rows:
    - [sk1426sk001, "socket.__format__.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.__format__.__class__.__name__ == 'method_descriptor' — Python class in Lib/socket.py; inherits __format__ from object; C-level descriptor"]
    - [sk1426sk002, "socket.__dir__.__class__.__name__.__eq__",    ["method_descriptor"], true, "socket.socket.__dir__.__class__.__name__ == 'method_descriptor' — Python class in Lib/socket.py; inherits __dir__ from object; C-level descriptor"]
    - [sk1426sk003, "socket.__dict__.__contains__",                ["__format__"],        false, "socket.socket.__dict__ does not contain '__format__' — not overridden; inherited from object"]
    - [sk1426sk004, "socket.__dict__.__contains__",                ["__dir__"],           false, "socket.socket.__dict__ does not contain '__dir__' — not overridden; inherited from object"]
    - [sk1426sk005, "socket.__format__.__class__.__name__.__len__", [],                   17,   "socket.socket.__format__.__class__.__name__.__len__() == 17 — len('method_descriptor') == 17"]
    - [sk1426sk006, "socket.__dir__.__class__.__name__.__len__",    [],                   17,   "socket.socket.__dir__.__class__.__name__.__len__() == 17 — len('method_descriptor') == 17"]

# ---------------------------------------------------------------------------
# socket.error.__format__.__class__.__name__ == 'method_descriptor'
# socket.error.__dir__.__class__.__name__ == 'method_descriptor'
# socket.timeout.__format__.__class__.__name__ == 'method_descriptor'
# socket.timeout.__dir__.__class__.__name__ == 'method_descriptor'
#
# Wave 542 theme: __format__ and __dir__ type checks on socket exception aliases.
#
# socket.error is an alias for OSError (builtins). socket.timeout is an alias for
# TimeoutError (builtins). Both are built-in exception classes. Neither defines
# its own __format__ or __dir__. Both report 'method_descriptor' from object.
# No prior socket spec anchors these checks under sk1426ex.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra1426.exception_format_dir_type:
  description: "socket.error.__format__.__class__.__name__=='method_descriptor' / error.__dir__.__class__.__name__=='method_descriptor' / socket.timeout.__format__.__class__.__name__=='method_descriptor' / timeout.__dir__.__class__.__name__=='method_descriptor' — socket.error is OSError alias; socket.timeout is TimeoutError alias; both inherit __format__ and __dir__ from object without override; both report C-level method_descriptor; __format__/__dir__ absent from both __dict__; no prior socket spec anchors these; first sk1426ex anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1426ex

  columns: [id, function, args, expected, description]
  rows:
    - [sk1426ex001, "error.__format__.__class__.__name__.__eq__",   ["method_descriptor"], true, "socket.error.__format__.__class__.__name__ == 'method_descriptor' — OSError alias; inherits from object; C-level descriptor"]
    - [sk1426ex002, "error.__dir__.__class__.__name__.__eq__",      ["method_descriptor"], true, "socket.error.__dir__.__class__.__name__ == 'method_descriptor' — OSError alias; inherits from object; C-level descriptor"]
    - [sk1426ex003, "timeout.__format__.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.timeout.__format__.__class__.__name__ == 'method_descriptor' — TimeoutError alias; inherits from object; C-level descriptor"]
    - [sk1426ex004, "timeout.__dir__.__class__.__name__.__eq__",    ["method_descriptor"], true, "socket.timeout.__dir__.__class__.__name__ == 'method_descriptor' — TimeoutError alias; inherits from object; C-level descriptor"]
    - [sk1426ex005, "error.__dict__.__contains__",                  ["__format__"],        false, "socket.error.__dict__ does not contain '__format__' — OSError does not override __format__"]
    - [sk1426ex006, "timeout.__dict__.__contains__",                ["__format__"],        false, "socket.timeout.__dict__ does not contain '__format__' — TimeoutError does not override __format__"]

# ---------------------------------------------------------------------------
# socket.gaierror.__format__.__class__.__name__ == 'method_descriptor'
# socket.herror.__format__.__class__.__name__ == 'method_descriptor'
# socket.gaierror.__dir__.__class__.__name__ == 'method_descriptor'
# socket.herror.__dir__.__class__.__name__ == 'method_descriptor'
#
# Wave 542 supplemental: gaierror and herror exception alias checks.
#
# socket.gaierror and socket.herror are additional socket exception aliases for
# OSError subclasses. Like error and timeout, neither overrides __format__ or __dir__,
# so both report 'method_descriptor' from object. Their __dict__ does not contain
# __format__ or __dir__. No prior socket spec anchors these under sk1426ga.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra1426.gaierror_herror_format_dir_type:
  description: "socket.gaierror.__format__.__class__.__name__=='method_descriptor' / gaierror.__dir__.__class__.__name__=='method_descriptor' / socket.herror.__format__.__class__.__name__=='method_descriptor' / herror.__dir__.__class__.__name__=='method_descriptor' — gaierror and herror are additional socket exception aliases; neither overrides __format__ or __dir__; both report C-level method_descriptor from object; __format__/__dir__ absent from both __dict__; no prior socket spec anchors these; first sk1426ga anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1426ga

  columns: [id, function, args, expected, description]
  rows:
    - [sk1426ga001, "gaierror.__format__.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.gaierror.__format__.__class__.__name__ == 'method_descriptor' — gaierror is OSError subclass; inherits from object via MRO; C-level descriptor"]
    - [sk1426ga002, "gaierror.__dir__.__class__.__name__.__eq__",    ["method_descriptor"], true, "socket.gaierror.__dir__.__class__.__name__ == 'method_descriptor' — gaierror inherits __dir__ from object; C-level descriptor"]
    - [sk1426ga003, "herror.__format__.__class__.__name__.__eq__",   ["method_descriptor"], true, "socket.herror.__format__.__class__.__name__ == 'method_descriptor' — herror is OSError subclass; inherits from object via MRO; C-level descriptor"]
    - [sk1426ga004, "herror.__dir__.__class__.__name__.__eq__",      ["method_descriptor"], true, "socket.herror.__dir__.__class__.__name__ == 'method_descriptor' — herror inherits __dir__ from object; C-level descriptor"]
    - [sk1426ga005, "gaierror.__dict__.__contains__",                ["__format__"],        false, "socket.gaierror.__dict__ does not contain '__format__' — not defined on gaierror; inherited from object"]
    - [sk1426ga006, "herror.__dict__.__contains__",                  ["__format__"],        false, "socket.herror.__dict__ does not contain '__format__' — not defined on herror; inherited from object"]
