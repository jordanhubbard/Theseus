spec: resource_extra2
version: ">=3.9"
backend: python_module(resource)

docs: https://docs.python.org/3/library/resource.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/resource.html — Python resource module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, setrlimit/getrlimit and getrusage"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/resource.c"
  notes:
    - "This spec extends resource.zspec.zsdl with new, non-duplicate invariants."
    - "resource is a POSIX-only Unix module; it is NOT available on Windows."
    - "resource.zspec.zsdl covers: getrlimit/setrlimit/getrusage/getpagesize func names, RLIMIT_CPU/FSIZE/NOFILE/AS class names, RUSAGE_SELF/CHILDREN class names, getpagesize behavior."
    - "struct_rusage is a C-level struct-sequence type returned by getrusage()."
    - "struct_rusage.__name__ == 'struct_rusage' and __module__ == 'resource'."
    - "struct_rusage.__bases__[0].__name__ == 'tuple' — C struct-sequences subclass tuple."
    - "RLIMIT_STACK and RLIMIT_DATA are portable POSIX constants not covered in resource.zspec.zsdl."
    - "Function __qualname__ == __name__ for C-level builtin functions in the resource module."
    - "RLIMIT_NOFILE, RLIMIT_STACK, RLIMIT_CPU, RLIMIT_DATA, RLIMIT_AS are all plain Python ints."
    - "RUSAGE_SELF == 0 and RUSAGE_CHILDREN == -1 are standardized across POSIX platforms."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct_rusage — class identity
# resource.zspec.zsdl does not cover struct_rusage at all.
# ---------------------------------------------------------------------------

invariant resource_extra2.struct_rusage.class_name:
  description: "resource.struct_rusage.__name__ == 'struct_rusage'"
  category: class_identity
  kind: python_call_eq
  function: struct_rusage.__name__.__eq__
  args: ["struct_rusage"]
  expected: true

invariant resource_extra2.struct_rusage.module:
  description: "resource.struct_rusage.__module__ == 'resource'"
  category: class_identity
  kind: python_call_eq
  function: struct_rusage.__module__.__eq__
  args: ["resource"]
  expected: true

invariant resource_extra2.struct_rusage.is_type:
  description: "type(resource.struct_rusage).__name__ == 'type' — struct_rusage is a class object"
  category: class_identity
  kind: python_call_eq
  function: struct_rusage.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant resource_extra2.struct_rusage.bases_tuple:
  description: "resource.struct_rusage.__bases__[0].__name__ == 'tuple' — C struct-sequence subclasses tuple"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_rusage.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "tuple"

# ---------------------------------------------------------------------------
# RLIMIT_STACK and RLIMIT_DATA — type checks
# resource.zspec.zsdl covers RLIMIT_CPU, RLIMIT_FSIZE, RLIMIT_NOFILE, RLIMIT_AS.
# New here: RLIMIT_STACK and RLIMIT_DATA (both portable POSIX constants).
# ---------------------------------------------------------------------------

invariant resource_extra2.RLIMIT_STACK.is_int:
  description: "resource.RLIMIT_STACK.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: RLIMIT_STACK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant resource_extra2.RLIMIT_DATA.is_int:
  description: "resource.RLIMIT_DATA.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: RLIMIT_DATA.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# RLIMIT_* constants — table of type checks
# Extends resource.zspec.zsdl table with RLIMIT_STACK and RLIMIT_DATA.
# Also recaps RLIMIT_NOFILE and RLIMIT_CPU as explicit anchors for this spec.
# ---------------------------------------------------------------------------

table resource_extra2.constants.rlimit_extra_types:
  kind: python_call_eq
  category: constants
  id_prefix: rlimit_type

  columns: [id, function, args, expected]
  rows:
    - [rlimit_nofile, RLIMIT_NOFILE.__class__.__name__.__eq__, ["int"], true]
    - [rlimit_stack,  RLIMIT_STACK.__class__.__name__.__eq__,  ["int"], true]
    - [rlimit_cpu,    RLIMIT_CPU.__class__.__name__.__eq__,    ["int"], true]
    - [rlimit_data,   RLIMIT_DATA.__class__.__name__.__eq__,   ["int"], true]
    - [rlimit_as,     RLIMIT_AS.__class__.__name__.__eq__,     ["int"], true]

# ---------------------------------------------------------------------------
# RUSAGE_SELF and RUSAGE_CHILDREN — integer values
# resource.zspec.zsdl covers their class names; it does NOT pin the values.
# RUSAGE_SELF == 0 and RUSAGE_CHILDREN == -1 are standardized on POSIX.
# ---------------------------------------------------------------------------

invariant resource_extra2.RUSAGE_SELF.value:
  description: "resource.RUSAGE_SELF == 0 — POSIX-standardized value for current process"
  category: constants
  kind: python_call_eq
  function: RUSAGE_SELF.__eq__
  args: [0]
  expected: true

invariant resource_extra2.RUSAGE_CHILDREN.value:
  description: "resource.RUSAGE_CHILDREN == -1 — POSIX-standardized value for terminated children"
  category: constants
  kind: python_call_eq
  function: RUSAGE_CHILDREN.__eq__
  args: [-1]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ attributes
# resource.zspec.zsdl covers __name__ for getrlimit/setrlimit/getrusage/getpagesize.
# New here: __qualname__ (== __name__ for C-level builtins).
# ---------------------------------------------------------------------------

table resource_extra2.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [getrlimit,   getrlimit.__qualname__.__eq__,   ["getrlimit"],   true]
    - [setrlimit,   setrlimit.__qualname__.__eq__,   ["setrlimit"],   true]
    - [getrusage,   getrusage.__qualname__.__eq__,   ["getrusage"],   true]
    - [getpagesize, getpagesize.__qualname__.__eq__, ["getpagesize"], true]

# ---------------------------------------------------------------------------
# Functions are C-level builtins
# resource.zspec.zsdl does not check __class__.__name__ for function objects.
# ---------------------------------------------------------------------------

table resource_extra2.function_types:
  kind: python_call_eq
  category: function_types
  id_prefix: func_type

  columns: [id, function, args, expected]
  rows:
    - [getrlimit,   getrlimit.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [setrlimit,   setrlimit.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [getrusage,   getrusage.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [getpagesize, getpagesize.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
