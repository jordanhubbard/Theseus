spec: inspect_extra105
version: ">=3.11"
backend: python_module(inspect)
extends: inspect_extra104

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra104.zspec.zsdl."
    - "This spec covers: inspect function __code__.co_qualname values (Python 3.11+, PEP 657); for top-level functions co_qualname equals the simple function name; for class methods it uses 'ClassName.method' pattern (Wave 258)."
    - "inspect.isfunction.__code__.co_qualname == 'isfunction'. Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_qualname == 'isclass'. Verified with Python 3.14.3."
    - "inspect.ismethod.__code__.co_qualname == 'ismethod'. Verified with Python 3.14.3."
    - "inspect.isgenerator.__code__.co_qualname == 'isgenerator'. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__code__.co_qualname == 'iscoroutine'. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_qualname == 'getmembers'. Verified with Python 3.14.3."
    - "inspect.getdoc.__code__.co_qualname == 'getdoc'. Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_qualname == 'getsource'. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__code__.co_qualname == 'getsourcelines'. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_qualname == 'getfile'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_qualname == 'isbuiltin'. Verified with Python 3.14.3."
    - "inspect.ismodule.__code__.co_qualname == 'ismodule'. Verified with Python 3.14.3."
    - "inspect.isabstract.__code__.co_qualname == 'isabstract'. Verified with Python 3.14.3."
    - "inspect.isawaitable.__code__.co_qualname == 'isawaitable'. Verified with Python 3.14.3."
    - "inspect.isasyncgen.__code__.co_qualname == 'isasyncgen'. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_qualname == 'signature'. Verified with Python 3.14.3."
    - "co_qualname was added in CPython 3.11 as part of PEP 657 fine-grained error locations. For top-level functions it always matches __qualname__ and the simple function name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect predicate function __code__.co_qualname values
#
# Wave 258 theme: inspect predicate functions __code__.co_qualname.
# co_qualname (PEP 657, Python 3.11+) records the qualified name of
# the function as stored in its code object. For top-level functions,
# co_qualname == __qualname__ == the simple function name.
#
# inspect.isfunction.__code__.co_qualname == 'isfunction'
# inspect.isclass.__code__.co_qualname == 'isclass'
# inspect.ismethod.__code__.co_qualname == 'ismethod'
# inspect.isgenerator.__code__.co_qualname == 'isgenerator'
# inspect.iscoroutine.__code__.co_qualname == 'iscoroutine'
# inspect.isbuiltin.__code__.co_qualname == 'isbuiltin'
# inspect.ismodule.__code__.co_qualname == 'ismodule'
# inspect.isabstract.__code__.co_qualname == 'isabstract'
# inspect.isawaitable.__code__.co_qualname == 'isawaitable'
# inspect.isasyncgen.__code__.co_qualname == 'isasyncgen'
#
# New to extra105.
# ---------------------------------------------------------------------------

table inspect_extra105.predicate_co_qualname:
  description: "inspect predicate function __code__.co_qualname values (Python 3.11+); all equal the simple function name for top-level predicates; wave 258; new to extra105"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectcoqn105

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_co_qualname_eq,
       "isfunction.__code__.co_qualname.__eq__",
       ["isfunction"],
       true,
       "inspect.isfunction.__code__.co_qualname.__eq__('isfunction') == True — co_qualname (Python 3.11+) is the qualified name stored in the code object; for the top-level function isfunction, co_qualname is 'isfunction', identical to __qualname__ and __name__; str.__eq__('isfunction') returns True; new to extra105"]
    - [isclass_co_qualname_eq,
       "isclass.__code__.co_qualname.__eq__",
       ["isclass"],
       true,
       "inspect.isclass.__code__.co_qualname.__eq__('isclass') == True — co_qualname for the top-level predicate isclass is 'isclass'; str.__eq__('isclass') returns True; new to extra105"]
    - [ismethod_co_qualname_eq,
       "ismethod.__code__.co_qualname.__eq__",
       ["ismethod"],
       true,
       "inspect.ismethod.__code__.co_qualname.__eq__('ismethod') == True — co_qualname for the top-level predicate ismethod is 'ismethod'; str.__eq__('ismethod') returns True; new to extra105"]
    - [isgenerator_co_qualname_eq,
       "isgenerator.__code__.co_qualname.__eq__",
       ["isgenerator"],
       true,
       "inspect.isgenerator.__code__.co_qualname.__eq__('isgenerator') == True — co_qualname for the top-level predicate isgenerator is 'isgenerator'; str.__eq__('isgenerator') returns True; new to extra105"]
    - [iscoroutine_co_qualname_eq,
       "iscoroutine.__code__.co_qualname.__eq__",
       ["iscoroutine"],
       true,
       "inspect.iscoroutine.__code__.co_qualname.__eq__('iscoroutine') == True — co_qualname for the top-level predicate iscoroutine is 'iscoroutine'; str.__eq__('iscoroutine') returns True; new to extra105"]
    - [isbuiltin_co_qualname_eq,
       "isbuiltin.__code__.co_qualname.__eq__",
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__code__.co_qualname.__eq__('isbuiltin') == True — co_qualname for isbuiltin is 'isbuiltin'; str.__eq__('isbuiltin') returns True; new to extra105"]
    - [ismodule_co_qualname_eq,
       "ismodule.__code__.co_qualname.__eq__",
       ["ismodule"],
       true,
       "inspect.ismodule.__code__.co_qualname.__eq__('ismodule') == True — co_qualname for ismodule is 'ismodule'; str.__eq__('ismodule') returns True; new to extra105"]
    - [isabstract_co_qualname_eq,
       "isabstract.__code__.co_qualname.__eq__",
       ["isabstract"],
       true,
       "inspect.isabstract.__code__.co_qualname.__eq__('isabstract') == True — co_qualname for isabstract is 'isabstract'; str.__eq__('isabstract') returns True; new to extra105"]
    - [isawaitable_co_qualname_eq,
       "isawaitable.__code__.co_qualname.__eq__",
       ["isawaitable"],
       true,
       "inspect.isawaitable.__code__.co_qualname.__eq__('isawaitable') == True — co_qualname for isawaitable is 'isawaitable'; str.__eq__('isawaitable') returns True; new to extra105"]
    - [isasyncgen_co_qualname_eq,
       "isasyncgen.__code__.co_qualname.__eq__",
       ["isasyncgen"],
       true,
       "inspect.isasyncgen.__code__.co_qualname.__eq__('isasyncgen') == True — co_qualname for isasyncgen is 'isasyncgen'; str.__eq__('isasyncgen') returns True; new to extra105"]

# ---------------------------------------------------------------------------
# Table 2: inspect utility function __code__.co_qualname values
#
# Wave 258 theme: inspect utility functions (getmembers, getdoc, getsource,
# getsourcelines, getfile, signature) co_qualname values.
#
# inspect.getmembers.__code__.co_qualname == 'getmembers'
# inspect.getdoc.__code__.co_qualname == 'getdoc'
# inspect.getsource.__code__.co_qualname == 'getsource'
# inspect.getsourcelines.__code__.co_qualname == 'getsourcelines'
# inspect.getfile.__code__.co_qualname == 'getfile'
# inspect.signature.__code__.co_qualname == 'signature'
#
# New to extra105.
# ---------------------------------------------------------------------------

table inspect_extra105.utility_co_qualname:
  description: "inspect utility function __code__.co_qualname values: getmembers/getdoc/getsource/getsourcelines/getfile/signature; all equal simple function name; wave 258; new to extra105"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectutilcoqn105

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_co_qualname_eq,
       "getmembers.__code__.co_qualname.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__code__.co_qualname.__eq__('getmembers') == True — getmembers(object, predicate) is a top-level utility function defined in Lib/inspect.py; its co_qualname is 'getmembers', the simple function name; str.__eq__('getmembers') returns True; new to extra105"]
    - [getdoc_co_qualname_eq,
       "getdoc.__code__.co_qualname.__eq__",
       ["getdoc"],
       true,
       "inspect.getdoc.__code__.co_qualname.__eq__('getdoc') == True — getdoc is a top-level utility function in Lib/inspect.py; co_qualname is 'getdoc'; str.__eq__('getdoc') returns True; new to extra105"]
    - [getsource_co_qualname_eq,
       "getsource.__code__.co_qualname.__eq__",
       ["getsource"],
       true,
       "inspect.getsource.__code__.co_qualname.__eq__('getsource') == True — getsource is a top-level utility function in Lib/inspect.py; co_qualname is 'getsource'; str.__eq__('getsource') returns True; new to extra105"]
    - [getsourcelines_co_qualname_eq,
       "getsourcelines.__code__.co_qualname.__eq__",
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__code__.co_qualname.__eq__('getsourcelines') == True — getsourcelines is a top-level utility function in Lib/inspect.py; co_qualname is 'getsourcelines'; str.__eq__('getsourcelines') returns True; new to extra105"]
    - [getfile_co_qualname_eq,
       "getfile.__code__.co_qualname.__eq__",
       ["getfile"],
       true,
       "inspect.getfile.__code__.co_qualname.__eq__('getfile') == True — getfile is a top-level utility function in Lib/inspect.py; co_qualname is 'getfile'; str.__eq__('getfile') returns True; new to extra105"]
    - [signature_co_qualname_eq,
       "signature.__code__.co_qualname.__eq__",
       ["signature"],
       true,
       "inspect.signature.__code__.co_qualname.__eq__('signature') == True — signature is a top-level utility function in Lib/inspect.py; co_qualname is 'signature'; str.__eq__('signature') returns True; new to extra105"]

# ---------------------------------------------------------------------------
# Table 3: inspect __code__.co_qualname string lengths
#
# Wave 258 theme: co_qualname string lengths for inspect functions.
# For top-level functions co_qualname length == __qualname__ length.
#
# inspect.isfunction.__code__.co_qualname len == 10
# inspect.isclass.__code__.co_qualname len == 7
# inspect.ismethod.__code__.co_qualname len == 8
# inspect.isgenerator.__code__.co_qualname len == 11
# inspect.getdoc.__code__.co_qualname len == 6
# inspect.getsource.__code__.co_qualname len == 9
# inspect.getfile.__code__.co_qualname len == 7
# inspect.getsourcelines.__code__.co_qualname len == 14
#
# New to extra105.
# ---------------------------------------------------------------------------

table inspect_extra105.co_qualname_lengths:
  description: "inspect function __code__.co_qualname.__len__() values; co_qualname length equals simple function name length for top-level functions; wave 258; new to extra105"
  kind: python_call_eq
  category: string_lengths
  id_prefix: inspectcoqnlen105

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_co_qualname_len_6,
       "getdoc.__code__.co_qualname.__len__",
       [],
       6,
       "inspect.getdoc.__code__.co_qualname.__len__() == 6 — co_qualname is 'getdoc' (6 characters); len('getdoc') == 6; new to extra105"]
    - [isclass_co_qualname_len_7,
       "isclass.__code__.co_qualname.__len__",
       [],
       7,
       "inspect.isclass.__code__.co_qualname.__len__() == 7 — co_qualname is 'isclass' (7 characters); len('isclass') == 7; new to extra105"]
    - [getfile_co_qualname_len_7,
       "getfile.__code__.co_qualname.__len__",
       [],
       7,
       "inspect.getfile.__code__.co_qualname.__len__() == 7 — co_qualname is 'getfile' (7 characters); len('getfile') == 7; new to extra105"]
    - [ismethod_co_qualname_len_8,
       "ismethod.__code__.co_qualname.__len__",
       [],
       8,
       "inspect.ismethod.__code__.co_qualname.__len__() == 8 — co_qualname is 'ismethod' (8 characters); len('ismethod') == 8; new to extra105"]
    - [getsource_co_qualname_len_9,
       "getsource.__code__.co_qualname.__len__",
       [],
       9,
       "inspect.getsource.__code__.co_qualname.__len__() == 9 — co_qualname is 'getsource' (9 characters); len('getsource') == 9; new to extra105"]
    - [isfunction_co_qualname_len_10,
       "isfunction.__code__.co_qualname.__len__",
       [],
       10,
       "inspect.isfunction.__code__.co_qualname.__len__() == 10 — co_qualname is 'isfunction' (10 characters); len('isfunction') == 10; new to extra105"]
    - [isgenerator_co_qualname_len_11,
       "isgenerator.__code__.co_qualname.__len__",
       [],
       11,
       "inspect.isgenerator.__code__.co_qualname.__len__() == 11 — co_qualname is 'isgenerator' (11 characters); len('isgenerator') == 11; new to extra105"]
    - [getsourcelines_co_qualname_len_14,
       "getsourcelines.__code__.co_qualname.__len__",
       [],
       14,
       "inspect.getsourcelines.__code__.co_qualname.__len__() == 14 — co_qualname is 'getsourcelines' (14 characters); len('getsourcelines') == 14; new to extra105"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra105
# ---------------------------------------------------------------------------

invariant inspect_extra105.isfunction_co_qualname:
  description: "inspect.isfunction.__code__.co_qualname == 'isfunction' — co_qualname (Python 3.11+) equals simple name for top-level functions; wave 258; new to extra105"
  kind: python_call_eq
  function: isfunction.__code__.co_qualname.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra105.getmembers_co_qualname:
  description: "inspect.getmembers.__code__.co_qualname == 'getmembers' — top-level function co_qualname equals simple name; wave 258; new to extra105"
  kind: python_call_eq
  function: getmembers.__code__.co_qualname.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra105.getsourcelines_co_qualname_len:
  description: "inspect.getsourcelines.__code__.co_qualname.__len__() == 14 — 'getsourcelines' has 14 characters; longest co_qualname in this spec; wave 258; new to extra105"
  kind: python_call_eq
  function: getsourcelines.__code__.co_qualname.__len__
  args: []
  expected: 14

invariant inspect_extra105.signature_co_qualname:
  description: "inspect.signature.__code__.co_qualname == 'signature' — top-level function co_qualname equals simple name; wave 258; new to extra105"
  kind: python_call_eq
  function: signature.__code__.co_qualname.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra105.isabstract_co_qualname:
  description: "inspect.isabstract.__code__.co_qualname == 'isabstract' — top-level predicate co_qualname equals simple name; wave 258; new to extra105"
  kind: python_call_eq
  function: isabstract.__code__.co_qualname.__eq__
  args: ["isabstract"]
  expected: true
