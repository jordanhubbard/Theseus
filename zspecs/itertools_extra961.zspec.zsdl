spec: itertools_extra961
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks itertools error conditions and class identity for count, islice, repeat, combinations, cycle"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra961.module_identity:
  description: "itertools module-level attribute identity"
  kind: python_call_eq
  category: identity
  id_prefix: it961id
  columns: [id, function, args, expected]
  rows:
    - [it961id001, itertools.count.__class__.__name__.__eq__,        ["type"],    true]
    - [it961id002, itertools.islice.__class__.__name__.__eq__,       ["type"],    true]
    - [it961id003, itertools.repeat.__class__.__name__.__eq__,       ["type"],    true]
    - [it961id004, itertools.combinations.__class__.__name__.__eq__, ["type"],    true]
    - [it961id005, itertools.cycle.__class__.__name__.__eq__,        ["type"],    true]
    - [it961id006, itertools.chain.__class__.__name__.__eq__,        ["type"],    true]
    - [it961id007, itertools.__name__.__eq__,                        ["itertools"], true]

table itertools_extra961.raises_type_errors:
  description: "itertools functions that raise TypeError on bad input"
  kind: python_call_raises
  category: type_errors
  id_prefix: it961te
  columns: [id, function, args, expected]
  rows:
    - [it961te001, itertools.count,  ["\"not_a_number\""], TypeError]
    - [it961te002, itertools.cycle,  ["42"],               TypeError]
    - [it961te003, itertools.cycle,  ["3.14"],             TypeError]

table itertools_extra961.raises_value_errors:
  description: "itertools functions that raise ValueError on bad input"
  kind: python_call_raises
  category: value_errors
  id_prefix: it961ve
  columns: [id, function, args, expected]
  rows:
    - [it961ve001, itertools.islice, ["[]", "-1"],  ValueError]
    - [it961ve002, itertools.islice, ["[]", "-5"],  ValueError]

table itertools_extra961.repeat_and_combinations_eq:
  description: "itertools.repeat and combinations class name checks"
  kind: python_call_eq
  category: class_name
  id_prefix: it961cn
  columns: [id, function, args, expected]
  rows:
    - [it961cn001, itertools.repeat.__name__.__eq__,       ["repeat"],       true]
    - [it961cn002, itertools.combinations.__name__.__eq__, ["combinations"], true]
    - [it961cn003, itertools.islice.__name__.__eq__,       ["islice"],       true]
    - [it961cn004, itertools.count.__name__.__eq__,        ["count"],        true]
    - [it961cn005, itertools.cycle.__name__.__eq__,        ["cycle"],        true]
