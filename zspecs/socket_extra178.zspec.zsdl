spec: socket_extra178
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "This spec covers: socket module identity attributes — __name__=='socket' (len=6); __package__=='' (socket.py is a plain module file, not a package, so __package__ is empty string); socket.socket.__name__=='socket' (len=6; the socket class and module share the same name); socket.SHUT_RD.__class__.__name__=='int'; socket.SHUT_WR.__class__.__name__=='int'; socket.SHUT_RDWR.__class__.__name__=='int'; socket.SHUT_RD.__eq__(0)==True; socket.SHUT_WR.__eq__(1)==True; socket.SHUT_RDWR.__eq__(2)==True."
    - "socket.__package__ == '' — socket is Lib/socket.py (a plain module file, not a package directory); the import system sets __package__ to '' for top-level non-package modules."
    - "socket.socket.__name__ == 'socket' — the socket class within the socket module shares the module's name; this is a deliberate naming convention (like 'datetime.datetime')."
    - "socket.SHUT_RD == 0, socket.SHUT_WR == 1, socket.SHUT_RDWR == 2 — these POSIX shutdown(2) constants are exposed as plain int objects (not enum members) in the socket module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket module __name__ and __package__ identity
#
# socket.__name__ == 'socket' (len 6)
# socket.__package__ == '' (plain module file, not a package)
# socket.__name__.__eq__('socket') == True
# socket.__package__.__eq__('') == True
#
# socket is implemented primarily as Lib/socket.py (with C extensions for the
# low-level socket primitives).  Because the top-level socket namespace is a
# plain module file rather than a package directory, __package__ is '' not
# 'socket'.  __name__ is 'socket', the name used at import time. New to extra178.
# ---------------------------------------------------------------------------

table socket_extra178.module_name_and_package:
  description: "socket.__name__=='socket' (len=6); __package__=='' (plain module, not a package); new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: socketmodule178

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq_socket,
       "__name__.__eq__",
       ["socket"],
       true,
       "socket.__name__.__eq__('socket') == True — socket.__name__ is the string 'socket', the module's fully-qualified name as registered in sys.modules; str.__eq__('socket') returns True; new to extra178"]
    - [name_len_6,
       "__name__.__len__",
       [],
       6,
       "socket.__name__.__len__() == 6 — the string 'socket' has 6 characters (s-o-c-k-e-t); str.__len__() returns 6; new to extra178"]
    - [package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "socket.__package__.__eq__('') == True — socket is Lib/socket.py, a plain module file rather than a package directory; the import system sets __package__ to '' for top-level non-package modules; str.__eq__('') returns True; new to extra178"]
    - [package_not_socket,
       "__package__.__eq__",
       ["socket"],
       false,
       "socket.__package__.__eq__('socket') == False — socket is a plain module (not a package), so __package__ is '' not 'socket'; str.__eq__('socket') returns False; new to extra178"]

# ---------------------------------------------------------------------------
# Table 2: socket.socket class __name__ identity
#
# socket.socket.__name__ == 'socket' (len 6)
# socket.socket.__name__.__eq__('socket') == True
# socket.socket.__name__.__len__() == 6
# socket.socket.__name__.__eq__('Socket') == False  (case-sensitive)
#
# socket.socket is the class that represents a BSD socket object.  Its __name__
# is 'socket' — the same string as the module name.  This mirrors the pattern
# of datetime.datetime, where a class and its containing module share a name.
# New to extra178.
# ---------------------------------------------------------------------------

table socket_extra178.socket_class_name:
  description: "socket.socket.__name__=='socket' (len=6); case-sensitive; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: socketmodule178

  columns: [id, function, args, expected, description]
  rows:
    - [socket_class_name_eq,
       "socket.__name__.__eq__",
       ["socket"],
       true,
       "socket.socket.__name__.__eq__('socket') == True — socket.socket is the BSD socket class; its __name__ attribute is 'socket', matching the module name; str.__eq__('socket') returns True; new to extra178"]
    - [socket_class_name_len_6,
       "socket.__name__.__len__",
       [],
       6,
       "socket.socket.__name__.__len__() == 6 — 'socket' has 6 characters (s-o-c-k-e-t); str.__len__() returns 6; new to extra178"]
    - [socket_class_name_not_Socket,
       "socket.__name__.__eq__",
       ["Socket"],
       false,
       "socket.socket.__name__.__eq__('Socket') == False — the class name is lowercase 'socket', not capitalized 'Socket'; Python identifiers are case-sensitive; str.__eq__('Socket') returns False; new to extra178"]
    - [socket_class_name_not_socket_socket,
       "socket.__name__.__eq__",
       ["socket.socket"],
       false,
       "socket.socket.__name__.__eq__('socket.socket') == False — __name__ is the bare class name 'socket', not the fully-qualified name 'socket.socket'; str.__eq__('socket.socket') returns False; new to extra178"]

# ---------------------------------------------------------------------------
# Table 3: socket.SHUT_RD, SHUT_WR, SHUT_RDWR class and value identity
#
# socket.SHUT_RD.__class__.__name__ == 'int'
# socket.SHUT_WR.__class__.__name__ == 'int'
# socket.SHUT_RDWR.__class__.__name__ == 'int'
# socket.SHUT_RD.__eq__(0) == True
# socket.SHUT_WR.__eq__(1) == True
# socket.SHUT_RDWR.__eq__(2) == True
#
# The SHUT_* constants are POSIX shutdown(2) direction flags exposed as plain
# Python int objects.  SHUT_RD=0 (stop receiving), SHUT_WR=1 (stop sending),
# SHUT_RDWR=2 (stop both).  New to extra178.
# ---------------------------------------------------------------------------

table socket_extra178.shut_constants_class_and_value:
  description: "SHUT_RD/WR/RDWR are plain int objects with values 0, 1, 2 respectively; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: socketmodule178

  columns: [id, function, args, expected, description]
  rows:
    - [shut_rd_class_int,
       "SHUT_RD.__class__.__name__.__eq__",
       ["int"],
       true,
       "socket.SHUT_RD.__class__.__name__.__eq__('int') == True — socket.SHUT_RD is a plain Python int (the POSIX shutdown(2) flag for disabling further receive operations); its __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra178"]
    - [shut_wr_class_int,
       "SHUT_WR.__class__.__name__.__eq__",
       ["int"],
       true,
       "socket.SHUT_WR.__class__.__name__.__eq__('int') == True — socket.SHUT_WR is a plain Python int (the POSIX shutdown(2) flag for disabling further send operations); its __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra178"]
    - [shut_rdwr_class_int,
       "SHUT_RDWR.__class__.__name__.__eq__",
       ["int"],
       true,
       "socket.SHUT_RDWR.__class__.__name__.__eq__('int') == True — socket.SHUT_RDWR is a plain Python int (the POSIX shutdown(2) flag for disabling both send and receive); its __class__.__name__ is 'int'; str.__eq__('int') returns True; new to extra178"]
    - [shut_rd_eq_0,
       "SHUT_RD.__eq__",
       [0],
       true,
       "socket.SHUT_RD.__eq__(0) == True — socket.SHUT_RD has the integer value 0 (POSIX SHUT_RD == 0); int.__eq__(0) returns True; new to extra178"]
    - [shut_wr_eq_1,
       "SHUT_WR.__eq__",
       [1],
       true,
       "socket.SHUT_WR.__eq__(1) == True — socket.SHUT_WR has the integer value 1 (POSIX SHUT_WR == 1); int.__eq__(1) returns True; new to extra178"]
    - [shut_rdwr_eq_2,
       "SHUT_RDWR.__eq__",
       [2],
       true,
       "socket.SHUT_RDWR.__eq__(2) == True — socket.SHUT_RDWR has the integer value 2 (POSIX SHUT_RDWR == 2); int.__eq__(2) returns True; new to extra178"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra178
# ---------------------------------------------------------------------------

invariant socket_extra178.name_eq_socket:
  description: "socket.__name__ == 'socket' — the module's fully-qualified name; new to extra178"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra178.name_len_6:
  description: "socket.__name__.__len__() == 6 — 'socket' is a 6-character string; new to extra178"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 6

invariant socket_extra178.package_empty:
  description: "socket.__package__ == '' — socket is Lib/socket.py (not a package directory), so __package__ is empty string; new to extra178"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant socket_extra178.socket_class_name_eq:
  description: "socket.socket.__name__ == 'socket' — the socket class and module share the same name; new to extra178"
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra178.shut_rd_eq_0:
  description: "socket.SHUT_RD.__eq__(0) == True — SHUT_RD is 0 (POSIX shutdown receive direction constant); new to extra178"
  kind: python_call_eq
  function: SHUT_RD.__eq__
  args: [0]
  expected: true

invariant socket_extra178.shut_wr_eq_1:
  description: "socket.SHUT_WR.__eq__(1) == True — SHUT_WR is 1 (POSIX shutdown send direction constant); new to extra178"
  kind: python_call_eq
  function: SHUT_WR.__eq__
  args: [1]
  expected: true

invariant socket_extra178.shut_rdwr_eq_2:
  description: "socket.SHUT_RDWR.__eq__(2) == True — SHUT_RDWR is 2 (POSIX shutdown both directions constant); new to extra178"
  kind: python_call_eq
  function: SHUT_RDWR.__eq__
  args: [2]
  expected: true
