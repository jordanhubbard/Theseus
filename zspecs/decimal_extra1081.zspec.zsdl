spec: decimal_extra1081
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal arithmetic/comparison dunder methods and module-level context function documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks Decimal arithmetic dunder __qualname__ values, Decimal comparison dunder __qualname__ values, and getcontext/setcontext/localcontext function qualnames (module is _decimal, not decimal)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1081.decimal_arithmetic_dunders:
  description: "decimal.Decimal arithmetic dunder method __qualname__ checks"
  kind: python_call_eq
  category: decimal_arithmetic_dunders
  id_prefix: dc1081ad
  columns: [id, function, args, expected]
  rows:
    - [dc1081ad001, decimal.Decimal.__add__.__qualname__.__eq__,      ["Decimal.__add__"],      true]
    - [dc1081ad002, decimal.Decimal.__sub__.__qualname__.__eq__,      ["Decimal.__sub__"],      true]
    - [dc1081ad003, decimal.Decimal.__mul__.__qualname__.__eq__,      ["Decimal.__mul__"],      true]
    - [dc1081ad004, decimal.Decimal.__truediv__.__qualname__.__eq__,  ["Decimal.__truediv__"],  true]
    - [dc1081ad005, decimal.Decimal.__mod__.__qualname__.__eq__,      ["Decimal.__mod__"],      true]
    - [dc1081ad006, decimal.Decimal.__pow__.__qualname__.__eq__,      ["Decimal.__pow__"],      true]
    - [dc1081ad007, decimal.Decimal.__neg__.__qualname__.__eq__,      ["Decimal.__neg__"],      true]
    - [dc1081ad008, decimal.Decimal.__abs__.__qualname__.__eq__,      ["Decimal.__abs__"],      true]
    - [dc1081ad009, decimal.Decimal.__add__.__class__.__name__.__eq__, ["wrapper_descriptor"],  true]

table decimal_extra1081.decimal_comparison_dunders:
  description: "decimal.Decimal comparison dunder method __qualname__ checks"
  kind: python_call_eq
  category: decimal_comparison_dunders
  id_prefix: dc1081cd
  columns: [id, function, args, expected]
  rows:
    - [dc1081cd001, decimal.Decimal.__lt__.__qualname__.__eq__, ["Decimal.__lt__"], true]
    - [dc1081cd002, decimal.Decimal.__le__.__qualname__.__eq__, ["Decimal.__le__"], true]
    - [dc1081cd003, decimal.Decimal.__gt__.__qualname__.__eq__, ["Decimal.__gt__"], true]
    - [dc1081cd004, decimal.Decimal.__ge__.__qualname__.__eq__, ["Decimal.__ge__"], true]
    - [dc1081cd005, decimal.Decimal.__eq__.__qualname__.__eq__, ["Decimal.__eq__"], true]
    - [dc1081cd006, decimal.Decimal.__ne__.__qualname__.__eq__, ["Decimal.__ne__"], true]
    - [dc1081cd007, decimal.Decimal.__int__.__qualname__.__eq__, ["Decimal.__int__"], true]
    - [dc1081cd008, decimal.Decimal.__float__.__qualname__.__eq__, ["Decimal.__float__"], true]

table decimal_extra1081.context_function_qualnames:
  description: "decimal module-level context function __qualname__ and __module__ checks"
  kind: python_call_eq
  category: context_function_qualnames
  id_prefix: dc1081cf
  columns: [id, function, args, expected]
  rows:
    - [dc1081cf001, decimal.getcontext.__qualname__.__eq__,   ["getcontext"],   true]
    - [dc1081cf002, decimal.getcontext.__module__.__eq__,     ["_decimal"],     true]
    - [dc1081cf003, decimal.setcontext.__qualname__.__eq__,   ["setcontext"],   true]
    - [dc1081cf004, decimal.setcontext.__module__.__eq__,     ["_decimal"],     true]
    - [dc1081cf005, decimal.localcontext.__qualname__.__eq__, ["localcontext"], true]
    - [dc1081cf006, decimal.localcontext.__module__.__eq__,   ["_decimal"],     true]
    - [dc1081cf007, decimal.Decimal.__pos__.__qualname__.__eq__, ["Decimal.__pos__"], true]
