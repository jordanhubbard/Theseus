    - [io1036tw001, io.TextIOWrapper.encoding.__class__.__name__.__eq__,      ["property"], true]
    - [io1036tw002, io.TextIOWrapper.errors.__class__.__name__.__eq__,        ["property"], true]
    - [io1036tw003, io.TextIOWrapper.line_buffering.__class__.__name__.__eq__, ["property"], true]
    - [io1036tw004, io.TextIOWrapper.write_through.__class__.__name__.__eq__, ["property"], true]
    - [io1036tw005, io.TextIOWrapper.__module__.__eq__,                       ["io"],       true]
    - [io1036tw006, io.TextIOWrapper.__name__.__eq__,                         ["TextIOWrapper"], true]
    - [io1036tw007, io.TextIOWrapper.__doc__.__class__.__name__.__eq__,       ["str"],      true]

table io_extra1036.bufferedreader_attr_descriptors:
