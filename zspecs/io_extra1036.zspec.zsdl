spec: io_extra1036
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module FileIO, TextIOWrapper, BufferedReader documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.FileIO, io.TextIOWrapper, and io.BufferedReader attribute class descriptors"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1036.fileio_attr_descriptors:
  description: "io.FileIO attribute descriptor class name checks"
  kind: python_call_eq
  category: fileio_attr_descriptors
  id_prefix: io1036fa
  columns: [id, function, args, expected]
  rows:
    - [io1036fa001, io.FileIO.name.__class__.__name__.__eq__,        ["getset_descriptor"], true]
    - [io1036fa002, io.FileIO.mode.__class__.__name__.__eq__,        ["getset_descriptor"], true]
    - [io1036fa003, io.FileIO.closefd.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [io1036fa004, io.FileIO.__module__.__eq__,                     ["io"],                true]
    - [io1036fa005, io.FileIO.__name__.__eq__,                       ["FileIO"],            true]
    - [io1036fa006, io.FileIO.__doc__.__class__.__name__.__eq__,     ["str"],               true]

table io_extra1036.textiowrapper_attr_descriptors:
