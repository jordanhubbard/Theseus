spec: abc_extra278
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Python collections.abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#abstract-base-classes — Python data model ABCs"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
    - "abc_extra28.zspec.zsdl — covers ABCMeta.__subclasshook__ name lengths, deprecated decorator lengths, module membership lengths (C vs Python), issubclass/isinstance behavioral invariants"
    - "abc_extra.zspec.zsdl — covers abc.abstractmethod, abc.ABC, abc.ABCMeta identity checks from the abc module"
  notes:
    - "This spec focuses on collections.abc.Sequence — its __abstractmethods__ frozenset, concrete mixin methods, and the MutableSequence comparison. The backend is collections.abc (not abc itself)."
    - "Sequence.__abstractmethods__ == frozenset({'__getitem__', '__len__'}); __len__() == 2; __class__.__name__ == 'frozenset'. Exactly two methods must be implemented to create a concrete Sequence subclass. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Sequence provides 5 concrete mixin methods: index, count, __contains__, __iter__, __reversed__. These are all defined with __qualname__ prefix 'Sequence.' and __module__ == 'collections.abc'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Sequence.__module__ == 'collections.abc' (len=15); Sequence.__name__ == 'Sequence' (len=8); Sequence.__mro__.__len__() == 7 ([Sequence, Reversible, Collection, Sized, Iterable, Container, object]). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Concrete method __qualname__ lengths: Sequence.index=14, Sequence.count=14, Sequence.__contains__=21, Sequence.__iter__=17, Sequence.__reversed__=21. __contains__ and __reversed__ tie for longest (21 chars each). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "MutableSequence.__abstractmethods__.__len__() == 5 — requires implementing insert, __len__, __setitem__, __getitem__, __delitem__. Compare: Sequence requires only 2 abstract methods. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Sequence.__abstractmethods__.__contains__('index') == False — index is a concrete mixin, not abstract. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Sequence.__abstractmethods__ frozenset checks — extra278
#
# collections.abc.Sequence has exactly 2 abstract methods: __getitem__ and
# __len__. These are the minimum interface a class must implement to be
# recognised as a concrete Sequence.
#
# Sequence.__abstractmethods__.__class__.__name__ == 'frozenset'
# Sequence.__abstractmethods__.__len__()          == 2
# Sequence.__abstractmethods__.__contains__('__getitem__') == True
# Sequence.__abstractmethods__.__contains__('__len__')     == True
# Sequence.__abstractmethods__.__contains__('index')       == False
# Sequence.__abstractmethods__.__contains__('count')       == False
# ---------------------------------------------------------------------------

table abc_extra278.sequence_abstractmethods_membership:
  description: "collections.abc.Sequence.__abstractmethods__ membership checks in extra278 namespace — frozenset with exactly 2 members (__getitem__ and __len__); concrete mixin methods (index, count) are NOT in abstractmethods; verified with Python 3.14.3"
  kind: python_call_eq
  category: abstract_methods
  id_prefix: seqabsmem278

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,    Sequence.__abstractmethods__.__class__.__name__.__eq__,  ["frozenset"],     true,  "Sequence.__abstractmethods__.__class__.__name__ == 'frozenset'; verified with Python 3.14.3"]
    - [len_eq,           Sequence.__abstractmethods__.__len__,                    [],                2,     "Sequence.__abstractmethods__.__len__() == 2 (exactly __getitem__ and __len__); verified with Python 3.14.3"]
    - [has_getitem,      Sequence.__abstractmethods__.__contains__,               ["__getitem__"],   true,  "Sequence.__abstractmethods__.__contains__('__getitem__') == True; verified with Python 3.14.3"]
    - [has_len,          Sequence.__abstractmethods__.__contains__,               ["__len__"],       true,  "Sequence.__abstractmethods__.__contains__('__len__') == True; verified with Python 3.14.3"]
    - [no_index,         Sequence.__abstractmethods__.__contains__,               ["index"],         false, "Sequence.__abstractmethods__.__contains__('index') == False — index is a concrete mixin; verified with Python 3.14.3"]
    - [no_count,         Sequence.__abstractmethods__.__contains__,               ["count"],         false, "Sequence.__abstractmethods__.__contains__('count') == False — count is a concrete mixin; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Sequence concrete mixin method __qualname__ lengths — extra278
#
# Sequence provides 5 concrete mixin methods for free once __getitem__ and
# __len__ are implemented. All carry the 'Sequence.' prefix (9 chars) in
# their __qualname__:
#   Sequence.__contains__.__qualname__  == 'Sequence.__contains__'  (len=21)
#   Sequence.__reversed__.__qualname__  == 'Sequence.__reversed__'  (len=21)
#   Sequence.__iter__.__qualname__      == 'Sequence.__iter__'      (len=17)
#   Sequence.index.__qualname__         == 'Sequence.index'         (len=14)
#   Sequence.count.__qualname__         == 'Sequence.count'         (len=14)
# __contains__ and __reversed__ tie for longest (21 chars each).
# index and count tie for shortest (14 chars each).
# All five have __module__ == 'collections.abc'.
# ---------------------------------------------------------------------------

table abc_extra278.sequence_concrete_method_qualname_lengths:
  description: "collections.abc.Sequence concrete mixin method __qualname__.__len__() in extra278 namespace — __contains__/__reversed__ tie at 21 (longest); index/count tie at 14 (shortest); all have __module__=='collections.abc' (len=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: seqconcrmqlen278

  columns: [id, function, args, expected]
  rows:
    - [__contains__,  Sequence.__contains__.__qualname__.__len__,  [], 21]
    - [__reversed__,  Sequence.__reversed__.__qualname__.__len__,  [], 21]
    - [__iter__,      Sequence.__iter__.__qualname__.__len__,      [], 17]
    - [index,         Sequence.index.__qualname__.__len__,         [], 14]
    - [count,         Sequence.count.__qualname__.__len__,         [], 14]

# ---------------------------------------------------------------------------
# Sequence class identity standalone invariants — extra278
# ---------------------------------------------------------------------------

invariant abc_extra278.Sequence.module_eq:
  description: "collections.abc.Sequence.__module__ == 'collections.abc' — Sequence is defined in the collections.abc submodule"
  category: identity
  kind: python_call_eq
  function: Sequence.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra278.Sequence.name_len:
  description: "collections.abc.Sequence.__name__.__len__() == 8 — 'Sequence' is 8 characters"
  category: identity
  kind: python_call_eq
  function: Sequence.__name__.__len__
  args: []
  expected: 8

invariant abc_extra278.Sequence.mro_len:
  description: "collections.abc.Sequence.__mro__.__len__() == 7 — MRO is [Sequence, Reversible, Collection, Sized, Iterable, Container, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Sequence.__mro__.__len__
  args: []
  expected: 7

invariant abc_extra278.Sequence.abstractmethods_len_is_2:
  description: "collections.abc.Sequence.__abstractmethods__.__len__() == 2 — exactly __getitem__ and __len__ must be implemented"
  category: abstract_methods
  kind: python_call_eq
  function: Sequence.__abstractmethods__.__len__
  args: []
  expected: 2

invariant abc_extra278.Sequence.contains_qualname_eq:
  description: "collections.abc.Sequence.__contains__.__qualname__ == 'Sequence.__contains__' — concrete mixin provided by Sequence (len=21)"
  category: method_names
  kind: python_call_eq
  function: Sequence.__contains__.__qualname__.__eq__
  args: ["Sequence.__contains__"]
  expected: true

invariant abc_extra278.Sequence.index_qualname_eq:
  description: "collections.abc.Sequence.index.__qualname__ == 'Sequence.index' — concrete mixin method for finding first occurrence (len=14)"
  category: method_names
  kind: python_call_eq
  function: Sequence.index.__qualname__.__eq__
  args: ["Sequence.index"]
  expected: true

invariant abc_extra278.MutableSequence.abstractmethods_len:
  description: "collections.abc.MutableSequence.__abstractmethods__.__len__() == 5 — requires insert, __len__, __setitem__, __getitem__, __delitem__; compare Sequence which requires only 2"
  category: abstract_methods
  kind: python_call_eq
  function: MutableSequence.__abstractmethods__.__len__
  args: []
  expected: 5

invariant abc_extra278.Sequence.module_len:
  description: "collections.abc.Sequence.__module__.__len__() == 15 — 'collections.abc' is 15 characters"
  category: identity
  kind: python_call_eq
  function: Sequence.__module__.__len__
  args: []
  expected: 15
