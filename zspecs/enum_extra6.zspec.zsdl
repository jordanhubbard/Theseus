spec: enum_extra6
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "Extends enum.zspec.zsdl through enum_extra5.zspec.zsdl."
    - "Previous specs cover: class/function __name__ attributes, MRO structure, member .name/.value, __members__, iteration, arithmetic/bitwise ops, boundary constants, qualname/module/metaclass in extra3-5."
    - "enum.Enum.__module__ == 'enum' — Enum class is defined in the enum module."
    - "enum.IntEnum.__module__ == 'enum' — IntEnum class is defined in the enum module."
    - "enum.Flag.__module__ == 'enum' — Flag class is defined in the enum module."
    - "enum.IntFlag.__module__ == 'enum' — IntFlag class is defined in the enum module."
    - "enum.StrEnum.__module__ == 'enum' (Python 3.11+) — StrEnum class is defined in the enum module."
    - "enum.auto.__module__ == 'enum' — auto helper class is defined in the enum module."
    - "enum.unique.__module__ == 'enum' — unique decorator function is defined in the enum module."
    - "enum.EnumType.__module__ == 'enum' (Python 3.11+) or enum.EnumMeta.__module__ == 'enum' (3.9/3.10)."
    - "enum.Enum.__class__.__name__ == 'EnumType' (3.11+) or 'EnumMeta' (3.9/3.10) — Enum's metaclass name."
    - "enum.Enum._generate_next_value_.__name__ == '_generate_next_value_' — the name of the generate-next method."
    - "enum.Enum._missing_.__name__ == '_missing_' — the name of the missing-value hook."
    - "enum.Enum._ignore_ is a list (or list subclass) — the default _ignore_ value on the Enum class."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module affiliation — enum.Enum and core subclasses
#
# All core enum classes are defined directly in the 'enum' module. Their
# __module__ attribute must equal 'enum'.
# ---------------------------------------------------------------------------

invariant enum_extra6.Enum.module:
  description: "enum.Enum.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: Enum.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra6.IntEnum.module:
  description: "enum.IntEnum.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: IntEnum.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra6.Flag.module:
  description: "enum.Flag.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: Flag.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra6.IntFlag.module:
  description: "enum.IntFlag.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: IntFlag.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra6.StrEnum.module:
  description: "enum.StrEnum.__module__ == 'enum' (Python 3.11+)"
  category: module
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra6.auto.module:
  description: "enum.auto.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: auto.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra6.unique.module:
  description: "enum.unique.__module__ == 'enum'"
  category: module
  kind: python_call_eq
  function: unique.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# EnumType / EnumMeta — module affiliation
#
# In Python 3.11+ the metaclass was renamed from EnumMeta to EnumType.
# Both must have __module__ == 'enum'. We gate each variant on its
# supported Python version range.
# ---------------------------------------------------------------------------

invariant enum_extra6.EnumMeta.module:
  description: "enum.EnumMeta.__module__ == 'enum' (Python 3.9 and 3.10)"
  category: module
  version: ">=3.9,<3.11"
  kind: python_call_eq
  function: EnumMeta.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra6.EnumType.module:
  description: "enum.EnumType.__module__ == 'enum' (Python 3.11+)"
  category: module
  version: ">=3.11"
  kind: python_call_eq
  function: EnumType.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# enum.Enum.__class__.__name__ — metaclass identity
#
# Enum is created by EnumMeta (renamed EnumType in 3.11). The __class__ of
# Enum is therefore its metaclass. We verify the name matches the version.
# ---------------------------------------------------------------------------

invariant enum_extra6.Enum.metaclass_name_lt311:
  description: "enum.Enum.__class__.__name__ == 'EnumMeta' on Python 3.9 / 3.10"
  category: metaclass
  version: ">=3.9,<3.11"
  kind: python_call_eq
  function: Enum.__class__.__name__.__eq__
  args: ["EnumMeta"]
  expected: true

invariant enum_extra6.Enum.metaclass_name_ge311:
  description: "enum.Enum.__class__.__name__ == 'EnumType' on Python 3.11+"
  category: metaclass
  version: ">=3.11"
  kind: python_call_eq
  function: Enum.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# enum.Enum._generate_next_value_ — function name
#
# Enum provides a _generate_next_value_ classmethod that auto() delegates to.
# The underlying function's __name__ attribute is '_generate_next_value_'.
# ---------------------------------------------------------------------------

invariant enum_extra6.Enum._generate_next_value_.name:
  description: "enum.Enum._generate_next_value_.__name__ == '_generate_next_value_'"
  category: internal_methods
  kind: python_call_eq
  function: Enum._generate_next_value_.__name__.__eq__
  args: ["_generate_next_value_"]
  expected: true

# ---------------------------------------------------------------------------
# enum.Enum._missing_ — function name
#
# Enum._missing_ is a classmethod hook invoked when a value lookup fails.
# The underlying function's __name__ attribute is '_missing_'.
# ---------------------------------------------------------------------------

invariant enum_extra6.Enum._missing_.name:
  description: "enum.Enum._missing_.__name__ == '_missing_'"
  category: internal_methods
  kind: python_call_eq
  function: Enum._missing_.__name__.__eq__
  args: ["_missing_"]
  expected: true

# ---------------------------------------------------------------------------
# enum.Enum._ignore_ — class-level default is a list
#
# Enum._ignore_ is set to an empty list [] on the base Enum class. This list
# is used during class creation to exclude listed names from enum membership.
# ---------------------------------------------------------------------------

invariant enum_extra6.Enum._ignore_.class_name:
  description: "enum.Enum._ignore_.__class__.__name__ == 'list' — _ignore_ default is an empty list"
  category: internal_methods
  kind: python_call_eq
  function: Enum._ignore_.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant enum_extra6.Enum._ignore_.length:
  description: "len(enum.Enum._ignore_) == 0 — default _ignore_ list is empty"
  category: internal_methods
  kind: python_call_eq
  function: Enum._ignore_.__len__
  args: []
  expected: 0
