spec: functools_extra39
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra38.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps(5)/partial(7)/lru_cache(9)/total_ordering(14)/singledispatch(14)/cached_property(15)/reduce(6)/cmp_to_key(10)/partialmethod(13)/singledispatchmethod/update_wrapper(14); __qualname__.__len__() for update_wrapper(14)/partialmethod(13)/singledispatchmethod(20)/cache(5)/total_ordering(14)/singledispatch(14)/cmp_to_key(10)/cached_property(15)/lru_cache(9)/wraps(5)/reduce(6)/partial(7); partial/__mro__/partialmethod/__mro__/cached_property/__mro__/singledispatchmethod/__mro__ (all 2); partial/__bases__[0].__name__/partialmethod/__bases__[0].__name__/cached_property/__bases__[0].__name__/singledispatchmethod.__bases__[0].__name__ (all 'object' len 6); WRAPPER_ASSIGNMENTS element lengths; functools.__spec__.__class__.__name__.__len__()==10; functools.__all__[-1].__len__()==11."
    - "This spec covers: wraps.__name__.__len__() (5 — 'wraps', confirming __name__ == __qualname__); cmp_to_key.__name__.__len__() (10 — 'cmp_to_key'); singledispatch.__name__.__len__() (14 — same as __qualname__); total_ordering.__name__.__len__() (14 — same as __qualname__); lru_cache.__qualname__.__len__() (9 — matches __name__); partial.__doc__.__class__.__name__.__len__() (3 — docstring is 'str'); functools.__all__[0].__len__() (14 — 'update_wrapper', the first public API name)."
    - "Key findings: wraps.__name__ == 'wraps' (5 chars) matches __qualname__. cmp_to_key.__name__ is 'cmp_to_key' (10 chars), the same as its qualname. singledispatch.__name__ is 'singledispatch' (14 chars), same as total_ordering — both are decorator helpers sharing the same length. lru_cache.__qualname__ is 'lru_cache' (9 chars), confirming lru_cache is not a nested class. functools.partial.__doc__.__class__.__name__ is 'str' (3 chars)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Remaining callable __name__.__len__() table — extra39 namespace
#
# functools.wraps.__name__ is 'wraps' (5 chars) — matching its __qualname__.
# functools.cmp_to_key.__name__ is 'cmp_to_key' (10 chars) — same as __qualname__.
# functools.singledispatch.__name__ is 'singledispatch' (14 chars) — same as __qualname__.
# functools.total_ordering.__name__ is 'total_ordering' (14 chars) — same as __qualname__.
# Prior specs recorded __qualname__.__len__() for all four, but not __name__.__len__()
# explicitly as standalone confirmed values in the extra39 namespace.
# No prior functools spec records these four __name__.__len__() values together
# in a combined table in the extra39 namespace.
# ---------------------------------------------------------------------------

table functools_extra39.remaining_callable_name_lengths:
  description: "functools callable __name__.__len__() for wraps/cmp_to_key/singledispatch/total_ordering — confirming __name__ == __qualname__"
  kind: python_call_eq
  category: string_properties
  id_prefix: remcallnamelen39

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_name,
       wraps.__name__.__len__,
       [],
       5,
       "len(functools.wraps.__name__) == 5 — 'wraps' (matches __qualname__)"]
    - [cmp_to_key_name,
       cmp_to_key.__name__.__len__,
       [],
       10,
       "len(functools.cmp_to_key.__name__) == 10 — 'cmp_to_key' (matches __qualname__)"]
    - [singledispatch_name,
       singledispatch.__name__.__len__,
       [],
       14,
       "len(functools.singledispatch.__name__) == 14 — 'singledispatch' (matches __qualname__)"]
    - [total_ordering_name,
       total_ordering.__name__.__len__,
       [],
       14,
       "len(functools.total_ordering.__name__) == 14 — 'total_ordering' (matches __qualname__, same length as singledispatch)"]

# ---------------------------------------------------------------------------
# lru_cache __qualname__.__len__() and partial __doc__ class name — extra39 namespace
#
# functools.lru_cache.__qualname__ is 'lru_cache' (9 chars) — matching __name__,
# confirming lru_cache is a module-level object, not a nested class. Prior specs
# recorded lru_cache.__name__.__len__() == 9 but not lru_cache.__qualname__.__len__()
# explicitly. functools.partial.__doc__.__class__.__name__ is 'str' (3 chars) —
# confirming the partial docstring is a plain Python string. No prior functools spec
# records these two values together in a combined table in the extra39 namespace.
# ---------------------------------------------------------------------------

table functools_extra39.lru_cache_qualname_and_partial_doc:
  description: "functools.lru_cache __qualname__.__len__() (9) and partial.__doc__.__class__.__name__.__len__() (3)"
  kind: python_call_eq
  category: string_properties
  id_prefix: lrucacheqdoc39

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_qualname,
       lru_cache.__qualname__.__len__,
       [],
       9,
       "len(functools.lru_cache.__qualname__) == 9 — 'lru_cache' (matches __name__, not a nested class)"]
    - [partial_doc_classname,
       partial.__doc__.__class__.__name__.__len__,
       [],
       3,
       "len(functools.partial.__doc__.__class__.__name__) == 3 — docstring is a 'str' object"]

# ---------------------------------------------------------------------------
# functools.__all__[0].__len__() — standalone invariant
#
# functools.__all__[0] is 'update_wrapper' (14 chars). Prior spec extra38 recorded
# functools.__all__[-1].__len__() == 11 ('Placeholder'), and functools.__all__.__len__()
# indirectly, but functools.__all__[0].__len__() == 14 was not recorded as a standalone
# in the extra39 namespace. 'update_wrapper' is the first name exported in
# functools.__all__, reflecting its role as the foundational public API function
# upon which wraps is built.
# ---------------------------------------------------------------------------

invariant functools_extra39.all_first_elem_len:
  description: "len(functools.__all__[0]) == 14 — 'update_wrapper' is the first element of functools.__all__"
  category: module_metadata
  kind: python_call_eq
  function: "__all__[0].__len__"
  args: []
  expected: 14
