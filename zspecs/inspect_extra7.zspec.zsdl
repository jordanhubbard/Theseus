spec: inspect_extra7
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect.zspec.zsdl, inspect_extra.zspec.zsdl, inspect_extra2.zspec.zsdl, inspect_extra3.zspec.zsdl, inspect_extra5.zspec.zsdl, inspect_extra6.zspec.zsdl, and inspect_signature.zspec.zsdl."
    - "inspect_extra2 covers __qualname__ for isfunction/ismethod/isclass/ismodule/isbuiltin."
    - "inspect_extra5 covers __name__ for isfunction/ismethod/isclass/ismodule/isbuiltin/getmembers/getsource/signature/getdoc; __name__ for Parameter/Signature; __module__ for Parameter/Signature."
    - "inspect_extra6 covers __name__ for FrameInfo/Traceback/BlockFinder/Parameter/Signature."
    - "NEW in this spec: __qualname__ for Parameter, Signature, BoundArguments, FrameInfo (none covered in prior specs)."
    - "NEW in this spec: __qualname__ for signature, getsource, getmembers, getdoc (not in inspect_extra2 which only covered the is* predicates)."
    - "inspect.Parameter.__qualname__ == 'Parameter' — top-level class in inspect module."
    - "inspect.Signature.__qualname__ == 'Signature' — top-level class in inspect module."
    - "inspect.BoundArguments.__qualname__ == 'BoundArguments' — top-level class in inspect module."
    - "inspect.FrameInfo.__qualname__ == 'FrameInfo' — top-level named tuple in inspect module."
    - "inspect.signature.__qualname__ == 'signature' — module-level function."
    - "inspect.getsource.__qualname__ == 'getsource' — module-level function."
    - "inspect.getmembers.__qualname__ == 'getmembers' — module-level function."
    - "inspect.getdoc.__qualname__ == 'getdoc' — module-level function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for inspect classes
#
# inspect_extra2 covered only the is* predicate functions.
# inspect_extra5/extra6 covered __name__ for these classes but not __qualname__.
# All are top-level names in the inspect module so __qualname__ == __name__.
# ---------------------------------------------------------------------------

table inspect_extra7.class_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Parameter,      Parameter.__qualname__.__eq__,      ["Parameter"],      true]
    - [Signature,      Signature.__qualname__.__eq__,      ["Signature"],      true]
    - [BoundArguments, BoundArguments.__qualname__.__eq__, ["BoundArguments"], true]
    - [FrameInfo,      FrameInfo.__qualname__.__eq__,      ["FrameInfo"],      true]

# ---------------------------------------------------------------------------
# __qualname__ for inspect helper functions
#
# inspect_extra2 covered only is*/predicate qualnames.
# signature, getsource, getmembers, getdoc were not covered there.
# ---------------------------------------------------------------------------

table inspect_extra7.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [signature,   signature.__qualname__.__eq__,   ["signature"],   true]
    - [getsource,   getsource.__qualname__.__eq__,   ["getsource"],   true]
    - [getmembers,  getmembers.__qualname__.__eq__,  ["getmembers"],  true]
    - [getdoc,      getdoc.__qualname__.__eq__,       ["getdoc"],      true]

# ---------------------------------------------------------------------------
# __module__ for inspect classes — not covered in any prior inspect spec.
#
# inspect_extra5 covered __module__ for Parameter and Signature only.
# BoundArguments and FrameInfo __module__ have not been recorded.
# ---------------------------------------------------------------------------

invariant inspect_extra7.BoundArguments.module:
  description: "inspect.BoundArguments.__module__ == 'inspect'"
  category: class_modules
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra7.FrameInfo.module:
  description: "inspect.FrameInfo.__module__ == 'inspect'"
  category: class_modules
  kind: python_call_eq
  function: FrameInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.BoundArguments — class is present and is a type
#
# BoundArguments is the object returned by Signature.bind() and
# Signature.bind_partial(). Its __class__.__name__ is 'type' (it is a regular
# class defined at module scope). This has not been recorded in prior specs.
# ---------------------------------------------------------------------------

invariant inspect_extra7.BoundArguments.metaclass:
  description: "inspect.BoundArguments.__class__.__name__ == 'type' — BoundArguments is an ordinary class"
  category: class_qualnames
  kind: python_call_eq
  function: BoundArguments.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.signature / inspect.getsource — __module__ checks
#
# inspect_extra5 did not record __module__ for these functions.
# ---------------------------------------------------------------------------

invariant inspect_extra7.signature.module:
  description: "inspect.signature.__module__ == 'inspect'"
  category: function_modules
  kind: python_call_eq
  function: signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra7.getsource.module:
  description: "inspect.getsource.__module__ == 'inspect'"
  category: function_modules
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true
