spec: io_extra1396
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, UnsupportedOperation documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method checks for io module classes."
    - "None of the io module classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, UnsupportedOperation) have '__class_getitem__' in their own __dict__; the attribute does not exist on these classes at all (not even via inheritance from object, since object has no __class_getitem__)."
    - "None of the io module classes have '__init_subclass__' in their own __dict__; all inherit __init_subclass__ from object; the inherited __init_subclass__.__class__.__name__ is 'builtin_function_or_method' for all io classes; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "io.IOBase.__dict__.__contains__('__class_getitem__') == False for all seven io classes; io.IOBase.__dict__.__contains__('__init_subclass__') == False for all seven io classes; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1396.abstract_base_classes_no_class_getitem:
  description: "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase __dict__ lacks __class_getitem__ — wave 540 theme: none of the four abstract io base classes have '__class_getitem__' in their own __dict__; these C extension abstract base classes do not define __class_getitem__ (the attribute does not exist, not even via inheritance); verified with Python 3.12"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: io1396ab
  columns: [id, function, args, expected, description]
  rows:
    - [io1396ab001, io.IOBase.__dict__.__contains__,          ["__class_getitem__"], false, "io.IOBase.__dict__.__contains__('__class_getitem__') == False (abstract base class has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [io1396ab002, io.RawIOBase.__dict__.__contains__,       ["__class_getitem__"], false, "io.RawIOBase.__dict__.__contains__('__class_getitem__') == False (abstract base class has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [io1396ab003, io.BufferedIOBase.__dict__.__contains__,  ["__class_getitem__"], false, "io.BufferedIOBase.__dict__.__contains__('__class_getitem__') == False (abstract base class has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [io1396ab004, io.TextIOBase.__dict__.__contains__,      ["__class_getitem__"], false, "io.TextIOBase.__dict__.__contains__('__class_getitem__') == False (abstract base class has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [io1396ab005, io.IOBase.__dict__.__contains__,          ["__class_getitem__"], false, "io.IOBase.__dict__.__contains__('__class_getitem__') == False (cross-check anchor: root abstract class absent); verified with Python 3.12"]
    - [io1396ab006, io.RawIOBase.__dict__.__contains__,       ["__class_getitem__"], false, "io.RawIOBase.__dict__.__contains__('__class_getitem__') == False (cross-check: RawIOBase inherits from IOBase, both lack __class_getitem__); verified with Python 3.12"]
    - [io1396ab007, io.BufferedIOBase.__dict__.__contains__,  ["__class_getitem__"], false, "io.BufferedIOBase.__dict__.__contains__('__class_getitem__') == False (cross-check: BufferedIOBase inherits from IOBase, both lack __class_getitem__); verified with Python 3.12"]
    - [io1396ab008, io.TextIOBase.__dict__.__contains__,      ["__class_getitem__"], false, "io.TextIOBase.__dict__.__contains__('__class_getitem__') == False (cross-check: TextIOBase inherits from IOBase, both lack __class_getitem__); verified with Python 3.12"]

table io_extra1396.concrete_classes_no_class_getitem:
  description: "io.BytesIO, io.StringIO, io.UnsupportedOperation __dict__ lacks __class_getitem__ — wave 540 theme: none of the concrete io classes have '__class_getitem__' in their own __dict__; consistent with the abstract base classes; none of the io module classes define __class_getitem__; verified with Python 3.12"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: io1396cc
  columns: [id, function, args, expected, description]
  rows:
    - [io1396cc001, io.BytesIO.__dict__.__contains__,              ["__class_getitem__"], false, "io.BytesIO.__dict__.__contains__('__class_getitem__') == False (concrete class has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [io1396cc002, io.StringIO.__dict__.__contains__,             ["__class_getitem__"], false, "io.StringIO.__dict__.__contains__('__class_getitem__') == False (concrete class has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [io1396cc003, io.UnsupportedOperation.__dict__.__contains__, ["__class_getitem__"], false, "io.UnsupportedOperation.__dict__.__contains__('__class_getitem__') == False (exception class has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [io1396cc004, io.BytesIO.__dict__.__contains__,              ["__class_getitem__"], false, "io.BytesIO.__dict__.__contains__('__class_getitem__') == False (cross-check: BytesIO concrete class absent); verified with Python 3.12"]
    - [io1396cc005, io.StringIO.__dict__.__contains__,             ["__class_getitem__"], false, "io.StringIO.__dict__.__contains__('__class_getitem__') == False (cross-check: StringIO concrete class absent); verified with Python 3.12"]
    - [io1396cc006, io.UnsupportedOperation.__dict__.__contains__, ["__class_getitem__"], false, "io.UnsupportedOperation.__dict__.__contains__('__class_getitem__') == False (cross-check: UnsupportedOperation exception class absent); verified with Python 3.12"]
    - [io1396cc007, io.IOBase.__dict__.__contains__,               ["__class_getitem__"], false, "io.IOBase.__dict__.__contains__('__class_getitem__') == False (final cross-check: all seven io classes uniformly absent); verified with Python 3.12"]

table io_extra1396.all_classes_init_subclass_not_in_dict:
  description: "All io module classes __dict__ lacks __init_subclass__ — wave 540 theme: none of the io module classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, UnsupportedOperation) have '__init_subclass__' in their own __dict__; all inherit __init_subclass__ from object and its class name is 'builtin_function_or_method'; verified with Python 3.12"
  kind: python_call_eq
  category: init_subclass_checks
  id_prefix: io1396is
  columns: [id, function, args, expected, description]
  rows:
    - [io1396is001, io.IOBase.__dict__.__contains__,          ["__init_subclass__"], false, "io.IOBase.__dict__.__contains__('__init_subclass__') == False (IOBase inherits __init_subclass__ from object, not in own __dict__); verified with Python 3.12"]
    - [io1396is002, io.RawIOBase.__dict__.__contains__,       ["__init_subclass__"], false, "io.RawIOBase.__dict__.__contains__('__init_subclass__') == False (RawIOBase inherits __init_subclass__ from object, not in own __dict__); verified with Python 3.12"]
    - [io1396is003, io.BufferedIOBase.__dict__.__contains__,  ["__init_subclass__"], false, "io.BufferedIOBase.__dict__.__contains__('__init_subclass__') == False (BufferedIOBase inherits __init_subclass__ from object, not in own __dict__); verified with Python 3.12"]
    - [io1396is004, io.TextIOBase.__dict__.__contains__,      ["__init_subclass__"], false, "io.TextIOBase.__dict__.__contains__('__init_subclass__') == False (TextIOBase inherits __init_subclass__ from object, not in own __dict__); verified with Python 3.12"]
    - [io1396is005, io.BytesIO.__dict__.__contains__,         ["__init_subclass__"], false, "io.BytesIO.__dict__.__contains__('__init_subclass__') == False (BytesIO inherits __init_subclass__ from object, not in own __dict__); verified with Python 3.12"]
    - [io1396is006, io.StringIO.__dict__.__contains__,        ["__init_subclass__"], false, "io.StringIO.__dict__.__contains__('__init_subclass__') == False (StringIO inherits __init_subclass__ from object, not in own __dict__); verified with Python 3.12"]
    - [io1396is007, io.UnsupportedOperation.__dict__.__contains__, ["__init_subclass__"], false, "io.UnsupportedOperation.__dict__.__contains__('__init_subclass__') == False (UnsupportedOperation inherits __init_subclass__ from object, not in own __dict__); verified with Python 3.12"]
    - [io1396is008, io.IOBase.__init_subclass__.__class__.__name__.__eq__,       ["builtin_function_or_method"], true, "io.IOBase.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [io1396is009, io.BytesIO.__init_subclass__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "io.BytesIO.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [io1396is010, io.UnsupportedOperation.__init_subclass__.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "io.UnsupportedOperation.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
