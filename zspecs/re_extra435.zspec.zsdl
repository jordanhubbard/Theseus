spec: re_extra435
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module flags and exception class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Flag integer values are stable across Python 3.x versions"
    - "__bases__[0] function fields are double-quoted per ZSDL rules for bracket expressions"
    - "No bare \\d, \\w, \\s sequences used in double-quoted YAML strings"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra435.flag_values:
  description: "Integer values of re module compile flags"
  kind: python_call_eq
  category: constants
  id_prefix: ref

  columns: [id, function, args, expected]
  rows:
    - [ref001, re.IGNORECASE.__eq__, [2], true]
    - [ref002, re.MULTILINE.__eq__, [8], true]
    - [ref003, re.DOTALL.__eq__, [16], true]
    - [ref004, re.UNICODE.__eq__, [32], true]
    - [ref005, re.VERBOSE.__eq__, [64], true]

table re_extra435.error_class_identity:
  description: "Class identity for re.error exception"
  kind: python_call_eq
  category: class_identity
  id_prefix: ree

  columns: [id, function, args, expected]
  rows:
    - [ree001, re.error.__name__.__eq__, ["error"], true]
    - [ree002, re.error.__module__.__eq__, ["re"], true]
    - [ree003, "re.error.__bases__[0].__name__.__eq__", ["Exception"], true]
