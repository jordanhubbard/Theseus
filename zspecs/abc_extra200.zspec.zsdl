spec: abc_extra200
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABC.__mro__ has len=2 (ABC, object); ABC is defined as 'class ABC(metaclass=ABCMeta): pass' with object as the only implicit base."
    - "abc.ABCMeta.__mro__ has len=3 (ABCMeta, type, object); ABCMeta inherits from type because it is a metaclass."
    - "abc.ABC.__mro__[0].__name__ == 'ABC' (len=3); first MRO entry is always the class itself."
    - "abc.ABC.__mro__[1].__name__ == 'object' (len=6); ABC's only base is object."
    - "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' (len=7); first MRO entry is the class itself."
    - "abc.ABCMeta.__mro__[1].__name__ == 'type' (len=4); ABCMeta's direct base is the built-in type metaclass."
    - "abc.ABCMeta.__mro__[2].__name__ == 'object' (len=6); object is the ultimate base of all Python classes including metaclasses."
    - "abc.ABCMeta.__mro__.__len__(3) > abc.ABC.__mro__.__len__(2) by 1 — the metaclass has an extra step (type) in its chain."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABC MRO
#
# abc.ABC.__mro__.__len__() == 2
# abc.ABC.__mro__[0].__name__ == 'ABC' (len=3)
# abc.ABC.__mro__[1].__name__ == 'object' (len=6)
# ---------------------------------------------------------------------------

table abc_extra200.ABC_mro_identity:
  description: "abc.ABC MRO identity checks in abcmro200 namespace — ABC.__mro__.__len__()==2 (ABC MRO is [ABC, object]; ABC is defined as 'class ABC(metaclass=ABCMeta): pass' — no explicit base other than the implicit object, giving the minimal 2-entry MRO); ABC.__mro__[0].__name__=='ABC' (len=3: A(1)B(2)C(3); first MRO entry is the class itself); ABC.__mro__[1].__name__=='object' (len=6; object is ABC's only base and the final MRO entry); ABC.__mro__.__len__(2) < ABCMeta.__mro__.__len__(3) by 1 — the convenience class has a shallower MRO than the metaclass; verified with Python 3.14.3"
  kind: python_call_eq
  category: ABC_mro
  id_prefix: abcmro200

  columns: [id, function, args, expected, description]
  rows:
    - ["abc_mro_is_tuple",  "abc.ABC.__mro__.__class__.__name__.__eq__",               ["tuple"],  true, "abc.ABC.__mro__.__class__.__name__ == 'tuple' — __mro__ is always a tuple; verified Python 3.14.3"]
    - ["abc_mro_len",       "abc.ABC.__mro__.__len__",                                  [],         2,    "abc.ABC.__mro__.__len__() == 2 (MRO is [ABC, object]); verified Python 3.14.3"]
    - ["abc_mro0_name_eq",  "abc.ABC.__mro__.__getitem__(0).__name__.__eq__",            ["ABC"],    true, "abc.ABC.__mro__[0].__name__ == 'ABC' (len=3; first MRO entry is the class itself); verified Python 3.14.3"]
    - ["abc_mro1_name_eq",  "abc.ABC.__mro__.__getitem__(1).__name__.__eq__",            ["object"], true, "abc.ABC.__mro__[1].__name__ == 'object' (len=6; object is ABC's only base and the final MRO entry); verified Python 3.14.3"]
    - ["abc_mro0_name_len", "abc.ABC.__mro__.__getitem__(0).__name__.__len__",           [],         3,    "abc.ABC.__mro__[0].__name__.__len__() == 3 ('ABC'=3: A(1)B(2)C(3)); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta MRO first two entries
#
# abc.ABCMeta.__mro__.__len__() == 3
# abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' (len=7)
# abc.ABCMeta.__mro__[1].__name__ == 'type' (len=4)
# ---------------------------------------------------------------------------

table abc_extra200.ABCMeta_mro_first_entries:
  description: "abc.ABCMeta MRO first two entry checks in abcmro200 namespace — ABCMeta.__mro__.__len__()==3 (ABCMeta MRO is [ABCMeta, type, object]; ABCMeta is a metaclass that inherits from type, the built-in metaclass; type in turn inherits from object, giving a 3-entry MRO); ABCMeta.__mro__[0].__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7; first MRO entry is the class itself); ABCMeta.__mro__[1].__name__=='type' (len=4: t(1)y(2)p(3)e(4); ABCMeta's direct base is the built-in type metaclass); ABCMeta.__mro__.__len__(3) > ABC.__mro__.__len__(2) by 1; ABCMeta.__mro__[0].__name__ (7) > ABC.__mro__[0].__name__ (3) by 4; verified with Python 3.14.3"
  kind: python_call_eq
  category: ABCMeta_mro
  id_prefix: abcmro200

  columns: [id, function, args, expected, description]
  rows:
    - ["abcmeta_mro_len",       "abc.ABCMeta.__mro__.__len__",                                  [],           3,    "abc.ABCMeta.__mro__.__len__() == 3 (MRO is [ABCMeta, type, object]); verified Python 3.14.3"]
    - ["abcmeta_mro0_name_eq",  "abc.ABCMeta.__mro__.__getitem__(0).__name__.__eq__",            ["ABCMeta"],  true, "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' (len=7; first MRO entry is the class itself); verified Python 3.14.3"]
    - ["abcmeta_mro1_name_eq",  "abc.ABCMeta.__mro__.__getitem__(1).__name__.__eq__",            ["type"],     true, "abc.ABCMeta.__mro__[1].__name__ == 'type' (len=4; ABCMeta's direct base is the built-in type metaclass); verified Python 3.14.3"]
    - ["abcmeta_mro0_name_len", "abc.ABCMeta.__mro__.__getitem__(0).__name__.__len__",           [],           7,    "abc.ABCMeta.__mro__[0].__name__.__len__() == 7 ('ABCMeta'=7: 'ABC'=3+'Meta'=4=7); verified Python 3.14.3"]
    - ["abcmeta_mro1_name_len", "abc.ABCMeta.__mro__.__getitem__(1).__name__.__len__",           [],           4,    "abc.ABCMeta.__mro__[1].__name__.__len__() == 4 ('type'=4: t(1)y(2)p(3)e(4)); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABCMeta MRO third entry and comparison checks
#
# abc.ABCMeta.__mro__[2].__name__ == 'object' (len=6)
# abc.ABCMeta.__mro__[1].__name__.__len__() == 4  (shorter than 'object'=6)
# abc.ABC.__mro__[1].__name__ == 'object' (same as ABCMeta.__mro__[2])
# ---------------------------------------------------------------------------

table abc_extra200.ABCMeta_mro_object_and_comparisons:
  description: "abc.ABCMeta.__mro__[2] and cross-class MRO comparison checks in abcmro200 namespace — ABCMeta.__mro__[2].__name__=='object' (len=6: o(1)b(2)j(3)e(4)c(5)t(6); object is always the final entry in any Python MRO); ABCMeta.__mro__[2].__name__ (6: 'object') == ABC.__mro__[1].__name__ (6: 'object') — object appears at different indices in the two MROs but is the same class; ABCMeta.__mro__[1].__name__ (4: 'type') < ABCMeta.__mro__[2].__name__ (6: 'object') by 2 — 'type' is shorter than 'object'; ABC.__mro__[1].__name__.__len__()==6; verified with Python 3.14.3"
  kind: python_call_eq
  category: ABCMeta_mro
  id_prefix: abcmro200

  columns: [id, function, args, expected, description]
  rows:
    - ["abcmeta_mro2_name_eq",  "abc.ABCMeta.__mro__.__getitem__(2).__name__.__eq__",  ["object"],  true, "abc.ABCMeta.__mro__[2].__name__ == 'object' (len=6; object is the ultimate base, always last in any MRO); verified Python 3.14.3"]
    - ["abcmeta_mro2_name_len", "abc.ABCMeta.__mro__.__getitem__(2).__name__.__len__", [],           6,   "abc.ABCMeta.__mro__[2].__name__.__len__() == 6 ('object'=6: o(1)b(2)j(3)e(4)c(5)t(6)); verified Python 3.14.3"]
    - ["abc_mro1_name_eq",      "abc.ABC.__mro__.__getitem__(1).__name__.__eq__",       ["object"],  true, "abc.ABC.__mro__[1].__name__ == 'object' (len=6; matches ABCMeta.__mro__[2].__name__ — both MROs end with object); verified Python 3.14.3"]
    - ["abc_mro1_name_len",     "abc.ABC.__mro__.__getitem__(1).__name__.__len__",      [],           6,   "abc.ABC.__mro__[1].__name__.__len__() == 6 ('object'=6; same length as ABCMeta.__mro__[2].__name__); verified Python 3.14.3"]
    - ["abcmeta_mro_len2",      "abc.ABCMeta.__mro__.__len__",                          [],           3,   "abc.ABCMeta.__mro__.__len__() == 3 (confirmed from object entry table; ABCMeta MRO ends at index 2 with object); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra200
# ---------------------------------------------------------------------------

invariant abc_extra200.abc_mro_is_tuple:
  description: "abc.ABC.__mro__.__class__.__name__.__eq__('tuple') == True — __mro__ is always a tuple in Python; ABC.__mro__ is a tuple of 2 class objects [ABC, object]; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABC_mro
  kind: python_call_eq
  function: ABC.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant abc_extra200.abc_mro_len_2:
  description: "abc.ABC.__mro__.__len__() == 2 — MRO is (ABC, object); ABC is defined as 'class ABC(metaclass=ABCMeta): pass' with no explicit base other than the implicit object; ABC.__mro__.__len__(2) < ABCMeta.__mro__.__len__(3) by 1 — the convenience class has a shallower MRO than the metaclass; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABC_mro
  kind: python_call_eq
  function: ABC.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra200.abc_mro0_name_eq:
  description: "abc.ABC.__mro__[0].__name__.__eq__('ABC') returns True — ABC.__mro__[0].__name__=='ABC' (len=3: A(1)B(2)C(3)); the first entry in any Python MRO is always the class itself; ABC.__mro__[0].__name__ (3: 'ABC') < ABCMeta.__mro__[0].__name__ (7: 'ABCMeta') by 4 — the convenience class name is shorter than the metaclass name; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABC_mro
  kind: python_call_eq
  function: "abc.ABC.__mro__.__getitem__(0).__name__.__eq__"
  args: ["ABC"]
  expected: true

invariant abc_extra200.abc_mro1_name_eq:
  description: "abc.ABC.__mro__[1].__name__.__eq__('object') returns True — ABC.__mro__[1].__name__=='object' (len=6); object is ABC's only base and the final entry in its 2-item MRO; ABC.__mro__[1].__name__ (6: 'object') == ABCMeta.__mro__[2].__name__ (6: 'object') — both MROs end with object at different indices; ABC.__mro__[1].__name__ (6) > ABC.__mro__[0].__name__ (3: 'ABC') by 3 — the base class name is longer than the class name; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABC_mro
  kind: python_call_eq
  function: "abc.ABC.__mro__.__getitem__(1).__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra200.abcmeta_mro_len_3:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — MRO is (ABCMeta, type, object); ABCMeta is a metaclass (a subclass of type); type itself inherits from object, giving ABCMeta a 3-step chain; ABCMeta.__mro__.__len__(3) > ABC.__mro__.__len__(2) by 1 — the metaclass has one extra step (type) that the convenience class does not; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABCMeta_mro
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra200.abcmeta_mro0_name_eq:
  description: "abc.ABCMeta.__mro__[0].__name__.__eq__('ABCMeta') returns True — ABCMeta.__mro__[0].__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7); the first entry in any Python MRO is always the class itself; ABCMeta.__mro__[0].__name__ (7: 'ABCMeta') > ABC.__mro__[0].__name__ (3: 'ABC') by 4 — the metaclass name is longer than the convenience class name; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABCMeta_mro
  kind: python_call_eq
  function: "abc.ABCMeta.__mro__.__getitem__(0).__name__.__eq__"
  args: ["ABCMeta"]
  expected: true

invariant abc_extra200.abcmeta_mro1_name_eq:
  description: "abc.ABCMeta.__mro__[1].__name__.__eq__('type') returns True — ABCMeta.__mro__[1].__name__=='type' (len=4: t(1)y(2)p(3)e(4)); the second entry in ABCMeta's MRO is type, the built-in metaclass; ABCMeta is a metaclass because it inherits from type; ABCMeta.__mro__[1].__name__ (4: 'type') < ABCMeta.__mro__[0].__name__ (7: 'ABCMeta') by 3; ABCMeta.__mro__[1].__name__ (4: 'type') < ABCMeta.__mro__[2].__name__ (6: 'object') by 2; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABCMeta_mro
  kind: python_call_eq
  function: "abc.ABCMeta.__mro__.__getitem__(1).__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra200.abcmeta_mro2_name_eq:
  description: "abc.ABCMeta.__mro__[2].__name__.__eq__('object') returns True — ABCMeta.__mro__[2].__name__=='object' (len=6: o(1)b(2)j(3)e(4)c(5)t(6)); object is the last entry in every Python MRO; ABCMeta.__mro__[2].__name__ (6: 'object') == ABC.__mro__[1].__name__ (6: 'object') — both MROs end with object but at different indices; ABCMeta.__mro__[2].__name__ (6) > ABCMeta.__mro__[1].__name__ (4: 'type') by 2; ABCMeta.__mro__[2].__name__ (6) < ABCMeta.__mro__[0].__name__ (7: 'ABCMeta') by 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: ABCMeta_mro
  kind: python_call_eq
  function: "abc.ABCMeta.__mro__.__getitem__(2).__name__.__eq__"
  args: ["object"]
  expected: true
