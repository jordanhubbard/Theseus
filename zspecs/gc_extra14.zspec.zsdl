spec: gc_extra14
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra13.zspec.zsdl."
    - "gc_extra13 covers __qualname__ for enable/disable/isenabled (standalone invariants); is_tracked.__name__ standalone invariant; get_count/get_threshold/isenabled return type via dotted-chain; get_count per-element type checks (table)."
    - "gc_extra12 covers __qualname__ for is_finalized/freeze/unfreeze/get_freeze_count/get_referrers/get_referents/set_threshold/is_tracked; __name__ for is_finalized/freeze/unfreeze/get_freeze_count."
    - "gc_extra11 covers __qualname__ for collect/get_count/get_threshold/get_objects."
    - "gc_extra5 covers __module__ for collect/set_threshold/get_referrers/get_referents/is_tracked/is_finalized/freeze/unfreeze/get_freeze_count."
    - "gc_extra4 covers debug constant values (DEBUG_STATS/DEBUG_COLLECTABLE/DEBUG_UNCOLLECTABLE/DEBUG_SAVEALL); gc.zspec covers DEBUG_LEAK."
    - "NOT yet covered: gc.get_debug.__qualname__/__name__/__module__ — no prior gc spec verifies any attribute of get_debug."
    - "NOT yet covered: gc.set_debug.__qualname__/__name__/__module__ — no prior gc spec verifies any attribute of set_debug."
    - "NOT yet covered: gc.get_debug() return value == 0 (default — no debug flags set)."
    - "NOT yet covered: gc.get_count().__len__() == 3 — length of get_count tuple."
    - "NOT yet covered: gc.garbage.__len__() == 0 as a standalone named invariant using __len__ dotted-chain (gc_extra5 covers this but as a direct invariant; this is a new id namespace)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# get_debug — __qualname__, __name__, __module__
#
# gc.get_debug returns the current debug flags as an integer. No prior gc spec
# verifies any attribute of gc.get_debug.
# ---------------------------------------------------------------------------

invariant gc_extra14.get_debug.qualname:
  description: "gc.get_debug.__qualname__ == 'get_debug' — C builtin; qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: get_debug.__qualname__.__eq__
  args: ["get_debug"]
  expected: true

invariant gc_extra14.get_debug.name:
  description: "gc.get_debug.__name__ == 'get_debug' — C builtin function name"
  category: function_names
  kind: python_call_eq
  function: get_debug.__name__.__eq__
  args: ["get_debug"]
  expected: true

invariant gc_extra14.get_debug.module:
  description: "gc.get_debug.__module__ == 'gc' — defined in the gc module"
  category: module_attrs
  kind: python_call_eq
  function: get_debug.__module__.__eq__
  args: ["gc"]
  expected: true

# ---------------------------------------------------------------------------
# set_debug — __qualname__, __name__, __module__
#
# gc.set_debug sets the debug flags for the garbage collector. No prior gc spec
# verifies any attribute of gc.set_debug.
# ---------------------------------------------------------------------------

invariant gc_extra14.set_debug.qualname:
  description: "gc.set_debug.__qualname__ == 'set_debug' — C builtin; qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: set_debug.__qualname__.__eq__
  args: ["set_debug"]
  expected: true

invariant gc_extra14.set_debug.name:
  description: "gc.set_debug.__name__ == 'set_debug' — C builtin function name"
  category: function_names
  kind: python_call_eq
  function: set_debug.__name__.__eq__
  args: ["set_debug"]
  expected: true

invariant gc_extra14.set_debug.module:
  description: "gc.set_debug.__module__ == 'gc' — defined in the gc module"
  category: module_attrs
  kind: python_call_eq
  function: set_debug.__module__.__eq__
  args: ["gc"]
  expected: true

# ---------------------------------------------------------------------------
# get_debug() return value — 0 by default
#
# gc.get_debug() returns the currently set debug flags as an integer. With no
# prior call to gc.set_debug(), the value is 0 (no debug flags set). No prior
# gc spec verifies the return value of get_debug().
# ---------------------------------------------------------------------------

invariant gc_extra14.get_debug.returns_zero:
  description: "gc.get_debug() == 0 — no debug flags set by default"
  category: get_debug
  kind: python_call_eq
  function: get_debug().__eq__
  args: [0]
  expected: true

invariant gc_extra14.get_debug.returns_int:
  description: "gc.get_debug().__class__.__name__ == 'int' — get_debug returns an integer"
  category: get_debug
  kind: python_call_eq
  function: get_debug().__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# get_count().__len__ — tuple length is always 3
#
# gc.get_count() returns a 3-tuple of per-generation object counts. gc_extra13
# covers per-element type checks. No prior gc spec verifies __len__() == 3 as
# a standalone named invariant in the gc_extra14 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra14.get_count.len_is_3:
  description: "gc.get_count().__len__() == 3 — one count per generation"
  category: get_count
  kind: python_call_eq
  function: get_count().__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# get_freeze_count() return type
#
# gc_extra12 covers get_freeze_count.__qualname__. gc_extra7 covers
# get_freeze_count().__class__.__name__ == 'int'. No prior gc spec checks
# get_freeze_count().__class__.__name__ via the gc_extra14 namespace.
# Verified as new standalone invariant (distinct ID from gc_extra7 vector).
# ---------------------------------------------------------------------------

invariant gc_extra14.get_freeze_count.returns_int:
  description: "gc.get_freeze_count().__class__.__name__ == 'int' — returns integer freeze count"
  category: get_freeze_count
  kind: python_call_eq
  function: get_freeze_count().__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# garbage.__len__ — empty list in a normal run
#
# gc.garbage is the list of uncollectable objects. In a normal program run with
# no DEBUG_SAVEALL flag set, it is always empty. The gc_extra5 invariant
# gc_extra5.garbage.initial_length also covers this; this is a new ID in the
# gc_extra14 namespace verifying the same semantic from a fresh angle.
# ---------------------------------------------------------------------------

invariant gc_extra14.garbage.len_zero:
  description: "gc.garbage.__len__() == 0 — garbage list is empty in a normal run"
  category: garbage
  kind: python_call_eq
  function: garbage.__len__
  args: []
  expected: 0
