spec: theseus_imaplib_cr
version: ">=3.9"
backend: python_cleanroom(theseus_imaplib_cr)
blocks: imaplib

docs: https://docs.python.org/3/library/imaplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/imaplib.html"
    - "RFC 9051 — Internet Message Access Protocol (IMAP4rev2)"
  notes:
    - "Clean-room IMAP4 response parsers. Do NOT import imaplib."
    - "ParsedUID: namedtuple(uid, flags, body)."
    - "Flags: frozenset of IMAP flag strings like \\Seen, \\Deleted."
    - "parse_flags(flags_str): parse '(\\Seen \\Recent)' → frozenset({'\\\\Seen', '\\\\Recent'})."
    - "parse_uid(uid_str): parse 'UID 42' → 42."
    - "imaplib_parse_flags_count(): len(parse_flags('(\\\\Seen \\\\Recent)')) == 2."
    - "imaplib_parse_flags_has_seen(): '\\\\Seen' in parse_flags('(\\\\Seen \\\\Recent)')."
    - "imaplib_parse_uid(): parse_uid('UID 42') == 42."
    - "Export: parse_flags, parse_uid, ParsedUID."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_imaplib_cr.parse_flags_count:
  description: "len(parse_flags('(\\Seen \\Recent)')) == 2"
  category: parse
  kind: python_call_eq
  function: imaplib_parse_flags_count
  args: []
  expected: 2

invariant theseus_imaplib_cr.parse_flags_has_seen:
  description: "'\\Seen' in parse_flags('(\\Seen \\Recent)')"
  category: parse
  kind: python_call_eq
  function: imaplib_parse_flags_has_seen
  args: []
  expected: true

invariant theseus_imaplib_cr.parse_uid:
  description: "parse_uid('UID 42') == 42"
  category: parse
  kind: python_call_eq
  function: imaplib_parse_uid
  args: []
  expected: 42
