spec: inspect_extra138
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter._ParameterKind — class identity, MRO, member count; and all five Parameter kind constants — __class__.__name__, integer values, .name attribute lengths (Wave 266)."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' (len 14) — all five kinds share this class. Verified with Python 3.14.3."
    - "_ParameterKind is an IntEnum subclass; its metaclass is EnumType. Verified with Python 3.14.3."
    - "len(_ParameterKind.__mro__) == 6 — MRO: _ParameterKind, IntEnum, int, ReprEnum, Enum, object. Verified with Python 3.14.3."
    - "_ParameterKind.__module__ == 'inspect' (len 7). Verified with Python 3.14.3."
    - "len(_ParameterKind.__members__) == 5 — five members: POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD. Verified with Python 3.14.3."
    - "POSITIONAL_ONLY integer value == 0, POSITIONAL_OR_KEYWORD == 1, VAR_POSITIONAL == 2, KEYWORD_ONLY == 3, VAR_KEYWORD == 4. Verified with Python 3.14.3."
    - "POSITIONAL_ONLY.name == 'POSITIONAL_ONLY' (len 15). Verified with Python 3.14.3."
    - "POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD' (len 21). Verified with Python 3.14.3."
    - "VAR_POSITIONAL.name == 'VAR_POSITIONAL' (len 14). Verified with Python 3.14.3."
    - "KEYWORD_ONLY.name == 'KEYWORD_ONLY' (len 12). Verified with Python 3.14.3."
    - "VAR_KEYWORD.name == 'VAR_KEYWORD' (len 11). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect._ParameterKind class identity
#
# Wave 266 theme: inspect._ParameterKind — IntEnum metaclass, MRO, module.
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' (len 14)
# inspect.Parameter.POSITIONAL_ONLY.__class__.__class__.__name__ == 'EnumType'
# len(inspect.Parameter.POSITIONAL_ONLY.__class__.__mro__) == 6
# inspect.Parameter.POSITIONAL_ONLY.__class__.__module__ == 'inspect'
# inspect.Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__ == 'IntEnum'
#
# _ParameterKind is an IntEnum defined in Lib/inspect.py. New to extra138.
# ---------------------------------------------------------------------------

table inspect_extra138.parameter_kind_class_identity:
  description: "inspect._ParameterKind: IntEnum subclass, __name__ len 14, MRO len 6, __module__ len 7; wave 266; new to extra138"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectpkind138

  columns: [id, function, args, expected, description]
  rows:
    - [pk_class_name_eq,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is an instance of _ParameterKind, the IntEnum that governs parameter kinds; __class__.__name__ is '_ParameterKind'; str.__eq__ returns True; new to extra138"]
    - [pk_class_name_len_eq_14,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__len__",
       [],
       14,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__len__() == 14 — __class__.__name__ is '_ParameterKind' which has 14 characters; len('_ParameterKind') == 14; new to extra138"]
    - [pk_metaclass_eq_enumtype,
       "Parameter.POSITIONAL_ONLY.__class__.__class__.__name__.__eq__",
       ["EnumType"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__class__.__name__.__eq__('EnumType') == True — _ParameterKind's metaclass is EnumType (the enum module's metaclass); __class__.__class__.__name__ is 'EnumType'; str.__eq__ returns True; new to extra138"]
    - [pk_mro_len_eq_6,
       "Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__",
       [],
       6,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__() == 6 — _ParameterKind MRO is [_ParameterKind, IntEnum, int, ReprEnum, Enum, object]; len(__mro__) is 6; new to extra138"]
    - [pk_module_eq_inspect,
       "Parameter.POSITIONAL_ONLY.__class__.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__module__.__eq__('inspect') == True — _ParameterKind is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra138"]
    - [pk_module_len_eq_7,
       "Parameter.POSITIONAL_ONLY.__class__.__module__.__len__",
       [],
       7,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__module__.__len__() == 7 — __module__ is 'inspect' which has 7 characters; len('inspect') == 7; new to extra138"]
    - [pk_bases_0_eq_intenum,
       "Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__.__eq__",
       ["IntEnum"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__.__eq__('IntEnum') == True — _ParameterKind directly inherits from IntEnum; __bases__[0].__name__ is 'IntEnum'; str.__eq__('IntEnum') returns True; new to extra138"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter kind constants — __class__.__name__ for all five
#
# Wave 266 theme: all five Parameter kind constants share the same class.
#
# All five kinds yield __class__.__name__ == '_ParameterKind'.
# The integer values are: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1,
# VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4.
#
# New to extra138.
# ---------------------------------------------------------------------------

table inspect_extra138.all_parameter_kinds_class:
  description: "All five inspect.Parameter kinds: __class__.__name__=='_ParameterKind' and integer values 0-4; wave 266; new to extra138"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectpkindall138

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_class_eq,
       "Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is an instance of _ParameterKind; str.__eq__('_ParameterKind') returns True; new to extra138"]
    - [positional_or_keyword_class_eq,
       "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD is an instance of _ParameterKind; str.__eq__('_ParameterKind') returns True; new to extra138"]
    - [var_positional_class_eq,
       "Parameter.VAR_POSITIONAL.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — VAR_POSITIONAL is an instance of _ParameterKind; str.__eq__('_ParameterKind') returns True; new to extra138"]
    - [keyword_only_class_eq,
       "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY is an instance of _ParameterKind; str.__eq__('_ParameterKind') returns True; new to extra138"]
    - [var_keyword_class_eq,
       "Parameter.VAR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD is an instance of _ParameterKind; str.__eq__('_ParameterKind') returns True; new to extra138"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter kind constants — .name attribute lengths
#
# Wave 266 theme: Parameter kind .name attribute string lengths.
#
# POSITIONAL_ONLY.name == 'POSITIONAL_ONLY' (len 15)
# POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD' (len 21)
# VAR_POSITIONAL.name == 'VAR_POSITIONAL' (len 14)
# KEYWORD_ONLY.name == 'KEYWORD_ONLY' (len 12)
# VAR_KEYWORD.name == 'VAR_KEYWORD' (len 11)
#
# The .name attribute on each IntEnum member returns the member's string name.
# New to extra138.
# ---------------------------------------------------------------------------

table inspect_extra138.parameter_kind_name_lengths:
  description: "inspect.Parameter kind .name attribute string lengths: 15,21,14,12,11; wave 266; new to extra138"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectpkindnames138

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_name_eq,
       "Parameter.POSITIONAL_ONLY.name.__eq__",
       ["POSITIONAL_ONLY"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True — the .name attribute of the IntEnum member returns its string name 'POSITIONAL_ONLY'; str.__eq__('POSITIONAL_ONLY') returns True; new to extra138"]
    - [positional_only_name_len_eq_15,
       "Parameter.POSITIONAL_ONLY.name.__len__",
       [],
       15,
       "inspect.Parameter.POSITIONAL_ONLY.name.__len__() == 15 — .name is 'POSITIONAL_ONLY' which has 15 characters; len('POSITIONAL_ONLY') == 15; new to extra138"]
    - [positional_or_keyword_name_eq,
       "Parameter.POSITIONAL_OR_KEYWORD.name.__eq__",
       ["POSITIONAL_OR_KEYWORD"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True — .name is 'POSITIONAL_OR_KEYWORD'; str.__eq__('POSITIONAL_OR_KEYWORD') returns True; new to extra138"]
    - [positional_or_keyword_name_len_eq_21,
       "Parameter.POSITIONAL_OR_KEYWORD.name.__len__",
       [],
       21,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__len__() == 21 — .name is 'POSITIONAL_OR_KEYWORD' which has 21 characters; len('POSITIONAL_OR_KEYWORD') == 21; new to extra138"]
    - [var_positional_name_eq,
       "Parameter.VAR_POSITIONAL.name.__eq__",
       ["VAR_POSITIONAL"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True — .name is 'VAR_POSITIONAL'; str.__eq__('VAR_POSITIONAL') returns True; new to extra138"]
    - [var_positional_name_len_eq_14,
       "Parameter.VAR_POSITIONAL.name.__len__",
       [],
       14,
       "inspect.Parameter.VAR_POSITIONAL.name.__len__() == 14 — .name is 'VAR_POSITIONAL' which has 14 characters; len('VAR_POSITIONAL') == 14; new to extra138"]
    - [keyword_only_name_eq,
       "Parameter.KEYWORD_ONLY.name.__eq__",
       ["KEYWORD_ONLY"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True — .name is 'KEYWORD_ONLY'; str.__eq__('KEYWORD_ONLY') returns True; new to extra138"]
    - [keyword_only_name_len_eq_12,
       "Parameter.KEYWORD_ONLY.name.__len__",
       [],
       12,
       "inspect.Parameter.KEYWORD_ONLY.name.__len__() == 12 — .name is 'KEYWORD_ONLY' which has 12 characters; len('KEYWORD_ONLY') == 12; new to extra138"]
    - [var_keyword_name_eq,
       "Parameter.VAR_KEYWORD.name.__eq__",
       ["VAR_KEYWORD"],
       true,
       "inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True — .name is 'VAR_KEYWORD'; str.__eq__('VAR_KEYWORD') returns True; new to extra138"]
    - [var_keyword_name_len_eq_11,
       "Parameter.VAR_KEYWORD.name.__len__",
       [],
       11,
       "inspect.Parameter.VAR_KEYWORD.name.__len__() == 11 — .name is 'VAR_KEYWORD' which has 11 characters; len('VAR_KEYWORD') == 11; new to extra138"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra138
# ---------------------------------------------------------------------------

invariant inspect_extra138.parameter_kind_class_name_len:
  description: "len(inspect.Parameter.POSITIONAL_ONLY.__class__.__name__) == 14 — __class__.__name__ is '_ParameterKind'; wave 266; new to extra138"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__len__
  args: []
  expected: 14

invariant inspect_extra138.parameter_kind_mro_len:
  description: "len(inspect.Parameter.POSITIONAL_ONLY.__class__.__mro__) == 6 — MRO: _ParameterKind, IntEnum, int, ReprEnum, Enum, object; wave 266; new to extra138"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__
  args: []
  expected: 6

invariant inspect_extra138.var_keyword_int_value:
  description: "int(inspect.Parameter.VAR_KEYWORD) == 4 — the five kinds are numbered 0-4; VAR_KEYWORD is last; wave 266; new to extra138"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__eq__
  args: [4]
  expected: true

invariant inspect_extra138.positional_only_int_value:
  description: "int(inspect.Parameter.POSITIONAL_ONLY) == 0 — POSITIONAL_ONLY has integer value 0; wave 266; new to extra138"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__eq__
  args: [0]
  expected: true

invariant inspect_extra138.positional_or_keyword_name_len:
  description: "len(inspect.Parameter.POSITIONAL_OR_KEYWORD.name) == 21 — longest kind name; wave 266; new to extra138"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.name.__len__
  args: []
  expected: 21
