spec: decimal_extra287
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module identity and DefaultContext attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c, Lib/_pydecimal.py"
  notes:
    - "decimal uses _decimal C extension but is imported via the Python wrapper Lib/decimal.py"
    - "decimal.__loader__.__class__.__name__ is 'SourceFileLoader' for the Python wrapper"
    - "decimal.DefaultContext.prec defaults to 28"
    - "decimal.DefaultContext.rounding defaults to 'ROUND_HALF_EVEN'"
    - "decimal.DefaultContext.Emax defaults to 999999999"
    - "decimal.DefaultContext.Emin defaults to -999999999"
    - "decimal.DefaultContext.capitals defaults to 1"
    - "decimal.DefaultContext.clamp defaults to 0"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table decimal_extra287.module_identity:
  description: "decimal module identity attributes"
  kind: python_call_eq
  category: identity
  id_prefix: dec287a

  columns: [id, function, args, expected, description]
  rows:
    - [dec287a001, decimal.__name__.__eq__, ["decimal"], true, "decimal module __name__ is 'decimal'"]
    - [dec287a002, decimal.__package__.__eq__, [""], true, "decimal module __package__ is empty string"]
    - [dec287a003, decimal.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "decimal.__spec__ is a ModuleSpec"]
    - [dec287a004, decimal.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "decimal.__loader__ is a SourceFileLoader"]

table decimal_extra287.default_context_values:
  description: "decimal.DefaultContext default attribute values"
  kind: python_call_eq
  category: identity
  id_prefix: dec287b

  columns: [id, function, args, expected, description]
  rows:
    - [dec287b001, decimal.DefaultContext.prec.__eq__, [28], true, "DefaultContext.prec == 28"]
    - [dec287b002, decimal.DefaultContext.rounding.__eq__, ["ROUND_HALF_EVEN"], true, "DefaultContext.rounding == 'ROUND_HALF_EVEN'"]
    - [dec287b003, decimal.DefaultContext.Emax.__eq__, [999999999], true, "DefaultContext.Emax == 999999999"]
    - [dec287b004, decimal.DefaultContext.Emin.__eq__, [-999999999], true, "DefaultContext.Emin == -999999999"]
    - [dec287b005, decimal.DefaultContext.capitals.__eq__, [1], true, "DefaultContext.capitals == 1"]
    - [dec287b006, decimal.DefaultContext.clamp.__eq__, [0], true, "DefaultContext.clamp == 0"]

invariant decimal_extra287.default_prec:
  description: "decimal.DefaultContext.prec is 28 by default"
  category: identity
  kind: python_call_eq
  function: decimal.DefaultContext.prec.__eq__
  args: [28]
  expected: true

invariant decimal_extra287.default_rounding:
  description: "decimal.DefaultContext.rounding is ROUND_HALF_EVEN by default"
  category: identity
  kind: python_call_eq
  function: decimal.DefaultContext.rounding.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true
