spec: decimal_extra186
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "decimal.__name__ == 'decimal' (len=7); confirmed Python 3.14.3 macOS."
    - "decimal.__package__ == '' (empty string, len=0); the decimal package attribute is empty; confirmed Python 3.14.3 macOS."
    - "decimal.getcontext.__name__ == 'getcontext' (len=10); confirmed Python 3.14.3 macOS."
    - "decimal.getcontext.__module__ == '_decimal' (not 'decimal'); function lives in C extension _decimal; confirmed Python 3.14.3 macOS."
    - "decimal.setcontext.__name__ == 'setcontext' (len=10); ties with getcontext; confirmed Python 3.14.3 macOS."
    - "decimal.localcontext.__name__ == 'localcontext' (len=12); longest of the three; confirmed Python 3.14.3 macOS."
    - "decimal.localcontext.__module__ == '_decimal'; function lives in C extension _decimal; confirmed Python 3.14.3 macOS."
    - "Length ordering: getcontext(10)==setcontext(10) < localcontext(12); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal module __name__ and __package__ identity
# __name__('decimal',7), __package__(empty,0)
# ---------------------------------------------------------------------------

table decimal_extra186.decimal_module_identity:
  description: "decimal module __name__ and __package__: __name__='decimal'(7), __package__=''(0)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmodule186

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,   decimal.__name__.__eq__,         ["decimal"], true, "decimal.__name__ == 'decimal'; confirmed Python 3.14.3 macOS"]
    - [mod_name_len,  decimal.__name__.__len__,         [],          7,    "decimal.__name__.__len__() == 7 — d(1)e(2)c(3)i(4)m(5)a(6)l(7); confirmed Python 3.14.3 macOS"]
    - [pkg_eq,        decimal.__package__.__eq__,       [""],        true, "decimal.__package__ == '' (empty string); top-level module, not a package; confirmed Python 3.14.3 macOS"]
    - [pkg_len,       decimal.__package__.__len__,      [],          0,    "decimal.__package__.__len__() == 0; package attribute is empty string; confirmed Python 3.14.3 macOS"]
    - [mod_name_eq2,  decimal.__name__.__eq__,          ["decimal"], true, "decimal.__name__ == 'decimal'; cross-check identity; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal module top-level function __name__ equality and lengths
# getcontext(10), setcontext(10), localcontext(12)
# ---------------------------------------------------------------------------

table decimal_extra186.decimal_func_names:
  description: "decimal module function __name__ values: getcontext='getcontext'(10), setcontext='setcontext'(10), localcontext='localcontext'(12)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmodule186

  columns: [id, function, args, expected, description]
  rows:
    - [getctx_name_eq,   decimal.getcontext.__name__.__eq__,   ["getcontext"],   true, "decimal.getcontext.__name__ == 'getcontext'; confirmed Python 3.14.3 macOS"]
    - [setctx_name_eq,   decimal.setcontext.__name__.__eq__,   ["setcontext"],   true, "decimal.setcontext.__name__ == 'setcontext'; confirmed Python 3.14.3 macOS"]
    - [locctx_name_eq,   decimal.localcontext.__name__.__eq__, ["localcontext"], true, "decimal.localcontext.__name__ == 'localcontext'; confirmed Python 3.14.3 macOS"]
    - [getctx_name_len,  decimal.getcontext.__name__.__len__,  [],               10,   "decimal.getcontext.__name__.__len__() == 10 — g(1)e(2)t(3)c(4)o(5)n(6)t(7)e(8)x(9)t(10); confirmed Python 3.14.3 macOS"]
    - [locctx_name_len,  decimal.localcontext.__name__.__len__,[],               12,   "decimal.localcontext.__name__.__len__() == 12; longest of the three; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal module function __module__ identity
# getcontext.__module__('_decimal'), localcontext.__module__('_decimal')
# ---------------------------------------------------------------------------

table decimal_extra186.decimal_func_modules:
  description: "decimal module function __module__ values: getcontext.__module__='_decimal', localcontext.__module__='_decimal' (C extension)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmodule186

  columns: [id, function, args, expected, description]
  rows:
    - [getctx_mod_eq,   decimal.getcontext.__module__.__eq__,   ["_decimal"], true, "decimal.getcontext.__module__ == '_decimal'; function is from C extension; confirmed Python 3.14.3 macOS"]
    - [locctx_mod_eq,   decimal.localcontext.__module__.__eq__, ["_decimal"], true, "decimal.localcontext.__module__ == '_decimal'; function is from C extension; confirmed Python 3.14.3 macOS"]
    - [setctx_name_len, decimal.setcontext.__name__.__len__,    [],           10,   "decimal.setcontext.__name__.__len__() == 10; ties with getcontext(10); confirmed Python 3.14.3 macOS"]
    - [getctx_len_eq_setctx, decimal.getcontext.__name__.__len__,[], 10,           "decimal.getcontext.__name__.__len__() == decimal.setcontext.__name__.__len__() == 10; confirmed Python 3.14.3 macOS"]
    - [locctx_gt_getctx,decimal.localcontext.__name__.__len__, [], 12,             "decimal.localcontext.__name__.__len__() == 12 > getcontext(10); localcontext is longest; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra186.mod_name_eq:
  description: "decimal.__name__ == 'decimal' — module name length 7; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.__name__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra186.mod_package_eq:
  description: "decimal.__package__ == '' — top-level module, package attribute is empty string (len=0); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.__package__.__eq__
  args: [""]
  expected: true

invariant decimal_extra186.getcontext_name_eq:
  description: "decimal.getcontext.__name__ == 'getcontext' — function name length 10; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.getcontext.__name__.__eq__
  args: ["getcontext"]
  expected: true

invariant decimal_extra186.getcontext_module_eq:
  description: "decimal.getcontext.__module__ == '_decimal' — function lives in C extension _decimal, not pure-Python decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.getcontext.__module__.__eq__
  args: ["_decimal"]
  expected: true

invariant decimal_extra186.setcontext_name_eq:
  description: "decimal.setcontext.__name__ == 'setcontext' — function name length 10, ties with getcontext; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.setcontext.__name__.__eq__
  args: ["setcontext"]
  expected: true

invariant decimal_extra186.localcontext_name_eq:
  description: "decimal.localcontext.__name__ == 'localcontext' — function name length 12, longest of the three; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.localcontext.__name__.__eq__
  args: ["localcontext"]
  expected: true

invariant decimal_extra186.localcontext_module_eq:
  description: "decimal.localcontext.__module__ == '_decimal' — function lives in C extension _decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.localcontext.__module__.__eq__
  args: ["_decimal"]
  expected: true

invariant decimal_extra186.localcontext_name_len:
  description: "decimal.localcontext.__name__.__len__() == 12 — localcontext(12) > getcontext(10)==setcontext(10); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.localcontext.__name__.__len__
  args: []
  expected: 12

