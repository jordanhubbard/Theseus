spec: cf3151
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 657 (cf3151): __setitem__, __delitem__, __contains__ dict-presence for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor, concurrent.futures.Executor."
    - "Key finding (__setitem__): all 4 concurrent.futures classes return false for __setitem__. No class defines mutable-mapping item assignment in its own __dict__. concurrent.futures.Future is a result container — results are set internally by the executor framework via private methods (set_result(), set_exception()), not via [] assignment. Executors manage worker pools through submit()/map() — no key-based mutation is part of the API."
    - "Key finding (__delitem__): all 4 concurrent.futures classes return false for __delitem__. Futures are not keyed containers; there is no item to delete. Executors are lifecycle-managed via shutdown() — not via del obj[key]."
    - "Key finding (__contains__): all 4 concurrent.futures classes return false for __contains__. No membership test is defined. concurrent.futures.Future wraps a single computation result — the concept of `x in future` is undefined. Executors manage an internal work queue but expose no membership test for submitted callables or futures."
    - "This is the fifth consecutive all-false wave for all 4 concurrent.futures subjects. Every dunder method tested since wave 652 has returned false for all subjects, with the sole exception of Future.__repr__ in wave 655. The concurrent.futures API surface is deliberately minimal: submit, map, shutdown."
    - "concurrent.futures.Executor is an abstract base class. Its concrete subclasses ThreadPoolExecutor and ProcessPoolExecutor add only concurrency-specific methods; none introduce container or mapping protocols."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __setitem__ dict-presence — operator.contains(Cls.__dict__, '__setitem__')
#
# All 4 concurrent.futures classes return false for __setitem__.
# concurrent.futures.Future: result is set by the executor framework via
#   internal calls (set_result, set_exception), never via [] assignment.
# ThreadPoolExecutor/ProcessPoolExecutor: pool managers dispatching callables,
#   not mutable mappings.
# Executor: abstract base — no container protocol defined.
# ---------------------------------------------------------------------------

table cf3151.setitem:
  description: "concurrent.futures types __setitem__ dict-presence checks; wave 657"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3151

  columns: [id, function, args, expected]
  rows:
    - ["cf3151001", operator.contains, [concurrent.futures.Future.__dict__,              "__setitem__"], false]
    - ["cf3151002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__setitem__"], false]
    - ["cf3151003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__setitem__"], false]
    - ["cf3151004", operator.contains, [concurrent.futures.Executor.__dict__,            "__setitem__"], false]

# ---------------------------------------------------------------------------
# __delitem__ dict-presence — operator.contains(Cls.__dict__, '__delitem__')
#
# All 4 concurrent.futures classes return false for __delitem__.
# Futures hold a single pending result — there is no keyed item to delete.
# Executors are shut down via shutdown(), not via del obj[key].
# The concurrent.futures API is purposefully small; no deletion protocol exists.
# ---------------------------------------------------------------------------

table cf3151.delitem:
  description: "concurrent.futures types __delitem__ dict-presence checks; wave 657"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3151

  columns: [id, function, args, expected]
  rows:
    - ["cf3151005", operator.contains, [concurrent.futures.Future.__dict__,              "__delitem__"], false]
    - ["cf3151006", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__delitem__"], false]
    - ["cf3151007", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__delitem__"], false]
    - ["cf3151008", operator.contains, [concurrent.futures.Executor.__dict__,            "__delitem__"], false]

# ---------------------------------------------------------------------------
# __contains__ dict-presence — operator.contains(Cls.__dict__, '__contains__')
#
# All 4 concurrent.futures classes return false for __contains__.
# concurrent.futures.Future: `x in future` is semantically undefined —
#   a Future holds at most one result (or exception), not a collection.
# ThreadPoolExecutor/ProcessPoolExecutor: maintain an internal work queue
#   but expose no membership test via `in`.
# Executor: abstract — no membership protocol.
# ---------------------------------------------------------------------------

table cf3151.contains:
  description: "concurrent.futures types __contains__ dict-presence checks; wave 657"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3151

  columns: [id, function, args, expected]
  rows:
    - ["cf3151009",  operator.contains, [concurrent.futures.Future.__dict__,              "__contains__"], false]
    - ["cf3151010", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__contains__"], false]
    - ["cf3151011", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__contains__"], false]
    - ["cf3151012", operator.contains, [concurrent.futures.Executor.__dict__,            "__contains__"], false]

# ---------------------------------------------------------------------------
# combined — __setitem__, __delitem__, __contains__ across all 4 cf subjects
#
# Covers the full matrix: 4 classes x 3 methods = 12 rows.
# __setitem__:  false for all 4.
# __delitem__:  false for all 4.
# __contains__: false for all 4.
# All 12 values are false.
# concurrent.futures maintains its streak: every tested dunder wave since 652
# has been all-false (exception: Future.__repr__ true in wave 655).
# The design of concurrent.futures is deliberately narrow: submit work, get
# results, shut down. No container, mapping, or membership protocol is offered.
# Cross-wave summary for cf subjects:
#   Wave 652 (cf3076): __get__/__set__/__delete__ — all false for all 4.
#   Wave 653 (cf3091): __hash__/__eq__/__bool__ — all false for all 4.
#   Wave 654 (cf3106): __lt__/__le__/__gt__ — all false for all 4.
#   Wave 655 (cf3121): __ge__ false; __repr__ true only for Future; __str__ false.
#   Wave 656 (cf3136): __call__/__len__/__getitem__ — all false for all 4.
#   Wave 657 (cf3151): __setitem__/__delitem__/__contains__ — all false for all 4.
# ---------------------------------------------------------------------------

