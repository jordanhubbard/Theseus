spec: decimal_extra218
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification, Version 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers: decimal class and function __qualname__ contracts for Decimal, Context, DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, getcontext, setcontext, localcontext."
    - "decimal.Decimal.__qualname__ == 'Decimal'; verified with Python 3.14.3."
    - "decimal.Context.__qualname__ == 'Context'; verified with Python 3.14.3."
    - "decimal.DecimalException.__qualname__ == 'DecimalException'; verified with Python 3.14.3."
    - "decimal.InvalidOperation.__qualname__ == 'InvalidOperation'; verified with Python 3.14.3."
    - "decimal.DivisionByZero.__qualname__ == 'DivisionByZero'; verified with Python 3.14.3."
    - "decimal.Overflow.__qualname__ == 'Overflow'; verified with Python 3.14.3."
    - "decimal.Underflow.__qualname__ == 'Underflow'; verified with Python 3.14.3."
    - "decimal.Inexact.__qualname__ == 'Inexact'; verified with Python 3.14.3."
    - "decimal.Rounded.__qualname__ == 'Rounded'; verified with Python 3.14.3."
    - "decimal.Subnormal.__qualname__ == 'Subnormal'; verified with Python 3.14.3."
    - "decimal.getcontext.__qualname__ == 'getcontext'; verified with Python 3.14.3."
    - "decimal.setcontext.__qualname__ == 'setcontext'; verified with Python 3.14.3."
    - "decimal.localcontext.__qualname__ == 'localcontext'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal class __qualname__ values
# All public decimal classes; __qualname__ == __name__ for top-level classes.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra218.class_qualnames:
  description: "decimal class __qualname__ contracts for Decimal, Context, DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: decclsqualname218

  columns: [id, function, args, expected]
  rows:
    - [decimal_qualname,      Decimal.__qualname__.__eq__,          ["Decimal"],          true]
    - [context_qualname,      Context.__qualname__.__eq__,          ["Context"],          true]
    - [decexc_qualname,       DecimalException.__qualname__.__eq__, ["DecimalException"], true]
    - [invalidop_qualname,    InvalidOperation.__qualname__.__eq__, ["InvalidOperation"], true]
    - [divbyzero_qualname,    DivisionByZero.__qualname__.__eq__,   ["DivisionByZero"],   true]
    - [overflow_qualname,     Overflow.__qualname__.__eq__,         ["Overflow"],         true]
    - [underflow_qualname,    Underflow.__qualname__.__eq__,        ["Underflow"],        true]
    - [inexact_qualname,      Inexact.__qualname__.__eq__,          ["Inexact"],          true]
    - [rounded_qualname,      Rounded.__qualname__.__eq__,          ["Rounded"],          true]
    - [subnormal_qualname,    Subnormal.__qualname__.__eq__,        ["Subnormal"],        true]

# ---------------------------------------------------------------------------
# decimal function __qualname__ values
# Top-level module functions: qualname equals simple function name.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra218.function_qualnames:
  description: "decimal function __qualname__ contracts for getcontext, setcontext, localcontext; verified with Python 3.14.3"
  kind: python_call_eq
  category: function_metadata
  id_prefix: decfnqualname218

  columns: [id, function, args, expected]
  rows:
    - [getcontext_qualname,  getcontext.__qualname__.__eq__,  ["getcontext"],  true]
    - [setcontext_qualname,  setcontext.__qualname__.__eq__,  ["setcontext"],  true]
    - [localcontext_qualname, localcontext.__qualname__.__eq__, ["localcontext"], true]

# ---------------------------------------------------------------------------
# Standalone invariants for key __qualname__ values
# ---------------------------------------------------------------------------

invariant decimal_extra218.Decimal.qualname:
  description: "decimal.Decimal.__qualname__ == 'Decimal' — top-level class; qualname equals simple name; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: Decimal.__qualname__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra218.DecimalException.qualname:
  description: "decimal.DecimalException.__qualname__ == 'DecimalException' — top-level class; qualname equals simple name; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: DecimalException.__qualname__.__eq__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra218.InvalidOperation.qualname:
  description: "decimal.InvalidOperation.__qualname__ == 'InvalidOperation' — top-level class; qualname equals simple name; verified with Python 3.14.3"
