spec: got
version: ">=15.0.0"
backend: node(got)

docs: https://github.com/sindresorhus/got#readme

provenance:
  derived_from:
    - "Got README — https://github.com/sindresorhus/got#readme"
    - "Test vectors verified with got via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "got source"
  notes:
    - "Human-friendly HTTP request library — auto-retries, pagination, JSON decoding."
    - "Install: npm install got"
    - "v15 ESM only; default export got() / named exports HTTPError / RequestError / etc."
    - "Spec covers shape — actual HTTP requires network."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "RequestError is the base class; HTTPError fires on 4xx/5xx by default."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes:
    HTTPError: "Non-2xx response"
    TimeoutError: "Request timed out"
    CancelError: "Request was cancelled via AbortController"

invariant got.default_export_is_function:
  description: "default export got() is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant got.has_extend:
  description: "got.extend exists for creating instances with custom defaults"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.extend.constructor.name"}
  expected: "Function"

invariant got.has_post:
  description: "got.post is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.post.constructor.name"}
  expected: "Function"

invariant got.has_get:
  description: "got.get is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.get.constructor.name"}
  expected: "Function"

invariant got.has_put:
  description: "got.put is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.put.constructor.name"}
  expected: "Function"

invariant got.has_HTTPError_class:
  description: "HTTPError is exported as a class"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "HTTPError.constructor.name"}
  expected: "Function"

invariant got.has_RequestError_class:
  description: "RequestError is the base error class"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "RequestError.constructor.name"}
  expected: "Function"

invariant got.has_TimeoutError:
  description: "TimeoutError exported"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "TimeoutError.constructor.name"}
  expected: "Function"
