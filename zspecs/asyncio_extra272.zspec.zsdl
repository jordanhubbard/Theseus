spec: asyncio_extra272
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "asyncio.__name__ == 'asyncio' and asyncio.__package__ == 'asyncio' (top-level package, __package__ equals __name__)."
    - "asyncio.__spec__.name == 'asyncio' and asyncio.__spec__.parent == 'asyncio'."
    - "asyncio.__spec__.__class__.__name__ == 'ModuleSpec' (importlib.machinery.ModuleSpec)."
    - "asyncio.__loader__.__class__.__name__ == 'SourceFileLoader' (file-system package)."
    - "asyncio.events.__name__ == 'asyncio.events' and asyncio.events.__package__ == 'asyncio'."
    - "asyncio.queues.__name__ == 'asyncio.queues' and asyncio.locks.__name__ == 'asyncio.locks'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio module __spec__ and __package__ identity — table
#
# Module-level attributes: __name__, __package__, __spec__.name,
# __spec__.parent, __spec__.__class__.__name__, __loader__.__class__.__name__.
# ---------------------------------------------------------------------------

table asyncio_extra272.asyncio_module_spec_identity:
  description: "asyncio module __spec__ and __package__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: aiospec

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       asyncio.__name__.__eq__,                        ["asyncio"],         true, "asyncio.__name__ == 'asyncio'"]
    - [pkg_eq,        asyncio.__package__.__eq__,                     ["asyncio"],         true, "asyncio.__package__ == 'asyncio'"]
    - [spec_name_eq,  asyncio.__spec__.name.__eq__,                   ["asyncio"],         true, "asyncio.__spec__.name == 'asyncio'"]
    - [spec_cls_eq,   asyncio.__spec__.__class__.__name__.__eq__,     ["ModuleSpec"],      true, "asyncio.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [loader_cls_eq, asyncio.__loader__.__class__.__name__.__eq__,   ["SourceFileLoader"], true, "asyncio.__loader__.__class__.__name__ == 'SourceFileLoader'"]

# ---------------------------------------------------------------------------
# asyncio submodule __name__ and __package__ — table
#
# asyncio.events, asyncio.queues, and asyncio.locks submodule identity.
# All submodules have __package__ == 'asyncio'.
# ---------------------------------------------------------------------------

table asyncio_extra272.asyncio_submodule_identity:
  description: "asyncio submodule __name__ and __package__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: aiosub

  columns: [id, function, args, expected, description]
  rows:
    - [ev_name,   asyncio.events.__name__.__eq__,    ["asyncio.events"],  true, "asyncio.events.__name__ == 'asyncio.events'"]
    - [ev_pkg,    asyncio.events.__package__.__eq__, ["asyncio"],         true, "asyncio.events.__package__ == 'asyncio'"]
    - [qu_name,   asyncio.queues.__name__.__eq__,    ["asyncio.queues"],  true, "asyncio.queues.__name__ == 'asyncio.queues'"]
    - [lk_name,   asyncio.locks.__name__.__eq__,     ["asyncio.locks"],   true, "asyncio.locks.__name__ == 'asyncio.locks'"]
    - [lk_pkg,    asyncio.locks.__package__.__eq__,  ["asyncio"],         true, "asyncio.locks.__package__ == 'asyncio'"]

# ---------------------------------------------------------------------------
# asyncio.__spec__.parent — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra272.asyncio_spec_parent:
  description: "asyncio.__spec__.parent == 'asyncio'"
  category: identity
  kind: python_call_eq
  function: asyncio.__spec__.parent.__eq__
  args: ["asyncio"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.events.__spec__.name — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra272.asyncio_events_spec_name:
  description: "asyncio.events.__spec__.name == 'asyncio.events'"
  category: identity
  kind: python_call_eq
  function: asyncio.events.__spec__.name.__eq__
  args: ["asyncio.events"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.queues.__spec__.name — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra272.asyncio_queues_spec_name:
  description: "asyncio.queues.__spec__.name == 'asyncio.queues'"
  category: identity
  kind: python_call_eq
  function: asyncio.queues.__spec__.name.__eq__
  args: ["asyncio.queues"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.queues.__package__ — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra272.asyncio_queues_package:
  description: "asyncio.queues.__package__ == 'asyncio'"
  category: identity
  kind: python_call_eq
  function: asyncio.queues.__package__.__eq__
  args: ["asyncio"]
  expected: true
