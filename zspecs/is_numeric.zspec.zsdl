  category: predicate
  id_prefix: isnumeric

  columns: [id, args, expected]
  rows:
    - [integer,     [42],     true]
    - [float,       [3.14],   true]
    - [str_int,     ["42"],   true]
    - [string,      ["hi"],   false]
    - [null_v,      [null],   false]

