spec: itertools_extra258
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.starmap, itertools.filterfalse, itertools.compress class identity — name, module, bases; itertools.accumulate class identity and __new__.__qualname__."
    - "itertools.starmap.__name__ == 'starmap' — C-level type name. Verified with Python 3.14.4."
    - "itertools.starmap.__module__ == 'itertools' — defined in itertools. Verified with Python 3.14.4."
    - "itertools.starmap.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.4."
    - "itertools.starmap.__new__.__qualname__ == 'starmap.__new__' — C-level constructor qualname. Verified with Python 3.14.4."
    - "itertools.filterfalse.__name__ == 'filterfalse' — C-level type name. Verified with Python 3.14.4."
    - "itertools.filterfalse.__module__ == 'itertools' — defined in itertools. Verified with Python 3.14.4."
    - "itertools.filterfalse.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.4."
    - "itertools.filterfalse.__new__.__qualname__ == 'filterfalse.__new__' — C-level constructor qualname. Verified with Python 3.14.4."
    - "itertools.compress.__name__ == 'compress' — C-level type name. Verified with Python 3.14.4."
    - "itertools.compress.__module__ == 'itertools' — defined in itertools. Verified with Python 3.14.4."
    - "itertools.compress.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.4."
    - "itertools.compress.__new__.__qualname__ == 'compress.__new__' — C-level constructor qualname. Verified with Python 3.14.4."
    - "itertools.accumulate.__name__ == 'accumulate' — C-level type name. Verified with Python 3.14.4."
    - "itertools.accumulate.__module__ == 'itertools' — defined in itertools. Verified with Python 3.14.4."
    - "itertools.accumulate.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.4."
    - "itertools.accumulate.__new__.__qualname__ == 'accumulate.__new__' — C-level constructor qualname. Verified with Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.starmap class identity contracts
#
# itertools.starmap.__name__              == 'starmap'
# itertools.starmap.__module__            == 'itertools'
# itertools.starmap.__bases__[0].__name__ == 'object'
# itertools.starmap.__qualname__          == 'starmap'
# itertools.starmap.__new__.__qualname__  == 'starmap.__new__'
#
# starmap is a C-level iterator type. New to extra258.
# ---------------------------------------------------------------------------

table itertools_extra258.starmap_identity:
  description: "itertools.starmap name, module, base, qualname, __new__ qualname contracts; new to extra258"
  kind: python_call_eq
  category: identity
  id_prefix: itsm258

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_name_eq,
       starmap.__name__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — C-level type name; new to extra258"]
    - [starmap_module_eq,
       starmap.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.starmap.__module__.__eq__('itertools') == True — defined in itertools; new to extra258"]
    - [starmap_base_name_eq,
       "starmap.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.starmap.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra258"]
    - [starmap_qualname_eq,
       starmap.__qualname__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__qualname__.__eq__('starmap') == True — top-level class; qualname equals name; new to extra258"]
    - [starmap_new_qualname_eq,
       starmap.__new__.__qualname__.__eq__,
       ["starmap.__new__"],
       true,
       "itertools.starmap.__new__.__qualname__.__eq__('starmap.__new__') == True — C-level constructor qualname; new to extra258"]

