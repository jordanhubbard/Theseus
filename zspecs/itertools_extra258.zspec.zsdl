  kind: python_call_eq
  function: starmap.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra258.starmap.base_is_object:
  description: "itertools.starmap.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra258"
