invariant itertools_extra258.starmap.name_eq:
  description: "itertools.starmap.__name__ == 'starmap' — C-level type name; new to extra258"
  category: identity
  kind: python_call_eq
  function: starmap.__name__.__eq__
  args: ["starmap"]
  expected: true

invariant itertools_extra258.starmap.module_eq:
