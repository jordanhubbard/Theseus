spec: re3376
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 672 (re3376): __trunc__, __round__, __index__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __trunc__, __round__, __index__ dict-presence (math.trunc(x), round(x), operator.index(x))."
    - "No re class defines __trunc__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; math.trunc() has no meaning for them. re.RegexFlag is an IntFlag enum but __trunc__ is not present in re.RegexFlag.__dict__."
    - "No re class defines __round__ in its own __dict__: re types are not numeric operands; round() is not defined on any re type. re.RegexFlag (IntFlag) does not define __round__ in its own __dict__."
    - "No re class defines __index__ in its own __dict__: re.Pattern and re.Match are not integer types. re.RegexFlag is an IntFlag subclass but __index__ is not stored in re.RegexFlag.__dict__ itself."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all numeric truncation, rounding, and integer-conversion operators absent from re class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — operator.contains(Cls.__dict__, '__trunc__')
#
# No re class defines __trunc__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but math.trunc() support is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3376.trunc:
  description: "re types __trunc__ dict-presence checks; wave 672"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3376

  columns: [id, function, args, expected]
  rows:
    - ["re3376001", operator.contains, [re.Pattern.__dict__,   "__trunc__"], false]
    - ["re3376002", operator.contains, [re.Match.__dict__,     "__trunc__"], false]
    - ["re3376003", operator.contains, [re.RegexFlag.__dict__, "__trunc__"], false]

# ---------------------------------------------------------------------------
# __round__ dict-presence — operator.contains(Cls.__dict__, '__round__')
#
# No re class defines __round__ in its own __dict__; all false.
# re types are not numeric operands; round() is not part of the re type
# protocol. re.RegexFlag (IntFlag) does not define __round__ in its own __dict__.
# ---------------------------------------------------------------------------

table re3376.round:
  description: "re types __round__ dict-presence checks; wave 672"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3376

  columns: [id, function, args, expected]
  rows:
    - ["re3376004", operator.contains, [re.Pattern.__dict__,   "__round__"], false]
    - ["re3376005", operator.contains, [re.Match.__dict__,     "__round__"], false]
    - ["re3376006", operator.contains, [re.RegexFlag.__dict__, "__round__"], false]

# ---------------------------------------------------------------------------
# __index__ dict-presence — operator.contains(Cls.__dict__, '__index__')
#
# No re class defines __index__ in its own __dict__; all false.
# re.Pattern and re.Match are not integer types. re.RegexFlag is an IntFlag
# subclass but __index__ is not stored in re.RegexFlag.__dict__ itself;
# it is inherited from the IntFlag/int MRO rather than defined locally.
# ---------------------------------------------------------------------------

table re3376.index:
  description: "re types __index__ dict-presence checks; wave 672"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3376

  columns: [id, function, args, expected]
  rows:
    - ["re3376007", operator.contains, [re.Pattern.__dict__,   "__index__"], false]
    - ["re3376008", operator.contains, [re.Match.__dict__,     "__index__"], false]
    - ["re3376009", operator.contains, [re.RegexFlag.__dict__, "__index__"], false]

# ---------------------------------------------------------------------------
# combined — __trunc__, __round__, __index__ across all 3 re subjects
#
# 3 classes x 3 methods = 9 rows.
# All nine values are false; re types do not implement truncation, rounding,
# or integer-index protocols in their own __dict__s. re.RegexFlag is an
# IntFlag subclass; __trunc__, __round__, __index__ are not stored in
# re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

