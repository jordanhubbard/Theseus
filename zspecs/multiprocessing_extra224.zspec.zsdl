spec: multiprocessing_extra224
version: ">=3.9"
backend: python_module(multiprocessing.context)

docs: https://docs.python.org/3/library/multiprocessing.html#contexts-and-start-methods

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#contexts-and-start-methods — multiprocessing context documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.context.BaseContext.__name__ == 'BaseContext'; module is 'multiprocessing.context'; verified with Python 3.14.3."
    - "multiprocessing.context.SpawnContext.__name__ == 'SpawnContext'; module is 'multiprocessing.context'; base is 'BaseContext'; verified with Python 3.14.3."
    - "multiprocessing.context.ForkContext.__name__ == 'ForkContext'; module is 'multiprocessing.context'; verified with Python 3.14.3."
    - "multiprocessing.context.ForkServerContext.__name__ == 'ForkServerContext'; module is 'multiprocessing.context'; verified with Python 3.14.3."
    - "On macOS the default context is SpawnContext (get_context() returns SpawnContext instance); verified with Python 3.14.3."
    - "get_context('spawn').__class__.__name__ == 'SpawnContext'; get_context('fork').__class__.__name__ == 'ForkContext'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.context class identity contracts — extra224 namespace
#
# BaseContext.__name__ == 'BaseContext' (11 chars); module 'multiprocessing.context'.
# SpawnContext.__name__ == 'SpawnContext' (12 chars); module 'multiprocessing.context'.
# ForkContext.__name__ == 'ForkContext' (11 chars); module 'multiprocessing.context'.
# ForkServerContext.__name__ == 'ForkServerContext' (17 chars); module 'multiprocessing.context'.
# ---------------------------------------------------------------------------

table multiprocessing_extra224.context_class_names:
  description: "multiprocessing.context class __name__ and __module__ contracts in mp224ccn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp224ccn

  columns: [id, function, args, expected, description]
  rows:
    - [base_name_eq,      BaseContext.__name__.__eq__,             ["BaseContext"],              true, "multiprocessing.context.BaseContext.__name__ == 'BaseContext'; verified with Python 3.14.3"]
    - [base_name_len_11,  BaseContext.__name__.__len__,            [],                           11,   "multiprocessing.context.BaseContext.__name__.__len__() == 11 — 'BaseContext' has 11 characters; verified with Python 3.14.3"]
    - [base_module_eq,    BaseContext.__module__.__eq__,           ["multiprocessing.context"],  true, "multiprocessing.context.BaseContext.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [spawn_name_eq,     SpawnContext.__name__.__eq__,            ["SpawnContext"],             true, "multiprocessing.context.SpawnContext.__name__ == 'SpawnContext'; verified with Python 3.14.3"]
    - [spawn_name_len_12, SpawnContext.__name__.__len__,           [],                           12,   "multiprocessing.context.SpawnContext.__name__.__len__() == 12 — 'SpawnContext' has 12 characters; verified with Python 3.14.3"]
    - [spawn_module_eq,   SpawnContext.__module__.__eq__,          ["multiprocessing.context"],  true, "multiprocessing.context.SpawnContext.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [fork_name_eq,      ForkContext.__name__.__eq__,             ["ForkContext"],              true, "multiprocessing.context.ForkContext.__name__ == 'ForkContext'; verified with Python 3.14.3"]
    - [fork_name_len_11,  ForkContext.__name__.__len__,            [],                           11,   "multiprocessing.context.ForkContext.__name__.__len__() == 11 — 'ForkContext' has 11 characters; verified with Python 3.14.3"]
    - [fork_module_eq,    ForkContext.__module__.__eq__,           ["multiprocessing.context"],  true, "multiprocessing.context.ForkContext.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [fsc_name_eq,       ForkServerContext.__name__.__eq__,       ["ForkServerContext"],        true, "multiprocessing.context.ForkServerContext.__name__ == 'ForkServerContext'; verified with Python 3.14.3"]
    - [fsc_name_len_17,   ForkServerContext.__name__.__len__,      [],                           17,   "multiprocessing.context.ForkServerContext.__name__.__len__() == 17 — 'ForkServerContext' has 17 characters; verified with Python 3.14.3"]
    - [fsc_module_eq,     ForkServerContext.__module__.__eq__,     ["multiprocessing.context"],  true, "multiprocessing.context.ForkServerContext.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]

