invariant multiprocessing_extra224.spawn_context_base_is_basecontext:
  description: "multiprocessing.context.SpawnContext.__bases__[0].__name__ == 'BaseContext' — SpawnContext directly inherits from BaseContext"
  category: identity
  kind: python_call_eq
  function: SpawnContext.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "BaseContext"

invariant multiprocessing_extra224.fork_context_base_is_basecontext:
  description: "multiprocessing.context.ForkContext.__bases__[0].__name__ == 'BaseContext' — ForkContext directly inherits from BaseContext"
  category: identity
  kind: python_call_eq
  function: ForkContext.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
