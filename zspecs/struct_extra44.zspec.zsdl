spec: struct_extra44
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra43.zspec.zsdl — covers Struct/error __class__.__qualname__.__eq__('type') and pack/unpack/calcsize/pack_into/unpack_from/iter_unpack __class__.__qualname__.__eq__('builtin_function_or_method') and Struct/pack/error __class__.__module__.__eq__('builtins')."
    - "struct_extra42.zspec.zsdl — covers Struct.__class__.__name__.__eq__('type'), error.__class__.__name__.__eq__('type'), pack/unpack/calcsize/pack_into/unpack_from/iter_unpack.__class__.__name__.__eq__('builtin_function_or_method')."
    - "struct_extra41.zspec.zsdl — covers Struct.size/__name__.__eq__('size') and Struct.format/__name__/__qualname__.__eq__; Struct.size/format __class__.__name__.__eq__('getset_descriptor')."
    - "struct_extra21.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__len__() and Struct.__init__/__repr__ __qualname__.__eq__/__len__()."
    - "struct_extra9.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__eq__ and __name__.__eq__ as class method descriptors."
    - "struct_extra18.zspec.zsdl — covers Struct/__module__.__eq__('_struct') and all module-level functions __module__.__eq__('_struct') and error/__module__.__eq__('struct')."
    - "struct_extra4.zspec.zsdl — covers Struct.__name__.__eq__('Struct'), pack_into.__name__.__eq__, all module-level function __qualname__.__eq__ and error.__qualname__.__eq__."
  notes:
    - "This spec extends struct through struct_extra43; it does NOT duplicate invariants present in those files."
    - "Coverage gap: No prior struct spec checks __doc__.__class__.__name__.__eq__('str') for any struct object. The struct module exposes docstrings on Struct, error, and the module-level functions (pack, unpack, calcsize, etc.). Each docstring is a Python str; checking __doc__.__class__.__name__ == 'str' confirms the docstring type as an independent structural regression vector distinct from content checks. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__class__.__name__ == 'str'. The Struct type has a C-level docstring; it is exposed as a Python str object. No prior spec checks Struct.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__.__class__.__name__ == 'str'. The pack builtin function has a docstring exposed as a Python str. No prior spec checks pack.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.unpack.__doc__.__class__.__name__ == 'str'. Same as pack. No prior spec checks unpack.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.calcsize.__doc__.__class__.__name__ == 'str'. calcsize has a C-level docstring. No prior spec checks calcsize.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.pack_into.__doc__.__class__.__name__ == 'str'. pack_into has a C-level docstring. No prior spec checks pack_into.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__doc__.__class__.__name__ == 'str'. unpack_from has a C-level docstring. No prior spec checks unpack_from.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__doc__.__class__.__name__ == 'str'. iter_unpack has a C-level docstring. No prior spec checks iter_unpack.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__doc__.__class__.__name__ == 'str'. The error exception class has a docstring. No prior spec checks error.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module-level object __doc__.__class__.__name__.__eq__('str')
#
# Every object in the struct module (Struct, error, pack, unpack, calcsize,
# pack_into, unpack_from, iter_unpack) exposes a docstring as a Python str.
# No prior struct spec checks __doc__.__class__.__name__ for any struct object.
# This provides an independent structural regression vector: if a C extension
# change inadvertently makes a docstring a bytes object or None, this detects it.
# ---------------------------------------------------------------------------

table struct_extra44.doc_class_names:
  description: "struct Struct/pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/error __doc__.__class__.__name__.__eq__('str') — verifies that each struct object's docstring is a Python str; novel __doc__.__class__.__name__ axis; no prior struct spec checks __doc__.__class__.__name__ for any struct object"
  kind: python_call_eq
  category: type_structure
  id_prefix: structmlen44

  columns: [id, function, args, expected]
  rows:
    - [Struct_doc_class_name_eq,      Struct.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [pack_doc_class_name_eq,        pack.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [unpack_doc_class_name_eq,      unpack.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [calcsize_doc_class_name_eq,    calcsize.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [pack_into_doc_class_name_eq,   pack_into.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [unpack_from_doc_class_name_eq, unpack_from.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [iter_unpack_doc_class_name_eq, iter_unpack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [error_doc_class_name_eq,       error.__doc__.__class__.__name__.__eq__,       ["str"], true]
