spec: uuid_extra1441
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
  - "RFC 9562 — Universally Unique IDentifiers (UUIDs)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra.zspec.zsdl — covers UUID class name/module; uuid1/3/4/5 __name__ (table); uuid4 return type/version; NAMESPACE_* class names (table); UUID int/hex attribute types."
    - "uuid_extra2.zspec.zsdl — covers uuid1/3/4/5 __name__ (standalone); NAMESPACE_DNS/URL/OID/X500 class names (standalone); RESERVED_NCS/RFC_4122/RESERVED_MICROSOFT/RESERVED_FUTURE values; constants type checks (table)."
    - "uuid_extra1426.zspec.zsdl — covers UUID.__format__/__dir__ class names (method_descriptor); SafeUUID.__format__/__dir__ class names (function); __format__/__dir__ absent from UUID/SafeUUID __dict__; name lengths."
  notes:
    - "This spec does NOT duplicate invariants present in any prior uuid spec."
    - "Wave 543 theme: __subclasshook__ and __instancecheck__ checks for uuid.UUID and uuid.SafeUUID."
    - "uuid.UUID.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__subclasshook__ in uuid.UUID.__dict__ == False — inherited from type metaclass, not defined on UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__instancecheck__ in uuid.UUID.__dict__ == False — inherited from type metaclass, not defined on UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__subclasshook__ in uuid.SafeUUID.__dict__ == False — inherited from EnumMeta/type metaclass. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__instancecheck__ in uuid.SafeUUID.__dict__ == False — inherited from EnumMeta/type metaclass. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Key distinction: UUID.__subclasshook__/__instancecheck__ come from the standard type metaclass (object-derived). SafeUUID's come from EnumMeta, yet the class name is still 'builtin_function_or_method' because EnumMeta itself is a C-extension type subclassing type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID — __subclasshook__ and __instancecheck__ type and dict checks
#
# Wave 543 theme: UUID inherits directly from object (MRO: [UUID, object]).
# __subclasshook__ and __instancecheck__ are both inherited from the type
# metaclass at the C level — class name is 'builtin_function_or_method'.
# Neither is present in UUID.__dict__.
# ---------------------------------------------------------------------------

table uuid_extra1441.UUID_subclasshook:
  description: "uuid.UUID.__subclasshook__.__class__.__name__=='builtin_function_or_method' and not in UUID.__dict__ — UUID inherits from object; __subclasshook__/__instancecheck__ come from type metaclass at C level; no Python-level override on UUID; wave 543 first uu1441us anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu1441us

  columns: [id, function, args, expected, description]
  rows:
    - [uu1441us001, "UUID.__subclasshook__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true,  "uuid.UUID.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C-level type metaclass inheritance"]
    - [uu1441us002, "UUID.__dict__.__contains__",                        ["__subclasshook__"],           false, "uuid.UUID.__dict__ does not contain '__subclasshook__' — not defined on UUID; inherited from type"]
    - [uu1441us003, "UUID.__instancecheck__.__class__.__name__.__eq__", ["builtin_function_or_method"],  true,  "uuid.UUID.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — C-level type metaclass inheritance"]
    - [uu1441us004, "UUID.__dict__.__contains__",                        ["__instancecheck__"],           false, "uuid.UUID.__dict__ does not contain '__instancecheck__' — not defined on UUID; inherited from type"]
    - [uu1441us005, "UUID.__subclasshook__.__class__.__name__.__eq__",  ["classmethod_descriptor"],      false, "uuid.UUID.__subclasshook__.__class__.__name__ is NOT 'classmethod_descriptor' — it is 'builtin_function_or_method'"]
    - [uu1441us006, "UUID.__instancecheck__.__class__.__name__.__eq__", ["wrapper_descriptor"],           false, "uuid.UUID.__instancecheck__.__class__.__name__ is NOT 'wrapper_descriptor' — it is 'builtin_function_or_method'"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID — __subclasshook__ and __instancecheck__ type and dict checks
#
# SafeUUID subclasses enum.Enum; its metaclass is EnumMeta (a subclass of type).
# Despite the more complex metaclass, __subclasshook__ and __instancecheck__
# are still 'builtin_function_or_method' because EnumMeta is a C-extension type.
# Neither is defined in SafeUUID.__dict__.
# ---------------------------------------------------------------------------

table uuid_extra1441.SafeUUID_subclasshook:
  description: "uuid.SafeUUID.__subclasshook__.__class__.__name__=='builtin_function_or_method' and not in SafeUUID.__dict__ — SafeUUID uses EnumMeta (C-extension subclass of type); __subclasshook__/__instancecheck__ still 'builtin_function_or_method'; neither defined on SafeUUID directly; wave 543 first uu1441sf anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu1441sf

  columns: [id, function, args, expected, description]
  rows:
    - [uu1441sf001, "SafeUUID.__subclasshook__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true,  "uuid.SafeUUID.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — EnumMeta is C-extension type subclassing type"]
    - [uu1441sf002, "SafeUUID.__dict__.__contains__",                        ["__subclasshook__"],           false, "uuid.SafeUUID.__dict__ does not contain '__subclasshook__' — inherited from EnumMeta/type; not defined on SafeUUID"]
    - [uu1441sf003, "SafeUUID.__instancecheck__.__class__.__name__.__eq__", ["builtin_function_or_method"],  true,  "uuid.SafeUUID.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — EnumMeta is C-extension type subclassing type"]
    - [uu1441sf004, "SafeUUID.__dict__.__contains__",                        ["__instancecheck__"],           false, "uuid.SafeUUID.__dict__ does not contain '__instancecheck__' — inherited from EnumMeta/type; not defined on SafeUUID"]
    - [uu1441sf005, "SafeUUID.__subclasshook__.__class__.__name__.__eq__",  ["function"],                    false, "uuid.SafeUUID.__subclasshook__.__class__.__name__ is NOT 'function' — it is 'builtin_function_or_method' (contrast with SafeUUID.__format__ which IS 'function')"]
    - [uu1441sf006, "SafeUUID.__instancecheck__.__class__.__name__.__eq__", ["method_descriptor"],            false, "uuid.SafeUUID.__instancecheck__.__class__.__name__ is NOT 'method_descriptor' — it is 'builtin_function_or_method'"]

# ---------------------------------------------------------------------------
# Contrast: UUID vs SafeUUID — __subclasshook__ and __instancecheck__ symmetry
#
# Unlike __format__ and __dir__ (where UUID gets 'method_descriptor' and SafeUUID
# gets 'function'), both UUID and SafeUUID get 'builtin_function_or_method' for
# __subclasshook__ and __instancecheck__. This is because these methods live on
# the metaclass (type / EnumMeta), not on the class itself.
# This table explicitly anchors the symmetry in the wave 543 namespace.
# ---------------------------------------------------------------------------

table uuid_extra1441.UUID_SafeUUID_symmetry:
  description: "uuid.UUID and uuid.SafeUUID have identical __subclasshook__/__instancecheck__ class names ('builtin_function_or_method') — contrast with __format__/__dir__ where UUID gets 'method_descriptor' and SafeUUID gets 'function'; __subclasshook__/__instancecheck__ live on metaclass not class; both absent from UUID.__dict__ and SafeUUID.__dict__; wave 543 uu1441sy anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu1441sy

  columns: [id, function, args, expected, description]
  rows:
    - [uu1441sy001, "UUID.__subclasshook__.__class__.__name__.__eq__",     ["builtin_function_or_method"], true, "uuid.UUID.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'"]
    - [uu1441sy002, "SafeUUID.__subclasshook__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "uuid.SafeUUID.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'"]
    - [uu1441sy003, "UUID.__instancecheck__.__class__.__name__.__eq__",     ["builtin_function_or_method"], true, "uuid.UUID.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'"]
    - [uu1441sy004, "SafeUUID.__instancecheck__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "uuid.SafeUUID.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'"]
    - [uu1441sy005, "UUID.__dict__.__contains__",     ["__subclasshook__"], false, "uuid.UUID.__dict__ missing '__subclasshook__'"]
    - [uu1441sy006, "SafeUUID.__dict__.__contains__", ["__subclasshook__"], false, "uuid.SafeUUID.__dict__ missing '__subclasshook__'"]
