spec: dataclasses_extra24
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses_extra23.zspec.zsdl."
    - "Focus: __qualname__ (direct string value) for dataclasses functions and classes not yet collected in a combined table under the extra24 namespace."
    - "dataclasses_extra23 covers: combined __qualname__.__eq__ table for dataclass/field/asdict/astuple/make_dataclass/replace/fields/is_dataclass; __qualname__.__len__ for dataclass/asdict/astuple/make_dataclass/field/replace as standalone invariants."
    - "dataclasses_extra22 covers: combined __qualname__.__eq__ table for Field/InitVar/FrozenInstanceError; Field/__qualname__.__len__==5; is_dataclass/__qualname__.__len__==12 standalone invariants."
    - "dataclasses_extra19 covers: standalone __qualname__.__eq__ for fields/asdict/astuple/is_dataclass/replace/make_dataclass."
    - "dataclasses_extra17 covers: field/__qualname__.__eq__ and dataclass/__qualname__.__len__ and field/__qualname__.__len__ standalone; Field/__qualname__.__eq__ and FrozenInstanceError/__qualname__.__eq__."
    - "dataclasses_extra13 covers: FrozenInstanceError/__qualname__.__len__==19."
    - "Focus of this spec: (1) combined __qualname__.__len__ table for Field/FrozenInstanceError/is_dataclass — three class/function qualname lengths not yet in a single combined table; (2) standalone invariants for Field.__qualname__.__eq__ and FrozenInstanceError.__qualname__.__eq__ in the extra24 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for Field, FrozenInstanceError, is_dataclass — table
# (dataclasses_extra24 namespace)
#
# dataclasses_extra22 covers Field.__qualname__.__len__==5 and
# is_dataclass.__qualname__.__len__==12 as standalone invariants.
# dataclasses_extra13 covers FrozenInstanceError.__qualname__.__len__==19.
# No prior spec collects all three together in a single combined table.
# ---------------------------------------------------------------------------

table dataclasses_extra24.class_qualname_lens:
  description: "__qualname__.__len__() for dataclasses class and predicate function"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: qlen

  columns: [id, function, args, expected]
  rows:
    - [Field,               Field.__qualname__.__len__,               [], 5]
    - [FrozenInstanceError, FrozenInstanceError.__qualname__.__len__, [], 19]
    - [is_dataclass,        is_dataclass.__qualname__.__len__,        [], 12]

# ---------------------------------------------------------------------------
# dataclasses.Field.__qualname__ == 'Field' — standalone invariant
# (dataclasses_extra24 namespace)
#
# dataclasses_extra17 covers Field.__qualname__.__eq__ as a standalone in the
# extra17 namespace. dataclasses_extra22 covers it in a combined table.
# Providing a standalone invariant in the extra24 namespace for completeness.
# ---------------------------------------------------------------------------

invariant dataclasses_extra24.Field.qualname:
  description: "dataclasses.Field.__qualname__ == 'Field' — top-level class, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: Field.__qualname__.__eq__
  args: ["Field"]
  expected: true

# ---------------------------------------------------------------------------
# dataclasses.FrozenInstanceError.__qualname__ == 'FrozenInstanceError' — standalone
# (dataclasses_extra24 namespace)
#
# dataclasses_extra17 covers FrozenInstanceError.__qualname__.__eq__ standalone.
# dataclasses_extra22 covers it in a combined table.
# Providing a standalone invariant in the extra24 namespace for completeness.
# ---------------------------------------------------------------------------

invariant dataclasses_extra24.FrozenInstanceError.qualname:
  description: "dataclasses.FrozenInstanceError.__qualname__ == 'FrozenInstanceError'"
  category: qualnames
  kind: python_call_eq
  function: FrozenInstanceError.__qualname__.__eq__
  args: ["FrozenInstanceError"]
  expected: true

# ---------------------------------------------------------------------------
# dataclasses.is_dataclass.__qualname__ == 'is_dataclass' — standalone invariant
# (dataclasses_extra24 namespace)
#
# dataclasses_extra19 covers is_dataclass.__qualname__.__eq__ as a standalone
# in the extra19 namespace. dataclasses_extra23 covers it in a combined table.
# Providing a standalone in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra24.is_dataclass.qualname:
  description: "dataclasses.is_dataclass.__qualname__ == 'is_dataclass'"
  category: qualnames
  kind: python_call_eq
  function: is_dataclass.__qualname__.__eq__
  args: ["is_dataclass"]
  expected: true

# ---------------------------------------------------------------------------
# dataclasses.dataclass.__qualname__ == 'dataclass' — standalone invariant
# (dataclasses_extra24 namespace)
#
# dataclasses_extra17 covers dataclass.__qualname__.__len__ and
# dataclasses_extra23 covers dataclass in the combined __qualname__.__eq__ table.
# Standalone in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra24.dataclass.qualname:
  description: "dataclasses.dataclass.__qualname__ == 'dataclass'"
  category: qualnames
  kind: python_call_eq
  function: dataclass.__qualname__.__eq__
  args: ["dataclass"]
  expected: true
