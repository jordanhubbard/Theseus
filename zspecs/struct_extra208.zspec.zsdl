spec: struct_extra208
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra207.zspec.zsdl — covers struct checks prior to extra208"
  notes:
    - "All __doc__ contains checks verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.pack.__doc__ contains 'pack', 'bytes', 'format'."
    - "struct.unpack.__doc__ contains 'unpack', 'tuple', 'format'."
    - "struct.pack_into.__doc__ contains 'buffer', 'offset'."
    - "struct.unpack_from.__doc__ contains 'offset'."
    - "struct.calcsize.__doc__ contains 'size', 'bytes'."
    - "struct.Struct.__doc__ contains 'Struct', 'compiled'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack and struct.unpack — __doc__ contains checks
#
# struct.pack.__doc__ contains 'pack', 'bytes', 'format'
# struct.unpack.__doc__ contains 'unpack', 'tuple', 'format'
# ---------------------------------------------------------------------------

table struct_extra208.pack_unpack_doc_contains:
  description: "struct.pack and struct.unpack __doc__ contains checks in structdoc208 namespace — wave 259 theme: struct.pack.__doc__.__contains__('pack')==True; struct.pack.__doc__.__contains__('bytes')==True; struct.pack.__doc__.__contains__('format')==True; struct.unpack.__doc__.__contains__('unpack')==True; struct.unpack.__doc__.__contains__('tuple')==True; struct.unpack.__doc__.__contains__('format')==True; all are C builtins in _struct; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc208

  columns: [id, function, args, expected, description]
  rows:
    - [pack_doc_has_pack,    struct.pack.__doc__.__contains__,   ["pack"],   true, "struct.pack.__doc__ contains 'pack'; function name in doc; verified with Python 3.14.3"]
    - [pack_doc_has_bytes,   struct.pack.__doc__.__contains__,   ["bytes"],  true, "struct.pack.__doc__ contains 'bytes'; returns a bytes object; verified with Python 3.14.3"]
    - [pack_doc_has_format,  struct.pack.__doc__.__contains__,   ["format"], true, "struct.pack.__doc__ contains 'format'; takes a format string; verified with Python 3.14.3"]
    - [unpack_doc_has_unpack, struct.unpack.__doc__.__contains__, ["unpack"], true, "struct.unpack.__doc__ contains 'unpack'; function name in doc; verified with Python 3.14.3"]
    - [unpack_doc_has_tuple, struct.unpack.__doc__.__contains__,  ["tuple"],  true, "struct.unpack.__doc__ contains 'tuple'; returns a tuple of values; verified with Python 3.14.3"]
    - [unpack_doc_has_format, struct.unpack.__doc__.__contains__, ["format"], true, "struct.unpack.__doc__ contains 'format'; takes a format string; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.pack_into and struct.unpack_from — __doc__ contains checks
#
# struct.pack_into.__doc__ contains 'buffer', 'offset'
# struct.unpack_from.__doc__ contains 'offset'
# ---------------------------------------------------------------------------

table struct_extra208.pack_into_unpack_from_doc_contains:
  description: "struct.pack_into and struct.unpack_from __doc__ contains checks in structdoc208a namespace — wave 259 theme: struct.pack_into.__doc__.__contains__('buffer')==True; struct.pack_into.__doc__.__contains__('offset')==True; struct.unpack_from.__doc__.__contains__('offset')==True; both functions use an offset into a buffer rather than creating a new bytes object; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc208a

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_doc_has_buffer,     struct.pack_into.__doc__.__contains__,    ["buffer"], true, "struct.pack_into.__doc__ contains 'buffer'; packs into a writable buffer; verified with Python 3.14.3"]
    - [pack_into_doc_has_offset,     struct.pack_into.__doc__.__contains__,    ["offset"], true, "struct.pack_into.__doc__ contains 'offset'; requires a byte offset; verified with Python 3.14.3"]
    - [unpack_from_doc_has_offset,   struct.unpack_from.__doc__.__contains__,  ["offset"], true, "struct.unpack_from.__doc__ contains 'offset'; reads from buffer at offset; verified with Python 3.14.3"]
    - [unpack_from_doc_has_format,   struct.unpack_from.__doc__.__contains__,  ["format"], true, "struct.unpack_from.__doc__ contains 'format'; takes a format string; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.calcsize and struct.Struct — __doc__ contains checks
#
# struct.calcsize.__doc__ contains 'size', 'bytes'
# struct.Struct.__doc__ contains 'Struct', 'compiled'
# ---------------------------------------------------------------------------

table struct_extra208.calcsize_Struct_doc_contains:
  description: "struct.calcsize and struct.Struct __doc__ contains checks in structdoc208b namespace — wave 259 theme: struct.calcsize.__doc__.__contains__('size')==True; struct.calcsize.__doc__.__contains__('bytes')==True; struct.Struct.__doc__.__contains__('Struct')==True; struct.Struct.__doc__.__contains__('compiled')==True; calcsize returns a byte count; Struct is a compiled struct object; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structdoc208b

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_doc_has_size,     struct.calcsize.__doc__.__contains__, ["size"],     true, "struct.calcsize.__doc__ contains 'size'; returns size in bytes; verified with Python 3.14.3"]
    - [calcsize_doc_has_bytes,    struct.calcsize.__doc__.__contains__, ["bytes"],    true, "struct.calcsize.__doc__ contains 'bytes'; size measured in bytes; verified with Python 3.14.3"]
    - [Struct_doc_has_Struct,     struct.Struct.__doc__.__contains__,   ["Struct"],   true, "struct.Struct.__doc__ contains 'Struct'; class name appears in doc; verified with Python 3.14.3"]
    - [Struct_doc_has_compiled,   struct.Struct.__doc__.__contains__,   ["compiled"], true, "struct.Struct.__doc__ contains 'compiled'; Struct is a compiled struct object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — struct_extra208
# ---------------------------------------------------------------------------

invariant struct_extra208.pack_doc_contains_pack:
  description: "struct.pack.__doc__.__contains__('pack') returns True — struct.pack's docstring reads 'pack(format, v1, v2, ...) -> bytes — Return a bytes object containing the values v1, v2, ... packed according to the format string'; the word 'pack' appears in the function signature at the start of the doc; struct.pack is a C builtin in _struct; it takes a format string and values and returns a bytes object; the doc contains 'pack' as the function name in the signature header; NEW in struct_extra208: first standalone pack.__doc__.__contains__('pack') invariant in structdoc208 namespace; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.pack.__doc__.__contains__
  args: ["pack"]
  expected: true

invariant struct_extra208.pack_doc_contains_bytes:
  description: "struct.pack.__doc__.__contains__('bytes') returns True — struct.pack's docstring reads 'pack(format, v1, v2, ...) -> bytes — Return a bytes object containing the values...'; the word 'bytes' appears twice: in the return type annotation '-> bytes' and in 'Return a bytes object'; struct.pack returns a bytes object (immutable byte string) containing the packed binary data; this contrasts with struct.pack_into which writes into an existing buffer in place; NEW in struct_extra208: first standalone pack.__doc__.__contains__('bytes') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.pack.__doc__.__contains__
  args: ["bytes"]
  expected: true

invariant struct_extra208.unpack_doc_contains_tuple:
  description: "struct.unpack.__doc__.__contains__('tuple') returns True — struct.unpack's docstring reads 'Return a tuple containing values unpacked according to the format string'; the word 'tuple' describes the return type; struct.unpack always returns a tuple even when unpacking a single value; this is important for users: unpacking '!H' from 2 bytes returns a 1-tuple (value,) not the value itself; compare: struct.pack takes positional values and returns bytes; struct.unpack takes bytes and returns a tuple; NEW in struct_extra208: first standalone unpack.__doc__.__contains__('tuple') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.unpack.__doc__.__contains__
  args: ["tuple"]
  expected: true

invariant struct_extra208.pack_into_doc_contains_buffer:
  description: "struct.pack_into.__doc__.__contains__('buffer') returns True — struct.pack_into's docstring reads 'Pack the values v1, v2, ... according to the format string and write the packed bytes into the writable buffer buf starting at offset'; the word 'buffer' appears as both the parameter name and in the description; pack_into differs from pack by writing into an existing mutable buffer (bytearray, memoryview, or array) rather than allocating a new bytes object; the buffer parameter is a writable bytes-like object; NEW in struct_extra208: first standalone pack_into.__doc__.__contains__('buffer') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.pack_into.__doc__.__contains__
  args: ["buffer"]
  expected: true

invariant struct_extra208.pack_into_doc_contains_offset:
  description: "struct.pack_into.__doc__.__contains__('offset') returns True — struct.pack_into's docstring reads 'write the packed bytes into the writable buffer buf starting at offset. Note that the offset is a required argument'; the word 'offset' appears twice, and the doc explicitly notes the offset is required (unlike struct.unpack_from where offset defaults to 0); the offset parameter specifies the byte position in the buffer where packing begins; this allows updating specific positions in a larger buffer; NEW in struct_extra208: first standalone pack_into.__doc__.__contains__('offset') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.pack_into.__doc__.__contains__
  args: ["offset"]
  expected: true

invariant struct_extra208.calcsize_doc_contains_size:
  description: "struct.calcsize.__doc__.__contains__('size') returns True — struct.calcsize's docstring reads 'Return size in bytes of the struct described by the format string'; the word 'size' is the primary concept: calcsize tells you how many bytes a packed struct will occupy; this is essential for allocating buffers before calling struct.pack_into or for verifying buffer sizes before struct.unpack; calcsize('!HI') returns 6 (2+4 bytes); NEW in struct_extra208: first standalone calcsize.__doc__.__contains__('size') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.calcsize.__doc__.__contains__
  args: ["size"]
  expected: true

invariant struct_extra208.Struct_doc_contains_compiled:
  description: "struct.Struct.__doc__.__contains__('compiled') returns True — struct.Struct's docstring reads 'Struct(fmt) --> compiled struct object'; the word 'compiled' describes the key benefit of using struct.Struct: the format string is compiled once and can be reused efficiently; compare: struct.pack/unpack recompile the format string on each call; struct.Struct pre-compiles the format so repeated pack/unpack operations are faster; the '--> compiled struct object' in the doc signature is reminiscent of Python's compiled regex pattern documentation; NEW in struct_extra208: first standalone Struct.__doc__.__contains__('compiled') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__doc__.__contains__
  args: ["compiled"]
  expected: true

