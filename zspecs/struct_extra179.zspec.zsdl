spec: struct_extra179
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/struct.py"
    - "CPython source: Modules/_struct.c"
  notes:
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor' — size is a C-level getset slot, not a member_descriptor."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor' — format is also a C-level getset slot."
    - "struct.Struct.__doc__.__class__.__name__ == 'str' — Struct has a docstring."
    - "struct.error.__doc__ is None — struct.error has no docstring; __doc__ is NoneType."
    - "struct.Struct.__module__ == '_struct' — Struct is implemented in the C extension module _struct."
    - "struct.pack.__qualname__ == 'pack' — top-level C function; qualname equals name."
    - "struct.unpack.__qualname__ == 'unpack' — top-level C function; qualname equals name."
    - "struct.calcsize.__qualname__ == 'calcsize' — top-level C function; qualname equals name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct descriptor types for size and format
#
# struct.Struct.size.__class__.__name__   == 'getset_descriptor'
# struct.Struct.format.__class__.__name__ == 'getset_descriptor'
#
# Both instance attributes are C-level getset descriptors from _struct.c.
# ---------------------------------------------------------------------------

table struct_extra179.struct_descriptor_types:
  description: "struct.Struct.size and struct.Struct.format are getset_descriptor objects from the C extension; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: structattrs179

  columns: [id, function, args, expected, description]
  rows:
    - [size_class_name_eq,
       Struct.size.__class__.__name__.__eq__,
       ["getset_descriptor"],
       true,
       "struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') == True — size is a C-level getset slot; new to extra179"]
    - [format_class_name_eq,
       Struct.format.__class__.__name__.__eq__,
       ["getset_descriptor"],
       true,
       "struct.Struct.format.__class__.__name__.__eq__('getset_descriptor') == True — format is a C-level getset slot; new to extra179"]
    - [struct_module_eq,
       Struct.__module__.__eq__,
       ["_struct"],
       true,
       "struct.Struct.__module__.__eq__('_struct') == True — Struct is implemented in the _struct C extension; new to extra179"]
    - [struct_doc_class_eq,
       Struct.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "struct.Struct.__doc__.__class__.__name__.__eq__('str') == True — Struct has a string docstring; new to extra179"]

# ---------------------------------------------------------------------------
# Table 2: struct top-level function qualnames
#
# struct.pack.__qualname__     == 'pack'
# struct.unpack.__qualname__   == 'unpack'
# struct.calcsize.__qualname__ == 'calcsize'
#
# All are C built-in functions with qualname equal to their simple name.
# ---------------------------------------------------------------------------

table struct_extra179.top_level_function_qualnames:
  description: "struct.pack, unpack, and calcsize qualnames match their simple names; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: structattrs179

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname_eq,
       pack.__qualname__.__eq__,
       ["pack"],
       true,
       "struct.pack.__qualname__.__eq__('pack') == True — pack is a top-level C function; qualname equals name; new to extra179"]
    - [unpack_qualname_eq,
       unpack.__qualname__.__eq__,
       ["unpack"],
       true,
       "struct.unpack.__qualname__.__eq__('unpack') == True — unpack is a top-level C function; qualname equals name; new to extra179"]
    - [calcsize_qualname_eq,
       calcsize.__qualname__.__eq__,
       ["calcsize"],
       true,
       "struct.calcsize.__qualname__.__eq__('calcsize') == True — calcsize is a top-level C function; qualname equals name; new to extra179"]

# ---------------------------------------------------------------------------
# Table 3: struct.error docstring and struct.Struct module identity
#
# struct.error.__doc__ is None — NoneType
# struct.Struct.__module__ == '_struct'
# ---------------------------------------------------------------------------

table struct_extra179.error_and_module_identity:
  description: "struct.error has no docstring (NoneType) and Struct is from _struct C extension; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: structattrs179

  columns: [id, function, args, expected, description]
  rows:
    - [error_doc_is_none,
       error.__doc__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "struct.error.__doc__.__class__.__name__.__eq__('NoneType') == True — struct.error has no docstring; new to extra179"]
    - [struct_module_is_underscore_struct,
       Struct.__module__.__eq__,
       ["_struct"],
       true,
       "struct.Struct.__module__.__eq__('_struct') == True — Struct class lives in the _struct C extension module; new to extra179"]
    - [size_descriptor_class_is_getset,
       Struct.size.__class__.__name__.__eq__,
       ["getset_descriptor"],
       true,
       "struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') == True — C-level slot descriptor; new to extra179"]
    - [format_descriptor_class_is_getset,
       Struct.format.__class__.__name__.__eq__,
       ["getset_descriptor"],
       true,
       "struct.Struct.format.__class__.__name__.__eq__('getset_descriptor') == True — C-level slot descriptor; new to extra179"]

