spec: cachetools_rust
version: ">=3.9"
backend: rust_module(cachetools_rust)

docs: https://cachetools.readthedocs.io/

provenance:
  derived_from:
    - "https://cachetools.readthedocs.io/ — cachetools library"
  notes:
    - "cachetools provides LRU, LFU, TTL caches."
    - "cachetools.LRUCache(maxsize=128) has maxsize attribute."
    - "cachetools.TTLCache(maxsize=128, ttl=60) has ttl attribute."
    - "cachetools.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant cachetools_rust.lru_maxsize:
  description: "LRUCache(maxsize=128).maxsize == 128"
  category: lru
  kind: python_call_eq
  function: cachetools_lru_maxsize
  args: [128]
  expected: 128

invariant cachetools_rust.has_ttl_cache:
  description: "cachetools has TTLCache"
  category: presence
  kind: python_call_eq
  function: cachetools_has_ttl_cache
  args: []
  expected: true

invariant cachetools_rust.version_nonempty:
  description: "cachetools.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: cachetools_version_nonempty
  args: []
  expected: true

