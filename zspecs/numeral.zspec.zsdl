spec: numeral
version: ">=2.0.6"
backend: node(numeral)

docs: https://www.npmjs.com/package/numeral

provenance:
  derived_from:
    - "numeral README — https://www.npmjs.com/package/numeral"
    - "Test vectors verified with numeral via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "numeral source"
  notes:
    - "numeral is an npm package. Install: npm install numeral"
    - "numeral(value) constructs a numeral object; .format(pattern) formats it as a string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a formatted string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table numeral.format:
  kind: node_factory_call_eq
  factory: ~
  method: format
  category: format
  id_prefix: numfmt

  columns: [id, factory_args, method_args, expected]
  rows:
    - [thousands,    [1000],     ["0,0"],   "1,000"]
    - [millions,     [1000000],  ["0,0"],   "1,000,000"]
