spec: numeral
version: ">=2.0.0"
backend: node(numeral)

docs: http://numeraljs.com/

provenance:
  derived_from:
    - "numeral README — https://github.com/adamwdraper/Numeral-js#readme"
    - "Test vectors verified with numeral@2.0.6 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "numeral source"
  notes:
    - "numeral exports the numeral factory function as module.exports."
    - "numeral(n) creates a numeral instance; .format(pattern) returns a formatted string."
    - "'0,0' adds thousand separators; '0.0a' uses abbreviated suffixes (k, m, b)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "format() returns a string. No errors for valid numeric inputs and patterns."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table numeral.format:
  kind: node_factory_call_eq
  function: ~
  method: format
  category: format
  id_prefix: num

  columns: [id, args, method_args, expected]
  rows:
    - [thousands,  [1234567],   ["0,0"],    "1,234,567"]
    - [decimal,    [1234.56],   ["0,0.00"], "1,234.56"]
    - [millions,   [1000000],   ["0.0a"],   "1.0m"]
    - [bytes,      [1024],      ["0b"],     "1KB"]
