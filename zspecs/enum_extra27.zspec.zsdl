spec: enum_extra27
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra26.zspec.zsdl."
    - "Focus: __qualname__ values for Enum class method qualnames (_generate_next_value_, _missing_) and combined class qualname table for IntEnum/IntFlag/Flag/StrEnum/auto/unique/EnumType in the extra27 namespace."
    - "enum_extra26 covers Enum.__str__/__repr__/__new__ method qualnames and EnumMeta method qualnames in the extra26 namespace."
    - "enum_extra21 covers a combined __qualname__ table for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique and EnumMeta.__qualname__ standalone in the extra21 namespace."
    - "No prior enum spec records Enum._generate_next_value_.__qualname__ or Enum._missing_.__qualname__ in any invariant or table."
    - "No prior enum spec has EnumType.__qualname__ as a standalone in the extra27 namespace."
    - "Enum._generate_next_value_.__qualname__ == 'Enum._generate_next_value_' (len=26)."
    - "Enum._missing_.__qualname__ == 'Enum._missing_' (len=14)."
    - "StrEnum was introduced in Python 3.11; spec version is set to >=3.11."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# enum.Enum class method __qualname__ values — combined table
#
# _generate_next_value_ is a staticmethod used by auto(); its __qualname__
# is 'Enum._generate_next_value_'. _missing_ is a classmethod for handling
# missing values; its __qualname__ is 'Enum._missing_'.
# No prior enum spec records either of these method qualnames.
# ---------------------------------------------------------------------------

table enum_extra27.Enum_special_method_qualnames:
  description: "__qualname__.__eq__ for enum.Enum special class methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [generate_next_value, "Enum._generate_next_value_.__qualname__.__eq__", ["Enum._generate_next_value_"], true]
    - [missing,             "Enum._missing_.__qualname__.__eq__",             ["Enum._missing_"],             true]

# ---------------------------------------------------------------------------
# enum.Enum class method __qualname__.__len__() — combined table
#
# Verifies the string length of each special method __qualname__:
#   Enum._generate_next_value_ -> 26, Enum._missing_ -> 14
# No prior enum spec records these method qualname lengths.
# ---------------------------------------------------------------------------

table enum_extra27.Enum_special_method_qualname_lens:
  description: "__qualname__.__len__() for enum.Enum special class methods"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [generate_next_value, "Enum._generate_next_value_.__qualname__.__len__", [], 26]
    - [missing,             "Enum._missing_.__qualname__.__len__",             [], 14]

# ---------------------------------------------------------------------------
# enum class __qualname__ values — combined table (extra27 namespace)
#
# enum_extra21 covers a combined table for Enum/IntEnum/Flag/IntFlag/StrEnum/
# auto/unique in the extra21 namespace. No prior spec has IntEnum/IntFlag/Flag/
# StrEnum/auto/unique/EnumType together as a combined table in the extra27
# namespace. Providing a fresh combined table for the extra27 namespace.
# EnumType.__qualname__ == 'EnumType' (Python 3.11+).
# ---------------------------------------------------------------------------

table enum_extra27.class_qualnames:
  description: "__qualname__.__eq__ for enum classes in the extra27 namespace — Python 3.11+"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [IntEnum,  IntEnum.__qualname__.__eq__,   ["IntEnum"],  true]
    - [IntFlag,  IntFlag.__qualname__.__eq__,   ["IntFlag"],  true]
    - [Flag,     Flag.__qualname__.__eq__,      ["Flag"],     true]
    - [StrEnum,  StrEnum.__qualname__.__eq__,   ["StrEnum"],  true]
    - [auto,     auto.__qualname__.__eq__,      ["auto"],     true]
    - [unique,   unique.__qualname__.__eq__,    ["unique"],   true]
    - [EnumType, EnumType.__qualname__.__eq__,  ["EnumType"], true]

# ---------------------------------------------------------------------------
# enum class __qualname__.__len__() — combined table (extra27 namespace)
#
# Verifies the string length of each class __qualname__:
#   IntEnum -> 7, IntFlag -> 7, Flag -> 4, StrEnum -> 7,
#   auto -> 4, unique -> 6, EnumType -> 8
# No prior enum spec has all seven together in the extra27 namespace.
# ---------------------------------------------------------------------------

table enum_extra27.class_qualname_lens:
  description: "__qualname__.__len__() for enum classes — Python 3.11+"
  kind: python_call_eq
  category: class_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [IntEnum,  IntEnum.__qualname__.__len__,  [], 7]
    - [IntFlag,  IntFlag.__qualname__.__len__,  [], 7]
    - [Flag,     Flag.__qualname__.__len__,     [], 4]
    - [StrEnum,  StrEnum.__qualname__.__len__,  [], 7]
    - [auto,     auto.__qualname__.__len__,     [], 4]
    - [unique,   unique.__qualname__.__len__,   [], 6]
    - [EnumType, EnumType.__qualname__.__len__, [], 8]
