spec: concurrent_futures_extra1921
version: ">=3.9"
backend: python_module(concurrent.futures)

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 575 (_extra1921): __slots__ inheritance checks, __abstractmethods__ set membership, __subclasshook__ dict presence, __init_subclass__ dict presence."
    - "concurrent.futures.Future, ThreadPoolExecutor, ProcessPoolExecutor, and Executor do NOT define __slots__ in their own __dict__."
    - "concurrent.futures.Executor does NOT use abc machinery and does NOT define __abstractmethods__ in its __dict__; submit/shutdown are concrete methods that raise NotImplementedError at runtime but are not registered as abstract."
    - "None of the checked concurrent.futures classes define __abstractmethods__, __subclasshook__, or __init_subclass__ in their own __dict__."
    - "concurrent.futures.Executor.__dict__ contains: __dict__, __doc__, __enter__, __exit__, __firstlineno__, __module__, __static_attributes__, __weakref__, map, shutdown, submit."
    - "Exception classes CancelledError, TimeoutError, BrokenExecutor, InvalidStateError also do not use __slots__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table concurrent_futures_extra1921.slots_protocol:
  description: "concurrent.futures types __slots__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1921

  columns: [id, function, args, expected]
  rows:
    - ["cf1921001", "concurrent.futures.Future.__dict__.__contains__", ["__slots__"], false]
    - ["cf1921002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__slots__"], false]
    - ["cf1921003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__slots__"], false]
    - ["cf1921004", "concurrent.futures.Executor.__dict__.__contains__", ["__slots__"], false]
    - ["cf1921005", "concurrent.futures.CancelledError.__dict__.__contains__", ["__slots__"], false]
    - ["cf1921006", "concurrent.futures.TimeoutError.__dict__.__contains__", ["__slots__"], false]
    - ["cf1921007", "concurrent.futures.BrokenExecutor.__dict__.__contains__", ["__slots__"], false]
    - ["cf1921008", "concurrent.futures.InvalidStateError.__dict__.__contains__", ["__slots__"], false]

