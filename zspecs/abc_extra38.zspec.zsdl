spec: abc_extra38
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra37.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token/update_abstractmethods, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), ABCMeta/__subclasshook__/__qualname__.__len__()==24, update_abstractmethods/__qualname__.__len__()==22, ABC/__abstractmethods__/__class__/__name__.__len__()==9, ABC/__name__.__len__()==3, abstractmethod/__name__.__len__()==14, get_cache_token/__name__.__len__()==15, abc/__name__.__len__()==3, ABCMeta mro entry name/qualname lengths, ABC/__subclasshook__/__qualname__.__len__()==20, issubclass/isinstance behavioral invariants, abstractmethod/__class__/__name__.__len__()==8, ABC/__doc__/__class__/__name__.__len__()==3, ABCMeta/__prepare__/__qualname__.__len__()==19, ABCMeta/__init__/__qualname__.__len__()==13, ABCMeta/__getattribute__/__qualname__.__len__()==21, ABCMeta/__call__/__repr__/__qualname__.__len__()==13, ABCMeta/__setattr__/__delattr__/__qualname__.__len__()==16, abstractmethod/__code__/__class__/__name__.__len__()==4, ABC/__init_subclass__/__qualname__/__len__()==21, metaclass chain tables, abstractmethod/__annotations__/__class__/__name__.__len__()==4, get_cache_token/__class__/__name__.__len__()==26, ABCMeta/__bases__[0]/__module__/__qualname__.__len__(), ABC/__bases__[0]/__module__/__qualname__.__len__(), abstractmethod/__class__/__module__.__len__()==8, abc/__spec__/__class__/__name__.__len__()==10, ABCMeta MRO __module__/__qualname__.__len__() tables, abstractmethod/__name__=='abstractmethod' (extra34), get_cache_token/__module__=='_abc' (extra34), ABC/__name__=='ABC' (extra34), ABC/__bases__[0].__name__=='object' (extra34), ABCMeta/__name__=='ABCMeta'/__module__=='abc'/__bases__[0].__name__=='type' (extra35), ABCMeta.register/__qualname__.__len__()==16 (extra35), ABCMeta/__mro__.__len__()==3, ABC/__mro__.__len__()==2, ABC/__mro__[1].__name__=='object' (extra35), ABCMeta MRO entries [0]/'ABCMeta', [1]/'type', [2]/'object', ABC/__mro__[0].__name__=='ABC', abstractmethod/__qualname__.__len__()==14, abstractproperty/__name__=='abstractproperty'/__module__=='abc', abstractclassmethod/__name__=='abstractclassmethod'/__module__=='abc' (extra36), abstractproperty/__qualname__=='abstractproperty', abstractproperty/__qualname__.__len__()==16, abstractproperty/__bases__[0].__name__=='property', abstractclassmethod/__bases__[0].__name__=='classmethod', abstractstaticmethod/__name__=='abstractstaticmethod', abstractstaticmethod/__bases__[0].__name__=='staticmethod', ABC/__qualname__=='ABC', ABC/__qualname__.__len__()==3 (extra37)."
    - "This spec covers: abstractmethod/__qualname__=='abstractmethod' (14 chars); abstractclassmethod/__qualname__=='abstractclassmethod' (19 chars); abstractstaticmethod/__qualname__=='abstractstaticmethod' (20 chars); ABCMeta.register/__qualname__=='ABCMeta.register' (16 chars); ABC/__abstractmethods__.__class__.__name__=='frozenset'; ABC/__abstractmethods__.__len__()==0; ABCMeta.__call__/__qualname__=='type.__call__' (13 chars)."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod' (14 chars). abstractmethod is a top-level class (a decorator class); __qualname__ equals __name__ for top-level classes. Prior specs measured __qualname__.__len__()==14 (extra34 and others); extra38 captures the string equality."
    - "abc.abstractclassmethod.__qualname__ == 'abstractclassmethod' (19 chars). abstractclassmethod is a top-level deprecated class; __qualname__ equals __name__. len('abstractclassmethod') == 19: a-b-s-t-r-a-c-t-c-l-a-s-s-m-e-t-h-o-d = 19."
    - "abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod' (20 chars). abstractstaticmethod is a top-level deprecated class; __qualname__ equals __name__. len('abstractstaticmethod') == 20: a-b-s-t-r-a-c-t-s-t-a-t-i-c-m-e-t-h-o-d = 20. One char longer than abstractclassmethod."
    - "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' (16 chars). register is a method of ABCMeta; its __qualname__ includes the class name prefix. Prior specs measured __qualname__.__len__()==16 (extra35); extra38 captures the string equality."
    - "abc.ABC.__abstractmethods__ is a frozenset (class name 'frozenset') with length 0. ABC itself has no abstract methods; __abstractmethods__ is an empty frozenset. The class name 'frozenset' has 9 chars. Note: abc.ABCMeta itself does NOT have a __abstractmethods__ attribute at the class level (AttributeError). The __abstractmethods__ attribute exists on instances of ABCMeta (i.e., on classes created with ABCMeta as their metaclass, like ABC)."
    - "abc.ABCMeta.__call__.__qualname__ == 'type.__call__' (13 chars). ABCMeta does not define its own __call__; it inherits __call__ from type. The __qualname__ of type.__call__ is 'type.__call__'. len('type.__call__') == 13."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc deprecated abstract class __qualname__ — extra38 namespace
#
# Three abstract decorator classes and their __qualname__ values:
#   abstractmethod.__qualname__      == 'abstractmethod'       (14 chars)
#   abstractclassmethod.__qualname__ == 'abstractclassmethod'  (19 chars)
#   abstractstaticmethod.__qualname__== 'abstractstaticmethod' (20 chars)
# All three are top-level classes so __qualname__ equals __name__. abstractmethod
# is the canonical decorator; abstractclassmethod and abstractstaticmethod are
# deprecated since Python 3.3 but remain in Python 3.14 for backward compatibility.
# ---------------------------------------------------------------------------

table abc_extra38.abstract_decorator_qualnames:
  description: "abc abstract decorator class __qualname__ string equality in extra38 namespace — abstractmethod, abstractclassmethod, abstractstaticmethod"
  kind: python_call_eq
  category: class_names
  id_prefix: abcabsdecqn38

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod,      abstractmethod.__qualname__.__eq__,      ["abstractmethod"],      true, "abstractmethod.__qualname__ == 'abstractmethod' — top-level class; qualname equals name (14 chars)"]
    - [abstractclassmethod, abstractclassmethod.__qualname__.__eq__,  ["abstractclassmethod"],  true, "abstractclassmethod.__qualname__ == 'abstractclassmethod' — deprecated; top-level class; qualname equals name (19 chars)"]
    - [abstractstaticmethod, abstractstaticmethod.__qualname__.__eq__, ["abstractstaticmethod"], true, "abstractstaticmethod.__qualname__ == 'abstractstaticmethod' — deprecated; top-level class; qualname equals name (20 chars)"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.register __qualname__ — extra38 namespace
#
# ABCMeta.register.__qualname__ == 'ABCMeta.register' (16 chars)
# register is a method defined on ABCMeta; its __qualname__ includes the
# enclosing class name prefix 'ABCMeta.'. Prior specs measured
# __qualname__.__len__()==16 in extra35; extra38 captures the string equality.
# 'ABCMeta.register': A-B-C-M-e-t-a(7) + '.'(1) + r-e-g-i-s-t-e-r(8) = 16.
# ---------------------------------------------------------------------------

invariant abc_extra38.ABCMeta_register_qualname_eq:
  description: "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' — method of ABCMeta; qualname includes class prefix (16 chars)"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

# ---------------------------------------------------------------------------
# abc.ABC.__abstractmethods__ — extra38 namespace
#
# ABC.__abstractmethods__ is a frozenset with 0 elements.
# ABC itself declares no abstract methods; __abstractmethods__ is present
# as an empty frozenset. Its class is 'frozenset' (9 chars).
# Note: abc.ABCMeta does NOT expose __abstractmethods__ at the class level
# (accessing it raises AttributeError). Only classes that USE ABCMeta as
# their metaclass (like ABC) carry __abstractmethods__ on themselves.
# ---------------------------------------------------------------------------

table abc_extra38.ABC_abstractmethods:
  description: "abc.ABC.__abstractmethods__ type and length in extra38 namespace — empty frozenset on ABC itself"
  kind: python_call_eq
  category: class_names
  id_prefix: abcabcabsmeth38

  columns: [id, function, args, expected, description]
  rows:
    - [class_name, ABC.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true, "ABC.__abstractmethods__.__class__.__name__ == 'frozenset' — ABC's abstract method set is a frozenset (9 chars)"]
    - [length,     ABC.__abstractmethods__.__len__,                   [],            0,    "ABC.__abstractmethods__.__len__() == 0 — ABC has no abstract methods of its own"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__call__.__qualname__ — extra38 namespace
#
# ABCMeta.__call__.__qualname__ == 'type.__call__' (13 chars)
# ABCMeta does not define its own __call__; it inherits __call__ from type
# (ABCMeta's base metaclass). The __qualname__ of the inherited method is
# 'type.__call__'. len('type.__call__') == 13:
# t-y-p-e(4) + '.'(1) + __call__(8) = 13.
# ---------------------------------------------------------------------------

invariant abc_extra38.ABCMeta_call_qualname_eq:
  description: "abc.ABCMeta.__call__.__qualname__ == 'type.__call__' — ABCMeta inherits __call__ from type; qualname reflects the defining class (13 chars)"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__call__.__qualname__.__eq__
  args: ["type.__call__"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — extra38
# ---------------------------------------------------------------------------

invariant abc_extra38.abstractmethod_qualname_eq:
  description: "abc.abstractmethod.__qualname__ == 'abstractmethod' — top-level decorator class; qualname equals name (14 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__qualname__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra38.abstractclassmethod_qualname_eq:
  description: "abc.abstractclassmethod.__qualname__ == 'abstractclassmethod' — deprecated top-level class; qualname equals name (19 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractclassmethod.__qualname__.__eq__
  args: ["abstractclassmethod"]
  expected: true

invariant abc_extra38.abstractstaticmethod_qualname_eq:
  description: "abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod' — deprecated top-level class; qualname equals name (20 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractstaticmethod.__qualname__.__eq__
  args: ["abstractstaticmethod"]
  expected: true

invariant abc_extra38.ABC_abstractmethods_class_name_eq:
  description: "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset' — ABC's abstract methods collection is a frozenset (9 chars)"
  category: class_names
  kind: python_call_eq
  function: ABC.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant abc_extra38.ABC_abstractmethods_len:
  description: "abc.ABC.__abstractmethods__.__len__() == 0 — ABC has no abstract methods; the frozenset is empty"
  category: class_names
  kind: python_call_eq
  function: ABC.__abstractmethods__.__len__
  args: []
  expected: 0

invariant abc_extra38.ABCMeta_call_qualname_len:
  description: "abc.ABCMeta.__call__.__qualname__.__len__() == 13 — 'type.__call__' has 13 characters"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__call__.__qualname__.__len__
  args: []
  expected: 13
