spec: abc_extra520
backend: python_module(abc)

table:
  id: metaclass_identities
  columns: [id, function, expected]
  rows:
    - [abc_metaclass,             abc.ABC.__class__.__name__,             ABCMeta]
    - [abcmeta_metaclass,         abc.ABCMeta.__class__.__name__,         type]
    - [abstractmethod_class,      abc.abstractmethod.__class__.__name__,  type]
    - [abstractclassmethod_class, abc.abstractclassmethod.__class__.__name__, type]
    - [abstractstaticmethod_class, abc.abstractstaticmethod.__class__.__name__, type]
    - [abstractproperty_class,    abc.abstractproperty.__class__.__name__, type]
  invariant:
    kind: python_call_eq

table:
  id: module_string_values
  columns: [id, function, expected]
  rows:
    - [abc_module_eq,            abc.ABC.__module__.__eq__,            abc]
    - [abcmeta_module_eq,        abc.ABCMeta.__module__.__eq__,        abc]
    - [abstractmethod_module_eq, abc.abstractmethod.__module__.__eq__, abc]
  invariant:
    kind: python_call_eq

invariants:
  - id: get_cache_token_class
    kind: python_call_eq
    function: abc.get_cache_token.__class__.__name__
    expected: builtin_function_or_method
