spec: functools_extra137
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partialmethod class identity and method qualnames (Wave 257)."
    - "functools.partialmethod.__name__ == 'partialmethod' — partialmethod is a class defined with 'class partialmethod:' in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.partialmethod.__module__ == 'functools' — partialmethod is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod inherits only from object. Verified with Python 3.14.3."
    - "len(functools.partialmethod.__mro__) == 2 — MRO is [partialmethod, object]. Verified with Python 3.14.3."
    - "functools.partialmethod.__class__.__name__ == 'type' — partialmethod is a class (type), not a function. Verified with Python 3.14.3."
    - "functools.partialmethod.__qualname__ == 'partialmethod' (len 13) — partialmethod is defined at module scope. Verified with Python 3.14.3."
    - "functools.partialmethod.__get__.__qualname__ == 'partialmethod.__get__' (len 21) — __get__ is a descriptor method defined inside the class body. Verified with Python 3.14.3."
    - "functools.partialmethod.__get__.__class__.__name__ == 'function' — __get__ is a regular Python function. Verified with Python 3.14.3."
    - "functools.partialmethod.__init__.__qualname__ == 'object.__init__' (len 15) — partialmethod does not override __init__; inherits from object. Verified with Python 3.14.3."
    - "functools.partialmethod.__repr__.__qualname__ == '_partial_repr' (len 13) — __repr__ is assigned from the module-level helper '_partial_repr'. Verified with Python 3.14.3."
    - "functools.partialmethod.__new__.__qualname__ == '_partial_new' (len 12) — __new__ is assigned from the module-level helper '_partial_new'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partialmethod class identity (__name__, __module__, __class__.__name__)
#
# Wave 257 theme: functools.partialmethod class identity.
#
# functools.partialmethod.__name__ == 'partialmethod'
# functools.partialmethod.__module__ == 'functools'
# functools.partialmethod.__class__.__name__ == 'type'
# functools.partialmethod.__qualname__ == 'partialmethod' (len 13)
#
# partialmethod is a pure-Python class defined in Lib/functools.py;
# its metaclass is the built-in type; it inherits only from object.
# New to extra137.
# ---------------------------------------------------------------------------

table functools_extra137.partialmethod_class_identity:
  description: "functools.partialmethod class identity: __name__=='partialmethod', __module__=='functools', __class__.__name__=='type', __qualname__ len==13; wave 257; new to extra137"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartialmethod137

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_name_eq,
       "partialmethod.__name__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — partialmethod is a Python class defined with 'class partialmethod:' in Lib/functools.py; the __name__ attribute of a class equals the identifier after 'class'; str.__eq__('partialmethod') returns True; new to extra137"]
    - [partialmethod_module_eq_functools,
       "partialmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in Lib/functools.py; the class __module__ reflects the defining module; str.__eq__('functools') returns True; new to extra137"]
    - [partialmethod_class_name_eq_type,
       "partialmethod.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partialmethod.__class__.__name__.__eq__('type') == True — partialmethod is a class (not a function); its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra137"]
    - [partialmethod_qualname_len_eq_13,
       "partialmethod.__qualname__.__len__",
       [],
       13,
       "functools.partialmethod.__qualname__.__len__() == 13 — __qualname__ is 'partialmethod' (13 characters); partialmethod is defined at module scope so qualname equals the class name; len('partialmethod') == 13; new to extra137"]
    - [partialmethod_qualname_eq,
       "partialmethod.__qualname__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__.__eq__('partialmethod') == True — partialmethod is defined at module scope in Lib/functools.py; __qualname__ is the simple class name 'partialmethod'; str.__eq__('partialmethod') returns True; new to extra137"]

# ---------------------------------------------------------------------------
# Table 2: functools.partialmethod MRO and bases
#
# Wave 257 theme: functools.partialmethod MRO and base class identity.
#
# functools.partialmethod.__bases__[0].__name__ == 'object'
# len(functools.partialmethod.__mro__) == 2
#
# partialmethod has no explicit base class declaration; it inherits from
# object; the MRO is [partialmethod, object] with length 2. New to extra137.
# ---------------------------------------------------------------------------

table functools_extra137.partialmethod_mro_bases:
  description: "functools.partialmethod __bases__[0].__name__=='object', MRO len==2; inherits only from object; wave 257; new to extra137"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartialmethod137

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_bases_first_eq_object,
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — partialmethod is defined without explicit base class; it inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra137"]
    - [partialmethod_mro_len_eq_2,
       "partialmethod.__mro__.__len__",
       [],
       2,
       "functools.partialmethod.__mro__.__len__() == 2 — the MRO of partialmethod is [partialmethod, object]; it has exactly two entries; len(__mro__) is 2; new to extra137"]
    - [partialmethod_get_qualname_eq,
       "partialmethod.__get__.__qualname__.__eq__",
       ["partialmethod.__get__"],
       true,
       "functools.partialmethod.__get__.__qualname__.__eq__('partialmethod.__get__') == True — partialmethod.__get__ is a descriptor method defined inside the class body in Lib/functools.py; its __qualname__ includes the enclosing class name; str.__eq__('partialmethod.__get__') returns True; new to extra137"]
    - [partialmethod_get_qualname_len_eq_21,
       "partialmethod.__get__.__qualname__.__len__",
       [],
       21,
       "functools.partialmethod.__get__.__qualname__.__len__() == 21 — __qualname__ is 'partialmethod.__get__' which is 21 characters long; len('partialmethod.__get__') == 21; new to extra137"]
    - [partialmethod_get_class_name_eq_function,
       "partialmethod.__get__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.partialmethod.__get__.__class__.__name__.__eq__('function') == True — partialmethod.__get__ is a regular Python function defined inside the class body; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra137"]

# ---------------------------------------------------------------------------
# Table 3: functools.partialmethod slot qualnames (__init__, __repr__, __new__)
#
# Wave 257 theme: partialmethod slot qualnames reveal implementation details.
#
# functools.partialmethod.__init__.__qualname__ == 'object.__init__' (len 15)
# functools.partialmethod.__repr__.__qualname__ == '_partial_repr' (len 13)
# functools.partialmethod.__new__.__qualname__ == '_partial_new' (len 12)
#
# partialmethod does not define its own __init__; it inherits object.__init__.
# __repr__ and __new__ are assigned from module-level helper functions.
# New to extra137.
# ---------------------------------------------------------------------------

table functools_extra137.partialmethod_slot_qualnames:
  description: "functools.partialmethod slot qualnames: __init__ inherits object.__init__ (len 15), __repr__ is '_partial_repr' (len 13), __new__ is '_partial_new' (len 12); wave 257; new to extra137"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartialmethod137

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_init_qualname_eq,
       "partialmethod.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "functools.partialmethod.__init__.__qualname__.__eq__('object.__init__') == True — partialmethod does not override __init__; it inherits object.__init__; the inherited method's __qualname__ is 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra137"]
    - [partialmethod_init_qualname_len_eq_15,
       "partialmethod.__init__.__qualname__.__len__",
       [],
       15,
       "functools.partialmethod.__init__.__qualname__.__len__() == 15 — __qualname__ is 'object.__init__' which is 15 characters; len('object.__init__') == 15; new to extra137"]
    - [partialmethod_repr_qualname_eq,
       "partialmethod.__repr__.__qualname__.__eq__",
       ["_partial_repr"],
       true,
       "functools.partialmethod.__repr__.__qualname__.__eq__('_partial_repr') == True — partialmethod.__repr__ is assigned from the module-level function '_partial_repr' defined in Lib/functools.py; its qualname reflects the def statement at module scope; str.__eq__('_partial_repr') returns True; new to extra137"]
    - [partialmethod_repr_qualname_len_eq_13,
       "partialmethod.__repr__.__qualname__.__len__",
       [],
       13,
       "functools.partialmethod.__repr__.__qualname__.__len__() == 13 — __qualname__ is '_partial_repr' which is 13 characters; len('_partial_repr') == 13; new to extra137"]
    - [partialmethod_new_qualname_eq,
       "partialmethod.__new__.__qualname__.__eq__",
       ["_partial_new"],
       true,
       "functools.partialmethod.__new__.__qualname__.__eq__('_partial_new') == True — partialmethod.__new__ is assigned from the module-level function '_partial_new' defined in Lib/functools.py; its qualname reflects the def statement at module scope; str.__eq__('_partial_new') returns True; new to extra137"]
    - [partialmethod_new_qualname_len_eq_12,
       "partialmethod.__new__.__qualname__.__len__",
       [],
       12,
       "functools.partialmethod.__new__.__qualname__.__len__() == 12 — __qualname__ is '_partial_new' which is 12 characters; len('_partial_new') == 12; new to extra137"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra137
# ---------------------------------------------------------------------------

invariant functools_extra137.partialmethod_name:
  description: "functools.partialmethod.__name__ == 'partialmethod' — class defined with 'class partialmethod:' in Lib/functools.py; wave 257; new to extra137"
  kind: python_call_eq
  function: partialmethod.__name__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra137.partialmethod_class_name:
  description: "functools.partialmethod.__class__.__name__ == 'type' — partialmethod is a class, not a function; wave 257; new to extra137"
  kind: python_call_eq
  function: partialmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra137.partialmethod_mro_len:
  description: "len(functools.partialmethod.__mro__) == 2 — MRO is [partialmethod, object]; wave 257; new to extra137"
  kind: python_call_eq
  function: partialmethod.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra137.partialmethod_get_qualname_len:
  description: "len(functools.partialmethod.__get__.__qualname__) == 21 — qualname is 'partialmethod.__get__'; wave 257; new to extra137"
  kind: python_call_eq
  function: partialmethod.__get__.__qualname__.__len__
  args: []
  expected: 21

invariant functools_extra137.partialmethod_repr_qualname:
  description: "functools.partialmethod.__repr__.__qualname__ == '_partial_repr' — __repr__ assigned from module-level helper; wave 257; new to extra137"
  kind: python_call_eq
  function: partialmethod.__repr__.__qualname__.__eq__
  args: ["_partial_repr"]
  expected: true
