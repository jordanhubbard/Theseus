spec: marshal_extra4
version: ">=3.9"
backend: python_module(marshal)

docs: https://docs.python.org/3/library/marshal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/marshal.html — Python marshal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/marshal.c (CPython internals)"
    - "marshal.zspec.zsdl — covers function __name__ (dumps/loads/dump/load), version == 5 and >= 1, dumps/loads byte-level scalars (0/1/-1/None/True/False/42/'hello'), error cases."
    - "marshal_extra.zspec.zsdl — covers version.__class__.__name__=='int', version >= 4, dumps returns bytes for str/list/None, roundtrip str/list."
    - "marshal_extra2.zspec.zsdl — covers version >= 2, dumps returns bytes for True/False/3.14/-1, roundtrip True/False/-1, __qualname__ for all four functions."
    - "marshal_extra3.zspec.zsdl — covers function __module__ (all 'marshal'), version >= 3 and <= 10, dumps returns bytes for empty string and empty list, dumps exact bytes for empty string and int 100, roundtrip empty list/empty tuple (class check)/int 100."
  notes:
    - "This spec extends marshal.zspec.zsdl through marshal_extra3.zspec.zsdl with additional new vectors."
    - "marshal.{dumps,loads,dump,load}.__class__.__name__ == 'builtin_function_or_method' — all four callables are C-level builtins. No prior spec asserts this class name."
    - "marshal.loads(hex fb30) == {} — fb30 is the FLAG_REF-tagged empty dict encoding (0xfb = 0x7b | FLAG_REF). Both 7b30 and fb30 decode to {}; only 7b30 was covered by marshal_extra3's roundtrip.empty_dict."
    - "marshal.dumps(b'hello') returns 10 bytes — the bytes type uses tag 0x73 ('s') with a 4-byte length prefix: 73 05000000 68656c6c6f. marshal.dumps(b'hello').__len__() == 10."
    - "marshal.loads(marshal.dumps(b'hello')) == b'hello' — bytes object round-trip. Pre-computed hex f30500000068656c6c6f (FLAG_REF variant) and 730500000068656c6c6f (plain variant) both decode to b'hello'."
    - "All expected values verified with Python 3.12 and 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __class__.__name__ == 'builtin_function_or_method' for all four callables
#
# No prior marshal spec checks the callable type (__class__.__name__) of the
# four marshal functions. All four are C-level builtins from the marshal C
# extension, so their __class__.__name__ is 'builtin_function_or_method'
# (not 'function', which would indicate a pure-Python callable).
# This is accessed via the dotted function attribute chain, which the runtime
# traverses correctly for module attributes.
# ---------------------------------------------------------------------------

table marshal_extra4.function_class_names:
  kind: python_call_eq
  category: function_types
  id_prefix: fcls

  columns: [id, function, args, expected]
  rows:
    - [dumps, dumps.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [loads, loads.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [dump,  dump.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [load,  load.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# loads for FLAG_REF-tagged empty dict — hex fb30
#
# marshal_extra3.roundtrip.empty_dict covers loads(7b30) == [].
# The tag byte 0xfb (= 0x7b | 0x80) is the FLAG_REF variant of the empty
# dict encoding, generated when the dict object has been seen before. Both
# encodings are valid and both must decode to {}. This invariant confirms
# that the FLAG_REF variant also round-trips correctly.
# ---------------------------------------------------------------------------

invariant marshal_extra4.roundtrip.empty_dict_flagref:
  description: "marshal.loads(hex fb30) == {} — FLAG_REF-tagged empty dict encoding also decodes to {}"
  category: roundtrip
  kind: python_call_eq
  function: loads
  args: [!hex fb30]
  expected: {}

# ---------------------------------------------------------------------------
# dumps(b'hello') result length
#
# No prior marshal spec passes a bytes object to dumps. marshal.dumps(b'hello')
# returns 10 bytes using the bytes/string tag (0x73) with a 4-byte LE length
# prefix (05 00 00 00) followed by the 5 payload bytes ('hello').
# The __len__ method is a single attribute accessible via getattr(), so
# method: __len__ works correctly on bytes results.
# ---------------------------------------------------------------------------

invariant marshal_extra4.dumps.bytes_obj_length:
  description: "marshal.dumps(b'hello').__len__() == 10 — bytes tag + 4-byte length prefix + 5 payload bytes"
  category: dumps_length
  kind: python_call_eq
  function: dumps
  args: [!ascii "hello"]
  method: __len__
  method_args: []
  expected: 10

# ---------------------------------------------------------------------------
# loads round-trip for bytes b'hello'
#
# Pre-computed plain variant: marshal.dumps(b'hello') == hex 730500000068656c6c6f
# (tag 0x73 for bytes, 4-byte little-endian length 5, then 'hello').
# The expected value is b'hello' expressed as !ascii "hello" (5 ASCII bytes).
# No prior marshal spec tests loads of a bytes-tagged value.
# ---------------------------------------------------------------------------

invariant marshal_extra4.roundtrip.bytes_hello:
  description: "marshal.loads(hex 730500000068656c6c6f) == b'hello' — bytes object round-trip"
  category: roundtrip
  kind: python_call_eq
  function: loads
  args: [!hex 730500000068656c6c6f]
  expected: !ascii "hello"
