spec: underscore
version: ">=1.13.0"
backend: node(underscore)

docs: https://underscorejs.org/

provenance:
  derived_from:
    - "underscore documentation — https://underscorejs.org/"
    - "Test vectors verified with underscore via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "underscore source"
  notes:
    - "underscore is an npm package. Install: npm install underscore"
    - "Sibling library to lodash with a similar but distinct API; #13 most-depended-upon."
    - "All invariants here are pure: collection helpers, predicates, object utilities."
    - "_.flatten() is shallow by default; _.flatten(arr, false) (or _.flattenDeep in lodash) is deep."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions — no IO, no exceptions on normal inputs, deterministic given input value."
  stderr: "null"
  stickiness: "N/A — each call is independent."
  codes: {}

# ── Array helpers ───────────────────────────────────────────────────────────

table underscore.arrays:
  kind: node_module_call_eq
  category: arrays
  id_prefix: arr

  columns: [id, function, args, expected]
  rows:
    - [first_of_three,    first,    [[1, 2, 3]],            1]
    - [last_of_three,     last,     [[1, 2, 3]],            3]
    - [first_n,           first,    [[1, 2, 3, 4], 2],      [1, 2]]
    - [initial_drops_last,initial,  [[1, 2, 3]],            [1, 2]]
    - [rest_drops_first,  rest,     [[1, 2, 3]],            [2, 3]]
    - [flatten_deep,      flatten,  [[1, [2, [3, [4]]]]],   [1, 2, 3, 4]]
    - [uniq_dedupes,      uniq,     [[1, 2, 2, 3, 3, 3]],   [1, 2, 3]]
    - [range_two_args,    range,    [1, 5],                  [1, 2, 3, 4]]
    - [range_with_step,   range,    [0, 10, 2],              [0, 2, 4, 6, 8]]
    - [without_filters,   without,  [[1, 2, 3, 4], 2, 4],    [1, 3]]
    - [union_all,         union,    [[1, 2], [2, 3], [3, 4]],[1, 2, 3, 4]]
    - [intersection,      intersection, [[1, 2, 3], [2, 3, 4]], [2, 3]]
    - [difference,        difference,   [[1, 2, 3, 4], [2, 4]], [1, 3]]
    - [zip_two,           zip,      [[1, 2], ["a", "b"]],   [[1, "a"], [2, "b"]]]

# ── Object helpers ──────────────────────────────────────────────────────────

table underscore.objects:
  kind: node_module_call_eq
  category: objects
  id_prefix: obj

  columns: [id, function, args, expected]
  rows:
    - [keys,        keys,    [{a: 1, b: 2}],               ["a", "b"]]
    - [values,      values,  [{a: 1, b: 2}],               [1, 2]]
    - [pairs,       pairs,   [{a: 1}],                      [["a", 1]]]
    - [invert,      invert,  [{a: 1, b: 2}],               {"1": "a", "2": "b"}]
    - [size_of_obj, size,    [{a: 1, b: 2, c: 3}],         3]
    - [size_of_arr, size,    [[1, 2, 3, 4]],                4]
    - [pick,        pick,    [{a: 1, b: 2, c: 3}, "a", "c"], {a: 1, c: 3}]
    - [omit,        omit,    [{a: 1, b: 2, c: 3}, "b"],     {a: 1, c: 3}]

# ── Predicates ──────────────────────────────────────────────────────────────

table underscore.predicates:
  kind: node_module_call_eq
  category: predicates
  id_prefix: pred

  columns: [id, function, args, expected]
  rows:
    - [is_array_true,     isArray,   [[1, 2]],          true]
    - [is_array_false,    isArray,   ["str"],           false]
    - [is_object_true,    isObject,  [{a: 1}],          true]
    - [is_object_false,   isObject,  [42],              false]
    - [is_string_true,    isString,  ["x"],             true]
    - [is_number_true,    isNumber,  [42],              true]
    - [is_function_false, isFunction, [42],             false]
    - [is_null_true,      isNull,    [~],               true]
    - [is_undefined_arr,  isUndefined, [[]],            false]
    - [is_empty_arr,      isEmpty,   [[]],              true]
    - [is_empty_obj,      isEmpty,   [{}],              true]
    - [is_empty_str,      isEmpty,   [""],              true]
    - [is_empty_one_item, isEmpty,   [[1]],             false]

# ── Identity / utility ──────────────────────────────────────────────────────

invariant underscore.identity:
  kind: node_module_call_eq
  category: util
  function: identity
  args: [42]
  expected: 42

invariant underscore.identity_string:
  kind: node_module_call_eq
  category: util
  function: identity
  args: ["hello"]
  expected: "hello"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:01:37Z
  iterations: 1
  pass_count: 37
  fail_count: 0
  total_invariants: 37
  notes: Synthesis succeeded in 1 iteration(s). 37 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
