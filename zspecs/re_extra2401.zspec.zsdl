spec: re_extra2401
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __hash__ and __eq__ implementation type classification for re module classes."
    - "re.Pattern defines its own __hash__ in C (slot wrapper 'of re.Pattern objects'), distinct from object.__hash__."
    - "re.Match inherits __hash__ from object (slot wrapper 'of object objects') — it does not define its own."
    - "re.error inherits __hash__ from object via the exception hierarchy."
    - "re.RegexFlag inherits __hash__ from int (slot wrapper 'of int objects') — RegexFlag is an IntFlag subclass."
    - "All four classes show __hash__.__class__.__name__ == 'wrapper_descriptor' but differ in which C type owns the slot."
    - "re.Pattern.__hash__ is object.__hash__ == False — Pattern has its own C hash slot."
    - "re.Match.__hash__ is object.__hash__ == True — Match inherits identity hash from object."
    - "re.RegexFlag.__hash__ is int.__hash__ == True — RegexFlag uses int's hash (value-based)."
    - "re.error is the same object as re.PatternError in Python 3.13+ (re.error was renamed but aliased)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __hash__ and __eq__ implementation type — all are wrapper_descriptor
#
# Every re class uses C-level slot wrappers for __hash__ and __eq__, but
# the owning C type differs: Pattern has its own slot, Match and error
# inherit from object, and RegexFlag inherits from int.
# ---------------------------------------------------------------------------

table re_extra2401.hash_class_names:
  kind: python_call_eq
  category: hash_eq_type
  id_prefix: re2401

  columns: [id, function, args, expected]
  rows:
    - ["re2401001", "re.Pattern.__hash__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]
    - ["re2401002", "re.Pattern.__eq__.__class__.__name__.__eq__",     ["wrapper_descriptor"], true]
    - ["re2401003", "re.Match.__hash__.__class__.__name__.__eq__",     ["wrapper_descriptor"], true]
    - ["re2401004", "re.Match.__eq__.__class__.__name__.__eq__",       ["wrapper_descriptor"], true]
    - ["re2401005", "re.error.__hash__.__class__.__name__.__eq__",     ["wrapper_descriptor"], true]
    - ["re2401006", "re.error.__eq__.__class__.__name__.__eq__",       ["wrapper_descriptor"], true]
    - ["re2401007", "re.RegexFlag.__hash__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["re2401008", "re.RegexFlag.__eq__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# __hash__ slot ownership — which C type owns the slot
#
# re.Pattern has its own C hash slot (not shared with object).
# re.Match and re.error inherit from object.
# re.RegexFlag inherits from int (value-based hash).
# ---------------------------------------------------------------------------

table re_extra2401.hash_slot_ownership:
  kind: python_call_eq
  category: hash_slot_identity
  id_prefix: re2401

  columns: [id, function, args, expected]
  rows:
    - ["re2401009",  "re.Pattern.__dict__.__contains__",  ["__hash__"], true]
    - ["re2401010",  "re.Match.__dict__.__contains__",    ["__hash__"], false]
    - ["re2401011",  "re.error.__dict__.__contains__",    ["__hash__"], false]
    - ["re2401012",  "re.RegexFlag.__dict__.__contains__", ["__hash__"], false]

# ---------------------------------------------------------------------------
# __eq__ slot ownership — __dict__ membership
#
# re.Pattern defines its own __eq__ in C for compiled-pattern equality.
# re.Match and re.error rely on object's identity-based __eq__.
# re.RegexFlag defines __eq__ (as an IntFlag subclass, it overrides __eq__
# for flag combination comparisons).
# ---------------------------------------------------------------------------

table re_extra2401.eq_slot_ownership:
  kind: python_call_eq
  category: eq_slot_identity
  id_prefix: re2401

  columns: [id, function, args, expected]
  rows:
    - ["re2401013", "re.Pattern.__dict__.__contains__",   ["__eq__"], true]
    - ["re2401014", "re.Match.__dict__.__contains__",     ["__eq__"], false]
    - ["re2401015", "re.error.__dict__.__contains__",     ["__eq__"], false]

# ---------------------------------------------------------------------------
# re.error / re.PatternError alias — same object in Python 3.13+
# ---------------------------------------------------------------------------

table re_extra2401.error_alias:
  kind: python_call_eq
  category: class_identity
  id_prefix: re2401

  columns: [id, function, args, expected]
  rows:
    - ["re2401016", "re.error.__name__.__eq__",        ["PatternError"], true]
    - ["re2401017", "re.PatternError.__name__.__eq__", ["PatternError"], true]
    - ["re2401018", "re.error.__module__.__eq__",      ["re"],           true]
    - ["re2401019", "re.Pattern.__name__.__eq__",      ["Pattern"],      true]
    - ["re2401020", "re.Match.__name__.__eq__",        ["Match"],        true]
    - ["re2401021", "re.RegexFlag.__name__.__eq__",    ["RegexFlag"],    true]
