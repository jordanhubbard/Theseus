spec: multiprocessing_extra160
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.AsyncResult

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec covers: multiprocessing.pool.AsyncResult (alias for ApplyResult) class identity and method qualnames, and multiprocessing.pool.IMapIterator class identity. Key finding: multiprocessing.pool.AsyncResult.__name__=='ApplyResult' (NOT 'AsyncResult' — AsyncResult is an alias for ApplyResult; the class's actual __name__ is 'ApplyResult', len=11: 'Apply'=5+'Result'=6=11); multiprocessing.pool.AsyncResult.__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20); multiprocessing.pool.AsyncResult.__bases__[0].__name__=='object' (ApplyResult inherits from object directly); AsyncResult method qualnames all start with 'ApplyResult.' (not 'AsyncResult.') because the class's own __name__ is 'ApplyResult'; IMapIterator.__name__=='IMapIterator' (len=12: 'IMap'=4+'Iterator'=8=12); IMapIterator.__module__=='multiprocessing.pool' (same module as ApplyResult/AsyncResult); IMapIterator.__bases__[0].__name__=='object'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.AsyncResult is multiprocessing.pool.ApplyResult — AsyncResult is a name alias for the ApplyResult class; the class's actual __name__ attribute is 'ApplyResult' (len=11), NOT 'AsyncResult'; multiprocessing.pool.AsyncResult.__name__=='ApplyResult' (confirmed in Python 3.14.3); all method qualnames reflect the actual class name 'ApplyResult.': get.__qualname__=='ApplyResult.get' (len=15: 'ApplyResult'=11+'.'=1+'get'=3=15); wait.__qualname__=='ApplyResult.wait' (len=16); ready.__qualname__=='ApplyResult.ready' (len=17); successful.__qualname__=='ApplyResult.successful' (len=22). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.AsyncResult method qualname length ordering: get(15) < wait(16) < ready(17) < successful(22); 'get'=3 < 'wait'=4 < 'ready'=5 < 'successful'=10; the 'ApplyResult.'=12 prefix (11+1=12) is constant; successful (22) is much longer than ready (17) because 'successful'=10 vs 'ready'=5 (5 char difference), giving a 5-char qualname difference: 22=17+5; get(15) is the shortest because 'get'=3 is the shortest method name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.IMapIterator.__name__=='IMapIterator' (len=12: 'IMap'=4+'Iterator'=8=12); IMapIterator is used by Pool.imap() and Pool.imap_unordered(); IMapIterator.__module__=='multiprocessing.pool' (len=20; same module as AsyncResult/ApplyResult and Pool); IMapIterator.__bases__[0].__name__=='object' (IMapIterator inherits from object); IMapUnorderedIterator.__bases__[0].__name__=='IMapIterator' (IMapUnorderedIterator inherits from IMapIterator — it is a subclass that yields results in completion order rather than submission order); 'IMapIterator' (len=12) < 'IMapUnorderedIterator' (len=21) by 9 chars. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.AsyncResult (ApplyResult) class identity — extra160
#
# multiprocessing.pool.AsyncResult.__name__.__eq__('ApplyResult')            == True
# multiprocessing.pool.AsyncResult.__module__.__eq__('multiprocessing.pool') == True
# multiprocessing.pool.AsyncResult.__bases__[0].__name__.__eq__('object')    == True
# ---------------------------------------------------------------------------

table multiprocessing_extra160.mp_async_result_class_identity:
  description: "multiprocessing.pool.AsyncResult class identity checks in mpasync160 namespace — multiprocessing.pool.AsyncResult.__name__=='ApplyResult' (len=11: 'Apply'=5+'Result'=6=11; KEY FINDING: AsyncResult is an alias for ApplyResult; the class's actual __name__ attribute is 'ApplyResult' not 'AsyncResult' — AsyncResult is a second name bound to the same class object; Pool.apply_async() returns an ApplyResult/AsyncResult instance); multiprocessing.pool.AsyncResult.__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20; ApplyResult/AsyncResult is defined in Lib/multiprocessing/pool.py; compare: Pool.__module__=='multiprocessing.pool' (same module); 'multiprocessing.pool' (len=20) < 'multiprocessing.context' (len=23) — pool submodule path is shorter); multiprocessing.pool.AsyncResult.__bases__[0].__name__=='object' (ApplyResult inherits from object directly — same as Pool.__bases__[0].__name__=='object' established in prior specs); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpasync160

  columns: [id, function, args, expected, description]
  rows:
    - [ar_name_eq,   multiprocessing.pool.AsyncResult.__name__.__eq__,                ["ApplyResult"],          true,  "mp.pool.AsyncResult.__name__ == 'ApplyResult' (alias name; actual __name__ is 'ApplyResult' not 'AsyncResult'); verified with Python 3.14.3"]
    - [ar_mod_eq,    multiprocessing.pool.AsyncResult.__module__.__eq__,               ["multiprocessing.pool"], true,  "mp.pool.AsyncResult.__module__ == 'multiprocessing.pool' (len=20; pool submodule); verified with Python 3.14.3"]
    - [ar_base_eq,   "multiprocessing.pool.AsyncResult.__bases__[0].__name__.__eq__",  ["object"],               true,  "mp.pool.AsyncResult.__bases__[0].__name__ == 'object' (ApplyResult inherits from object directly); verified with Python 3.14.3"]
    - [ar_name_len,  multiprocessing.pool.AsyncResult.__name__.__len__,                [],                       11,    "mp.pool.AsyncResult.__name__.__len__() == 11 ('ApplyResult'; actual class name len); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.AsyncResult method qualnames (get, wait) — extra160
#
# AsyncResult.get.__qualname__.__eq__('ApplyResult.get')   == True
# AsyncResult.wait.__qualname__.__eq__('ApplyResult.wait') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra160.mp_async_result_get_wait_qualnames:
  description: "multiprocessing.pool.AsyncResult.get and wait method qualname checks in mpasyncgw160 namespace — AsyncResult.get.__qualname__=='ApplyResult.get' (len=15: 'ApplyResult'=11+'.'=1+'get'=3=15; NOTE: qualname uses 'ApplyResult' not 'AsyncResult' because the class's actual __name__ is 'ApplyResult'; get() retrieves the result when it is ready, optionally blocking for timeout seconds; if the remote call raised an exception, get() re-raises it); AsyncResult.wait.__qualname__=='ApplyResult.wait' (len=16: 'ApplyResult'=11+'.'=1+'wait'=4=16; wait() waits until the result is ready or the optional timeout expires; unlike get(), wait() does not return the result — it only waits; 'wait'=4 > 'get'=3 so wait qualname(16) > get qualname(15) by 1); qualname prefix 'ApplyResult.'=12 (11+1=12) is the same for all method qualnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpasyncgw160

  columns: [id, function, args, expected, description]
  rows:
    - [ar_get_qn_eq,    multiprocessing.pool.AsyncResult.get.__qualname__.__eq__,   ["ApplyResult.get"],   true,  "mp.pool.AsyncResult.get.__qualname__ == 'ApplyResult.get' (len=15; qualname uses class's actual __name__); verified with Python 3.14.3"]
    - [ar_wait_qn_eq,   multiprocessing.pool.AsyncResult.wait.__qualname__.__eq__,  ["ApplyResult.wait"],  true,  "mp.pool.AsyncResult.wait.__qualname__ == 'ApplyResult.wait' (len=16; 1 longer than get=15); verified with Python 3.14.3"]
    - [ar_get_qn_len,   multiprocessing.pool.AsyncResult.get.__qualname__.__len__,  [],                    15,    "mp.pool.AsyncResult.get.__qualname__.__len__() == 15 ('ApplyResult.get'; shortest method qualname); verified with Python 3.14.3"]
    - [ar_wait_qn_len,  multiprocessing.pool.AsyncResult.wait.__qualname__.__len__, [],                    16,    "mp.pool.AsyncResult.wait.__qualname__.__len__() == 16 ('ApplyResult.wait'; 'wait'=4 > 'get'=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.IMapIterator class identity — extra160
#
# IMapIterator.__name__.__eq__('IMapIterator')            == True
# IMapIterator.__module__.__eq__('multiprocessing.pool') == True
# IMapIterator.__bases__[0].__name__.__eq__('object')     == True
# ---------------------------------------------------------------------------

table multiprocessing_extra160.mp_imap_iterator_identity:
  description: "multiprocessing.pool.IMapIterator class identity checks in mpimapi160 namespace — multiprocessing.pool.IMapIterator.__name__=='IMapIterator' (len=12: 'IMap'=4+'Iterator'=8=12; IMapIterator is the iterator class returned by Pool.imap(); it allows iterating over results as worker processes complete them in submission order); multiprocessing.pool.IMapIterator.__module__=='multiprocessing.pool' (len=20: same submodule as AsyncResult/ApplyResult and Pool; 'multiprocessing.pool'=20: 'multiprocessing'=15+'.'=1+'pool'=4=20); multiprocessing.pool.IMapIterator.__bases__[0].__name__=='object' (IMapIterator inherits from object directly); compare: IMapUnorderedIterator.__bases__[0].__name__=='IMapIterator' (IMapUnorderedIterator subclasses IMapIterator — used by Pool.imap_unordered() which yields results in completion order rather than submission order); 'IMapIterator' (len=12) < 'IMapUnorderedIterator' (len=21) by 9 chars; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpimapi160

  columns: [id, function, args, expected, description]
  rows:
    - [imi_name_eq,   multiprocessing.pool.IMapIterator.__name__.__eq__,                ["IMapIterator"],          true,  "mp.pool.IMapIterator.__name__ == 'IMapIterator' (len=12; used by Pool.imap()); verified with Python 3.14.3"]
    - [imi_mod_eq,    multiprocessing.pool.IMapIterator.__module__.__eq__,               ["multiprocessing.pool"],  true,  "mp.pool.IMapIterator.__module__ == 'multiprocessing.pool' (len=20; same module as AsyncResult/ApplyResult); verified with Python 3.14.3"]
    - [imi_base_eq,   "multiprocessing.pool.IMapIterator.__bases__[0].__name__.__eq__",  ["object"],                true,  "mp.pool.IMapIterator.__bases__[0].__name__ == 'object' (inherits from object directly); verified with Python 3.14.3"]
    - [imi_name_len,  multiprocessing.pool.IMapIterator.__name__.__len__,                [],                        12,    "mp.pool.IMapIterator.__name__.__len__() == 12 ('IMapIterator'; 9 shorter than IMapUnorderedIterator=21); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra160
# ---------------------------------------------------------------------------

invariant multiprocessing_extra160.mp_AsyncResult_name_is_ApplyResult:
  description: "multiprocessing.pool.AsyncResult.__name__.__eq__('ApplyResult') returns True — KEY FINDING: multiprocessing.pool.AsyncResult is a name alias for the ApplyResult class; the class's actual __name__ attribute is 'ApplyResult' (len=11: 'Apply'=5+'Result'=6=11), NOT 'AsyncResult'; in Python, class.__name__ always returns the class's own name as defined (via 'class ApplyResult'), not the alias name; 'AsyncResult' is merely a second binding to the same class object (multiprocessing.pool.AsyncResult is multiprocessing.pool.ApplyResult evaluates to True); Pool.apply_async() returns an ApplyResult instance that supports get(), wait(), ready(), and successful(); compare: multiprocessing.pool.IMapIterator.__name__=='IMapIterator' (len=12; 1 longer than ApplyResult=11); NEW in extra160: first standalone mp.pool.AsyncResult.__name__ identity invariant in mpasync160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.AsyncResult.__name__.__eq__
  args: ["ApplyResult"]
  expected: true

invariant multiprocessing_extra160.mp_AsyncResult_module_eq:
  description: "multiprocessing.pool.AsyncResult.__module__.__eq__('multiprocessing.pool') returns True — multiprocessing.pool.AsyncResult (alias for ApplyResult) is defined in Lib/multiprocessing/pool.py; __module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20); compare module lengths in the multiprocessing family: pool (len=20) < context (len=23) < process (len=24); 'multiprocessing.pool' (len=20) is 3 chars shorter than 'multiprocessing.context' (len=23) because 'pool'=4 < 'context'=7 (3 chars shorter); Pool, ApplyResult/AsyncResult, IMapIterator, and IMapUnorderedIterator all share __module__=='multiprocessing.pool'; NEW in extra160: first standalone mp.pool.AsyncResult.__module__ identity invariant in mpasync160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.AsyncResult.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra160.mp_AsyncResult_get_qualname_eq:
  description: "multiprocessing.pool.AsyncResult.get.__qualname__.__eq__('ApplyResult.get') returns True — AsyncResult.get is defined on ApplyResult (the class's actual name); get.__qualname__=='ApplyResult.get' (len=15: 'ApplyResult'=11+'.'=1+'get'=3=15); the qualname uses 'ApplyResult' not 'AsyncResult' because the class's actual __name__ is 'ApplyResult'; get(timeout=None) retrieves the computation result, blocking up to timeout seconds if not ready; if the remote call raised an exception, get() re-raises it in the calling process; get qualname (len=15) is the shortest among the four AsyncResult method qualnames: get(15) < wait(16) < ready(17) < successful(22); the 'ApplyResult.'=12 prefix (11+1) is constant; NEW in extra160: first standalone mp.pool.AsyncResult.get.__qualname__ identity invariant in mpasyncgw160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.AsyncResult.get.__qualname__.__eq__
  args: ["ApplyResult.get"]
  expected: true

invariant multiprocessing_extra160.mp_IMapIterator_name_eq:
  description: "multiprocessing.pool.IMapIterator.__name__.__eq__('IMapIterator') returns True — multiprocessing.pool.IMapIterator is the iterator class returned by Pool.imap(); IMapIterator.__name__=='IMapIterator' (len=12: 'IMap'=4+'Iterator'=8=12; 'I'=1 prefix stands for iterator-mode map; 'Map'=3 indicates it maps a function over an iterable; 'Iterator'=8 indicates it is an iterator object); IMapIterator yields results one at a time in the same order as the input arguments (submission order); IMapIterator.__module__=='multiprocessing.pool' (len=20; same module as ApplyResult/AsyncResult and Pool); IMapIterator.__bases__[0].__name__=='object' (inherits from object); compare: IMapUnorderedIterator.__name__=='IMapUnorderedIterator' (len=21; IMapUnorderedIterator inherits from IMapIterator and yields in completion order rather than submission order); 'IMapIterator' (len=12) < 'IMapUnorderedIterator' (len=21); NEW in extra160: first standalone mp.pool.IMapIterator.__name__ identity invariant in mpimapi160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.IMapIterator.__name__.__eq__
  args: ["IMapIterator"]
  expected: true

invariant multiprocessing_extra160.mp_IMapIterator_base_is_object:
  description: "multiprocessing.pool.IMapIterator.__bases__[0].__name__.__eq__('object') returns True — multiprocessing.pool.IMapIterator inherits from object; __bases__[0].__name__=='object' (len=6); IMapIterator is a stand-alone class in multiprocessing.pool — it does not inherit from any other multiprocessing class; contrast: IMapUnorderedIterator.__bases__[0].__name__=='IMapIterator' (IMapUnorderedIterator IS-A IMapIterator — the unordered variant inherits from the ordered iterator); Pool.imap() returns an IMapIterator; Pool.imap_unordered() returns an IMapUnorderedIterator; both use the pool's worker processes to compute results but differ in the order results are yielded; IMapIterator (base=object) vs Pool (base=object) — both pool result classes inherit from object directly; NEW in extra160: first standalone mp.pool.IMapIterator.__bases__[0].__name__ identity invariant in mpimapi160 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.IMapIterator.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
