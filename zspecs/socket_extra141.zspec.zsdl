spec: socket_extra141
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra140.zspec.zsdl — covers socket.socket method_descriptor __doc__ lengths (recv/send/bind/connect/listen/setsockopt/getsockopt/sendall/recvfrom/accept) / socket.socket method __qualname__ lengths (table + invariants)."
    - "socket_extra139.zspec.zsdl — covers socket.socket.__eq__/__hash__ qualnames / socket.socket.family and type as property descriptors / socket.socket class __name__/__module__/__mro__ / socket.getfqdn and create_connection __doc__ lengths."
    - "socket_extra138.zspec.zsdl — covers socket.socket.__doc__ identity and content / socket.__spec__ and __loader__ attribute identity / socket.herror and socket.gaierror exception class identity / socket.getfqdn and create_connection qualnames."
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO class identity."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout __class__.__name__=='builtin_function_or_method'."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra140."
    - "Wave 296 theme: socket.socket class __doc__ length / socket.gethostname/__doc__/__len__() / socket.gethostbyname/__doc__/__len__() / socket.getaddrinfo/__doc__/__len__() / socket.setdefaulttimeout/__doc__/__len__() / socket.getdefaulttimeout/__doc__/__len__() / __doc__.__class__.__name__ checks."
    - "socket.socket.__doc__.__len__() == 58. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__doc__.__len__() == 54. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__doc__.__len__() == 106. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__doc__.__len__() == 658. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__doc__.__len__() == 224. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__doc__.__len__() == 232. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.__doc__ (58 chars) is 'A subclass of _socket.socket adding the makefile() method.' — the Python-level socket class (Lib/socket.py) wraps the C-level _socket.socket with a short description. This is the class's own docstring, distinct from all its method docstrings."
    - "Note: socket.getaddrinfo (658 chars) is by far the longest docstring in this group — it fully describes the 5-tuple result format, the host/port argument semantics for IPv4/IPv6/None, and how the family/type/proto filtering arguments work."
    - "Note: socket.gethostname (54) is shorter than socket.gethostbyname (106) even though gethostbyname accepts an argument. gethostname has no parameters to document; gethostbyname documents the host argument and the return value format '255.255.255.255'."
    - "Note: socket.setdefaulttimeout (224) and socket.getdefaulttimeout (232) have very similar docstrings — they share a common description of the timeout semantics and None behavior. getdefaulttimeout (232) is 8 chars longer because its docstring uses 'Returns' instead of 'Set'/'Sets' and 'Returns the default timeout in seconds (float)' is slightly longer than the setter description."
    - "Note: socket.getaddrinfo.__class__.__name__ is 'function' (Python-level in Lib/socket.py), while gethostname and gethostbyname are 'builtin_function_or_method' (C-level from socketmodule.c). This explains the difference in docstring style."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__doc__.__len__()==58
# socket.gethostname.__doc__.__len__()==54
# socket.gethostbyname.__doc__.__len__()==106
# socket.getaddrinfo.__doc__.__len__()==658
#
# Wave 296 theme: socket.socket class and main host-resolution function __doc__ lengths.
#
# socket.socket.__doc__ (58) describes the Python-level class as a subclass of
# _socket.socket adding makefile(). socket.getaddrinfo (658) is by far the
# longest — it fully describes the 5-tuple format and filtering semantics.
# gethostname (54) is shorter than gethostbyname (106) because it takes no
# arguments. No prior socket spec anchors these __doc__ lengths under sockdoc141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra141.socket_class_and_host_function_doc_lengths:
  description: "socket.socket/__doc__/__len__()==58 / gethostname/__doc__/__len__()==54 / gethostbyname/__doc__/__len__()==106 / getaddrinfo/__doc__/__len__()==658 — socket.socket (58) describes Python wrapper adding makefile(); gethostname (54) takes no args; gethostbyname (106) documents host arg and IP format; getaddrinfo (658) is the longest, fully describing 5-tuple result and filtering; no prior socket spec anchors these; first sockdoc141 anchor"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: sockdoc141

  columns: [id, function, args, expected, description]
  rows:
    - [socket_class_doc_len,   socket.__doc__.__len__,      [], 58,  "socket.socket.__doc__.__len__() is 58 ('A subclass of _socket.socket adding the makefile() method.')"]
    - [gethostname_doc_len,    gethostname.__doc__.__len__,  [], 54,  "socket.gethostname.__doc__.__len__() is 54 (no arguments; 'gethostname() -> string\\n\\nReturn the current host name.')"]
    - [gethostbyname_doc_len,  gethostbyname.__doc__.__len__, [], 106, "socket.gethostbyname.__doc__.__len__() is 106 (documents host argument and '255.255.255.255' return format)"]
    - [getaddrinfo_doc_len,    getaddrinfo.__doc__.__len__,   [], 658, "socket.getaddrinfo.__doc__.__len__() is 658 (longest in this group; describes 5-tuple format, IPv4/IPv6/None host, family/type/proto filtering)"]

# ---------------------------------------------------------------------------
# socket.setdefaulttimeout.__doc__.__len__()==224
# socket.getdefaulttimeout.__doc__.__len__()==232
#
# Wave 296 theme: socket.setdefaulttimeout and getdefaulttimeout __doc__ lengths.
#
# setdefaulttimeout (224) and getdefaulttimeout (232) have very similar docstrings
# sharing the common description of timeout semantics and the None sentinel.
# getdefaulttimeout (232) is 8 chars longer. No prior socket spec anchors
# these __doc__ lengths under sockdoc141. (extra99 covers their __qualname__.__len__().)
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra141.timeout_function_doc_lengths:
  description: "socket.setdefaulttimeout/__doc__/__len__()==224 / getdefaulttimeout/__doc__/__len__()==232 — both share timeout semantics and None-means-no-timeout description; getdefaulttimeout (232) is 8 chars longer than setdefaulttimeout (224); extra99 covers their qualname lengths; __doc__ lengths are fresh under sockdoc141"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: sockdoc141

  columns: [id, function, args, expected, description]
  rows:
    - [setdefaulttimeout_doc_len, setdefaulttimeout.__doc__.__len__, [], 224, "socket.setdefaulttimeout.__doc__.__len__() is 224 (documents timeout in seconds/float and None=no-timeout semantics)"]
    - [getdefaulttimeout_doc_len, getdefaulttimeout.__doc__.__len__, [], 232, "socket.getdefaulttimeout.__doc__.__len__() is 232 (8 chars longer than setdefaulttimeout; same semantics but 'Returns' phrasing)"]

# ---------------------------------------------------------------------------
# socket.socket.__doc__.__class__.__name__.__eq__('str')
# socket.gethostname.__doc__.__class__.__name__.__eq__('str')
# socket.gethostbyname.__doc__.__class__.__name__.__eq__('str')
# socket.getaddrinfo.__doc__.__class__.__name__.__eq__('str')
# socket.setdefaulttimeout.__doc__.__class__.__name__.__eq__('str')
# socket.getdefaulttimeout.__doc__.__class__.__name__.__eq__('str')
#
# Wave 296 theme: __doc__.__class__.__name__ == 'str' for socket class and functions.
#
# All six subjects have str docstrings. gethostname, gethostbyname, setdefaulttimeout,
# getdefaulttimeout are C-level builtin_function_or_method objects with str docstrings.
# getaddrinfo and socket.socket are Python-level (Lib/socket.py) with str docstrings.
# No prior socket spec anchors all six __doc__.__class__.__name__ checks together
# under sockdoc141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra141.socket_function_doc_class:
  description: "socket.socket/__doc__/__class__.__name__.__eq__('str')==True / gethostname/__doc__/__class__.__name__.__eq__('str')==True / gethostbyname/__doc__/__class__.__name__.__eq__('str')==True / getaddrinfo/__doc__/__class__.__name__.__eq__('str')==True / setdefaulttimeout/__doc__/__class__.__name__.__eq__('str')==True / getdefaulttimeout/__doc__/__class__.__name__.__eq__('str')==True — all six have str docstrings; C-level builtins (gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout) and Python-level (getaddrinfo/socket) both use str; no prior socket spec anchors all six; first sockdoc141 anchor"
  kind: python_call_eq
  category: doc_identity
  id_prefix: sockdoc141

  columns: [id, function, args, expected, description]
  rows:
    - [socket_class_doc_class,       socket.__doc__.__class__.__name__.__eq__,            ["str"], true, "socket.socket.__doc__.__class__.__name__ == 'str' (Python-level class in Lib/socket.py)"]
    - [gethostname_doc_class,        gethostname.__doc__.__class__.__name__.__eq__,        ["str"], true, "socket.gethostname.__doc__.__class__.__name__ == 'str' (C-level builtin_function_or_method)"]
    - [gethostbyname_doc_class,      gethostbyname.__doc__.__class__.__name__.__eq__,      ["str"], true, "socket.gethostbyname.__doc__.__class__.__name__ == 'str' (C-level builtin_function_or_method)"]
    - [getaddrinfo_doc_class,        getaddrinfo.__doc__.__class__.__name__.__eq__,        ["str"], true, "socket.getaddrinfo.__doc__.__class__.__name__ == 'str' (Python-level function in Lib/socket.py)"]
    - [setdefaulttimeout_doc_class,  setdefaulttimeout.__doc__.__class__.__name__.__eq__,  ["str"], true, "socket.setdefaulttimeout.__doc__.__class__.__name__ == 'str' (C-level builtin_function_or_method)"]
    - [getdefaulttimeout_doc_class,  getdefaulttimeout.__doc__.__class__.__name__.__eq__,  ["str"], true, "socket.getdefaulttimeout.__doc__.__class__.__name__ == 'str' (C-level builtin_function_or_method)"]

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__doc__.__len__()==658 — standalone
#
# socket.getaddrinfo.__doc__.__len__() is 658. The getaddrinfo docstring is
# by far the longest of the host-resolution and socket-class functions examined
# in this spec. It describes: the 5-tuple output format (family, type, proto,
# canonname, sockaddr), the semantics of None as host (maps to NULL in the C API),
# the semantics of None as port (maps to NULL), the optional family/type/proto
# filtering arguments, and the zero-means-no-filter behavior. No prior socket spec
# anchors socket.getaddrinfo.__doc__.__len__()==658 as a standalone under sockdoc141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra141.getaddrinfo_doc_len_658:
  description: "socket.getaddrinfo.__doc__.__len__() == 658 — longest docstring in this spec's group (658 chars); describes 5-tuple output format, None host/port semantics mapping to C NULL, family/type/proto filtering, and zero-means-no-filter behavior; Python-level function in Lib/socket.py; no prior socket spec anchors this as a standalone; first standalone under sockdoc141"
  category: doc_lengths
  kind: python_call_eq
  function: getaddrinfo.__doc__.__len__
  args: []
  expected: 658

# ---------------------------------------------------------------------------
# socket.gethostname.__doc__.__len__()==54 — standalone
#
# socket.gethostname.__doc__.__len__() is 54. The gethostname docstring is:
# 'gethostname() -> string\n\nReturn the current host name.' (54 chars including
# the newlines). It is the shortest of the host-resolution function docstrings
# examined in this spec — shorter even than socket.socket.__doc__ (58).
# gethostname takes no arguments, making its documentation minimal. No prior socket
# spec anchors socket.gethostname.__doc__.__len__()==54 as a standalone under
# sockdoc141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra141.gethostname_doc_len_54:
  description: "socket.gethostname.__doc__.__len__() == 54 — shortest of the host-resolution function docstrings in this spec (54 chars); 'gethostname() -> string\\n\\nReturn the current host name.'; no arguments to document; shorter than socket.socket.__doc__ (58); C-level builtin_function_or_method; no prior socket spec anchors this as a standalone; first standalone under sockdoc141"
  category: doc_lengths
  kind: python_call_eq
  function: gethostname.__doc__.__len__
  args: []
  expected: 54

# ---------------------------------------------------------------------------
# socket.socket.__doc__.__len__()==58 — standalone
#
# socket.socket.__doc__.__len__() is 58. The socket.socket class docstring is
# 'A subclass of _socket.socket adding the makefile() method.' (58 chars). This
# is the Python-level socket class (defined in Lib/socket.py) that wraps the
# C-level _socket.socket with additional Python functionality. The docstring
# explicitly names the one additional method (makefile) that the Python subclass
# adds beyond the C base class. No prior socket spec anchors socket.socket.__doc__
# .__len__()==58 as a standalone under sockdoc141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra141.socket_class_doc_len_58:
  description: "socket.socket.__doc__.__len__() == 58 — 'A subclass of _socket.socket adding the makefile() method.' (58 chars); explicitly names makefile() as the one Python-level addition to the C base; Python-level class in Lib/socket.py; 4 chars longer than gethostname (54); no prior socket spec anchors this as a standalone; first standalone under sockdoc141"
  category: doc_lengths
  kind: python_call_eq
  function: socket.__doc__.__len__
  args: []
  expected: 58

# ---------------------------------------------------------------------------
# socket.gethostbyname.__doc__.__len__()==106 — standalone
#
# socket.gethostbyname.__doc__.__len__() is 106. The gethostbyname docstring is:
# "gethostbyname(host) -> address\n\nReturn the IP address (a string of the form
# '255.255.255.255') for a host." (106 chars). It documents the host argument,
# the return type signature '-> address', and the '255.255.255.255' format
# example in single quotes. No prior socket spec anchors
# socket.gethostbyname.__doc__.__len__()==106 as a standalone under sockdoc141.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra141.gethostbyname_doc_len_106:
  description: "socket.gethostbyname.__doc__.__len__() == 106 — 'gethostbyname(host) -> address\\n\\nReturn the IP address (a string of the form \\'255.255.255.255\\') for a host.' (106 chars); documents host arg, return type, and '255.255.255.255' format example; C-level builtin_function_or_method; no prior socket spec anchors this as a standalone; first standalone under sockdoc141"
  category: doc_lengths
  kind: python_call_eq
  function: gethostbyname.__doc__.__len__
  args: []
  expected: 106

# ---------------------------------------------------------------------------
# socket.setdefaulttimeout.__doc__.__len__()==224 — standalone
#
# socket.setdefaulttimeout.__doc__.__len__() is 224. The setdefaulttimeout
# docstring documents: the timeout argument in seconds (float), the None sentinel
# meaning no timeout, and the fact that the default is None at import time.
# At 224 chars it is 8 chars shorter than getdefaulttimeout (232). No prior socket
# spec anchors socket.setdefaulttimeout.__doc__.__len__()==224 as a standalone
# under sockdoc141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra141.setdefaulttimeout_doc_len_224:
  description: "socket.setdefaulttimeout.__doc__.__len__() == 224 — documents timeout in seconds (float), None-means-no-timeout sentinel, and default-is-None-at-import behavior; 8 chars shorter than getdefaulttimeout (232); C-level builtin_function_or_method; no prior socket spec anchors this as a standalone; first standalone under sockdoc141"
  category: doc_lengths
  kind: python_call_eq
  function: setdefaulttimeout.__doc__.__len__
  args: []
  expected: 224

# ---------------------------------------------------------------------------
# socket.getdefaulttimeout.__doc__.__len__()==232 — standalone
#
# socket.getdefaulttimeout.__doc__.__len__() is 232. The getdefaulttimeout
# docstring mirrors setdefaulttimeout in describing the timeout semantics (seconds
# as float, None = no timeout, default None at import). At 232 chars it is 8 chars
# longer than setdefaulttimeout (224) because the getter description uses slightly
# different phrasing ('Returns the default timeout' vs 'Set the default timeout').
# No prior socket spec anchors socket.getdefaulttimeout.__doc__.__len__()==232
# as a standalone under sockdoc141. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra141.getdefaulttimeout_doc_len_232:
  description: "socket.getdefaulttimeout.__doc__.__len__() == 232 — mirrors setdefaulttimeout semantics (timeout in seconds/float, None sentinel, default None); 8 chars longer than setdefaulttimeout (224) due to phrasing difference; C-level builtin_function_or_method; no prior socket spec anchors this as a standalone; first standalone under sockdoc141"
  category: doc_lengths
  kind: python_call_eq
  function: getdefaulttimeout.__doc__.__len__
  args: []
  expected: 232
