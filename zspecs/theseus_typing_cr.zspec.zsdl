spec: theseus_typing_cr
version: ">=3.8"
backend: python_cleanroom(theseus_typing_cr)
blocks: typing

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/typing.html"
  not_derived_from:
    - "CPython source: Lib/typing.py (internal implementation)"
  notes:
    - "Clean-room typing module. Do NOT import typing."
    - "Type aliases and generic types for static type checking."
    - "Optional, Union, List, Dict, Tuple, Set, Any, Callable."
    - "TypeVar, Generic, Protocol, ClassVar, Final."
    - "get_type_hints, cast, overload."

error_model: python_exceptions

invariant theseus_typing_cr.typing2_optional:
  description: "Optional[int] is equivalent to Union[int, None]"
  category: Optional
  kind: python_call_eq
  function: typing2_optional
  args: []
  expected: true

invariant theseus_typing_cr.typing2_typevar:
  description: "TypeVar creates a type variable with the given name"
  category: TypeVar
  kind: python_call_eq
  function: typing2_typevar
  args: []
  expected: "T"

invariant theseus_typing_cr.typing2_cast:
  description: "cast returns the value unchanged at runtime"
  category: cast
  kind: python_call_eq
  function: typing2_cast
  args: []
  expected: 42
