spec: asyncio_extra2071
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "asyncio types (Task, Future, Event, Lock, Queue) are concurrency primitives, not numeric or copy-protocol types."
    - "None of these types define __pos__, __neg__, __getattribute__, __reduce__, __reduce_ex__, __copy__, or __deepcopy__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2071.unary_sign_protocol:
  description: "asyncio types __pos__/__neg__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2071

  columns: [id, function, args, expected]
  rows:
    - ["as2071001", "asyncio.Task.__dict__.__contains__", ["__pos__"], false]
    - ["as2071002", "asyncio.Task.__dict__.__contains__", ["__neg__"], false]
    - ["as2071003", "asyncio.Future.__dict__.__contains__", ["__pos__"], false]
    - ["as2071004", "asyncio.Future.__dict__.__contains__", ["__neg__"], false]
    - ["as2071005", "asyncio.Event.__dict__.__contains__", ["__pos__"], false]
    - ["as2071006", "asyncio.Event.__dict__.__contains__", ["__neg__"], false]
    - ["as2071007", "asyncio.Lock.__dict__.__contains__", ["__pos__"], false]
    - ["as2071008", "asyncio.Lock.__dict__.__contains__", ["__neg__"], false]
    - ["as2071009", "asyncio.Queue.__dict__.__contains__", ["__pos__"], false]
    - ["as2071010", "asyncio.Queue.__dict__.__contains__", ["__neg__"], false]

