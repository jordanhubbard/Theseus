spec: theseus_tabnanny_cr
version: ">=3.0"
backend: python_cleanroom(theseus_tabnanny_cr)
blocks: tabnanny

docs: https://docs.python.org/3/library/tabnanny.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tabnanny.html"
  not_derived_from:
    - "CPython source: Lib/tabnanny.py"
  notes:
    - "Clean-room tabnanny module. Do NOT import tabnanny."

error_model: python_exceptions

invariant theseus_tabnanny_cr.tabnanny2_nannynag:
  description: "NannyNag exception class exists"
  category: behavior
  kind: python_call_eq
  function: tabnanny2_nannynag
  args: []
  expected: true

invariant theseus_tabnanny_cr.tabnanny2_check:
  description: "check() function exists and is callable"
  category: behavior
  kind: python_call_eq
  function: tabnanny2_check
  args: []
  expected: true

invariant theseus_tabnanny_cr.tabnanny2_process_tokens:
  description: "process_tokens() detects indentation issues"
  category: behavior
  kind: python_call_eq
  function: tabnanny2_process_tokens
  args: []
  expected: true
