spec: pathlib_extra1141
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath __weakref__.__class__.__name__ and WindowsPath __module__/__qualname__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.PurePath/__weakref__/__class__.__name__, pathlib.PurePosixPath/__weakref__/__class__.__name__, pathlib.PureWindowsPath/__weakref__/__class__.__name__, pathlib.Path/__weakref__/__class__.__name__, pathlib.PosixPath/__weakref__/__class__.__name__, pathlib.WindowsPath/__module__/__qualname__; none of these were covered in _extra1111 or _extra1126"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1141.purepath_family_weakref_class_names:
  description: "pathlib PurePath-family class __weakref__.__class__.__name__ checks — all must be getset_descriptor"
  kind: python_call_eq
  category: purepath_family_weakref_class_names
  id_prefix: pl1141pw
  columns: [id, function, args, expected]
  rows:
    - [pl1141pw001, pathlib.PurePath.__weakref__.__class__.__name__.__eq__,       ["getset_descriptor"], true]
    - [pl1141pw002, pathlib.PurePosixPath.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"], true]
    - [pl1141pw003, pathlib.PureWindowsPath.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [pl1141pw004, pathlib.PurePath.__weakref__.__class__.__name__.__eq__,       ["member_descriptor"],  false]
    - [pl1141pw005, pathlib.PurePosixPath.__weakref__.__class__.__name__.__eq__,  ["str"],               false]
    - [pl1141pw006, pathlib.PureWindowsPath.__weakref__.__class__.__name__.__eq__, ["str"],               false]
    - [pl1141pw007, pathlib.PurePath.__weakref__.__class__.__name__.__eq__,       ["getset_descriptor"], true]

table pathlib_extra1141.path_and_posixpath_weakref_class_names:
  description: "pathlib.Path and pathlib.PosixPath __weakref__.__class__.__name__ checks"
  kind: python_call_eq
  category: path_and_posixpath_weakref_class_names
  id_prefix: pl1141pp
  columns: [id, function, args, expected]
  rows:
    - [pl1141pp001, pathlib.Path.__weakref__.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [pl1141pp002, pathlib.PosixPath.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [pl1141pp003, pathlib.Path.__weakref__.__class__.__name__.__eq__,     ["str"],               false]
    - [pl1141pp004, pathlib.PosixPath.__weakref__.__class__.__name__.__eq__, ["member_descriptor"], false]
    - [pl1141pp005, pathlib.Path.__weakref__.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [pl1141pp006, pathlib.PosixPath.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [pl1141pp007, pathlib.Path.__weakref__.__class__.__module__.__eq__,   ["builtins"],          true]
    - [pl1141pp008, pathlib.PosixPath.__weakref__.__class__.__module__.__eq__, ["builtins"],        true]

table pathlib_extra1141.windowspath_identity:
  description: "pathlib.WindowsPath __module__, __qualname__, and __name__ checks"
  kind: python_call_eq
  category: windowspath_identity
  id_prefix: pl1141wi
  columns: [id, function, args, expected]
  rows:
    - [pl1141wi001, pathlib.WindowsPath.__module__.__eq__,   ["pathlib"],     true]
    - [pl1141wi002, pathlib.WindowsPath.__qualname__.__eq__, ["WindowsPath"], true]
    - [pl1141wi003, pathlib.WindowsPath.__name__.__eq__,     ["WindowsPath"], true]
    - [pl1141wi004, pathlib.WindowsPath.__module__.__eq__,   ["_pathlib"],    false]
    - [pl1141wi005, pathlib.WindowsPath.__qualname__.__eq__, ["Path"],        false]
    - [pl1141wi006, pathlib.WindowsPath.__name__.__class__.__name__.__eq__,   ["str"], true]
    - [pl1141wi007, pathlib.WindowsPath.__module__.__class__.__name__.__eq__, ["str"], true]
    - [pl1141wi008, pathlib.WindowsPath.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
