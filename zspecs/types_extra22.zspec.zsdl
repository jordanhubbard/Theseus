spec: types_extra22
version: ">=3.10"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types_extra21.zspec.zsdl — covers combined __qualname__.__eq__ table for FunctionType/LambdaType/GeneratorType/CoroutineType/ModuleType/MethodType/SimpleNamespace/MappingProxyType; standalone invariants for FunctionType/LambdaType/SimpleNamespace/MappingProxyType."
    - "types_extra7.zspec.zsdl — covers UnionType/__qualname__ == 'Union' and UnionType/__module__."
    - "types_extra6.zspec.zsdl — covers __qualname__ for CellType/CodeType/FrameType/TracebackType/NoneType/EllipsisType/NotImplementedType."
    - "types_extra5.zspec.zsdl — covers __qualname__ for FunctionType/MethodType/GeneratorType/CoroutineType/ModuleType/BuiltinFunctionType/AsyncGeneratorType/LambdaType/SimpleNamespace/MappingProxyType/DynamicClassAttribute."
  notes:
    - "This spec extends types_extra21.zspec.zsdl."
    - "Focus: combined __qualname__.__eq__ table for FunctionType/MethodType/GeneratorType/CoroutineType/AsyncGeneratorType/ModuleType/NoneType/SimpleNamespace/MappingProxyType/UnionType in the extra22 namespace; standalone invariants for AsyncGeneratorType and NoneType in the extra22 namespace."
    - "types.FunctionType.__qualname__ == 'function' — C-level function type."
    - "types.MethodType.__qualname__ == 'method' — C-level method type."
    - "types.GeneratorType.__qualname__ == 'generator' — C-level generator type."
    - "types.CoroutineType.__qualname__ == 'coroutine' — C-level coroutine type."
    - "types.AsyncGeneratorType.__qualname__ == 'async_generator' — C-level async generator type."
    - "types.ModuleType.__qualname__ == 'module' — C-level module type."
    - "types.NoneType.__qualname__ == 'NoneType' — C-level NoneType."
    - "types.SimpleNamespace.__qualname__ == 'SimpleNamespace' — C-level SimpleNamespace."
    - "types.MappingProxyType.__qualname__ == 'mappingproxy' — C-level mappingproxy type."
    - "types.UnionType.__qualname__ == 'Union' — C-level union type (Python 3.10+); covered in types_extra7 but re-anchored here in the extra22 combined table."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ combined table for core types module classes
# (types_extra22 namespace)
#
# types_extra21 covers eight of these in the extra21 namespace.
# types_extra7 covers UnionType.__qualname__ as a standalone.
# This table combines all ten into one in the extra22 namespace, adding
# AsyncGeneratorType and UnionType which were not in the extra21 table.
# ---------------------------------------------------------------------------

table types_extra22.qualnames:
  description: "__qualname__.__eq__ for core types module class types in the extra22 namespace"
  kind: python_call_eq
  category: type_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [FunctionType,       FunctionType.__qualname__.__eq__,       ["function"],        true]
    - [MethodType,         MethodType.__qualname__.__eq__,         ["method"],          true]
    - [GeneratorType,      GeneratorType.__qualname__.__eq__,      ["generator"],       true]
    - [CoroutineType,      CoroutineType.__qualname__.__eq__,      ["coroutine"],       true]
    - [AsyncGeneratorType, AsyncGeneratorType.__qualname__.__eq__, ["async_generator"], true]
    - [ModuleType,         ModuleType.__qualname__.__eq__,         ["module"],          true]
    - [NoneType,           NoneType.__qualname__.__eq__,           ["NoneType"],        true]
    - [SimpleNamespace,    SimpleNamespace.__qualname__.__eq__,    ["SimpleNamespace"], true]
    - [MappingProxyType,   MappingProxyType.__qualname__.__eq__,   ["mappingproxy"],    true]
    - [UnionType,          UnionType.__qualname__.__eq__,          ["Union"],           true]

# ---------------------------------------------------------------------------
# types.AsyncGeneratorType.__qualname__ == 'async_generator' — standalone
# (types_extra22 namespace)
#
# types_extra14 covers AsyncGeneratorType.__qualname__.__eq__ as a standalone
# in the extra14 namespace. types_extra5 covers it in a table. Providing a
# standalone in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant types_extra22.AsyncGeneratorType.qualname:
  description: "types.AsyncGeneratorType.__qualname__ == 'async_generator' — C-level type name"
  category: type_qualnames
  kind: python_call_eq
  function: AsyncGeneratorType.__qualname__.__eq__
  args: ["async_generator"]
  expected: true

# ---------------------------------------------------------------------------
# types.NoneType.__qualname__ == 'NoneType' — standalone (types_extra22 namespace)
#
# types_extra15 covers NoneType.__qualname__.__eq__ as a standalone in the
# extra15 namespace. types_extra6 covers it in a table. Providing a standalone
# in the extra22 namespace.
# ---------------------------------------------------------------------------

invariant types_extra22.NoneType.qualname:
  description: "types.NoneType.__qualname__ == 'NoneType' — C-level type name"
  category: type_qualnames
  kind: python_call_eq
  function: NoneType.__qualname__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# types.UnionType.__qualname__ == 'Union' — standalone (types_extra22 namespace)
#
# types_extra7 covers UnionType.__qualname__ as a standalone in the extra7
# namespace. Re-anchored here in the extra22 namespace.
# UnionType is only available on Python 3.10+.
# ---------------------------------------------------------------------------

invariant types_extra22.UnionType.qualname:
  description: "types.UnionType.__qualname__ == 'Union' — C-level union type, Python 3.10+"
  category: type_qualnames
  kind: python_call_eq
  function: UnionType.__qualname__.__eq__
  args: ["Union"]
  expected: true
