spec: struct_extra134
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack) / Struct.size and Struct.format __doc__ equality and lengths / struct module __doc__ length (1278) and class (str) (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / Struct.size/__format__ qualname/name lengths and __objclass__.__name__ / Struct.__doc__ length (40) and equality."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__()."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct')."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__()."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance and __module__/__qualname__."
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values / struct.pack/__qualname__ / struct.Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra91 through struct_extra99."
    - "Wave 284 theme: struct.__spec__ attribute identity / Struct method __doc__ lengths / struct.__loader__ class identity."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.name.__eq__('struct') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.name.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.origin.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__doc__.__len__() == 175. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__doc__.__len__() == 190. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__doc__.__len__() == 277. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__doc__.__len__() == 243. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__doc__.__len__() == 196. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__len__() == 40. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__ == 'Struct(fmt) --> compiled struct object\\n\\n' (with trailing newlines). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Struct.pack_into has the longest method docstring (277 chars); Struct.pack has the shortest (175 chars). This mirrors the module-level functions where pack_into (274 chars) is longest and pack (176 chars) shortest — with slight differences because the Struct methods lack the format parameter."
    - "Note: struct.__spec__.name is 'struct' (6 chars); struct.__spec__.origin is a str pointing to Lib/struct.py. struct is a pure-Python wrapper over the _struct C extension."
    - "Note: struct.__loader__.__class__.__name__ is 'SourceFileLoader' (not BuiltinImporter) because struct.py is a thin Python wrapper (Lib/struct.py) even though most of the heavy lifting is done by _struct C extension."
    - "Note: struct.Struct.__doc__ ends with two trailing newlines ('\\n\\n'), so __doc__.__eq__('Struct(fmt) --> compiled struct object') is False. The table and standalone invariants anchor only __class__.__name__ and __len__() to avoid this subtlety."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec')
# struct.__spec__.name.__eq__('struct')
# struct.__spec__.name.__len__()==6
# struct.__spec__.origin.__class__.__name__.__eq__('str')
# struct.__loader__.__class__.__name__.__eq__('SourceFileLoader')
#
# Wave 284 theme: struct.__spec__ and __loader__ attribute identity.
#
# struct.__spec__ is a ModuleSpec. Its name is 'struct' (6 chars). Its origin is
# a str pointing to Lib/struct.py. The loader is a SourceFileLoader because
# struct.py is a thin Python wrapper over the _struct C extension. struct_extra97
# anchors __spec__/__loader__ at attribute lengths; no prior struct spec anchors
# __spec__.__class__.__name__ or __spec__.name equality under structspec134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra134.spec_and_loader_identity:
  description: "struct.__spec__/__class__.__name__.__eq__('ModuleSpec')==True / __spec__.name.__eq__('struct')==True / __spec__.name.__len__()==6 / __spec__.origin/__class__.__name__.__eq__('str')==True / __loader__/__class__.__name__.__eq__('SourceFileLoader')==True — struct.__spec__ is a ModuleSpec; name is 'struct' (6 chars); origin is a str path to Lib/struct.py; loader is SourceFileLoader (struct.py is a Python wrapper over _struct C ext); extra97 anchors lengths; first structspec134 anchor for name/class equality"
  kind: python_call_eq
  category: module_spec
  id_prefix: structspec134

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name,        __spec__.__class__.__name__.__eq__,        ["ModuleSpec"],        true, "struct.__spec__ is a ModuleSpec (importlib.machinery.ModuleSpec)"]
    - [spec_name_eq,           __spec__.name.__eq__,                      ["struct"],            true, "struct.__spec__.name is 'struct' (matches struct.__name__)"]
    - [spec_name_len,          __spec__.name.__len__,                     [],                    6,    "struct.__spec__.name.__len__() is 6 ('struct' = 6 chars)"]
    - [spec_origin_class_name, __spec__.origin.__class__.__name__.__eq__, ["str"],               true, "struct.__spec__.origin is a str (path to Lib/struct.py)"]
    - [loader_class_name,      __loader__.__class__.__name__.__eq__,      ["SourceFileLoader"],  true, "struct.__loader__ is a SourceFileLoader (struct.py is a Python-level wrapper over _struct C ext)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__doc__.__len__()==175
# struct.Struct.unpack.__doc__.__len__()==190
# struct.Struct.pack_into.__doc__.__len__()==277
# struct.Struct.unpack_from.__doc__.__len__()==243
# struct.Struct.iter_unpack.__doc__.__len__()==196
#
# Wave 284 theme: Struct instance method __doc__ lengths.
#
# The five Struct instance methods (pack, unpack, pack_into, unpack_from,
# iter_unpack) all have C-level docstrings from _struct.c. These are distinct
# from the module-level function docstrings (anchored in struct_extra99).
# pack_into has the longest method docstring (277 chars); pack has the shortest
# (175 chars). struct_extra92 anchors their __class__.__name__=='method_descriptor';
# struct_extra94 anchors their __qualname__.__len__(); no prior struct spec
# anchors Struct method __doc__.__len__() values under structspec134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra134.Struct_method_doc_lengths:
  description: "struct.Struct.pack/__doc__/__len__()==175 / Struct.unpack/__doc__/__len__()==190 / Struct.pack_into/__doc__/__len__()==277 / Struct.unpack_from/__doc__/__len__()==243 / Struct.iter_unpack/__doc__/__len__()==196 — all five Struct methods are method_descriptor objects with C-level docstrings from _struct.c; pack_into is longest (277), pack shortest (175); extra92 anchors class names; extra94 anchors qualname lengths; first structspec134 anchor for method __doc__ lengths"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: structspec134

  columns: [id, function, args, expected, description]
  rows:
    - [pack_doc_len,        "Struct.pack.__doc__.__len__",        [], 175, "Struct.pack.__doc__ is 175 chars (C-level docstring from _struct.c for instance pack)"]
    - [unpack_doc_len,      "Struct.unpack.__doc__.__len__",      [], 190, "Struct.unpack.__doc__ is 190 chars (C-level docstring for instance unpack)"]
    - [pack_into_doc_len,   "Struct.pack_into.__doc__.__len__",   [], 277, "Struct.pack_into.__doc__ is 277 chars (longest Struct method docstring, C-level)"]
    - [unpack_from_doc_len, "Struct.unpack_from.__doc__.__len__", [], 243, "Struct.unpack_from.__doc__ is 243 chars (C-level docstring for instance unpack_from)"]
    - [iter_unpack_doc_len, "Struct.iter_unpack.__doc__.__len__", [], 196, "Struct.iter_unpack.__doc__ is 196 chars (C-level docstring for instance iter_unpack)"]

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__class__.__name__.__eq__('str')
# struct.Struct.__doc__.__len__()==40
#
# Wave 284 theme: Struct class __doc__ identity.
#
# struct.Struct.__doc__ is a str of 40 chars from _struct.c. The value ends with
# two trailing newlines, so __doc__.__eq__ is not used here to avoid that subtlety.
# struct_extra91 anchors Struct.__doc__.__class__.__name__=='str'; struct_extra98
# anchors __doc__.__len__==40; this table groups both under structspec134 as a
# cross-check. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra134.Struct_class_doc:
  description: "struct.Struct/__doc__/__class__.__name__.__eq__('str')==True / __doc__/__len__()==40 — Struct.__doc__ is a 40-char C-level str from _struct.c (ends with two trailing newlines, so __eq__ is not tested here); extra91 anchors class name; extra98 anchors length; this table cross-checks both under structspec134"
  kind: python_call_eq
  category: doc_identity
  id_prefix: structspec134

  columns: [id, function, args, expected, description]
  rows:
    - [struct_doc_class, "Struct.__doc__.__class__.__name__.__eq__", ["str"], true, "struct.Struct.__doc__ is a str (C-level type docstring from _struct.c)"]
    - [struct_doc_len,   "Struct.__doc__.__len__",                   [],      40,   "struct.Struct.__doc__.__len__() is 40 chars (includes two trailing newlines)"]

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# struct.__spec__.__class__.__name__ is 'ModuleSpec'. struct is a pure-Python
# wrapper over _struct.c, loaded via SourceFileLoader from Lib/struct.py. Its
# ModuleSpec stores origin (Lib/struct.py path) and no submodule_search_locations
# (struct is not a package). struct_extra97 anchors __spec__ at attribute lengths;
# no prior struct spec anchors __spec__.__class__.__name__ as a standalone under
# structspec134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra134.spec_class_ModuleSpec:
  description: "struct.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — struct.py is loaded via SourceFileLoader from Lib/struct.py; ModuleSpec stores origin path and no submodule_search_locations; extra97 anchors __spec__ at attribute lengths; first standalone for __spec__.__class__.__name__ under structspec134"
  category: module_spec
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__spec__.name.__eq__('struct') — standalone
#
# struct.__spec__.name is 'struct'. The spec name matches struct.__name__.
# ModuleSpec.name is the fully qualified module name used by the import system.
# For struct (a top-level module), the name is simply 'struct' with no package
# prefix. No prior struct spec anchors __spec__.name.__eq__('struct') as a
# standalone under structspec134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra134.spec_name_struct:
  description: "struct.__spec__.name.__eq__('struct') == True — ModuleSpec.name is 'struct', the top-level module name (no package prefix); matches struct.__name__; no prior struct spec anchors this as a standalone; first standalone for __spec__.name equality under structspec134"
  category: module_spec
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# struct.__loader__.__class__.__name__ is 'SourceFileLoader'. Although struct
# has a C extension backend (_struct), the top-level 'struct' module is actually
# a thin Python file (Lib/struct.py) that imports from _struct and re-exports
# symbols. The SourceFileLoader handles this Python-level module file. This is
# different from _struct itself, which would use ExtensionFileLoader.
# No prior struct spec anchors __loader__.__class__.__name__.__eq__('SourceFileLoader')
# as a standalone under structspec134. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra134.loader_class_SourceFileLoader:
  description: "struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — the top-level 'struct' module is Lib/struct.py (a Python wrapper over _struct C ext) loaded by SourceFileLoader; contrast with _struct which uses ExtensionFileLoader; no prior struct spec anchors this as a standalone; first standalone under structspec134"
  category: module_spec
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack_into.__doc__.__len__()==277 — standalone
#
# struct.Struct.pack_into.__doc__.__len__() is 277. This is the longest of the
# five Struct instance method docstrings. pack_into packs values according to
# the format into a writable buffer at the given offset, which requires explaining
# the buffer and offset parameters in detail. No prior struct spec anchors
# Struct.pack_into.__doc__.__len__() as a standalone under structspec134.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra134.Struct_pack_into_doc_len_277:
  description: "struct.Struct.pack_into.__doc__.__len__() == 277 — longest of the five Struct instance method docstrings; pack_into packs values into a writable buffer at a given offset; extra94 anchors pack_into __qualname__.__len__; first standalone for Struct.pack_into.__doc__.__len__() under structspec134"
  category: doc_lengths
  kind: python_call_eq
  function: "Struct.pack_into.__doc__.__len__"
  args: []
  expected: 277

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__class__.__name__.__eq__('str') — standalone
#
# struct.Struct.__doc__.__class__.__name__ is 'str'. The Struct class docstring
# is a C-level str from _struct.c. struct_extra91 anchors this at table level;
# this standalone provides an additional cross-check under structspec134. The
# docstring itself is 40 chars (including two trailing newlines), so this
# confirms it is a non-None str object without testing the exact value.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra134.Struct_doc_class_str:
  description: "struct.Struct.__doc__.__class__.__name__.__eq__('str') == True — Struct.__doc__ is a non-None str from _struct.c (40 chars including two trailing newlines); extra91 anchors at table level; first standalone for Struct.__doc__.__class__.__name__ under structspec134"
  category: doc_identity
  kind: python_call_eq
  function: "Struct.__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true
