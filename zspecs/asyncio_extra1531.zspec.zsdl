spec: asyncio_extra1531
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-future.html — Python asyncio Future and Task documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "Wave 549 theme: comparison operator dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__, __eq__, __hash__ in class __dict__."
    - "asyncio classes are async concurrency primitives — not ordered or value-equality types. None of Queue, Task, Future, Lock, Event, Semaphore, Barrier, or TaskGroup define any comparison operator protocol methods in their own __dict__."
    - "asyncio.Queue does not define comparison operators — Queue is an async FIFO queue; ordering or equality by value is semantically undefined for a queue object."
    - "asyncio.Future does not define __eq__ or __hash__ in its own __dict__ — Future identity equality falls through to the default object.__eq__ inherited from object, not overridden at the Future class level."
    - "asyncio.Task does not define any comparison operators — Task is a Future subclass wrapping a coroutine; comparison is not part of the Task interface."
    - "asyncio.Lock, Event, Semaphore: synchronization primitives — no comparison operators in their __dict__."
    - "asyncio.Barrier: synchronization barrier — no comparison operators in its __dict__."
    - "asyncio.TaskGroup: async context manager grouping tasks — no comparison operators in its __dict__."
    - "Anchor 'true' rows confirm that domain methods ARE present: Queue.qsize, Future.result, Lock.locked, Event.is_set, Semaphore.acquire, Barrier.wait, TaskGroup.create_task, Task.cancel."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Queue and asyncio.Future comparison operator __dict__ absence
#
# asyncio.Queue.__dict__.__contains__('__lt__')   == False
# asyncio.Queue.__dict__.__contains__('__le__')   == False
# asyncio.Queue.__dict__.__contains__('__gt__')   == False
# asyncio.Queue.__dict__.__contains__('__ge__')   == False
# asyncio.Queue.__dict__.__contains__('__ne__')   == False
# asyncio.Queue.__dict__.__contains__('__eq__')   == False
# asyncio.Queue.__dict__.__contains__('__hash__') == False
# asyncio.Queue.__dict__.__contains__('qsize')    == True
# asyncio.Future.__dict__.__contains__('__lt__')  == False
# asyncio.Future.__dict__.__contains__('__eq__')  == False
# asyncio.Future.__dict__.__contains__('result')  == True
# ---------------------------------------------------------------------------

table asyncio_extra1531.queue_future_no_cmp_ops:
  description: "asyncio.Queue and asyncio.Future have no comparison operator methods in their own __dict__ — as1531qf namespace. asyncio.Queue.__dict__.__contains__('__lt__')==False (Queue is an async FIFO queue — it provides put(), get(), qsize() but no comparison operators; ordering between queue objects is semantically meaningless); asyncio.Queue.__dict__.__contains__('__le__')==False (no less-than-or-equal on Queue); asyncio.Queue.__dict__.__contains__('__gt__')==False (no greater-than on Queue); asyncio.Queue.__dict__.__contains__('__ge__')==False (no greater-than-or-equal on Queue); asyncio.Queue.__dict__.__contains__('__ne__')==False (no not-equal on Queue); asyncio.Queue.__dict__.__contains__('__eq__')==False (Queue does not override __eq__ — identity comparison falls through to object); asyncio.Queue.__dict__.__contains__('__hash__')==False (Queue does not override __hash__); asyncio.Queue.__dict__.__contains__('qsize')==True (Queue.qsize() IS defined directly in Queue.__dict__ — returns the number of items); asyncio.Future.__dict__.__contains__('__lt__')==False (Future is an awaitable result container — no ordering operators); asyncio.Future.__dict__.__contains__('__eq__')==False (Future does not override __eq__ in its own __dict__); asyncio.Future.__dict__.__contains__('result')==True (Future.result() IS defined in Future.__dict__); verified with Python 3.14.4"
  kind: python_call_eq
  category: comparison_protocol
  id_prefix: as1531qf

  columns: [id, function, args, expected, description]
  rows:
    - [as1531qf001, asyncio.Queue.__dict__.__contains__,  ["__lt__"],   false, "asyncio.Queue.__dict__.__contains__('__lt__')==False — Queue is an async FIFO queue, not an ordered type; no __lt__ in __dict__; verified with Python 3.14.4"]
    - [as1531qf002, asyncio.Queue.__dict__.__contains__,  ["__le__"],   false, "asyncio.Queue.__dict__.__contains__('__le__')==False — no less-than-or-equal operator on Queue; verified with Python 3.14.4"]
    - [as1531qf003, asyncio.Queue.__dict__.__contains__,  ["__gt__"],   false, "asyncio.Queue.__dict__.__contains__('__gt__')==False — no greater-than operator on Queue; verified with Python 3.14.4"]
    - [as1531qf004, asyncio.Queue.__dict__.__contains__,  ["__ge__"],   false, "asyncio.Queue.__dict__.__contains__('__ge__')==False — no greater-than-or-equal operator on Queue; verified with Python 3.14.4"]
    - [as1531qf005, asyncio.Queue.__dict__.__contains__,  ["__ne__"],   false, "asyncio.Queue.__dict__.__contains__('__ne__')==False — Queue does not override __ne__; verified with Python 3.14.4"]
    - [as1531qf006, asyncio.Queue.__dict__.__contains__,  ["__eq__"],   false, "asyncio.Queue.__dict__.__contains__('__eq__')==False — Queue does not override __eq__ in its own __dict__; identity falls through to object; verified with Python 3.14.4"]
    - [as1531qf007, asyncio.Queue.__dict__.__contains__,  ["__hash__"], false, "asyncio.Queue.__dict__.__contains__('__hash__')==False — Queue does not override __hash__; verified with Python 3.14.4"]
    - [as1531qf008, asyncio.Queue.__dict__.__contains__,  ["qsize"],    true,  "asyncio.Queue.__dict__.__contains__('qsize')==True — qsize() IS defined directly in Queue.__dict__; returns current queue depth; verified with Python 3.14.4"]
    - [as1531qf009, asyncio.Future.__dict__.__contains__, ["__lt__"],   false, "asyncio.Future.__dict__.__contains__('__lt__')==False — Future is an async result container, not an ordered type; no __lt__; verified with Python 3.14.4"]
    - [as1531qf010, asyncio.Future.__dict__.__contains__, ["__eq__"],   false, "asyncio.Future.__dict__.__contains__('__eq__')==False — Future does not override __eq__ in its own __dict__; verified with Python 3.14.4"]
    - [as1531qf011, asyncio.Future.__dict__.__contains__, ["result"],   true,  "asyncio.Future.__dict__.__contains__('result')==True — Future.result() IS defined directly in Future.__dict__; the core retrieval interface; verified with Python 3.14.4"]

