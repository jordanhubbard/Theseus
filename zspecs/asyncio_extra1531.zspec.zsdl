table asyncio_extra1531.task_lock_no_cmp_ops:
  description: "asyncio.Task and asyncio.Lock have no comparison operator methods in their own __dict__ — as1531tl namespace. asyncio.Task.__dict__.__contains__('__lt__')==False (Task is a coroutine-driving Future subclass — comparison operators make no sense for a scheduled coroutine); asyncio.Task.__dict__.__contains__('__le__')==False (no less-than-or-equal on Task); asyncio.Task.__dict__.__contains__('__gt__')==False (no greater-than on Task); asyncio.Task.__dict__.__contains__('__ge__')==False (no greater-than-or-equal on Task); asyncio.Task.__dict__.__contains__('__ne__')==False (no not-equal override on Task); asyncio.Task.__dict__.__contains__('__eq__')==False (Task does not override __eq__); asyncio.Task.__dict__.__contains__('__hash__')==False (Task does not override __hash__); asyncio.Task.__dict__.__contains__('cancel')==True (Task.cancel() IS defined in Task.__dict__ — the coroutine cancellation method); asyncio.Lock.__dict__.__contains__('__lt__')==False (Lock is a mutual exclusion primitive — no ordering operators); asyncio.Lock.__dict__.__contains__('__eq__')==False (Lock does not override __eq__); asyncio.Lock.__dict__.__contains__('locked')==True (Lock.locked() IS defined in Lock.__dict__ — returns True if lock is held); verified with Python 3.14.4"
  kind: python_call_eq
  category: comparison_protocol
  id_prefix: as1531tl

  columns: [id, function, args, expected, description]
  rows:
    - [as1531tl001, asyncio.Task.__dict__.__contains__, ["__lt__"],   false, "asyncio.Task.__dict__.__contains__('__lt__')==False — Task is a coroutine wrapper, not an ordered type; no __lt__; verified with Python 3.14.4"]
    - [as1531tl002, asyncio.Task.__dict__.__contains__, ["__le__"],   false, "asyncio.Task.__dict__.__contains__('__le__')==False — no less-than-or-equal on Task; verified with Python 3.14.4"]
    - [as1531tl003, asyncio.Task.__dict__.__contains__, ["__gt__"],   false, "asyncio.Task.__dict__.__contains__('__gt__')==False — no greater-than on Task; verified with Python 3.14.4"]
    - [as1531tl004, asyncio.Task.__dict__.__contains__, ["__ge__"],   false, "asyncio.Task.__dict__.__contains__('__ge__')==False — no greater-than-or-equal on Task; verified with Python 3.14.4"]
    - [as1531tl005, asyncio.Task.__dict__.__contains__, ["__ne__"],   false, "asyncio.Task.__dict__.__contains__('__ne__')==False — Task does not override __ne__; verified with Python 3.14.4"]
    - [as1531tl006, asyncio.Task.__dict__.__contains__, ["__eq__"],   false, "asyncio.Task.__dict__.__contains__('__eq__')==False — Task does not override __eq__; verified with Python 3.14.4"]
    - [as1531tl007, asyncio.Task.__dict__.__contains__, ["__hash__"], false, "asyncio.Task.__dict__.__contains__('__hash__')==False — Task does not override __hash__; verified with Python 3.14.4"]
    - [as1531tl008, asyncio.Task.__dict__.__contains__, ["cancel"],   true,  "asyncio.Task.__dict__.__contains__('cancel')==True — Task.cancel() IS defined directly in Task.__dict__; the coroutine cancellation method; verified with Python 3.14.4"]
    - [as1531tl009, asyncio.Lock.__dict__.__contains__, ["__lt__"],   false, "asyncio.Lock.__dict__.__contains__('__lt__')==False — Lock is a mutual exclusion primitive; no ordering operators; verified with Python 3.14.4"]
    - [as1531tl010, asyncio.Lock.__dict__.__contains__, ["__eq__"],   false, "asyncio.Lock.__dict__.__contains__('__eq__')==False — Lock does not override __eq__; verified with Python 3.14.4"]
    - [as1531tl011, asyncio.Lock.__dict__.__contains__, ["locked"],   true,  "asyncio.Lock.__dict__.__contains__('locked')==True — Lock.locked() IS defined directly in Lock.__dict__; verified with Python 3.14.4"]

