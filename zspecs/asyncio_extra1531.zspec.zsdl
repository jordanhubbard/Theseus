table asyncio_extra1531.sync_primitives_no_cmp_ops:
  description: "asyncio.Event, Semaphore, Barrier, TaskGroup have no comparison operator methods in their own __dict__ — as1531sp namespace. asyncio.Event.__dict__.__contains__('__lt__')==False (Event is an async signaling primitive — is_set(), set(), clear(), wait() are its interface; no comparison operators); asyncio.Event.__dict__.__contains__('__eq__')==False (Event does not override __eq__); asyncio.Event.__dict__.__contains__('__hash__')==False (Event does not override __hash__); asyncio.Event.__dict__.__contains__('is_set')==True (Event.is_set() IS defined in Event.__dict__); asyncio.Semaphore.__dict__.__contains__('__lt__')==False (Semaphore has an internal counter but exposes no comparison operators — acquire/release manage the counter); asyncio.Semaphore.__dict__.__contains__('__ge__')==False (no greater-than-or-equal on Semaphore); asyncio.Semaphore.__dict__.__contains__('acquire')==True (Semaphore.acquire() IS defined in Semaphore.__dict__); asyncio.Barrier.__dict__.__contains__('__lt__')==False (Barrier is a synchronization point for a fixed number of coroutines; no ordering operators); asyncio.Barrier.__dict__.__contains__('__eq__')==False (Barrier does not override __eq__); asyncio.Barrier.__dict__.__contains__('wait')==True (Barrier.wait() IS defined in Barrier.__dict__); asyncio.TaskGroup.__dict__.__contains__('__lt__')==False (TaskGroup groups tasks as a context manager; no ordering operators); asyncio.TaskGroup.__dict__.__contains__('__hash__')==False (TaskGroup does not override __hash__); asyncio.TaskGroup.__dict__.__contains__('create_task')==True (TaskGroup.create_task() IS defined in TaskGroup.__dict__); verified with Python 3.14.4"
  kind: python_call_eq
  category: comparison_protocol
  id_prefix: as1531sp

  columns: [id, function, args, expected, description]
  rows:
    - [as1531sp001, asyncio.Event.__dict__.__contains__,     ["__lt__"],      false, "asyncio.Event.__dict__.__contains__('__lt__')==False — Event is a signaling primitive, not an ordered type; no __lt__; verified with Python 3.14.4"]
    - [as1531sp002, asyncio.Event.__dict__.__contains__,     ["__eq__"],      false, "asyncio.Event.__dict__.__contains__('__eq__')==False — Event does not override __eq__; verified with Python 3.14.4"]
    - [as1531sp003, asyncio.Event.__dict__.__contains__,     ["__hash__"],    false, "asyncio.Event.__dict__.__contains__('__hash__')==False — Event does not override __hash__; verified with Python 3.14.4"]
    - [as1531sp004, asyncio.Event.__dict__.__contains__,     ["is_set"],      true,  "asyncio.Event.__dict__.__contains__('is_set')==True — Event.is_set() IS defined in Event.__dict__; returns True if the event is set; verified with Python 3.14.4"]
    - [as1531sp005, asyncio.Semaphore.__dict__.__contains__, ["__lt__"],      false, "asyncio.Semaphore.__dict__.__contains__('__lt__')==False — Semaphore counter is managed via acquire/release, not comparison operators; verified with Python 3.14.4"]
    - [as1531sp006, asyncio.Semaphore.__dict__.__contains__, ["__ge__"],      false, "asyncio.Semaphore.__dict__.__contains__('__ge__')==False — no greater-than-or-equal on Semaphore; verified with Python 3.14.4"]
    - [as1531sp007, asyncio.Semaphore.__dict__.__contains__, ["acquire"],     true,  "asyncio.Semaphore.__dict__.__contains__('acquire')==True — Semaphore.acquire() IS defined in Semaphore.__dict__; the core acquisition coroutine; verified with Python 3.14.4"]
    - [as1531sp008, asyncio.Barrier.__dict__.__contains__,   ["__lt__"],      false, "asyncio.Barrier.__dict__.__contains__('__lt__')==False — Barrier is a synchronization point; no ordering operators; verified with Python 3.14.4"]
    - [as1531sp009, asyncio.Barrier.__dict__.__contains__,   ["__eq__"],      false, "asyncio.Barrier.__dict__.__contains__('__eq__')==False — Barrier does not override __eq__; verified with Python 3.14.4"]
    - [as1531sp010, asyncio.Barrier.__dict__.__contains__,   ["wait"],        true,  "asyncio.Barrier.__dict__.__contains__('wait')==True — Barrier.wait() IS defined in Barrier.__dict__; waits until all parties arrive; verified with Python 3.14.4"]
    - [as1531sp011, asyncio.TaskGroup.__dict__.__contains__, ["__lt__"],      false, "asyncio.TaskGroup.__dict__.__contains__('__lt__')==False — TaskGroup groups tasks; no ordering operators; verified with Python 3.14.4"]
    - [as1531sp012, asyncio.TaskGroup.__dict__.__contains__, ["__hash__"],    false, "asyncio.TaskGroup.__dict__.__contains__('__hash__')==False — TaskGroup does not override __hash__; verified with Python 3.14.4"]
    - [as1531sp013, asyncio.TaskGroup.__dict__.__contains__, ["create_task"], true,  "asyncio.TaskGroup.__dict__.__contains__('create_task')==True — TaskGroup.create_task() IS defined in TaskGroup.__dict__; the core task-spawning method; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1531
# ---------------------------------------------------------------------------

invariant asyncio_extra1531.queue_no_lt:
  description: "asyncio.Queue.__dict__.__contains__('__lt__') returns False — asyncio.Queue does not define __lt__ in its own __dict__; Queue is an async FIFO queue used for inter-coroutine communication; its __dict__ contains qsize(), put(), get(), empty(), full(), task_done(), join(), shutdown() — all queue-management methods; no comparison operator protocol methods exist in Queue.__dict__; wave 549 theme: comparison operator dict-presence checks; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: asyncio.Queue.__dict__.__contains__
  args: ["__lt__"]
  expected: false

invariant asyncio_extra1531.future_no_hash:
  description: "asyncio.Future.__dict__.__contains__('__hash__') returns False — asyncio.Future does not define __hash__ in its own __dict__; Future is an awaitable result container representing a pending async computation; its __dict__ contains __await__, result(), set_result(), cancel(), done(), cancelled() — async result-handling interface; __hash__ is not overridden at the Future class level so hashing falls through to the default object identity-based hash; wave 549 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: asyncio.Future.__dict__.__contains__
  args: ["__hash__"]
  expected: false

invariant asyncio_extra1531.task_no_ne:
  description: "asyncio.Task.__dict__.__contains__('__ne__') returns False — asyncio.Task does not define __ne__ in its own __dict__; Task is a Future subclass that schedules and drives a coroutine to completion in the event loop; its __dict__ contains coroutine-management methods (get_coro(), get_context()), cancellation methods (cancel(), cancelling(), uncancel()), and stack-inspection methods (get_stack(), print_stack()) — no comparison operators; wave 549 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: asyncio.Task.__dict__.__contains__
  args: ["__ne__"]
  expected: false

invariant asyncio_extra1531.semaphore_no_le:
  description: "asyncio.Semaphore.__dict__.__contains__('__le__') returns False — asyncio.Semaphore does not define __le__ in its own __dict__; Semaphore maintains an internal counter that is decremented on acquire() and incremented on release(); the counter is managed through acquire/release coroutines, not through Python's comparison operator protocol; __le__ is absent from Semaphore.__dict__; wave 549 theme; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  category: comparison_protocol
  kind: python_call_eq
  function: asyncio.Semaphore.__dict__.__contains__
  args: ["__le__"]
  expected: false
