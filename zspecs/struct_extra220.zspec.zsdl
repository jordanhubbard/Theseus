spec: struct_extra220
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.__doc__.__contains__('struct') == True — module docstring mentions 'struct'."
    - "struct.pack.__doc__.__contains__('pack') == True — pack() docstring mentions 'pack'."
    - "struct.unpack.__doc__.__contains__('unpack') == True — unpack() docstring mentions 'unpack'."
    - "struct.calcsize.__doc__.__contains__('size') == True — calcsize() docstring mentions 'size'."
    - "struct.Struct.__doc__.__contains__('Struct') == True — Struct class docstring mentions 'Struct'."
    - "struct.pack_into.__doc__.__contains__('pack') == True — pack_into() docstring mentions 'pack'."
    - "struct.unpack_from.__doc__.__contains__('unpack') == True — unpack_from() docstring mentions 'unpack'."
    - "struct.iter_unpack.__doc__.__contains__('unpack') == True — iter_unpack() docstring mentions 'unpack'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct __doc__ contains checks
#
# struct.__doc__.__contains__('struct')        == True
# struct.pack.__doc__.__contains__('pack')     == True
# struct.unpack.__doc__.__contains__('unpack') == True
# struct.calcsize.__doc__.__contains__('size') == True
# struct.Struct.__doc__.__contains__('Struct') == True
# struct.pack_into.__doc__.__contains__('pack')    == True
# struct.unpack_from.__doc__.__contains__('unpack') == True
# struct.iter_unpack.__doc__.__contains__('unpack') == True
# ---------------------------------------------------------------------------

table struct_extra220.doc_contains_checks:
  description: "struct __doc__ contains checks in struct220 namespace — wave 220 theme: module docstring contains 'struct'; pack docstring contains 'pack'; unpack docstring contains 'unpack'; calcsize docstring contains 'size'; Struct class docstring contains 'Struct'; pack_into docstring contains 'pack'; unpack_from docstring contains 'unpack'; iter_unpack docstring contains 'unpack'; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: doc_contains
  id_prefix: struct220

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_struct,      struct.__doc__.__contains__,           ["struct"], true, "struct.__doc__.__contains__('struct') == True — module docstring mentions struct"]
    - [pack_doc_pack,          struct.pack.__doc__.__contains__,      ["pack"],   true, "struct.pack.__doc__.__contains__('pack') == True — pack() docstring mentions pack"]
    - [unpack_doc_unpack,      struct.unpack.__doc__.__contains__,    ["unpack"], true, "struct.unpack.__doc__.__contains__('unpack') == True — unpack() docstring mentions unpack"]
    - [calcsize_doc_size,      struct.calcsize.__doc__.__contains__,  ["size"],   true, "struct.calcsize.__doc__.__contains__('size') == True — calcsize() docstring mentions size"]
    - [Struct_doc_Struct,      struct.Struct.__doc__.__contains__,    ["Struct"], true, "struct.Struct.__doc__.__contains__('Struct') == True — Struct class docstring mentions Struct"]
    - [pack_into_doc_pack,     struct.pack_into.__doc__.__contains__, ["pack"],   true, "struct.pack_into.__doc__.__contains__('pack') == True — pack_into() docstring mentions pack"]
    - [unpack_from_doc_unpack, struct.unpack_from.__doc__.__contains__, ["unpack"], true, "struct.unpack_from.__doc__.__contains__('unpack') == True — unpack_from() docstring mentions unpack"]
    - [iter_unpack_doc_unpack, struct.iter_unpack.__doc__.__contains__, ["unpack"], true, "struct.iter_unpack.__doc__.__contains__('unpack') == True — iter_unpack() docstring mentions unpack"]

# ---------------------------------------------------------------------------
# Standalone invariants for struct __doc__ contains checks
# ---------------------------------------------------------------------------

invariant struct_extra220.module_doc_contains_struct:
  description: "struct.__doc__.__contains__('struct') == True — struct module docstring is 'Functions to convert between Python values and C structs...' which contains 'struct'; confirms module docstring is present; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: struct.__doc__.__contains__
  args: ["struct"]
  expected: true

invariant struct_extra220.pack_doc_contains_pack:
  description: "struct.pack.__doc__.__contains__('pack') == True — struct.pack docstring is 'pack(format, v1, v2, ...) -> bytes\\n\\nReturn a bytes object containing the values v1, v2, ... packed according to the format string...' which contains 'pack'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: struct.pack.__doc__.__contains__
  args: ["pack"]
  expected: true

invariant struct_extra220.Struct_doc_contains_Struct:
  description: "struct.Struct.__doc__.__contains__('Struct') == True — Struct class docstring is 'Struct(fmt) --> compiled struct object...' which contains 'Struct'; confirms the class has a descriptive docstring; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: struct.Struct.__doc__.__contains__
  args: ["Struct"]
  expected: true
