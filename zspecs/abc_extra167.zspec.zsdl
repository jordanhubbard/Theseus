spec: abc_extra167
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.__name__=='abc'; abc.__package__=='' (empty string — abc is a frozen module, not a package); abc.__spec__.__class__.__name__=='ModuleSpec'; abc.__loader__.__class__.__name__=='type' (FrozenImporter is itself a class whose metaclass is type); abc.__doc__.__class__.__name__=='str'; abc.__doc__.__contains__('ABC')==True; abc.__doc__.__contains__('Abstract')==True. KEY FINDINGS: abc.__package__=='' (empty string, NOT 'abc' — abc is a frozen top-level module; since it is not a package, __package__ is empty); abc.__loader__ is _frozen_importlib.FrozenImporter (the class itself, not an instance) so abc.__loader__.__class__.__name__=='type' (FrozenImporter is a class, and the class of a class is 'type'); abc.__doc__=='Abstract Base Classes (ABCs) according to PEP 3119.' (the docstring does NOT contain lowercase 'abstract' — only 'Abstract' with capital A and 'ABCs'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__name__=='abc' (len=3: 'a'+'b'+'c'=3); abc.__package__=='' (empty string, len=0; frozen module, not a package — CONTRAST: multiprocessing.__package__=='multiprocessing' (len=15) because multiprocessing IS a package; abc is a top-level module not a package). Verified with Python 3.14.3."
    - "abc.__loader__ is _frozen_importlib.FrozenImporter (the FrozenImporter CLASS, not an instance); abc.__loader__.__class__.__name__=='type' because FrozenImporter is a class whose metaclass is 'type'; compare: abc.__loader__.__name__=='FrozenImporter' (the class's __name__). Verified with Python 3.14.3."
    - "abc.__doc__=='Abstract Base Classes (ABCs) according to PEP 3119.' (full docstring); abc.__doc__.__class__.__name__=='str' (len=3); abc.__doc__.__contains__('ABC')==True; abc.__doc__.__contains__('Abstract')==True; abc.__doc__.__contains__('abstract')==False (lowercase 'abstract' NOT in docstring). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.__name__ and __package__ module identity — extra167
#
# abc.__name__.__eq__('abc')  == True
# abc.__name__.__len__()      == 3
# abc.__package__.__eq__('') == True
# abc.__package__.__len__()  == 0
# ---------------------------------------------------------------------------

table abc_extra167.abc_module_name_and_package:
  description: "abc.__name__ and __package__ module identity checks in abcmodname167 namespace — abc.__name__.__eq__('abc')==True (abc.__name__=='abc' (len=3: 'a'+'b'+'c'=3); the abc module's __name__ is simply 'abc'; abc is a top-level module (not a submodule) so its __name__ has no dots; 'abc'=3 is the shortest module name in this entire spec series: 'abc'=3 < 'asyncio.tasks'=13 < 'asyncio.events'=14 < 'asyncio.runners'=15 < 'multiprocessing.process'=23 < 'concurrent.futures._base'=24); abc.__name__.__len__()==3 ('abc'=3: shortest in spec series); abc.__package__.__eq__('')==True (KEY FINDING: abc.__package__=='' (empty string, len=0); abc is a FROZEN MODULE (not a package directory); since abc is not a package, its __package__ is '' (empty string) rather than 'abc'; CONTRAST: multiprocessing.__package__=='multiprocessing' (IS a package; __package__==__name__); concurrent.futures.__package__=='concurrent.futures' (IS a package); abc's frozen status causes __package__=='' whereas packages have __package__==__name__); abc.__package__.__len__()==0 ('':len=0; the only module in this spec series with __package__.__len__()==0); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodname167

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,   abc.__name__.__eq__,      ["abc"],  true,  "abc.__name__ == 'abc' (len=3: shortest module name in spec series; frozen top-level module); verified with Python 3.14.3"]
    - [abc_name_len,  abc.__name__.__len__,     [],       3,     "abc.__name__.__len__() == 3 ('abc'=3; shortest in this spec series; abc=3 < asyncio.tasks=13); verified with Python 3.14.3"]
    - [abc_pkg_eq,    abc.__package__.__eq__,   [""],     true,  "abc.__package__ == '' (empty string; abc is frozen, not a package; __package__ is '' not 'abc'); verified with Python 3.14.3"]
    - [abc_pkg_len,   abc.__package__.__len__,  [],       0,     "abc.__package__.__len__() == 0 (empty string; only module in spec series with __package__.__len__()==0); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__spec__.__class__.__name__ — extra167
#
# abc.__spec__.__class__.__name__.__eq__('ModuleSpec') == True
# abc.__spec__.__class__.__name__.__len__()            == 10
# ---------------------------------------------------------------------------

table abc_extra167.abc_spec_class_name:
  description: "abc.__spec__.__class__.__name__ checks in abcspecname167 namespace — abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (abc.__spec__.__class__.__name__=='ModuleSpec' (len=10: 'Module'=6+'Spec'=4=10); even though abc is a frozen module (not loaded from a .py file), it still gets a ModuleSpec object; the importlib machinery creates a ModuleSpec for all modules — frozen or not; abc.__spec__.origin=='frozen' (the origin of a frozen module is 'frozen' rather than a file path); the spec's loader is _frozen_importlib.FrozenImporter); abc.__spec__.__class__.__name__.__len__()==10 ('ModuleSpec'=10; same as multiprocessing (extra170) and concurrent.futures (extra169) — ModuleSpec is universal across all standard library modules); abc.__name__.__eq__('abc')==True (cross-check; len=3); abc.__package__.__eq__('')==True (cross-check; empty string; abc is frozen, not a package); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcspecname167

  columns: [id, function, args, expected, description]
  rows:
    - [abc_spec_cls_eq,   abc.__spec__.__class__.__name__.__eq__,  ["ModuleSpec"],  true,  "abc.__spec__.__class__.__name__ == 'ModuleSpec' (len=10; frozen module still gets ModuleSpec); verified with Python 3.14.3"]
    - [abc_spec_cls_len,  abc.__spec__.__class__.__name__.__len__, [],              10,    "abc.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'=10; universal across all modules); verified with Python 3.14.3"]
    - [abc_name_xchk,     abc.__name__.__eq__,                     ["abc"],         true,  "abc.__name__ == 'abc' (cross-check; len=3); verified with Python 3.14.3"]
    - [abc_pkg_xchk,      abc.__package__.__eq__,                  [""],            true,  "abc.__package__ == '' (cross-check; empty string; frozen module, not a package); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__loader__.__class__.__name__ — extra167
#
# abc.__loader__.__class__.__name__.__eq__('type') == True
# abc.__loader__.__class__.__name__.__len__()      == 4
# ---------------------------------------------------------------------------

table abc_extra167.abc_loader_class_name:
  description: "abc.__loader__.__class__.__name__ checks in abcloadercls167 namespace — KEY FINDING: abc.__loader__.__class__.__name__.__eq__('type')==True (abc.__loader__.__class__.__name__=='type' (len=4: 'type'=4); abc.__loader__ is _frozen_importlib.FrozenImporter — the CLASS OBJECT itself, not an instance; FrozenImporter is a class (its metaclass is 'type'), so FrozenImporter.__class__.__name__=='type'; this contrasts with how non-frozen modules work: for a SourceFileLoader-loaded module, __loader__ would be an INSTANCE of SourceFileLoader, and __loader__.__class__.__name__ would be 'SourceFileLoader'; because abc is frozen, __loader__ is the class FrozenImporter itself (not an instance), so __class__ is 'type'; abc.__loader__.__class__.__name__.__len__()==4 ('type'=4: 't'+'y'+'p'+'e'=4; one char longer than 'abc'=3); abc.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (cross-check; len=10); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcloadercls167

  columns: [id, function, args, expected, description]
  rows:
    - [abc_loader_cls_eq,   abc.__loader__.__class__.__name__.__eq__,  ["type"],        true,  "abc.__loader__.__class__.__name__ == 'type' (FrozenImporter is a class; class of a class is 'type'); verified with Python 3.14.3"]
    - [abc_loader_cls_len,  abc.__loader__.__class__.__name__.__len__, [],              4,     "abc.__loader__.__class__.__name__.__len__() == 4 ('type'=4; 1 longer than 'abc'=3); verified with Python 3.14.3"]
    - [abc_spec_xchk,       abc.__spec__.__class__.__name__.__eq__,   ["ModuleSpec"],  true,  "abc.__spec__.__class__.__name__ == 'ModuleSpec' (cross-check; len=10); verified with Python 3.14.3"]
    - [abc_name_xchk2,      abc.__name__.__eq__,                       ["abc"],         true,  "abc.__name__ == 'abc' (cross-check; len=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__doc__.__class__.__name__ and __doc__.__contains__ — extra167
#
# abc.__doc__.__class__.__name__.__eq__('str')  == True
# abc.__doc__.__contains__('ABC')               == True
# abc.__doc__.__contains__('Abstract')          == True
# ---------------------------------------------------------------------------

table abc_extra167.abc_doc_class_and_contains:
  description: "abc.__doc__.__class__.__name__ and __contains__ checks in abcdoccls167 namespace — abc.__doc__.__class__.__name__.__eq__('str')==True (abc.__doc__.__class__.__name__=='str' (len=3: 'str'=3); the abc module's docstring is a str; abc.__doc__=='Abstract Base Classes (ABCs) according to PEP 3119.' — the complete module docstring); abc.__doc__.__class__.__name__.__len__()==3 ('str'=3; same as abc.__name__.__len__()==3 — coincidence; 'str' type name and 'abc' module name share the same 3-char length); abc.__doc__.__contains__('ABC')==True (abc.__doc__ contains 'ABC' (the abbreviation for Abstract Base Class) — confirmed with Python 3.14.3); abc.__doc__.__contains__('Abstract')==True (abc.__doc__ contains 'Abstract' (capital A) — confirmed with Python 3.14.3; NOTE: lowercase 'abstract' is NOT in the docstring — only the proper-noun form 'Abstract' and the abbreviation 'ABC' appear); abc.__name__.__eq__('abc')==True (cross-check; len=3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdoccls167

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_cls_eq,        abc.__doc__.__class__.__name__.__eq__,  ["str"],      true,  "abc.__doc__.__class__.__name__ == 'str' (len=3; module docstring is a str); verified with Python 3.14.3"]
    - [abc_doc_cls_len,       abc.__doc__.__class__.__name__.__len__, [],           3,     "abc.__doc__.__class__.__name__.__len__() == 3 ('str'=3; same as 'abc' name len=3 — coincidence); verified with Python 3.14.3"]
    - [abc_doc_has_ABC,       abc.__doc__.__contains__,               ["ABC"],      true,  "abc.__doc__.__contains__('ABC') == True (docstring contains 'ABC' abbreviation); verified with Python 3.14.3"]
    - [abc_doc_has_Abstract,  abc.__doc__.__contains__,               ["Abstract"], true,  "abc.__doc__.__contains__('Abstract') == True (docstring contains 'Abstract'; lowercase 'abstract' is NOT present); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra167
# ---------------------------------------------------------------------------

invariant abc_extra167.abc_module_name_eq:
  description: "abc.__name__.__eq__('abc') returns True — abc.__name__=='abc' (len=3: 'a'+'b'+'c'=3); 'abc' is the shortest module name in this spec series: 'abc'=3 vs 'asyncio.tasks'=13 vs 'concurrent.futures._base'=24; the abc module is a top-level standard library module for Abstract Base Classes; it is always available in the Python standard library; abc.__name__=='abc' is the fully qualified name (no dots) confirming abc is a top-level module not a subpackage; COMPARISON: abc.__name__=='abc' (len=3) vs abc.__package__=='' (len=0) — the module has a 3-char name but an empty string __package__ because abc is frozen and not a package; abc.__name__.__len__()==3 == abc.__doc__.__class__.__name__.__len__()==3 (both are 3; 'abc'=3 and 'str'=3 — coincidence); NEW in extra167: first standalone abc.__name__ identity invariant in abcmodname167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__name__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra167.abc_module_package_is_empty:
  description: "abc.__package__.__eq__('') returns True — KEY FINDING: abc.__package__=='' (empty string, len=0); abc is a frozen module in CPython (its origin is 'frozen' — see abc.__spec__.origin=='frozen'); frozen modules are embedded in the CPython interpreter binary rather than loaded from .py files; because abc is not a package directory (no __init__.py, no submodules), its __package__ is the empty string; COMPARISON: multiprocessing.__package__=='multiprocessing' (len=15 — IS a package); concurrent.futures.__package__=='concurrent.futures' (len=18 — IS a package); abc.__package__=='' (len=0 — NOT a package, frozen module); the empty __package__ distinguishes abc from the package modules; abc.__package__.__len__()==0 — the only module in this spec series with zero-length __package__; NOTE: abc.__package__=='' does not mean abc is anonymous — abc.__name__=='abc' still identifies it correctly; __package__ is used by the import system to resolve relative imports, and '' means no relative imports are possible from abc; NEW in extra167: first standalone abc.__package__ identity invariant in abcmodname167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__package__.__eq__
  args: [""]
  expected: true

invariant abc_extra167.abc_spec_class_is_ModuleSpec:
  description: "abc.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — abc.__spec__.__class__.__name__=='ModuleSpec' (len=10: 'Module'=6+'Spec'=4=10); the abc module, despite being frozen, still has a __spec__ attribute of type importlib.machinery.ModuleSpec; the import system creates a ModuleSpec for every module it loads — including frozen modules; abc.__spec__.origin=='frozen' (not a file path); abc.__spec__.name=='abc'; the ModuleSpec class is in importlib.machinery; COMPARISON across spec series: abc.__spec__.__class__.__name__=='ModuleSpec' (frozen module); multiprocessing.__spec__.__class__.__name__=='ModuleSpec' (package); concurrent.futures.__spec__.__class__.__name__=='ModuleSpec' (namespace package subpackage) — all are 'ModuleSpec' regardless of how the module was loaded; NEW in extra167: first standalone abc.__spec__.__class__.__name__ invariant in abcspecname167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant abc_extra167.abc_loader_class_is_type:
  description: "abc.__loader__.__class__.__name__.__eq__('type') returns True — KEY FINDING: abc.__loader__.__class__.__name__=='type' (len=4: 'type'=4); abc.__loader__ is _frozen_importlib.FrozenImporter — the CLASS OBJECT itself (not an instance of FrozenImporter); Python's frozen module loader works differently from the SourceFileLoader: for frozen modules, the loader is the FrozenImporter CLASS itself (not an instance), so abc.__loader__.__class__.__name__ resolves to 'type' (the metaclass of FrozenImporter); abc.__loader__.__name__=='FrozenImporter' (the class's own __name__ attribute); CONTRAST: for a SourceFileLoader-loaded module, __loader__ would be a SourceFileLoader INSTANCE (not the class itself), and __loader__.__class__.__name__ would be 'SourceFileLoader'; the frozen module pattern of using the class itself as the loader is specific to CPython's frozen module bootstrap; 'type'=4 is 1 char longer than 'abc'=3 and 6 chars shorter than 'ModuleSpec'=10; NEW in extra167: first standalone abc.__loader__.__class__.__name__ invariant confirming 'type' in abcloadercls167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra167.abc_doc_class_is_str:
  description: "abc.__doc__.__class__.__name__.__eq__('str') returns True — abc.__doc__.__class__.__name__=='str' (len=3: 'str'=3); the abc module docstring is a str instance; abc.__doc__=='Abstract Base Classes (ABCs) according to PEP 3119.' (full docstring: 51 chars); the __doc__ attribute is a str for any module with a docstring (as opposed to NoneType for modules with no docstring); COINCIDENCE: abc.__doc__.__class__.__name__.__len__()==3 == abc.__name__.__len__()==3 — the type name 'str'=3 and the module name 'abc'=3 share the same 3-char length; COMPARISON: concurrent.futures.__doc__.__class__.__name__=='str' (len=3; from extra169: same invariant holds for all documented modules); abc.__doc__.__contains__('ABC')==True and abc.__doc__.__contains__('Abstract')==True (confirmed); the short docstring summarizes the module's purpose in one sentence; NEW in extra167: first standalone abc.__doc__.__class__.__name__ invariant in abcdoccls167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra167.abc_doc_contains_ABC:
  description: "abc.__doc__.__contains__('ABC') returns True — abc.__doc__.__contains__('ABC')==True; the abc module docstring is 'Abstract Base Classes (ABCs) according to PEP 3119.' and contains the acronym 'ABC' (also 'ABCs'); 'ABC' appears in the docstring as the abbreviation for Abstract Base Class — the primary concept of the module; abc.ABC is also the name of the key class in the module; IMPORTANT FINDING: abc.__doc__.__contains__('abstract')==False — the docstring does NOT contain lowercase 'abstract'; it only contains 'Abstract' (capital A as part of 'Abstract Base Classes') and 'ABCs'; this is relevant for the invariant in the prompt which asks whether the docstring contains 'abstract' (lowercase) — the answer is False; however 'Abstract' (capital A) and 'ABC' are both present; abc.__doc__.__contains__('Abstract')==True (capital A version is present); NEW in extra167: first standalone abc.__doc__.__contains__('ABC') invariant in abcdoccls167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__doc__.__contains__
  args: ["ABC"]
  expected: true

invariant abc_extra167.abc_doc_contains_Abstract:
  description: "abc.__doc__.__contains__('Abstract') returns True — abc.__doc__.__contains__('Abstract')==True; the abc module docstring 'Abstract Base Classes (ABCs) according to PEP 3119.' begins with 'Abstract' (capital A); 'Abstract Base Classes' is the full form of the acronym 'ABC'; the presence of 'Abstract' in the docstring confirms the module's purpose is abstract base class machinery; KEY DISTINCTION: 'Abstract' (capital A) IS in the docstring (True); 'abstract' (lowercase a) is NOT in the docstring (False) — the docstring uses the formal proper-noun form 'Abstract Base Classes' with capital A, not lowercase; this distinction matters for precise string matching; abc.__doc__.__contains__('PEP')==True (the docstring also references PEP 3119, the specification that introduced ABCs); 'Abstract'=8 chars matches the length of the 'abstract' prefix in the deprecated class names from extra165/166: abstractproperty(16)=abstract(8)+property(8), abstractclassmethod(19)=abstract(8)+classmethod(11), abstractstaticmethod(20)=abstract(8)+staticmethod(12) — the 'abstract'=8 prefix length is preserved in both the docstring word 'Abstract'=8 (case-insensitively) and the decorator naming convention; NEW in extra167: first standalone abc.__doc__.__contains__('Abstract') invariant in abcdoccls167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.__doc__.__contains__
  args: ["Abstract"]
  expected: true
