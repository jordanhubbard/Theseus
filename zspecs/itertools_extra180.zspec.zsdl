    - [product_name_len_7,
       "product.__name__.__len__",
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — the name 'product' has exactly 7 characters: p-r-o-d-u-c-t; str.__len__() returns 7; new to extra180"]
    - [product_module_eq,
       "product.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — itertools.product is defined in the C extension itertoolsmodule.c; its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra180"]
    - [product_module_len_9,
