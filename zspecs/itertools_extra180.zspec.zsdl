spec: itertools_extra180
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.product class identity — itertools.product.__name__=='product' (len=7); itertools.product.__module__=='itertools'; itertools.product.__mro__.__len__()==2; itertools.combinations_with_replacement.__name__.__len__()==29 (the full name length); itertools.chain.__module__=='itertools'; itertools.groupby.__module__=='itertools'; itertools.product.__qualname__=='product' (len=7; equals name — not nested); itertools.islice.__qualname__=='islice' (len=6)."
    - "itertools.product.__name__ == 'product' — itertools.product is a C extension type in itertoolsmodule.c that computes the Cartesian product of input iterables; its __name__ is 'product', 7 characters. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools' — itertools.product is defined in the C extension module itertoolsmodule.c; its __module__ attribute is 'itertools', 9 characters. Verified with Python 3.14.3."
    - "itertools.product.__mro__.__len__() == 2 — the MRO of itertools.product is (product, object); len is 2. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__name__.__len__() == 29 — the name 'combinations_with_replacement' has exactly 29 characters. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools' — itertools.chain is a C extension type; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.groupby.__module__ == 'itertools' — itertools.groupby is a C extension type; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.product.__qualname__ == 'product' — product is a module-level C extension type (not nested), so its __qualname__ equals its __name__ 'product', 7 characters. Verified with Python 3.14.3."
    - "itertools.islice.__qualname__ == 'islice' — islice is a module-level C extension type (not nested), so its __qualname__ equals its __name__ 'islice', 6 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.product __name__ and __module__
#
# itertools.product.__name__ == 'product'
# itertools.product.__name__.__len__() == 7
# itertools.product.__module__ == 'itertools'
# itertools.product.__module__.__len__() == 9
#
# product is a module-level C extension type in itertoolsmodule.c that computes
# Cartesian products. Its __name__ is 'product' (7 chars). Its __module__ is
# 'itertools' (9 chars). New to extra180.
# ---------------------------------------------------------------------------

table itertools_extra180.product_name_and_module:
  description: "itertools.product.__name__ 'product' len 7; __module__ 'itertools' len 9; new to extra180"
  kind: python_call_eq
  category: identity
