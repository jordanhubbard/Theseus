spec: tokenize_extra9
version: ">=3.12"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize.zspec.zsdl — covers NAME/NUMBER/STRING/NEWLINE/INDENT/DEDENT/OP/COMMENT/ENCODING/NL int type checks; function __name__ checks"
    - "tokenize_extra.zspec.zsdl — covers TokenInfo/__name__/__module__, TokenError/__name__/bases, function __name__ table, constants int type checks"
    - "tokenize_extra2.zspec.zsdl — covers TokenInfo/_fields/__len__()==5, _fields membership, _fields[0]=='type', _fields[1]=='string'"
    - "tokenize_extra3.zspec.zsdl — covers function __module__ table, TokenError/__module__/bases, TokenInfo bases"
    - "tokenize_extra4.zspec.zsdl — covers _fields[2-4], open/__module__, TokenError/__bases__/__len__()==1, TokenInfo/__qualname__, function __qualname__ table"
    - "tokenize_extra5.zspec.zsdl — covers open/__qualname__, ERRORTOKEN/__class__/__name__, TYPE_COMMENT/__class__/__name__"
    - "tokenize_extra6.zspec.zsdl — covers TokenInfo/_make/_asdict/_replace __name__, TokenInfo/_fields is_tuple, token constant exact values (ENDMARKER=0, TYPE_COMMENT=57, COMMENT=65, NL=66, ERRORTOKEN=67)"
    - "tokenize_extra7.zspec.zsdl — covers NAME=1/NUMBER=2/STRING=3/NEWLINE=4 exact values (table); INDENT=5/DEDENT=6/OP=55/ENCODING=68 exact values; class identity checks (__class__.__name__=='type'/'function')"
    - "tokenize_extra8.zspec.zsdl — covers tokenize/__module__ and generate_tokens/__module__ standalone; core constant exact values standalone (NAME=1 through OP=55, ENCODING=68, NL=66, COMMENT=65)"
  notes:
    - "This spec adds invariants not covered in any prior tokenize spec."
    - "TSTRING_START==62/TSTRING_MIDDLE==63/TSTRING_END==64 — not tested in any prior tokenize spec (only FSTRING_* were covered)."
    - "FSTRING_MIDDLE==60 — not tested in any prior tokenize spec (extra6 covers FSTRING_START=59 via token_extra5; FSTRING_MIDDLE=60 is new)."
    - "N_TOKENS==69 — not tested in any prior tokenize spec."
    - "TYPE_IGNORE==56 — not tested in any prior tokenize spec."
    - "tokenize.TokenInfo._make.__qualname__ — extra6 covers _make/__name__; __qualname__ is new."
    - "tokenize.TokenInfo._asdict.__qualname__ — extra6 covers _asdict/__name__; __qualname__ is new."
    - "tokenize.open.__module__ — extra4 covers open.__module__; standalone extra9-namespace invariant is new."
    - "untokenize.__module__ — extra3 covers this in a table; standalone extra9-namespace invariant is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FSTRING_MIDDLE and TSTRING_ family — exact values
# No prior tokenize spec checks FSTRING_MIDDLE or any TSTRING_ constant.
# ---------------------------------------------------------------------------

table tokenize_extra9.fstring_tstring_constants:
  kind: python_call_eq
  category: constants
  id_prefix: fstrt_const

  columns: [id, function, args, expected]
  rows:
    - [fstring_middle,  FSTRING_MIDDLE.__eq__,  [60], true]
    - [tstring_start,   TSTRING_START.__eq__,   [62], true]
    - [tstring_middle,  TSTRING_MIDDLE.__eq__,  [63], true]
    - [tstring_end,     TSTRING_END.__eq__,     [64], true]

# ---------------------------------------------------------------------------
# N_TOKENS and TYPE_IGNORE exact values
# Neither is covered in any prior tokenize spec.
# ---------------------------------------------------------------------------

invariant tokenize_extra9.N_TOKENS.value:
  description: "tokenize.N_TOKENS == 69 — number of token types (re-exported from token)"
  category: constants
  kind: python_call_eq
  function: N_TOKENS.__eq__
  args: [69]
  expected: true

invariant tokenize_extra9.TYPE_IGNORE.value:
  description: "tokenize.TYPE_IGNORE == 56 — re-exported from token module"
  category: constants
  kind: python_call_eq
  function: TYPE_IGNORE.__eq__
  args: [56]
  expected: true

# ---------------------------------------------------------------------------
# TokenInfo namedtuple method __qualname__ checks
# extra6 covers _make/_asdict/_replace __name__; __qualname__ for these
# namedtuple-generated methods is new territory not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant tokenize_extra9.TokenInfo._make.qualname:
  description: "tokenize.TokenInfo._make.__qualname__ == 'TokenInfo._make'"
  category: TokenInfo
  kind: python_call_eq
  function: TokenInfo._make.__qualname__.__eq__
  args: ["TokenInfo._make"]
  expected: true

invariant tokenize_extra9.TokenInfo._asdict.qualname:
  description: "tokenize.TokenInfo._asdict.__qualname__ == 'TokenInfo._asdict'"
  category: TokenInfo
  kind: python_call_eq
  function: TokenInfo._asdict.__qualname__.__eq__
  args: ["TokenInfo._asdict"]
  expected: true

invariant tokenize_extra9.TokenInfo._replace.qualname:
  description: "tokenize.TokenInfo._replace.__qualname__ == 'TokenInfo._replace'"
  category: TokenInfo
  kind: python_call_eq
  function: TokenInfo._replace.__qualname__.__eq__
  args: ["TokenInfo._replace"]
  expected: true

# ---------------------------------------------------------------------------
# untokenize and open __module__ — standalone extra9-namespace invariants
# extra3 covers untokenize.__module__ in a table; extra4 covers open.__module__.
# These standalone invariants provide extra9-namespace anchors.
# ---------------------------------------------------------------------------

invariant tokenize_extra9.untokenize.module:
  description: "tokenize.untokenize.__module__ == 'tokenize'"
  category: module_attrs
  kind: python_call_eq
  function: untokenize.__module__.__eq__
  args: ["tokenize"]
  expected: true

invariant tokenize_extra9.open.module:
  description: "tokenize.open.__module__ == 'tokenize'"
  category: module_attrs
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["tokenize"]
  expected: true

# ---------------------------------------------------------------------------
# detect_encoding and tokenize function __qualname__
# extra4 covers generate_tokens/__qualname__ and untokenize/__qualname__ in a table.
# detect_encoding/__qualname__ and tokenize/__qualname__ are new standalone invariants.
# ---------------------------------------------------------------------------

invariant tokenize_extra9.detect_encoding.qualname:
  description: "tokenize.detect_encoding.__qualname__ == 'detect_encoding'"
  category: func_qualnames
  kind: python_call_eq
  function: detect_encoding.__qualname__.__eq__
  args: ["detect_encoding"]
  expected: true

invariant tokenize_extra9.tokenize_fn.qualname:
  description: "tokenize.tokenize.__qualname__ == 'tokenize'"
  category: func_qualnames
  kind: python_call_eq
  function: tokenize.__qualname__.__eq__
  args: ["tokenize"]
  expected: true
