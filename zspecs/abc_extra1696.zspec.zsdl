spec: abc_extra1696
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/pickle.html — Python pickle protocol documentation"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 560 (_extra1696): pickling protocol dict-presence checks."
    - "abc.ABCMeta is a metaclass derived from type; it does not define any pickle protocol dunders (__reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__) in its own __dict__."
    - "abc.ABC is a plain helper class with no custom pickling; its __dict__ contains none of the pickle protocol dunders."
    - "abc.abstractmethod is a decorator function/class; it defines none of the pickle dunders in its own __dict__."
    - "abc types also define none of the copy protocol dunders (__copy__, __deepcopy__)."
    - "__init_subclass__ is a protocol-adjacent hook: ABCMeta and ABC define it via normal class machinery but not in their own __dict__ directly."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Pickling protocol methods absent from ABCMeta and ABC __dict__
#
# ABCMeta is a metaclass whose primary role is to track abstract methods;
# ABC is the user-facing base class helper.  Neither defines pickle protocol
# dunders in their own __dict__.  abc.abstractmethod similarly defines none.
# ---------------------------------------------------------------------------

table abc_extra1696.pickling_protocol:
  description: "abc types pickling protocol dict-presence checks — ABCMeta, ABC, abstractmethod define none of the pickle protocol dunders in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1696

  columns: [id, function, args, expected]
  rows:
    - ["ab1696001", "ABCMeta.__dict__.__contains__",      ["__reduce__"],        false]
    - ["ab1696002", "ABCMeta.__dict__.__contains__",      ["__getstate__"],      false]
    - ["ab1696003", "ABCMeta.__dict__.__contains__",      ["__setstate__"],      false]
    - ["ab1696004", "ABCMeta.__dict__.__contains__",      ["__getnewargs__"],    false]
    - ["ab1696005", "ABCMeta.__dict__.__contains__",      ["__getnewargs_ex__"], false]
    - ["ab1696006", "ABC.__dict__.__contains__",          ["__reduce__"],        false]
    - ["ab1696007", "ABC.__dict__.__contains__",          ["__getstate__"],      false]
    - ["ab1696008", "ABC.__dict__.__contains__",          ["__setstate__"],      false]
    - ["ab1696009", "ABC.__dict__.__contains__",          ["__getnewargs__"],    false]
    - ["ab1696010", "ABC.__dict__.__contains__",          ["__getnewargs_ex__"], false]
    - ["ab1696011", "abstractmethod.__dict__.__contains__", ["__reduce__"],      false]
    - ["ab1696012", "abstractmethod.__dict__.__contains__", ["__getstate__"],    false]
    - ["ab1696013", "abstractmethod.__dict__.__contains__", ["__setstate__"],    false]

# ---------------------------------------------------------------------------
# Table 2: Copy protocol and __init_subclass__ adjacent checks
#
# __copy__ and __deepcopy__ are absent from abc types.  __init_subclass__ is
# a protocol-adjacent hook for class creation; ABCMeta does not add it to its
# own __dict__ (it is inherited from type via the normal MRO).  ABC similarly
# does not define __init_subclass__ in its own __dict__.
# ---------------------------------------------------------------------------

table abc_extra1696.copy_and_adjacent_protocol:
  description: "abc types copy protocol and protocol-adjacent dict-presence checks — ABCMeta, ABC, abstractmethod define no __copy__, __deepcopy__; ABCMeta and ABC do not add __init_subclass__ to their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1696

  columns: [id, function, args, expected]
  rows:
    - ["ab1696014", "ABCMeta.__dict__.__contains__",      ["__copy__"],           false]
    - ["ab1696015", "ABCMeta.__dict__.__contains__",      ["__deepcopy__"],       false]
    - ["ab1696016", "ABC.__dict__.__contains__",          ["__copy__"],           false]
    - ["ab1696017", "ABC.__dict__.__contains__",          ["__deepcopy__"],       false]
    - ["ab1696018", "abstractmethod.__dict__.__contains__", ["__copy__"],         false]
    - ["ab1696019", "abstractmethod.__dict__.__contains__", ["__deepcopy__"],     false]
    - ["ab1696020", "ABCMeta.__dict__.__contains__",      ["__init_subclass__"],  false]
    - ["ab1696021", "ABC.__dict__.__contains__",          ["__init_subclass__"],  false]
    - ["ab1696022", "abstractmethod.__dict__.__contains__", ["__getnewargs__"],   false]
    - ["ab1696023", "abstractmethod.__dict__.__contains__", ["__getnewargs_ex__"], false]
