spec: select_extra4
version: ">=3.9"
backend: python_module(select)

docs: https://docs.python.org/3/library/select.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/select.html — Python select module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/selectmodule.c"
  notes:
    - "Extends select.zspec.zsdl, select_extra.zspec.zsdl, select_extra2.zspec.zsdl, and select_extra3.zspec.zsdl."
    - "select.zspec.zsdl covers: select.__name__; poll.__name__; kqueue.__name__; kevent.__name__; kqueue/poll instance class."
    - "select_extra covers: error.__name__=='error'; error.__bases__[0].__name__=='OSError'; select.__name__; select.__module__."
    - "select_extra2 covers: select.__name__; select.__module__; error.__name__=='OSError'; error.__bases__[0].__name__=='Exception'; POLLIN/POLLOUT values; KQ_FILTER_READ/WRITE values; KQ_EV_ADD/DELETE/ENABLE/DISABLE."
    - "select_extra3 covers: module __name__; poll.__module__; error.__module__; POLLERR>=1; POLLERR==8; POLLHUP==16; POLLNVAL==32."
    - "This spec adds: kqueue.__module__; kevent.__module__; kqueue.__qualname__; kevent.__qualname__; select.__qualname__; KQ_FILTER_PROC; KQ_FILTER_SIGNAL; KQ_EV_CLEAR; KQ_EV_ERROR; KQ_EV_EOF; KQ_EV_ONESHOT."
    - "All invariants target macOS/Darwin where kqueue/kevent are available."
    - "KQ_FILTER_PROC == -5 and KQ_FILTER_SIGNAL == -6 on macOS/Darwin — kqueue filter identifiers are negative."
    - "KQ_EV_CLEAR == 32; KQ_EV_ERROR == 16384; KQ_EV_EOF == 32768; KQ_EV_ONESHOT == 16 — verified on Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# kqueue and kevent — __module__ and __qualname__ attributes
# select.zspec.zsdl covers kqueue.__name__ and kevent.__name__.
# __module__ and __qualname__ for these types are new here.
# ---------------------------------------------------------------------------

invariant select_extra4.kqueue.module:
  description: "select.kqueue.__module__ == 'select' — kqueue is defined in the C select extension"
  category: classes
  kind: python_call_eq
  function: kqueue.__module__.__eq__
  args: ["select"]
  expected: true

invariant select_extra4.kevent.module:
  description: "select.kevent.__module__ == 'select' — kevent is defined in the C select extension"
  category: classes
  kind: python_call_eq
  function: kevent.__module__.__eq__
  args: ["select"]
  expected: true

invariant select_extra4.kqueue.qualname:
  description: "select.kqueue.__qualname__ == 'kqueue' — top-level class, qualname matches name"
  category: classes
  kind: python_call_eq
  function: kqueue.__qualname__.__eq__
  args: ["kqueue"]
  expected: true

invariant select_extra4.kevent.qualname:
  description: "select.kevent.__qualname__ == 'kevent' — top-level class, qualname matches name"
  category: classes
  kind: python_call_eq
  function: kevent.__qualname__.__eq__
  args: ["kevent"]
  expected: true

# ---------------------------------------------------------------------------
# select.select — __qualname__ attribute
# select_extra and select_extra2 cover __name__ and __module__ for select.select.
# __qualname__ is new here.
# ---------------------------------------------------------------------------

invariant select_extra4.select.qualname:
  description: "select.select.__qualname__ == 'select' — top-level C builtin function"
  category: functions
  kind: python_call_eq
  function: select.__qualname__.__eq__
  args: ["select"]
  expected: true

# ---------------------------------------------------------------------------
# KQ_FILTER_PROC and KQ_FILTER_SIGNAL — macOS/BSD kqueue process/signal filters
# Not covered in any prior select spec.
# KQ_FILTER_PROC == -5 and KQ_FILTER_SIGNAL == -6 on macOS/Darwin.
# ---------------------------------------------------------------------------

invariant select_extra4.KQ_FILTER_PROC.is_int:
  description: "select.KQ_FILTER_PROC.__class__.__name__ == 'int' — KQ_FILTER_PROC is an integer constant"
  category: constants
  kind: python_call_eq
  function: KQ_FILTER_PROC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select_extra4.KQ_FILTER_PROC.value:
  description: "select.KQ_FILTER_PROC == -5 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: KQ_FILTER_PROC.__eq__
  args: [-5]
  expected: true

invariant select_extra4.KQ_FILTER_SIGNAL.is_int:
  description: "select.KQ_FILTER_SIGNAL.__class__.__name__ == 'int' — KQ_FILTER_SIGNAL is an integer constant"
  category: constants
  kind: python_call_eq
  function: KQ_FILTER_SIGNAL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant select_extra4.KQ_FILTER_SIGNAL.value:
  description: "select.KQ_FILTER_SIGNAL == -6 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: KQ_FILTER_SIGNAL.__eq__
  args: [-6]
  expected: true

# ---------------------------------------------------------------------------
# KQ_EV_CLEAR, KQ_EV_ERROR, KQ_EV_EOF, KQ_EV_ONESHOT — kqueue event flags
# select_extra2 covers KQ_EV_ADD/DELETE/ENABLE/DISABLE.
# These four flags are new here.
# KQ_EV_ONESHOT==16; KQ_EV_CLEAR==32; KQ_EV_ERROR==16384; KQ_EV_EOF==32768 on macOS/Darwin.
# ---------------------------------------------------------------------------

table select_extra4.kq_ev_extra_flags:
  kind: python_call_eq
  category: constants
  id_prefix: kqev_extra

  columns: [id, function, args, expected]
  rows:
    - [oneshot, KQ_EV_ONESHOT.__eq__, [16],    true]
    - [clear,   KQ_EV_CLEAR.__eq__,   [32],    true]
    - [error,   KQ_EV_ERROR.__eq__,   [16384], true]
    - [eof,     KQ_EV_EOF.__eq__,     [32768], true]

table select_extra4.kq_ev_extra_flag_types:
  kind: python_call_eq
  category: constants
  id_prefix: kqev_type

  columns: [id, function, args, expected]
  rows:
    - [oneshot, KQ_EV_ONESHOT.__class__.__name__.__eq__, ["int"], true]
    - [clear,   KQ_EV_CLEAR.__class__.__name__.__eq__,   ["int"], true]
    - [error,   KQ_EV_ERROR.__class__.__name__.__eq__,   ["int"], true]
    - [eof,     KQ_EV_EOF.__class__.__name__.__eq__,     ["int"], true]
