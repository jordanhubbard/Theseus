spec: datetime_extra15
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
    - "datetime.zspec.zsdl — covers class __name__/__qualname__ table, MINYEAR/MAXYEAR, date/datetime/timedelta/timezone constructors"
    - "datetime_extra12.zspec.zsdl — covers __qualname__ for all six classes as standalone invariants; __module__ table; MINYEAR/MAXYEAR values and class names"
    - "datetime_extra13.zspec.zsdl — covers __name__ for date/time/datetime/timedelta/timezone (table); __bases__[0].__name__ for timedelta"
    - "datetime_extra14.zspec.zsdl — covers __bases__[0].__name__ table for all six classes; standalone base-class invariants for datetime/timezone/date"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra14.zspec.zsdl."
    - "NEW in extra15 — Axis 1: MINYEAR.__class__.__qualname__ and MAXYEAR.__class__.__qualname__ == 'int' — qualname of the int type itself."
    - "NEW in extra15 — Axis 2: resolution.__class__.__name__ == 'timedelta' for date/datetime/time/timedelta — all four resolution sentinels are timedelta instances."
    - "NEW in extra15 — Axis 3: combined __qualname__ table for all six datetime classes in extra15 namespace."
    - "datetime.MINYEAR.__class__.__qualname__ == 'int' — verified Python 3.12."
    - "datetime.MAXYEAR.__class__.__qualname__ == 'int' — verified Python 3.12."
    - "datetime.date.resolution.__class__.__name__ == 'timedelta' — verified Python 3.12."
    - "datetime.datetime.resolution.__class__.__name__ == 'timedelta' — verified Python 3.12."
    - "datetime.time.resolution.__class__.__name__ == 'timedelta' — verified Python 3.12."
    - "datetime.timedelta.resolution.__class__.__name__ == 'timedelta' — verified Python 3.12."
    - "All six datetime classes have flat (non-dotted) __qualname__ values — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MINYEAR and MAXYEAR: __class__.__qualname__ == 'int'
#
# datetime_extra11 and extra12 confirm these are plain int instances via
# __class__.__name__. This spec anchors __class__.__qualname__ (which also
# equals 'int' for the built-in int type) in the extra15 namespace.
# ---------------------------------------------------------------------------

invariant datetime_extra15.MINYEAR.class_qualname:
  description: "datetime.MINYEAR.__class__.__qualname__ == 'int' — type qualname for module constant"
  category: class_qualnames
  kind: python_call_eq
  function: MINYEAR.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true

invariant datetime_extra15.MAXYEAR.class_qualname:
  description: "datetime.MAXYEAR.__class__.__qualname__ == 'int' — type qualname for module constant"
  category: class_qualnames
  kind: python_call_eq
  function: MAXYEAR.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# resolution sentinels: __class__.__name__ == 'timedelta'
#
# Each datetime class with a resolution attribute (date, datetime, time,
# timedelta) exposes a class-level timedelta sentinel. No prior spec checks
# the __class__.__name__ of these resolution attributes via a table.
# ---------------------------------------------------------------------------

table datetime_extra15.resolution_types:
  kind: python_call_eq
  category: resolution
  id_prefix: res

  columns: [id, function, args, expected]
  rows:
    - [date,      "date.resolution.__class__.__name__.__eq__",      ["timedelta"], true]
    - [datetime,  "datetime.resolution.__class__.__name__.__eq__",  ["timedelta"], true]
    - [time,      "time.resolution.__class__.__name__.__eq__",      ["timedelta"], true]
    - [timedelta, "timedelta.resolution.__class__.__name__.__eq__", ["timedelta"], true]

# ---------------------------------------------------------------------------
# __qualname__ for all six datetime classes — extra15 namespace table
#
# datetime_extra12 anchors these as standalone invariants. This spec
# consolidates all six in a single table in the extra15 namespace.
# ---------------------------------------------------------------------------

table datetime_extra15.class_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [date,      date.__qualname__.__eq__,      ["date"],      true]
    - [time,      time.__qualname__.__eq__,      ["time"],      true]
    - [datetime,  datetime.__qualname__.__eq__,  ["datetime"],  true]
    - [timedelta, timedelta.__qualname__.__eq__,  ["timedelta"], true]
    - [timezone,  timezone.__qualname__.__eq__,  ["timezone"],  true]
    - [tzinfo,    tzinfo.__qualname__.__eq__,    ["tzinfo"],    true]
