spec: hashlib_extra2551
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "Theme: __reduce__, __reduce_ex__, and __getnewargs__ dict-presence — checking whether the HASH class defines its own pickling/serialization protocol in its class __dict__."
    - "HASH = type(hashlib.md5()) — the concrete C extension type for all fixed-length hash objects (sha256/md5/sha1/sha512 instances)."
    - "HASH does NOT define __reduce__, __reduce_ex__, __getnewargs__, __getnewargs_ex__, __getstate__, or __setstate__ in its own __dict__. Verified with Python 3.14 on macOS/Darwin 25.4.0."
    - "hashlib hash objects are NOT picklable: pickle.dumps(hashlib.md5()) raises TypeError. The absence of pickling dunders from HASH.__dict__ is consistent with this unpicklability."
    - "__reduce__ and __reduce_ex__ are inherited from object (appear in object.__dict__, not in HASH.__dict__)."
    - "HASH.__dict__ positive controls: __repr__, update, digest, hexdigest, copy, name, digest_size, block_size are all present."
    - "All expected values verified by running Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: HASH.__dict__ — __reduce__ absent
#
# HASH does not override __reduce__ in its own __dict__.
# Pickling dispatches through __reduce_ex__ (also absent), then falls to
# object.__reduce_ex__ which ultimately raises TypeError for HASH instances.
# ---------------------------------------------------------------------------

table hashlib_extra2551.HASH_reduce_absent:
  description: "__reduce__ absent from HASH.__dict__; HASH delegates pickle dispatch to object.__reduce__; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2551

  columns: [id, function, args, expected]
  rows:
    - ["hl2551-001", "sha256.__class__.__dict__.__contains__", ["__reduce__"],    false]
    - ["hl2551-002", "sha256.__class__.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["hl2551-003", "sha256.__class__.__dict__.__contains__", ["__getnewargs__"], false]

# ---------------------------------------------------------------------------
# Table 2: HASH.__dict__ — __getnewargs_ex__ and __getstate__ also absent
#
# The full set of pickle-protocol dunders is absent from HASH.__dict__.
# HASH defines no custom serialization at any level of the pickle protocol
# (__reduce__, __reduce_ex__, __getnewargs__, __getnewargs_ex__, __getstate__,
# __setstate__ are all missing from HASH.__dict__).
# ---------------------------------------------------------------------------

table hashlib_extra2551.HASH_all_pickle_dunders_absent:
  description: "__getnewargs_ex__, __getstate__, __setstate__ all absent from HASH.__dict__; no pickle protocol defined; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2551

  columns: [id, function, args, expected]
  rows:
    - ["hl2551-004", "sha256.__class__.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["hl2551-005", "sha256.__class__.__dict__.__contains__", ["__getstate__"],      false]
    - ["hl2551-006", "sha256.__class__.__dict__.__contains__", ["__setstate__"],      false]

# ---------------------------------------------------------------------------
# Table 3: HASH.__dict__ — positive controls (members that ARE present)
#
# Confirms that __dict__.__contains__ operates correctly for HASH.
# __repr__, update, digest, hexdigest, copy, name, digest_size, block_size
# are all explicitly defined in the HASH C extension type's own __dict__.
# ---------------------------------------------------------------------------

table hashlib_extra2551.HASH_dict_positive_controls:
  description: "HASH.__dict__ positive controls — expected members are present; confirms __dict__.__contains__ is operational; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2551

  columns: [id, function, args, expected]
  rows:
    - ["hl2551-007", "sha256.__class__.__dict__.__contains__", ["__repr__"],    true]
    - ["hl2551-008", "sha256.__class__.__dict__.__contains__", ["update"],      true]
    - ["hl2551-009", "sha256.__class__.__dict__.__contains__", ["digest"],      true]
    - ["hl2551-010", "sha256.__class__.__dict__.__contains__", ["hexdigest"],   true]
    - ["hl2551-011", "sha256.__class__.__dict__.__contains__", ["copy"],        true]
    - ["hl2551-012", "sha256.__class__.__dict__.__contains__", ["name"],        true]

# ---------------------------------------------------------------------------
# Table 4: HASH.__dict__ — cross-class consistency: md5 vs sha256
#
# Both sha256() and md5() produce HASH instances of the same C extension type.
# The absence of pickle dunders applies regardless of which constructor was used.
# Accessing via md5().__class__.__dict__.__contains__ gives the same results.
# ---------------------------------------------------------------------------

table hashlib_extra2551.HASH_md5_reduce_absent:
  description: "md5().__class__.__dict__.__contains__ confirms same HASH type as sha256(); __reduce__/__reduce_ex__/__getnewargs__ absent via md5 path; verified Python 3.14"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2551

  columns: [id, function, args, expected]
  rows:
    - ["hl2551-013", "md5.__class__.__dict__.__contains__", ["__reduce__"],     false]
    - ["hl2551-014", "md5.__class__.__dict__.__contains__", ["__reduce_ex__"],  false]
    - ["hl2551-015", "md5.__class__.__dict__.__contains__", ["__getnewargs__"], false]
    - ["hl2551-016", "md5.__class__.__dict__.__contains__", ["__getstate__"],   false]
    - ["hl2551-017", "md5.__class__.__dict__.__contains__", ["__setstate__"],   false]
