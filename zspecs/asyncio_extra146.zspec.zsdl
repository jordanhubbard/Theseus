# asyncio.IncompleteReadError.__bases__[0].__name__ == 'EOFError'            (len=8)
# asyncio.IncompleteReadError.__mro__.__len__()     == 5
# asyncio.IncompleteReadError.__doc__.__len__()     == 167
# ---------------------------------------------------------------------------

table asyncio_extra146.incomplete_read_error:
  description: "asyncio.IncompleteReadError identity checks — IncompleteReadError.__name__.__eq__('IncompleteReadError')==True (len=19: the longest exception class name in this spec; 2 more than InvalidStateError and LimitOverrunError at 17); IncompleteReadError.__module__.__eq__('asyncio.exceptions')==True (len=18: same module as InvalidStateError and LimitOverrunError); IncompleteReadError.__bases__[0].__name__.__eq__('EOFError')==True (len=8: inherits from EOFError rather than Exception directly, making it the only exception in this spec with a base class name shorter than 'Exception'=9); IncompleteReadError.__mro__.__len__()==5 (IncompleteReadError -> EOFError -> Exception -> BaseException -> object, one deeper than the others at 4 due to the extra EOFError level); IncompleteReadError.__doc__.__len__()==167 (the longest exception doc in this spec: multi-paragraph describing 'partial' and 'expected' attributes); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioirre146

  columns: [id, function, args, expected, description]
  rows:
    - [ire_name_eq,   asyncio.IncompleteReadError.__name__.__eq__,              ["IncompleteReadError"],  true,  "asyncio.IncompleteReadError.__name__ == 'IncompleteReadError' (len=19); verified with Python 3.14.3"]
    - [ire_name_len,  asyncio.IncompleteReadError.__name__.__len__,              [],                       19,    "asyncio.IncompleteReadError.__name__.__len__() == 19 (longest in this spec); verified with Python 3.14.3"]
    - [ire_mod_eq,    asyncio.IncompleteReadError.__module__.__eq__,            ["asyncio.exceptions"],   true,  "asyncio.IncompleteReadError.__module__ == 'asyncio.exceptions' (len=18); verified with Python 3.14.3"]
    - [ire_mod_len,   asyncio.IncompleteReadError.__module__.__len__,            [],                       18,    "asyncio.IncompleteReadError.__module__.__len__() == 18; verified with Python 3.14.3"]
    - [ire_mro_len,   asyncio.IncompleteReadError.__mro__.__len__,               [],                       5,     "asyncio.IncompleteReadError.__mro__.__len__() == 5 (deepest MRO in this spec due to EOFError level); verified with Python 3.14.3"]
    - [ire_doc_len,   asyncio.IncompleteReadError.__doc__.__len__,               [],                       167,   "asyncio.IncompleteReadError.__doc__.__len__() == 167 (longest doc in this spec); verified with Python 3.14.3"]

