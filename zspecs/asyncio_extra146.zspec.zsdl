spec: asyncio_extra146
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-exceptions.html — Python asyncio exceptions documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py, Lib/asyncio/queues.py"
  notes:
    - "This spec covers: asyncio.InvalidStateError — __name__=='InvalidStateError' (len=17); __module__=='asyncio.exceptions' (len=18); __bases__[0].__name__=='Exception' (len=9); __mro__.__len__()==4; __doc__.__len__()==43. asyncio.IncompleteReadError — __name__=='IncompleteReadError' (len=19); __module__=='asyncio.exceptions' (len=18); __bases__[0].__name__=='EOFError' (len=8); __mro__.__len__()==5 (one deeper than the other exceptions due to EOFError in MRO); __doc__.__len__()==167. asyncio.LimitOverrunError — __name__=='LimitOverrunError' (len=17); __module__=='asyncio.exceptions' (len=18); __bases__[0].__name__=='Exception' (len=9); __mro__.__len__()==4; __doc__.__len__()==119. asyncio.QueueEmpty — __name__=='QueueEmpty' (len=10); __module__=='asyncio.queues' (len=14); __bases__[0].__name__=='Exception' (len=9); __mro__.__len__()==4; __doc__.__len__()==59. asyncio.QueueFull — __name__=='QueueFull' (len=9); __module__=='asyncio.queues' (len=14); __bases__[0].__name__=='Exception' (len=9); __mro__.__len__()==4; __doc__.__len__()==68. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "InvalidStateError and LimitOverrunError share __name__ len==17 and __mro__.__len__()==4. IncompleteReadError has the longest __name__ (len=19) and deepest MRO (len==5) because EOFError adds an extra level. QueueEmpty and QueueFull differ from the others in module ('asyncio.queues' len=14 vs 'asyncio.exceptions' len=18). QueueFull has the shortest __name__ at len=9; QueueEmpty is len=10. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.InvalidStateError and LimitOverrunError — extra146
#
# asyncio.InvalidStateError.__name__              == 'InvalidStateError'    (len=17)
# asyncio.InvalidStateError.__module__            == 'asyncio.exceptions'   (len=18)
# asyncio.InvalidStateError.__bases__[0].__name__ == 'Exception'            (len=9)
# asyncio.InvalidStateError.__mro__.__len__()     == 4
# asyncio.InvalidStateError.__doc__.__len__()     == 43
# asyncio.LimitOverrunError.__name__              == 'LimitOverrunError'    (len=17)
# asyncio.LimitOverrunError.__module__            == 'asyncio.exceptions'   (len=18)
# asyncio.LimitOverrunError.__bases__[0].__name__ == 'Exception'            (len=9)
# asyncio.LimitOverrunError.__mro__.__len__()     == 4
# asyncio.LimitOverrunError.__doc__.__len__()     == 119
# ---------------------------------------------------------------------------

table asyncio_extra146.exceptions_module_classes:
  description: "asyncio.InvalidStateError and LimitOverrunError identity checks — both are defined in 'asyncio.exceptions' (len=18) and inherit directly from Exception (len=9); InvalidStateError.__name__.__eq__('InvalidStateError')==True (len=17: the same length as LimitOverrunError.__name__ len=17); InvalidStateError.__mro__.__len__()==4 (InvalidStateError -> Exception -> BaseException -> object); InvalidStateError.__doc__.__len__()==43 (single-sentence: 'The operation is not allowed in this state.'); LimitOverrunError.__name__.__eq__('LimitOverrunError')==True (len=17: tied with InvalidStateError); LimitOverrunError.__mro__.__len__()==4 (same depth as InvalidStateError); LimitOverrunError.__doc__.__len__()==119 (multi-sentence doc about the buffer limit and the 'consumed' attribute); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioe146

  columns: [id, function, args, expected, description]
  rows:
    - [ise_name_eq,   asyncio.InvalidStateError.__name__.__eq__,              ["InvalidStateError"],   true,  "asyncio.InvalidStateError.__name__ == 'InvalidStateError' (len=17); verified with Python 3.14.3"]
    - [ise_name_len,  asyncio.InvalidStateError.__name__.__len__,              [],                      17,    "asyncio.InvalidStateError.__name__.__len__() == 17; verified with Python 3.14.3"]
    - [ise_mod_eq,    asyncio.InvalidStateError.__module__.__eq__,            ["asyncio.exceptions"],  true,  "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions' (len=18); verified with Python 3.14.3"]
    - [ise_mod_len,   asyncio.InvalidStateError.__module__.__len__,            [],                      18,    "asyncio.InvalidStateError.__module__.__len__() == 18; verified with Python 3.14.3"]
    - [ise_mro_len,   asyncio.InvalidStateError.__mro__.__len__,               [],                      4,     "asyncio.InvalidStateError.__mro__.__len__() == 4; verified with Python 3.14.3"]
    - [ise_doc_len,   asyncio.InvalidStateError.__doc__.__len__,               [],                      43,    "asyncio.InvalidStateError.__doc__.__len__() == 43; verified with Python 3.14.3"]
    - [loe_name_eq,   asyncio.LimitOverrunError.__name__.__eq__,              ["LimitOverrunError"],   true,  "asyncio.LimitOverrunError.__name__ == 'LimitOverrunError' (len=17); verified with Python 3.14.3"]
    - [loe_name_len,  asyncio.LimitOverrunError.__name__.__len__,              [],                      17,    "asyncio.LimitOverrunError.__name__.__len__() == 17 (tied with InvalidStateError); verified with Python 3.14.3"]
    - [loe_mod_len,   asyncio.LimitOverrunError.__module__.__len__,            [],                      18,    "asyncio.LimitOverrunError.__module__.__len__() == 18 ('asyncio.exceptions'); verified with Python 3.14.3"]
    - [loe_mro_len,   asyncio.LimitOverrunError.__mro__.__len__,               [],                      4,     "asyncio.LimitOverrunError.__mro__.__len__() == 4 (same as InvalidStateError); verified with Python 3.14.3"]
    - [loe_doc_len,   asyncio.LimitOverrunError.__doc__.__len__,               [],                      119,   "asyncio.LimitOverrunError.__doc__.__len__() == 119; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.IncompleteReadError — extra146
#
# asyncio.IncompleteReadError.__name__              == 'IncompleteReadError' (len=19)
