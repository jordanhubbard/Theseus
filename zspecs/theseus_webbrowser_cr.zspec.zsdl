spec: theseus_webbrowser_cr
version: ">=3.0"
backend: python_cleanroom(theseus_webbrowser_cr)
blocks: webbrowser

docs: https://docs.python.org/3/library/webbrowser.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/webbrowser.html"
  not_derived_from:
    - "CPython source: Lib/webbrowser.py"
  notes:
    - "Clean-room webbrowser module. Do NOT import webbrowser."

error_model: python_exceptions

invariant theseus_webbrowser_cr.webbrowser2_browser_class:
  description: "BaseBrowser class exists"
  category: behavior
  kind: python_call_eq
  function: webbrowser2_browser_class
  args: []
  expected: true

invariant theseus_webbrowser_cr.webbrowser2_get:
  description: "get() returns a browser-like object or None"
  category: behavior
  kind: python_call_eq
  function: webbrowser2_get
  args: []
  expected: true

invariant theseus_webbrowser_cr.webbrowser2_register:
  description: "register() works without error"
  category: behavior
  kind: python_call_eq
  function: webbrowser2_register
  args: []
  expected: true
