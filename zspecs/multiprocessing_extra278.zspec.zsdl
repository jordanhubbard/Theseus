spec: multiprocessing_extra278
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing package identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py, Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.__loader__.__class__.__name__ is 'SourceFileLoader' on CPython"
    - "cpu_count, current_process, etc. are defined in multiprocessing.context"
    - "multiprocessing.__spec__.__class__.__name__ is 'ModuleSpec'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra278.package_identity:
  description: "multiprocessing package-level identity attributes"
  kind: python_call_eq
  category: identity
  id_prefix: mp278i

  columns: [id, function, args, expected, description]
  rows:
    - [mp278i001, multiprocessing.__name__, [], multiprocessing, "__name__ is 'multiprocessing'"]
    - [mp278i002, multiprocessing.__package__, [], multiprocessing, "__package__ is 'multiprocessing'"]
    - [mp278i003, multiprocessing.__spec__.__class__.__name__, [], ModuleSpec, "__spec__ is a ModuleSpec"]
    - [mp278i004, multiprocessing.__loader__.__class__.__name__, [], SourceFileLoader, "__loader__ is SourceFileLoader"]

table multiprocessing_extra278.function_names:
  description: "multiprocessing top-level function __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: mp278f

  columns: [id, function, args, expected, description]
  rows:
    - [mp278f001, multiprocessing.cpu_count.__name__, [], cpu_count, "cpu_count.__name__"]
    - [mp278f002, multiprocessing.current_process.__name__, [], current_process, "current_process.__name__"]
    - [mp278f003, multiprocessing.active_children.__name__, [], active_children, "active_children.__name__"]
    - [mp278f004, multiprocessing.freeze_support.__name__, [], freeze_support, "freeze_support.__name__"]
    - [mp278f005, multiprocessing.set_start_method.__name__, [], set_start_method, "set_start_method.__name__"]
    - [mp278f006, multiprocessing.get_start_method.__name__, [], get_start_method, "get_start_method.__name__"]
    - [mp278f007, multiprocessing.get_all_start_methods.__name__, [], get_all_start_methods, "get_all_start_methods.__name__"]

invariant multiprocessing_extra278.pkg_name:
  description: "multiprocessing.__name__ == 'multiprocessing'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.__name__
  args: []
  expected: "multiprocessing"

invariant multiprocessing_extra278.cpu_count_module:
  description: "multiprocessing.cpu_count.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.cpu_count.__module__
  args: []
  expected: "multiprocessing.context"

invariant multiprocessing_extra278.spec_class:
  description: "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.__spec__.__class__.__name__
  args: []
  expected: "ModuleSpec"
