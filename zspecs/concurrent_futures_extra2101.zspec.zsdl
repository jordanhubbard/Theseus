  columns: [id, function, args, expected]
  rows:
    - ["cf2101022", "concurrent.futures.Future.__dict__.__contains__", ["__mro_entries__"], false]
    - ["cf2101023", "concurrent.futures.Executor.__dict__.__contains__", ["__mro_entries__"], false]
    - ["cf2101024", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__mro_entries__"], false]
