spec: concurrent_futures_extra2101
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2101 (concurrent_futures_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks."
    - "concurrent.futures.Future defines __class_getitem__ in its own __dict__ (Python 3.9+) — it supports generic alias subscripting."
    - "concurrent.futures.Executor does NOT define __class_getitem__ in its own __dict__."
    - "concurrent.futures.ThreadPoolExecutor does NOT define __class_getitem__ in its own __dict__."
    - "concurrent.futures.ProcessPoolExecutor does NOT define __class_getitem__ in its own __dict__."
    - "None of the checked classes define __init_subclass__ in their own __dict__ — inherited from object."
    - "None of the checked classes define __subclasshook__ in their own __dict__."
    - "None of the checked classes define __mro_entries__ in their own __dict__ — MRO resolution protocol is absent."
    - "Executor inherits directly from object; ThreadPoolExecutor and ProcessPoolExecutor inherit from Executor."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table concurrent_futures_extra2101.class_getitem_protocol:
  description: "concurrent.futures classes __class_getitem__ dict-presence checks — generic alias protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2101

  columns: [id, function, args, expected]
  rows:
    - ["cf2101001", "concurrent.futures.Future.__dict__.__contains__", ["__class_getitem__"], true]
    - ["cf2101002", "concurrent.futures.Executor.__dict__.__contains__", ["__class_getitem__"], false]
    - ["cf2101003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__class_getitem__"], false]
    - ["cf2101004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__class_getitem__"], false]
    - ["cf2101005", "concurrent.futures.CancelledError.__dict__.__contains__", ["__class_getitem__"], false]
    - ["cf2101006", "concurrent.futures.TimeoutError.__dict__.__contains__", ["__class_getitem__"], false]
    - ["cf2101007", "concurrent.futures.BrokenExecutor.__dict__.__contains__", ["__class_getitem__"], false]

table concurrent_futures_extra2101.init_subclass_protocol:
  description: "concurrent.futures classes __init_subclass__ dict-presence checks — subclass hook protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2101

  columns: [id, function, args, expected]
  rows:
    - ["cf2101008", "concurrent.futures.Future.__dict__.__contains__", ["__init_subclass__"], false]
    - ["cf2101009", "concurrent.futures.Executor.__dict__.__contains__", ["__init_subclass__"], false]
    - ["cf2101010", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__init_subclass__"], false]
    - ["cf2101011", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__init_subclass__"], false]
    - ["cf2101012", "concurrent.futures.CancelledError.__dict__.__contains__", ["__init_subclass__"], false]
    - ["cf2101013", "concurrent.futures.TimeoutError.__dict__.__contains__", ["__init_subclass__"], false]
    - ["cf2101014", "concurrent.futures.BrokenExecutor.__dict__.__contains__", ["__init_subclass__"], false]

table concurrent_futures_extra2101.subclasshook_protocol:
  description: "concurrent.futures classes __subclasshook__ dict-presence checks — ABC virtual subclass hook protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2101

  columns: [id, function, args, expected]
  rows:
    - ["cf2101015", "concurrent.futures.Future.__dict__.__contains__", ["__subclasshook__"], false]
    - ["cf2101016", "concurrent.futures.Executor.__dict__.__contains__", ["__subclasshook__"], false]
    - ["cf2101017", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__subclasshook__"], false]
    - ["cf2101018", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__subclasshook__"], false]
    - ["cf2101019", "concurrent.futures.CancelledError.__dict__.__contains__", ["__subclasshook__"], false]
    - ["cf2101020", "concurrent.futures.TimeoutError.__dict__.__contains__", ["__subclasshook__"], false]
    - ["cf2101021", "concurrent.futures.BrokenExecutor.__dict__.__contains__", ["__subclasshook__"], false]

table concurrent_futures_extra2101.mro_entries_protocol:
  description: "concurrent.futures classes __mro_entries__ dict-presence checks — MRO resolution protocol"
