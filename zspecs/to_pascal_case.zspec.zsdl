spec: to_pascal_case
version: ">=1.0.0"
backend: node(to-pascal-case)

docs: https://www.npmjs.com/package/to-pascal-case

provenance:
  derived_from:
    - "to-pascal-case README — https://www.npmjs.com/package/to-pascal-case"
    - "Test vectors verified with to-pascal-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "to-pascal-case source"
  notes:
    - "to-pascal-case is an npm package. Install: npm install to-pascal-case"
    - "Converts a string to PascalCase."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table to_pascal_case.toPascalCase:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: pascalcase

  columns: [id, args, expected]
  rows:
    - [spaces,  ["hello world"],  "HelloWorld"]
    - [hyphen,  ["foo-bar"],      "FooBar"]
    - [snake,   ["foo_bar"],      "FooBar"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:45:31Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
