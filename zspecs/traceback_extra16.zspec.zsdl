spec: traceback_extra16
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl through traceback_extra15.zspec.zsdl."
    - "traceback_extra15 covers: TracebackException/StackSummary/FrameSummary __bases__.__len__() == 1; MRO lengths as standalone invariants; print_tb/format_list/extract_stack __qualname__ as standalone invariants."
    - "traceback_extra10 covers: TracebackException/__mro__[1].__name__ == 'object'; StackSummary/__mro__[1].__name__ == 'list'; FrameSummary/__mro__[1].__name__ == 'object'."
    - "Prior specs cover: __name__/__qualname__/__module__/__class__.__name__ for all 17 module-level functions; __bases__[0].__name__ and MRO lengths for the three classes."
    - "NOT yet covered in any prior spec: TracebackException.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: StackSummary.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: FrameSummary.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: StackSummary.__mro__[2].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: traceback module __name__ attribute ('traceback') as an invariant."
    - "NOT yet covered in any prior spec: traceback module __package__ attribute ('') as an invariant."
    - "For all three classes, __mro__[-1].__name__ == 'object' — the terminal element of every MRO is always object."
    - "StackSummary.__mro__[2].__name__ == 'object' — third MRO element, since StackSummary has MRO length 3."
    - "traceback.__name__ == 'traceback' — the module's own name matches its identifier."
    - "traceback.__package__ == '' — traceback is a top-level module with an empty package string."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class MRO terminal element — all three traceback classes
#
# traceback_extra10 covers __mro__[1].__name__ for TracebackException,
# StackSummary, and FrameSummary. No prior spec checks __mro__[-1].__name__
# for any of these classes. For every Python class, __mro__[-1].__name__ is
# always 'object'. These standalone invariants confirm the MRO terminates
# correctly.
# ---------------------------------------------------------------------------

invariant traceback_extra16.TracebackException.mro_last:
  description: "traceback.TracebackException.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "TracebackException.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant traceback_extra16.StackSummary.mro_last:
  description: "traceback.StackSummary.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "StackSummary.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant traceback_extra16.FrameSummary.mro_last:
  description: "traceback.FrameSummary.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "FrameSummary.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant traceback_extra16.StackSummary.mro_index2:
  description: "traceback.StackSummary.__mro__[2].__name__ == 'object' — third MRO slot (MRO length is 3)"
  category: class_hierarchy
  kind: python_call_eq
  function: "StackSummary.__mro__[2].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# traceback module identity — __name__ and __package__
#
# No prior traceback spec records the module-level __name__ or __package__
# attributes as invariants. traceback is a top-level standard-library module;
# its __name__ is 'traceback' and its __package__ is the empty string.
# ---------------------------------------------------------------------------

invariant traceback_extra16.module.name:
  description: "traceback.__name__ == 'traceback' — module self-identifies by its own name"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra16.module.package:
  description: "traceback.__package__ == '' — top-level module has empty package string"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# MRO terminal element table — all three classes
#
# Consolidates the mro[-1].__name__ == 'object' checks in a single table.
# Also includes StackSummary.__mro__[2].__name__ == 'object' as a bonus row
# confirming the third MRO position for the one class with MRO length 3.
# ---------------------------------------------------------------------------

table traceback_extra16.mro_terminal_names:
  description: "__mro__[-1].__name__ == 'object' for TracebackException, StackSummary, FrameSummary"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected]
  rows:
    - [TracebackException_last, "TracebackException.__mro__[-1].__name__.__eq__", ["object"], true]
    - [StackSummary_last,       "StackSummary.__mro__[-1].__name__.__eq__",       ["object"], true]
    - [FrameSummary_last,       "FrameSummary.__mro__[-1].__name__.__eq__",       ["object"], true]
    - [StackSummary_index2,     "StackSummary.__mro__[2].__name__.__eq__",        ["object"], true]
