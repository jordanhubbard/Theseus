spec: decimal_extra242
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic Specification, Version 1.72"
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers str_repr, is_finite, is_nan, is_infinite, is_zero, is_signed, is_normal, as_tuple, class_name, getcontext.prec"
    - "decimal_extra.zspec.zsdl — covers is_nan/is_infinite/is_zero/is_signed, to_eng_string, Context/BasicContext/ExtendedContext class names, ROUND_* constants"
  notes:
    - "This spec covers: Decimal is_signed, is_normal, and is_subnormal behavioral contracts with distinct test vectors."
    - "Decimal('-1').is_signed() == True — negative numbers have sign bit 1; verified Python 3.14.3 macOS."
    - "Decimal('1').is_signed() == False — positive numbers have sign bit 0; verified Python 3.14.3 macOS."
    - "Decimal('-0').is_signed() == True — negative zero has sign bit 1 even though its value is zero; verified Python 3.14.3 macOS."
    - "Decimal('1').is_normal() == True — a regular nonzero finite number is normal; verified Python 3.14.3 macOS."
    - "Decimal('0').is_normal() == False — zero is not classified as normal; verified Python 3.14.3 macOS."
    - "Decimal('Inf').is_normal() == False — infinity is not normal; verified Python 3.14.3 macOS."
    - "Decimal('-1').is_normal() == True — negative regular numbers are also normal; verified Python 3.14.3 macOS."
    - "Decimal('NaN').is_normal() == False — NaN is not normal; verified Python 3.14.3 macOS."
    - "Decimal('1').is_subnormal() == False — normal numbers are not subnormal; verified Python 3.14.3 macOS."
    - "Decimal('0').is_subnormal() == False — zero is neither normal nor subnormal; verified Python 3.14.3 macOS."
    - "Decimal('Inf').is_subnormal() == False — infinity is not subnormal; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# is_signed() — sign bit predicate
# is_signed() tests the IEEE 754 sign bit, not mathematical positivity.
# Decimal('-0').is_signed() == True because the sign bit is set.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra242.is_signed:
  description: "Decimal.is_signed() sign bit predicate; verified Python 3.14.3"
  kind: python_call_eq
  category: predicates
  id_prefix: dectest242
  function: Decimal
  method: is_signed

  columns: [id, args, expected]
  rows:
    - [negative_one,  ["-1"],  true ]
    - [positive_one,  ["1"],   false]
    - [negative_zero, ["-0"],  true ]
    - [positive_zero, ["0"],   false]
    - [negative_inf,  ["-Inf"], true]

# ---------------------------------------------------------------------------
# is_normal() — normal finite nonzero number predicate
# is_normal() returns True for regular nonzero finite numbers in range.
# Returns False for zero, infinity, NaN, and subnormals.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra242.is_normal:
  description: "Decimal.is_normal() predicate for finite nonzero numbers; verified Python 3.14.3"
  kind: python_call_eq
  category: predicates
  id_prefix: dectest242
  function: Decimal
  method: is_normal

  columns: [id, args, expected]
  rows:
    - [positive_one,   ["1"],    true ]
    - [positive_zero,  ["0"],    false]
    - [infinity,       ["Inf"],  false]
    - [negative_one,   ["-1"],   true ]
    - [nan,            ["NaN"],  false]

# ---------------------------------------------------------------------------
# is_subnormal() — subnormal number predicate
# With default context (prec=28, Emin=-999999) no common value is subnormal.
# is_subnormal() returns False for normal, zero, infinity, and NaN.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra242.is_subnormal:
  description: "Decimal.is_subnormal() returns False for normal, zero, infinity, NaN in default context; verified Python 3.14.3"
  kind: python_call_eq
  category: predicates
  id_prefix: dectest242
  function: Decimal
  method: is_subnormal

  columns: [id, args, expected]
  rows:
    - [positive_one,  ["1"],   false]
    - [zero,          ["0"],   false]
    - [infinity,      ["Inf"], false]
    - [negative_one,  ["-1"],  false]
    - [nan,           ["NaN"], false]

# ---------------------------------------------------------------------------
# Standalone invariants — is_signed
# ---------------------------------------------------------------------------

invariant decimal_extra242.Decimal.is_signed.negative_one:
  description: "Decimal('-1').is_signed() == True — negative numbers have sign bit 1; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["-1"]
  method: is_signed
  expected: true

invariant decimal_extra242.Decimal.is_signed.positive_one:
  description: "Decimal('1').is_signed() == False — positive numbers have sign bit 0; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_signed
  expected: false

invariant decimal_extra242.Decimal.is_signed.negative_zero:
  description: "Decimal('-0').is_signed() == True — negative zero has sign bit 1 even though its value equals 0; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["-0"]
  method: is_signed
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — is_normal
# ---------------------------------------------------------------------------

invariant decimal_extra242.Decimal.is_normal.positive_one:
  description: "Decimal('1').is_normal() == True — a regular nonzero finite number is normal; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_normal
  expected: true

invariant decimal_extra242.Decimal.is_normal.zero:
  description: "Decimal('0').is_normal() == False — zero is not normal; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_normal
  expected: false

invariant decimal_extra242.Decimal.is_normal.infinity:
  description: "Decimal('Inf').is_normal() == False — infinity is not normal; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["Inf"]
  method: is_normal
  expected: false

invariant decimal_extra242.Decimal.is_normal.negative_one:
  description: "Decimal('-1').is_normal() == True — negative regular numbers are also normal; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["-1"]
  method: is_normal
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — is_subnormal
# ---------------------------------------------------------------------------

invariant decimal_extra242.Decimal.is_subnormal.positive_one:
  description: "Decimal('1').is_subnormal() == False — normal numbers are not subnormal; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_subnormal
  expected: false

invariant decimal_extra242.Decimal.is_subnormal.zero:
  description: "Decimal('0').is_subnormal() == False — zero is neither normal nor subnormal; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_subnormal
  expected: false

invariant decimal_extra242.Decimal.is_subnormal.infinity:
  description: "Decimal('Inf').is_subnormal() == False — infinity is not subnormal; verified Python 3.14.3 macOS"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["Inf"]
  method: is_subnormal
  expected: false
