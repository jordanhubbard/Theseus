spec: operator_extra10
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra9.zspec.zsdl."
    - "operator_extra5 covers __qualname__ for add/sub/mul/truediv/floordiv/mod/pow/neg/pos/abs/eq/ne/lt/le/gt/ge and inplace iadd/isub/imul/itruediv (via table)."
    - "operator_extra5 covers __qualname__ for not_/xor/lshift/rshift/contains/truth/is_/concat/index/length_hint (via table)."
    - "operator_extra6 covers matmul __name__/__qualname__/__module__."
    - "operator_extra7 covers imatmul/__module__ and ipow/__module__."
    - "NEW axis: __qualname__ for in-place operators iand/ior/ixor/imod/ifloordiv/ilshift/irshift/ipow — not yet verified as standalone invariants."
    - "NEW axis: __qualname__ for invert/is_not — not yet verified as standalone invariants."
    - "NEW axis: __name__ length checks for selected operators — not yet covered by any spec."
    - "operator.iand.__qualname__ == 'iand' — C builtin; __qualname__ equals __name__."
    - "operator.ior.__qualname__ == 'ior' — C builtin."
    - "operator.ixor.__qualname__ == 'ixor' — C builtin."
    - "operator.invert.__qualname__ == 'invert' — C builtin."
    - "operator.is_not.__qualname__ == 'is_not' — C builtin."
    - "operator.imatmul.__qualname__ == 'imatmul' — C builtin."
    - "operator.ipow.__qualname__ == 'ipow' — C builtin."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for in-place bitwise / modular operators
#
# operator_extra5 covers __qualname__ for many operators but omits the in-place
# bitwise group (iand/ior/ixor) and the in-place arithmetic remainders
# (imod/ifloordiv/ipow/ilshift/irshift). All are C builtins whose __qualname__
# equals their __name__.
# ---------------------------------------------------------------------------

table operator_extra10.inplace_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn

  columns: [id, function, args, expected]
  rows:
    - [iand,      iand.__qualname__.__eq__,      ["iand"],      true]
    - [ior,       ior.__qualname__.__eq__,        ["ior"],       true]
    - [ixor,      ixor.__qualname__.__eq__,       ["ixor"],      true]
    - [imod,      imod.__qualname__.__eq__,       ["imod"],      true]
    - [ifloordiv, ifloordiv.__qualname__.__eq__,  ["ifloordiv"], true]
    - [ipow,      ipow.__qualname__.__eq__,       ["ipow"],      true]
    - [ilshift,   ilshift.__qualname__.__eq__,    ["ilshift"],   true]
    - [irshift,   irshift.__qualname__.__eq__,    ["irshift"],   true]
    - [imatmul,   imatmul.__qualname__.__eq__,    ["imatmul"],   true]

# ---------------------------------------------------------------------------
# __qualname__ for invert and is_not
#
# operator_extra5 does not include invert or is_not in its qualname table.
# operator_extra9 covers and_/or_ __name__ (trailing underscore operators)
# but not invert or is_not. Both are C builtins; __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant operator_extra10.invert.qualname:
  description: "operator.invert.__qualname__ == 'invert' — C builtin unary bitwise NOT"
  category: qualnames
  kind: python_call_eq
  function: invert.__qualname__.__eq__
  args: ["invert"]
  expected: true

invariant operator_extra10.is_not.qualname:
  description: "operator.is_not.__qualname__ == 'is_not' — C builtin identity non-equality"
  category: qualnames
  kind: python_call_eq
  function: is_not.__qualname__.__eq__
  args: ["is_not"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ length checks — a structural axis distinct from equality
#
# No prior spec checks the string length of __name__ attributes for operator
# functions. These verify the character count of selected function names.
# ---------------------------------------------------------------------------

invariant operator_extra10.imatmul.name_len:
  description: "len(operator.imatmul.__name__) == 7 — 'imatmul' has 7 characters"
  category: function_names
  kind: python_call_eq
  function: imatmul.__name__.__len__
  args: []
  expected: 7

invariant operator_extra10.ifloordiv.name_len:
  description: "len(operator.ifloordiv.__name__) == 9 — 'ifloordiv' has 9 characters"
  category: function_names
  kind: python_call_eq
  function: ifloordiv.__name__.__len__
  args: []
  expected: 9

invariant operator_extra10.length_hint.name_len:
  description: "len(operator.length_hint.__name__) == 11 — 'length_hint' has 11 characters"
  category: function_names
  kind: python_call_eq
  function: length_hint.__name__.__len__
  args: []
  expected: 11
