spec: pathlib_extra289
version: ">=3.4"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "pathlib_extra288 covers PurePath division (the / operator via __truediv__)."
    - "This spec focuses on PurePath error/edge cases: empty path, root path, name/parent of boundary paths, and error-raising stat calls."
    - "PurePath('').name == '' — the empty path has no name component."
    - "str(PurePath('')) == '.' — the empty path normalizes to '.' (the current directory)."
    - "PurePath('') == PurePath('.') — the empty path is equivalent to the current-directory path."
    - "PurePath('/').name == '' — the root path has no name component."
    - "str(PurePath('/').parent) == '/' — the parent of root is root itself."
    - "str(PurePath('/a').parent) == '/' — the parent of a single-component absolute path is root."
    - "PurePath('/a').is_absolute() == True — paths starting with '/' are absolute."
    - "PurePath('a').is_absolute() == False — a relative path is not absolute."
    - "Path('/nonexistent_abc_xyz_123').stat() raises FileNotFoundError — stat requires the path to exist."
    - "PurePath('/a/b.txt').suffix == '.txt' — suffix is the last file extension including the dot."
    - "PurePath('/a/b.txt').stem == 'b' — stem is the filename without the final extension."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePath edge cases — name and parent at the root and empty path boundaries
#
# PurePath('').name == ''  — empty path has no name
# PurePath('/').name  == '' — root has no name
# str(PurePath('/').parent) == '/'  — parent of root is root
# str(PurePath('/a').parent) == '/' — parent of a first-level path is root
# ---------------------------------------------------------------------------

table pathlib_extra289.PurePath_boundary_name_parent:
  description: "PurePath name and parent at boundary paths: empty path and root"
  kind: python_call_eq
  category: boundary
  id_prefix: pbnd289

  columns: [id, function, args, expected, description]
  rows:
    - [empty_name,       "PurePath('').name",              [], "",  "PurePath('').name == '' — empty path has no name component"]
    - [root_name,        "PurePath('/').name",             [], "",  "PurePath('/').name == '' — root path has no name component"]
    - [root_parent_str,  "PurePath('/').parent.__str__",   [], "/", "str(PurePath('/').parent) == '/' — parent of root is root"]
    - [a_parent_str,     "PurePath('/a').parent.__str__",  [], "/", "str(PurePath('/a').parent) == '/' — parent of single-segment absolute path is root"]
    - [a_name,           "PurePath('/a').name",            [], "a", "PurePath('/a').name == 'a' — name of /a is 'a'"]

# ---------------------------------------------------------------------------
# PurePath suffix, stem, and is_absolute
#
# PurePath('/a/b.txt').suffix == '.txt'
# PurePath('/a/b.txt').stem   == 'b'
# PurePath('/a/b').suffix     == ''
# PurePath('/a').is_absolute() == True
# PurePath('a').is_absolute()  == False
# ---------------------------------------------------------------------------

table pathlib_extra289.PurePath_suffix_stem_abs:
  description: "PurePath suffix, stem, and is_absolute() for various path forms"
  kind: python_call_eq
  category: components
  id_prefix: pcomp289

  columns: [id, function, args, expected, description]
  rows:
    - [suffix_txt,         "PurePath('/a/b.txt').suffix",        [], ".txt", "PurePath('/a/b.txt').suffix == '.txt' — the dot is included in suffix"]
    - [suffix_none,        "PurePath('/a/b').suffix",            [], "",     "PurePath('/a/b').suffix == '' — no extension gives empty suffix"]
    - [stem_txt,           "PurePath('/a/b.txt').stem",          [], "b",    "PurePath('/a/b.txt').stem == 'b' — stem excludes the final extension"]
    - [stem_no_ext,        "PurePath('/a/b').stem",              [], "b",    "PurePath('/a/b').stem == 'b' — stem is the full name when there is no extension"]
    - [is_abs_slash,       "PurePath('/a').is_absolute",         [], true,   "PurePath('/a').is_absolute() == True — paths starting with '/' are absolute"]
    - [is_abs_relative,    "PurePath('a').is_absolute",          [], false,  "PurePath('a').is_absolute() == False — relative paths are not absolute"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra289.PurePath.empty_name_is_empty_string:
  description: "PurePath('').name == '' — the empty path has no final component; name is an empty string"
  category: boundary
  kind: python_call_eq
  function: "PurePath('').name.__eq__"
  args: [""]
  expected: true

invariant pathlib_extra289.PurePath.root_name_is_empty_string:
  description: "PurePath('/').name == '' — the root path has no name component; name is an empty string"
  category: boundary
  kind: python_call_eq
  function: "PurePath('/').name.__eq__"
  args: [""]
  expected: true

invariant pathlib_extra289.PurePath.root_parent_is_root:
  description: "str(PurePath('/').parent) == '/' — the root path is its own parent; navigating up from root stays at root"
  category: boundary
  kind: python_call_eq
  function: "PurePath('/').parent.__str__"
  args: []
  expected: "/"

invariant pathlib_extra289.PurePath.a_parent_is_root:
  description: "str(PurePath('/a').parent) == '/' — the parent of the first-level absolute path '/a' is root '/'"
  category: boundary
  kind: python_call_eq
  function: "PurePath('/a').parent.__str__"
  args: []
  expected: "/"

invariant pathlib_extra289.PurePath.suffix_dot_txt:
  description: "PurePath('/a/b.txt').suffix == '.txt' — suffix includes the leading dot and represents the final file extension"
  category: components
  kind: python_call_eq
  function: "PurePath('/a/b.txt').suffix.__eq__"
  args: [".txt"]
  expected: true

invariant pathlib_extra289.PurePath.stem_no_extension:
  description: "PurePath('/a/b.txt').stem == 'b' — stem is the filename without the last extension"
  category: components
  kind: python_call_eq
  function: "PurePath('/a/b.txt').stem.__eq__"
  args: ["b"]
  expected: true

invariant pathlib_extra289.PurePath.is_absolute_true:
  description: "PurePath('/a').is_absolute() == True — any path starting with '/' is absolute on POSIX systems"
  category: components
  kind: python_call_eq
  function: "PurePath('/a').is_absolute"
  args: []
  expected: true

invariant pathlib_extra289.Path.stat_nonexistent_raises:
  description: "Path('/nonexistent_abc_xyz_123').stat() raises FileNotFoundError — stat() requires the path to exist on the filesystem"
  category: errors
  kind: python_call_raises
  function: "Path('/nonexistent_abc_xyz_123').stat"
  args: []
  raises: FileNotFoundError
