    - ["as3091008", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__hash__"], false]
    - ["as3091009", operator.contains, [asyncio.Handle.__dict__,           "__hash__"], false]
    - ["as3091010", operator.contains, [asyncio.TimerHandle.__dict__,      "__hash__"], true]
    - ["as3091011", operator.contains, [asyncio.Timeout.__dict__,          "__hash__"], false]
    - ["as3091012", operator.contains, [asyncio.TaskGroup.__dict__,        "__hash__"], false]
    - ["as3091013", operator.contains, [asyncio.StreamReader.__dict__,     "__hash__"], false]
    - ["as3091014", operator.contains, [asyncio.StreamWriter.__dict__,     "__hash__"], false]

# ---------------------------------------------------------------------------
# __eq__ dict-presence — operator.contains(Cls.__dict__, '__eq__')
#
# asyncio.TimerHandle: TRUE — defines __eq__ to compare timer handles by their
#   scheduled time, enabling meaningful equality comparisons in the event loop
#   scheduler.
# All other asyncio classes: false — they do not define __eq__ in their own
#   __dict__ and rely on identity-based equality inherited from object.
# ---------------------------------------------------------------------------

