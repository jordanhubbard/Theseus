# ---------------------------------------------------------------------------
# __bool__ dict-presence — operator.contains(Cls.__dict__, '__bool__')
#
# All 14 asyncio classes return false for __bool__.
# No asyncio class defines custom boolean coercion; they all evaluate as truthy
# by inheriting the default from object (which always returns True).
# asyncio synchronization primitives (Lock, Semaphore, etc.) do not expose
# their internal locked/unlocked state as a bool via __bool__.
# ---------------------------------------------------------------------------

