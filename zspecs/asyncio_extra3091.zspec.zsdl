spec: as3091
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 653 (as3091): __hash__, __eq__, __bool__ dict-presence for asyncio types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: asyncio.Task, asyncio.Future, asyncio.Queue, asyncio.Event, asyncio.Semaphore, asyncio.Lock, asyncio.Condition, asyncio.BoundedSemaphore, asyncio.Handle, asyncio.TimerHandle, asyncio.Timeout, asyncio.TaskGroup, asyncio.StreamReader, asyncio.StreamWriter."
    - "Key finding: asyncio.TimerHandle defines both __hash__ and __eq__ in its own __dict__ (both true). TimerHandle overrides __eq__ to compare scheduled times and __hash__ for use in sets/dicts (e.g. scheduler internals)."
    - "All other 13 asyncio classes return false for __hash__, __eq__, and __bool__ — they inherit identity-based hashing and equality from object and define no custom boolean coercion."
    - "__bool__ is false for all 14 asyncio classes — none define custom truthiness; they always evaluate as truthy by inheriting from object."
    - "asyncio.Future does NOT define __hash__ = None in its own __dict__ on Python 3.14 — it inherits identity-based hashing from object rather than explicitly suppressing it."
    - "asyncio.Task similarly does not override __hash__ or __eq__ in its own __dict__ on Python 3.14."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __hash__ dict-presence — operator.contains(Cls.__dict__, '__hash__')
#
# asyncio.TimerHandle: TRUE — defines __hash__ explicitly to support use
#   in sets and dicts. TimerHandle objects can be compared and hashed by their
#   scheduled time and internal state.
# All other asyncio classes: false — they do not define __hash__ in their own
#   __dict__ and rely on identity-based hashing inherited from object.
# ---------------------------------------------------------------------------

table as3091.hash:
  description: "asyncio types __hash__ dict-presence checks; wave 653"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3091

  columns: [id, function, args, expected]
  rows:
    - ["as3091001", operator.contains, [asyncio.Task.__dict__,             "__hash__"], false]
    - ["as3091002", operator.contains, [asyncio.Future.__dict__,           "__hash__"], false]
    - ["as3091003", operator.contains, [asyncio.Queue.__dict__,            "__hash__"], false]
