spec: io_extra2761
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "io_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "io_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 631 (io_extra2761) theme: __matmul__, __truediv__, and __iadd__ dict-presence checks."
    - "None of the io classes define __matmul__, __truediv__, or __iadd__ in their own __dict__."
    - "__matmul__ supports the @ operator; io stream classes are sequential I/O objects, not matrix/numeric types."
    - "__truediv__ supports the / operator; io stream classes do not implement true-division numeric semantics."
    - "__iadd__ supports the += operator; io stream classes do not implement in-place addition semantics."
    - "Covers io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and io.TextIOWrapper."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __matmul__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2761.no_matmul_in_io_classes:
  description: "__matmul__ is absent from all io class __dict__s — io stream classes do not implement the @ matrix-multiplication protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2761

  columns: [id, function, args, expected]
  rows:
    - ["io2761001", "io.IOBase.__dict__.__contains__",         ["__matmul__"], false]
    - ["io2761002", "io.RawIOBase.__dict__.__contains__",      ["__matmul__"], false]
    - ["io2761003", "io.BufferedIOBase.__dict__.__contains__", ["__matmul__"], false]
    - ["io2761004", "io.TextIOBase.__dict__.__contains__",     ["__matmul__"], false]
    - ["io2761005", "io.BytesIO.__dict__.__contains__",        ["__matmul__"], false]
    - ["io2761006", "io.StringIO.__dict__.__contains__",       ["__matmul__"], false]

# ---------------------------------------------------------------------------
# __truediv__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2761.no_truediv_in_io_classes:
  description: "__truediv__ is absent from all io class __dict__s — io stream classes do not implement the / true-division protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2761

  columns: [id, function, args, expected]
  rows:
    - ["io2761007", "io.IOBase.__dict__.__contains__",          ["__truediv__"], false]
    - ["io2761008", "io.FileIO.__dict__.__contains__",          ["__truediv__"], false]
    - ["io2761009", "io.BufferedReader.__dict__.__contains__",  ["__truediv__"], false]
    - ["io2761010", "io.BufferedWriter.__dict__.__contains__",  ["__truediv__"], false]
    - ["io2761011", "io.BufferedRandom.__dict__.__contains__",  ["__truediv__"], false]
    - ["io2761012", "io.TextIOWrapper.__dict__.__contains__",   ["__truediv__"], false]

# ---------------------------------------------------------------------------
# __iadd__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2761.no_iadd_in_io_classes:
  description: "__iadd__ is absent from all io class __dict__s — io stream classes do not implement the += in-place addition protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2761

  columns: [id, function, args, expected]
  rows:
    - ["io2761013", "io.IOBase.__dict__.__contains__",         ["__iadd__"], false]
    - ["io2761014", "io.BytesIO.__dict__.__contains__",        ["__iadd__"], false]
    - ["io2761015", "io.StringIO.__dict__.__contains__",       ["__iadd__"], false]
    - ["io2761016", "io.FileIO.__dict__.__contains__",         ["__iadd__"], false]
    - ["io2761017", "io.BufferedReader.__dict__.__contains__", ["__iadd__"], false]
    - ["io2761018", "io.BufferedWriter.__dict__.__contains__", ["__iadd__"], false]

# ---------------------------------------------------------------------------
# Complementary: io stream classes have I/O methods but not arithmetic operator hooks
# Confirms that io classes are sequential I/O objects, not numeric or matrix types
# ---------------------------------------------------------------------------

table io_extra2761.io_has_stream_methods_not_arithmetic_operator_hooks:
  description: "io.BytesIO defines read/write/seek/tell but NOT __matmul__/__truediv__/__iadd__; io.StringIO similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2761

  columns: [id, function, args, expected]
  rows:
    - ["io2761019", "io.BytesIO.__dict__.__contains__",  ["read"],       true]
    - ["io2761020", "io.BytesIO.__dict__.__contains__",  ["write"],      true]
    - ["io2761021", "io.BytesIO.__dict__.__contains__",  ["seek"],       true]
    - ["io2761022", "io.BytesIO.__dict__.__contains__",  ["tell"],       true]
    - ["io2761023", "io.BytesIO.__dict__.__contains__",  ["__matmul__"], false]
    - ["io2761024", "io.BytesIO.__dict__.__contains__",  ["__truediv__"],false]
    - ["io2761025", "io.BytesIO.__dict__.__contains__",  ["__iadd__"],   false]
    - ["io2761026", "io.StringIO.__dict__.__contains__", ["read"],       true]
    - ["io2761027", "io.StringIO.__dict__.__contains__", ["write"],      true]
    - ["io2761028", "io.StringIO.__dict__.__contains__", ["seek"],       true]
    - ["io2761029", "io.StringIO.__dict__.__contains__", ["tell"],       true]
    - ["io2761030", "io.StringIO.__dict__.__contains__", ["__matmul__"], false]
    - ["io2761031", "io.StringIO.__dict__.__contains__", ["__truediv__"],false]
    - ["io2761032", "io.StringIO.__dict__.__contains__", ["__iadd__"],   false]
