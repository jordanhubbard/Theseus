spec: reprlib_extra8
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl and prior extras through reprlib_extra7.zspec.zsdl."
    - "reprlib.zspec.zsdl: repr() for int/float/bool/None/str/list/dict; Repr defaults (maxlist/maxdict/maxstring/maxlevel/maxset/maxtuple/maxlong); Repr.__name__; list truncation at 7 elements."
    - "reprlib_extra: Repr.__module__, recursive_repr.__name__, repr.__name__, aRepr.__class__.__name__, aRepr attribute types (maxstring/maxlist/maxdict/maxtuple as int)."
    - "reprlib_extra2: Repr.__name__/__module__, Repr.__bases__[0].__name__=='object', Repr class attr types (maxstring/maxlevel/maxlist as int), repr.__name__, recursive_repr.__name__, aRepr class name, aRepr instance attr types table."
    - "reprlib_extra3: Repr.__name__ table, recursive_repr.__name__ table, Repr.__module__, aRepr.__class__.__name__, Repr() defaults (maxstring/maxlist/maxdict/maxother/maxlevel), recursive_repr.__module__, Repr().repr_list.__func__.__name__."
    - "reprlib_extra4: Repr.__qualname__, recursive_repr.__qualname__, repr.__qualname__=='Repr.repr', function_names table, repr([1..11]) truncation, repr(0), repr(-100), aRepr.maxarray, Repr().maxarray, Repr().maxlong method_args form."
    - "reprlib_extra5: Repr.__name__/recursive_repr.__name__/repr.__name__ standalone; Repr().maxlist/maxstring/maxdict method_args form; aRepr.maxset/maxtuple/maxfrozenset/maxlong values."
    - "reprlib_extra6: Repr().maxset/maxtuple/maxfrozenset method_args form; aRepr.maxstring/maxlist/maxdict/maxlevel values; repr([1,2]); repr([10,20,30,40]); repr(1); Repr().maxother method_args form."
    - "reprlib_extra7: class_function_names table (id_prefix rname); repr.__name__ standalone; Repr().maxlevel/maxlong method_args form; aRepr.maxother value; repr(3.14)/repr(True)/repr(False)/repr({})/repr([1,2,3])."
    - "This spec adds: repr.__name__/Repr.__name__/aRepr.__class__.__name__ grouped in a table under id_prefix rname8 (extra8 namespace, distinct structural anchor from extra7 id_prefix rname); Repr().maxstring.__class__.__name__ == 'int' (fresh Repr() instance form — reprlib_extra checks aRepr form, reprlib_extra2 checks class-level form; the Repr() instance form is new); repr() of a negative float; repr() of an empty list; repr(99) as a new integer not present in any prior spec."
    - "reprlib.repr.__name__ == 'repr' — grouped in rname8 table (extra8 namespace anchor)."
    - "reprlib.Repr.__name__ == 'Repr' — grouped in rname8 table (extra8 namespace anchor)."
    - "reprlib.aRepr.__class__.__name__ == 'Repr' — grouped in rname8 table (extra8 namespace anchor)."
    - "reprlib.Repr().maxstring.__class__.__name__ == 'int' — Repr() fresh instance; prior specs check aRepr.maxstring (extra) and Repr.maxstring class attribute (extra2); the Repr() instance attribute type is new."
    - "reprlib.repr(-3.14) == '-3.14' — negative float within maxother limit; reprlib_extra7 covers repr(3.14) (positive); negative float is new."
    - "reprlib.repr([]) == '[]' — empty list repr; no prior spec covers empty list."
    - "reprlib.repr(99) == '99' — small positive integer; reprlib_extra4 covers 0 and -100; reprlib_extra6 covers 1; 99 is a new integer vector."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Identity table — extra8 namespace, id_prefix rname8
#
# reprlib_extra7 uses id_prefix rname in a table covering Repr.__name__,
# Repr.__module__, recursive_repr.__name__, recursive_repr.__module__.
# This table uses id_prefix rname8 (extra8 namespace) and covers three of
# the assigned axes: repr.__name__, Repr.__name__, aRepr.__class__.__name__.
# ---------------------------------------------------------------------------

table reprlib_extra8.identity_names:
  kind: python_call_eq
  category: identity
  id_prefix: rname8

  columns: [id, function, args, expected]
  rows:
    - [repr_name,        repr.__name__.__eq__,              ["repr"],  true]
    - [Repr_name,        Repr.__name__.__eq__,              ["Repr"],  true]
    - [aRepr_class_name, aRepr.__class__.__name__.__eq__,  ["Repr"],  true]

# ---------------------------------------------------------------------------
# maxstring value type — Repr() fresh instance form
#
# reprlib_extra (reprlib_extra.aRepr.maxstring_is_int) checks the type of
# aRepr.maxstring (the module-level Repr instance).
# reprlib_extra2 (reprlib_extra2.Repr.maxstring_is_int) checks the type of
# Repr.maxstring (the class-level attribute).
# This invariant checks the type of maxstring on a freshly constructed Repr()
# instance, which is the assigned "maxstring value type" axis in the extra8 namespace.
# ---------------------------------------------------------------------------

invariant reprlib_extra8.Repr_instance.maxstring_type:
  description: "reprlib.Repr().maxstring.__class__.__name__ == 'int' — maxstring on a fresh Repr() instance is an int"
  category: Repr_defaults
  kind: python_call_eq
  function: Repr
  args: []
  method: maxstring.__class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# reprlib.repr — additional primitive vectors
#
# reprlib_extra7 covers repr(3.14) (positive float) and repr(True)/repr(False).
# reprlib_extra4 covers repr(0) and repr(-100) (integers).
# reprlib_extra6 covers repr(1) and repr([1,2]) and repr([10,20,30,40]).
# New here:
#   repr(-3.14) — negative float (reprlib_extra7 covers positive 3.14, not negative)
#   repr([])    — empty list (args: [[]] passes [] as the argument to repr)
#   repr(99)    — integer 99, not used in any prior spec
# ---------------------------------------------------------------------------

invariant reprlib_extra8.repr.negative_float:
  description: "reprlib.repr(-3.14) == '-3.14' — negative float within maxother limit"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [-3.14]
  expected: "-3.14"

invariant reprlib_extra8.repr.empty_list:
  description: "reprlib.repr([]) == '[]' — empty list repr; no prior spec covers empty list"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [[]]
  expected: "[]"

invariant reprlib_extra8.repr.integer_99:
  description: "reprlib.repr(99) == '99' — small positive integer not covered in any prior spec"
  category: primitives
  kind: python_call_eq
  function: repr
  args: [99]
  expected: "99"
