spec: cbor
version: ">=9.0.0"
backend: node(cbor)

docs: https://github.com/hildjj/node-cbor#readme

provenance:
  derived_from:
    - "node-cbor README — https://github.com/hildjj/node-cbor#readme"
    - "RFC 8949 — Concise Binary Object Representation (CBOR)"
    - "Test vectors verified with node-cbor via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "node-cbor source"
  notes:
    - "node-cbor implements RFC 8949 CBOR encoding/decoding."
    - "Install: npm install cbor"
    - "encode(value) returns a Node Buffer; decode(buf) returns the JS value."
    - "Wire-byte vectors below are derived from RFC 8949 Appendix A (Examples)."
  rfcs:
    - "RFC 8949 — Concise Binary Object Representation (CBOR) — https://www.rfc-editor.org/rfc/rfc8949"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; never throws on valid input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# encode(value) — Buffer -> base64 for equality comparison
table cbor.encode:
  kind: node_chain_eq
  category: encode
  entry: named
  function: encode
  id_prefix: enc

  columns: [id, entry_args, chain, expected]
  rows:
    - [single_pair_object,
       [{a: 1}],
       [{method: toString, args: ["base64"]}],
       "oWFhAQ=="]

    - [array_three,
       [[1, 2, 3]],
       [{method: toString, args: ["base64"]}],
       "gwECAw=="]

    - [int_42,
       [42],
       [{method: toString, args: ["base64"]}],
       "GCo="]

    - [boolean_true,
       [true],
       [{method: toString, args: ["base64"]}],
       "9Q==",
       {rfc: "RFC 8949 §3.3 — major type 7 / simple value 21 = 0xf5"}]

    - [null_value,
       [~],
       [{method: toString, args: ["base64"]}],
       "9g==",
       {rfc: "RFC 8949 §3.3 — major type 7 / simple value 22 = 0xf6"}]

# decode round-trip via re-encode of decoded result
table cbor.roundtrip:
  kind: node_chain_eq
  category: roundtrip
  entry: named
  function: encode
  id_prefix: rt

  columns: [id, entry_args, chain, expected]
  rows:
    - [object_in_array,
       [[{x: 1}, {y: [2, 3]}]],
       [{method: toString, args: ["base64"]}],
       "gqFheAGhYXmCAgM="]
