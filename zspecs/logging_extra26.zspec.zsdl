spec: logging_extra26
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging_extra22.zspec.zsdl — covers __mro__[-1].__name__ for nine major logging classes."
    - "logging_extra23.zspec.zsdl — covers __qualname__ for Logger.debug/info/warning/error/critical/exception, Handler.emit/handle, Formatter.format."
    - "logging_extra24.zspec.zsdl — covers __qualname__ for StreamHandler.emit, FileHandler.emit, NullHandler.emit, Filter.filter, LogRecord class and getMessage method, getLogger/basicConfig/makeLogRecord module-level functions."
    - "logging_extra25.zspec.zsdl — covers Handler/Formatter class __qualname__/__module__, Handler.setLevel/format method qualnames, Formatter.formatTime qualname, StreamHandler/FileHandler class __qualname__/__bases__[0].__name__, LogRecord.__module__."
  notes:
    - "This spec extends the logging chain through logging_extra25; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) logging.Logger.__qualname__ and __module__ — extra23 covers Logger method qualnames but not the Logger class itself; (2) logging.Logger.__bases__[0].__name__ == 'Filterer' — Logger inherits from Filterer; (3) logging.RootLogger.__qualname__ and __module__ — no prior spec checks RootLogger class attributes; (4) logging.RootLogger.__bases__[0].__name__ == 'Logger' — RootLogger inherits from Logger; (5) logging level constants DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET — their integer values and __class__.__name__ == 'int'."
    - "logging.Logger.__qualname__ == 'Logger' — len 6. No prior spec checks Logger class __qualname__ as a standalone. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Logger.__module__ == 'logging' — len 7. No prior spec checks Logger.__module__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Logger.__bases__[0].__name__ == 'Filterer' — Logger inherits directly from Filterer. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.RootLogger.__qualname__ == 'RootLogger' — len 10. No prior spec checks RootLogger class attributes. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.RootLogger.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.RootLogger.__bases__[0].__name__ == 'Logger' — RootLogger inherits from Logger. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.DEBUG == 10; logging.INFO == 20; logging.WARNING == 30; logging.ERROR == 40; logging.CRITICAL == 50; logging.NOTSET == 0. All are plain ints (__class__.__name__ == 'int'). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# logging.Logger class __qualname__ and __module__
#
# logging_extra23 covers Logger.debug/info/warning/error/critical/exception
# method __qualname__ values. No prior spec checks Logger class __qualname__
# or __module__ as standalone invariants.
# Logger.__qualname__ == 'Logger' (len 6).
# Logger.__module__ == 'logging' (len 7).
# ---------------------------------------------------------------------------

invariant logging_extra26.Logger.qualname_eq:
  description: "logging.Logger.__qualname__ == 'Logger' — no prior spec checks Logger class __qualname__ as a standalone invariant"
  category: class_qualname
  kind: python_call_eq
  function: "Logger.__qualname__.__eq__"
  args: ["Logger"]
  expected: true

invariant logging_extra26.Logger.qualname_len:
  description: "len(logging.Logger.__qualname__) == 6 — len('Logger') == 6"
  category: class_qualname
  kind: python_call_eq
  function: "Logger.__qualname__.__len__"
  args: []
  expected: 6

invariant logging_extra26.Logger.module_eq:
  description: "logging.Logger.__module__ == 'logging' — no prior spec checks Logger.__module__"
  category: class_module
  kind: python_call_eq
  function: "Logger.__module__.__eq__"
  args: ["logging"]
  expected: true

# ---------------------------------------------------------------------------
# logging.Logger.__bases__[0].__name__
#
# Logger inherits from Filterer. No prior spec checks Logger's inheritance chain
# via __bases__[0].__name__. Logger.__bases__[0].__name__ == 'Filterer'.
# ---------------------------------------------------------------------------

invariant logging_extra26.Logger.bases0_name_eq:
  description: "logging.Logger.__bases__[0].__name__ == 'Filterer' — Logger inherits directly from Filterer"
  category: class_hierarchy
  kind: python_call_eq
  "function": "Logger.__bases__[0].__name__.__eq__"
  args: ["Filterer"]
  expected: true

# ---------------------------------------------------------------------------
# logging.RootLogger class __qualname__, __module__, and __bases__[0].__name__
#
# No prior spec checks any attribute of RootLogger. RootLogger is the class
# used for the root logger instance (logging.root / logging.getLogger()).
# RootLogger.__qualname__ == 'RootLogger' (len 10).
# RootLogger.__module__ == 'logging' (len 7).
# RootLogger.__bases__[0].__name__ == 'Logger' (inherits from Logger).
# ---------------------------------------------------------------------------

invariant logging_extra26.RootLogger.qualname_eq:
  description: "logging.RootLogger.__qualname__ == 'RootLogger' — no prior spec checks any RootLogger class attribute"
  category: class_qualname
  kind: python_call_eq
  function: "RootLogger.__qualname__.__eq__"
  args: ["RootLogger"]
  expected: true

invariant logging_extra26.RootLogger.qualname_len:
  description: "len(logging.RootLogger.__qualname__) == 10 — len('RootLogger') == 10"
  category: class_qualname
  kind: python_call_eq
  function: "RootLogger.__qualname__.__len__"
  args: []
  expected: 10

invariant logging_extra26.RootLogger.module_eq:
  description: "logging.RootLogger.__module__ == 'logging' — no prior spec checks RootLogger.__module__"
  category: class_module
  kind: python_call_eq
  function: "RootLogger.__module__.__eq__"
  args: ["logging"]
  expected: true

invariant logging_extra26.RootLogger.bases0_name_eq:
  description: "logging.RootLogger.__bases__[0].__name__ == 'Logger' — RootLogger inherits from Logger"
  category: class_hierarchy
  kind: python_call_eq
  "function": "RootLogger.__bases__[0].__name__.__eq__"
  args: ["Logger"]
  expected: true

# ---------------------------------------------------------------------------
# logging level constants: DEBUG, INFO, WARNING, ERROR, CRITICAL, NOTSET
#
# The logging module defines six integer level constants. No prior spec checks
# their values or types. All six are plain Python ints (__class__.__name__ == 'int').
# DEBUG == 10, INFO == 20, WARNING == 30, ERROR == 40, CRITICAL == 50, NOTSET == 0.
# ---------------------------------------------------------------------------

invariant logging_extra26.DEBUG.class_name_eq:
  description: "logging.DEBUG.__class__.__name__ == 'int' — DEBUG is a plain Python int constant"
  category: level_constants
  kind: python_call_eq
  "function": "DEBUG.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

table logging_extra26.level_values:
  description: "Numeric values for logging level constants: NOTSET==0, DEBUG==10, INFO==20, WARNING==30, ERROR==40, CRITICAL==50"
  kind: python_call_eq
  category: level_constants
  id_prefix: lv26

  columns: [id, function, args, expected]
  rows:
    - [NOTSET,    NOTSET.__eq__,    [0],  true]
    - [DEBUG,     DEBUG.__eq__,     [10], true]
    - [INFO,      INFO.__eq__,      [20], true]
    - [WARNING,   WARNING.__eq__,   [30], true]
    - [ERROR,     ERROR.__eq__,     [40], true]
    - [CRITICAL,  CRITICAL.__eq__,  [50], true]

table logging_extra26.level_class_names:
  description: "__class__.__name__ == 'int' for INFO, WARNING, ERROR, CRITICAL, NOTSET — all logging levels are plain ints"
  kind: python_call_eq
  category: level_constants
  id_prefix: lcn26

  columns: [id, function, args, expected]
  rows:
    - [INFO,     "INFO.__class__.__name__.__eq__",     ["int"], true]
    - [WARNING,  "WARNING.__class__.__name__.__eq__",  ["int"], true]
    - [ERROR,    "ERROR.__class__.__name__.__eq__",    ["int"], true]
    - [CRITICAL, "CRITICAL.__class__.__name__.__eq__", ["int"], true]
    - [NOTSET,   "NOTSET.__class__.__name__.__eq__",   ["int"], true]
