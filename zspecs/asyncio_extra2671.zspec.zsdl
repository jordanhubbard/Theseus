spec: asyncio_extra2671
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier __dict__ for __sub__, __floordiv__, __mod__ presence (all false)"]
  created_at: "2026-04-13"
error_model: python_exceptions

table asyncio_extra2671.queue_task_future_dict_presence:
  description: "asyncio.Queue, asyncio.Task, asyncio.Future __dict__ does not contain __sub__, __floordiv__, __mod__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2671qtf
  columns: [id, function, args, expected]
  rows:
    - ["as2671qtf001", asyncio.Queue.__dict__.__contains__, ["__sub__"], false]
    - ["as2671qtf002", asyncio.Queue.__dict__.__contains__, ["__floordiv__"], false]
    - ["as2671qtf003", asyncio.Queue.__dict__.__contains__, ["__mod__"], false]
    - ["as2671qtf004", asyncio.Task.__dict__.__contains__, ["__sub__"], false]
    - ["as2671qtf005", asyncio.Task.__dict__.__contains__, ["__floordiv__"], false]
    - ["as2671qtf006", asyncio.Task.__dict__.__contains__, ["__mod__"], false]
    - ["as2671qtf007", asyncio.Future.__dict__.__contains__, ["__sub__"], false]
    - ["as2671qtf008", asyncio.Future.__dict__.__contains__, ["__floordiv__"], false]
    - ["as2671qtf009", asyncio.Future.__dict__.__contains__, ["__mod__"], false]

