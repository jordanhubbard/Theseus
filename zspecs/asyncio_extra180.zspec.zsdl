spec: asyncio_extra180
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio queues documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec covers: asyncio.LifoQueue and PriorityQueue class identity — asyncio.LifoQueue.__name__=='LifoQueue' (len=9); asyncio.LifoQueue.__module__=='asyncio.queues'; asyncio.LifoQueue.__mro__.__len__()==4 (LifoQueue > Queue > _LoopBoundMixin > object); asyncio.LifoQueue.__bases__[0].__name__=='Queue'; asyncio.PriorityQueue.__name__=='PriorityQueue' (len=13); asyncio.PriorityQueue.__module__=='asyncio.queues'; asyncio.PriorityQueue.__mro__.__len__()==4; asyncio.PriorityQueue.__bases__[0].__name__=='Queue'."
    - "asyncio.LifoQueue.__name__ == 'LifoQueue' (len=9: L-i-f-o-Q-u-e-u-e). LifoQueue is a last-in, first-out variant of asyncio.Queue used in async producer-consumer patterns. Its MRO is [LifoQueue, Queue, _LoopBoundMixin, object] giving __mro__.__len__()==4. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.PriorityQueue.__name__ == 'PriorityQueue' (len=13: P-r-i-o-r-i-t-y-Q-u-e-u-e). PriorityQueue retrieves items in priority order (lowest value first). Its MRO is also [PriorityQueue, Queue, _LoopBoundMixin, object] giving __mro__.__len__()==4. Both LifoQueue and PriorityQueue share the same MRO depth of 4. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.LifoQueue.__module__ == 'asyncio.queues'. asyncio.PriorityQueue.__module__ == 'asyncio.queues'. Both classes are defined in the asyncio.queues submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue'. asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue'. Both LifoQueue and PriorityQueue directly subclass asyncio.Queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.LifoQueue class identity — __name__, __module__, MRO
#
# asyncio.LifoQueue.__name__ == 'LifoQueue' (len=9)
# asyncio.LifoQueue.__module__ == 'asyncio.queues'
# asyncio.LifoQueue.__mro__.__len__() == 4  (LifoQueue > Queue > _LoopBoundMixin > object)
#
# LifoQueue is defined in asyncio.queues and inherits from Queue which inherits
# from _LoopBoundMixin which inherits from object, giving MRO depth 4.
# New to extra180.
# ---------------------------------------------------------------------------

table asyncio_extra180.lifoqueue_identity:
  description: "asyncio.LifoQueue.__name__ 'LifoQueue' len 9; __module__ 'asyncio.queues'; __mro__.__len__()==4; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolifopq180

  columns: [id, function, args, expected, description]
  rows:
    - [lq_name_eq,
       LifoQueue.__name__.__eq__,
       ["LifoQueue"],
       true,
       "asyncio.LifoQueue.__name__.__eq__('LifoQueue') == True — LifoQueue is a last-in first-out variant of asyncio.Queue used in async producer-consumer patterns; its __name__ is 'LifoQueue' (9 chars: L-i-f-o-Q-u-e-u-e); str.__eq__('LifoQueue') returns True; new to extra180"]
    - [lq_name_len_9,
       LifoQueue.__name__.__len__,
       [],
       9,
       "asyncio.LifoQueue.__name__.__len__() == 9 — 'LifoQueue' has 9 characters: L-i-f-o-Q-u-e-u-e; shorter than 'PriorityQueue'=13; NAME LENGTHS: LifoQueue=9 < PriorityQueue=13; str.__len__() returns 9; new to extra180"]
    - [lq_module_eq,
       LifoQueue.__module__.__eq__,
       ["asyncio.queues"],
       true,
       "asyncio.LifoQueue.__module__.__eq__('asyncio.queues') == True — LifoQueue is defined in the asyncio.queues submodule, not in asyncio.__init__; its __module__ is 'asyncio.queues'; str.__eq__('asyncio.queues') returns True; new to extra180"]
    - [lq_mro_len_4,
       LifoQueue.__mro__.__len__,
       [],
       4,
       "asyncio.LifoQueue.__mro__.__len__() == 4 — MRO is [LifoQueue, Queue, _LoopBoundMixin, object]; LifoQueue subclasses Queue which subclasses _LoopBoundMixin which subclasses object; __mro__.__len__() returns 4; new to extra180"]
    - [lq_module_len,
       LifoQueue.__module__.__len__,
       [],
       14,
       "asyncio.LifoQueue.__module__.__len__() == 14 — 'asyncio.queues' has 14 characters: asyncio=7 + '.'=1 + queues=6 = 14; str.__len__() returns 14; new to extra180"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.LifoQueue.__bases__ and base class identity
#
# asyncio.LifoQueue.__bases__[0].__name__ == 'Queue'
#
# LifoQueue directly subclasses asyncio.Queue (its only base class).
# New to extra180.
# ---------------------------------------------------------------------------

table asyncio_extra180.lifoqueue_bases:
  description: "asyncio.LifoQueue.__bases__[0].__name__=='Queue'; bases len 1; base module 'asyncio.queues'; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolifopq180

  columns: [id, function, args, expected, description]
  rows:
    - [lq_base0_name_eq,
       "LifoQueue.__bases__[0].__name__.__eq__",
       ["Queue"],
       true,
       "asyncio.LifoQueue.__bases__[0].__name__.__eq__('Queue') == True — LifoQueue's sole direct base class is asyncio.Queue; __bases__[0].__name__ is 'Queue' (5 chars: Q-u-e-u-e); str.__eq__('Queue') returns True; new to extra180"]
    - [lq_bases_len_1,
       "LifoQueue.__bases__.__len__",
       [],
       1,
       "asyncio.LifoQueue.__bases__.__len__() == 1 — LifoQueue has exactly one direct base class: Queue; __bases__ is a 1-element tuple; tuple.__len__() returns 1; new to extra180"]
    - [lq_base0_module_eq,
       "LifoQueue.__bases__[0].__module__.__eq__",
       ["asyncio.queues"],
       true,
       "asyncio.LifoQueue.__bases__[0].__module__.__eq__('asyncio.queues') == True — asyncio.Queue (LifoQueue's base) is also defined in asyncio.queues; its __module__ is 'asyncio.queues'; str.__eq__('asyncio.queues') returns True; new to extra180"]
    - [lq_base0_name_len_5,
       "LifoQueue.__bases__[0].__name__.__len__",
       [],
       5,
       "asyncio.LifoQueue.__bases__[0].__name__.__len__() == 5 — 'Queue' has 5 characters: Q-u-e-u-e; the base class name; str.__len__() returns 5; new to extra180"]
    - [lq_mro0_name_eq,
       "LifoQueue.__mro__[0].__name__.__eq__",
       ["LifoQueue"],
       true,
       "asyncio.LifoQueue.__mro__[0].__name__.__eq__('LifoQueue') == True — the first element of the MRO is always the class itself; __mro__[0] is LifoQueue; str.__eq__('LifoQueue') returns True; new to extra180"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.PriorityQueue class identity — __name__, __module__, MRO, bases
#
# asyncio.PriorityQueue.__name__ == 'PriorityQueue' (len=13)
# asyncio.PriorityQueue.__module__ == 'asyncio.queues'
# asyncio.PriorityQueue.__mro__.__len__() == 4
# asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue'
#
# PriorityQueue is defined in asyncio.queues alongside LifoQueue and Queue.
# New to extra180.
# ---------------------------------------------------------------------------

table asyncio_extra180.priorityqueue_identity:
  description: "asyncio.PriorityQueue.__name__ 'PriorityQueue' len 13; __module__ 'asyncio.queues'; __mro__.__len__()==4; __bases__[0].__name__=='Queue'; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolifopq180

  columns: [id, function, args, expected, description]
  rows:
    - [pq_name_eq,
       PriorityQueue.__name__.__eq__,
       ["PriorityQueue"],
       true,
       "asyncio.PriorityQueue.__name__.__eq__('PriorityQueue') == True — PriorityQueue retrieves entries in priority order (lowest value first) using heapq under the hood; its __name__ is 'PriorityQueue' (13 chars: P-r-i-o-r-i-t-y-Q-u-e-u-e); str.__eq__('PriorityQueue') returns True; new to extra180"]
    - [pq_name_len_13,
       PriorityQueue.__name__.__len__,
       [],
       13,
       "asyncio.PriorityQueue.__name__.__len__() == 13 — 'PriorityQueue' has 13 characters: P-r-i-o-r-i-t-y-Q-u-e-u-e; longer than 'LifoQueue'=9; NAME LENGTHS: LifoQueue=9 < PriorityQueue=13; str.__len__() returns 13; new to extra180"]
    - [pq_module_eq,
       PriorityQueue.__module__.__eq__,
       ["asyncio.queues"],
       true,
       "asyncio.PriorityQueue.__module__.__eq__('asyncio.queues') == True — PriorityQueue is defined in the same asyncio.queues submodule as LifoQueue and Queue; its __module__ is 'asyncio.queues'; str.__eq__('asyncio.queues') returns True; new to extra180"]
    - [pq_mro_len_4,
       PriorityQueue.__mro__.__len__,
       [],
       4,
       "asyncio.PriorityQueue.__mro__.__len__() == 4 — MRO is [PriorityQueue, Queue, _LoopBoundMixin, object]; same MRO depth as LifoQueue=4; both queue variants share the same inheritance chain; __mro__.__len__() returns 4; new to extra180"]
    - [pq_base0_name_eq,
       "PriorityQueue.__bases__[0].__name__.__eq__",
       ["Queue"],
       true,
       "asyncio.PriorityQueue.__bases__[0].__name__.__eq__('Queue') == True — PriorityQueue's sole direct base class is asyncio.Queue, the same as LifoQueue; __bases__[0].__name__ is 'Queue'; str.__eq__('Queue') returns True; new to extra180"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra180
# ---------------------------------------------------------------------------

invariant asyncio_extra180.lifoqueue_name_eq:
  description: "asyncio.LifoQueue.__name__ == 'LifoQueue' — last-in first-out async queue variant; name len=9 (L-i-f-o-Q-u-e-u-e); new to extra180"
  category: identity
  kind: python_call_eq
  function: LifoQueue.__name__.__eq__
  args: ["LifoQueue"]
  expected: true

invariant asyncio_extra180.lifoqueue_module_eq:
  description: "asyncio.LifoQueue.__module__ == 'asyncio.queues' — defined in the queues submodule alongside Queue and PriorityQueue; new to extra180"
  category: identity
  kind: python_call_eq
  function: LifoQueue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra180.lifoqueue_mro_len_4:
  description: "asyncio.LifoQueue.__mro__.__len__() == 4 — MRO is [LifoQueue, Queue, _LoopBoundMixin, object]; 4 levels deep; same as PriorityQueue; new to extra180"
  category: identity
  kind: python_call_eq
  function: LifoQueue.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra180.priorityqueue_name_len_13:
  description: "asyncio.PriorityQueue.__name__.__len__() == 13 — 'PriorityQueue' has 13 chars; longer than 'LifoQueue'=9; NAME LENGTHS: LifoQueue=9 < PriorityQueue=13; new to extra180"
  category: identity
  kind: python_call_eq
  function: PriorityQueue.__name__.__len__
  args: []
  expected: 13

invariant asyncio_extra180.priorityqueue_module_eq:
  description: "asyncio.PriorityQueue.__module__ == 'asyncio.queues' — defined in the same module as LifoQueue; new to extra180"
  category: identity
  kind: python_call_eq
  function: PriorityQueue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra180.priorityqueue_mro_len_4:
  description: "asyncio.PriorityQueue.__mro__.__len__() == 4 — MRO is [PriorityQueue, Queue, _LoopBoundMixin, object]; same depth as LifoQueue=4; new to extra180"
  category: identity
  kind: python_call_eq
  function: PriorityQueue.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra180.lifoqueue_base0_name_eq:
  description: "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue' — LifoQueue directly subclasses asyncio.Queue; new to extra180"
  category: identity
  kind: python_call_eq
  function: "LifoQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant asyncio_extra180.priorityqueue_base0_name_eq:
  description: "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue' — PriorityQueue directly subclasses asyncio.Queue, same as LifoQueue; new to extra180"
  category: identity
  kind: python_call_eq
  function: "PriorityQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true
