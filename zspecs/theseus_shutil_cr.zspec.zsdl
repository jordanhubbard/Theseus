spec: theseus_shutil_cr
version: ">=3.8"
backend: python_cleanroom(theseus_shutil_cr)
blocks: shutil

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/shutil.html"
  not_derived_from:
    - "CPython source: Lib/shutil.py (internal implementation)"
  notes:
    - "Clean-room shutil subset. Do NOT import shutil."
    - "copyfileobj(fsrc, fdst): copy file-like object content between two file-like objects."
    - "copyfile(src, dst): copy bytes of src path to dst path (no metadata)."
    - "which(name): return path to executable, or None if not found."
    - "rmtree(path): recursively remove directory tree."
    - "gettempdir()-independent: rely only on os module (not tempfile)."

error_model: python_exceptions

invariant theseus_shutil_cr.shutil2_copyfileobj:
  description: "copyfileobj with BytesIO returns copied bytes"
  category: copyfileobj
  kind: python_call_eq
  function: shutil2_copyfileobj
  args: []
  expected: true

invariant theseus_shutil_cr.shutil2_which:
  description: "which('python3') or which('python') is not None"
  category: which
  kind: python_call_eq
  function: shutil2_which
  args: []
  expected: true

invariant theseus_shutil_cr.shutil2_rmtree:
  description: "rmtree removes a directory tree; returns True when gone"
  category: rmtree
  kind: python_call_eq
  function: shutil2_rmtree
  args: []
  expected: true
