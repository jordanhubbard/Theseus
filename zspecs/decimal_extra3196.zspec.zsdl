spec: dc3196
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 660 (dc3196): __pow__, __lshift__, __rshift__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "decimal.Decimal defines __pow__ in its own __dict__ (true): Decimal supports ** exponentiation as a full IEEE 754 numeric type implementing the complete arithmetic protocol."
    - "decimal.Decimal does NOT define __lshift__ in its own __dict__ (false): Decimal supports decimal arithmetic but not bitwise left-shift, which is an integer operation."
    - "decimal.Decimal does NOT define __rshift__ in its own __dict__ (false): Decimal supports decimal arithmetic but not bitwise right-shift, which is an integer operation."
    - "decimal.Context does NOT define __pow__, __lshift__, or __rshift__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __pow__ dict-presence — operator.contains(Cls.__dict__, '__pow__')
#
# decimal.Decimal defines __pow__ in its own __dict__ (true): full numeric type
# supporting ** exponentiation per IEEE 754.
# All other decimal classes are false: Context is a configuration object;
# exception subclasses do not define arithmetic.
# ---------------------------------------------------------------------------

table dc3196.pow:
  description: "decimal types __pow__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3196

  columns: [id, function, args, expected]
  rows:
    - ["dc3196001", operator.contains, [decimal.Decimal.__dict__,          "__pow__"], true]
    - ["dc3196002", operator.contains, [decimal.Context.__dict__,           "__pow__"], false]
    - ["dc3196003", operator.contains, [decimal.DecimalException.__dict__,  "__pow__"], false]
    - ["dc3196004", operator.contains, [decimal.InvalidOperation.__dict__,  "__pow__"], false]
    - ["dc3196005", operator.contains, [decimal.Overflow.__dict__,          "__pow__"], false]
    - ["dc3196006", operator.contains, [decimal.Underflow.__dict__,         "__pow__"], false]

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — operator.contains(Cls.__dict__, '__lshift__')
#
# No decimal class defines __lshift__ in its own __dict__; all false.
# Decimal arithmetic does not include bitwise left-shift; that is an integer
# operation only. decimal.Decimal is a decimal floating-point type, not an int.
# ---------------------------------------------------------------------------

table dc3196.lshift:
  description: "decimal types __lshift__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
