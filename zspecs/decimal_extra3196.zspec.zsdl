    - ["dc3196008", operator.contains, [decimal.Context.__dict__,           "__lshift__"], false]
    - ["dc3196009", operator.contains, [decimal.DecimalException.__dict__,  "__lshift__"], false]
    - ["dc3196010", operator.contains, [decimal.InvalidOperation.__dict__,  "__lshift__"], false]
    - ["dc3196011", operator.contains, [decimal.Overflow.__dict__,          "__lshift__"], false]
    - ["dc3196012", operator.contains, [decimal.Underflow.__dict__,         "__lshift__"], false]

