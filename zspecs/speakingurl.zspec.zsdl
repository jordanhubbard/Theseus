spec: speakingurl
version: ">=14.0.1"
backend: node(speakingurl)

docs: https://www.npmjs.com/package/speakingurl

provenance:
  derived_from:
    - "speakingurl README — https://www.npmjs.com/package/speakingurl"
    - "Test vectors verified with speakingurl via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "speakingurl source"
  notes:
    - "speakingurl is an npm package. Install: npm install speakingurl"
    - "Generates a URL slug from a string, handling special characters and transliteration."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table speakingurl.slug:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: spkurl

  columns: [id, args, expected]
  rows:
    - [spaces,   ["Hello World"],  "hello-world"]
    - [multi,    ["Foo Bar Baz"],  "foo-bar-baz"]
