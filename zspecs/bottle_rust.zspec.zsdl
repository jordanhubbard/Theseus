spec: bottle_rust
version: ">=3.9"
backend: rust_module(bottle_rust)

docs: https://bottlepy.org/

provenance:
  derived_from:
    - "https://bottlepy.org/ — Bottle web framework"
  notes:
    - "Bottle is a lightweight WSGI micro web framework."
    - "bottle.Bottle is a class."
    - "bottle.app() returns a Bottle instance."
    - "bottle.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant bottle_rust.has_bottle_class:
  description: "bottle.Bottle is a class"
  category: presence
  kind: python_call_eq
  function: bottle_has_bottle_class
  args: []
  expected: true

invariant bottle_rust.has_route:
  description: "bottle.route is callable"
  category: presence
  kind: python_call_eq
  function: bottle_has_route
  args: []
  expected: true

invariant bottle_rust.version_nonempty:
  description: "bottle.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: bottle_version_nonempty
  args: []
  expected: true

