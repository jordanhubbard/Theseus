spec: io_extra
version: ">=3.2"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "Python io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "io.TextIOWrapper wraps a BufferedIOBase and decodes bytes to str using a codec."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' and its module is '_io' (C implementation)."
    - "io.BufferedRandom supports both reading and writing on a seekable raw stream."
    - "io.BufferedRandom.__name__ == 'BufferedRandom' and its module is '_io'."
    - "io.UnsupportedOperation is the exception raised when an unsupported stream operation is attempted."
    - "io.UnsupportedOperation is a subclass of OSError and ValueError."
    - "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' and its module is 'io'."
    - "io.DEFAULT_BUFFER_SIZE is a positive integer; on most platforms it equals 8192 (8 KiB) per POSIX defaults."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'."
    - "SEEK_SET, SEEK_CUR, SEEK_END are plain ints; their __class__.__name__ == 'int'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# DEFAULT_BUFFER_SIZE — type and lower-bound checks
# ---------------------------------------------------------------------------

invariant io_extra.DEFAULT_BUFFER_SIZE.is_int:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra.DEFAULT_BUFFER_SIZE.positive:
  description: "io.DEFAULT_BUFFER_SIZE > 0"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# SEEK_* constants — type checks
# ---------------------------------------------------------------------------

table io_extra.seek_constants.types:
  description: "SEEK_SET, SEEK_CUR, SEEK_END are plain int objects"
  kind: python_call_eq
  category: constants
  id_prefix: seek_type

  columns: [id, function, args, expected]
  rows:
    - [seek_set, SEEK_SET.__class__.__name__.__eq__, ["int"], true]
    - [seek_cur, SEEK_CUR.__class__.__name__.__eq__, ["int"], true]
    - [seek_end, SEEK_END.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# TextIOWrapper — class identity
# ---------------------------------------------------------------------------

invariant io_extra.TextIOWrapper.class_name:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper'"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra.TextIOWrapper.is_type:
  description: "type(io.TextIOWrapper).__name__ == 'type' — TextIOWrapper is a class"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra.TextIOWrapper.base:
  description: "io.TextIOWrapper.__bases__[0].__name__ == 'TextIOBase'"
  category: class_metadata
  kind: python_call_eq
  function: TextIOWrapper.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "TextIOBase"

# ---------------------------------------------------------------------------
# BufferedRandom — class identity
# ---------------------------------------------------------------------------

invariant io_extra.BufferedRandom.class_name:
  description: "io.BufferedRandom.__name__ == 'BufferedRandom'"
  category: class_metadata
  kind: python_call_eq
  function: BufferedRandom.__name__.__eq__
  args: ["BufferedRandom"]
  expected: true

invariant io_extra.BufferedRandom.is_type:
  description: "type(io.BufferedRandom).__name__ == 'type' — BufferedRandom is a class"
  category: class_metadata
  kind: python_call_eq
  function: BufferedRandom.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra.BufferedRandom.base:
  description: "io.BufferedRandom.__bases__[0].__name__ == 'BufferedIOBase'"
  category: class_metadata
  kind: python_call_eq
  function: BufferedRandom.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "BufferedIOBase"

# ---------------------------------------------------------------------------
# UnsupportedOperation — class identity and hierarchy
# ---------------------------------------------------------------------------

invariant io_extra.UnsupportedOperation.class_name:
  description: "io.UnsupportedOperation.__name__ == 'UnsupportedOperation'"
  category: unsupported_op
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra.UnsupportedOperation.module:
  description: "io.UnsupportedOperation.__module__ == 'io'"
  category: unsupported_op
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra.UnsupportedOperation.is_type:
  description: "type(io.UnsupportedOperation).__name__ == 'type'"
  category: unsupported_op
  kind: python_call_eq
  function: UnsupportedOperation.__class__.__name__.__eq__
  args: ["type"]
  expected: true
