spec: brace_expansion
version: ">=4.0.0"
backend: node(brace-expansion)

docs: https://github.com/juliangruber/brace-expansion#readme

provenance:
  derived_from:
    - "brace-expansion README — https://github.com/juliangruber/brace-expansion#readme"
    - "Test vectors verified with brace-expansion@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "brace-expansion source: index.js"
  notes:
    - "brace-expansion exports an object with an expand() method."
    - "expand(str) returns an array of expanded strings."
    - "Comma-separated alternatives {a,b} expand to one entry per alternative."
    - "Numeric ranges {1..3} expand to strings '1','2','3'."
    - "Strings without braces expand to a single-element array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of strings. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table brace_expansion.expand:
  kind: node_module_call_eq
  function: expand
  category: expand
  id_prefix: be

  columns: [id, args, expected]
  rows:
    - [comma,    ["{a,b}c"],  ["ac", "bc"]]
    - [range,    ["{1..3}"],  ["1", "2", "3"]]
    - [plain,    ["abc"],     ["abc"]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:00:50Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
