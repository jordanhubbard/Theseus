spec: certifi
version: ">=2020.0"
backend: python_module(certifi)

docs: https://pypi.org/project/certifi/

provenance:
  derived_from:
    - "certifi PyPI page — https://pypi.org/project/certifi/"
    - "certifi README — https://github.com/certifi/python-certifi"
    - "Test vectors verified with certifi 2025.11.12 on macOS/Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "certifi source: core.py"
    - "certifi source: __init__.py"
  notes:
    - "certifi exposes one primary API: certifi.where() returning the path to cacert.pem."
    - "The CA bundle path always ends with 'cacert.pem' and contains 'certifi' in the path."
    - "certifi.__version__ is a date-based version string (YYYY.MM.DD) containing two dots."
    - "Verified: certifi.where() on macOS returns a 61-character path — not used as a fixed"
    - "  expected value since path length varies by installation; use string property checks."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — __version__ is a date-based string containing dots
# ---------------------------------------------------------------------------

invariant certifi.version.contains_dot:
  description: "__version__ contains a dot (date-based versioning e.g. '2025.11.12')"
  category: version
  kind: python_call_eq
  function: __version__.__contains__
  args: ["."]
  expected: true

invariant certifi.version.contains_two_dots:
  description: "__version__ has exactly two dots (YYYY.MM.DD format, e.g. '2025.11.12')"
  category: version
  kind: python_call_eq
  function: __version__.count
  args: ["."]
  expected: 2

# ---------------------------------------------------------------------------
# where — certifi.where() returns a path string ending with cacert.pem
# ---------------------------------------------------------------------------

invariant certifi.where.ends_with_pem:
  description: "certifi.where() returns a path ending with '.pem'"
  category: where
  kind: python_call_eq
  function: where
  args: []
  method: endswith
  method_args: [".pem"]
  expected: true

invariant certifi.where.ends_with_cacert_pem:
  description: "certifi.where() returns a path ending with 'cacert.pem'"
  category: where
  kind: python_call_eq
  function: where
  args: []
  method: endswith
  method_args: ["cacert.pem"]
  expected: true

invariant certifi.where.contains_cacert:
  description: "certifi.where() path contains the substring 'cacert'"
  category: where
  kind: python_call_eq
  function: where
  args: []
  method: __contains__
  method_args: ["cacert"]
  expected: true

invariant certifi.where.contains_certifi:
  description: "certifi.where() path contains 'certifi' (file lives inside the certifi package)"
  category: where
  kind: python_call_eq
  function: where
  args: []
  method: __contains__
  method_args: ["certifi"]
  expected: true

invariant certifi.where.is_absolute_path:
  description: "certifi.where() returns an absolute path (starts with '/')"
  category: where
  kind: python_call_eq
  function: where
  args: []
  method: startswith
  method_args: ["/"]
  expected: true

invariant certifi.where.does_not_end_with_slash:
  description: "certifi.where() path does not end with '/' (it is a file path, not a directory)"
  category: where
  kind: python_call_eq
  function: where
  args: []
  method: endswith
  method_args: ["/"]
  expected: false

# ---------------------------------------------------------------------------
# contents — path string properties imply a valid CA bundle location
# ---------------------------------------------------------------------------

invariant certifi.contents.pem_occurs_once:
  description: "'.pem' appears exactly once in the path (unique file extension)"
  category: contents
  kind: python_call_eq
  function: where
  args: []
  method: count
  method_args: [".pem"]
  expected: 1

invariant certifi.contents.path_has_slashes:
  description: "certifi.where() path contains '/' characters (is a file system path)"
  category: contents
  kind: python_call_eq
  function: where
  args: []
  method: __contains__
  method_args: ["/"]
  expected: true

invariant certifi.contents.not_dot_relative:
  description: "certifi.where() does not start with '.' (is not a relative path)"
  category: contents
  kind: python_call_eq
  function: where
  args: []
  method: startswith
  method_args: ["."]
  expected: false
