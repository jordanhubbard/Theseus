spec: threading_extra1471
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 545 theme: __len__ and __getitem__ method presence and type checks for threading classes."
    - "threading.Thread: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "threading.Event: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "threading.Semaphore: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__ (has __enter__/__exit__). Verified with Python 3.12."
    - "threading.Barrier: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "threading.Condition: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__ (has __enter__/__exit__). Verified with Python 3.12."
    - "threading.BoundedSemaphore: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "All threading synchronization primitives are lock/event/barrier types; none implement sequence or mapping protocols."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread and Event — __len__ and __getitem__ absence
#
# Wave 545 theme: threading.Thread, Event — the fundamental thread class and
# event synchronization primitive.
#
# threading.Thread.__dict__.__contains__("__len__") == False
# threading.Thread.__dict__.__contains__("__getitem__") == False
# threading.Event.__dict__.__contains__("__len__") == False
# threading.Event.__dict__.__contains__("__getitem__") == False
# threading.Thread.__dict__.__contains__("__setitem__") == False
# threading.Event.__dict__.__contains__("__setitem__") == False
#
# Thread is a Python class representing an OS-level thread. Event is a
# boolean-flag synchronization primitive. Neither implements sequence or
# mapping protocols. New to extra1471.
# ---------------------------------------------------------------------------

table threading_extra1471.thread_event_len_getitem_absence:
  description: "threading.Thread and Event have no __len__, __getitem__, or __setitem__ in __dict__; synchronization objects, not sequences; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1471te

  columns: [id, function, args, expected, description]
  rows:
    - [th1471te001,
       "Thread.__dict__.__contains__",
       ["__len__"],
       false,
       "threading.Thread.__dict__.__contains__('__len__') == False — Thread represents an OS-level thread of execution; it does not implement the sequence protocol; __len__ is not in Thread.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471te002,
       "Thread.__dict__.__contains__",
       ["__getitem__"],
       false,
       "threading.Thread.__dict__.__contains__('__getitem__') == False — Thread does not support index access; threads are not containers; __getitem__ is not in Thread.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471te003,
       "Thread.__dict__.__contains__",
       ["__setitem__"],
       false,
       "threading.Thread.__dict__.__contains__('__setitem__') == False — Thread does not support item assignment; __setitem__ is not in Thread.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471te004,
       "Event.__dict__.__contains__",
       ["__len__"],
       false,
       "threading.Event.__dict__.__contains__('__len__') == False — Event is a boolean-flag synchronization primitive; it does not implement the sequence protocol; __len__ is not in Event.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471te005,
       "Event.__dict__.__contains__",
       ["__getitem__"],
       false,
       "threading.Event.__dict__.__contains__('__getitem__') == False — Event does not support index access; it manages only an internal boolean flag; __getitem__ is not in Event.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471te006,
       "Event.__dict__.__contains__",
       ["__setitem__"],
       false,
       "threading.Event.__dict__.__contains__('__setitem__') == False — Event does not support item assignment; __setitem__ is not in Event.__dict__; verified with Python 3.12; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore and Condition — __len__ and __getitem__ absence
#
# Wave 545 theme: threading.Semaphore, Condition — context-manager-supporting
# synchronization primitives.
#
# threading.Semaphore.__dict__.__contains__("__len__") == False
# threading.Semaphore.__dict__.__contains__("__getitem__") == False
# threading.Condition.__dict__.__contains__("__len__") == False
# threading.Condition.__dict__.__contains__("__getitem__") == False
# threading.Semaphore.__dict__.__contains__("__enter__") == True
# threading.Condition.__dict__.__contains__("__enter__") == True
#
# Semaphore and Condition both define __enter__/__exit__ for use as context
# managers (with statement), but they do NOT define __len__ or __getitem__.
# New to extra1471.
# ---------------------------------------------------------------------------

table threading_extra1471.semaphore_condition_len_getitem_absence:
  description: "threading.Semaphore/Condition have no __len__ or __getitem__ in __dict__; both define __enter__/__exit__ for context manager use; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1471sc

  columns: [id, function, args, expected, description]
  rows:
    - [th1471sc001,
       "Semaphore.__dict__.__contains__",
       ["__len__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__len__') == False — Semaphore is a counting synchronization primitive; it does not implement the sequence protocol; __len__ is not in Semaphore.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471sc002,
       "Semaphore.__dict__.__contains__",
       ["__getitem__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__getitem__') == False — Semaphore does not support index access; __getitem__ is not in Semaphore.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471sc003,
       "Semaphore.__dict__.__contains__",
       ["__enter__"],
       true,
       "threading.Semaphore.__dict__.__contains__('__enter__') == True — Semaphore IS a context manager and defines __enter__ for use in 'with' statements; __enter__ IS in Semaphore.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471sc004,
       "Condition.__dict__.__contains__",
       ["__len__"],
       false,
       "threading.Condition.__dict__.__contains__('__len__') == False — Condition is a synchronization primitive wrapping a lock with wait/notify; it does not implement the sequence protocol; __len__ is not in Condition.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471sc005,
       "Condition.__dict__.__contains__",
       ["__getitem__"],
       false,
       "threading.Condition.__dict__.__contains__('__getitem__') == False — Condition does not support index access; __getitem__ is not in Condition.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471sc006,
       "Condition.__dict__.__contains__",
       ["__enter__"],
       true,
       "threading.Condition.__dict__.__contains__('__enter__') == True — Condition IS a context manager and defines __enter__ for use in 'with' statements; __enter__ IS in Condition.__dict__; verified with Python 3.12; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier and BoundedSemaphore — __len__ and __getitem__ absence
#
# Wave 545 theme: threading.Barrier, BoundedSemaphore — barrier and bounded
# semaphore synchronization primitives.
#
# threading.Barrier.__dict__.__contains__("__len__") == False
# threading.Barrier.__dict__.__contains__("__getitem__") == False
# threading.BoundedSemaphore.__dict__.__contains__("__len__") == False
# threading.BoundedSemaphore.__dict__.__contains__("__getitem__") == False
# threading.Barrier.__dict__.__contains__("__delitem__") == False
# threading.BoundedSemaphore.__dict__.__contains__("__delitem__") == False
#
# Barrier makes threads wait until a specified number have reached a barrier
# point. BoundedSemaphore is a Semaphore that raises ValueError if released
# beyond its initial count. Neither implements sequence or mapping protocols.
# New to extra1471.
# ---------------------------------------------------------------------------

table threading_extra1471.barrier_boundedsemaphore_len_getitem_absence:
  description: "threading.Barrier/BoundedSemaphore have no __len__, __getitem__, or __delitem__ in __dict__; synchronization primitives only; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1471bb

  columns: [id, function, args, expected, description]
  rows:
    - [th1471bb001,
       "Barrier.__dict__.__contains__",
       ["__len__"],
       false,
       "threading.Barrier.__dict__.__contains__('__len__') == False — Barrier synchronizes a fixed number of threads at a common point; it does not implement the sequence protocol; __len__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471bb002,
       "Barrier.__dict__.__contains__",
       ["__getitem__"],
       false,
       "threading.Barrier.__dict__.__contains__('__getitem__') == False — Barrier does not support index access; __getitem__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471bb003,
       "Barrier.__dict__.__contains__",
       ["__delitem__"],
       false,
       "threading.Barrier.__dict__.__contains__('__delitem__') == False — Barrier does not support item deletion; __delitem__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471bb004,
       "BoundedSemaphore.__dict__.__contains__",
       ["__len__"],
       false,
       "threading.BoundedSemaphore.__dict__.__contains__('__len__') == False — BoundedSemaphore is a Semaphore with an upper release bound; it does not implement the sequence protocol; __len__ is not in BoundedSemaphore.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471bb005,
       "BoundedSemaphore.__dict__.__contains__",
       ["__getitem__"],
       false,
       "threading.BoundedSemaphore.__dict__.__contains__('__getitem__') == False — BoundedSemaphore does not support index access; __getitem__ is not in BoundedSemaphore.__dict__; verified with Python 3.12; new to extra1471"]
    - [th1471bb006,
       "BoundedSemaphore.__dict__.__contains__",
       ["__delitem__"],
       false,
       "threading.BoundedSemaphore.__dict__.__contains__('__delitem__') == False — BoundedSemaphore does not support item deletion; __delitem__ is not in BoundedSemaphore.__dict__; verified with Python 3.12; new to extra1471"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1471
# ---------------------------------------------------------------------------

invariant threading_extra1471.thread_no_len:
  description: "threading.Thread.__dict__ does not contain '__len__' — Thread is a thread object, not a sequence; wave 545; new to extra1471"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant threading_extra1471.thread_no_getitem:
  description: "threading.Thread.__dict__ does not contain '__getitem__' — Thread does not support index access; wave 545; new to extra1471"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__getitem__"]
  expected: false

invariant threading_extra1471.event_no_len:
  description: "threading.Event.__dict__ does not contain '__len__' — Event is a boolean flag primitive, not a sequence; wave 545; new to extra1471"
  kind: python_call_eq
  function: Event.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant threading_extra1471.semaphore_no_len:
  description: "threading.Semaphore.__dict__ does not contain '__len__' — Semaphore is a counting primitive, not a sequence; wave 545; new to extra1471"
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant threading_extra1471.condition_no_len:
  description: "threading.Condition.__dict__ does not contain '__len__' — Condition is a wait/notify primitive, not a sequence; wave 545; new to extra1471"
  kind: python_call_eq
  function: Condition.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant threading_extra1471.barrier_no_len:
  description: "threading.Barrier.__dict__ does not contain '__len__' — Barrier is a thread synchronization barrier, not a sequence; wave 545; new to extra1471"
  kind: python_call_eq
  function: Barrier.__dict__.__contains__
  args: ["__len__"]
  expected: false
