spec: decimal_extra1051
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal and Context documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.Decimal, decimal.Context, decimal.DecimalException __init_subclass__ qualnames and Decimal method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1051.init_subclass_qualnames:
  description: "decimal class __init_subclass__.__qualname__ identity (should equal object.__init_subclass__)"
  kind: python_call_eq
  category: init_subclass_qualnames
  id_prefix: dc1051x
  columns: [id, function, args, expected]
  rows:
    - [dc1051x001, decimal.Decimal.__init_subclass__.__qualname__.__eq__,          ["object.__init_subclass__"], true]
    - [dc1051x002, decimal.Context.__init_subclass__.__qualname__.__eq__,          ["object.__init_subclass__"], true]
    - [dc1051x003, decimal.DecimalException.__init_subclass__.__qualname__.__eq__, ["object.__init_subclass__"], true]
    - [dc1051x004, decimal.InvalidOperation.__init_subclass__.__qualname__.__eq__, ["object.__init_subclass__"], true]
    - [dc1051x005, decimal.DivisionByZero.__init_subclass__.__qualname__.__eq__,   ["object.__init_subclass__"], true]
    - [dc1051x006, decimal.Overflow.__init_subclass__.__qualname__.__eq__,         ["object.__init_subclass__"], true]
    - [dc1051x007, decimal.Underflow.__init_subclass__.__qualname__.__eq__,        ["object.__init_subclass__"], true]

table decimal_extra1051.decimal_method_qualnames:
  description: "decimal.Decimal arithmetic and query method __qualname__ checks"
  kind: python_call_eq
  category: decimal_method_qualnames
  id_prefix: dc1051m
  columns: [id, function, args, expected]
  rows:
    - [dc1051m001, decimal.Decimal.fma.__qualname__.__eq__,         ["Decimal.fma"],         true]
    - [dc1051m002, decimal.Decimal.is_finite.__qualname__.__eq__,   ["Decimal.is_finite"],   true]
    - [dc1051m003, decimal.Decimal.is_infinite.__qualname__.__eq__, ["Decimal.is_infinite"], true]
    - [dc1051m004, decimal.Decimal.is_nan.__qualname__.__eq__,      ["Decimal.is_nan"],      true]
    - [dc1051m005, decimal.Decimal.is_zero.__qualname__.__eq__,     ["Decimal.is_zero"],     true]
    - [dc1051m006, decimal.Decimal.is_signed.__qualname__.__eq__,   ["Decimal.is_signed"],   true]
    - [dc1051m007, decimal.Decimal.is_normal.__qualname__.__eq__,   ["Decimal.is_normal"],   true]

table decimal_extra1051.class_identity:
  description: "decimal class __name__ and __module__ identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: dc1051ci
  columns: [id, function, args, expected]
  rows:
    - [dc1051ci001, decimal.Decimal.__name__.__eq__,          ["Decimal"],          true]
    - [dc1051ci002, decimal.Context.__name__.__eq__,          ["Context"],          true]
    - [dc1051ci003, decimal.DecimalException.__name__.__eq__, ["DecimalException"], true]
    - [dc1051ci004, decimal.Decimal.__module__.__eq__,        ["decimal"],          true]
    - [dc1051ci005, decimal.Context.__module__.__eq__,        ["decimal"],          true]
    - [dc1051ci006, decimal.DecimalException.__module__.__eq__, ["decimal"],        true]
    - [dc1051ci007, decimal.Decimal.sqrt.__qualname__.__eq__, ["Decimal.sqrt"],     true]
