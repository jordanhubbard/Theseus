spec: pathlib_extra36
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra31.zspec.zsdl — covers PurePosixPath/__qualname__/__module__; PureWindowsPath/__qualname__/__module__; PosixPath/__qualname__/__module__; PurePath/__bases__[0].__name__; PurePath properties fget.__qualname__"
    - "pathlib_extra32.zspec.zsdl — covers PurePath.parent/parents/suffixes/drive/root/anchor fget.__qualname__/__module__"
    - "pathlib_extra33.zspec.zsdl — covers PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__; PosixPath/WindowsPath __bases__[0].__name__; Path/__init__/__qualname__; PurePath/__init__/__name__/__qualname__; Path/__truediv__/__name__/__qualname__"
    - "pathlib_extra34.zspec.zsdl — covers __module__.__len__() for Path/PurePath/PurePosixPath/PureWindowsPath; __name__.__len__() for all six classes; __qualname__.__len__() for Path/PurePath"
    - "pathlib_extra35.zspec.zsdl — covers __qualname__.__len__() for PosixPath/PurePosixPath/PureWindowsPath/WindowsPath; Path.open/read_text/write_text/mkdir/exists/stat __qualname__.__len__(); PosixPath/WindowsPath __module__.__len__()"
  notes:
    - "This spec extends pathlib_extra35.zspec.zsdl."
    - "Prior specs covered: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__, bases, Path/__init__/__truediv__ __name__/__qualname__, module/name/qualname lengths for all six classes, Path.open/read_text/write_text/mkdir/exists/stat qualname lengths."
    - "This spec covers: __mro__.__len__() for Path, PurePath, PurePosixPath, PosixPath; __bases__[0].__name__.__len__() for Path, PurePosixPath; __qualname__.__len__() for Path.rename/unlink/rmdir/chmod/symlink_to methods."
    - "No prior pathlib spec checks pathlib.Path.__mro__.__len__()."
    - "No prior pathlib spec checks pathlib.PurePath.__mro__.__len__()."
    - "No prior pathlib spec checks pathlib.PurePosixPath.__mro__.__len__()."
    - "No prior pathlib spec checks pathlib.PosixPath.__mro__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.__bases__[0].__name__.__len__()."
    - "No prior pathlib spec checks pathlib.PurePosixPath.__bases__[0].__name__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.rename.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.unlink.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.rmdir.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.chmod.__qualname__.__len__()."
    - "No prior pathlib spec checks pathlib.Path.symlink_to.__qualname__.__len__()."
    - "pathlib.PurePath.__mro__ == [PurePath, object] — len 2."
    - "pathlib.Path.__mro__ == [Path, PurePath, object] — len 3."
    - "pathlib.PurePosixPath.__mro__ == [PurePosixPath, PurePath, object] — len 3."
    - "pathlib.PosixPath.__mro__ == [PosixPath, Path, PurePosixPath, PurePath, object] — len 5."
    - "pathlib.Path.__bases__[0].__name__ == 'PurePath' — len 8."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — len 8."
    - "pathlib.Path.rename.__qualname__ == 'Path.rename' — len 11."
    - "pathlib.Path.unlink.__qualname__ == 'Path.unlink' — len 11."
    - "pathlib.Path.rmdir.__qualname__ == 'Path.rmdir' — len 10."
    - "pathlib.Path.chmod.__qualname__ == 'Path.chmod' — len 10."
    - "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to' — len 15."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for PurePath, Path, PurePosixPath, PosixPath
#
# PurePath is the root of the pathlib hierarchy (len 2: PurePath, object).
# Path extends PurePath (len 3: Path, PurePath, object).
# PurePosixPath extends PurePath (len 3: PurePosixPath, PurePath, object).
# PosixPath has the deepest MRO among the four (len 5):
#   PosixPath -> Path -> PurePosixPath -> PurePath -> object
# No prior pathlib spec checks any class's MRO depth.
# ---------------------------------------------------------------------------

invariant pathlib_extra36.PurePath.mro_len:
  description: "pathlib.PurePath.__mro__.__len__() == 2 — MRO: PurePath, object (direct object subclass)"
  category: class_hierarchy
  kind: python_call_eq
  function: PurePath.__mro__.__len__
  args: []
  expected: 2

invariant pathlib_extra36.Path.mro_len:
  description: "pathlib.Path.__mro__.__len__() == 3 — MRO: Path, PurePath, object"
  category: class_hierarchy
  kind: python_call_eq
  function: Path.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra36.PurePosixPath.mro_len:
  description: "pathlib.PurePosixPath.__mro__.__len__() == 3 — MRO: PurePosixPath, PurePath, object"
  category: class_hierarchy
  kind: python_call_eq
  function: PurePosixPath.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra36.PosixPath.mro_len:
  description: "pathlib.PosixPath.__mro__.__len__() == 5 — MRO: PosixPath, Path, PurePosixPath, PurePath, object"
  category: class_hierarchy
  kind: python_call_eq
  function: PosixPath.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() for Path and PurePosixPath
#
# Path.__bases__[0] is PurePath (len 8).
# PurePosixPath.__bases__[0] is also PurePath (len 8).
# Both concrete and pure POSIX classes share PurePath as their direct base.
# No prior pathlib spec checks the string length of any class's first base name
# (extra31 checked PurePath.__bases__[0].__name__ == 'object' but not its length).
# ---------------------------------------------------------------------------

invariant pathlib_extra36.Path.bases0_name_len:
  description: "pathlib.Path.__bases__[0].__name__.__len__() == 8 — first base is 'PurePath' (8 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__len__"
  args: []
  expected: 8

invariant pathlib_extra36.PurePosixPath.bases0_name_len:
  description: "pathlib.PurePosixPath.__bases__[0].__name__.__len__() == 8 — first base is 'PurePath' (8 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__len__"
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# __qualname__.__len__() for Path.rename, Path.unlink, Path.rmdir,
# Path.chmod, Path.symlink_to
#
# These five Path methods have not been covered in any prior pathlib spec.
# Qualnames are dotted class.method strings; lengths:
#   Path.rename     -> 'Path.rename'     -> 11
#   Path.unlink     -> 'Path.unlink'     -> 11
#   Path.rmdir      -> 'Path.rmdir'      -> 10
#   Path.chmod      -> 'Path.chmod'      -> 10
#   Path.symlink_to -> 'Path.symlink_to' -> 15
# ---------------------------------------------------------------------------

invariant pathlib_extra36.Path.rename.qualname_len:
  description: "pathlib.Path.rename.__qualname__.__len__() == 11 — 'Path.rename' has 11 characters"
  category: string_lengths
  kind: python_call_eq
  function: "Path.rename.__qualname__.__len__"
  args: []
  expected: 11

invariant pathlib_extra36.Path.unlink.qualname_len:
  description: "pathlib.Path.unlink.__qualname__.__len__() == 11 — 'Path.unlink' has 11 characters"
  category: string_lengths
  kind: python_call_eq
  function: "Path.unlink.__qualname__.__len__"
  args: []
  expected: 11

invariant pathlib_extra36.Path.rmdir.qualname_len:
  description: "pathlib.Path.rmdir.__qualname__.__len__() == 10 — 'Path.rmdir' has 10 characters"
  category: string_lengths
  kind: python_call_eq
  function: "Path.rmdir.__qualname__.__len__"
  args: []
  expected: 10

invariant pathlib_extra36.Path.chmod.qualname_len:
  description: "pathlib.Path.chmod.__qualname__.__len__() == 10 — 'Path.chmod' has 10 characters"
  category: string_lengths
  kind: python_call_eq
  function: "Path.chmod.__qualname__.__len__"
  args: []
  expected: 10

invariant pathlib_extra36.Path.symlink_to.qualname_len:
  description: "pathlib.Path.symlink_to.__qualname__.__len__() == 15 — 'Path.symlink_to' has 15 characters"
  category: string_lengths
  kind: python_call_eq
  function: "Path.symlink_to.__qualname__.__len__"
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# Consolidated table — MRO depth for pathlib classes
#
# PurePath is the shallowest (2), PosixPath is the deepest (5).
# All are first covered in this spec (pathlib_extra36).
# ---------------------------------------------------------------------------

table pathlib_extra36.class_mro_lengths:
  description: "pathlib class __mro__.__len__() — PurePath (2), Path (3), PurePosixPath (3), PosixPath (5)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: ple36a

  columns: [id, function, args, expected]
  rows:
    - [PurePath_mro_len,      PurePath.__mro__.__len__,      [], 2]
    - [Path_mro_len,          Path.__mro__.__len__,          [], 3]
    - [PurePosixPath_mro_len, PurePosixPath.__mro__.__len__, [], 3]
    - [PosixPath_mro_len,     PosixPath.__mro__.__len__,     [], 5]

# ---------------------------------------------------------------------------
# Consolidated table — __bases__[0].__name__.__len__() and new Path method
# __qualname__.__len__() values
#
# Groups the base-name lengths for Path/PurePosixPath and the five new
# method qualname lengths in one comprehensive table.
# ---------------------------------------------------------------------------

table pathlib_extra36.bases_and_method_qualname_lengths:
  description: "pathlib __bases__[0].__name__.__len__() for Path/PurePosixPath and Path.rename/unlink/rmdir/chmod/symlink_to __qualname__ lengths"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: ple36b

  columns: [id, function, args, expected]
  rows:
    - [Path_bases0_name_len,         "Path.__bases__[0].__name__.__len__",         [], 8]
    - [PurePosixPath_bases0_name_len, "PurePosixPath.__bases__[0].__name__.__len__", [], 8]
    - [Path_rename_qualname_len,     "Path.rename.__qualname__.__len__",            [], 11]
    - [Path_unlink_qualname_len,     "Path.unlink.__qualname__.__len__",            [], 11]
    - [Path_rmdir_qualname_len,      "Path.rmdir.__qualname__.__len__",             [], 10]
    - [Path_chmod_qualname_len,      "Path.chmod.__qualname__.__len__",             [], 10]
    - [Path_symlink_to_qualname_len, "Path.symlink_to.__qualname__.__len__",        [], 15]
