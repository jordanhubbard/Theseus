spec: concurrent_futures_extra42
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra41.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future method __name__/__qualname__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__name__/__qualname__.__len__()==14, BrokenExecutor/__module__.__len__()==24, CancelledError/__module__.__len__()==24, BrokenExecutor/__bases__[0].__name__.__len__()==12, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, __spec__.__class__.__name__.__len__()==10, ThreadPoolExecutor/__name__=='ThreadPoolExecutor', ProcessPoolExecutor/__name__=='ProcessPoolExecutor', executor __module__ string equality, wait/__name__=='wait', function __module__ string equality (extra36), Executor/__name__=='Executor'/__module__==concurrent.futures._base, Executor map/submit qualname lengths, InvalidStateError/BrokenExecutor __name__/__module__ string equality (extra37), ProcessPoolExecutor/ThreadPoolExecutor/__bases__[0].__name__=='Executor', Future/__bases__[0].__name__=='object', exception MRO depths all 5 (extra38), ProcessPoolExecutor/__mro__.__len__()==3, ThreadPoolExecutor/__mro__.__len__()==3, Future/__mro__.__len__()==2, Executor/__mro__.__len__()==2, Executor/__bases__[0].__name__=='object', sentinel __class__.__name__=='str' (extra39), ThreadPoolExecutor/__qualname__=='ThreadPoolExecutor' (18 chars), ProcessPoolExecutor/__qualname__=='ProcessPoolExecutor' (19 chars), Future/__qualname__=='Future' (6 chars), Executor/__qualname__=='Executor' (8 chars), CancelledError/__qualname__=='CancelledError' (14 chars), BrokenExecutor/__qualname__=='BrokenExecutor' (14 chars) and their __len__() measurements (extra40), all class __qualname__.__len__() tables including InvalidStateError(17) and TimeoutError(12) (extra41)."
    - "This spec covers: InvalidStateError/__qualname__=='InvalidStateError'; TimeoutError/__qualname__=='TimeoutError'; ThreadPoolExecutor/__module__.__len__()==25; ProcessPoolExecutor/__module__.__len__()==26; TimeoutError/__module__=='builtins'; TimeoutError/__module__.__len__()==8; InvalidStateError/__module__.__len__()==24 (same as _base module)."
    - "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError'. Extra40 captured __qualname__ equality for ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor/CancelledError/BrokenExecutor; extra42 adds InvalidStateError and TimeoutError. Qualname equals name for top-level classes. Verified with Python 3.14.3."
    - "concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError'. TimeoutError in concurrent.futures is an alias for the builtin TimeoutError; its __qualname__ == 'TimeoutError'. len('TimeoutError') == 12 (captured in extra41). Verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__module__.__len__() == 25. ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; len('concurrent.futures.thread') == 25. This is 1 longer than the base module path of 24 chars. Verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__module__.__len__() == 26. ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; len('concurrent.futures.process') == 26. This is the longest module path at 26 chars (1 more than thread). Verified with Python 3.14.3."
    - "concurrent.futures.TimeoutError.__module__ == 'builtins'. TimeoutError in concurrent.futures is the builtin TimeoutError; its __module__ is 'builtins' rather than 'concurrent.futures._base'. This makes it unique among concurrent.futures exports. Verified with Python 3.14.3."
    - "concurrent.futures.TimeoutError.__module__.__len__() == 8. TimeoutError.__module__ == 'builtins'; len('builtins') == 8. This is far shorter than the 24-char base module path used by Future/Executor/CancelledError/BrokenExecutor/InvalidStateError. Verified with Python 3.14.3."
    - "concurrent.futures.InvalidStateError.__module__.__len__() == 24. InvalidStateError.__module__ == 'concurrent.futures._base'; len('concurrent.futures._base') == 24. Same length as CancelledError and BrokenExecutor module paths (all from _base). Verified with Python 3.14.3."
    - "ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread') == True. ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process') == True. TimeoutError.__module__.__eq__('builtins') == True. All verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures exception class __qualname__ string equality — extra42
#
# Extra40 captured qualname equality for the four core classes and for
# CancelledError and BrokenExecutor. Extra42 extends to the remaining two:
#   InvalidStateError.__qualname__ == 'InvalidStateError'
#   TimeoutError.__qualname__      == 'TimeoutError'
# Both are top-level classes so __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra42.exception_qualname_eq:
  description: "concurrent.futures exception class __qualname__ string equality in extra42 namespace — InvalidStateError, TimeoutError"
  kind: python_call_eq
  category: class_names
  id_prefix: cfexcqneq42

  columns: [id, function, args, expected, description]
  rows:
    - [InvalidStateError, InvalidStateError.__qualname__.__eq__, ["InvalidStateError"], true, "InvalidStateError.__qualname__ == 'InvalidStateError' — top-level exception; qualname equals name (17 chars)"]
    - [TimeoutError,      TimeoutError.__qualname__.__eq__,      ["TimeoutError"],      true, "TimeoutError.__qualname__ == 'TimeoutError' — builtin alias; qualname equals name (12 chars)"]

# ---------------------------------------------------------------------------
# concurrent.futures executor class __module__ lengths — extra42 namespace
#
# The executor classes have sub-module paths distinct from the _base module:
#   ThreadPoolExecutor.__module__.__len__()  == 25  ('concurrent.futures.thread')
#   ProcessPoolExecutor.__module__.__len__() == 26  ('concurrent.futures.process')
# This contrasts with Future/Executor/CancelledError/BrokenExecutor/InvalidStateError
# which all use 'concurrent.futures._base' (24 chars).
# TimeoutError is unique: it comes from 'builtins' (8 chars).
# ---------------------------------------------------------------------------

table concurrent_futures_extra42.module_path_lengths:
  description: "concurrent.futures class __module__.__len__() in extra42 namespace — ThreadPoolExecutor, ProcessPoolExecutor, InvalidStateError, TimeoutError"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfmodpathlen42

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__module__.__len__,  [], 25, "ThreadPoolExecutor.__module__.__len__() == 25 — 'concurrent.futures.thread' has 25 chars"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__module__.__len__, [], 26, "ProcessPoolExecutor.__module__.__len__() == 26 — 'concurrent.futures.process' has 26 chars; longest executor module path"]
    - [InvalidStateError,   InvalidStateError.__module__.__len__,   [], 24, "InvalidStateError.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 chars; same as CancelledError/BrokenExecutor"]
    - [TimeoutError,        TimeoutError.__module__.__len__,        [],  8, "TimeoutError.__module__.__len__() == 8 — 'builtins' has 8 chars; unique: only export from builtins"]

# ---------------------------------------------------------------------------
# concurrent.futures executor class __module__ string equality — extra42
#
# Three notable module string equalities not previously captured:
#   ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'
#   ProcessPoolExecutor.__module__ == 'concurrent.futures.process'
#   TimeoutError.__module__ == 'builtins'
# The executor __module__ string equality was listed as covered in prior specs,
# but that covered the general case. Here we explicitly verify the sub-module paths
# and the unique 'builtins' origin of TimeoutError.
# ---------------------------------------------------------------------------

table concurrent_futures_extra42.module_string_equality:
  description: "concurrent.futures class __module__ string equality in extra42 namespace — thread, process, and builtins modules"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfmodulesq42

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__module__.__eq__,  ["concurrent.futures.thread"],   true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' — defined in thread sub-module"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"],  true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' — defined in process sub-module"]
    - [TimeoutError,        TimeoutError.__module__.__eq__,        ["builtins"],                    true, "TimeoutError.__module__ == 'builtins' — this is the builtin TimeoutError; unique among concurrent.futures exports"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra42
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra42.InvalidStateError_qualname_eq:
  description: "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError' — top-level exception; qualname equals name (17 chars)"
  category: class_names
  kind: python_call_eq
  function: InvalidStateError.__qualname__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant concurrent_futures_extra42.TimeoutError_qualname_eq:
  description: "concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError' — builtin alias; qualname equals name (12 chars)"
  category: class_names
  kind: python_call_eq
  function: TimeoutError.__qualname__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant concurrent_futures_extra42.ThreadPoolExecutor_module_len:
  description: "concurrent.futures.ThreadPoolExecutor.__module__.__len__() == 25 — 'concurrent.futures.thread' has 25 characters"
  category: module_identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__len__
  args: []
  expected: 25

invariant concurrent_futures_extra42.ProcessPoolExecutor_module_len:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__len__() == 26 — 'concurrent.futures.process' has 26 characters; longest executor module path"
  category: module_identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__len__
  args: []
  expected: 26

invariant concurrent_futures_extra42.TimeoutError_module_len:
  description: "concurrent.futures.TimeoutError.__module__.__len__() == 8 — 'builtins' has 8 characters; unique: only export from builtins in this module"
  category: module_identity
  kind: python_call_eq
  function: TimeoutError.__module__.__len__
  args: []
  expected: 8

invariant concurrent_futures_extra42.TimeoutError_module_eq:
  description: "concurrent.futures.TimeoutError.__module__ == 'builtins' — TimeoutError is the builtin OSError subclass, not defined in concurrent.futures._base"
  category: module_identity
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true
