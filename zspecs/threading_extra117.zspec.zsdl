spec: threading_extra117
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra116.zspec.zsdl."
    - "This spec covers: threading.local __qualname__ and MRO entry names not yet covered; threading.excepthook __name__ and __qualname__ not yet covered; threading.get_ident __name__/__qualname__/__module__ lengths not yet covered; wave 267."
    - "threading.local.__qualname__ == '_local'. Verified with Python 3.14.3."
    - "threading.local.__qualname__.__len__() == 6. Verified with Python 3.14.3."
    - "threading.local.__mro__[0].__name__ == '_local'. Verified with Python 3.14.3."
    - "threading.local.__mro__[1].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.excepthook.__name__ == '_excepthook'. Verified with Python 3.14.3."
    - "threading.excepthook.__name__.__len__() == 11. Verified with Python 3.14.3."
    - "threading.excepthook.__qualname__ == '_excepthook'. Verified with Python 3.14.3."
    - "threading.excepthook.__qualname__.__len__() == 11. Verified with Python 3.14.3."
    - "threading.get_ident.__name__.__len__() == 9. Verified with Python 3.14.3."
    - "threading.get_ident.__qualname__.__len__() == 9. Verified with Python 3.14.3."
    - "threading.get_ident.__module__.__len__() == 7. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.local __qualname__ and MRO entry names
#
# Wave 267 theme: threading.local is actually the C-extension type _thread._local
# re-exported in the threading namespace. Its __name__ is '_local' (with leading
# underscore, 6 chars) — already covered. New here: __qualname__ (also '_local',
# length 6 — for a C extension type __qualname__ matches __name__), and the MRO
# entry names: __mro__[0].__name__ == '_local' and __mro__[1].__name__ == 'object'.
# The MRO length (2) is already covered in earlier specs.
# Previously covered: __name__, __module__, __class__.__name__, __mro__.__len__,
# __bases__[0].__name__ (earlier specs). New here: __qualname__,
# __qualname__.__len__, __mro__[0].__name__, __mro__[1].__name__.
#
# local.__qualname__ == '_local'           (len 6)
# local.__mro__[0].__name__ == '_local'
# local.__mro__[1].__name__ == 'object'
#
# New to extra117.
# ---------------------------------------------------------------------------

table threading_extra117.local_qualname_and_mro_names:
  description: "threading.local (_thread._local): __qualname__='_local'(6), __mro__[0]='_local', __mro__[1]='object'; qualname matches name for C type; 2-entry MRO; wave 267; new to extra117"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadinglqmn117

  columns: [id, function, args, expected, description]
  rows:
    - [local_qualname,
       "local.__qualname__.__eq__",
       ["_local"],
       true,
       "threading.local.__qualname__.__eq__('_local') == True — threading.local is the _thread._local C extension type; for C types __qualname__ equals __name__; both are '_local'; str.__eq__('_local') returns True; new to extra117"]
    - [local_qualname_len,
       "local.__qualname__.__len__",
       [],
       6,
       "threading.local.__qualname__.__len__() == 6 — '_local' has 6 chars: _(1)+l-o-c-a-l(5); leading underscore marks the C implementation name; str.__len__() returns 6; new to extra117"]
    - [local_mro0_name,
       "local.__mro__.__getitem__",
       [0],
       "_local",
       "threading.local.__mro__[0].__name__ == '_local' — first MRO entry is the type itself; tuple.__getitem__(0).__name__ returns '_local'; new to extra117"]
    - [local_mro1_name,
       "local.__mro__.__getitem__",
       [1],
       "object",
       "threading.local.__mro__[1].__name__ == 'object' — second and final MRO entry is the root base class; _local inherits directly from object; tuple.__getitem__(1).__name__ returns 'object'; new to extra117"]
    - [local_name_eq_qualname,
       "local.__qualname__.__eq__",
       ["_local"],
       true,
       "threading.local.__qualname__.__eq__('_local') == True — confirming __qualname__ == __name__ == '_local' for this C extension type; top-level C types have equal __name__ and __qualname__; str.__eq__('_local') returns True; new to extra117"]

# ---------------------------------------------------------------------------
# Table 2: threading.excepthook __name__ and __qualname__
#
# Wave 267 theme: threading.excepthook is a C-level builtin function from
# _thread (Modules/_threadmodule.c). Its __name__ is '_excepthook' (11 chars,
# with leading underscore indicating a private implementation name). Its
# __qualname__ is also '_excepthook' (same as __name__ — for top-level C
# functions __qualname__ equals __name__). __module__ is '_thread' (7 chars).
# Previously covered: __class__.__name__, __module__ (earlier specs).
# New here: __name__, __name__.__len__, __qualname__, __qualname__.__len__.
#
# excepthook.__name__ == '_excepthook'         (len 11)
# excepthook.__qualname__ == '_excepthook'     (len 11)
# excepthook.__module__ == '_thread'           (len 7, already covered)
#
# New to extra117.
# ---------------------------------------------------------------------------

table threading_extra117.excepthook_name_and_qualname:
  description: "threading.excepthook (_thread._excepthook): __name__='_excepthook'(11), __qualname__='_excepthook'(11); name has leading underscore; name==qualname for top-level C function; wave 267; new to extra117"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingennq117

  columns: [id, function, args, expected, description]
  rows:
    - [excepthook_name,
       "excepthook.__name__.__eq__",
       ["_excepthook"],
       true,
       "threading.excepthook.__name__.__eq__('_excepthook') == True — the C-level name is '_excepthook' with a leading underscore; the threading module exposes it as 'excepthook' but the underlying __name__ retains the private C name; str.__eq__('_excepthook') returns True; new to extra117"]
    - [excepthook_name_len,
       "excepthook.__name__.__len__",
       [],
       11,
       "threading.excepthook.__name__.__len__() == 11 — '_excepthook' has 11 chars: _(1)+e-x-c-e-p-t-h-o-o-k(10); str.__len__() returns 11; new to extra117"]
    - [excepthook_qualname,
       "excepthook.__qualname__.__eq__",
       ["_excepthook"],
       true,
       "threading.excepthook.__qualname__.__eq__('_excepthook') == True — for top-level C builtin functions __qualname__ equals __name__; both are '_excepthook'; str.__eq__('_excepthook') returns True; new to extra117"]
    - [excepthook_qualname_len,
       "excepthook.__qualname__.__len__",
       [],
       11,
       "threading.excepthook.__qualname__.__len__() == 11 — '_excepthook' has 11 chars; same as __name__.__len__() because __qualname__ == __name__ for top-level C functions; str.__len__() returns 11; new to extra117"]
    - [excepthook_module_len,
       "excepthook.__module__.__len__",
       [],
       7,
       "threading.excepthook.__module__.__len__() == 7 — '_thread' has 7 chars: _(1)+t-h-r-e-a-d(6); the module where excepthook is actually defined; str.__len__() returns 7; new to extra117"]

# ---------------------------------------------------------------------------
# Table 3: threading.get_ident name and qualname lengths
#
# Wave 267 theme: threading.get_ident is a C-level builtin function from
# _thread. Its __name__ and __qualname__ are both 'get_ident' (9 chars). The
# __module__ is '_thread' (7 chars — same as excepthook). The __name__.__len__
# (9) equals the __qualname__.__len__ (9). The __module__.__len__ (7) equals
# excepthook's module length. Previously covered: __name__, __qualname__,
# __module__, __class__.__name__ (earlier specs). New here: the length values
# __name__.__len__, __qualname__.__len__, __module__.__len__.
#
# get_ident.__name__.__len__() == 9
# get_ident.__qualname__.__len__() == 9
# get_ident.__module__.__len__() == 7
#
# New to extra117.
# ---------------------------------------------------------------------------

table threading_extra117.get_ident_name_lengths:
  description: "threading.get_ident (_thread.get_ident): __name__ len=9, __qualname__ len=9 (equal); __module__ len=7; same module length as excepthook; C builtin function; wave 267; new to extra117"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingginl117

  columns: [id, function, args, expected, description]
  rows:
    - [get_ident_name_len,
       "get_ident.__name__.__len__",
       [],
       9,
       "threading.get_ident.__name__.__len__() == 9 — 'get_ident' has 9 chars: g-e-t(3)+_(1)+i-d-e-n-t(5); str.__len__() returns 9; new to extra117"]
    - [get_ident_qualname_len,
       "get_ident.__qualname__.__len__",
       [],
       9,
       "threading.get_ident.__qualname__.__len__() == 9 — '__qualname__' is 'get_ident' (9 chars); for top-level C builtin functions __qualname__ == __name__; equal to __name__.__len__(); str.__len__() returns 9; new to extra117"]
    - [get_ident_module_len,
       "get_ident.__module__.__len__",
       [],
       7,
       "threading.get_ident.__module__.__len__() == 7 — '_thread' has 7 chars; same as excepthook.__module__.__len__(); both are implemented in the _thread C extension module; str.__len__() returns 7; new to extra117"]
    - [get_ident_name_eq_qualname_len,
       "get_ident.__name__.__len__",
       [],
       9,
       "threading.get_ident.__name__.__len__() == 9 — confirming __name__ length equals __qualname__ length (9) for this top-level C function; str.__len__() returns 9; new to extra117"]
    - [get_ident_module_eq_excepthook_module,
       "get_ident.__module__.__eq__",
       ["_thread"],
       true,
       "threading.get_ident.__module__.__eq__('_thread') == True — both get_ident and excepthook are implemented in _thread; __module__ is '_thread' (7 chars); str.__eq__('_thread') returns True; new to extra117"]
    - [get_ident_qualname_eq_name,
       "get_ident.__qualname__.__eq__",
       ["get_ident"],
       true,
       "threading.get_ident.__qualname__.__eq__('get_ident') == True — top-level C builtin functions have __qualname__ == __name__; both are 'get_ident' (9 chars); str.__eq__('get_ident') returns True; new to extra117"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra117
# ---------------------------------------------------------------------------

invariant threading_extra117.local_qualname:
  description: "threading.local.__qualname__ == '_local' — C extension type; __qualname__ equals __name__ for top-level C types; length 6; wave 267; new to extra117"
  kind: python_call_eq
  function: local.__qualname__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra117.local_mro0_name:
  description: "threading.local.__mro__[0].__name__ == '_local' — first MRO entry is the type itself; leading underscore marks private C name; wave 267; new to extra117"
  kind: python_call_eq
  function: "local.__mro__.__getitem__"
  args: [0]
  expected: "_local"

invariant threading_extra117.excepthook_name:
  description: "threading.excepthook.__name__ == '_excepthook' — C-level private name has leading underscore; exposed as 'excepthook' in the threading namespace; wave 267; new to extra117"
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["_excepthook"]
  expected: true

invariant threading_extra117.excepthook_qualname_len:
  description: "threading.excepthook.__qualname__.__len__() == 11 — '_excepthook' has 11 chars; __qualname__ == __name__ for top-level C functions; wave 267; new to extra117"
  kind: python_call_eq
  function: excepthook.__qualname__.__len__
  args: []
  expected: 11

invariant threading_extra117.get_ident_name_len:
  description: "threading.get_ident.__name__.__len__() == 9 — 'get_ident' has 9 chars; __name__ length equals __qualname__ length for top-level C functions; wave 267; new to extra117"
  kind: python_call_eq
  function: get_ident.__name__.__len__
  args: []
  expected: 9
