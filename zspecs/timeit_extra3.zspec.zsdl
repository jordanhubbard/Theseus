spec: timeit_extra3
version: ">=3.9"
backend: python_module(timeit)

docs: https://docs.python.org/3/library/timeit.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/timeit.html — Python timeit module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/timeit.py"
  notes:
    - "This spec extends timeit.zspec.zsdl, timeit_extra.zspec.zsdl, and timeit_extra2.zspec.zsdl."
    - "timeit.zspec.zsdl covers: timeit/__name__, repeat/__name__, default_timer type, Timer/__name__, Timer/__module__, Timer method names, timeit() returns float."
    - "timeit_extra.zspec.zsdl covers: Timer/__qualname__, Timer/__doc__, Timer method __qualname__ and type, default_timer/__name__, module __name__, repeat() returns list, repeat() length."
    - "timeit_extra2.zspec.zsdl covers: Timer/__bases__[0].__name__, timeit/__module__, repeat/__module__, timeit/__qualname__, repeat/__qualname__, function __name__ batch table."
    - "This spec adds: Timer/__bases__.__len__, default_timer/__qualname__, default_timer/__module__, Timer method __module__ checks — not covered in any prior spec."
    - "timeit.Timer.__bases__.__len__() == 1 — Timer has exactly one direct base class."
    - "timeit.default_timer.__qualname__ == 'perf_counter' — qualname of the aliased builtin."
    - "timeit.default_timer.__module__ == 'time' — default_timer is time.perf_counter."
    - "timeit.Timer.timeit/__module__ == 'timeit', and likewise for repeat, autorange, print_exc."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Timer.__bases__ — count
# timeit_extra2.zspec.zsdl checks __bases__[0].__name__ == 'object' but NOT __len__.
# ---------------------------------------------------------------------------

invariant timeit_extra3.Timer.bases_len:
  description: "len(timeit.Timer.__bases__) == 1 — Timer has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: Timer.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# default_timer — __qualname__ and __module__
# timeit_extra.zspec.zsdl checks default_timer.__name__ == 'perf_counter'.
# Neither extra spec checks __qualname__ or __module__ of default_timer.
# ---------------------------------------------------------------------------

invariant timeit_extra3.default_timer.qualname:
  description: "timeit.default_timer.__qualname__ == 'perf_counter' — qualname of the aliased builtin"
  category: functions
  kind: python_call_eq
  function: default_timer.__qualname__.__eq__
  args: ["perf_counter"]
  expected: true

invariant timeit_extra3.default_timer.module:
  description: "timeit.default_timer.__module__ == 'time' — default_timer is time.perf_counter"
  category: functions
  kind: python_call_eq
  function: default_timer.__module__.__eq__
  args: ["time"]
  expected: true

# ---------------------------------------------------------------------------
# Timer method __module__ checks
# No prior spec checks __module__ for Timer's individual methods.
# ---------------------------------------------------------------------------

invariant timeit_extra3.Timer.timeit_method.module:
  description: "timeit.Timer.timeit.__module__ == 'timeit' — method defined in timeit module"
  category: methods
  kind: python_call_eq
  function: Timer.timeit.__module__.__eq__
  args: ["timeit"]
  expected: true

invariant timeit_extra3.Timer.repeat_method.module:
  description: "timeit.Timer.repeat.__module__ == 'timeit' — method defined in timeit module"
  category: methods
  kind: python_call_eq
  function: Timer.repeat.__module__.__eq__
  args: ["timeit"]
  expected: true

invariant timeit_extra3.Timer.autorange_method.module:
  description: "timeit.Timer.autorange.__module__ == 'timeit' — method defined in timeit module"
  category: methods
  kind: python_call_eq
  function: Timer.autorange.__module__.__eq__
  args: ["timeit"]
  expected: true

invariant timeit_extra3.Timer.print_exc_method.module:
  description: "timeit.Timer.print_exc.__module__ == 'timeit' — method defined in timeit module"
  category: methods
  kind: python_call_eq
  function: Timer.print_exc.__module__.__eq__
  args: ["timeit"]
  expected: true

# ---------------------------------------------------------------------------
# Table: Timer method __module__ batch check
# ---------------------------------------------------------------------------

table timeit_extra3.Timer.method_modules:
  kind: python_call_eq
  category: methods
  id_prefix: method_module

  columns: [id, function, args, expected]
  rows:
    - [timeit_module,    Timer.timeit.__module__.__eq__,    ["timeit"], true]
    - [repeat_module,    Timer.repeat.__module__.__eq__,    ["timeit"], true]
    - [autorange_module, Timer.autorange.__module__.__eq__, ["timeit"], true]
    - [print_exc_module, Timer.print_exc.__module__.__eq__, ["timeit"], true]
