spec: xml_etree_extra
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "Python 3 xml.etree.ElementTree documentation — https://docs.python.org/3/library/xml.etree.elementtree.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py"
    - "elementtree.zspec.zsdl — covers fromstring tag/text/attrib/get/findtext, Element constructor, tostring, SubElement, ParseError raise behavior"
    - "xml_parse.zspec.zsdl — covers ElementTree class name/module/base checks, XMLParser feed/close/version, ParseError name/module/base/is_exception_subclass/args, XMLParser class name checks"
  notes:
    - "This spec (xml_etree_extra) covers symbols in xml.etree.ElementTree not yet in elementtree.zspec.zsdl or xml_parse.zspec.zsdl."
    - "Element.__name__ is verified here; elementtree.zspec.zsdl tests Element constructor behavior but not its __name__."
    - "ElementTree.__name__ is already in xml_parse.zspec.zsdl; not duplicated here."
    - "SubElement.__name__ is not in prior specs."
    - "Comment and ProcessingInstruction are factory functions (C-level built-ins on CPython) that create Element nodes with special tags."
    - "parse.__name__ == 'parse' — the module-level file-parsing function."
    - "fromstring.__name__ == 'fromstring' — the module-level XML-string parser."
    - "tostring.__name__ == 'tostring' — the module-level serialiser."
    - "indent.__name__ == 'indent' — added in Python 3.9; modifies element tree in-place for pretty-printing."
    - "iterparse.__name__ == 'iterparse' — incremental parser returning (event, element) pairs."
    - "register_namespace.__name__ == 'register_namespace' — registers a namespace prefix globally."
    - "ParseError.__name__ and __bases__ already in xml_parse; not duplicated here."
    - "fromstring('<root/>') returns an Element whose __class__.__name__ == 'Element'."
    - "version is set to >=3.9 because indent() was added in Python 3.9."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — symbols not yet verified in prior xml.etree.ElementTree specs
# ---------------------------------------------------------------------------

invariant xml_etree_extra.Element.name:
  description: "Element.__name__ == 'Element'"
  category: class_names
  kind: python_call_eq
  function: Element.__name__.__eq__
  args: ["Element"]
  expected: true

invariant xml_etree_extra.SubElement.name:
  description: "SubElement.__name__ == 'SubElement'"
  category: class_names
  kind: python_call_eq
  function: SubElement.__name__.__eq__
  args: ["SubElement"]
  expected: true

# ---------------------------------------------------------------------------
# Function name checks — module-level API functions
# ---------------------------------------------------------------------------

table xml_etree_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fnname

  columns: [id, function, args, expected]
  rows:
    - [parse,               parse.__name__.__eq__,               ["parse"],               true]
    - [fromstring,          fromstring.__name__.__eq__,          ["fromstring"],          true]
    - [tostring,            tostring.__name__.__eq__,            ["tostring"],            true]
    - [indent,              indent.__name__.__eq__,              ["indent"],              true]
    - [iterparse,           iterparse.__name__.__eq__,           ["iterparse"],           true]
    - [register_namespace,  register_namespace.__name__.__eq__,  ["register_namespace"],  true]

# ---------------------------------------------------------------------------
# Comment and ProcessingInstruction — factory function name checks
#
# On CPython these are C-level built-ins; their __name__ is the function name.
# ---------------------------------------------------------------------------

invariant xml_etree_extra.Comment.name:
  description: "Comment.__name__ == 'Comment'"
  category: function_names
  kind: python_call_eq
  function: Comment.__name__.__eq__
  args: ["Comment"]
  expected: true

invariant xml_etree_extra.ProcessingInstruction.name:
  description: "ProcessingInstruction.__name__ == 'ProcessingInstruction'"
  category: function_names
  kind: python_call_eq
  function: ProcessingInstruction.__name__.__eq__
  args: ["ProcessingInstruction"]
  expected: true

# ---------------------------------------------------------------------------
# ParseError inheritance — verify in this spec context
#
# ParseError.__bases__[0].__name__ == 'SyntaxError' (complementary to xml_parse)
# ---------------------------------------------------------------------------

invariant xml_etree_extra.ParseError.name:
  description: "ParseError.__name__ == 'ParseError'"
  category: class_names
  kind: python_call_eq
  function: ParseError.__name__.__eq__
  args: ["ParseError"]
  expected: true

invariant xml_etree_extra.ParseError.base_is_SyntaxError:
  description: "ParseError.__bases__[0].__name__ == 'SyntaxError'"
  category: hierarchy
  kind: python_call_eq
  function: ParseError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SyntaxError"

# ---------------------------------------------------------------------------
# fromstring — result class check
#
# fromstring('<root/>') returns an Element; verify via __class__.__name__
# ---------------------------------------------------------------------------

invariant xml_etree_extra.fromstring.result_class:
  description: "fromstring('<root/>').__class__.__name__ == 'Element'"
  category: fromstring
  kind: python_call_eq
  function: fromstring
  args: ["<root/>"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Element"]
  expected: true

# ---------------------------------------------------------------------------
# Element — module membership (the class is defined in xml.etree.ElementTree)
# ---------------------------------------------------------------------------

invariant xml_etree_extra.Element.module_is_str:
  description: "Element.__module__.__class__.__name__ == 'str' — module attribute is a string"
  category: modules
  kind: python_call_eq
  function: Element.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
