spec: threading_extra74
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra73.zspec.zsdl."
    - "Wave 239 theme: threading Thread subclasses and Condition/Semaphore deeper code attrs."
    - "Semaphore.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple. Verified with Python 3.14.3."
    - "Semaphore.__init__.__code__.co_varnames.__len__() == 2 — Semaphore.__init__ has co_varnames ('self', 'value') with 2 entries. Verified with Python 3.14.3."
    - "Event.set.__code__.co_name == 'set' — Event.set is a pure-Python method; co_name records the def name 'set'. Verified with Python 3.14.3."
    - "Event.set.__code__.co_argcount == 1 — Event.set(self) has 1 positional parameter. Verified with Python 3.14.3."
    - "Event.clear.__code__.co_name == 'clear' — Event.clear is a pure-Python method; co_name records the def name 'clear'. Verified with Python 3.14.3."
    - "Event.clear.__code__.co_argcount == 1 — Event.clear(self) has 1 positional parameter. Verified with Python 3.14.3."
    - "Event.is_set.__code__.co_name == 'is_set' — Event.is_set is a pure-Python method; co_name records the def name 'is_set'. Verified with Python 3.14.3."
    - "Event.is_set.__code__.co_argcount == 1 — Event.is_set(self) has 1 positional parameter. Verified with Python 3.14.3."
    - "threading.current_thread.__class__.__name__ == 'function' — current_thread is a pure-Python function. Verified with Python 3.14.3."
    - "threading.current_thread.__module__ == 'threading' — current_thread is defined in the threading module. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Semaphore.__init__ co_varnames — extra74
#
# Wave 239 theme: Semaphore.__init__ co_varnames is a tuple of length 2.
#
# threading.Semaphore is a pure-Python class defined in Lib/threading.py.
# Its __init__ is defined as:
#   def __init__(self, value=1):
#
# Semaphore.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'
# Semaphore.__init__.__code__.co_varnames.__len__()          == 2
#   co_varnames contains ('self', 'value')
#
# No prior threading spec checks Semaphore.__init__.__code__.co_varnames via thrdmore74. New to extra74.
# ---------------------------------------------------------------------------

table threading_extra74.Semaphore_varnames:
  description: "Semaphore.__init__.__code__.co_varnames.__class__.__name__=='tuple', __len__()==2; wave 239 Semaphore co_varnames; new to extra74"
  kind: python_call_eq
  category: code_attributes
  id_prefix: thrdmore74

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_varnames_class_name_eq_tuple,
       Semaphore.__init__.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "threading.Semaphore.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple in CPython code objects; it stores the names of all local variables (parameters first, then other locals); __class__.__name__ for a tuple is 'tuple' (5 chars); str.__eq__('tuple') returns True; no prior threading spec checks Semaphore.__init__.__code__.co_varnames.__class__.__name__ via thrdmore74; new to extra74"]
    - [Semaphore_varnames_len_eq_2,
       Semaphore.__init__.__code__.co_varnames.__len__,
       [],
       2,
       "threading.Semaphore.__init__.__code__.co_varnames.__len__() == 2 — Semaphore.__init__ is defined as 'def __init__(self, value=1):' with 2 local variable names: ('self', 'value'); tuple.__len__() returns 2; no prior threading spec checks Semaphore.__init__.__code__.co_varnames.__len__ via thrdmore74; new to extra74"]

# ---------------------------------------------------------------------------
# Event.set and Event.clear code attributes — extra74
#
# Wave 239 theme: Event.set and Event.clear co_name and co_argcount.
#
# threading.Event is a pure-Python class in Lib/threading.py.
# Event.set and Event.clear are pure-Python methods.
#
# Event.set.__code__.co_name     == 'set'
# Event.set.__code__.co_argcount == 1
# Event.clear.__code__.co_name     == 'clear'
# Event.clear.__code__.co_argcount == 1
#
# NOTE: Event.set is the threading.Event.set method (not the Python built-in set type).
#
# No prior threading spec checks Event.set or Event.clear __code__ via thrdmore74. New to extra74.
# ---------------------------------------------------------------------------

table threading_extra74.Event_set_clear_code:
  description: "Event.set/__code__.co_name=='set', co_argcount==1; Event.clear/__code__.co_name=='clear', co_argcount==1; wave 239 Event method __code__; new to extra74"
  kind: python_call_eq
  category: code_attributes
  id_prefix: thrdmore74

  columns: [id, function, args, expected, description]
  rows:
    - [Event_set_co_name_eq_set,
       Event.set.__code__.co_name.__eq__,
       ["set"],
       true,
       "threading.Event.set.__code__.co_name.__eq__('set') == True — Event.set is a pure-Python method in Lib/threading.py (not the built-in set type); the code object's co_name stores the name from the def statement which is 'set' (3 chars); str.__eq__('set') returns True; no prior threading spec checks Event.set.__code__.co_name via thrdmore74; new to extra74"]
    - [Event_set_co_argcount_eq_1,
       Event.set.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Event.set.__code__.co_argcount.__eq__(1) == True — Event.set is defined as 'def set(self):' with 1 positional parameter (self); co_argcount counts only positional parameters and equals 1; int.__eq__(1) returns True; no prior threading spec checks Event.set.__code__.co_argcount via thrdmore74; new to extra74"]
    - [Event_clear_co_name_eq_clear,
       Event.clear.__code__.co_name.__eq__,
       ["clear"],
       true,
       "threading.Event.clear.__code__.co_name.__eq__('clear') == True — Event.clear is a pure-Python method in Lib/threading.py that resets the internal flag to False; the code object's co_name stores the name from the def statement which is 'clear' (5 chars); str.__eq__('clear') returns True; no prior threading spec checks Event.clear.__code__.co_name via thrdmore74; new to extra74"]
    - [Event_clear_co_argcount_eq_1,
       Event.clear.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Event.clear.__code__.co_argcount.__eq__(1) == True — Event.clear is defined as 'def clear(self):' with 1 positional parameter (self); co_argcount counts only positional parameters and equals 1; int.__eq__(1) returns True; no prior threading spec checks Event.clear.__code__.co_argcount via thrdmore74; new to extra74"]

# ---------------------------------------------------------------------------
# Event.is_set code attributes — extra74
#
# Wave 239 theme: Event.is_set co_name and co_argcount.
#
# Event.is_set.__code__.co_name     == 'is_set'
# Event.is_set.__code__.co_argcount == 1
#
# No prior threading spec checks Event.is_set __code__ via thrdmore74. New to extra74.
# ---------------------------------------------------------------------------

table threading_extra74.Event_is_set_code:
  description: "Event.is_set/__code__.co_name=='is_set', co_argcount==1; wave 239 Event.is_set __code__; new to extra74"
  kind: python_call_eq
  category: code_attributes
  id_prefix: thrdmore74

  columns: [id, function, args, expected, description]
  rows:
    - [Event_is_set_co_name_eq_is_set,
       Event.is_set.__code__.co_name.__eq__,
       ["is_set"],
       true,
       "threading.Event.is_set.__code__.co_name.__eq__('is_set') == True — Event.is_set is a pure-Python method in Lib/threading.py that returns True if the internal flag is True; the code object's co_name stores the name from the def statement which is 'is_set' (6 chars); str.__eq__('is_set') returns True; no prior threading spec checks Event.is_set.__code__.co_name via thrdmore74; new to extra74"]
    - [Event_is_set_co_argcount_eq_1,
       Event.is_set.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Event.is_set.__code__.co_argcount.__eq__(1) == True — Event.is_set is defined as 'def is_set(self):' with 1 positional parameter (self); co_argcount counts only positional parameters and equals 1; int.__eq__(1) returns True; no prior threading spec checks Event.is_set.__code__.co_argcount via thrdmore74; new to extra74"]

# ---------------------------------------------------------------------------
# current_thread function identity — extra74
#
# Wave 239 theme: threading.current_thread is a plain Python function.
#
# threading.current_thread.__class__.__name__ == 'function'
# threading.current_thread.__module__         == 'threading'
#
# No prior threading spec checks current_thread identity via thrdmore74. New to extra74.
# ---------------------------------------------------------------------------

table threading_extra74.current_thread_identity:
  description: "current_thread.__class__.__name__=='function', __module__=='threading'; wave 239 current_thread identity; new to extra74"
  kind: python_call_eq
  category: function_identity
  id_prefix: thrdmore74

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_class_name_eq_function,
       current_thread.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.current_thread.__class__.__name__.__eq__('function') == True — current_thread is a pure-Python function defined in Lib/threading.py; its __class__ is the built-in function type and __class__.__name__ is 'function' (8 chars); str.__eq__('function') returns True; no prior threading spec checks current_thread.__class__.__name__ via thrdmore74; new to extra74"]
    - [current_thread_module_eq_threading,
       current_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.current_thread.__module__.__eq__('threading') == True — current_thread is defined in Lib/threading.py and its __module__ attribute records the module name as the str 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks current_thread.__module__ via thrdmore74; new to extra74"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra74
# ---------------------------------------------------------------------------

invariant threading_extra74.Semaphore_varnames_class_tuple:
  description: "threading.Semaphore.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is a tuple; wave 239 Semaphore co_varnames; new to extra74"
  kind: python_call_eq
  function: Semaphore.__init__.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant threading_extra74.Semaphore_varnames_len:
  description: "threading.Semaphore.__init__.__code__.co_varnames.__len__() == 2 — Semaphore.__init__ co_varnames has 2 entries: ('self', 'value'); wave 239 Semaphore co_varnames; new to extra74"
  kind: python_call_eq
  function: Semaphore.__init__.__code__.co_varnames.__len__
  args: []
  expected: 2

invariant threading_extra74.Event_set_co_name:
  description: "threading.Event.set.__code__.co_name.__eq__('set') == True — Event.set co_name is 'set'; wave 239 Event method __code__; new to extra74"
  kind: python_call_eq
  function: Event.set.__code__.co_name.__eq__
  args: ["set"]
  expected: true

invariant threading_extra74.Event_is_set_co_name:
  description: "threading.Event.is_set.__code__.co_name.__eq__('is_set') == True — Event.is_set co_name is 'is_set'; wave 239 Event.is_set __code__; new to extra74"
  kind: python_call_eq
  function: Event.is_set.__code__.co_name.__eq__
  args: ["is_set"]
  expected: true

invariant threading_extra74.current_thread_class_function:
  description: "threading.current_thread.__class__.__name__.__eq__('function') == True — current_thread is a plain Python function; wave 239 current_thread identity; new to extra74"
  kind: python_call_eq
  function: current_thread.__class__.__name__.__eq__
  args: ["function"]
  expected: true
