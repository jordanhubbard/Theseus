spec: re_extra2536
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/re/"
    - "CPython source: Modules/_sre.c"
  notes:
    - "Theme: __format__, __bytes__, and __fspath__ dict-presence checks across re module classes."
    - "re.Pattern does not define __format__, __bytes__, or __fspath__ in its own __dict__."
    - "re.Match does not define __format__, __bytes__, or __fspath__ in its own __dict__."
    - "Neither re.Pattern nor re.Match implements the filesystem path protocol; regex objects represent patterns, not paths."
    - "Neither class defines __bytes__ for bytes conversion; use pattern.pattern to access the raw pattern string."
    - "Neither class defines a custom __format__; they rely on the default object.__format__ inherited from object."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern — __format__, __bytes__, __fspath__ dict-presence
# ---------------------------------------------------------------------------

table re_extra2536.pattern_proto_dict:
  description: "re.Pattern.__dict__ contains no __format__, __bytes__, or __fspath__; all __dict__.__contains__ calls return False; verified with Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: re2536

  columns: [id, function, args, expected]
  rows:
    - ["re2536001", re.Pattern.__dict__.__contains__, ["__format__"], false]
    - ["re2536002", re.Pattern.__dict__.__contains__, ["__bytes__"], false]
    - ["re2536003", re.Pattern.__dict__.__contains__, ["__fspath__"], false]

