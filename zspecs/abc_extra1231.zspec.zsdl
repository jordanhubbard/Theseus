spec: abc_extra1231
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc.__dict__.__contains__ for ABC, ABCMeta, abstractmethod, abstractproperty, abstractclassmethod, abstractstaticmethod, get_cache_token, update_abstractmethods, __builtins__, __doc__, __file__, __name__, __spec__; absent: abstractattribute, Interface, Protocol, nonexistent"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.__dict__.__contains__ for all public names and selected dunder module attributes; also checks qualname identity for ABCMeta/ABC/abstractmethod and function class names for get_cache_token (builtin_function_or_method) and update_abstractmethods (function) — behaviors not covered by extra1201 (__bases__/__mro__ lengths) or extra1216 (ABCMeta.__dict__ members, ABC.__dict__ members, __isabstractmethod__ in deprecated decorator __dict__)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1231.dict_contains_public_names:
  description: "abc.__dict__ contains all public names: ABC, ABCMeta, abstractmethod, abstractproperty, abstractclassmethod, abstractstaticmethod, get_cache_token, update_abstractmethods"
  kind: python_call_eq
  category: module_interface
  id_prefix: ab1231dc
  columns: [id, function, args, expected]
  rows:
    - [ab1231dc001, abc.__dict__.__contains__, ["ABC"],                   true]
    - [ab1231dc002, abc.__dict__.__contains__, ["ABCMeta"],               true]
    - [ab1231dc003, abc.__dict__.__contains__, ["abstractmethod"],        true]
    - [ab1231dc004, abc.__dict__.__contains__, ["abstractproperty"],      true]
    - [ab1231dc005, abc.__dict__.__contains__, ["abstractclassmethod"],   true]
    - [ab1231dc006, abc.__dict__.__contains__, ["abstractstaticmethod"],  true]
    - [ab1231dc007, abc.__dict__.__contains__, ["get_cache_token"],       true]
    - [ab1231dc008, abc.__dict__.__contains__, ["update_abstractmethods"], true]

table abc_extra1231.dict_contains_module_dunders_and_absent:
  description: "abc.__dict__ contains module dunder attrs __builtins__, __doc__, __file__, __name__, __spec__; absent: abstractattribute, Interface, Protocol, nonexistent"
  kind: python_call_eq
  category: module_interface
  id_prefix: ab1231md
  columns: [id, function, args, expected]
  rows:
    - [ab1231md001, abc.__dict__.__contains__, ["__builtins__"],       true]
    - [ab1231md002, abc.__dict__.__contains__, ["__doc__"],            true]
    - [ab1231md003, abc.__dict__.__contains__, ["__file__"],           true]
    - [ab1231md004, abc.__dict__.__contains__, ["__name__"],           true]
    - [ab1231md005, abc.__dict__.__contains__, ["__spec__"],           true]
    - [ab1231md006, abc.__dict__.__contains__, ["abstractattribute"],  false]
    - [ab1231md007, abc.__dict__.__contains__, ["Interface"],          false]
    - [ab1231md008, abc.__dict__.__contains__, ["Protocol"],           false]
    - [ab1231md009, abc.__dict__.__contains__, ["nonexistent"],        false]

table abc_extra1231.qualnames_and_function_types:
  description: "abc.ABCMeta, abc.ABC, and abc.abstractmethod __qualname__ equal their simple names; get_cache_token is a builtin_function_or_method and update_abstractmethods is a function"
  kind: python_call_eq
  category: module_interface
  id_prefix: ab1231qt
  columns: [id, function, args, expected]
  rows:
    - [ab1231qt001, abc.ABCMeta.__qualname__.__eq__,               ["ABCMeta"],        true]
    - [ab1231qt002, abc.ABC.__qualname__.__eq__,                    ["ABC"],            true]
    - [ab1231qt003, abc.abstractmethod.__qualname__.__eq__,         ["abstractmethod"], true]
    - [ab1231qt004, abc.get_cache_token.__qualname__.__eq__,        ["get_cache_token"], true]
    - [ab1231qt005, abc.update_abstractmethods.__qualname__.__eq__, ["update_abstractmethods"], true]
    - [ab1231qt006, abc.get_cache_token.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [ab1231qt007, abc.update_abstractmethods.__class__.__name__.__eq__, ["function"],                   true]
    - [ab1231qt008, abc.ABCMeta.__dict__.__contains__, ["_dump_registry"], true]
    - [ab1231qt009, abc.ABCMeta.__dict__.__contains__, ["_abc_registry"],  false]
    - [ab1231qt010, abc.__name__.__eq__, ["abc"], true]
    - [ab1231qt011, abc.__name__.__len__.__eq__, [3], true]
