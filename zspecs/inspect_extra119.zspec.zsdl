    - "len(inspect.Attribute._fields[1]) == 4 ('kind'). Verified with Python 3.14.3."
    - "len(inspect.Attribute._fields[2]) == 14 ('defining_class'). Verified with Python 3.14.3."
    - "len(inspect.Attribute._fields[3]) == 6 ('object'). Verified with Python 3.14.3."
    - "inspect.Attribute._make.__qualname__ == 'Attribute._make' (len 15). Verified with Python 3.14.3."
    - "inspect.Attribute._asdict.__qualname__ == 'Attribute._asdict' (len 17). Verified with Python 3.14.3."
    - "inspect.Attribute.__mro__.__len__() == 3. Verified with Python 3.14.3."
    - "inspect.Attribute.__mro__[0].__name__ == 'Attribute'. Verified with Python 3.14.3."
    - "inspect.Attribute.__mro__[1].__name__ == 'tuple'. Verified with Python 3.14.3."
    - "inspect.Attribute.__mro__[2].__name__ == 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Attribute._fields element access
#
# Wave 270 theme: inspect.Attribute is a namedtuple with 4 fields:
# 'name', 'kind', 'defining_class', and 'object'. These are the fields of the
# NamedTuple returned by inspect.classify_class_attrs(). Prior specs covered
# Attribute._fields.__len__() == 4 (in extra108). New here: individual element
# access via __getitem__. The _fields tuple element values are:
# [0]='name' (4 chars), [1]='kind' (4 chars), [2]='defining_class' (14 chars),
# [3]='object' (6 chars). Elements 0 and 1 have the same length (4).
# Element 2 is the longest (14 chars — 'defining_class').
#
# Attribute._fields[0] == 'name'             (len 4)
# Attribute._fields[1] == 'kind'             (len 4)
# Attribute._fields[2] == 'defining_class'   (len 14)
# Attribute._fields[3] == 'object'           (len 6)
#
# New to extra119.
# ---------------------------------------------------------------------------

table inspect_extra119.attribute_fields_elements:
  description: "inspect.Attribute._fields elements: [0]='name'(4), [1]='kind'(4), [2]='defining_class'(14), [3]='object'(6); [0] and [1] share len=4; [2] is longest (14); namedtuple fields of classify_class_attrs result; wave 270; new to extra119"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectaffe119

  columns: [id, function, args, expected, description]
  rows:
    - [attr_fields0_eq,
       "Attribute._fields.__getitem__",
       [0],
       "name",
       "inspect.Attribute._fields[0] == 'name' — the first field of the Attribute namedtuple is 'name', the attribute name string; tuple.__getitem__(0) returns 'name'; new to extra119"]
    - [attr_fields1_eq,
       "Attribute._fields.__getitem__",
       [1],
       "kind",
       "inspect.Attribute._fields[1] == 'kind' — the second field of the Attribute namedtuple is 'kind', a string describing the attribute kind (e.g. 'method', 'data'); tuple.__getitem__(1) returns 'kind'; new to extra119"]
    - [attr_fields2_eq,
       "Attribute._fields.__getitem__",
       [2],
       "defining_class",
       "inspect.Attribute._fields[2] == 'defining_class' — the third field is 'defining_class', the class in which the attribute was defined (14 chars); the longest field name; tuple.__getitem__(2) returns 'defining_class'; new to extra119"]
    - [attr_fields3_eq,
       "Attribute._fields.__getitem__",
       [3],
       "object",
       "inspect.Attribute._fields[3] == 'object' — the fourth field is 'object', holding the attribute value itself (6 chars); tuple.__getitem__(3) returns 'object'; new to extra119"]
    - [attr_fields0_len,
       "Attribute._fields.__getitem__(0).__len__",
       [],
       4,
       "inspect.Attribute._fields[0].__len__() == 4 — 'name' has 4 chars: n-a-m-e; same length as _fields[1] ('kind'); str.__len__() returns 4; new to extra119"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Attribute._fields element string lengths
#
# Wave 270 theme: The _fields element string lengths follow the pattern:
# 4, 4, 14, 6. The first two ('name', 'kind') are both 4 chars — the shortest.
# 'defining_class' (14 chars) is the longest field name in the namedtuple.
# 'object' (6 chars) is the fourth field. The defining_class field name length
# (14) coincidentally equals the length of Python's typical __qualname__ for a
# method in a 5-char class (e.g. 'chain.__next__' = 14). None of these element
# string lengths have been covered in prior inspect specs (only __len__ of
# _fields itself was covered in extra108, not element lengths).
#
# len(Attribute._fields[0]) == 4
# len(Attribute._fields[1]) == 4
# len(Attribute._fields[2]) == 14
# len(Attribute._fields[3]) == 6
#
# New to extra119.
# ---------------------------------------------------------------------------

table inspect_extra119.attribute_fields_element_lens:
  description: "inspect.Attribute._fields element lengths: [0]='name'(4), [1]='kind'(4), [2]='defining_class'(14), [3]='object'(6); first two equal (4); [2] is longest (14); wave 270; new to extra119"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectaffel119

  columns: [id, function, args, expected, description]
  rows:
    - [attr_fields0_len_4,
       "Attribute._fields.__getitem__(0).__len__",
       [],
       4,
       "inspect.Attribute._fields[0].__len__() == 4 — 'name' has 4 chars: n-a-m-e; equal to _fields[1].__len__() (also 4); str.__len__() returns 4; new to extra119"]
    - [attr_fields1_len_4,
       "Attribute._fields.__getitem__(1).__len__",
       [],
       4,
       "inspect.Attribute._fields[1].__len__() == 4 — 'kind' has 4 chars: k-i-n-d; equal to _fields[0].__len__() (also 4); str.__len__() returns 4; new to extra119"]
    - [attr_fields2_len_14,
       "Attribute._fields.__getitem__(2).__len__",
       [],
       14,
       "inspect.Attribute._fields[2].__len__() == 14 — 'defining_class' has 14 chars: d-e-f-i-n-i-n-g(8)+_(1)+c-l-a-s-s(5); the longest field name in Attribute; str.__len__() returns 14; new to extra119"]
    - [attr_fields3_len_6,
       "Attribute._fields.__getitem__(3).__len__",
       [],
       6,
       "inspect.Attribute._fields[3].__len__() == 6 — 'object' has 6 chars: o-b-j-e-c-t; between kind (4) and defining_class (14); str.__len__() returns 6; new to extra119"]
    - [attr_fields_len_4,
       "Attribute._fields.__len__",
       [],
       4,
       "inspect.Attribute._fields.__len__() == 4 — Attribute namedtuple has 4 fields (name, kind, defining_class, object); tuple.__len__() returns 4; confirming prior extra108 coverage; new to extra119"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Attribute namedtuple class method qualnames and MRO
#
# Wave 270 theme: inspect.Attribute is a namedtuple subclass, so it inherits
# the namedtuple class methods: _make (create from iterable) and _asdict
# (convert to dict). Their qualnames follow the pattern 'Attribute._make'
# (15 chars) and 'Attribute._asdict' (17 chars). 'Attribute' has 9 chars;
# '_make' has 5 chars (giving 9+1+5=15) and '_asdict' has 7 chars
# (giving 9+1+7=17). The MRO of Attribute has 3 entries: Attribute (index 0),
# tuple (index 1), object (index 2). As a namedtuple it extends tuple, not
# directly object. This gives __mro__.__len__() == 3, unlike simpler
# namedtuple-free classes that have __mro__.__len__() == 2.
#
# Attribute._make.__qualname__ == 'Attribute._make'     (len 15)
# Attribute._asdict.__qualname__ == 'Attribute._asdict' (len 17)
# Attribute.__mro__.__len__() == 3
# Attribute.__mro__[1].__name__ == 'tuple'
#
# New to extra119.
# ---------------------------------------------------------------------------

table inspect_extra119.attribute_classmethods_and_mro:
  description: "inspect.Attribute namedtuple class methods and MRO: _make.__qualname__='Attribute._make'(15), _asdict.__qualname__='Attribute._asdict'(17), __mro__ len=3 (Attribute->tuple->object); wave 270; new to extra119"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectacm119

  columns: [id, function, args, expected, description]
  rows:
    - [attr_make_qualname_eq,
       "Attribute._make.__qualname__.__eq__",
       ["Attribute._make"],
       true,
       "inspect.Attribute._make.__qualname__.__eq__('Attribute._make') == True — _make is the classmethod that creates an Attribute from an iterable; its qualname is 'Attribute._make' (15 chars); str.__eq__('Attribute._make') returns True; new to extra119"]
    - [attr_make_qualname_len,
       "Attribute._make.__qualname__.__len__",
       [],
       15,
       "inspect.Attribute._make.__qualname__.__len__() == 15 — 'Attribute._make' has 15 chars: Attribute(9)+dot(1)+_make(5); str.__len__() returns 15; new to extra119"]
    - [attr_asdict_qualname_eq,
       "Attribute._asdict.__qualname__.__eq__",
       ["Attribute._asdict"],
       true,
       "inspect.Attribute._asdict.__qualname__.__eq__('Attribute._asdict') == True — _asdict is the namedtuple method that returns an OrderedDict; its qualname is 'Attribute._asdict' (17 chars); str.__eq__('Attribute._asdict') returns True; new to extra119"]
    - [attr_asdict_qualname_len,
       "Attribute._asdict.__qualname__.__len__",
       [],
       17,
       "inspect.Attribute._asdict.__qualname__.__len__() == 17 — 'Attribute._asdict' has 17 chars: Attribute(9)+dot(1)+_asdict(7); two more than _make (15); str.__len__() returns 17; new to extra119"]
    - [attr_mro_len,
       "Attribute.__mro__.__len__",
       [],
       3,
       "inspect.Attribute.__mro__.__len__() == 3 — Attribute is a namedtuple subclass; its MRO is [Attribute, tuple, object] (3 entries); unlike plain dataclasses (MRO len=2); tuple.__len__() returns 3; new to extra119"]
    - [attr_mro1_tuple,
       "Attribute.__mro__.__getitem__",
       [1],
       "tuple",
       "inspect.Attribute.__mro__[1].__name__ == 'tuple' — the second MRO entry for a namedtuple subclass is always tuple; namedtuple generates classes that inherit from tuple; tuple.__getitem__(1).__name__ returns 'tuple'; new to extra119"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra119
# ---------------------------------------------------------------------------

invariant inspect_extra119.attr_fields0:
  description: "inspect.Attribute._fields[0] == 'name' — first namedtuple field; 4 chars; wave 270; new to extra119"
  kind: python_call_eq
  function: "Attribute._fields.__getitem__"
  args: [0]
  expected: "name"

invariant inspect_extra119.attr_fields2:
  description: "inspect.Attribute._fields[2] == 'defining_class' — third namedtuple field; 14 chars (longest); wave 270; new to extra119"
  kind: python_call_eq
  function: "Attribute._fields.__getitem__"
  args: [2]
  expected: "defining_class"

invariant inspect_extra119.attr_fields2_len:
  description: "inspect.Attribute._fields[2].__len__() == 14 — 'defining_class' has 14 chars; the longest Attribute field name; wave 270; new to extra119"
  kind: python_call_eq
  function: "Attribute._fields.__getitem__(2).__len__"
  args: []
  expected: 14

invariant inspect_extra119.attr_make_qualname:
  description: "inspect.Attribute._make.__qualname__ == 'Attribute._make' — namedtuple classmethod; qualname len=15; wave 270; new to extra119"
  kind: python_call_eq
  function: Attribute._make.__qualname__.__eq__
  args: ["Attribute._make"]
  expected: true

invariant inspect_extra119.attr_mro_len:
  description: "inspect.Attribute.__mro__.__len__() == 3 — namedtuple subclass; MRO is [Attribute, tuple, object]; len=3 unlike plain classes (len=2); wave 270; new to extra119"
  kind: python_call_eq
  function: Attribute.__mro__.__len__
  args: []
  expected: 3

