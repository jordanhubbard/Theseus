spec: inspect_extra121
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra120.zspec.zsdl."
    - "This spec covers: inspect.getouterframes and inspect.getframeinfo function __code__.co_varnames elements not previously covered — getouterframes co_varnames[2]='framelist'(9), co_varnames[3]='traceback_info'(14), co_varnames[4]='frameinfo'(9); getframeinfo co_varnames[2]='positions'(9), co_varnames[3]='lineno'(6), co_varnames tuple len=9; getinnerframes co_varnames[0]='tb'(2); wave 272."
    - "Prior spec extra111 covered: getouterframes co_name='getouterframes', co_argcount=2 (new in extra111). Prior extra97 covered getouterframes co_argcount==2. New here: co_varnames elements at indices 2, 3, 4 for getouterframes and indices 2, 3 for getframeinfo; also getinnerframes co_varnames[0]='tb'."
    - "inspect.getouterframes.__code__.co_varnames[2] == 'framelist' (len 9). Verified with Python 3.14.3."
    - "inspect.getouterframes.__code__.co_varnames[3] == 'traceback_info' (len 14). Verified with Python 3.14.3."
    - "inspect.getouterframes.__code__.co_varnames[4] == 'frameinfo' (len 9). Verified with Python 3.14.3."
    - "inspect.getouterframes.__code__.co_varnames.__len__() == 5. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__code__.co_varnames[2] == 'positions' (len 9). Verified with Python 3.14.3."
    - "inspect.getframeinfo.__code__.co_varnames[3] == 'lineno' (len 6). Verified with Python 3.14.3."
    - "inspect.getframeinfo.__code__.co_varnames.__len__() == 9. Verified with Python 3.14.3."
    - "inspect.getinnerframes.__code__.co_varnames[0] == 'tb' (len 2). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getouterframes __code__.co_varnames[2], [3], [4]
#
# Wave 272 theme: inspect.getouterframes(frame, context=1) is a pure-Python
# function with 2 declared parameters (frame, context) and 3 additional local
# variables used in its implementation. Prior specs extra97 and extra111 covered
# co_argcount=2 and co_name='getouterframes'. New here: the remaining co_varnames
# entries. co_varnames[2] == 'framelist' (9 chars) — the list accumulating
# FrameInfo entries as the function walks outer frames. co_varnames[3] ==
# 'traceback_info' (14 chars) — an intermediate FrameInfo-like tuple from
# getframeinfo. co_varnames[4] == 'frameinfo' (9 chars) — the final FrameInfo
# namedtuple appended to framelist. The co_varnames tuple has exactly 5 entries:
# 2 parameters + 3 internal locals.
#
# getouterframes.__code__.co_varnames[2] == 'framelist'       (len 9)
# getouterframes.__code__.co_varnames[3] == 'traceback_info'  (len 14)
# getouterframes.__code__.co_varnames[4] == 'frameinfo'       (len 9)
# getouterframes.__code__.co_varnames.__len__() == 5
#
# New to extra121.
# ---------------------------------------------------------------------------

table inspect_extra121.getouterframes_co_varnames_2_to_4:
  description: "inspect.getouterframes co_varnames[2]='framelist'(9), [3]='traceback_info'(14), [4]='frameinfo'(9); tuple len=5; prior extra111 covered co_name and co_argcount; wave 272; new to extra121"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgofcv121

  columns: [id, function, args, expected, description]
  rows:
    - [getouterframes_cv2_eq,
       "getouterframes.__code__.co_varnames.__getitem__",
       [2],
       "framelist",
       "inspect.getouterframes.__code__.co_varnames[2] == 'framelist' — the local list that accumulates FrameInfo tuples as getouterframes walks the call stack; tuple.__getitem__(2) returns 'framelist'; new to extra121"]
    - [getouterframes_cv2_len,
       "getouterframes.__code__.co_varnames.__getitem__(2).__len__",
       [],
       9,
       "inspect.getouterframes.__code__.co_varnames[2].__len__() == 9 — 'framelist' has 9 chars: f-r-a-m-e-l-i-s-t; same length as co_varnames[4] 'frameinfo' (also 9); str.__len__() returns 9; new to extra121"]
    - [getouterframes_cv3_eq,
       "getouterframes.__code__.co_varnames.__getitem__",
       [3],
       "traceback_info",
       "inspect.getouterframes.__code__.co_varnames[3] == 'traceback_info' — the intermediate frame info tuple obtained from getframeinfo for each frame in the stack; tuple.__getitem__(3) returns 'traceback_info'; new to extra121"]
    - [getouterframes_cv3_len,
       "getouterframes.__code__.co_varnames.__getitem__(3).__len__",
       [],
       14,
       "inspect.getouterframes.__code__.co_varnames[3].__len__() == 14 — 'traceback_info' has 14 chars: t-r-a-c-e-b-a-c-k-_-i-n-f-o; the longest co_varnames entry in getouterframes; str.__len__() returns 14; new to extra121"]
    - [getouterframes_cv4_eq,
       "getouterframes.__code__.co_varnames.__getitem__",
       [4],
       "frameinfo",
       "inspect.getouterframes.__code__.co_varnames[4] == 'frameinfo' — the FrameInfo namedtuple appended to framelist on each iteration; tuple.__getitem__(4) returns 'frameinfo'; new to extra121"]
    - [getouterframes_cv4_len,
       "getouterframes.__code__.co_varnames.__getitem__(4).__len__",
       [],
       9,
       "inspect.getouterframes.__code__.co_varnames[4].__len__() == 9 — 'frameinfo' has 9 chars: f-r-a-m-e-i-n-f-o; same length as co_varnames[2] 'framelist' (also 9); str.__len__() returns 9; new to extra121"]
    - [getouterframes_cv_len,
       "getouterframes.__code__.co_varnames.__len__",
       [],
       5,
       "inspect.getouterframes.__code__.co_varnames.__len__() == 5 — getouterframes has 5 local variable names: 2 declared parameters (frame, context) + 3 internal locals (framelist, traceback_info, frameinfo); tuple.__len__() returns 5; new to extra121"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getframeinfo __code__.co_varnames[2] and [3]; tuple length
#
# Wave 272 theme: inspect.getframeinfo(frame, context=1) is a pure-Python
# function with 2 declared parameters and 7 additional internal locals,
# giving co_varnames length 9. Its implementation collects source lines,
# determines the filename, and constructs a Traceback namedtuple. co_varnames[2]
# == 'positions' (9 chars) — frame position info (Python 3.11+). co_varnames[3]
# == 'lineno' (6 chars) — the current line number extracted from positions.
# The co_varnames tuple has 9 entries total, more than getouterframes (5) and
# much more than simple stack inspection utilities.
#
# getframeinfo.__code__.co_varnames[2] == 'positions'  (len 9)
# getframeinfo.__code__.co_varnames[3] == 'lineno'     (len 6)
# getframeinfo.__code__.co_varnames.__len__() == 9
#
# New to extra121.
# ---------------------------------------------------------------------------

table inspect_extra121.getframeinfo_co_varnames_2_3_and_len:
  description: "inspect.getframeinfo co_varnames[2]='positions'(9), [3]='lineno'(6), tuple len=9; getframeinfo has 2 params + 7 locals; more locals than getouterframes (5 total); wave 272; new to extra121"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgficv121

  columns: [id, function, args, expected, description]
  rows:
    - [getframeinfo_cv2_eq,
       "getframeinfo.__code__.co_varnames.__getitem__",
       [2],
       "positions",
       "inspect.getframeinfo.__code__.co_varnames[2] == 'positions' — holds position information for the frame (added Python 3.11+); used to extract the precise line number; tuple.__getitem__(2) returns 'positions'; new to extra121"]
    - [getframeinfo_cv2_len,
       "getframeinfo.__code__.co_varnames.__getitem__(2).__len__",
       [],
       9,
       "inspect.getframeinfo.__code__.co_varnames[2].__len__() == 9 — 'positions' has 9 chars: p-o-s-i-t-i-o-n-s; same length as getouterframes co_varnames[2] 'framelist' (also 9); str.__len__() returns 9; new to extra121"]
    - [getframeinfo_cv3_eq,
       "getframeinfo.__code__.co_varnames.__getitem__",
       [3],
       "lineno",
       "inspect.getframeinfo.__code__.co_varnames[3] == 'lineno' — the current line number extracted from the frame or positions; included in the Traceback namedtuple; tuple.__getitem__(3) returns 'lineno'; new to extra121"]
    - [getframeinfo_cv3_len,
       "getframeinfo.__code__.co_varnames.__getitem__(3).__len__",
       [],
       6,
       "inspect.getframeinfo.__code__.co_varnames[3].__len__() == 6 — 'lineno' has 6 chars: l-i-n-e-n-o; str.__len__() returns 6; new to extra121"]
    - [getframeinfo_cv_len,
       "getframeinfo.__code__.co_varnames.__len__",
       [],
       9,
       "inspect.getframeinfo.__code__.co_varnames.__len__() == 9 — getframeinfo has 9 local variable names: 2 declared parameters (frame, context) + 7 internal locals (positions, lineno, filename, start, lines, lnum, index); tuple.__len__() returns 9; new to extra121"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getinnerframes and getouterframes co_varnames[0] first param
#
# Wave 272 theme: inspect.getinnerframes(tb, context=1) uses 'tb' (a traceback
# object) as its first parameter, rather than 'frame' as getouterframes uses.
# This distinction matters semantically: getinnerframes traverses a traceback
# chain (used for exception handling inspection), while getouterframes traverses
# a frame chain (used for call stack inspection). co_varnames[0] == 'tb' (2 chars)
# is notably short — the shortest first parameter name among the three stack
# inspection functions. The 'tb' abbreviation reflects the standard Python
# convention for traceback object variables. getouterframes co_varnames[0] is
# 'frame' (5 chars) for comparison.
#
# getinnerframes.__code__.co_varnames[0] == 'tb'      (len 2)
# getouterframes.__code__.co_varnames[0] == 'frame'   (len 5)
#
# New to extra121.
# ---------------------------------------------------------------------------

table inspect_extra121.getinnerframes_vs_getouterframes_cv0:
  description: "inspect.getinnerframes co_varnames[0]='tb'(2) vs getouterframes co_varnames[0]='frame'(5); 'tb' is shortest first-param name; traceback-vs-frame distinction; wave 272; new to extra121"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgifcv0121

  columns: [id, function, args, expected, description]
  rows:
    - [getinnerframes_cv0_eq,
       "getinnerframes.__code__.co_varnames.__getitem__",
       [0],
       "tb",
       "inspect.getinnerframes.__code__.co_varnames[0] == 'tb' — getinnerframes takes a traceback object as its first argument; 'tb' is the standard Python shorthand for traceback; tuple.__getitem__(0) returns 'tb'; new to extra121"]
    - [getinnerframes_cv0_len,
       "getinnerframes.__code__.co_varnames.__getitem__(0).__len__",
       [],
       2,
       "inspect.getinnerframes.__code__.co_varnames[0].__len__() == 2 — 'tb' has 2 chars: t-b; the shortest first-parameter name among the stack inspection functions; getouterframes uses 'frame' (5 chars); str.__len__() returns 2; new to extra121"]
    - [getouterframes_cv0_eq,
       "getouterframes.__code__.co_varnames.__getitem__",
       [0],
       "frame",
       "inspect.getouterframes.__code__.co_varnames[0] == 'frame' — getouterframes takes a frame object as its first argument; 'frame' contrasts with getinnerframes' 'tb'; tuple.__getitem__(0) returns 'frame'; new to extra121"]
    - [getouterframes_cv0_len,
       "getouterframes.__code__.co_varnames.__getitem__(0).__len__",
       [],
       5,
       "inspect.getouterframes.__code__.co_varnames[0].__len__() == 5 — 'frame' has 5 chars: f-r-a-m-e; 3 more than 'tb' (2 chars); str.__len__() returns 5; new to extra121"]
    - [getinnerframes_cv_len,
       "getinnerframes.__code__.co_varnames.__len__",
       [],
       5,
       "inspect.getinnerframes.__code__.co_varnames.__len__() == 5 — getinnerframes has 5 local variable names: 2 declared parameters (tb, context) + 3 internal locals (framelist, traceback_info, frameinfo); same count as getouterframes; tuple.__len__() returns 5; new to extra121"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra121
# ---------------------------------------------------------------------------

invariant inspect_extra121.getouterframes_cv2_framelist:
  description: "inspect.getouterframes.__code__.co_varnames[2] == 'framelist' — accumulator local; 9 chars; prior extra111 covered co_name/co_argcount; wave 272; new to extra121"
  kind: python_call_eq
  function: "getouterframes.__code__.co_varnames.__getitem__"
  args: [2]
  expected: "framelist"

invariant inspect_extra121.getouterframes_cv3_traceback_info:
  description: "inspect.getouterframes.__code__.co_varnames[3] == 'traceback_info' — frame info intermediate local; 14 chars; longest co_varnames entry in getouterframes; wave 272; new to extra121"
  kind: python_call_eq
  function: "getouterframes.__code__.co_varnames.__getitem__"
  args: [3]
  expected: "traceback_info"

invariant inspect_extra121.getframeinfo_cv2_positions:
  description: "inspect.getframeinfo.__code__.co_varnames[2] == 'positions' — frame position info local; 9 chars; Python 3.11+; wave 272; new to extra121"
  kind: python_call_eq
  function: "getframeinfo.__code__.co_varnames.__getitem__"
  args: [2]
  expected: "positions"

invariant inspect_extra121.getframeinfo_cv_len:
  description: "inspect.getframeinfo.__code__.co_varnames.__len__() == 9 — 2 params + 7 locals; more complex than getouterframes (5); wave 272; new to extra121"
  kind: python_call_eq
  function: getframeinfo.__code__.co_varnames.__len__
  args: []
  expected: 9

invariant inspect_extra121.getinnerframes_cv0_tb:
  description: "inspect.getinnerframes.__code__.co_varnames[0] == 'tb' — first param is traceback object; 2 chars; shortest first-param name; contrasts with getouterframes 'frame' (5 chars); wave 272; new to extra121"
  kind: python_call_eq
  function: "getinnerframes.__code__.co_varnames.__getitem__"
  args: [0]
  expected: "tb"

