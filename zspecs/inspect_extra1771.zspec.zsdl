spec: inspect_extra1771
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 565 (_extra1771): async protocol dict-presence checks."
    - "Theme: which inspect stdlib types define __aenter__, __aexit__, __aiter__, __anext__, __await__ in their own __dict__."
    - "inspect.Parameter: Python class representing a single callable parameter — introspection type, not async -> all False."
    - "inspect.Signature: Python class representing the complete signature of a callable — introspection type, not async -> all False."
    - "inspect.BoundArguments: Python class representing arguments bound to a signature — introspection type, not async -> all False."
    - "Rationale: inspect types implement the signature-introspection protocol (parameter kinds, default values, binding), not the async protocol."
    - "Complementary checks confirm the class identity of key inspect module-level functions."
    - "inspect.isfunction.__class__.__name__ -> 'function' — isfunction is a Python-level predicate function."
    - "inspect.isclass.__class__.__name__ -> 'function' — isclass is a Python-level predicate function."
    - "inspect.getmembers.__class__.__name__ -> 'function' — getmembers is a Python-level utility function."
    - "inspect.signature.__class__.__name__ -> 'function' — signature is a Python-level factory function."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: async protocol dict-presence checks for inspect types
#
# Wave 565 theme: which inspect types define __aenter__, __aexit__,
# __aiter__, __anext__, __await__ in their own __dict__.
#
# inspect.Parameter: immutable object describing one parameter of a callable
#   signature. Carries kind (POSITIONAL_ONLY, KEYWORD_ONLY, etc.), name,
#   default, and annotation. A pure introspection value type; no async protocol.
# inspect.Signature: immutable object describing the full parameter list and
#   return annotation of a callable. Used by inspect.signature(). No async protocol.
# inspect.BoundArguments: produced by Signature.bind() and Signature.bind_partial().
#   Holds the mapping of parameters to supplied arguments. No async protocol.
# ---------------------------------------------------------------------------

table inspect_extra1771.async_protocol:
  description: "inspect types async protocol dict-presence checks — all False — wave 565 _extra1771"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1771

  columns: [id, function, args, expected]
  rows:
    - ["in1771001", "inspect.Parameter.__dict__.__contains__",      ["__aenter__"], false]
    - ["in1771002", "inspect.Parameter.__dict__.__contains__",      ["__aexit__"],  false]
    - ["in1771003", "inspect.Parameter.__dict__.__contains__",      ["__aiter__"],  false]
    - ["in1771004", "inspect.Parameter.__dict__.__contains__",      ["__anext__"],  false]
    - ["in1771005", "inspect.Parameter.__dict__.__contains__",      ["__await__"],  false]
    - ["in1771006", "inspect.Signature.__dict__.__contains__",      ["__aenter__"], false]
    - ["in1771007", "inspect.Signature.__dict__.__contains__",      ["__aexit__"],  false]
    - ["in1771008", "inspect.Signature.__dict__.__contains__",      ["__aiter__"],  false]
    - ["in1771009", "inspect.Signature.__dict__.__contains__",      ["__anext__"],  false]
    - ["in1771010", "inspect.Signature.__dict__.__contains__",      ["__await__"],  false]
    - ["in1771011", "inspect.BoundArguments.__dict__.__contains__", ["__aenter__"], false]
    - ["in1771012", "inspect.BoundArguments.__dict__.__contains__", ["__aexit__"],  false]
    - ["in1771013", "inspect.BoundArguments.__dict__.__contains__", ["__aiter__"],  false]
    - ["in1771014", "inspect.BoundArguments.__dict__.__contains__", ["__anext__"],  false]
    - ["in1771015", "inspect.BoundArguments.__dict__.__contains__", ["__await__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for inspect module-level functions
#
# The async theme is all-False for all inspect types. Complementary checks
# confirm genuine inspect-specific structural properties:
# - inspect.isfunction.__class__.__name__ -> 'function': Python-level predicate.
# - inspect.isclass.__class__.__name__ -> 'function': Python-level predicate.
# - inspect.getmembers.__class__.__name__ -> 'function': Python-level utility.
# - inspect.signature.__class__.__name__ -> 'function': Python-level factory.
# - inspect.Parameter.__dict__.__contains__('kind') -> True: Parameter exposes
#   the kind descriptor in its own __dict__.
# - inspect.Signature.__dict__.__contains__('parameters') -> True: Signature
#   exposes the parameters property in its own __dict__.
# - inspect.BoundArguments.__dict__.__contains__('args') -> True: BoundArguments
#   exposes the args property in its own __dict__.
# - inspect.Parameter.__dict__.__contains__('empty') -> True: the sentinel
#   value Parameter.empty is defined on the class.
# ---------------------------------------------------------------------------

table inspect_extra1771.complementary_checks:
  description: "inspect module-level function type names and key dict-presence complementary checks — wave 565 _extra1771"
  kind: python_call_eq
  category: complementary
  id_prefix: in1771

  columns: [id, function, args, expected]
  rows:
    - ["in1771016", "inspect.isfunction.__class__.__name__.__eq__",  ["function"], true]
    - ["in1771017", "inspect.isclass.__class__.__name__.__eq__",     ["function"], true]
    - ["in1771018", "inspect.getmembers.__class__.__name__.__eq__",  ["function"], true]
    - ["in1771019", "inspect.signature.__class__.__name__.__eq__",   ["function"], true]
    - ["in1771020", "inspect.Parameter.__dict__.__contains__",       ["kind"],       true]
    - ["in1771021", "inspect.Signature.__dict__.__contains__",       ["parameters"], true]
    - ["in1771022", "inspect.BoundArguments.__dict__.__contains__",  ["args"],       true]
    - ["in1771023", "inspect.Parameter.__dict__.__contains__",       ["empty"],      true]
