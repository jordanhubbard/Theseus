spec: asyncio_extra616
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module class and method introspection"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __doc__ type checks for core asyncio classes and __qualname__ checks for Lock and Queue methods"
  created_at: "2026-04-12T00:00:00Z"

table asyncio_extra616.doc_class_name:
  description: "Verify that __doc__ attributes of core asyncio classes are strings"
  kind: python_call_eq
  category: doc_type
  id_prefix: as616dc
  columns: [id, function, args, expected]
  rows:
    - [as616dc001, asyncio.AbstractEventLoop.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [as616dc002, asyncio.Future.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [as616dc003, asyncio.Task.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [as616dc004, asyncio.Queue.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [as616dc005, asyncio.Lock.__doc__.__class__.__name__.__eq__, ["str"], true]

table asyncio_extra616.lock_qualnames:
  description: "Verify __qualname__ of asyncio.Lock methods"
  kind: python_call_eq
  category: qualname
  id_prefix: as616lq
  columns: [id, function, args, expected]
  rows:
    - [as616lq001, asyncio.Lock.acquire.__qualname__.__eq__, ["Lock.acquire"], true]
    - [as616lq002, asyncio.Lock.release.__qualname__.__eq__, ["Lock.release"], true]

table asyncio_extra616.queue_qualnames:
  description: "Verify __qualname__ of asyncio.Queue methods"
  kind: python_call_eq
  category: qualname
  id_prefix: as616qn
  columns: [id, function, args, expected]
  rows:
    - [as616qn001, asyncio.Queue.put.__qualname__.__eq__, ["Queue.put"], true]
    - [as616qn002, asyncio.Queue.get.__qualname__.__eq__, ["Queue.get"], true]
    - [as616qn003, asyncio.Queue.empty.__qualname__.__eq__, ["Queue.empty"], true]
    - [as616qn004, asyncio.Queue.full.__qualname__.__eq__, ["Queue.full"], true]
    - [as616qn005, asyncio.Queue.qsize.__qualname__.__eq__, ["Queue.qsize"], true]
