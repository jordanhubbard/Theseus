spec: struct_extra39
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra38.zspec.zsdl — covers Struct/__bases__[0]/__qualname__.__eq__('object') and error/__bases__[0]/__qualname__.__eq__('Exception'); error/__mro__[1]/__name__.__eq__('Exception') and error/__mro__[2]/__name__.__eq__('BaseException')."
    - "struct_extra32.zspec.zsdl — covers Struct METHOD __name__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack."
    - "struct_extra27.zspec.zsdl — covers Struct/__mro__.__len__()==2 and error/__mro__.__len__()==4; Struct METHOD __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack."
    - "struct_extra21.zspec.zsdl — covers Struct.__init__/__repr__ __qualname__.__eq__ and __qualname__.__len__(); Struct METHOD __qualname__.__len__() table."
    - "struct_extra9.zspec.zsdl — covers Struct METHOD pack/unpack/pack_into/unpack_from/iter_unpack __name__.__eq__ and __qualname__.__eq__."
    - "struct_extra4.zspec.zsdl — covers error/__qualname__.__eq__('error') and Struct/__qualname__.__eq__('Struct'); module-level function __qualname__.__eq__ table."
  notes:
    - "This spec extends struct through struct_extra38; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: struct_extra38 covers error/__mro__[1]/__name__.__eq__('Exception') and error/__mro__[2]/__name__.__eq__('BaseException'). struct_extra27 covers Struct/__mro__.__len__()==2 and error/__mro__.__len__()==4 (counts). But NO prior spec checks Struct/__mro__[1]/__name__.__eq__('object') or error/__mro__[3]/__name__.__eq__('object') as invariants. Struct's mro is (Struct, object) so mro[1] is object. error's mro is (error, Exception, BaseException, object) so mro[3] is object. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__mro__[1].__name__ == 'object'. Struct inherits directly from object; mro is (Struct, object). extra27 covers __mro__.__len__()==2 (count only). extra38 covers mro entries for error, not for Struct. No prior spec checks Struct/__mro__[1]/__name__.__eq__('object'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[3].__name__ == 'object'. error's mro is (error, Exception, BaseException, object); mro[3] is object. extra38 covers mro[1] (Exception) and mro[2] (BaseException). No prior spec checks error/__mro__[3]/__name__.__eq__('object'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: struct.Struct.size is a getset_descriptor with __qualname__ == 'Struct.size' (len 11). No prior struct spec checks Struct.size.__qualname__ at all. struct_extra29 covers Struct.__dict__['size'].__class__.__name__.__len__()==17 (descriptor type name length); but accessing Struct.size directly (not via __dict__) gives the descriptor object, and Struct.size.__qualname__ is a distinct attribute chain. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__qualname__ == 'Struct.size'. Struct.size is a getset_descriptor; its __qualname__ is 'Struct.size' (11 chars). No prior spec checks Struct.size.__qualname__.__eq__('Struct.size') or Struct.size.__qualname__.__len__()==11. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__mro__[1] and struct.error.__mro__[3] __name__ string eq
#
# struct_extra27 covers Struct/__mro__.__len__()==2 and error/__mro__.__len__()==4.
# struct_extra38 covers error/__mro__[1]/__name__.__eq__('Exception') and
#   error/__mro__[2]/__name__.__eq__('BaseException').
# No prior spec checks:
#   - Struct/__mro__[1]/__name__.__eq__('object')  (Struct's second mro entry)
#   - error/__mro__[3]/__name__.__eq__('object')   (error's fourth mro entry)
# Struct's full mro: (Struct, object).
# error's full mro: (error, Exception, BaseException, object).
# ---------------------------------------------------------------------------

table struct_extra39.mro_object_name_eq:
  description: "struct.Struct/__mro__[1]/__name__.__eq__('object') and error/__mro__[3]/__name__.__eq__('object') — novel: extra38 covers error mro[1]/mro[2] (__name__ eq); extra27 covers mro len counts only; no prior spec checks Struct/mro[1] or error/mro[3] __name__ eq"
  kind: python_call_eq
  category: type_structure
  id_prefix: smoe39

  columns: [id, function, args, expected]
  rows:
    - [Struct_mro1_name_eq, "Struct.__mro__[1].__name__.__eq__", ["object"], true]
    - [error_mro3_name_eq,  "error.__mro__[3].__name__.__eq__",  ["object"], true]

# ---------------------------------------------------------------------------
# struct.Struct.size __qualname__ string eq and length
#
# struct.Struct.size is a getset_descriptor attribute on the Struct type.
# struct_extra29 covers Struct.__dict__['size'].__class__.__name__.__len__()==17
#   (descriptor type name accessed via __dict__; not via Struct.size directly).
# No prior spec checks Struct.size.__qualname__.__eq__('Struct.size') or
#   Struct.size.__qualname__.__len__().
# Struct.size.__qualname__ == 'Struct.size' (len 11).
# ---------------------------------------------------------------------------

invariant struct_extra39.Struct_size_qualname_eq:
  description: "struct.Struct.size.__qualname__ == 'Struct.size' — getset_descriptor; novel: extra29 covers descriptor type name via __dict__; no prior spec checks Struct.size.__qualname__.__eq__"
  category: type_structure
  kind: python_call_eq
  function: "Struct.size.__qualname__.__eq__"
  args: ["Struct.size"]
  expected: true

invariant struct_extra39.Struct_size_qualname_len:
  description: "struct.Struct.size.__qualname__.__len__() == 11 — len('Struct.size') == 11; novel: no prior spec checks Struct.size.__qualname__.__len__()"
  category: type_structure
  kind: python_call_eq
  function: "Struct.size.__qualname__.__len__"
  args: []
  expected: 11
