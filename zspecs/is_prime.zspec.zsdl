spec: is_prime
version: ">=1.0.1"
backend: node(is-prime)

docs: https://www.npmjs.com/package/is-prime

provenance:
  derived_from:
    - "is-prime README — https://www.npmjs.com/package/is-prime"
    - "Test vectors verified with is-prime via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-prime source"
  notes:
    - "is-prime is an npm package. Install: npm install is-prime"
    - "The module exports a single function that returns true if the number is prime."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_prime.isPrime:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: isprime

  columns: [id, args, expected]
  rows:
    - [prime_2,    [2],   true]
    - [prime_7,    [7],   true]
    - [prime_13,   [13],  true]
    - [not_prime,  [4],   false]
    - [not_prime2, [9],   false]
