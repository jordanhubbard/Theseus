spec: decimal_extra312
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal string representation invariants
# All test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0.
# Decimal preserves trailing zeros: Decimal('1.50').__str__() == '1.50'
# Scientific notation is preserved: Decimal('1E+2').__str__() == '1E+2'
# Decimal('1E+2').to_integral_value().__str__() == '1E+2' (not '100')
# Special values: NaN, Infinity, -Infinity
# Boolean: Decimal('0').__bool__() == False; Decimal('1').__bool__() == True
# ---------------------------------------------------------------------------

invariant decimal_extra312.Decimal.str_1_5:
  description: "decimal.Decimal('1.5').__str__().__eq__('1.5') == True — Decimal preserves the given precision; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('1.5').__str__().__eq__"
  args: ["1.5"]
  expected: true

invariant decimal_extra312.Decimal.str_1_50:
  description: "decimal.Decimal('1.50').__str__().__eq__('1.50') == True — Decimal preserves trailing zeros to maintain significance; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('1.50').__str__().__eq__"
  args: ["1.50"]
  expected: true

invariant decimal_extra312.Decimal.str_0_1:
  description: "decimal.Decimal('0.1').__str__().__eq__('0.1') == True — Decimal represents 0.1 exactly (unlike float); verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('0.1').__str__().__eq__"
  args: ["0.1"]
  expected: true

invariant decimal_extra312.Decimal.str_1E_plus_2:
  description: "decimal.Decimal('1E+2').__str__().__eq__('1E+2') == True — scientific notation is preserved as-is in the string representation; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('1E+2').__str__().__eq__"
  args: ["1E+2"]
  expected: true

invariant decimal_extra312.Decimal.to_integral_value_1E2:
  description: "decimal.Decimal('1E+2').to_integral_value().__str__().__eq__('1E+2') == True — to_integral_value() on an already-integral Decimal preserves the coefficient and exponent, returning '1E+2' not '100'; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('1E+2').to_integral_value().__str__().__eq__"
  args: ["1E+2"]
  expected: true

invariant decimal_extra312.Decimal.str_NaN:
  description: "decimal.Decimal('NaN').__str__().__eq__('NaN') == True — NaN special value round-trips through str(); verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('NaN').__str__().__eq__"
  args: ["NaN"]
  expected: true

invariant decimal_extra312.Decimal.str_Infinity:
  description: "decimal.Decimal('Infinity').__str__().__eq__('Infinity') == True — positive infinity round-trips through str(); verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('Infinity').__str__().__eq__"
  args: ["Infinity"]
  expected: true

invariant decimal_extra312.Decimal.str_neg_Infinity:
  description: "decimal.Decimal('-Infinity').__str__().__eq__('-Infinity') == True — negative infinity round-trips through str(); verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('-Infinity').__str__().__eq__"
  args: ["-Infinity"]
  expected: true

invariant decimal_extra312.Decimal.bool_zero_is_false:
  description: "decimal.Decimal('0').__bool__() == False — zero Decimal is falsy, consistent with Python numeric conventions; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('0').__bool__"
  args: []
  expected: false

invariant decimal_extra312.Decimal.bool_one_is_true:
  description: "decimal.Decimal('1').__bool__() == True — nonzero Decimal is truthy; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: "Decimal('1').__bool__"
  args: []
  expected: true

# ---------------------------------------------------------------------------
# decimal.Decimal string representations — table form
# Covers the full set of tested string round-trips and special values
# ---------------------------------------------------------------------------

table decimal_extra312.decimal_str_representations:
  description: "decimal.Decimal string representations for various inputs"
  kind: python_call_eq
  category: behavioral
  id_prefix: decimalstr312

  columns: [id, function, args, expected]
  rows:
    - [str_1_5,        "Decimal('1.5').__str__().__eq__",          ["1.5"],       true]
    - [str_1_50,       "Decimal('1.50').__str__().__eq__",         ["1.50"],      true]
    - [str_0_1,        "Decimal('0.1').__str__().__eq__",          ["0.1"],       true]
    - [str_1e2,        "Decimal('1E+2').__str__().__eq__",         ["1E+2"],      true]
    - [str_nan,        "Decimal('NaN').__str__().__eq__",          ["NaN"],       true]
    - [str_inf,        "Decimal('Infinity').__str__().__eq__",     ["Infinity"],  true]
    - [str_neg_inf,    "Decimal('-Infinity').__str__().__eq__",    ["-Infinity"], true]

# ---------------------------------------------------------------------------
# decimal.Decimal boolean behavior — zero is False, nonzero is True
# ---------------------------------------------------------------------------

table decimal_extra312.decimal_bool:
  description: "decimal.Decimal boolean values: zero is False, nonzero is True"
  kind: python_call_eq
  category: behavioral
  id_prefix: decimalstr312

  columns: [id, function, args, expected]
  rows:
    - [bool_zero,      "Decimal('0').__bool__",   [], false]
    - [bool_one,       "Decimal('1').__bool__",   [], true]
    - [bool_neg_one,   "Decimal('-1').__bool__",  [], true]
