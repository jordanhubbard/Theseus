spec: pika_rust
version: ">=3.9"
backend: rust_module(pika_rust)

docs: https://pika.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://pika.readthedocs.io/en/stable/ — Pika documentation"
  not_derived_from:
    - "pika source: pika/__init__.py"
  notes:
    - "Pika is a Python AMQP 0-9-1 client library (RabbitMQ)."
    - "pika.ConnectionParameters is available."
    - "pika.ConnectionParameters.__name__ == 'ConnectionParameters'."
    - "pika.ConnectionParameters(host='localhost').host == 'localhost'."
    - "pika.BasicProperties is available."
    - "pika.__version__ is a non-empty string."
    - "Expose pika_conn_params_host(host) -> str: pika.ConnectionParameters(host=host).host."
    - "Expose pika_has_basic_props() -> bool: hasattr(pika, 'BasicProperties')."
    - "Expose pika_version_nonempty() -> bool: len(pika.__version__) > 0."
    - "All test vectors verified against pika 1.3.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pika_conn_params_host — host parameter roundtrip
table pika_rust.connection.host:
  kind: python_call_eq
  category: conn_host
  id_prefix: pika_h
  function: pika_conn_params_host

  columns: [id, args, expected]
  rows:
    - [localhost, ["localhost"], "localhost"]
    - [server,   ["myserver"],  "myserver"]

# pika_has_basic_props — BasicProperties present
invariant pika_rust.module.has_basic_props:
  description: "pika.BasicProperties is available"
  category: module
  kind: python_call_eq
  function: pika_has_basic_props
  args: []
  expected: true

# pika_version_nonempty — version non-empty
invariant pika_rust.version.nonempty:
  description: "pika.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pika_version_nonempty
  args: []
  expected: true

