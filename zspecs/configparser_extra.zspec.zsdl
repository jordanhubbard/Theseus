spec: configparser_extra
version: ">=3.9"
backend: python_module(configparser)

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — Python configparser documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/configparser.py"
  notes:
    - "ConfigParser is the primary high-level class; RawConfigParser is the lower-level base that performs no interpolation."
    - "SafeConfigParser was deprecated in Python 3.2 and removed in Python 3.12. It was an alias for ConfigParser."
    - "DEFAULTSECT is the module-level constant 'DEFAULT', naming the special section that provides default values."
    - "Error is the base class for all configparser exceptions."
    - "NoSectionError and NoOptionError both inherit directly from Error."
    - "DuplicateSectionError inherits from Error."
    - "InterpolationError inherits from Error."
    - "ConfigParser().sections() == [] — a freshly created parser has no sections."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — ConfigParser, RawConfigParser
# ---------------------------------------------------------------------------

invariant configparser_extra.class_names.ConfigParser_name:
  description: "ConfigParser.__name__ == 'ConfigParser'"
  category: class_names
  kind: python_call_eq
  function: ConfigParser.__name__.__eq__
  args: ["ConfigParser"]
  expected: true

invariant configparser_extra.class_names.ConfigParser_module:
  description: "ConfigParser.__module__ == 'configparser'"
  category: class_names
  kind: python_call_eq
  function: ConfigParser.__module__.__eq__
  args: ["configparser"]
  expected: true

invariant configparser_extra.class_names.RawConfigParser_name:
  description: "RawConfigParser.__name__ == 'RawConfigParser'"
  category: class_names
  kind: python_call_eq
  function: RawConfigParser.__name__.__eq__
  args: ["RawConfigParser"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class names — Error, NoSectionError, NoOptionError,
#                         DuplicateSectionError, InterpolationError
# ---------------------------------------------------------------------------

invariant configparser_extra.exceptions.Error_name:
  description: "Error.__name__ == 'Error'"
  category: exceptions
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant configparser_extra.exceptions.NoSectionError_name:
  description: "NoSectionError.__name__ == 'NoSectionError'"
  category: exceptions
  kind: python_call_eq
  function: NoSectionError.__name__.__eq__
  args: ["NoSectionError"]
  expected: true

invariant configparser_extra.exceptions.NoOptionError_name:
  description: "NoOptionError.__name__ == 'NoOptionError'"
  category: exceptions
  kind: python_call_eq
  function: NoOptionError.__name__.__eq__
  args: ["NoOptionError"]
  expected: true

invariant configparser_extra.exceptions.DuplicateSectionError_name:
  description: "DuplicateSectionError.__name__ == 'DuplicateSectionError'"
  category: exceptions
  kind: python_call_eq
  function: DuplicateSectionError.__name__.__eq__
  args: ["DuplicateSectionError"]
  expected: true

invariant configparser_extra.exceptions.InterpolationError_name:
  description: "InterpolationError.__name__ == 'InterpolationError'"
  category: exceptions
  kind: python_call_eq
  function: InterpolationError.__name__.__eq__
  args: ["InterpolationError"]
  expected: true

# ---------------------------------------------------------------------------
# Exception inheritance — NoSectionError, NoOptionError base == Error
# ---------------------------------------------------------------------------

invariant configparser_extra.exceptions.NoSectionError_base:
  description: "NoSectionError.__bases__[0].__name__ == 'Error'"
  category: exceptions
  kind: python_call_eq
  function: NoSectionError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

invariant configparser_extra.exceptions.NoOptionError_base:
  description: "NoOptionError.__bases__[0].__name__ == 'Error'"
  category: exceptions
  kind: python_call_eq
  function: NoOptionError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

# ---------------------------------------------------------------------------
# ConfigParser instance behavior
# ---------------------------------------------------------------------------

invariant configparser_extra.ConfigParser.sections_empty:
  description: "ConfigParser().sections() == [] — new parser has no sections"
  category: ConfigParser
  kind: python_call_eq
  function: ConfigParser
  args: []
  method: sections
  expected: []

# ---------------------------------------------------------------------------
# Module-level constant
# ---------------------------------------------------------------------------

invariant configparser_extra.constants.DEFAULTSECT:
  description: "DEFAULTSECT == 'DEFAULT'"
  category: constants
  kind: python_call_eq
  function: DEFAULTSECT.__eq__
  args: ["DEFAULT"]
  expected: true
