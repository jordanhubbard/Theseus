spec: mimetypes_rust
version: ">=3.9"
backend: rust_module(mimetypes_rust)

docs: https://docs.python.org/3/library/mimetypes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mimetypes.html — Python mimetypes documentation"
  not_derived_from:
    - "CPython source: Lib/mimetypes.py"
  notes:
    - "Clean-room Rust reimplementation of Python mimetypes module, exposed via PyO3."
    - "guess_type(url) returns (type, encoding) tuple based on filename extension."
    - "guess_type('file.html') == ('text/html', None)."
    - "guess_type('file.json') == ('application/json', None)."
    - "guess_type('file.txt') == ('text/plain', None)."
    - "guess_type('image.png') == ('image/png', None)."
    - "guess_type('file.tar.gz') == ('application/x-tar', 'gzip') — encoding in slot [1]."
    - "guess_type('file.xyz') == (None, None) for unknown extensions."
    - "guess_type result[0] is the MIME type or None; result[1] is the encoding or None."
    - "All test vectors verified against Python 3.14.3 mimetypes module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# guess_type — MIME type component (index 0)
table mimetypes_rust.guess_type.mime_type:
  kind: python_call_eq
  category: guess_type
  id_prefix: guess_mime
  function: guess_type
  method: __getitem__
  method_args: [0]

  columns: [id, args, expected]
  rows:
    - [html,  ["file.html"],     "text/html"]
    - [json,  ["file.json"],     "application/json"]
    - [txt,   ["file.txt"],      "text/plain"]
    - [png,   ["image.png"],     "image/png"]
    - [css,   ["style.css"],     "text/css"]
    - [js,    ["app.js"],        "text/javascript"]
    - [pdf,   ["doc.pdf"],       "application/pdf"]

# guess_type — encoding component (index 1)
table mimetypes_rust.guess_type.encoding:
  kind: python_call_eq
  category: guess_type
  id_prefix: guess_enc
  function: guess_type
  method: __getitem__
  method_args: [1]

  columns: [id, args, expected]
  rows:
    - [html_no_enc,  ["file.html"],    null]
    - [json_no_enc,  ["file.json"],    null]
    - [gz_enc,       ["file.tar.gz"],  "gzip"]
    - [bz2_enc,      ["file.tar.bz2"], "bzip2"]

