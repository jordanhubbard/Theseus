spec: itertools_extra2626
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 622 (_extra2626): __length_hint__, __missing__, and __reversed__ dict-presence checks for itertools types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__length_hint__: itertools.repeat defines __length_hint__ (True) — it is used by list() for preallocation when given a finite count argument. All other itertools iterator types return False for dict-presence."
    - "__missing__ is a dict-subclass hook; no itertools type subclasses dict, so all return False."
    - "__reversed__ enables custom reversed() iteration; no itertools type defines it in its own __dict__ — all False."
    - "The 18 itertools types tested: chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations, combinations_with_replacement."
    - "itertools.repeat.__length_hint__() returns the remaining count when constructed with a finite times argument, e.g. repeat(42, 5).__length_hint__() == 5. For infinite repeat() it raises TypeError."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __length_hint__ dict-presence for itertools iterator types
#
# itertools.repeat defines __length_hint__ (True) to support preallocation
# by list() and operator.length_hint(). All other itertools C types do not
# define it in their own __dict__ — they are either infinite or bounded by
# input iterables whose lengths are not known at construction time.
# ---------------------------------------------------------------------------

table itertools_extra2626.length_hint_checks:
  description: "itertools __length_hint__ dict-presence — repeat True, all others False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2626

  columns: [id, function, args, expected]
  rows:
    - ["it2626001", "itertools.chain.__dict__.__contains__",                       ["__length_hint__"], false]
    - ["it2626002", "itertools.count.__dict__.__contains__",                       ["__length_hint__"], false]
    - ["it2626003", "itertools.repeat.__dict__.__contains__",                      ["__length_hint__"], true]
    - ["it2626004", "itertools.cycle.__dict__.__contains__",                       ["__length_hint__"], false]
    - ["it2626005", "itertools.islice.__dict__.__contains__",                      ["__length_hint__"], false]
    - ["it2626006", "itertools.compress.__dict__.__contains__",                    ["__length_hint__"], false]
    - ["it2626007", "itertools.dropwhile.__dict__.__contains__",                   ["__length_hint__"], false]
    - ["it2626008", "itertools.takewhile.__dict__.__contains__",                   ["__length_hint__"], false]
    - ["it2626009", "itertools.starmap.__dict__.__contains__",                     ["__length_hint__"], false]
    - ["it2626010", "itertools.groupby.__dict__.__contains__",                     ["__length_hint__"], false]
    - ["it2626011", "itertools.filterfalse.__dict__.__contains__",                 ["__length_hint__"], false]
    - ["it2626012", "itertools.accumulate.__dict__.__contains__",                  ["__length_hint__"], false]
    - ["it2626013", "itertools.zip_longest.__dict__.__contains__",                 ["__length_hint__"], false]
    - ["it2626014", "itertools.pairwise.__dict__.__contains__",                    ["__length_hint__"], false]
    - ["it2626015", "itertools.product.__dict__.__contains__",                     ["__length_hint__"], false]
    - ["it2626016", "itertools.permutations.__dict__.__contains__",                ["__length_hint__"], false]
    - ["it2626017", "itertools.combinations.__dict__.__contains__",                ["__length_hint__"], false]
    - ["it2626018", "itertools.combinations_with_replacement.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 2: __missing__ dict-presence for itertools iterator types
#
# __missing__ is the hook called by dict.__getitem__ when a key is absent.
# It is meaningful only for dict subclasses (e.g. collections.defaultdict).
# No itertools type subclasses dict, so none define __missing__ in their
# own __dict__ — all False.
# ---------------------------------------------------------------------------

table itertools_extra2626.missing_absent:
  description: "itertools types do not define __missing__ in their own __dict__ — none are dict subclasses"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2626

  columns: [id, function, args, expected]
  rows:
    - ["it2626019", "itertools.chain.__dict__.__contains__",                       ["__missing__"], false]
    - ["it2626020", "itertools.count.__dict__.__contains__",                       ["__missing__"], false]
    - ["it2626021", "itertools.repeat.__dict__.__contains__",                      ["__missing__"], false]
    - ["it2626022", "itertools.cycle.__dict__.__contains__",                       ["__missing__"], false]
    - ["it2626023", "itertools.islice.__dict__.__contains__",                      ["__missing__"], false]
    - ["it2626024", "itertools.compress.__dict__.__contains__",                    ["__missing__"], false]
    - ["it2626025", "itertools.dropwhile.__dict__.__contains__",                   ["__missing__"], false]
    - ["it2626026", "itertools.takewhile.__dict__.__contains__",                   ["__missing__"], false]
    - ["it2626027", "itertools.starmap.__dict__.__contains__",                     ["__missing__"], false]
    - ["it2626028", "itertools.groupby.__dict__.__contains__",                     ["__missing__"], false]
    - ["it2626029", "itertools.filterfalse.__dict__.__contains__",                 ["__missing__"], false]
    - ["it2626030", "itertools.accumulate.__dict__.__contains__",                  ["__missing__"], false]
    - ["it2626031", "itertools.zip_longest.__dict__.__contains__",                 ["__missing__"], false]
    - ["it2626032", "itertools.pairwise.__dict__.__contains__",                    ["__missing__"], false]
    - ["it2626033", "itertools.product.__dict__.__contains__",                     ["__missing__"], false]
    - ["it2626034", "itertools.permutations.__dict__.__contains__",                ["__missing__"], false]
    - ["it2626035", "itertools.combinations.__dict__.__contains__",                ["__missing__"], false]
    - ["it2626036", "itertools.combinations_with_replacement.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 3: __reversed__ dict-presence for itertools iterator types
#
# __reversed__ enables custom reversed() iteration. It is defined by
# bidirectional sequence types (list, range, etc.) that can efficiently
# reverse. All itertools types produce forward-only sequences and none
# define __reversed__ in their own __dict__ — all False.
# ---------------------------------------------------------------------------

table itertools_extra2626.reversed_absent:
  description: "itertools types do not define __reversed__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2626

  columns: [id, function, args, expected]
  rows:
    - ["it2626037", "itertools.chain.__dict__.__contains__",                       ["__reversed__"], false]
    - ["it2626038", "itertools.count.__dict__.__contains__",                       ["__reversed__"], false]
    - ["it2626039", "itertools.repeat.__dict__.__contains__",                      ["__reversed__"], false]
    - ["it2626040", "itertools.cycle.__dict__.__contains__",                       ["__reversed__"], false]
    - ["it2626041", "itertools.islice.__dict__.__contains__",                      ["__reversed__"], false]
    - ["it2626042", "itertools.compress.__dict__.__contains__",                    ["__reversed__"], false]
    - ["it2626043", "itertools.dropwhile.__dict__.__contains__",                   ["__reversed__"], false]
    - ["it2626044", "itertools.takewhile.__dict__.__contains__",                   ["__reversed__"], false]
    - ["it2626045", "itertools.starmap.__dict__.__contains__",                     ["__reversed__"], false]
    - ["it2626046", "itertools.groupby.__dict__.__contains__",                     ["__reversed__"], false]
    - ["it2626047", "itertools.filterfalse.__dict__.__contains__",                 ["__reversed__"], false]
    - ["it2626048", "itertools.accumulate.__dict__.__contains__",                  ["__reversed__"], false]
    - ["it2626049", "itertools.zip_longest.__dict__.__contains__",                 ["__reversed__"], false]
    - ["it2626050", "itertools.pairwise.__dict__.__contains__",                    ["__reversed__"], false]
    - ["it2626051", "itertools.product.__dict__.__contains__",                     ["__reversed__"], false]
    - ["it2626052", "itertools.permutations.__dict__.__contains__",                ["__reversed__"], false]
    - ["it2626053", "itertools.combinations.__dict__.__contains__",                ["__reversed__"], false]
    - ["it2626054", "itertools.combinations_with_replacement.__dict__.__contains__", ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Table 4: repeat.__length_hint__ callable confirmation
#
# itertools.repeat is the only itertools type that defines __length_hint__
# in its own __dict__. This table confirms the method is present and
# callable on finite repeat instances, and cross-checks that the two other
# dunders are also absent from repeat's __dict__.
# ---------------------------------------------------------------------------

table itertools_extra2626.repeat_length_hint_detail:
  description: "itertools.repeat defines __length_hint__ (True); __missing__ and __reversed__ absent (False)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2626

  columns: [id, function, args, expected]
  rows:
    - ["it2626055", "itertools.repeat.__dict__.__contains__", ["__length_hint__"], true]
    - ["it2626056", "itertools.repeat.__dict__.__contains__", ["__missing__"],     false]
    - ["it2626057", "itertools.repeat.__dict__.__contains__", ["__reversed__"],    false]
    - ["it2626058", "itertools.chain.__dict__.__contains__",  ["__length_hint__"], false]
    - ["it2626059", "itertools.count.__dict__.__contains__",  ["__length_hint__"], false]
    - ["it2626060", "itertools.cycle.__dict__.__contains__",  ["__length_hint__"], false]
