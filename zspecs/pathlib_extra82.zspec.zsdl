spec: pathlib_extra82
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra81."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for open/read_text/write_text/iterdir/mkdir/exists/unlink/stat/rename/read_bytes/write_bytes/touch/rmdir/resolve; PurePath/__dict__ membership; Path/__dict__ membership."
    - "pathlib_extra81 covers Path.read_bytes/write_bytes/touch/rmdir/resolve __code__.co_name and co_argcount."
    - "This spec covers: Path.glob/rglob/is_dir/is_file/absolute __code__.co_name and co_argcount."
    - "pathlib.Path.glob.__code__.co_name == 'glob' — verified by code object attribute."
    - "pathlib.Path.glob.__code__.co_argcount == 2 — glob(self, pattern): self + pattern; case_sensitive and recurse_symlinks are keyword-only."
    - "pathlib.Path.rglob.__code__.co_name == 'rglob' — verified by code object attribute."
    - "pathlib.Path.rglob.__code__.co_argcount == 2 — rglob(self, pattern): self + pattern; case_sensitive and recurse_symlinks are keyword-only."
    - "pathlib.Path.is_dir.__code__.co_name == 'is_dir' — verified by code object attribute."
    - "pathlib.Path.is_dir.__code__.co_argcount == 1 — is_dir(self): only self; follow_symlinks is keyword-only."
    - "pathlib.Path.is_file.__code__.co_name == 'is_file' — verified by code object attribute."
    - "pathlib.Path.is_file.__code__.co_argcount == 1 — is_file(self): only self; follow_symlinks is keyword-only."
    - "pathlib.Path.absolute.__code__.co_name == 'absolute' — verified by code object attribute."
    - "pathlib.Path.absolute.__code__.co_argcount == 1 — absolute(self): only self, no other parameters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.glob and Path.rglob __code__ attributes
# glob(self, pattern): co_argcount == 2 (self + pattern).
# rglob(self, pattern): co_argcount == 2 (self + pattern).
# case_sensitive and recurse_symlinks are keyword-only in both methods.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra82.glob_rglob_code:
  description: "Path.glob and Path.rglob __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore82

  columns: [id, function, args, expected]
  rows:
    - [glob_co_name,  Path.glob.__code__.co_name.__eq__,     ["glob"],  true]
    - [glob_co_argc,  Path.glob.__code__.co_argcount.__eq__,  [2],      true]
    - [rglob_co_name, Path.rglob.__code__.co_name.__eq__,    ["rglob"], true]
    - [rglob_co_argc, Path.rglob.__code__.co_argcount.__eq__, [2],      true]

# ---------------------------------------------------------------------------
# Path.is_dir and Path.is_file __code__ attributes
# is_dir(self): co_argcount == 1; follow_symlinks is keyword-only.
# is_file(self): co_argcount == 1; follow_symlinks is keyword-only.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra82.is_dir_is_file_code:
  description: "Path.is_dir and Path.is_file __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore82

  columns: [id, function, args, expected]
  rows:
    - [is_dir_co_name,  Path.is_dir.__code__.co_name.__eq__,     ["is_dir"],  true]
    - [is_dir_co_argc,  Path.is_dir.__code__.co_argcount.__eq__,  [1],        true]
    - [is_file_co_name, Path.is_file.__code__.co_name.__eq__,    ["is_file"], true]
    - [is_file_co_argc, Path.is_file.__code__.co_argcount.__eq__, [1],        true]

# ---------------------------------------------------------------------------
# Path.absolute __code__ attributes
# absolute(self): co_argcount == 1; no parameters beyond self.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra82.absolute_code:
  description: "Path.absolute __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore82

  columns: [id, function, args, expected]
  rows:
    - [absolute_co_name, Path.absolute.__code__.co_name.__eq__,    ["absolute"], true]
    - [absolute_co_argc, Path.absolute.__code__.co_argcount.__eq__, [1],         true]

# ---------------------------------------------------------------------------
# Combined co_name identity for glob/rglob/is_dir/is_file/absolute
# Confirms all five method code objects carry the correct co_name.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra82.method_code_names:
  description: "Path method __code__.co_name values match their method names"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore82

  columns: [id, function, args, expected]
  rows:
    - [glob_name,     Path.glob.__code__.co_name.__eq__,     ["glob"],     true]
    - [rglob_name,    Path.rglob.__code__.co_name.__eq__,    ["rglob"],    true]
    - [is_dir_name,   Path.is_dir.__code__.co_name.__eq__,   ["is_dir"],   true]
    - [is_file_name,  Path.is_file.__code__.co_name.__eq__,  ["is_file"],  true]
    - [absolute_name, Path.absolute.__code__.co_name.__eq__, ["absolute"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra82.glob_code.co_name:
  description: "pathlib.Path.glob.__code__.co_name == 'glob'"
  category: code_attrs
  kind: python_call_eq
  function: Path.glob.__code__.co_name.__eq__
  args: ["glob"]
  expected: true

invariant pathlib_extra82.glob_code.co_argcount:
  description: "pathlib.Path.glob.__code__.co_argcount == 2 (self + pattern; keyword-only params not counted)"
  category: code_attrs
  kind: python_call_eq
  function: Path.glob.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant pathlib_extra82.rglob_code.co_argcount:
  description: "pathlib.Path.rglob.__code__.co_argcount == 2 (self + pattern; keyword-only params not counted)"
  category: code_attrs
  kind: python_call_eq
  function: Path.rglob.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant pathlib_extra82.is_dir_code.co_argcount:
  description: "pathlib.Path.is_dir.__code__.co_argcount == 1 (only self; follow_symlinks is keyword-only)"
  category: code_attrs
  kind: python_call_eq
  function: Path.is_dir.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant pathlib_extra82.absolute_code.co_argcount:
  description: "pathlib.Path.absolute.__code__.co_argcount == 1 (only self, no other parameters)"
  category: code_attrs
  kind: python_call_eq
  function: Path.absolute.__code__.co_argcount.__eq__
  args: [1]
  expected: true
