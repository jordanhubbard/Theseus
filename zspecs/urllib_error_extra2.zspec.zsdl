spec: urllib_error_extra2
version: ">=3.0"
backend: python_module(urllib.error)

docs: https://docs.python.org/3/library/urllib.error.html

provenance:
  derived_from:
    - "Python 3 urllib.error documentation — https://docs.python.org/3/library/urllib.error.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/error.py"
  notes:
    - "This spec extends urllib_error.zspec.zsdl and urllib_error_extra.zspec.zsdl."
    - "urllib_error.zspec.zsdl covers: class_names table (URLError, HTTPError, ContentTooShortError), modules table (URLError, HTTPError, ContentTooShortError module == 'urllib.error'), URLError reason, HTTPError code/reason/url, URLError.__bases__[0].__name__ == 'OSError', HTTPError.__bases__[0].__name__ == 'URLError'."
    - "urllib_error_extra.zspec.zsdl covers: URLError.__name__, HTTPError.__name__, HTTPError.__bases__[0].__name__ (again)."
    - "Focus: __qualname__ for all three exception classes, ContentTooShortError bases, and new attribute vectors."
    - "For top-level exception classes, __qualname__ == __name__."
    - "urllib.error.URLError.__qualname__ == 'URLError'."
    - "urllib.error.HTTPError.__qualname__ == 'HTTPError'."
    - "urllib.error.ContentTooShortError.__qualname__ == 'ContentTooShortError'."
    - "urllib.error.ContentTooShortError.__bases__[0].__name__ == 'URLError' — ContentTooShortError subclasses URLError."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Exception classes; raised by urllib.request operations on network failures or HTTP errors."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# __qualname__ checks — all three exception classes
# Prior specs only check __name__ and __module__; __qualname__ is new.
# ---------------------------------------------------------------------------

table urllib_error_extra2.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [URLError,              URLError.__qualname__.__eq__,              ["URLError"],              true]
    - [HTTPError,             HTTPError.__qualname__.__eq__,             ["HTTPError"],             true]
    - [ContentTooShortError,  ContentTooShortError.__qualname__.__eq__,  ["ContentTooShortError"],  true]

# ---------------------------------------------------------------------------
# Inheritance: ContentTooShortError — not yet covered in any prior spec
# urllib_error.zspec.zsdl covers URLError.__bases__[0] and HTTPError.__bases__[0].
# ContentTooShortError inherits from URLError.
# ---------------------------------------------------------------------------

invariant urllib_error_extra2.ContentTooShortError.base_is_URLError:
  description: "urllib.error.ContentTooShortError.__bases__[0].__name__ == 'URLError'"
  category: hierarchy
  kind: python_call_eq
  function: ContentTooShortError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "URLError"

# ---------------------------------------------------------------------------
# __module__ for ContentTooShortError — already in urllib_error.modules table,
# but __qualname__ is not. We add additional module checks for completeness
# on vectors not individually covered as invariants in prior specs.
# ---------------------------------------------------------------------------

invariant urllib_error_extra2.URLError.qualname_is_str:
  description: "urllib.error.URLError.__qualname__.__class__.__name__ == 'str'"
  category: qualnames
  kind: python_call_eq
  function: URLError.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant urllib_error_extra2.HTTPError.qualname_is_str:
  description: "urllib.error.HTTPError.__qualname__.__class__.__name__ == 'str'"
  category: qualnames
  kind: python_call_eq
  function: HTTPError.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant urllib_error_extra2.ContentTooShortError.qualname_is_str:
  description: "urllib.error.ContentTooShortError.__qualname__.__class__.__name__ == 'str'"
  category: qualnames
  kind: python_call_eq
  function: ContentTooShortError.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPError construction — additional attribute vectors not in prior specs
# urllib_error.zspec.zsdl: covers code 404, reason 'Not Found', url, code 500.
# We add code 403 and code 301 as new distinct vectors.
# ---------------------------------------------------------------------------

invariant urllib_error_extra2.httperror_403_code:
  description: "HTTPError('http://example.com', 403, 'Forbidden', {}, None).code == 403"
  category: httperror
  kind: python_call_eq
  function: HTTPError
  args: ["http://example.com", 403, "Forbidden", {}, null]
  method: code
  expected: 403

invariant urllib_error_extra2.httperror_403_msg:
  description: "HTTPError('http://example.com', 403, 'Forbidden', {}, None).msg == 'Forbidden'"
  category: httperror
  kind: python_call_eq
  function: HTTPError
  args: ["http://example.com", 403, "Forbidden", {}, null]
  method: msg
  expected: "Forbidden"
