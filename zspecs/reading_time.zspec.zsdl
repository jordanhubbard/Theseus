spec: reading_time
version: ">=1.2.0"
backend: node(reading-time)

docs: https://www.npmjs.com/package/reading-time

provenance:
  derived_from:
    - "reading-time README — https://www.npmjs.com/package/reading-time"
    - "Test vectors verified with reading-time via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "reading-time source"
  notes:
    - "reading-time is an npm package. Install: npm install reading-time"
    - "readingTime(text) estimates reading time at 200 words per minute."
    - "Returns {text, minutes, time (ms), words}."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns reading time estimate object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table reading_time.estimate:
  kind: node_module_call_eq
  function: ~
  category: estimate
  id_prefix: rt

  columns: [id, args, expected]
  rows:
    - [one_word,  ["hello"],
       {"text": "1 min read", "minutes": 0.005, "time": 300, "words": 1}]
    - [seven,     ["This is a short text for testing"],
       {"text": "1 min read", "minutes": 0.035, "time": 2100, "words": 7}]
