spec: socket_extra2776
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra2761.zspec.zsdl — covers __matmul__, __truediv__, and __iadd__ absence for socket.socket, AddressFamily, SocketKind."
    - "socket_extra2746.zspec.zsdl — covers __imatmul__, __ifloordiv__, __imod__ absence for socket.socket, AddressFamily, SocketKind."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "socket.socket.__dict__.__contains__('__isub__') == False — socket.socket is a network I/O type; it defines no in-place subtraction operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__imul__') == False — socket.socket defines no in-place multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.socket.__dict__.__contains__('__itruediv__') == False — socket.socket defines no in-place true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__isub__') == False — AddressFamily is an IntEnum subclass; it does not add in-place subtraction to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__imul__') == False — AddressFamily does not add in-place multiplication to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.AddressFamily.__dict__.__contains__('__itruediv__') == False — AddressFamily does not add in-place true division to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__isub__') == False — SocketKind is an IntEnum subclass; it does not add in-place subtraction to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__imul__') == False — SocketKind does not add in-place multiplication to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "socket.SocketKind.__dict__.__contains__('__itruediv__') == False — SocketKind does not add in-place true division to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.socket.__dict__ — __isub__, __imul__, __itruediv__ absence
# socket.socket is the main socket class; it wraps a file descriptor and
# provides network I/O methods (connect, bind, send, recv, etc.). In-place
# arithmetic operators (-=, *=, /=) have no meaning for a network socket.
# ---------------------------------------------------------------------------

table socket_extra2776.socket_dict_isub_imul_itruediv:
  description: "socket.socket.__dict__ does not contain __isub__, __imul__, or __itruediv__ — socket.socket is a network I/O type with no in-place arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2776

  columns: [id, function, args, expected]
  rows:
    - ["sk2776-sock-isub",     socket.socket.__dict__.__contains__,  ["__isub__"],     false]
    - ["sk2776-sock-imul",     socket.socket.__dict__.__contains__,  ["__imul__"],     false]
    - ["sk2776-sock-itruediv", socket.socket.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Table 2: socket.AddressFamily.__dict__ — __isub__, __imul__, __itruediv__ absence
# AddressFamily is an IntEnum subclass (AF_INET=2, AF_INET6=10, AF_UNIX=1, etc.).
# It inherits integer arithmetic from int/IntEnum but does not add in-place
# operators to its own __dict__ (checked with 'in AddressFamily.__dict__',
# not MRO lookup).
# ---------------------------------------------------------------------------

table socket_extra2776.addressfamily_dict_isub_imul_itruediv:
  description: "socket.AddressFamily.__dict__ does not contain __isub__, __imul__, or __itruediv__ — AddressFamily (IntEnum subclass) adds no new in-place arithmetic operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2776

  columns: [id, function, args, expected]
  rows:
    - ["sk2776-af-isub",     socket.AddressFamily.__dict__.__contains__,  ["__isub__"],     false]
    - ["sk2776-af-imul",     socket.AddressFamily.__dict__.__contains__,  ["__imul__"],     false]
    - ["sk2776-af-itruediv", socket.AddressFamily.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Table 3: socket.SocketKind.__dict__ — __isub__, __imul__, __itruediv__ absence
# SocketKind is an IntEnum subclass (SOCK_STREAM=1, SOCK_DGRAM=2, etc.).
# Like AddressFamily, it does not add in-place arithmetic operators to its
# own __dict__.
# ---------------------------------------------------------------------------

table socket_extra2776.socketkind_dict_isub_imul_itruediv:
  description: "socket.SocketKind.__dict__ does not contain __isub__, __imul__, or __itruediv__ — SocketKind (IntEnum subclass) adds no new in-place arithmetic operators to its own __dict__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2776

  columns: [id, function, args, expected]
  rows:
    - ["sk2776-sk-isub",     socket.SocketKind.__dict__.__contains__,  ["__isub__"],     false]
    - ["sk2776-sk-imul",     socket.SocketKind.__dict__.__contains__,  ["__imul__"],     false]
    - ["sk2776-sk-itruediv", socket.SocketKind.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — socket, AddressFamily, SocketKind all absent
# ---------------------------------------------------------------------------

table socket_extra2776.all_types_all_dunders_absent:
  description: "socket.socket, socket.AddressFamily, and socket.SocketKind all lack __isub__, __imul__, and __itruediv__ in __dict__ — no socket type defines these in-place arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: sk2776

  columns: [id, function, args, expected]
  rows:
    - ["sk2776-x-sock-isub",     socket.socket.__dict__.__contains__,       ["__isub__"],     false]
    - ["sk2776-x-sock-imul",     socket.socket.__dict__.__contains__,       ["__imul__"],     false]
    - ["sk2776-x-sock-itruediv", socket.socket.__dict__.__contains__,       ["__itruediv__"], false]
    - ["sk2776-x-af-isub",       socket.AddressFamily.__dict__.__contains__, ["__isub__"],     false]
    - ["sk2776-x-af-imul",       socket.AddressFamily.__dict__.__contains__, ["__imul__"],     false]
    - ["sk2776-x-af-itruediv",   socket.AddressFamily.__dict__.__contains__, ["__itruediv__"], false]
    - ["sk2776-x-sk-isub",       socket.SocketKind.__dict__.__contains__,   ["__isub__"],     false]
    - ["sk2776-x-sk-imul",       socket.SocketKind.__dict__.__contains__,   ["__imul__"],     false]
    - ["sk2776-x-sk-itruediv",   socket.SocketKind.__dict__.__contains__,   ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra2776.socket_no_isub:
  description: "socket.socket.__dict__.__contains__('__isub__') == False — socket.socket is a network I/O object; it defines no -= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant socket_extra2776.socket_no_imul:
  description: "socket.socket.__dict__.__contains__('__imul__') == False — socket.socket defines no *= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant socket_extra2776.socket_no_itruediv:
  description: "socket.socket.__dict__.__contains__('__itruediv__') == False — socket.socket defines no /= operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false

