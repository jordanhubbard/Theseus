spec: math_extra20
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra19.zspec.zsdl."
    - "math has no __all__ attribute (verified: hasattr(math, '__all__') == False)."
    - "No prior spec records __qualname__.__len__ for any math function — prior specs use __qualname__.__eq__."
    - "No prior spec records __class__.__name__.__len__ for math constants pi/tau/e/inf/nan."
    - "All five numeric constants are floats; type(math.pi).__name__ == 'float', len 5."
    - "math.__doc__.__class__.__name__ == 'str', len 3."
    - "math.__spec__.__class__.__name__ == 'ModuleSpec', len 10 — ExtensionFileLoader is the loader class."
    - "math.__dict__.__class__.__name__ == 'dict', len 4 — module __dict__ is a plain dict, not mappingproxy."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# math constant __class__.__name__.__len__ — five numeric constants
#
# math.pi, tau, e, inf, nan are all floats. No prior spec records the
# character length of their class name. 'float' has 5 characters.
# ---------------------------------------------------------------------------

table math_extra20.constant_class_name_len:
  description: "__class__.__name__.__len__ for the five math numeric constants"
  kind: python_call_eq
  category: constants
  id_prefix: cname_len

  columns: [id, function, args, expected, description]
  rows:
    - [pi,  pi.__class__.__name__.__len__,  [], 5, "type(math.pi).__name__ is 'float', len 5"]
    - [tau, tau.__class__.__name__.__len__, [], 5, "type(math.tau).__name__ is 'float', len 5"]
    - [e,   e.__class__.__name__.__len__,   [], 5, "type(math.e).__name__ is 'float', len 5"]
    - [inf, inf.__class__.__name__.__len__, [], 5, "type(math.inf).__name__ is 'float', len 5"]
    - [nan, nan.__class__.__name__.__len__, [], 5, "type(math.nan).__name__ is 'float', len 5"]

# ---------------------------------------------------------------------------
# math function __qualname__.__len__ — logarithm, exponential, and root
#
# Prior specs use __qualname__.__eq__ to confirm the string value; no prior
# spec uses __qualname__.__len__ to confirm the character count. These are
# C builtins; __qualname__ equals the bare function name.
# ---------------------------------------------------------------------------

table math_extra20.log_exp_qualname_len:
  description: "__qualname__.__len__ for math logarithm, exponential, and root functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qlen_log

  columns: [id, function, args, expected, description]
  rows:
    - [log,   log.__qualname__.__len__,   [], 3, "len('log') == 3"]
    - [log2,  log2.__qualname__.__len__,  [], 4, "len('log2') == 4"]
    - [log10, log10.__qualname__.__len__, [], 5, "len('log10') == 5"]
    - [exp,   exp.__qualname__.__len__,   [], 3, "len('exp') == 3"]
    - [pow,   pow.__qualname__.__len__,   [], 3, "len('pow') == 3"]
    - [sqrt,  sqrt.__qualname__.__len__,  [], 4, "len('sqrt') == 4"]
    - [fabs,  fabs.__qualname__.__len__,  [], 4, "len('fabs') == 4"]

# ---------------------------------------------------------------------------
# math function __qualname__.__len__ — rounding functions
#
# floor/ceil/trunc are commonly used rounding functions. No prior spec
# records __qualname__.__len__ for any of them.
# ---------------------------------------------------------------------------

table math_extra20.rounding_qualname_len:
  description: "__qualname__.__len__ for math rounding functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qlen_round

  columns: [id, function, args, expected, description]
  rows:
    - [floor, floor.__qualname__.__len__, [], 5, "len('floor') == 5"]
    - [ceil,  ceil.__qualname__.__len__,  [], 4, "len('ceil') == 4"]
    - [trunc, trunc.__qualname__.__len__, [], 5, "len('trunc') == 5"]

# ---------------------------------------------------------------------------
# math function __qualname__.__len__ — number theory and combinatorics
#
# gcd, lcm (3.9+), comb (3.8+), perm (3.8+). No prior spec uses __len__.
# ---------------------------------------------------------------------------

table math_extra20.number_theory_qualname_len:
  description: "__qualname__.__len__ for math number-theory and combinatorics functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qlen_num

  columns: [id, function, args, expected, description]
  rows:
    - [gcd,  gcd.__qualname__.__len__,  [], 3, "len('gcd') == 3"]
    - [lcm,  lcm.__qualname__.__len__,  [], 3, "len('lcm') == 3"]
    - [comb, comb.__qualname__.__len__, [], 4, "len('comb') == 4"]
    - [perm, perm.__qualname__.__len__, [], 4, "len('perm') == 4"]

# ---------------------------------------------------------------------------
# math function __qualname__.__len__ — predicate functions
#
# isfinite, isinf, isnan, isclose return bool. No prior spec uses __len__.
# ---------------------------------------------------------------------------

table math_extra20.predicate_qualname_len:
  description: "__qualname__.__len__ for math predicate (bool-returning) functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qlen_pred

  columns: [id, function, args, expected, description]
  rows:
    - [isfinite, isfinite.__qualname__.__len__, [], 8, "len('isfinite') == 8"]
    - [isinf,    isinf.__qualname__.__len__,    [], 5, "len('isinf') == 5"]
    - [isnan,    isnan.__qualname__.__len__,    [], 5, "len('isnan') == 5"]
    - [isclose,  isclose.__qualname__.__len__,  [], 7, "len('isclose') == 7"]

# ---------------------------------------------------------------------------
# math module metadata — __doc__ and __spec__ class name lengths
#
# math.__doc__ is a str; 'str' has length 3.
# math.__spec__ is a ModuleSpec; 'ModuleSpec' has length 10.
# No prior math spec touches __class__.__name__.__len__ on module attributes.
# ---------------------------------------------------------------------------

invariant math_extra20.doc_class_name_len:
  description: "math.__doc__.__class__.__name__.__len__() == 3 — __doc__ is a str, 'str' has 3 characters"
  category: module_metadata
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

invariant math_extra20.spec_class_name_len:
  description: "math.__spec__.__class__.__name__.__len__() == 10 — __spec__ is a ModuleSpec, 10 characters"
  category: module_metadata
  kind: python_call_eq
  function: __spec__.__class__.__name__.__len__
  args: []
  expected: 10
