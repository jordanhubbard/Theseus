spec: math_extra20
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra19.zspec.zsdl."
    - "Prior specs cover __name__ for ceil/floor/log/pow and __class__.__name__ for pi/e/tau/inf/nan constants."
    - "No prior spec covers __module__ for any math function."
    - "No prior spec covers __qualname__ for any math function."
    - "math.floor.__module__ == 'math' — C builtin in the math module."
    - "math.ceil.__module__ == 'math' — C builtin in the math module."
    - "math.sqrt.__module__ == 'math' — C builtin in the math module."
    - "math.log.__module__ == 'math' — C builtin in the math module."
    - "math.gcd.__module__ == 'math' — C builtin in the math module."
    - "math.isfinite.__module__ == 'math' — C builtin in the math module."
    - "math.floor.__qualname__ == 'floor' — top-level builtin qualname equals __name__."
    - "math.ceil.__qualname__ == 'ceil' — top-level builtin qualname equals __name__."
    - "math.sqrt.__qualname__ == 'sqrt' — top-level builtin qualname equals __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# math function __qualname__ attributes
#
# For builtin functions at module level, __qualname__ == __name__. No prior
# math spec checks __qualname__ for any function. These confirm that the
# math module's C builtins follow the same qualname convention as pure-Python
# top-level functions.
# ---------------------------------------------------------------------------

invariant math_extra20.floor.qualname:
  description: "math.floor.__qualname__ == 'floor' — builtin qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: floor.__qualname__.__eq__
  args: ["floor"]
  expected: true

invariant math_extra20.ceil.qualname:
  description: "math.ceil.__qualname__ == 'ceil' — builtin qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: ceil.__qualname__.__eq__
  args: ["ceil"]
  expected: true

invariant math_extra20.sqrt.qualname:
  description: "math.sqrt.__qualname__ == 'sqrt' — builtin qualname equals name"
  category: function_identity
  kind: python_call_eq
  function: sqrt.__qualname__.__eq__
  args: ["sqrt"]
  expected: true

# ---------------------------------------------------------------------------
# math function __module__ table
#
# No prior spec covers __module__ for any math function. All math module
# builtins have __module__ == 'math'. This table anchors that invariant
# across a representative set of arithmetic, rounding, and predicate functions.
# ---------------------------------------------------------------------------

table math_extra20.function_modules:
  description: "__module__ == 'math' for representative math builtin functions"
  kind: python_call_eq
  category: function_metadata
  id_prefix: mmod

  columns: [id, function, args, expected]
  rows:
    - [floor,    floor.__module__.__eq__,    ["math"], true]
    - [ceil,     ceil.__module__.__eq__,     ["math"], true]
    - [sqrt,     sqrt.__module__.__eq__,     ["math"], true]
    - [log,      log.__module__.__eq__,      ["math"], true]
    - [gcd,      gcd.__module__.__eq__,      ["math"], true]
    - [isfinite, isfinite.__module__.__eq__, ["math"], true]
    - [isinf,    isinf.__module__.__eq__,    ["math"], true]
    - [isnan,    isnan.__module__.__eq__,    ["math"], true]
    - [factorial, factorial.__module__.__eq__, ["math"], true]
    - [fabs,     fabs.__module__.__eq__,     ["math"], true]
