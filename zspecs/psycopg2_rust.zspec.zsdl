spec: psycopg2_rust
version: ">=3.9"
backend: rust_module(psycopg2_rust)

docs: https://www.psycopg.org/docs/

provenance:
  derived_from:
    - "https://www.psycopg.org/docs/ — psycopg2 documentation"
  not_derived_from:
    - "psycopg2 source: psycopg2/__init__.py"
  notes:
    - "psycopg2 is the PostgreSQL adapter for Python."
    - "psycopg2.__version__ is a non-empty string."
    - "psycopg2.extensions.STATUS_READY is an int."
    - "psycopg2.extensions.ISOLATION_LEVEL_DEFAULT == None."
    - "psycopg2.Error is a subclass of Exception."
    - "Expose psycopg2_version_nonempty() -> bool: len(psycopg2.__version__) > 0."
    - "Expose psycopg2_has_extensions() -> bool: hasattr(psycopg2, 'extensions')."
    - "Expose psycopg2_status_ready_positive() -> bool: psycopg2.extensions.STATUS_READY > 0."
    - "All test vectors verified against psycopg2 2.9.10."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# psycopg2_version_nonempty — version non-empty
invariant psycopg2_rust.version.nonempty:
  description: "psycopg2.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: psycopg2_version_nonempty
  args: []
  expected: true

# psycopg2_has_extensions — extensions module present
invariant psycopg2_rust.module.has_extensions:
  description: "psycopg2.extensions is available"
  category: module
  kind: python_call_eq
  function: psycopg2_has_extensions
  args: []
  expected: true

# psycopg2_status_ready_positive — STATUS_READY > 0
invariant psycopg2_rust.extensions.status_ready:
  description: "psycopg2.extensions.STATUS_READY > 0"
  category: extensions
  kind: python_call_eq
  function: psycopg2_status_ready_positive
  args: []
  expected: true

