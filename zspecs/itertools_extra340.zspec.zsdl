spec: itertools_extra340
version: ">=3.0"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.__name__ == 'itertools' — the module name attribute."
    - "itertools.__package__ == '' — itertools is a built-in C extension, not a package; __package__ is the empty string."
    - "itertools.__spec__.name == 'itertools' — the ModuleSpec name matches the module name."
    - "itertools.__doc__.__class__.__name__ == 'str' — the module docstring is a plain Python string."
    - "itertools.__doc__.__len__() == 1386 — docstring length verified on Python 3.14 macOS."
    - "itertools.__loader__.__class__.__name__ == 'type' — the loader for a built-in C extension is the module type itself."
    - "itertools has no __all__ attribute — confirmed on Python 3.14; hasattr(itertools, '__all__') is False."
    - "itertools.chain.__module__ == 'itertools' — chain is defined in the itertools C extension."
    - "itertools.count.__module__ == 'itertools' — count is defined in the itertools C extension."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity attributes: __name__, __package__, __spec__.name
# ---------------------------------------------------------------------------

invariant itertools_extra340.module.name:
  description: "itertools.__name__ == 'itertools'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra340.module.package:
  description: "itertools.__package__ == '' — itertools is not a package"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra340.module.spec_name:
  description: "itertools.__spec__.name == 'itertools'"
  category: module_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["itertools"]
  expected: true

# ---------------------------------------------------------------------------
# __doc__ — class name and length
# ---------------------------------------------------------------------------

invariant itertools_extra340.doc.class_name:
  description: "itertools.__doc__.__class__.__name__ == 'str'"
  category: doc
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra340.doc.length:
  description: "itertools.__doc__.__len__() == 1386"
  category: doc
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 1386

# ---------------------------------------------------------------------------
# __loader__ — class name
#
# itertools is a built-in C extension; its __loader__ is the built-in module
# loader whose __class__.__name__ is 'type'.
# ---------------------------------------------------------------------------

invariant itertools_extra340.loader.class_name:
  description: "itertools.__loader__.__class__.__name__ == 'type'"
  category: loader
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# chain and count — __module__ checks
# ---------------------------------------------------------------------------

invariant itertools_extra340.chain.module:
  description: "itertools.chain.__module__ == 'itertools'"
  category: type_modules
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra340.count.module:
  description: "itertools.count.__module__ == 'itertools'"
  category: type_modules
  kind: python_call_eq
  function: count.__module__.__eq__
  args: ["itertools"]
  expected: true
