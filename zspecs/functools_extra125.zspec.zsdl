spec: functools_extra125
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra124.zspec.zsdl."
    - "This spec covers: functools.__all__ element access and membership not yet covered — __all__[0]='update_wrapper'(14), __all__[7]='lru_cache'(9), __all__[8]='reduce'(6), __all__[14]='Placeholder'(11); __all__.__contains__('lru_cache')=True, __all__.__contains__('reduce')=True, __all__.__contains__('map')=False; __all__.index('lru_cache')=7, __all__.index('reduce')=8; wave 271."
    - "Prior spec extra36 covered __all__.__len__()==15 and __all__.__class__.__name__.__len__()==4. New here: element access, membership tests, and index lookups."
    - "functools.__all__[0] == 'update_wrapper' (len 14). Verified with Python 3.14.3."
    - "functools.__all__[7] == 'lru_cache' (len 9). Verified with Python 3.14.3."
    - "functools.__all__[8] == 'reduce' (len 6). Verified with Python 3.14.3."
    - "functools.__all__[14] == 'Placeholder' (len 11). Verified with Python 3.14.3."
    - "functools.__all__.__contains__('lru_cache') == True. Verified with Python 3.14.3."
    - "functools.__all__.__contains__('reduce') == True. Verified with Python 3.14.3."
    - "functools.__all__.__contains__('map') == False — map is a built-in not in functools. Verified with Python 3.14.3."
    - "functools.__all__.index('lru_cache') == 7. Verified with Python 3.14.3."
    - "functools.__all__.index('reduce') == 8. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.__all__ element access by index
#
# Wave 271 theme: functools.__all__ is a list of 15 strings (extra36 established
# this). New here: individual element access. The list is:
# [0]='update_wrapper'(14), [1]='wraps'(5), [2]='WRAPPER_ASSIGNMENTS'(19),
# [3]='WRAPPER_UPDATES'(15), [4]='total_ordering'(14), [5]='cache'(5),
# [6]='cmp_to_key'(10), [7]='lru_cache'(9), [8]='reduce'(6), [9]='partial'(7),
# [10]='partialmethod'(13), [11]='singledispatch'(14), [12]='singledispatchmethod'(20),
# [13]='cached_property'(15), [14]='Placeholder'(11).
# Notable: [0]='update_wrapper'(14) and [4]='total_ordering'(14) share the same
# length. The first element 'update_wrapper' is what @wraps ultimately delegates
# to. The last element 'Placeholder' (14, added in Python 3.14) has 11 chars.
#
# __all__[0]  == 'update_wrapper'  (len 14)
# __all__[7]  == 'lru_cache'       (len 9)
# __all__[8]  == 'reduce'          (len 6)
# __all__[14] == 'Placeholder'     (len 11)
#
# New to extra125.
# ---------------------------------------------------------------------------

table functools_extra125.all_element_access:
  description: "functools.__all__ element access: [0]='update_wrapper'(14), [7]='lru_cache'(9), [8]='reduce'(6), [14]='Placeholder'(11); prior extra36 covered __len__=15 and class name len=4; wave 271; new to extra125"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsalea125

  columns: [id, function, args, expected, description]
  rows:
    - [all_elem0_eq,
       "__all__.__getitem__",
       [0],
       "update_wrapper",
       "functools.__all__[0] == 'update_wrapper' — the first exported name; @wraps calls update_wrapper internally; 14 chars; list.__getitem__(0) returns 'update_wrapper'; new to extra125"]
    - [all_elem0_len,
       "__all__.__getitem__(0).__len__",
       [],
       14,
       "functools.__all__[0].__len__() == 14 — 'update_wrapper' has 14 chars; shares this length with __all__[4] ('total_ordering') and __all__[11] ('singledispatch'); str.__len__() returns 14; new to extra125"]
    - [all_elem7_eq,
       "__all__.__getitem__",
       [7],
       "lru_cache",
       "functools.__all__[7] == 'lru_cache' — the LRU memoization decorator; added in Python 3.2; 9 chars; at index 7 in the __all__ list; list.__getitem__(7) returns 'lru_cache'; new to extra125"]
    - [all_elem7_len,
       "__all__.__getitem__(7).__len__",
       [],
       9,
       "functools.__all__[7].__len__() == 9 — 'lru_cache' has 9 chars: l-r-u-_-c-a-c-h-e; str.__len__() returns 9; new to extra125"]
    - [all_elem8_eq,
       "__all__.__getitem__",
       [8],
       "reduce",
       "functools.__all__[8] == 'reduce' — the left-folding reduction function; originally from Python 2 built-ins; 6 chars; at index 8 in __all__; list.__getitem__(8) returns 'reduce'; new to extra125"]
    - [all_elem14_eq,
       "__all__.__getitem__",
       [14],
       "Placeholder",
       "functools.__all__[14] == 'Placeholder' — added in Python 3.14 as a sentinel for partial(); 11 chars; the last element in __all__ (index 14); list.__getitem__(14) returns 'Placeholder'; new to extra125"]
    - [all_elem14_len,
       "__all__.__getitem__(14).__len__",
       [],
       11,
       "functools.__all__[14].__len__() == 11 — 'Placeholder' has 11 chars: P-l-a-c-e-h-o-l-d-e-r; the last __all__ element; Python 3.14 addition; str.__len__() returns 11; new to extra125"]

# ---------------------------------------------------------------------------
# Table 2: functools.__all__ membership tests
#
# Wave 271 theme: functools.__all__ is a list so __contains__ performs a
# linear membership test. 'lru_cache' and 'reduce' are both present.
# 'map' is NOT present — map() is a Python built-in, not part of functools.
# 'filter' and 'zip' are likewise built-ins. This distinctly characterises
# functools as a module of higher-order function tools, not a replacement for
# built-ins. __contains__ on a list returns True/False. None of these
# membership tests have been recorded in prior functools specs.
#
# __all__.__contains__('lru_cache') == True
# __all__.__contains__('reduce')    == True
# __all__.__contains__('map')       == False
#
# New to extra125.
# ---------------------------------------------------------------------------

table functools_extra125.all_membership:
  description: "functools.__all__ membership: 'lru_cache' in __all__=True, 'reduce' in __all__=True, 'map' in __all__=False (map is a built-in not in functools); list.__contains__; wave 271; new to extra125"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsalmem125

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_lru_cache,
       "__all__.__contains__",
       ["lru_cache"],
       true,
       "functools.__all__.__contains__('lru_cache') == True — lru_cache is exported by functools; it provides LRU memoization via a C-level C implementation; list.__contains__('lru_cache') returns True; new to extra125"]
    - [all_contains_reduce,
       "__all__.__contains__",
       ["reduce"],
       true,
       "functools.__all__.__contains__('reduce') == True — reduce is exported by functools; it performs left-folding reduction over an iterable; list.__contains__('reduce') returns True; new to extra125"]
    - [all_contains_map_false,
       "__all__.__contains__",
       ["map"],
       false,
       "functools.__all__.__contains__('map') == False — map() is a Python built-in, not part of functools; functools provides higher-order tools but does not re-export built-ins; list.__contains__('map') returns False; new to extra125"]
    - [all_contains_cache,
       "__all__.__contains__",
       ["cache"],
       true,
       "functools.__all__.__contains__('cache') == True — cache (unbounded LRU) was added in Python 3.9; it is exported by functools; list.__contains__('cache') returns True; new to extra125"]
    - [all_contains_filter_false,
       "__all__.__contains__",
       ["filter"],
       false,
       "functools.__all__.__contains__('filter') == False — filter() is a Python built-in, not part of functools; like map(), it is not re-exported; list.__contains__('filter') returns False; new to extra125"]

# ---------------------------------------------------------------------------
# Table 3: functools.__all__ index lookups
#
# Wave 271 theme: list.index() returns the position of the first occurrence
# of a value. 'lru_cache' is at index 7 and 'reduce' is at index 8 — they
# are adjacent in __all__. These are both legacy high-level tools: lru_cache
# is C-accelerated memoization; reduce is the functional fold. Their adjacency
# reflects historical grouping. __all__.index('lru_cache') == 7 and
# __all__.index('reduce') == 8 have not been recorded in prior functools specs.
#
# __all__.index('lru_cache') == 7
# __all__.index('reduce')    == 8
# __all__.__getitem__(8).__len__() == 6
#
# New to extra125.
# ---------------------------------------------------------------------------

table functools_extra125.all_index_lookups:
  description: "functools.__all__ index lookups: index('lru_cache')=7, index('reduce')=8 (adjacent); 'reduce' len=6; lru_cache and reduce are adjacent legacy higher-order tools; wave 271; new to extra125"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsalidx125

  columns: [id, function, args, expected, description]
  rows:
    - [all_index_lru_cache,
       "__all__.index",
       ["lru_cache"],
       7,
       "functools.__all__.index('lru_cache') == 7 — lru_cache is the 8th exported name (0-indexed position 7); list.index('lru_cache') returns 7; new to extra125"]
    - [all_index_reduce,
       "__all__.index",
       ["reduce"],
       8,
       "functools.__all__.index('reduce') == 8 — reduce is the 9th exported name (0-indexed position 8); adjacent to lru_cache (7); list.index('reduce') returns 8; new to extra125"]
    - [all_elem8_len,
       "__all__.__getitem__(8).__len__",
       [],
       6,
       "functools.__all__[8].__len__() == 6 — 'reduce' has 6 chars: r-e-d-u-c-e; shorter than 'lru_cache' (9); str.__len__() returns 6; new to extra125"]
    - [all_count_lru_cache,
       "__all__.count",
       ["lru_cache"],
       1,
       "functools.__all__.count('lru_cache') == 1 — 'lru_cache' appears exactly once in __all__; all __all__ elements are distinct; list.count('lru_cache') returns 1; new to extra125"]
    - [all_count_map,
       "__all__.count",
       ["map"],
       0,
       "functools.__all__.count('map') == 0 — 'map' does not appear in __all__; it is a built-in; list.count('map') returns 0; new to extra125"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra125
# ---------------------------------------------------------------------------

invariant functools_extra125.all_elem0_eq:
  description: "functools.__all__[0] == 'update_wrapper' — first exported name; 14 chars; @wraps delegates to it; wave 271; new to extra125"
  kind: python_call_eq
  function: "__all__.__getitem__"
  args: [0]
  expected: "update_wrapper"

invariant functools_extra125.all_contains_lru_cache:
  description: "functools.__all__.__contains__('lru_cache') == True — lru_cache is exported by functools; C-accelerated LRU memoization; wave 271; new to extra125"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["lru_cache"]
  expected: true

invariant functools_extra125.all_contains_reduce:
  description: "functools.__all__.__contains__('reduce') == True — reduce is exported by functools; left-fold over iterables; wave 271; new to extra125"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["reduce"]
  expected: true

invariant functools_extra125.all_index_lru_cache:
  description: "functools.__all__.index('lru_cache') == 7 — lru_cache is at index 7 in __all__; adjacent to reduce (index 8); wave 271; new to extra125"
  kind: python_call_eq
  function: __all__.index
  args: ["lru_cache"]
  expected: 7

invariant functools_extra125.all_elem14_eq:
  description: "functools.__all__[14] == 'Placeholder' — last exported name; Python 3.14 addition; 11 chars; sentinel for partial(); wave 271; new to extra125"
  kind: python_call_eq
  function: "__all__.__getitem__"
  args: [14]
  expected: "Placeholder"
