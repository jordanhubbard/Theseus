spec: asyncio_extra601
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio top-level coroutine function identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__, __module__, and __class__.__name__ identity for asyncio top-level coroutine functions"
  created_at: "2026-04-12T00:00:00Z"

table asyncio_extra601.as601qn:
  id_prefix: as601qn

  columns: [id, function, args, expected]
  rows:
    - [as601qn01, asyncio.sleep.__qualname__.__eq__, ["sleep"], true]
    - [as601qn02, asyncio.sleep.__module__.__eq__, ["asyncio.tasks"], true]
    - [as601qn03, asyncio.gather.__qualname__.__eq__, ["gather"], true]
    - [as601qn04, asyncio.gather.__module__.__eq__, ["asyncio.tasks"], true]
    - [as601qn05, asyncio.wait.__qualname__.__eq__, ["wait"], true]
    - [as601qn06, asyncio.wait_for.__qualname__.__eq__, ["wait_for"], true]
    - [as601qn07, asyncio.shield.__qualname__.__eq__, ["shield"], true]
    - [as601qn08, asyncio.ensure_future.__qualname__.__eq__, ["ensure_future"], true]
    - [as601qn09, asyncio.run.__qualname__.__eq__, ["run"], true]
    - [as601qn10, asyncio.create_task.__qualname__.__eq__, ["create_task"], true]
    - [as601qn11, asyncio.current_task.__qualname__.__eq__, ["current_task"], true]
    - [as601qn12, asyncio.all_tasks.__qualname__.__eq__, ["all_tasks"], true]

table asyncio_extra601.as601fn:
  id_prefix: as601fn

  columns: [id, function, args, expected]
  rows:
    - [as601fn01, asyncio.sleep.__class__.__name__.__eq__, ["function"], true]
    - [as601fn02, asyncio.gather.__class__.__name__.__eq__, ["function"], true]
