    - [tpe_submit_cross,   "ThreadPoolExecutor.__dict__.__contains__", ["submit"], true, "ThreadPoolExecutor.__dict__.__contains__('submit') == True — cross-check; verified with Python 3.14.3"]
    - [exe_map_cross,      "Executor.__dict__.__contains__", ["map"],     true, "Executor.__dict__.__contains__('map') == True — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra87
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra87.ThreadPoolExecutor_has_submit:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit') returns True — submit() is defined directly on ThreadPoolExecutor, not just inherited; it schedules work to the thread pool; NEW in extra87: first standalone __dict__ membership invariant for ThreadPoolExecutor.submit in cfexecdictmem87 namespace; wave 250; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: "ThreadPoolExecutor.__dict__.__contains__"
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra87.ThreadPoolExecutor_no_map:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map') returns False — map() is not overridden in ThreadPoolExecutor; it is inherited from the Executor base class; ProcessPoolExecutor does override map() but ThreadPoolExecutor does not; NEW in extra87: first standalone __dict__ non-membership invariant for ThreadPoolExecutor.map in cfexecdictmem87 namespace; wave 250; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: "ThreadPoolExecutor.__dict__.__contains__"
  args: ["map"]
  expected: false

invariant concurrent_futures_extra87.Executor_has_context_manager:
  description: "concurrent.futures.Executor.__dict__.__contains__('__enter__') returns True — Executor implements the context manager protocol via __enter__ and __exit__; this allows executors to be used as 'with' statement context managers; NEW in extra87: first standalone __dict__ context manager membership invariant for Executor in cfexecdictmem87 namespace; wave 250; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: "Executor.__dict__.__contains__"
  args: ["__enter__"]
  expected: true

invariant concurrent_futures_extra87.Future_has_result:
  description: "concurrent.futures.Future.__dict__.__contains__('result') returns True — result() is defined directly on Future; it blocks and returns the result of the call that the Future represents, or raises an exception; NEW in extra87: first standalone __dict__ membership invariant for Future.result in cfexecdictmem87 namespace; wave 250; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: "Future.__dict__.__contains__"
  args: ["result"]
  expected: true

invariant concurrent_futures_extra87.ProcessPoolExecutor_has_map:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map') returns True — ProcessPoolExecutor overrides Executor.map() (unlike ThreadPoolExecutor which inherits it unchanged); this override allows process pool-specific batching behavior; NEW in extra87: first standalone __dict__ map-override membership invariant for ProcessPoolExecutor in cfexecdictmem87 namespace; wave 250; verified with Python 3.14.3"
  category: class_dict
  kind: python_call_eq
  function: "ProcessPoolExecutor.__dict__.__contains__"
  args: ["map"]
  expected: true
