spec: concurrent_futures_extra87
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra86

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra86.zspec.zsdl."
    - "This spec covers: wave 250 theme — concurrent.futures executor __dict__ membership. NEW in extra87: ThreadPoolExecutor.__dict__.__contains__('submit')==True; ThreadPoolExecutor.__dict__.__contains__('shutdown')==True; ThreadPoolExecutor.__dict__.__contains__('map')==False (map is inherited from Executor, not defined on TPE); ProcessPoolExecutor.__dict__.__contains__('submit')==True; ProcessPoolExecutor.__dict__.__contains__('shutdown')==True; ProcessPoolExecutor.__dict__.__contains__('map')==True (PPE overrides map); Executor.__dict__.__contains__('map')==True; Executor.__dict__.__contains__('submit')==True; Executor.__dict__.__contains__('__enter__')==True; Executor.__dict__.__contains__('__exit__')==True; Future.__dict__.__contains__('result')==True; Future.__dict__.__contains__('done')==True; Future.__dict__.__contains__('cancel')==True; Future.__dict__.__contains__('exception')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit') == True. submit is defined directly on ThreadPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown') == True. shutdown is defined directly on ThreadPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map') == False. map is inherited from Executor; not overridden in ThreadPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('submit') == True. submit is defined directly on ProcessPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('shutdown') == True. shutdown is defined directly on ProcessPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map') == True. map is overridden in ProcessPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('map') == True. map is defined on the base Executor class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('submit') == True. submit is defined on Executor (not abstract in Python 3.14.3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('__enter__') == True. Executor implements the context manager protocol. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('__exit__') == True. Executor implements the context manager protocol. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('result') == True. result() is defined on Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('done') == True. done() is defined on Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('cancel') == True. cancel() is defined on Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('exception') == True. exception() is defined on Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures ThreadPoolExecutor __dict__ membership — extra87
#
# Wave 250 theme: concurrent.futures executor __dict__ membership.
#
# ThreadPoolExecutor.__dict__.__contains__('submit') == True
# ThreadPoolExecutor.__dict__.__contains__('shutdown') == True
# ThreadPoolExecutor.__dict__.__contains__('map') == False  (inherited from Executor)
# ---------------------------------------------------------------------------

table concurrent_futures_extra87.ThreadPoolExecutor_dict_membership:
  description: "concurrent.futures ThreadPoolExecutor __dict__ membership checks in cfexecdictmem87 namespace — wave 250 theme: concurrent.futures executor __dict__ membership; ThreadPoolExecutor.__dict__.__contains__('submit')==True (defined directly on TPE); ThreadPoolExecutor.__dict__.__contains__('shutdown')==True (defined directly on TPE); ThreadPoolExecutor.__dict__.__contains__('map')==False (inherited from Executor, not overridden in TPE); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_dict
  id_prefix: cfexecdictmem87

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_has_submit,   "ThreadPoolExecutor.__dict__.__contains__", ["submit"],   true,  "ThreadPoolExecutor.__dict__.__contains__('submit') == True — defined directly on TPE; verified with Python 3.14.3"]
    - [tpe_has_shutdown, "ThreadPoolExecutor.__dict__.__contains__", ["shutdown"], true,  "ThreadPoolExecutor.__dict__.__contains__('shutdown') == True — defined directly on TPE; verified with Python 3.14.3"]
    - [tpe_no_map,       "ThreadPoolExecutor.__dict__.__contains__", ["map"],      false, "ThreadPoolExecutor.__dict__.__contains__('map') == False — map is inherited from Executor, not overridden in TPE; verified with Python 3.14.3"]

