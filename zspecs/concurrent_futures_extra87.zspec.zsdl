table concurrent_futures_extra87.Future_dict_membership:
  description: "concurrent.futures Future __dict__ membership checks in cfexecdictmem87 namespace — wave 250 theme: concurrent.futures executor __dict__ membership; Future.__dict__.__contains__('result')==True; Future.__dict__.__contains__('done')==True; Future.__dict__.__contains__('cancel')==True; Future.__dict__.__contains__('exception')==True; ThreadPoolExecutor.__dict__.__contains__('submit')==True (cross-check); Executor.__dict__.__contains__('map')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_dict
  id_prefix: cfexecdictmem87c

  columns: [id, function, args, expected, description]
  rows:
    - [fut_has_result,     "Future.__dict__.__contains__", ["result"],    true, "Future.__dict__.__contains__('result') == True — result() defined on Future; verified with Python 3.14.3"]
    - [fut_has_done,       "Future.__dict__.__contains__", ["done"],      true, "Future.__dict__.__contains__('done') == True — done() defined on Future; verified with Python 3.14.3"]
    - [fut_has_cancel,     "Future.__dict__.__contains__", ["cancel"],    true, "Future.__dict__.__contains__('cancel') == True — cancel() defined on Future; verified with Python 3.14.3"]
