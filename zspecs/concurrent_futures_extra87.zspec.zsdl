table concurrent_futures_extra87.ProcessPoolExecutor_dict_membership:
  description: "concurrent.futures ProcessPoolExecutor __dict__ membership checks in cfexecdictmem87 namespace — wave 250 theme: concurrent.futures executor __dict__ membership; ProcessPoolExecutor.__dict__.__contains__('submit')==True (defined directly on PPE); ProcessPoolExecutor.__dict__.__contains__('shutdown')==True (defined directly on PPE); ProcessPoolExecutor.__dict__.__contains__('map')==True (PPE overrides Executor.map); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_dict
  id_prefix: cfexecdictmem87a

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_has_submit,   "ProcessPoolExecutor.__dict__.__contains__", ["submit"],   true, "ProcessPoolExecutor.__dict__.__contains__('submit') == True — defined directly on PPE; verified with Python 3.14.3"]
    - [ppe_has_shutdown, "ProcessPoolExecutor.__dict__.__contains__", ["shutdown"], true, "ProcessPoolExecutor.__dict__.__contains__('shutdown') == True — defined directly on PPE; verified with Python 3.14.3"]
    - [ppe_has_map,      "ProcessPoolExecutor.__dict__.__contains__", ["map"],      true, "ProcessPoolExecutor.__dict__.__contains__('map') == True — PPE overrides Executor.map; verified with Python 3.14.3"]

