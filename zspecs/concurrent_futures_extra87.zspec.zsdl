table concurrent_futures_extra87.Executor_dict_membership:
  description: "concurrent.futures Executor __dict__ membership checks in cfexecdictmem87 namespace — wave 250 theme: concurrent.futures executor __dict__ membership; Executor.__dict__.__contains__('map')==True (defined on Executor base class); Executor.__dict__.__contains__('submit')==True (defined on Executor in Python 3.14.3); Executor.__dict__.__contains__('__enter__')==True (context manager protocol); Executor.__dict__.__contains__('__exit__')==True (context manager protocol); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_dict
  id_prefix: cfexecdictmem87b

  columns: [id, function, args, expected, description]
  rows:
    - [exe_has_map,     "Executor.__dict__.__contains__", ["map"],      true, "Executor.__dict__.__contains__('map') == True — defined on Executor base class; verified with Python 3.14.3"]
    - [exe_has_submit,  "Executor.__dict__.__contains__", ["submit"],   true, "Executor.__dict__.__contains__('submit') == True — defined on Executor in Python 3.14.3; verified with Python 3.14.3"]
    - [exe_has_enter,   "Executor.__dict__.__contains__", ["__enter__"],true, "Executor.__dict__.__contains__('__enter__') == True — context manager protocol; verified with Python 3.14.3"]
    - [exe_has_exit,    "Executor.__dict__.__contains__", ["__exit__"], true, "Executor.__dict__.__contains__('__exit__') == True — context manager protocol; verified with Python 3.14.3"]

