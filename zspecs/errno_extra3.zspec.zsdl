spec: errno_extra3
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/errno.html"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "Extends errno.zspec.zsdl, errno_extra.zspec.zsdl, and errno_extra2.zspec.zsdl."
    - "errno.zspec.zsdl covers: POSIX constant values (EPERM=1, ENOENT=2, ESRCH=3, EINTR=4, EIO=5, EBADF=9, ENOMEM=12, EACCES=13, EINVAL=22); ENOTSUP type; errorcode type and spot lookups for keys 1/2/22."
    - "errno_extra.zspec.zsdl covers: ENOENT/EACCES/EEXIST/EPERM class names and values; errorcode class name; errorcode[2]=='ENOENT'."
    - "errno_extra2.zspec.zsdl covers: class names for EPERM/ENOENT/ESRCH/EINTR/EIO/ENXIO/EACCES/EEXIST/ENOTDIR/EISDIR; errorcode class name and len>=50; EPERM/ENOENT/EACCES positivity."
    - "This spec adds: class name checks for EBADF, ENOMEM, EINVAL (not yet covered by prior specs)."
    - "It also adds errorcode reverse-lookups for keys 9 (EBADF) and 12 (ENOMEM), and __contains__ checks for those keys."
    - "errno.EBADF.__class__.__name__ == 'int' — EBADF (bad file descriptor) is a plain int."
    - "errno.ENOMEM.__class__.__name__ == 'int' — ENOMEM (out of memory) is a plain int."
    - "errno.EINVAL.__class__.__name__ == 'int' — EINVAL (invalid argument) is a plain int."
    - "errno.errorcode[9] == 'EBADF' — POSIX standard reverse-lookup for errno 9."
    - "errno.errorcode[12] == 'ENOMEM' — POSIX standard reverse-lookup for errno 12."
    - "9 in errno.errorcode — key 9 is present in errorcode on all POSIX platforms."
    - "12 in errno.errorcode — key 12 is present in errorcode on all POSIX platforms."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "The errno module exposes read-only integer constants and the errorcode dict. No functions raise exceptions during normal use."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks — EBADF, ENOMEM, EINVAL not yet covered by prior specs
#
# errno_extra2 has: EPERM/ENOENT/ESRCH/EINTR/EIO/ENXIO/EACCES/EEXIST/ENOTDIR/EISDIR
# New here: EBADF (bad file descriptor), ENOMEM (out of memory), EINVAL (invalid arg)
# ---------------------------------------------------------------------------

table errno_extra3.constant_class_names:
  description: "EBADF, ENOMEM, and EINVAL are plain int objects — __class__.__name__ == 'int'"
  kind: python_call_eq
  category: constant_types
  id_prefix: cls

  columns: [id, function, args, expected]
  rows:
    - [EBADF,  EBADF.__class__.__name__.__eq__,  ["int"], true]
    - [ENOMEM, ENOMEM.__class__.__name__.__eq__, ["int"], true]
    - [EINVAL, EINVAL.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# errorcode reverse-lookups for errno 9 (EBADF) and 12 (ENOMEM)
# errno.zspec.zsdl covers keys 1, 2, 22; errno_extra covers key 2 again.
# New here: keys 9 and 12.
# ---------------------------------------------------------------------------

invariant errno_extra3.errorcode.ebadf_lookup:
  description: "errno.errorcode[9] == 'EBADF' — reverse-lookup of errno 9 (bad file descriptor)"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [9]
  expected: "EBADF"

invariant errno_extra3.errorcode.enomem_lookup:
  description: "errno.errorcode[12] == 'ENOMEM' — reverse-lookup of errno 12 (out of memory)"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [12]
  expected: "ENOMEM"

# ---------------------------------------------------------------------------
# errorcode __contains__ checks for EBADF and ENOMEM keys
# errno_extra covers key 2 (__contains__); new here: keys 9 and 12.
# ---------------------------------------------------------------------------

invariant errno_extra3.errorcode.contains_ebadf_key:
  description: "9 in errno.errorcode — EBADF key is present on all POSIX platforms"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [9]
  expected: true

invariant errno_extra3.errorcode.contains_enomem_key:
  description: "12 in errno.errorcode — ENOMEM key is present on all POSIX platforms"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [12]
  expected: true
