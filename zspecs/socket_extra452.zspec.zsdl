spec: socket_extra452
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket address family, socket kind, and protocol constants"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "AF_INET and AF_INET6 are AddressFamily enum members; numeric values are platform-specific"
    - "IPPROTO_TCP == 6 and IPPROTO_UDP == 17 are IANA-assigned and stable across all platforms"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra452.address_family_types:
  description: "AF_* constants are AddressFamily enum members"
  kind: python_call_eq
  category: types
  id_prefix: aft

  columns: [id, function, args, expected]
  rows:
    - [aft001, socket.AF_INET.__class__.__name__.__eq__,  ["AddressFamily"], true]
    - [aft002, socket.AF_INET6.__class__.__name__.__eq__, ["AddressFamily"], true]

table socket_extra452.socket_kind_types:
  description: "SOCK_* constants are SocketKind enum members"
  kind: python_call_eq
  category: types
  id_prefix: skt

  columns: [id, function, args, expected]
  rows:
    - [skt001, socket.SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"], true]
    - [skt002, socket.SOCK_DGRAM.__class__.__name__.__eq__,  ["SocketKind"], true]
    - [skt003, socket.SOCK_RAW.__class__.__name__.__eq__,    ["SocketKind"], true]

table socket_extra452.enum_class_identity:
  description: "AddressFamily and SocketKind enum class identity"
  kind: python_call_eq
  category: identity
  id_prefix: eci

  columns: [id, function, args, expected]
  rows:
    - [eci001, socket.AddressFamily.__name__.__eq__,   ["AddressFamily"], true]
    - [eci002, socket.AddressFamily.__module__.__eq__, ["socket"],        true]
    - [eci003, socket.SocketKind.__name__.__eq__,      ["SocketKind"],    true]
    - [eci004, socket.SocketKind.__module__.__eq__,    ["socket"],        true]

table socket_extra452.protocol_constants:
  description: "IPPROTO_* constants have IANA-assigned values"
  kind: python_call_eq
  category: behavior
  id_prefix: ipc

  columns: [id, function, args, expected]
  rows:
    - [ipc001, socket.IPPROTO_TCP.__eq__, [6],  true]
    - [ipc002, socket.IPPROTO_UDP.__eq__, [17], true]
