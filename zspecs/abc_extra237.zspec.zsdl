spec: abc_extra237
version: ">=3.4"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers abc.ABC.__init_subclass__ and abc.ABC.__subclasshook__ identity."
    - "ABC.__init_subclass__ is a builtin_function_or_method (C extension bound to the ABCMeta class)."
    - "ABC.__init_subclass__.__name__ == '__init_subclass__' — 17 characters."
    - "ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' — 21 characters."
    - "ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method'."
    - "ABC.__subclasshook__ is also a builtin_function_or_method."
    - "ABC.__subclasshook__.__name__ == '__subclasshook__' — 16 characters."
    - "ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' — 20 characters."
    - "ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABC.__init_subclass__ identity contracts
#
# __init_subclass__ is a builtin_function_or_method bound to ABC's metaclass.
# Covers __name__, __qualname__, __class__.__name__.
# ---------------------------------------------------------------------------

table abc_extra237.init_subclass_identity:
  description: "abc.ABC.__init_subclass__ identity: name, qualname, class; new to extra237"
  kind: python_call_eq
  category: method_identity
  id_prefix: abc237iss

  columns: [id, function, args, expected, description]
  rows:
    - [iss_name_eq,
       ABC.__init_subclass__.__name__.__eq__,
       ["__init_subclass__"],
       true,
       "abc.ABC.__init_subclass__.__name__.__eq__('__init_subclass__') == True — builtin carries its simple name; new to extra237"]
    - [iss_qualname_eq,
       ABC.__init_subclass__.__qualname__.__eq__,
       ["ABC.__init_subclass__"],
       true,
       "abc.ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__') == True — qualname includes class prefix; new to extra237"]
    - [iss_class_name_eq,
       ABC.__init_subclass__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "abc.ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' — C extension builtin; new to extra237"]
    - [iss_name_len_17,
       ABC.__init_subclass__.__name__.__len__,
       [],
       17,
       "abc.ABC.__init_subclass__.__name__.__len__() == 17 — '__init_subclass__' has 17 characters; new to extra237"]
    - [iss_qualname_len_21,
       ABC.__init_subclass__.__qualname__.__len__,
       [],
       21,
       "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 — 'ABC.__init_subclass__' has 21 characters; new to extra237"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABC.__subclasshook__ identity contracts
#
# __subclasshook__ is a builtin_function_or_method bound to ABC's metaclass.
# Covers __name__, __qualname__, __class__.__name__.
# ---------------------------------------------------------------------------

table abc_extra237.subclasshook_identity:
  description: "abc.ABC.__subclasshook__ identity: name, qualname, class; new to extra237"
  kind: python_call_eq
  category: method_identity
  id_prefix: abc237ssh

  columns: [id, function, args, expected, description]
  rows:
    - [ssh_name_eq,
       ABC.__subclasshook__.__name__.__eq__,
       ["__subclasshook__"],
       true,
       "abc.ABC.__subclasshook__.__name__.__eq__('__subclasshook__') == True — builtin carries its simple name; new to extra237"]
    - [ssh_qualname_eq,
       ABC.__subclasshook__.__qualname__.__eq__,
       ["ABC.__subclasshook__"],
       true,
       "abc.ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__') == True — qualname includes class prefix; new to extra237"]
    - [ssh_class_name_eq,
       ABC.__subclasshook__.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "abc.ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C extension builtin; new to extra237"]
    - [ssh_name_len_16,
       ABC.__subclasshook__.__name__.__len__,
       [],
       16,
       "abc.ABC.__subclasshook__.__name__.__len__() == 16 — '__subclasshook__' has 16 characters; new to extra237"]
    - [ssh_qualname_len_20,
       ABC.__subclasshook__.__qualname__.__len__,
       [],
       20,
       "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 — 'ABC.__subclasshook__' has 20 characters; new to extra237"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra237
# ---------------------------------------------------------------------------

invariant abc_extra237.ABC.init_subclass_name:
  description: "abc.ABC.__init_subclass__.__name__ == '__init_subclass__'; new to extra237"
  category: method_identity
  kind: python_call_eq
  function: ABC.__init_subclass__.__name__.__eq__
  args: ["__init_subclass__"]
  expected: true

invariant abc_extra237.ABC.init_subclass_qualname:
  description: "abc.ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__'; new to extra237"
  category: method_identity
  kind: python_call_eq
  function: ABC.__init_subclass__.__qualname__.__eq__
  args: ["ABC.__init_subclass__"]
  expected: true

invariant abc_extra237.ABC.init_subclass_class:
  description: "abc.ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method'; new to extra237"
  category: method_identity
  kind: python_call_eq
  function: ABC.__init_subclass__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra237.ABC.init_subclass_name_len:
  description: "abc.ABC.__init_subclass__.__name__.__len__() == 17 — '__init_subclass__' has 17 characters; new to extra237"
  category: method_identity
  kind: python_call_eq
  function: ABC.__init_subclass__.__name__.__len__
  args: []
  expected: 17

invariant abc_extra237.ABC.init_subclass_qualname_len:
  description: "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 — 'ABC.__init_subclass__' has 21 characters; new to extra237"
  category: method_identity
  kind: python_call_eq
  function: ABC.__init_subclass__.__qualname__.__len__
  args: []
  expected: 21

invariant abc_extra237.ABC.subclasshook_name:
  description: "abc.ABC.__subclasshook__.__name__ == '__subclasshook__'; new to extra237"
  category: method_identity
  kind: python_call_eq
  function: ABC.__subclasshook__.__name__.__eq__
  args: ["__subclasshook__"]
  expected: true

invariant abc_extra237.ABC.subclasshook_qualname:
  description: "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__'; new to extra237"
  category: method_identity
  kind: python_call_eq
  function: ABC.__subclasshook__.__qualname__.__eq__
  args: ["ABC.__subclasshook__"]
  expected: true

