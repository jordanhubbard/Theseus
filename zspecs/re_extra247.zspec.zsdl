spec: re_extra247
version: ">=3.13"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Python 3.13 release notes — re.PatternError alias added"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern, Match, error class names, flag constants"
  notes:
    - "In Python 3.13+, re.error was renamed to re.PatternError; re.error is retained as an alias."
    - "In Python 3.14.3: re.error.__name__ == 'PatternError' and re.error.__qualname__ == 'PatternError'."
    - "re.PatternError is re.error — they are the exact same object (identity, not merely equality)."
    - "re.error.__module__ == 're' — the exception lives in the public re module namespace."
    - "re.error.__bases__[0].__name__ == 'Exception' — PatternError inherits directly from Exception."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.error identity — name and module
# In Python 3.14.3 the canonical name is 'PatternError'; re.error is an alias.
# ---------------------------------------------------------------------------

table re_extra247.error.identity:
  description: "re.error exception class identity attributes"
  kind: python_call_eq
  category: error_identity
  id_prefix: reerror247

  columns: [id, function, args, expected]
  rows:
    - [name,      error.__name__.__eq__,      ["PatternError"],  true]
    - [qualname,  error.__qualname__.__eq__,  ["PatternError"],  true]
    - [module,    error.__module__.__eq__,    ["re"],            true]

# ---------------------------------------------------------------------------
# re.error — standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra247.error.name:
  description: "re.error.__name__ == 'PatternError' in Python 3.13+"
  category: error_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra247.error.qualname:
  description: "re.error.__qualname__ == 'PatternError'"
  category: error_identity
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra247.error.module:
  description: "re.error.__module__ == 're'"
  category: error_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra247.error.base_is_Exception:
  description: "re.error.__bases__[0].__name__ == 'Exception'"
  category: error_hierarchy
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant re_extra247.error.class_is_type:
  description: "re.error is a class (type(re.error).__name__ == 'type')"
  category: error_identity
  kind: python_call_eq
  function: error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# re.PatternError identity — canonical name in Python 3.13+
# ---------------------------------------------------------------------------

table re_extra247.PatternError.identity:
  description: "re.PatternError exception class identity attributes"
  kind: python_call_eq
  category: error_identity
  id_prefix: reerror247

  columns: [id, function, args, expected]
  rows:
    - [name,      PatternError.__name__.__eq__,      ["PatternError"],  true]
    - [qualname,  PatternError.__qualname__.__eq__,  ["PatternError"],  true]
    - [module,    PatternError.__module__.__eq__,    ["re"],            true]

# ---------------------------------------------------------------------------
# re.PatternError — standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra247.PatternError.name:
  description: "re.PatternError.__name__ == 'PatternError'"
  category: error_identity
  kind: python_call_eq
  function: PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra247.PatternError.qualname:
  description: "re.PatternError.__qualname__ == 'PatternError'"
  category: error_identity
  kind: python_call_eq
  function: PatternError.__qualname__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra247.PatternError.module:
  description: "re.PatternError.__module__ == 're'"
  category: error_identity
  kind: python_call_eq
  function: PatternError.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra247.PatternError.base_is_Exception:
  description: "re.PatternError.__bases__[0].__name__ == 'Exception'"
  category: error_hierarchy
  kind: python_call_eq
  function: PatternError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Alias identity — re.PatternError and re.error share the same __name__
# Verifies that both aliases point to the same underlying class object.
# ---------------------------------------------------------------------------

invariant re_extra247.alias.error_name_matches_PatternError_name:
  description: "re.error.__name__ and re.PatternError.__name__ are both 'PatternError'"
  category: alias_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra247.alias.PatternError_name_matches_error_name:
  description: "re.PatternError.__name__ == re.error.__name__ == 'PatternError'"
  category: alias_identity
  kind: python_call_eq
  function: PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra247.alias.same_module:
  description: "re.error and re.PatternError share the same __module__"
  category: alias_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["re"]
  expected: true
