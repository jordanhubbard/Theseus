spec: pdb_extra5
version: ">=3.9"
backend: python_module(pdb)

docs: https://docs.python.org/3/library/pdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pdb.html — Python pdb documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pdb.py"
  notes:
    - "This spec extends pdb.zspec.zsdl through pdb_extra4.zspec.zsdl."
    - "pdb covers: Pdb/__name__, Restart/__name__, Pdb/__module__, run/runeval/runcall/set_trace/post_mortem/pm __name__ (table), Pdb().prompt, Pdb().use_rawinput."
    - "pdb_extra covers: Pdb/__name__/__module__/__bases__[0].__name__, run/runeval/runcall/set_trace/post_mortem/pm/help __name__ standalone."
    - "pdb_extra2 covers: Pdb/__name__/__module__/__qualname__, run/runcall/post_mortem/set_trace/pm __name__ and __module__."
    - "pdb_extra3 covers: runeval/__module__, help/__module__, Restart/__module__, Restart.__bases__[0]/__name__, Pdb.__bases__.__len__()==2, Pdb.__bases__[0]/__module__=='bdb', Pdb.__bases__[1]/__name__/'Cmd'/__module__/'cmd', function __qualname__ table."
    - "pdb_extra4 covers: Restart/__qualname__, Restart/__bases__.__len__()==1, Pdb.__bases__[0]/__qualname__=='Bdb', Pdb.__bases__[1]/__qualname__=='Cmd', Pdb.__bases__.__class__.__name__=='tuple', Pdb/__name__/__class__.__name__=='str', Restart/__name__/__class__.__name__=='str'."
    - "NEW in this spec: Pdb command-method names (do_break/do_continue/do_step/do_next/do_quit/do_list), Pdb instance state (skip/nosigint/use_rawinput type), Pdb().__class__.__name__, run/__class__.__name__=='function', Pdb.do_break/__module__, Pdb.MAX_CHAINED_EXCEPTION_DEPTH."
    - "pdb.Pdb.do_break.__name__ == 'do_break' — debugger command method names follow do_<cmd> convention."
    - "pdb.Pdb().__class__.__name__ == 'Pdb' — instantiating Pdb yields a Pdb object."
    - "pdb.run.__class__.__name__ == 'function' — run is a plain Python function."
    - "pdb.Pdb().skip is None by default — no skip patterns configured."
    - "pdb.Pdb().nosigint is False by default — signal handling is enabled."
    - "pdb.Pdb.MAX_CHAINED_EXCEPTION_DEPTH == 999 — maximum chained exception display depth."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pdb command-method names — do_<cmd> naming convention.
# Not covered in any prior pdb spec.
# ---------------------------------------------------------------------------

table pdb_extra5.command_method_names:
  kind: python_call_eq
  category: command_methods
  id_prefix: cmd

  columns: [id, function, args, expected]
  rows:
    - [do_break,    Pdb.do_break.__name__.__eq__,    ["do_break"],    true]
    - [do_continue, Pdb.do_continue.__name__.__eq__, ["do_continue"], true]
    - [do_step,     Pdb.do_step.__name__.__eq__,     ["do_step"],     true]
    - [do_next,     Pdb.do_next.__name__.__eq__,     ["do_next"],     true]
    - [do_quit,     Pdb.do_quit.__name__.__eq__,     ["do_quit"],     true]
    - [do_list,     Pdb.do_list.__name__.__eq__,     ["do_list"],     true]

# ---------------------------------------------------------------------------
# Pdb.do_break.__module__ — command methods are defined in pdb.
# Not covered in any prior pdb spec.
# ---------------------------------------------------------------------------

invariant pdb_extra5.do_break.module:
  description: "pdb.Pdb.do_break.__module__ == 'pdb' — command methods are defined in pdb"
  category: command_methods
  kind: python_call_eq
  function: Pdb.do_break.__module__.__eq__
  args: ["pdb"]
  expected: true

# ---------------------------------------------------------------------------
# Pdb().__class__.__name__ — instantiation returns a Pdb object.
# Not covered in any prior pdb spec.
# ---------------------------------------------------------------------------

invariant pdb_extra5.Pdb.instance_class_name:
  description: "pdb.Pdb().__class__.__name__ == 'Pdb' — instantiation yields a Pdb instance"
  category: pdb_instance
  kind: python_call_eq
  function: Pdb
  args: []
  method: __class__.__name__.__eq__
  method_args: ["Pdb"]
  expected: true

# ---------------------------------------------------------------------------
# Pdb instance state — skip and nosigint defaults.
# pdb base covers prompt and use_rawinput; skip and nosigint are new.
# ---------------------------------------------------------------------------

invariant pdb_extra5.Pdb.skip_is_none:
  description: "pdb.Pdb().skip is None — no skip patterns by default"
  category: pdb_instance
  kind: python_call_eq
  function: Pdb
  args: []
  method: skip.__class__.__name__.__eq__
  method_args: ["NoneType"]
  expected: true

invariant pdb_extra5.Pdb.nosigint_is_false:
  description: "pdb.Pdb().nosigint == False — signal handling is enabled by default"
  category: pdb_instance
  kind: python_call_eq
  function: Pdb
  args: []
  method: nosigint.__eq__
  method_args: [false]
  expected: true

# ---------------------------------------------------------------------------
# run.__class__.__name__ — run is a plain Python function.
# Not covered in any prior pdb spec.
# ---------------------------------------------------------------------------

invariant pdb_extra5.run.class_is_function:
  description: "pdb.run.__class__.__name__ == 'function' — run is a plain function object"
  category: function_types
  kind: python_call_eq
  function: run.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Pdb.MAX_CHAINED_EXCEPTION_DEPTH — class-level constant.
# Not covered in any prior pdb spec.
# ---------------------------------------------------------------------------

invariant pdb_extra5.Pdb.MAX_CHAINED_EXCEPTION_DEPTH:
  description: "pdb.Pdb.MAX_CHAINED_EXCEPTION_DEPTH == 999"
  category: pdb_class_constants
  kind: python_call_eq
  function: Pdb.MAX_CHAINED_EXCEPTION_DEPTH.__eq__
  args: [999]
  expected: true
