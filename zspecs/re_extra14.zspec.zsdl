spec: re_extra14
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra13.zspec.zsdl."
    - "re_extra13 covers: compile.__qualname__=='compile'; Pattern/Match/error mro().__len__(); table of function qualnames (compile/escape/purge)."
    - "re_extra12 covers: fullmatch(r'\\d+','123').__class__.__name__; fullmatch(r'\\d+','12x') is None; escape('hello'); IGNORECASE|MULTILINE==10; search named group; search capture group 1; sub whitespace collapse; split single spaces."
    - "re_extra10 covers: LOCALE/UNICODE values; purge/escape/subn qualnames."
    - "re_extra7 covers: RegexFlag member values IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/NOFLAG."
    - "NOT yet covered: re.RegexFlag.__name__ == 'RegexFlag' as a standalone invariant."
    - "NOT yet covered: re.RegexFlag.__qualname__ == 'RegexFlag' as a standalone invariant."
    - "NOT yet covered: re.RegexFlag.__module__ == 're' as a standalone invariant."
    - "NOT yet covered: re.RegexFlag.__bases__[0].__name__ == 'IntFlag'."
    - "NOT yet covered: re.compile(r'[a-z]+').pattern == '[a-z]+' as a standalone invariant."
    - "NOT yet covered: re.match(r'(\\w+)\\s+(\\w+)', ...).group(2) — second capture group."
    - "NOT yet covered: re.match(r'(\\w+)\\s+(\\w+)', ...).groups().__len__() == 2."
    - "NOT yet covered: re.subn(r'\\d', 'X', 'a1b2c3') return value and count."
    - "NOT yet covered: re.match(r'\\d+', '123abc').start() == 0 and .end() == 3."
    - "re.RegexFlag.__name__ == 'RegexFlag' — the enum class name."
    - "re.RegexFlag.__qualname__ == 'RegexFlag' — enum class at module scope so qualname equals name."
    - "re.RegexFlag.__module__ == 're' — defined in the re module."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from IntFlag."
    - "re.compile(r'[a-z]+').pattern == '[a-z]+'  — compiled pattern stores the source pattern string."
    - "re.match(r'(\\w+)\\s+(\\w+)', 'foo bar').group(2) == 'bar' — second capture group."
    - "re.match(r'(\\w+)\\s+(\\w+)', 'foo bar').groups().__len__() == 2 — two capture groups."
    - "re.subn(r'\\d', 'X', 'a1b2c3')[0] == 'aXbXcX' — replacement string."
    - "re.subn(r'\\d', 'X', 'a1b2c3')[1] == 3 — three replacements made."
    - "re.match(r'\\d+', '123abc').start() == 0 — match starts at position 0."
    - "re.match(r'\\d+', '123abc').end() == 3 — match ends at position 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag class identity — __name__, __qualname__, __module__
#
# re_extra7 covers RegexFlag member integer values (IGNORECASE, MULTILINE, etc.)
# and the RegexFlag base class (IntFlag) as re.RegexFlag.__bases__[0].__name__.
# No prior spec records RegexFlag.__name__, __qualname__, or __module__ as
# standalone invariants. RegexFlag is an IntFlag enum defined in the re module;
# its __name__ and __qualname__ are both 'RegexFlag' and its __module__ is 're'.
# ---------------------------------------------------------------------------

invariant re_extra14.RegexFlag.name:
  description: "re.RegexFlag.__name__ == 'RegexFlag' — the enum class name"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra14.RegexFlag.qualname:
  description: "re.RegexFlag.__qualname__ == 'RegexFlag' — module-scope enum: qualname equals name"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__qualname__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra14.RegexFlag.module:
  description: "re.RegexFlag.__module__ == 're' — RegexFlag is defined in the re module"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.RegexFlag base class — IntFlag
#
# re_extra7 mentions that RegexFlag inherits from IntFlag but does not test it
# as a standalone invariant. This is the first spec to record the base class
# name for RegexFlag.
# ---------------------------------------------------------------------------

invariant re_extra14.RegexFlag.base_class:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from IntFlag"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["IntFlag"]
  expected: true

# ---------------------------------------------------------------------------
# re.compile — .pattern attribute
#
# No prior spec checks the .pattern attribute of a compiled Pattern.
# re.compile(r'[a-z]+').pattern == '[a-z]+' — the source pattern string is
# stored verbatim on the compiled object.
# ---------------------------------------------------------------------------

invariant re_extra14.compile.pattern_attr:
  description: "re.compile(r'[a-z]+').pattern == '[a-z]+' — compiled pattern stores its source"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["[a-z]+"]
  method: pattern.__eq__
  method_args: ["[a-z]+"]
  expected: true

# ---------------------------------------------------------------------------
# re.match — second capture group and groups tuple length
#
# re_extra7 covers match().group(1) (first capture group).
# re_extra11 covers match().groups() and match().re.__class__.__name__.
# No prior spec records match().group(2) or groups().__len__() == 2.
# ---------------------------------------------------------------------------

invariant re_extra14.match.group_two:
  description: "re.match(r'(\\w+)\\s+(\\w+)', 'foo bar').group(2) == 'bar' — second capture group"
  category: match_attrs
  kind: python_call_eq
  function: match
  args: ["(\\w+)\\s+(\\w+)", "foo bar"]
  method: group
  method_args: [2]
  expected: "bar"

invariant re_extra14.match.groups_len:
  description: "re.match(r'(\\w+)\\s+(\\w+)', 'foo bar').groups().__len__() == 2 — two capture groups"
  category: match_attrs
  kind: python_call_eq
  function: match
  args: ["(\\w+)\\s+(\\w+)", "foo bar"]
  method: groups.__len__
  expected: 2

# ---------------------------------------------------------------------------
# re.subn — replacement string and replacement count
#
# re_extra10 covers subn(r'a', 'b', 'aababba') with count==4.
# No prior spec covers subn(r'\d', 'X', 'a1b2c3') (digit replacement).
# re.subn returns a (new_string, count) tuple; we extract element 0 and 1.
# ---------------------------------------------------------------------------

invariant re_extra14.subn.result_string:
  description: "re.subn(r'\\d', 'X', 'a1b2c3')[0] == 'aXbXcX' — digits replaced with X"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "a1b2c3"]
  method: __getitem__
  method_args: [0]
  expected: "aXbXcX"

invariant re_extra14.subn.replacement_count:
  description: "re.subn(r'\\d', 'X', 'a1b2c3')[1] == 3 — three digit replacements"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "a1b2c3"]
  method: __getitem__
  method_args: [1]
  expected: 3

# ---------------------------------------------------------------------------
# re.match — .start() and .end() on a digit pattern
#
# re_extra7 covers match span/start/end for a word-character pattern.
# No prior spec tests start() and end() on a digit-only match (r'\d+', '123abc').
# The match spans positions 0 through 3.
# ---------------------------------------------------------------------------

invariant re_extra14.match.start_zero:
  description: "re.match(r'\\d+', '123abc').start() == 0 — digit match starts at 0"
  category: match_attrs
  kind: python_call_eq
  function: match
  args: ["\\d+", "123abc"]
  method: start
  expected: 0

invariant re_extra14.match.end_three:
  description: "re.match(r'\\d+', '123abc').end() == 3 — digit match ends at 3"
  category: match_attrs
  kind: python_call_eq
  function: match
  args: ["\\d+", "123abc"]
  method: end
  expected: 3

# ---------------------------------------------------------------------------
# Table: RegexFlag class identity
#
# Groups the three class-identity invariants for RegexFlag as table rows so
# the invariant set can be indexed by id. No prior spec provides a table for
# RegexFlag class attributes.
# ---------------------------------------------------------------------------

table re_extra14.RegexFlag_identity:
  description: "re.RegexFlag class identity attributes"
  kind: python_call_eq
  category: class_identity
  id_prefix: rfi

  columns: [id, function, args, expected]
  rows:
    - [name,     RegexFlag.__name__.__eq__,     ["RegexFlag"], true]
    - [qualname, RegexFlag.__qualname__.__eq__,  ["RegexFlag"], true]
    - [module,   RegexFlag.__module__.__eq__,    ["re"],        true]
