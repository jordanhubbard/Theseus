spec: multiprocessing_extra280
version: ">=3.9"
backend: python_module(multiprocessing.queues)

docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing.queues Queue, JoinableQueue, SimpleQueue identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "multiprocessing.queues.Queue.__bases__[0].__name__ == 'object' (Queue inherits directly from object)"
    - "multiprocessing.queues.JoinableQueue.__bases__[0].__name__ == 'Queue' (inherits from Queue)"
    - "multiprocessing.queues.SimpleQueue.__bases__[0].__name__ == 'object' (inherits directly from object)"
    - "All method qualnames follow 'Queue.<method>' pattern as expected for pure-Python class"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra280.queue_method_qualnames:
  description: "multiprocessing.queues.Queue method __qualname__ values for core queue operations"
  kind: python_call_eq
  category: identity
  id_prefix: mp280a

  columns: [id, function, args, expected, description]
  rows:
    - [mp280a001, multiprocessing.queues.Queue.put.__qualname__.__eq__, ["Queue.put"], true, "Queue.put qualname"]
    - [mp280a002, multiprocessing.queues.Queue.get.__qualname__.__eq__, ["Queue.get"], true, "Queue.get qualname"]
    - [mp280a003, multiprocessing.queues.Queue.put_nowait.__qualname__.__eq__, ["Queue.put_nowait"], true, "Queue.put_nowait qualname"]
    - [mp280a004, multiprocessing.queues.Queue.get_nowait.__qualname__.__eq__, ["Queue.get_nowait"], true, "Queue.get_nowait qualname"]
    - [mp280a005, multiprocessing.queues.Queue.empty.__qualname__.__eq__, ["Queue.empty"], true, "Queue.empty qualname"]
    - [mp280a006, multiprocessing.queues.Queue.full.__qualname__.__eq__, ["Queue.full"], true, "Queue.full qualname"]
    - [mp280a007, multiprocessing.queues.Queue.qsize.__qualname__.__eq__, ["Queue.qsize"], true, "Queue.qsize qualname"]
    - [mp280a008, multiprocessing.queues.Queue.close.__qualname__.__eq__, ["Queue.close"], true, "Queue.close qualname"]

table multiprocessing_extra280.queue_class_identity:
  description: "multiprocessing.queues Queue, JoinableQueue, SimpleQueue class name, module, and base class identity"
  kind: python_call_eq
  category: identity
  id_prefix: mp280b

  columns: [id, function, args, expected, description]
  rows:
    - [mp280b001, multiprocessing.queues.Queue.__name__.__eq__, ["Queue"], true, "Queue.__name__ is 'Queue'"]
    - [mp280b002, multiprocessing.queues.Queue.__module__.__eq__, ["multiprocessing.queues"], true, "Queue.__module__ is 'multiprocessing.queues'"]
    - [mp280b003, "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__", ["object"], true, "Queue base class is object"]
    - [mp280b004, multiprocessing.queues.JoinableQueue.__name__.__eq__, ["JoinableQueue"], true, "JoinableQueue.__name__ is 'JoinableQueue'"]
    - [mp280b005, multiprocessing.queues.JoinableQueue.__module__.__eq__, ["multiprocessing.queues"], true, "JoinableQueue.__module__ is 'multiprocessing.queues'"]
    - [mp280b006, "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__", ["Queue"], true, "JoinableQueue base class is Queue"]
    - [mp280b007, multiprocessing.queues.SimpleQueue.__name__.__eq__, ["SimpleQueue"], true, "SimpleQueue.__name__ is 'SimpleQueue'"]
    - [mp280b008, multiprocessing.queues.SimpleQueue.__module__.__eq__, ["multiprocessing.queues"], true, "SimpleQueue.__module__ is 'multiprocessing.queues'"]
    - [mp280b009, "multiprocessing.queues.SimpleQueue.__bases__[0].__name__.__eq__", ["object"], true, "SimpleQueue base class is object"]

invariant multiprocessing_extra280.queue_base_is_object:
  description: "multiprocessing.queues.Queue inherits directly from object"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra280.joinablequeue_base_is_queue:
  description: "multiprocessing.queues.JoinableQueue inherits from Queue"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra280.simplequeue_base_is_object:
  description: "multiprocessing.queues.SimpleQueue inherits directly from object"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.queues.SimpleQueue.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
