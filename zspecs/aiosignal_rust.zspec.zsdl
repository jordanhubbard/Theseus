spec: aiosignal_rust
version: ">=3.9"
backend: rust_module(aiosignal_rust)

docs: https://github.com/aio-libs/aiosignal

provenance:
  derived_from:
    - "https://github.com/aio-libs/aiosignal — aiosignal"
  notes:
    - "aiosignal provides signal/callback support for asyncio."
    - "aiosignal.Signal is a class."
    - "aiosignal.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant aiosignal_rust.has_signal_class:
  description: "aiosignal.Signal is a class"
  category: presence
  kind: python_call_eq
  function: aiosignal_has_signal_class
  args: []
  expected: true

invariant aiosignal_rust.signal_len_zero:
  description: "Signal([]).send() returns list (empty)"
  category: signal
  kind: python_call_eq
  function: aiosignal_signal_is_list
  args: []
  expected: true

invariant aiosignal_rust.version_nonempty:
  description: "aiosignal.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: aiosignal_version_nonempty
  args: []
  expected: true

