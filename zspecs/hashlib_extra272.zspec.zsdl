spec: hashlib_extra272
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra271.zspec.zsdl — covers algorithms_available set membership and __class__.__name__ identity."
    - "hashlib_extra270.zspec.zsdl — covers algorithms_guaranteed set membership."
  notes:
    - "hashlib.__name__ == 'hashlib' — the pure-Python hashlib module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.__package__ == '' — hashlib is a top-level module with empty package. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.__spec__.name == 'hashlib' — ModuleSpec.name attribute matches the module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is an importlib.machinery.ModuleSpec instance. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.__spec__.origin.__class__.__name__ == 'str' — the origin is a string path to the source file. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' — hashlib is loaded from a .py source file. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib._hashlib.__name__ == '_hashlib' — the C extension submodule exposed as hashlib._hashlib. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib._hashlib.__package__ == '' — C extension modules have empty package. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib._hashlib.__spec__.name == '_hashlib' — ModuleSpec.name for C extension matches module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib._hashlib.__loader__.__class__.__name__ == 'ExtensionFileLoader' — C extension modules use ExtensionFileLoader. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module __spec__ and __loader__ identity
# hashlib is a pure-Python module loaded via SourceFileLoader.
# Its __spec__ is an importlib.machinery.ModuleSpec instance.
# ---------------------------------------------------------------------------

table hashlib_extra272.hashlib_module_spec_identity:
  description: "hashlib module __spec__ and __loader__ identity — __name__/'hashlib', __package__/'', __spec__.name/'hashlib', __spec__.__class__.__name__/'ModuleSpec', __loader__.__class__.__name__/'SourceFileLoader'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibspec272

  columns: [id, function, args, expected, description]
  rows:
    - [hashlib_name,          __name__.__eq__,                     ["hashlib"],          true, "hashlib.__name__ == 'hashlib' — pure-Python top-level module"]
    - [hashlib_package,       __package__.__eq__,                  [""],                 true, "hashlib.__package__ == '' — top-level module has empty package string"]
    - [hashlib_spec_name,     __spec__.name.__eq__,                ["hashlib"],          true, "hashlib.__spec__.name == 'hashlib' — ModuleSpec.name matches module name"]
    - [hashlib_spec_class,    __spec__.__class__.__name__.__eq__,  ["ModuleSpec"],       true, "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' — importlib.machinery.ModuleSpec instance"]
    - [hashlib_loader_class,  __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' — pure-Python source loaded via SourceFileLoader"]

# ---------------------------------------------------------------------------
# hashlib._hashlib C extension module __spec__ and __loader__ identity
# hashlib exposes _hashlib as an attribute. _hashlib is a C extension module
# loaded via ExtensionFileLoader. Its __spec__ is a ModuleSpec with name '_hashlib'.
# ---------------------------------------------------------------------------

table hashlib_extra272.hashlib_c_ext_spec_identity:
  description: "hashlib._hashlib C extension __spec__ and __loader__ identity — _hashlib.__name__/'_hashlib', _hashlib.__package__/'', _hashlib.__spec__.name/'_hashlib', _hashlib.__loader__.__class__.__name__/'ExtensionFileLoader'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibcext272

  columns: [id, function, args, expected, description]
  rows:
    - [c_ext_name,          _hashlib.__name__.__eq__,                               ["_hashlib"],           true, "hashlib._hashlib.__name__ == '_hashlib' — C extension module name"]
    - [c_ext_package,       _hashlib.__package__.__eq__,                            [""],                   true, "hashlib._hashlib.__package__ == '' — C extension module has empty package string"]
    - [c_ext_spec_name,     _hashlib.__spec__.name.__eq__,                          ["_hashlib"],           true, "hashlib._hashlib.__spec__.name == '_hashlib' — ModuleSpec.name matches C extension name"]
    - [c_ext_spec_class,    _hashlib.__spec__.__class__.__name__.__eq__,            ["ModuleSpec"],         true, "hashlib._hashlib.__spec__.__class__.__name__ == 'ModuleSpec' — importlib.machinery.ModuleSpec instance"]
    - [c_ext_loader_class,  _hashlib.__loader__.__class__.__name__.__eq__,          ["ExtensionFileLoader"], true, "hashlib._hashlib.__loader__.__class__.__name__ == 'ExtensionFileLoader' — C extension loaded via ExtensionFileLoader"]

# ---------------------------------------------------------------------------
# Standalone invariants — hashlib module spec properties
# ---------------------------------------------------------------------------

invariant hashlib_extra272.hashlib_name_eq:
  description: "hashlib.__name__ == 'hashlib' — the module name attribute of the pure-Python hashlib module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra272.hashlib_package_eq:
  description: "hashlib.__package__ == '' — hashlib is a top-level module so __package__ is the empty string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant hashlib_extra272.hashlib_spec_name_eq:
  description: "hashlib.__spec__.name == 'hashlib' — the ModuleSpec.name attribute for the hashlib module; mirrors __name__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra272.hashlib_spec_class_eq:
  description: "hashlib.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is an importlib.machinery.ModuleSpec; set by the import system for all Python modules; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant hashlib_extra272.hashlib_spec_origin_class_eq:
  description: "hashlib.__spec__.origin.__class__.__name__ == 'str' — the origin is a filesystem path string pointing to hashlib.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant hashlib_extra272.hashlib_loader_class_eq:
  description: "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' — hashlib.py is loaded from source by SourceFileLoader (importlib._bootstrap_external); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant hashlib_extra272.c_ext_name_eq:
  description: "hashlib._hashlib.__name__ == '_hashlib' — the C extension submodule name; accessible as an attribute of the hashlib module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: _hashlib.__name__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra272.c_ext_loader_class_eq:
  description: "hashlib._hashlib.__loader__.__class__.__name__ == 'ExtensionFileLoader' — C extension modules use ExtensionFileLoader from importlib._bootstrap_external; contrasts with SourceFileLoader used for hashlib.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: _hashlib.__loader__.__class__.__name__.__eq__
  args: ["ExtensionFileLoader"]
  expected: true
