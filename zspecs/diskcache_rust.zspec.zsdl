spec: diskcache_rust
version: ">=3.9"
backend: rust_module(diskcache_rust)

docs: https://grantjenks.com/docs/diskcache/

provenance:
  derived_from:
    - "https://grantjenks.com/docs/diskcache/ — DiskCache documentation"
  not_derived_from:
    - "diskcache source: diskcache/core.py"
  notes:
    - "DiskCache provides disk and file backed cache for Python."
    - "import diskcache; diskcache.Cache is available."
    - "diskcache.Cache.__name__ == 'Cache'."
    - "diskcache.FanoutCache is available."
    - "diskcache.__version__ is a non-empty string."
    - "Expose diskcache_cache_name() -> str: diskcache.Cache.__name__."
    - "Expose diskcache_has_fanout() -> bool: hasattr(diskcache, 'FanoutCache')."
    - "Expose diskcache_version_nonempty() -> bool: len(diskcache.__version__) > 0."
    - "All test vectors verified against diskcache 5.6.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# diskcache_cache_name — Cache class name
invariant diskcache_rust.cache.class_name:
  description: "diskcache.Cache.__name__ == 'Cache'"
  category: cache
  kind: python_call_eq
  function: diskcache_cache_name
  args: []
  expected: "Cache"

# diskcache_has_fanout — FanoutCache present
invariant diskcache_rust.module.has_fanout:
  description: "diskcache.FanoutCache is available"
  category: module
  kind: python_call_eq
  function: diskcache_has_fanout
  args: []
  expected: true

# diskcache_version_nonempty — version non-empty
invariant diskcache_rust.version.nonempty:
  description: "diskcache.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: diskcache_version_nonempty
  args: []
  expected: true

