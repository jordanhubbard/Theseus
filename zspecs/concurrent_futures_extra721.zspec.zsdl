spec: concurrent_futures_extra721
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: Cover concurrent.futures Future and Executor method qualnames
provenance:
  derived_from: concurrent.futures standard library documentation
  not_derived_from: any third-party futures wrapper
  notes: Validates method qualname invariants for Future and Executor classes in concurrent.futures
  created_at: "2026-04-12"
error_model: python_exceptions

table concurrent_futures_extra721.future_method_qualnames:
  description: concurrent.futures.Future method qualname checks
  kind: python_call_eq
  category: method_qualname
  id_prefix: cf721fu
  columns: [id, function, args, expected]
  cf721fu001: [concurrent.futures.Future.cancel.__qualname__.__eq__, ["Future.cancel"], true]
  cf721fu002: [concurrent.futures.Future.result.__qualname__.__eq__, ["Future.result"], true]
  cf721fu003: [concurrent.futures.Future.exception.__qualname__.__eq__, ["Future.exception"], true]
  cf721fu004: [concurrent.futures.Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"], true]
  cf721fu005: [concurrent.futures.Future.running.__qualname__.__eq__, ["Future.running"], true]
  cf721fu006: [concurrent.futures.Future.done.__qualname__.__eq__, ["Future.done"], true]
  cf721fu007: [concurrent.futures.Future.cancelled.__qualname__.__eq__, ["Future.cancelled"], true]
  cf721fu008: [concurrent.futures.Future.set_result.__qualname__.__eq__, ["Future.set_result"], true]
  cf721fu009: [concurrent.futures.Future.set_exception.__qualname__.__eq__, ["Future.set_exception"], true]

table concurrent_futures_extra721.executor_method_qualnames:
  description: concurrent.futures.Executor method qualname checks
  kind: python_call_eq
  category: method_qualname
  id_prefix: cf721ex
  columns: [id, function, args, expected]
  cf721ex001: [concurrent.futures.Executor.submit.__qualname__.__eq__, ["Executor.submit"], true]
  cf721ex002: [concurrent.futures.Executor.map.__qualname__.__eq__, ["Executor.map"], true]
  cf721ex003: [concurrent.futures.Executor.shutdown.__qualname__.__eq__, ["Executor.shutdown"], true]
