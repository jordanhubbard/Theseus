spec: inspect_extra143
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.isroutine (Python function), inspect.isgeneratorfunction (Python function), inspect.iscoroutinefunction (Python function), inspect.isasyncgenfunction (Python function), inspect.isframe (Python function), inspect.iscode (Python function), inspect.istraceback (Python function) — __qualname__ len, __module__, __doc__ len, co_argcount (Wave 271)."
    - "inspect.isroutine: __qualname__ == 'isroutine' (len 9); __module__ == 'inspect'; __doc__ len == 60; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isgeneratorfunction: __qualname__ == 'isgeneratorfunction' (len 19); __module__ == 'inspect'; __doc__ len == 180; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction: __qualname__ == 'iscoroutinefunction' (len 19); __module__ == 'inspect'; __doc__ len == 163; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction: __qualname__ == 'isasyncgenfunction' (len 18); __module__ == 'inspect'; __doc__ len == 179; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isframe: __qualname__ == 'isframe' (len 7); __module__ == 'inspect'; __doc__ len == 772; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.iscode: __qualname__ == 'iscode' (len 6); __module__ == 'inspect'; __doc__ len == 1718; co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.istraceback: __qualname__ == 'istraceback' (len 11); __module__ == 'inspect'; __doc__ len == 334; co_argcount == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isroutine and inspect.isgeneratorfunction — qualname, doc
#
# Wave 271 theme: inspect predicates for callables and generators.
#
# inspect.isroutine.__class__.__name__ == 'function'
# inspect.isroutine.__qualname__ == 'isroutine' (len 9)
# inspect.isroutine.__module__ == 'inspect' (len 7)
# len(inspect.isroutine.__doc__) == 60
# inspect.isroutine.__code__.co_argcount == 1
# inspect.isgeneratorfunction.__class__.__name__ == 'function'
# inspect.isgeneratorfunction.__qualname__ == 'isgeneratorfunction' (len 19)
# inspect.isgeneratorfunction.__module__ == 'inspect' (len 7)
# len(inspect.isgeneratorfunction.__doc__) == 180
# inspect.isgeneratorfunction.__code__.co_argcount == 1
#
# isroutine(object) returns True for any callable except a class;
# isgeneratorfunction returns True for generator functions. New to extra143.
# ---------------------------------------------------------------------------

