spec: abc_extra2161
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Theme: descriptor protocol dict-presence — checks for __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, __func__ in class __dict__."
    - "abc.ABCMeta does not define any descriptor protocol methods in its own __dict__."
    - "abc.ABC does not define any descriptor protocol methods in its own __dict__."
    - "abc.abstractmethod does not define any descriptor protocol methods in its own __dict__."
    - "Despite documentation suggesting abstractmethod may act as a descriptor, it is implemented as a plain Python function and its own __dict__ is empty — it has no __get__ etc. defined directly on it."
    - "Verified: type(abc.abstractmethod) == 'function' and abc.abstractmethod.__dict__ == {}."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

