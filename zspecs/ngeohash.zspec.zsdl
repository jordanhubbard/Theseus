spec: ngeohash
version: ">=0.6.0"
backend: node(ngeohash)

docs: https://www.npmjs.com/package/ngeohash

provenance:
  derived_from:
    - "ngeohash README — https://www.npmjs.com/package/ngeohash"
    - "Test vectors verified with ngeohash via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "ngeohash source"
  notes:
    - "ngeohash is an npm package. Install: npm install ngeohash"
    - "geohash.encode(lat, lng) encodes lat/lng to a geohash string."
    - "geohash.decode(hash) returns an object with latitude, longitude, and error fields."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns geohash string or decoded object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ngeohash.encode:
  kind: node_module_call_eq
  function: encode
  category: encode
  id_prefix: ngh_enc

  columns: [id, args, expected]
  rows:
    - [sf,     [37.8324, -122.4197], "9q8znr0tw"]
    - [origin, [0, 0],               "7zzzzzzzz"]
    - [london, [51.5074, -0.1278],   "gcpvj0duq"]

table ngeohash.decode:
  kind: node_module_call_eq
  function: decode
  category: decode
  id_prefix: ngh_dec

  columns: [id, args, expected]
  rows:
    - [sf_short, ["9q8yy"],
       {"latitude": 37.77099609375, "longitude": -122.40966796875,
        "error": {"latitude": 0.02197265625, "longitude": 0.02197265625}}]
