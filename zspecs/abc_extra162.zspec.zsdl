spec: abc_extra162
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABCMeta.__module__.__len__()==3 ('abc'=3); abc.ABC.__module__.__len__()==3; abc.abstractmethod.__module__.__len__()==3 — all three expose __module__=='abc' (len=3); abc.ABCMeta.__mro__.__len__()==3 (MRO: ABCMeta -> type -> object; 3 entries); abc.ABC.__mro__.__len__()==2 (MRO: ABC -> object; 2 entries). KEY FINDINGS: the 'abc' module name has len=3 which matches abc.ABC.__name__.__len__()==3 (established in extra161) — module name length equals ABC class name length; ABCMeta.__mro__ has 3 entries because ABCMeta is a subclass of 'type' (the metaclass hierarchy: ABCMeta -> type -> object); ABC.__mro__ has only 2 entries because ABC is a regular class (ABC -> object; ABC's metaclass IS ABCMeta but ABC itself is not a metaclass so its MRO is short). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__module__.__len__()==3 ('abc'=3: 'a'+'b'+'c'=3; the module name 'abc' has the same length as ABC.__name__=='ABC'=3 — a coincidence where module name len equals the primary class name len); abc.ABC.__module__.__len__()==3 (same 'abc' module as ABCMeta); abc.abstractmethod.__module__.__len__()==3 (same 'abc' module; abstractmethod is defined in Lib/abc.py just like ABCMeta and ABC; compare: abc.get_cache_token.__module__=='_abc' (len=4; from extra161) — get_cache_token is in the C extension module, which is 1 char longer than 'abc'=3). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__mro__.__len__()==3: the MRO is [ABCMeta, type, object]; ABCMeta IS-A type (the metaclass of type); ABCMeta IS-A object (everything is object); 3-entry MRO because ABCMeta -> type -> object; 'type' appears at MRO index 1: ABCMeta.__mro__[1].__name__=='type'. abc.ABC.__mro__.__len__()==2: the MRO is [ABC, object]; ABC is a simple helper class with ABCMeta as its metaclass but ABC itself is not a metaclass; 2-entry MRO because ABC -> object. KEY CONTRAST: ABCMeta MRO len(3) > ABC MRO len(2) because ABCMeta is a metaclass subclassing 'type' while ABC is a regular class rooted at object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module __len__ checks — extra162
#
# abc.ABCMeta.__module__.__len__()       == 3
# abc.ABC.__module__.__len__()           == 3
# abc.abstractmethod.__module__.__len__() == 3
# ---------------------------------------------------------------------------

table abc_extra162.abc_module_lengths:
  description: "abc.ABCMeta, abc.ABC, and abc.abstractmethod __module__ length checks in abcmodlen162 namespace — abc.ABCMeta.__module__.__len__()==3 (ABCMeta.__module__=='abc' (len=3: 'a'+'b'+'c'=3); the 'abc' module name has len=3 which coincidentally equals abc.ABC.__name__.__len__()==3 (established in extra161) and the module name 'abc'=3; all three abc module names have the same length 3); abc.ABC.__module__.__len__()==3 (ABC.__module__=='abc' (len=3; same module as ABCMeta)); abc.abstractmethod.__module__.__len__()==3 (abstractmethod.__module__=='abc' (len=3; abstractmethod is also defined in Lib/abc.py — all three public abc entities share the same module 'abc' of length 3)); abc.ABCMeta.__module__.__eq__('abc')==True (cross-check; confirming the module value); KEY PATTERN: ABCMeta(7) + ABC(3) + abstractmethod(14) all live in 'abc' (len=3) — the module name is 3 chars while the class/function names range from 3 to 14 chars; compare: abc.get_cache_token.__module__=='_abc' (len=4; from extra161) — the C extension module '_abc' is 1 char longer than the Python module 'abc'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodlen162

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_mod_len,      abc.ABCMeta.__module__.__len__,      [],       3,     "ABCMeta.__module__.__len__() == 3 ('abc'=3; module name same len as ABC class name=3); verified with Python 3.14.3"]
    - [abc_mod_len,          abc.ABC.__module__.__len__,           [],       3,     "ABC.__module__.__len__() == 3 ('abc'=3; same module as ABCMeta); verified with Python 3.14.3"]
    - [abstractmethod_mod_len, abc.abstractmethod.__module__.__len__, [],    3,     "abstractmethod.__module__.__len__() == 3 ('abc'=3; all three public abc entities share module len=3); verified with Python 3.14.3"]
    - [abcmeta_mod_eq,       abc.ABCMeta.__module__.__eq__,       ["abc"],  true,  "ABCMeta.__module__ == 'abc' (cross-check; the pure Python abc module; len=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__mro__ length — extra162
#
# abc.ABCMeta.__mro__.__len__() == 3
# abc.ABCMeta.__mro__[1].__name__ == 'type'
# abc.ABCMeta.__mro__[2].__name__ == 'object'
# ---------------------------------------------------------------------------

table abc_extra162.abc_ABCMeta_mro:
  description: "abc.ABCMeta.__mro__ length and member checks in abcabcmetamro162 namespace — abc.ABCMeta.__mro__.__len__()==3 (ABCMeta's MRO has exactly 3 entries: [ABCMeta, type, object]; ABCMeta is a subclass of 'type' — ABCMeta IS a metaclass; the metaclass hierarchy: ABCMeta -> type -> object; 'type' appears at MRO index 1 because type is the built-in metaclass that ABCMeta extends; 'object' appears at MRO index 2 as the universal base); abc.ABCMeta.__mro__[1].__name__.__eq__('type')==True (the second MRO entry for ABCMeta is 'type' (len=4: 't'+'y'+'p'+'e'=4); ABCMeta inherits from type, gaining the ability to intercept class creation via __new__ and __init__; type.__name__=='type' (len=4)); abc.ABCMeta.__mro__[2].__name__.__eq__('object')==True (the third MRO entry is 'object' (len=6); object is the universal base class); ABCMeta.__mro__.__len__()==3 vs ABC.__mro__.__len__()==2 (ABCMeta has one MORE MRO entry than ABC because ABCMeta is a metaclass inheriting from type while ABC is a regular class); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmetamro162

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_mro_len,       abc.ABCMeta.__mro__.__len__,                   [],        3,     "ABCMeta.__mro__.__len__() == 3 (MRO: ABCMeta -> type -> object; 3 entries); verified with Python 3.14.3"]
    - [abcmeta_mro1_name_eq,  "abc.ABCMeta.__mro__[1].__name__.__eq__",      ["type"],   true,  "ABCMeta.__mro__[1].__name__ == 'type' (ABCMeta IS-A type; metaclass inheritance); verified with Python 3.14.3"]
    - [abcmeta_mro2_name_eq,  "abc.ABCMeta.__mro__[2].__name__.__eq__",      ["object"], true,  "ABCMeta.__mro__[2].__name__ == 'object' (universal base at MRO index 2); verified with Python 3.14.3"]
    - [abcmeta_mro_len2,      abc.ABCMeta.__mro__.__len__,                   [],        3,     "ABCMeta.__mro__.__len__() == 3 (cross-check; 1 longer than ABC.__mro__ len=2); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC.__mro__ length — extra162
#
# abc.ABC.__mro__.__len__() == 2
# abc.ABC.__mro__[1].__name__ == 'object'
# ---------------------------------------------------------------------------

table abc_extra162.abc_ABC_mro:
  description: "abc.ABC.__mro__ length and member checks in abcabcmro162 namespace — abc.ABC.__mro__.__len__()==2 (ABC's MRO has exactly 2 entries: [ABC, object]; abc.ABC is a regular class (not a metaclass) with ABCMeta as its metaclass; the class itself only inherits from object — its metaclass ABCMeta intercepts class creation but does not appear in the MRO; the MRO for a regular class rooted only at object is the minimal 2-entry MRO: [the_class, object]); abc.ABC.__mro__[1].__name__.__eq__('object')==True (the second MRO entry for ABC is 'object' (len=6); ABC's only inheritance parent is object — ABC.__bases__ == (<class 'object'>,) — confirmed by the 2-entry MRO); abc.ABC.__mro__.__len__()==2 vs abc.ABCMeta.__mro__.__len__()==3 (ABC has the shorter MRO: 2 entries vs ABCMeta's 3 because ABC is a regular class while ABCMeta is a metaclass extending type; the extra 'type' entry in ABCMeta's MRO accounts for the length difference of 3-2=1); abc.ABC.__module__.__len__()==3 (cross-check; 'abc'=3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmro162

  columns: [id, function, args, expected, description]
  rows:
    - [abc_mro_len,       abc.ABC.__mro__.__len__,                [],         2,     "ABC.__mro__.__len__() == 2 (MRO: ABC -> object; minimal 2-entry MRO for regular class); verified with Python 3.14.3"]
    - [abc_mro1_name_eq,  "abc.ABC.__mro__[1].__name__.__eq__",   ["object"], true,  "ABC.__mro__[1].__name__ == 'object' (second MRO entry is object; ABC's only base); verified with Python 3.14.3"]
    - [abc_mro_len2,      abc.ABC.__mro__.__len__,                [],         2,     "ABC.__mro__.__len__() == 2 (cross-check; 1 shorter than ABCMeta.__mro__=3); verified with Python 3.14.3"]
    - [abc_mod_len2,      abc.ABC.__module__.__len__,             [],         3,     "ABC.__module__.__len__() == 3 (cross-check; 'abc'=3; module len == ABC name len); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module and MRO length cross-comparison — extra162
#
# ABCMeta.__module__ len == ABC.__module__ len == abstractmethod.__module__ len == 3
# ABCMeta.__mro__ len == 3  vs  ABC.__mro__ len == 2
# ---------------------------------------------------------------------------

table abc_extra162.abc_module_and_mro_cross_comparison:
  description: "abc module lengths and MRO lengths cross-comparison in abcmodmro162 namespace — ABCMeta.__module__ len(3) == ABC.__module__ len(3) == abstractmethod.__module__ len(3) (all three public abc entities share the same module 'abc' of length 3; the module name 'abc'=3 is the shortest possible meaningful abbreviation for 'abstract base classes'); ABCMeta.__mro__.__len__()==3 vs ABC.__mro__.__len__()==2 (KEY CONTRAST: ABCMeta has a 3-entry MRO while ABC has a 2-entry MRO; they are NOT the same MRO length despite looking related; ABCMeta MRO len(3) == ABCMeta module len(3) — a coincidence where the MRO length and module string length are both 3; ABC MRO len(2) != ABC module len(3) — these are different); abc.ABC.__module__.__len__()==3 (cross-check); abc.abstractmethod.__module__.__len__()==3 (cross-check); KEY COINCIDENCE: 'abc' module name length (3) == ABCMeta.__mro__ length (3) == ABC.__name__ length (3) == ABC.__module__ length (3) — all are 3; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmodmro162

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_mro_len3,  abc.ABCMeta.__mro__.__len__,         [],  3,  "ABCMeta.__mro__.__len__() == 3 (ABCMeta->type->object; 3 entries; same as 'abc' module len=3); verified with Python 3.14.3"]
    - [abc_mro_len3,      abc.ABC.__mro__.__len__,              [],  2,  "ABC.__mro__.__len__() == 2 (ABC->object; 2 entries; 1 shorter than ABCMeta mro=3); verified with Python 3.14.3"]
    - [abcmeta_mod_len2,  abc.ABCMeta.__module__.__len__,      [],  3,  "ABCMeta.__module__.__len__() == 3 ('abc'=3; same as ABCMeta mro len=3 and ABC name len=3); verified with Python 3.14.3"]
    - [am_mod_len2,       abc.abstractmethod.__module__.__len__, [], 3,  "abstractmethod.__module__.__len__() == 3 ('abc'=3; all three abc entities share module len=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra162
# ---------------------------------------------------------------------------

invariant abc_extra162.abc_ABCMeta_module_len:
  description: "abc.ABCMeta.__module__.__len__() returns 3 — abc.ABCMeta.__module__=='abc' (len=3: 'a'+'b'+'c'=3); the 'abc' module name is just 3 chars long — a very short module name for a foundational module; it is the minimal abbreviation of 'abstract base classes'; ABCMeta.__module__.__len__()==3 is notable because it equals abc.ABC.__name__.__len__()==3 (established in extra161) — the module name length matches the ABC class name length; ABCMeta.__module__.__len__()==3 also equals ABCMeta.__mro__.__len__()==3 (the MRO of ABCMeta also has 3 entries: ABCMeta -> type -> object); compare: abc.get_cache_token.__module__=='_abc' (len=4; from extra161) — the C extension module '_abc' has length 4, one longer than the Python module 'abc'=3 due to the leading underscore; all three public abc entities (ABCMeta, ABC, abstractmethod) have __module__.__len__()==3 because they all live in Lib/abc.py; NEW in extra162: first standalone ABCMeta.__module__.__len__ invariant in abcmodlen162 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__module__.__len__
  args: []
  expected: 3

invariant abc_extra162.abc_ABC_module_len:
  description: "abc.ABC.__module__.__len__() returns 3 — abc.ABC.__module__=='abc' (len=3); ABC is defined in Lib/abc.py alongside ABCMeta — they share the same module 'abc' (len=3); ABC.__module__.__len__()==3 establishes the TRIPLE COINCIDENCE: abc.ABC.__name__.__len__()==3 (established in extra161: 'ABC'=3), abc.ABC.__module__.__len__()==3 ('abc'=3), and abc.ABC.__mro__.__len__()==2... wait: ABC.__mro__.__len__()==2 (NOT 3); so the module length (3) does NOT equal the MRO length (2) for ABC; but for ABCMeta: ABCMeta.__mro__.__len__()==3 == ABCMeta.__module__.__len__()==3 (THESE match); compare: abc.ABC.__module__.__len__()==3 vs abc.ABC.__name__.__len__()==3 — both are 3, so ABC name length equals its module name length: 'ABC'=3 == 'abc'=3 (one uppercase, one lowercase, same 3-char alphabetic string); NEW in extra162: first standalone ABC.__module__.__len__ invariant in abcmodlen162 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__module__.__len__
  args: []
  expected: 3

invariant abc_extra162.abc_abstractmethod_module_len:
  description: "abc.abstractmethod.__module__.__len__() returns 3 — abc.abstractmethod.__module__=='abc' (len=3); abstractmethod is defined in Lib/abc.py — the same module as ABCMeta and ABC; abstractmethod.__module__.__len__()==3 confirms that all three core abc entities (ABCMeta, ABC, abstractmethod) share __module__=='abc' (len=3); compare: abc.abstractmethod.__name__.__len__()==14 (established in extra161: 'abstractmethod'=14) vs abstractmethod.__module__.__len__()==3 ('abc'=3); the function name (14 chars) is 11 chars longer than its module name (3 chars) — the function name is nearly 5x longer than the module it lives in; this contrasts with abc.get_cache_token which is in '_abc' (len=4 from extra161): abstractmethod is in the Python module 'abc'=3 while get_cache_token is in the C module '_abc'=4; NEW in extra162: first standalone abstractmethod.__module__.__len__ invariant in abcmodlen162 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__module__.__len__
  args: []
  expected: 3

invariant abc_extra162.abc_ABCMeta_mro_len:
  description: "abc.ABCMeta.__mro__.__len__() returns 3 — abc.ABCMeta.__mro__ is the tuple (ABCMeta, type, object) with exactly 3 entries; ABCMeta IS-A type (ABCMeta is a metaclass that extends the built-in 'type' metaclass; any class whose metaclass is ABCMeta gains the abstract-method enforcement machinery); the MRO ABCMeta -> type -> object captures: ABCMeta (the abc metaclass), type (the built-in metaclass base — all metaclasses are subclasses of type), object (the universal base); ABCMeta.__mro__.__len__()==3 COINCIDES with ABCMeta.__module__.__len__()==3 ('abc'=3) — both the MRO length and the module name length are 3; compare: abc.ABC.__mro__.__len__()==2 (ABC has a shorter 2-entry MRO because it is a regular class, not a metaclass); ABCMeta MRO len(3) > ABC MRO len(2) by 1 — the extra 'type' entry in ABCMeta's MRO accounts for the difference; NEW in extra162: first standalone ABCMeta.__mro__.__len__ invariant in abcabcmetamro162 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra162.abc_ABC_mro_len:
  description: "abc.ABC.__mro__.__len__() returns 2 — abc.ABC.__mro__ is the tuple (ABC, object) with exactly 2 entries; abc.ABC is a regular class (not a metaclass) that uses ABCMeta as its metaclass; the class ABC itself inherits only from object — ABC.__bases__ == (<class 'object'>,); the 2-entry MRO [ABC, object] is the minimal MRO for any class that inherits from nothing else; compare: abc.ABCMeta.__mro__.__len__()==3 (ABCMeta has a 3-entry MRO because ABCMeta IS a metaclass extending type — type adds the intermediate entry between ABCMeta and object); ABC MRO len(2) < ABCMeta MRO len(3) by 1 — the difference is the presence of 'type' in ABCMeta's MRO; NOTE: abc.ABC.__mro__.__len__()==2 is DIFFERENT from abc.ABC.__name__.__len__()==3 (MRO length is 2, name length is 3 — these are separate quantities); compare: asyncio.AbstractEventLoop.__mro__.__len__()==2 (AbstractEventLoop -> object; same 2-entry MRO as abc.ABC; both are regular classes with no intermediate parent); NEW in extra162: first standalone ABC.__mro__.__len__ invariant in abcabcmro162 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__mro__.__len__
  args: []
  expected: 2
