spec: asyncio_extra50
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio queues documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio coroutines and tasks"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "This spec extends asyncio_extra49.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__() (extra30: Queue.put/get/put_nowait/get_nowait/join/task_done; Lock.acquire/release), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, MRO depths, AbstractEventLoop/__name__/__len__() tables, BaseEventLoop/Handle/TimerHandle/Protocol/StreamReader lengths, Event/Semaphore method __qualname__ string values, BoundedSemaphore/Condition/TaskGroup/Runner identity, shield/ensure_future/create_task/get_event_loop/get_running_loop/new_event_loop/run/iscoroutine/iscoroutinefunction qualname/module, class/function __qualname__ string equality tables, Task/Future/Runner __qualname__.__len__(), Task/Future __name__/__module__/__qualname__, Task/__bases__[0].__name__=='Future', Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/TaskGroup/Runner/Task/Future __class__.__name__=='type', gather/sleep/run __class__.__name__=='function', class/function __class__.__name__.__len__() tables (extra47), Queue/Lock/Event/Semaphore/Task/Future __class__.__qualname__=='type', gather/sleep/run __class__.__qualname__=='function', class/function __class__.__qualname__.__len__() tables (extra48), QueueEmpty/QueueFull __class__.__name__=='type', QueueEmpty/QueueFull __bases__[0].__name__=='Exception', QueueEmpty/QueueFull __mro__.__len__()==4, exception __module__ string equality for QueueEmpty/QueueFull/InvalidStateError/TimeoutError/CancelledError (extra49)."
    - "This spec covers: Queue/__doc__/__class__/__name__=='str'; Lock/__doc__/__class__/__name__=='str'; Event/__doc__/__class__/__name__=='str'; Semaphore/__doc__/__class__/__name__=='str'; Task/__doc__/__class__/__name__=='str'; Future/__doc__/__class__/__name__=='str'; QueueEmpty/__doc__/__class__/__name__=='str'; QueueFull/__doc__/__class__/__name__=='str'; asyncio module __doc__/__class__/__name__=='str'; Queue/__doc__/__class__/__qualname__=='str'; Lock/__doc__/__class__/__qualname__=='str'; asyncio module __doc__/__class__/__qualname__=='str'."
    - "asyncio.Queue.__doc__.__class__.__name__ == 'str'. Class docstrings are compiled by Python into __doc__ attributes of type str. Queue has a non-None docstring describing its asyncio.Queue API; its __class__ is the built-in str type, so __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__doc__.__class__.__name__ == 'str'. The Lock class docstring is stored as a plain Python string. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__doc__.__class__.__name__ == 'str'. The Event class docstring is stored as a plain Python string. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__doc__.__class__.__name__ == 'str'. The Semaphore class docstring is stored as a plain Python string. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__doc__.__class__.__name__ == 'str'. Task is implemented as a C extension in _asyncio; its docstring is still exposed as a plain Python string with __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__doc__.__class__.__name__ == 'str'. Future is implemented as a C extension in _asyncio; its docstring is exposed as a plain Python string with __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueEmpty.__doc__.__class__.__name__ == 'str'. QueueEmpty is a lightweight exception class defined in asyncio.queues; its docstring is a plain Python string. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.QueueFull.__doc__.__class__.__name__ == 'str'. QueueFull is a lightweight exception class defined in asyncio.queues; its docstring is a plain Python string. __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__doc__.__class__.__name__ == 'str'. The asyncio module itself has a module-level docstring accessible as asyncio.__doc__. Module docstrings are plain Python strings; __class__.__name__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__doc__.__class__.__qualname__ == 'str'. The built-in str type has no enclosing class or function scope, so __qualname__ == __name__ == 'str'. This is consistent with all built-in types across the spec series. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__doc__.__class__.__qualname__ == 'str'. Same reasoning as Queue: the docstring is a str instance; str.__qualname__ == 'str'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.__doc__.__class__.__qualname__ == 'str'. The module docstring is a str instance; str.__qualname__ == 'str'. Consistent with abc_extra44 which captured the same pattern for abc.__doc__. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio class __doc__.__class__.__name__ — extra50
#
# All asyncio class and exception docstrings are instances of the built-in
# str type. Python compiles docstring literals into __doc__ attributes whose
# type is always str, so __doc__.__class__.__name__ == 'str' universally:
#   Queue.__doc__.__class__.__name__      == 'str'
#   Lock.__doc__.__class__.__name__       == 'str'
#   Event.__doc__.__class__.__name__      == 'str'
#   Semaphore.__doc__.__class__.__name__  == 'str'
#   Task.__doc__.__class__.__name__       == 'str'
#   Future.__doc__.__class__.__name__     == 'str'
#   QueueEmpty.__doc__.__class__.__name__ == 'str'
#   QueueFull.__doc__.__class__.__name__  == 'str'
# Prior specs (extra30–extra49) covered __class__.__name__ for the classes
# themselves but never traversed into the __doc__ dimension. Extra50 opens
# the __doc__ dimension for asyncio for the first time.
# ---------------------------------------------------------------------------

table asyncio_extra50.class_doc_class_name_eq:
  description: "asyncio class __doc__.__class__.__name__ string equality in extra50 namespace — all class docstrings are str instances"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciodoc50clsname

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,      Queue.__doc__.__class__.__name__.__eq__,      ["str"], true, "Queue.__doc__.__class__.__name__ == 'str' — Queue class docstring is a plain Python string"]
    - [Lock,       Lock.__doc__.__class__.__name__.__eq__,       ["str"], true, "Lock.__doc__.__class__.__name__ == 'str' — Lock class docstring is a plain Python string"]
    - [Event,      Event.__doc__.__class__.__name__.__eq__,      ["str"], true, "Event.__doc__.__class__.__name__ == 'str' — Event class docstring is a plain Python string"]
    - [Semaphore,  Semaphore.__doc__.__class__.__name__.__eq__,  ["str"], true, "Semaphore.__doc__.__class__.__name__ == 'str' — Semaphore class docstring is a plain Python string"]
    - [Task,       Task.__doc__.__class__.__name__.__eq__,       ["str"], true, "Task.__doc__.__class__.__name__ == 'str' — Task is C-implemented; docstring exposed as plain Python string"]
    - [Future,     Future.__doc__.__class__.__name__.__eq__,     ["str"], true, "Future.__doc__.__class__.__name__ == 'str' — Future is C-implemented; docstring exposed as plain Python string"]
    - [QueueEmpty, QueueEmpty.__doc__.__class__.__name__.__eq__, ["str"], true, "QueueEmpty.__doc__.__class__.__name__ == 'str' — exception class docstring is a plain Python string"]
    - [QueueFull,  QueueFull.__doc__.__class__.__name__.__eq__,  ["str"], true, "QueueFull.__doc__.__class__.__name__ == 'str' — exception class docstring is a plain Python string"]

# ---------------------------------------------------------------------------
# asyncio module __doc__.__class__.__name__ — extra50
#
# The asyncio module itself carries a module-level docstring accessible via
# asyncio.__doc__ (or just __doc__ within the backend scope). Module
# docstrings are plain Python strings, so __doc__.__class__.__name__ == 'str'.
# This is the module-level counterpart to the class-level checks above.
# ---------------------------------------------------------------------------

invariant asyncio_extra50.module_doc_class_name_eq:
  description: "asyncio.__doc__.__class__.__name__ == 'str' — module-level docstring is a plain Python string; __class__ is built-in str type"
  category: class_names
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio class __doc__.__class__.__qualname__ — extra50
#
# The built-in str type has __qualname__ == __name__ == 'str' because it
# has no enclosing class or function scope. Therefore every docstring (a str
# instance) has __doc__.__class__.__qualname__ == 'str'. This is verified
# here for Queue, Lock, and the module docstring:
#   Queue.__doc__.__class__.__qualname__  == 'str'
#   Lock.__doc__.__class__.__qualname__   == 'str'
#   asyncio.__doc__.__class__.__qualname__ == 'str'
# The __qualname__ == __name__ identity for built-in types is consistent
# across all spec series (abc_extra44, concurrent_futures_extra46, etc.).
# ---------------------------------------------------------------------------

table asyncio_extra50.doc_class_qualname_eq:
  description: "asyncio __doc__.__class__.__qualname__ string equality in extra50 namespace — Queue, Lock, and module docstrings all have __class__.__qualname__ == 'str'"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciodoc50clsqual

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,  Queue.__doc__.__class__.__qualname__.__eq__,  ["str"], true, "Queue.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope)"]
    - [Lock,   Lock.__doc__.__class__.__qualname__.__eq__,   ["str"], true, "Lock.__doc__.__class__.__qualname__ == 'str' — built-in str type has __qualname__ == __name__ == 'str' (no enclosing scope)"]
    - [module, __doc__.__class__.__qualname__.__eq__,        ["str"], true, "asyncio.__doc__.__class__.__qualname__ == 'str' — module docstring is a str; str.__qualname__ == 'str'"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra50
# ---------------------------------------------------------------------------

