spec: ipaddr_js
version: ">=1.0.0"
backend: node(ipaddr.js)

docs: https://github.com/whitequark/ipaddr.js#readme

provenance:
  derived_from:
    - "ipaddr.js README — https://github.com/whitequark/ipaddr.js#readme"
    - "Test vectors verified with ipaddr.js@1.9.1 pre-installed in theseus repo, 2026-04-24"
  not_derived_from:
    - "ipaddr.js source: lib/ipaddr.js"
  notes:
    - "ipaddr.js exports { isValid, parse, process, fromByteArray, parseCIDR }."
    - "isValid(str) returns true if str is a valid IPv4 or IPv6 address."
    - "parse(str) returns an object with 'octets' (IPv4) or 'parts' (IPv6) array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "isValid returns boolean; parse returns object. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ipaddr_js.isValid:
  kind: node_module_call_eq
  function: isValid
  category: isValid
  id_prefix: ip_valid

  columns: [id, args, expected]
  rows:
    - [v4_valid,  ["192.168.1.1"],  true]
    - [v6_valid,  ["::1"],          true]
    - [invalid,   ["not-an-ip"],    false]
    - [empty,     [""],             false]

table ipaddr_js.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: ip_parse

  columns: [id, args, expected]
  rows:
    - [loopback,  ["127.0.0.1"],   {"octets": [127, 0, 0, 1]}]
    - [private,   ["10.0.0.1"],    {"octets": [10, 0, 0, 1]}]
