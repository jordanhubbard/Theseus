spec: ipaddr_js
version: ">=1.9.0"
backend: node(ipaddr.js)

docs: https://www.npmjs.com/package/ipaddr.js

provenance:
  derived_from:
    - "ipaddr.js README — https://www.npmjs.com/package/ipaddr.js"
    - "Test vectors verified with ipaddr.js via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "ipaddr.js source"
  notes:
    - "ipaddr.js is an npm package. Install: npm install ipaddr.js"
    - "ipaddr.isValid(str) checks if a string is a valid IPv4 or IPv6 address."
    - "ipaddr.parse(str).kind() returns 'ipv4' or 'ipv6'."
    - "ipaddr.parse(str).range() returns the address range (e.g. 'private', 'loopback')."
    - "ipaddr.parse(str).toByteArray() returns the address as a byte array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean, string, or byte array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ipaddr_js.isValid:
  kind: node_module_call_eq
  function: isValid
  category: validate
  id_prefix: ipaddrval

  columns: [id, args, expected]
  rows:
    - [v4_valid,  ["192.168.1.1"],  true]
    - [v6_valid,  ["2001:db8::1"],  true]
    - [invalid,   ["not.an.ip"],    false]

table ipaddr_js.kind:
  kind: node_factory_call_eq
  factory: parse
  method: kind
  category: classify
  id_prefix: ipaddrk

  columns: [id, factory_args, expected]
  rows:
    - [v4, ["192.168.1.1"], "ipv4"]
    - [v6, ["2001:db8::1"], "ipv6"]

table ipaddr_js.toByteArray:
  kind: node_factory_call_eq
  factory: parse
  method: toByteArray
  category: convert
  id_prefix: ipaddrba

  columns: [id, factory_args, expected]
  rows:
    - [loopback, ["127.0.0.1"], [127, 0, 0, 1]]
    - [private,  ["192.168.1.1"], [192, 168, 1, 1]]
