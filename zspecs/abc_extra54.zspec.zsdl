spec: abc_extra54
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/library/importlib.html#importlib.machinery.SourceFileLoader — SourceFileLoader documentation"
    - "https://docs.python.org/3/reference/import.html#module-spec — ModuleSpec documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "CPython source: Lib/_frozen_importlib.py"
  notes:
    - "This spec extends abc_extra53.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2)/abstractproperty(3)/abstractclassmethod(3)/abstractstaticmethod(3), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() tables, ABCMeta/__dict__.__class__.__name__.__eq__('mappingproxy') (extra9), ABC/__dict__.__class__.__name__.__eq__('mappingproxy') (extra8), ABCMeta/__dict__.__class__.__qualname__ and ABC/__dict__.__class__.__qualname__ (extra49), abstractproperty/abstractclassmethod/abstractstaticmethod __dict__.__class__.__name__.__eq__('mappingproxy') (extra49), abc module __dict__.__class__.__name__/__qualname__ (extra49), abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta' (extra40), __class__.__qualname__ string equality for all abc exports (extra41-extra43), abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', abstractclassmethod/__class__.__module__=='builtins', abstractstaticmethod/__class__.__module__=='builtins' (extra42), abstractproperty/__init__.__class__.__name__=='wrapper_descriptor', abstractmethod/__init__.__class__.__name__=='method-wrapper' (extra50), __class__.__module__.__len__() cross-checks (extra50), __repr__.__class__.__name__ for all abc objects (extra51), __weakref__.__class__.__name__ for abstractproperty/abstractclassmethod/abstractstaticmethod (extra51), ABCMeta.__instancecheck__/__subclasscheck__.__class__.__name__.__eq__('function') (extra52), ABC/ABCMeta __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra52), abc.__package__.__eq__('') (extra53), ABC/ABCMeta/abstractmethod/get_cache_token __doc__.__class__.__name__.__eq__('str') (extra53), ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') (extra53). NOTE: abc has no __all__ — confirmed in extra52; hasattr(abc, '__all__') is False in Python 3.14.3."
    - "This spec covers (abcload54 namespace): wave 225 theme — __loader__ identity + __spec__ attribute chains + __file__ check. IMPORTANT: In Python 3.14.3, abc is loaded via FrozenImporter (not SourceFileLoader). abc.__loader__ is the FrozenImporter class object itself (not an instance), so abc.__loader__.__class__.__name__ == 'type' (NOT 'SourceFileLoader'). The correct loader identity assertion for abc is abc.__loader__.__name__.__eq__('FrozenImporter') — the NAME attribute on the class is 'FrozenImporter'. abc has no __cached__ attribute in Python 3.14.3 (FrozenImporter-loaded modules do not have __cached__). abc.__spec__.__class__.__name__.__eq__('ModuleSpec') — still valid; all modules have a ModuleSpec. abc.__file__.__class__.__name__.__eq__('str') — still valid; abc.__file__ points to Lib/abc.py as a str even when loaded frozen. Additional wave 225 check: ABCMeta.__instancecheck__.__qualname__.__len__()==25 — cross-check of the qualname string length confirmed in extra53."
    - "abc.__loader__.__class__.__name__ == 'type'. In Python 3.14.3, abc is a frozen module loaded by FrozenImporter. abc.__loader__ is the FrozenImporter class object itself (not an instance of FrozenImporter). The class of a class is 'type'; therefore abc.__loader__.__class__.__name__ == 'type'. This is distinct from abc.__loader__.__name__ which equals 'FrozenImporter'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__loader__.__name__ == 'FrozenImporter'. abc.__loader__ IS the FrozenImporter class object (from _frozen_importlib). The __name__ attribute of this class is 'FrozenImporter'. __name__.__eq__('FrozenImporter') returns True. This is the correct loader identity assertion for abc in Python 3.14.3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__spec__.__class__.__name__ == 'ModuleSpec'. Every loaded module has a __spec__ attribute containing a ModuleSpec object describing the module's import configuration (even frozen modules). __spec__.__class__.__name__ == 'ModuleSpec'. __eq__('ModuleSpec') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__file__.__class__.__name__ == 'str'. abc.__file__ points to Lib/abc.py as a plain Python str, even though the module is loaded frozen. __file__.__class__.__name__ == 'str'. __eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc has no __cached__ attribute in Python 3.14.3. FrozenImporter-loaded modules do not set __cached__; hasattr(abc, '__cached__') is False. No __cached__ check is included in this spec."
    - "ABCMeta.__instancecheck__.__qualname__.__len__() == 25. 'ABCMeta.__instancecheck__' has 25 characters. This cross-checks the qualname string length confirmed in extra53 via string equality. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc __loader__/__spec__/__file__ class name checks — extra54
#
# Wave 225 theme: __loader__ identity + __spec__ attribute chains +
# __file__ check.
#
# IMPORTANT: abc is loaded via FrozenImporter in Python 3.14.3, NOT
# SourceFileLoader. abc.__loader__ is the FrozenImporter class object itself.
#
# abc.__loader__.__class__.__name__ == 'type'  (loader IS a class; class of class is 'type')
# abc.__loader__.__name__ == 'FrozenImporter'  (the loader class NAME)
# abc.__spec__.__class__.__name__ == 'ModuleSpec'
# abc.__file__.__class__.__name__ == 'str'
#
# NOTE: abc has NO __cached__ attribute in Python 3.14.3 (not set by FrozenImporter).
#
# No prior abc spec has captured __loader__.__class__.__name__,
# __loader__.__name__, __spec__.__class__.__name__, or __file__.__class__.__name__
# as string equality checks. Extra54 introduces this wave 225 theme in abcload54.
# ---------------------------------------------------------------------------

table abc_extra54.loader_spec_file:
  description: "abc __loader__/__spec__/__file__ class name checks in abcload54 namespace — abc is a frozen module loaded by FrozenImporter in Python 3.14.3 (NOT SourceFileLoader); abc.__loader__ IS the FrozenImporter class object so __loader__.__class__.__name__ == 'type' and __loader__.__name__ == 'FrozenImporter'; __spec__ is a ModuleSpec object; __file__ is a plain Python str; abc has no __cached__ attribute (FrozenImporter does not set it); wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__ check; first loader/spec/file class name checks in any abc spec"
  kind: python_call_eq
  category: loader_identity
  id_prefix: abcload54

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name,  __loader__.__class__.__name__.__eq__, ["type"],            true, "abc.__loader__.__class__.__name__ == 'type' — abc is a frozen module; abc.__loader__ IS the FrozenImporter class object (from _frozen_importlib), not an instance; the class of a class is 'type'; __loader__.__class__.__name__.__eq__('type') returns True; contrast with SourceFileLoader modules where __loader__ is an instance and __class__.__name__ == 'SourceFileLoader'; wave 225 first __loader__.__class__.__name__ check in any abc spec"]
    - [loader_name,        __loader__.__name__.__eq__,           ["FrozenImporter"],  true, "abc.__loader__.__name__ == 'FrozenImporter' — abc.__loader__ IS the FrozenImporter class object; the NAME attribute of this class is 'FrozenImporter'; __loader__.__name__.__eq__('FrozenImporter') returns True; this is the correct loader identity assertion for abc in Python 3.14.3; wave 225 first __loader__.__name__ check in any abc spec"]
    - [spec_class_name,    __spec__.__class__.__name__.__eq__,   ["ModuleSpec"],      true, "abc.__spec__.__class__.__name__ == 'ModuleSpec' — Python's import machinery stores module metadata in a ModuleSpec object even for frozen modules; __spec__ is a ModuleSpec instance; __spec__.__class__.__name__.__eq__('ModuleSpec') returns True; wave 225 first __spec__.__class__.__name__ check in any abc spec"]
    - [file_class_name,    __file__.__class__.__name__.__eq__,   ["str"],             true, "abc.__file__.__class__.__name__ == 'str' — abc.__file__ points to Lib/abc.py as a plain Python str even though the module is loaded frozen; __file__.__class__.__name__.__eq__('str') returns True; wave 225 first __file__.__class__.__name__ check in any abc spec; note: abc has no __cached__ attribute (FrozenImporter does not set it)"]

# ---------------------------------------------------------------------------
# ABCMeta.__instancecheck__.__qualname__.__len__() cross-check — extra54
#
# Wave 225 bonus check: extra53 confirmed that ABCMeta.__instancecheck__.__qualname__
# == 'ABCMeta.__instancecheck__' via string equality. This table provides the
# cross-check: __qualname__.__len__() == 25 (length of 'ABCMeta.__instancecheck__').
#
# This is a second dimension of the same invariant, placed in abcload54 to
# complement the qualname string equality in extra53's abcpkg53instcheck table.
# ---------------------------------------------------------------------------

table abc_extra54.instancecheck_qualname_len:
  description: "abc ABCMeta.__instancecheck__.__qualname__.__len__() cross-check in abcload54 namespace — 'ABCMeta.__instancecheck__' has 25 characters; this cross-checks the qualname string equality confirmed in extra53 (abcpkg53instcheck table); ABCMeta overrides __instancecheck__ in pure Python (Lib/abc.py); first standalone __qualname__.__len__ cross-check for __instancecheck__ in abcload54 namespace"
  kind: python_call_eq
  category: qualname
  id_prefix: abcload54instchecklen

  columns: [id, function, args, expected, description]
  rows:
    - [qualname_len, ABCMeta.__instancecheck__.__qualname__.__len__, [], 25, "ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — 'ABCMeta.__instancecheck__' has 25 characters (A-B-C-M-e-t-a-.-_-_-i-n-s-t-a-n-c-e-c-h-e-c-k-_-_); ABCMeta overrides __instancecheck__ in pure Python (Lib/abc.py); this cross-checks the qualname string equality established in extra53; wave 225 __qualname__.__len__() cross-check in abcload54 namespace"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra54
# ---------------------------------------------------------------------------

invariant abc_extra54.loader_class_name_eq:
  description: "abc.__loader__.__class__.__name__.__eq__('type') returns True — abc is a frozen module in Python 3.14.3; abc.__loader__ IS the FrozenImporter class object, not an instance; the class of a class is 'type'; __loader__.__class__.__name__ == 'type'; wave 225 first __loader__.__class__.__name__ invariant in any abc spec"
  category: loader_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra54.loader_name_eq:
  description: "abc.__loader__.__name__.__eq__('FrozenImporter') returns True — abc.__loader__ IS the FrozenImporter class object (from _frozen_importlib); its __name__ attribute is 'FrozenImporter'; this is the correct loader identity assertion for abc in Python 3.14.3 where abc is frozen; wave 225 first __loader__.__name__ invariant in any abc spec"
  category: loader_identity
  kind: python_call_eq
  function: __loader__.__name__.__eq__
  args: ["FrozenImporter"]
  expected: true

invariant abc_extra54.spec_class_name_eq:
  description: "abc.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — abc module spec is a ModuleSpec object even for frozen modules; __spec__.__class__.__name__ == 'ModuleSpec'; wave 225 first __spec__.__class__.__name__ invariant in any abc spec"
  category: loader_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant abc_extra54.file_class_name_eq:
  description: "abc.__file__.__class__.__name__.__eq__('str') returns True — abc.__file__ points to Lib/abc.py as a plain Python str even though the module is loaded frozen; __file__.__class__.__name__ == 'str'; wave 225 first __file__.__class__.__name__ invariant in any abc spec"
  category: loader_identity
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra54.instancecheck_qualname_len:
  description: "ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — 'ABCMeta.__instancecheck__' has 25 characters; cross-checks the qualname string equality confirmed in extra53; ABCMeta overrides __instancecheck__ in pure Python (Lib/abc.py); wave 225 __qualname__.__len__ cross-check in abcload54 namespace"
  category: qualname
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25
