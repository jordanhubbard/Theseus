spec: concurrent_futures_extra280
version: ">=3.14"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3.14/library/concurrent.futures.html#concurrent.futures.InterpreterPoolExecutor — InterpreterPoolExecutor (Python 3.14)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/interpreter.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "concurrent_futures_extra28.zspec.zsdl — covers __all__ metadata, class __dict__.__class__.__name__.__len__(), Future internal method qualname lengths, function __module__ lengths"
    - "concurrent_futures_extra.zspec.zsdl — covers Future/ThreadPoolExecutor/ProcessPoolExecutor/__name__/__module__, CancelledError/TimeoutError/BrokenExecutor identity, wait/as_completed names, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED type checks"
  notes:
    - "This spec covers: concurrent.futures.InterpreterPoolExecutor (new in Python 3.14) class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()); InterpreterPoolExecutor method qualname lengths (submit, map, shutdown); concurrent.futures.interpreter submodule identity (__name__, __spec__.name, __name__.__len__(), __package__, __loader__.__class__.__name__); concurrent.futures._base module identity (__name__, __spec__.name, __package__.__len__(), __loader__.__class__.__name__)."
    - "concurrent.futures.InterpreterPoolExecutor was introduced in Python 3.14 to support running tasks in isolated sub-interpreters (PEP 734). It inherits from ThreadPoolExecutor. __module__ == 'concurrent.futures.interpreter'; __bases__[0].__name__ == 'ThreadPoolExecutor'; __mro__.__len__() == 4. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "InterpreterPoolExecutor.__name__.__len__() == 23 ('InterpreterPoolExecutor'); __module__.__len__() == 30 ('concurrent.futures.interpreter'); __qualname__ == __name__ (top-level class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "InterpreterPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25) — inherited from ThreadPoolExecutor, not overridden. InterpreterPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27) — also inherited. InterpreterPoolExecutor.map.__qualname__ == 'Executor.map' (len=12) — inherited from the base Executor class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.interpreter.__name__ == 'concurrent.futures.interpreter' (len=30); __package__ == 'concurrent.futures'; __loader__.__class__.__name__ == 'SourceFileLoader'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures._base.__name__ == 'concurrent.futures._base' (len=24); __package__ == 'concurrent.futures' (len=18); __loader__.__class__.__name__ == 'SourceFileLoader'. The _base submodule is the private implementation module where Future, Executor, wait(), as_completed(), and the LOGGER are defined. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.InterpreterPoolExecutor class identity — extra280
#
# New in Python 3.14 (PEP 734). InterpreterPoolExecutor runs tasks in
# isolated sub-interpreters via thread-based dispatch, inheriting from
# ThreadPoolExecutor.
#
# InterpreterPoolExecutor.__name__               == 'InterpreterPoolExecutor'  (len=23)
# InterpreterPoolExecutor.__module__             == 'concurrent.futures.interpreter'  (len=30)
# InterpreterPoolExecutor.__qualname__           == 'InterpreterPoolExecutor'
# InterpreterPoolExecutor.__bases__[0].__name__  == 'ThreadPoolExecutor'
# InterpreterPoolExecutor.__mro__.__len__()      == 4
# ---------------------------------------------------------------------------

table concurrent_futures_extra280.interpreter_pool_executor_identity:
  description: "concurrent.futures.InterpreterPoolExecutor class identity in extra280 namespace — new in Python 3.14 (PEP 734); inherits from ThreadPoolExecutor; __module__=='concurrent.futures.interpreter' (len=30); __mro__.__len__()==4 ([InterpreterPoolExecutor, ThreadPoolExecutor, Executor, object]); __name__.__len__()==23; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ipexec280

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,     InterpreterPoolExecutor.__name__.__eq__,              ["InterpreterPoolExecutor"],          true,  "InterpreterPoolExecutor.__name__ == 'InterpreterPoolExecutor'; verified with Python 3.14.3"]
    - [module_eq,   InterpreterPoolExecutor.__module__.__eq__,            ["concurrent.futures.interpreter"],   true,  "InterpreterPoolExecutor.__module__ == 'concurrent.futures.interpreter'; verified with Python 3.14.3"]
    - [qualname_eq, InterpreterPoolExecutor.__qualname__.__eq__,          ["InterpreterPoolExecutor"],          true,  "InterpreterPoolExecutor.__qualname__ == 'InterpreterPoolExecutor' (top-level class); verified with Python 3.14.3"]
    - [base_eq,     "InterpreterPoolExecutor.__bases__[0].__name__.__eq__", ["ThreadPoolExecutor"],             true,  "InterpreterPoolExecutor.__bases__[0].__name__ == 'ThreadPoolExecutor'; verified with Python 3.14.3"]
    - [mro_len,     InterpreterPoolExecutor.__mro__.__len__,              [],                                   4,     "InterpreterPoolExecutor.__mro__.__len__() == 4 ([IPE, ThreadPoolExecutor, Executor, object]); verified with Python 3.14.3"]
    - [name_len,    InterpreterPoolExecutor.__name__.__len__,             [],                                   23,    "InterpreterPoolExecutor.__name__.__len__() == 23 ('InterpreterPoolExecutor'=23); verified with Python 3.14.3"]
    - [module_len,  InterpreterPoolExecutor.__module__.__len__,           [],                                   30,    "InterpreterPoolExecutor.__module__.__len__() == 30 ('concurrent.futures.interpreter'=30); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# InterpreterPoolExecutor inherited method __qualname__ lengths — extra280
#
# InterpreterPoolExecutor does not override submit, map, or shutdown — they
# are inherited from ThreadPoolExecutor and Executor respectively:
#   submit.__qualname__   == 'ThreadPoolExecutor.submit'   (len=25, from ThreadPoolExecutor)
#   shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27, from ThreadPoolExecutor)
#   map.__qualname__      == 'Executor.map'                (len=12, from base Executor)
# shutdown has the longest qualname of the three (27 chars).
# ---------------------------------------------------------------------------

table concurrent_futures_extra280.ipe_inherited_method_qualname_lengths:
  description: "concurrent.futures.InterpreterPoolExecutor inherited method __qualname__.__len__() in extra280 namespace — submit/shutdown from ThreadPoolExecutor; map from Executor; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: ipemqualnamelen280

  columns: [id, function, args, expected]
  rows:
    - [submit,   InterpreterPoolExecutor.submit.__qualname__.__len__,   [], 25]
    - [shutdown, InterpreterPoolExecutor.shutdown.__qualname__.__len__, [], 27]
    - [map,      InterpreterPoolExecutor.map.__qualname__.__len__,      [], 12]

# ---------------------------------------------------------------------------
# concurrent.futures.interpreter submodule identity — extra280
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra280.interpreter_module_name_eq:
  description: "concurrent.futures.interpreter.__name__ == 'concurrent.futures.interpreter' — the interpreter submodule added for InterpreterPoolExecutor in Python 3.14"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.interpreter.__name__.__eq__
  args: ["concurrent.futures.interpreter"]
  expected: true

invariant concurrent_futures_extra280.interpreter_module_name_len:
  description: "concurrent.futures.interpreter.__name__.__len__() == 30 — 'concurrent.futures.interpreter' is 30 characters"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.interpreter.__name__.__len__
  args: []
  expected: 30

invariant concurrent_futures_extra280.interpreter_module_loader_eq:
  description: "concurrent.futures.interpreter.__loader__.__class__.__name__ == 'SourceFileLoader' — plain Python source module"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.interpreter.__loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures._base submodule identity — extra280
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra280.base_module_name_eq:
  description: "concurrent.futures._base.__name__ == 'concurrent.futures._base' — private implementation module"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.__name__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra280.base_module_name_len:
  description: "concurrent.futures._base.__name__.__len__() == 24 — 'concurrent.futures._base' is 24 characters"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.__name__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra280.base_module_package_len:
  description: "concurrent.futures._base.__package__.__len__() == 18 — 'concurrent.futures' is 18 characters"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.__package__.__len__
  args: []
  expected: 18

invariant concurrent_futures_extra280.ipe_submit_qualname_eq:
  description: "concurrent.futures.InterpreterPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' — method inherited from ThreadPoolExecutor, not overridden"
  category: method_names
  kind: python_call_eq
  function: InterpreterPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra280.ipe_map_qualname_eq:
  description: "concurrent.futures.InterpreterPoolExecutor.map.__qualname__ == 'Executor.map' — map is inherited from the base Executor class (len=12)"
  category: method_names
  kind: python_call_eq
  function: InterpreterPoolExecutor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true
