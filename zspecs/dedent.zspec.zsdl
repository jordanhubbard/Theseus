spec: dedent
version: ">=1.7.2"
backend: node(dedent)

docs: https://www.npmjs.com/package/dedent

provenance:
  derived_from:
    - "dedent README — https://www.npmjs.com/package/dedent"
    - "Test vectors verified with dedent via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "dedent source"
  notes:
    - "dedent is an npm package. Install: npm install dedent"
    - "Removes common leading whitespace from multiline strings."
    - "ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table dedent.dedent:
  kind: node_module_call_eq
  function: "default"
  category: string
  id_prefix: dedent

  columns: [id, args, expected]
  rows:
    - [two_spaces,   ["  hello\n  world"],  "hello\nworld"]
    - [four_spaces,  ["    a\n    b"],       "a\nb"]
