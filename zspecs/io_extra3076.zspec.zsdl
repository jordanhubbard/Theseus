spec: io3076
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 652 (io3076): __get__, __set__, __delete__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper, io.IOBase."
    - "None of the io stream classes define the descriptor protocol in their own __dict__: __get__, __set__, and __delete__ are all absent."
    - "The io module classes are I/O stream implementations, not descriptors; they do not implement the descriptor protocol."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
#
# No io stream class defines __get__ in its own __dict__; all false.
# io classes are I/O abstractions, not descriptor objects.
# ---------------------------------------------------------------------------

table io3076.get:
  description: "io types __get__ dict-presence checks; wave 652"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3076

  columns: [id, function, args, expected]
  rows:
    - ["io3076001", operator.contains, [io.RawIOBase.__dict__,      "__get__"], false]
    - ["io3076002", operator.contains, [io.BufferedIOBase.__dict__,  "__get__"], false]
