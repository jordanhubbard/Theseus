spec: struct_extra916
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __qualname__ attributes of struct module functions, error class, and Struct class"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra916.pack_unpack_qualnames:
  description: "struct pack/unpack function __qualname__ identity"
  kind: python_call_eq
  category: pack_unpack_qualnames
  id_prefix: st916pu
  columns: [id, function, args, expected]
  rows:
    - [st916pu001, struct.pack.__qualname__.__eq__,        ["pack"],        true]
    - [st916pu002, struct.unpack.__qualname__.__eq__,      ["unpack"],      true]
    - [st916pu003, struct.pack_into.__qualname__.__eq__,   ["pack_into"],   true]
    - [st916pu004, struct.unpack_from.__qualname__.__eq__, ["unpack_from"], true]
    - [st916pu005, struct.iter_unpack.__qualname__.__eq__, ["iter_unpack"], true]
    - [st916pu006, struct.calcsize.__qualname__.__eq__,    ["calcsize"],    true]

table struct_extra916.class_qualnames:
  description: "struct.Struct and struct.error __qualname__ identity"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: st916cq
  columns: [id, function, args, expected]
  rows:
    - [st916cq001, struct.Struct.__qualname__.__eq__, ["Struct"], true]
    - [st916cq002, struct.error.__qualname__.__eq__,  ["error"],  true]

table struct_extra916.module_identity:
  description: "struct module-level identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: st916mi
  columns: [id, function, args, expected]
  rows:
    - [st916mi001, struct.pack.__module__.__eq__,        ["struct"], true]
    - [st916mi002, struct.unpack.__module__.__eq__,      ["struct"], true]
    - [st916mi003, struct.pack_into.__module__.__eq__,   ["struct"], true]
    - [st916mi004, struct.unpack_from.__module__.__eq__, ["struct"], true]
    - [st916mi005, struct.calcsize.__module__.__eq__,    ["struct"], true]
    - [st916mi006, struct.Struct.__module__.__eq__,      ["struct"], true]
    - [st916mi007, struct.error.__module__.__eq__,       ["struct"], true]
    - [st916mi008, struct.Struct.__class__.__name__.__eq__, ["type"],   true]
    - [st916mi009, struct.error.__class__.__name__.__eq__,  ["type"],   true]
