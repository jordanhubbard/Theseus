spec: inspect_extra83
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra82

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra82.zspec.zsdl."
    - "This spec covers: inspect signature/Parameter/Signature __qualname__ and __module__ (Wave 247)."
    - "inspect.signature.__code__.co_name == 'signature' — pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_argcount == 1 — signature(obj, ...) takes 1 positional argument (obj); follow_wrapped is keyword-only. Verified with Python 3.14.3."
    - "inspect.signature.__module__ == 'inspect' — defined in the inspect module. Verified with Python 3.14.3."
    - "inspect.signature.__qualname__ == 'signature' — pure-Python function qualname. Verified with Python 3.14.3."
    - "inspect.Signature.__name__ == 'Signature' — class name. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' — defined in the inspect module. Verified with Python 3.14.3."
    - "inspect.Signature.__qualname__ == 'Signature' — class qualname. Verified with Python 3.14.3."
    - "inspect.Parameter.__name__ == 'Parameter' — class name. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' — defined in the inspect module. Verified with Python 3.14.3."
    - "inspect.Parameter.__qualname__ == 'Parameter' — class qualname. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__name__ == 'BoundArguments' — class name. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect' — defined in the inspect module. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__qualname__ == 'BoundArguments' — class qualname. Verified with Python 3.14.3."
    - "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object. Verified with Python 3.14.3."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.signature function code attrs and __module__/__qualname__ — extra83
#
# Wave 247 theme: inspect.signature function code attributes and identity.
#
# inspect.signature.__code__.co_name     == 'signature'
# inspect.signature.__code__.co_argcount == 1
# inspect.signature.__module__           == 'inspect'
# inspect.signature.__qualname__         == 'signature'
#
# No prior inspect spec checks signature code attrs/__module__/__qualname__ via inspectextra83. New to extra83.
# ---------------------------------------------------------------------------

table inspect_extra83.signature_func_attrs:
  description: "signature.__code__.co_name=='signature', co_argcount==1; signature.__module__=='inspect'; signature.__qualname__=='signature'; wave 247 inspect signature attrs; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra83

  columns: [id, function, args, expected, description]
  rows:
    - [signature_code_co_name_eq_signature,
       signature.__code__.co_name.__eq__,
       ["signature"],
       true,
       "inspect.signature.__code__.co_name.__eq__('signature') == True — signature is a pure-Python function defined in Lib/inspect.py; its code object co_name records the function name 'signature' (9 chars); str.__eq__('signature') returns True; no prior inspect spec checks signature.__code__.co_name via inspectextra83; new to extra83"]
    - [signature_code_co_argcount_eq_1,
       signature.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.signature.__code__.co_argcount.__eq__(1) == True — signature(obj, ...) takes exactly one positional argument: obj; follow_wrapped and globals are keyword-only; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks signature.__code__.co_argcount via inspectextra83; new to extra83"]
    - [signature_module_eq_inspect,
       signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — signature is a pure-Python function defined in Lib/inspect.py; its __module__ attribute records 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks signature.__module__ via inspectextra83; new to extra83"]
    - [signature_qualname_eq_signature,
       signature.__qualname__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__qualname__.__eq__('signature') == True — signature is a pure-Python function defined in Lib/inspect.py; its __qualname__ attribute is the string 'signature' (9 chars); str.__eq__('signature') returns True; no prior inspect spec checks signature.__qualname__ via inspectextra83; new to extra83"]

# ---------------------------------------------------------------------------
# inspect.Signature class identity attributes — extra83
#
# Wave 247 theme: inspect.Signature class __name__/__module__/__qualname__.
#
# inspect.Signature.__name__     == 'Signature'
# inspect.Signature.__module__   == 'inspect'
# inspect.Signature.__qualname__ == 'Signature'
# inspect.Signature.__bases__[0].__name__ == 'object'
#
# No prior inspect spec checks Signature class identity via inspectextra83. New to extra83.
# ---------------------------------------------------------------------------

table inspect_extra83.Signature_class_identity:
  description: "Signature.__name__=='Signature'; Signature.__module__=='inspect'; Signature.__qualname__=='Signature'; Signature.__bases__[0].__name__=='object'; wave 247 inspect Signature class identity; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra83

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_name_eq_Signature,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature is a pure-Python class defined in Lib/inspect.py; its __name__ attribute is the string 'Signature' (9 chars); str.__eq__('Signature') returns True; no prior inspect spec checks Signature.__name__ via inspectextra83; new to extra83"]
    - [Signature_module_eq_inspect,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is a pure-Python class defined in Lib/inspect.py; its __module__ attribute records 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks Signature.__module__ via inspectextra83; new to extra83"]
    - [Signature_qualname_eq_Signature,
       Signature.__qualname__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__qualname__.__eq__('Signature') == True — Signature is a pure-Python class defined in Lib/inspect.py; its __qualname__ attribute is the string 'Signature' (9 chars); str.__eq__('Signature') returns True; no prior inspect spec checks Signature.__qualname__ via inspectextra83; new to extra83"]
    - [Signature_bases0_name_eq_object,
       "Signature.__bases__.__getitem__(0).__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature inherits directly from object; __bases__[0] is object; object.__name__ is 'object' (6 chars); str.__eq__('object') returns True; no prior inspect spec checks Signature.__bases__[0].__name__ via inspectextra83; new to extra83"]

# ---------------------------------------------------------------------------
# inspect.Parameter class identity attributes — extra83
#
# Wave 247 theme: inspect.Parameter class __name__/__module__/__qualname__.
#
# inspect.Parameter.__name__     == 'Parameter'
# inspect.Parameter.__module__   == 'inspect'
# inspect.Parameter.__qualname__ == 'Parameter'
# inspect.Parameter.__bases__[0].__name__ == 'object'
#
# No prior inspect spec checks Parameter class identity via inspectextra83. New to extra83.
# ---------------------------------------------------------------------------

table inspect_extra83.Parameter_class_identity:
  description: "Parameter.__name__=='Parameter'; Parameter.__module__=='inspect'; Parameter.__qualname__=='Parameter'; Parameter.__bases__[0].__name__=='object'; wave 247 inspect Parameter class identity; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra83

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_name_eq_Parameter,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a pure-Python class defined in Lib/inspect.py; its __name__ attribute is the string 'Parameter' (9 chars); str.__eq__('Parameter') returns True; no prior inspect spec checks Parameter.__name__ via inspectextra83; new to extra83"]
    - [Parameter_module_eq_inspect,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is a pure-Python class defined in Lib/inspect.py; its __module__ attribute records 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks Parameter.__module__ via inspectextra83; new to extra83"]
    - [Parameter_qualname_eq_Parameter,
       Parameter.__qualname__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is a pure-Python class defined in Lib/inspect.py; its __qualname__ attribute is the string 'Parameter' (9 chars); str.__eq__('Parameter') returns True; no prior inspect spec checks Parameter.__qualname__ via inspectextra83; new to extra83"]
    - [Parameter_bases0_name_eq_object,
       "Parameter.__bases__.__getitem__(0).__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object; __bases__[0] is object; object.__name__ is 'object' (6 chars); str.__eq__('object') returns True; no prior inspect spec checks Parameter.__bases__[0].__name__ via inspectextra83; new to extra83"]

# ---------------------------------------------------------------------------
# inspect.BoundArguments class identity attributes — extra83
#
# Wave 247 theme: inspect.BoundArguments class __name__/__module__/__qualname__.
#
# inspect.BoundArguments.__name__     == 'BoundArguments'
# inspect.BoundArguments.__module__   == 'inspect'
# inspect.BoundArguments.__qualname__ == 'BoundArguments'
# inspect.BoundArguments.__bases__[0].__name__ == 'object'
#
# No prior inspect spec checks BoundArguments class identity via inspectextra83. New to extra83.
# ---------------------------------------------------------------------------

table inspect_extra83.BoundArguments_class_identity:
  description: "BoundArguments.__name__=='BoundArguments'; BoundArguments.__module__=='inspect'; BoundArguments.__qualname__=='BoundArguments'; BoundArguments.__bases__[0].__name__=='object'; wave 247; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra83

  columns: [id, function, args, expected, description]
  rows:
    - [BoundArguments_name_eq_BoundArguments,
       BoundArguments.__name__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments is a pure-Python class defined in Lib/inspect.py; its __name__ attribute is the string 'BoundArguments' (14 chars); str.__eq__('BoundArguments') returns True; no prior inspect spec checks BoundArguments.__name__ via inspectextra83; new to extra83"]
    - [BoundArguments_module_eq_inspect,
       BoundArguments.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is a pure-Python class defined in Lib/inspect.py; its __module__ attribute records 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks BoundArguments.__module__ via inspectextra83; new to extra83"]
    - [BoundArguments_qualname_eq_BoundArguments,
       BoundArguments.__qualname__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — BoundArguments is a pure-Python class defined in Lib/inspect.py; its __qualname__ attribute is the string 'BoundArguments' (14 chars); str.__eq__('BoundArguments') returns True; no prior inspect spec checks BoundArguments.__qualname__ via inspectextra83; new to extra83"]
    - [BoundArguments_bases0_name_eq_object,
       "BoundArguments.__bases__.__getitem__(0).__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments inherits directly from object; __bases__[0] is object; object.__name__ is 'object' (6 chars); str.__eq__('object') returns True; no prior inspect spec checks BoundArguments.__bases__[0].__name__ via inspectextra83; new to extra83"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra83
# ---------------------------------------------------------------------------

invariant inspect_extra83.signature_co_name:
  description: "inspect.signature.__code__.co_name.__eq__('signature') == True — signature code object name is 'signature'; wave 247 inspect signature attrs; new to extra83"
  kind: python_call_eq
  function: signature.__code__.co_name.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra83.signature_module:
  description: "inspect.signature.__module__.__eq__('inspect') == True — signature is defined in Lib/inspect.py; wave 247 inspect signature module; new to extra83"
  kind: python_call_eq
  function: signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra83.Signature_module:
  description: "inspect.Signature.__module__.__eq__('inspect') == True — Signature class is defined in Lib/inspect.py; wave 247 inspect Signature module; new to extra83"
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra83.Parameter_module:
  description: "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter class is defined in Lib/inspect.py; wave 247 inspect Parameter module; new to extra83"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra83.BoundArguments_module:
  description: "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments class is defined in Lib/inspect.py; wave 247 inspect BoundArguments module; new to extra83"
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true
