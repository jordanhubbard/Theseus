spec: warnings_extra18
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
  notes:
    - "This spec extends prior warnings specs through warnings_extra17.zspec.zsdl."
    - "Focus: __qualname__ values for module-level warnings functions and the catch_warnings class."
    - "Module-level functions have __qualname__ equal to their simple name (no class prefix)."
    - "warnings.DeprecationWarning is NOT an attribute of the warnings module — it is a builtin; accessing warnings.DeprecationWarning raises AttributeError."
    - "warnings.warn.__qualname__ == 'warn' — module-level function."
    - "warnings.warn_explicit.__qualname__ == 'warn_explicit' — module-level function."
    - "warnings.filterwarnings.__qualname__ == 'filterwarnings' — module-level function."
    - "warnings.simplefilter.__qualname__ == 'simplefilter' — module-level function."
    - "warnings.resetwarnings.__qualname__ == 'resetwarnings' — module-level function."
    - "warnings.catch_warnings.__qualname__ == 'catch_warnings' — top-level class (context manager)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warnings module-level function __qualname__ values
#
# For module-level functions, __qualname__ equals the simple function name.
# No prior warnings spec records __qualname__ for these five functions.
# ---------------------------------------------------------------------------

invariant warnings_extra18.warn.qualname:
  description: "warnings.warn.__qualname__ == 'warn'"
  category: function_qualname
  kind: python_call_eq
  function: warn.__qualname__.__eq__
  args: ["warn"]
  expected: true

invariant warnings_extra18.warn_explicit.qualname:
  description: "warnings.warn_explicit.__qualname__ == 'warn_explicit'"
  category: function_qualname
  kind: python_call_eq
  function: warn_explicit.__qualname__.__eq__
  args: ["warn_explicit"]
  expected: true

invariant warnings_extra18.filterwarnings.qualname:
  description: "warnings.filterwarnings.__qualname__ == 'filterwarnings'"
  category: function_qualname
  kind: python_call_eq
  function: filterwarnings.__qualname__.__eq__
  args: ["filterwarnings"]
  expected: true

invariant warnings_extra18.simplefilter.qualname:
  description: "warnings.simplefilter.__qualname__ == 'simplefilter'"
  category: function_qualname
  kind: python_call_eq
  function: simplefilter.__qualname__.__eq__
  args: ["simplefilter"]
  expected: true

invariant warnings_extra18.resetwarnings.qualname:
  description: "warnings.resetwarnings.__qualname__ == 'resetwarnings'"
  category: function_qualname
  kind: python_call_eq
  function: resetwarnings.__qualname__.__eq__
  args: ["resetwarnings"]
  expected: true

# ---------------------------------------------------------------------------
# warnings.catch_warnings class __qualname__ value
#
# catch_warnings is a top-level class (used as a context manager).
# Its __qualname__ equals its class name.
# No prior warnings spec records __qualname__ for catch_warnings.
# ---------------------------------------------------------------------------

invariant warnings_extra18.catch_warnings.qualname:
  description: "warnings.catch_warnings.__qualname__ == 'catch_warnings'"
  category: class_qualname
  kind: python_call_eq
  function: catch_warnings.__qualname__.__eq__
  args: ["catch_warnings"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all six __qualname__ checks
#
# Covers warn/warn_explicit/filterwarnings/simplefilter/resetwarnings
# (functions) and catch_warnings (class).
# ---------------------------------------------------------------------------

table warnings_extra18.qualnames:
  description: "__qualname__ values for warnings module-level functions and catch_warnings class"
  kind: python_call_eq
  category: function_qualname

  columns: [id, function, args, expected]
  rows:
    - [warn,           warn.__qualname__.__eq__,           ["warn"],           true]
    - [warn_explicit,  warn_explicit.__qualname__.__eq__,  ["warn_explicit"],  true]
    - [filterwarnings, filterwarnings.__qualname__.__eq__,  ["filterwarnings"], true]
    - [simplefilter,   simplefilter.__qualname__.__eq__,   ["simplefilter"],   true]
    - [resetwarnings,  resetwarnings.__qualname__.__eq__,  ["resetwarnings"],  true]
    - [catch_warnings, catch_warnings.__qualname__.__eq__,  ["catch_warnings"], true]
