spec: re_extra195
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra194.zspec.zsdl."
    - "This spec covers re module constants and flags: re.IGNORECASE.__class__.__name__, re.IGNORECASE.__class__.__module__, re.MULTILINE.__class__.__name__, re.DOTALL.__class__.__name__, re.VERBOSE.__class__.__name__, re.RegexFlag.__name__, re.RegexFlag.__module__, re.RegexFlag.__bases__[0].__name__."
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag' (len=9); all re flag constants are instances of the RegexFlag enum; confirmed Python 3.14.3 macOS."
    - "re.IGNORECASE.__class__.__module__ == 're' (len=2); the RegexFlag enum is defined in the re module; confirmed Python 3.14.3 macOS."
    - "re.MULTILINE.__class__.__name__ == 'RegexFlag' — all flag instances share the same class; confirmed Python 3.14.3 macOS."
    - "re.DOTALL.__class__.__name__ == 'RegexFlag' — confirmed Python 3.14.3 macOS."
    - "re.VERBOSE.__class__.__name__ == 'RegexFlag' — confirmed Python 3.14.3 macOS."
    - "re.RegexFlag.__name__ == 'RegexFlag' (len=9); confirmed Python 3.14.3 macOS."
    - "re.RegexFlag.__module__ == 're' (len=2); confirmed Python 3.14.3 macOS."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (len=7); RegexFlag inherits from IntFlag, allowing bitwise combination and integer coercion; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re flag constants class identity
# all IGNORECASE, MULTILINE, DOTALL, VERBOSE are RegexFlag instances
# ---------------------------------------------------------------------------

table re_extra195.flag_class_names:
  description: "re flag constants class names: IGNORECASE, MULTILINE, DOTALL, VERBOSE — all __class__.__name__ == 'RegexFlag'"
  kind: python_call_eq
  category: identity
  id_prefix: reflags195

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_class_eq, re.IGNORECASE.__class__.__name__.__eq__, ["RegexFlag"], true, "re.IGNORECASE.__class__.__name__ == 'RegexFlag' (len=9); IGNORECASE is a RegexFlag enum member; confirmed Python 3.14.3 macOS"]
    - [multiline_class_eq,  re.MULTILINE.__class__.__name__.__eq__,  ["RegexFlag"], true, "re.MULTILINE.__class__.__name__ == 'RegexFlag'; same class as IGNORECASE; confirmed Python 3.14.3 macOS"]
    - [dotall_class_eq,     re.DOTALL.__class__.__name__.__eq__,     ["RegexFlag"], true, "re.DOTALL.__class__.__name__ == 'RegexFlag'; same class as IGNORECASE; confirmed Python 3.14.3 macOS"]
    - [verbose_class_eq,    re.VERBOSE.__class__.__name__.__eq__,    ["RegexFlag"], true, "re.VERBOSE.__class__.__name__ == 'RegexFlag'; same class as IGNORECASE; confirmed Python 3.14.3 macOS"]
    - [ignorecase_class_len, re.IGNORECASE.__class__.__name__.__len__, [], 9, "re.IGNORECASE.__class__.__name__.__len__() == 9 — R(1)e(2)g(3)e(4)x(5)F(6)l(7)a(8)g(9); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.RegexFlag class identity attributes
# __name__(RegexFlag,9), __module__(re,2), __bases__[0].__name__(IntFlag,7)
# ---------------------------------------------------------------------------

table re_extra195.regexflag_class_identity:
  description: "re.RegexFlag class identity: __name__='RegexFlag'(9), __module__='re'(2), __bases__[0].__name__='IntFlag'(7)"
  kind: python_call_eq
  category: identity
  id_prefix: reflags195

  columns: [id, function, args, expected, description]
  rows:
    - [regexflag_name_eq,   re.RegexFlag.__name__.__eq__,                          ["RegexFlag"], true, "re.RegexFlag.__name__ == 'RegexFlag' (len=9); confirmed Python 3.14.3 macOS"]
    - [regexflag_module_eq, re.RegexFlag.__module__.__eq__,                        ["re"],        true, "re.RegexFlag.__module__ == 're' (len=2); RegexFlag is defined in the re module; confirmed Python 3.14.3 macOS"]
    - [regexflag_base_eq,   "re.RegexFlag.__bases__[0].__name__.__eq__",           ["IntFlag"],   true, "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (len=7); RegexFlag inherits from IntFlag allowing bitwise combination; confirmed Python 3.14.3 macOS"]
    - [regexflag_name_len,  re.RegexFlag.__name__.__len__,                         [],            9,    "re.RegexFlag.__name__.__len__() == 9 — R(1)e(2)g(3)e(4)x(5)F(6)l(7)a(8)g(9); confirmed Python 3.14.3 macOS"]
    - [regexflag_module_len, re.RegexFlag.__module__.__len__,                      [],            2,    "re.RegexFlag.__module__.__len__() == 2 — r(1)e(2); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re flag constants module identity
# IGNORECASE.__class__.__module__ == 're', RegexFlag.__bases__[0] lengths
# ---------------------------------------------------------------------------

table re_extra195.flag_module_and_base_lengths:
  description: "re flag constants module identity and base class lengths: IGNORECASE.__class__.__module__='re'(2), RegexFlag.__bases__[0].__name__='IntFlag'(7)"
  kind: python_call_eq
  category: identity
  id_prefix: reflags195

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_module_eq,  re.IGNORECASE.__class__.__module__.__eq__, ["re"], true, "re.IGNORECASE.__class__.__module__ == 're' (len=2); the RegexFlag enum lives in the re module; confirmed Python 3.14.3 macOS"]
    - [ignorecase_module_len, re.IGNORECASE.__class__.__module__.__len__, [], 2, "re.IGNORECASE.__class__.__module__.__len__() == 2 — r(1)e(2); confirmed Python 3.14.3 macOS"]
    - [regexflag_base_len,    "re.RegexFlag.__bases__[0].__name__.__len__",  [], 7, "re.RegexFlag.__bases__[0].__name__.__len__() == 7 — I(1)n(2)t(3)F(4)l(5)a(6)g(7); confirmed Python 3.14.3 macOS"]
    - [regexflag_name_len2,   re.RegexFlag.__name__.__len__, [], 9, "re.RegexFlag.__name__.__len__() == 9; same length as IGNORECASE.__class__.__name__; confirmed Python 3.14.3 macOS"]
    - [regexflag_base_name_eq, "re.RegexFlag.__bases__[0].__name__.__eq__", ["IntFlag"], true, "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (len=7); IntFlag enables bitwise OR combination of flag values and integer coercion; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra195.ignorecase_class_name_eq:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — IGNORECASE is an instance of the RegexFlag enum (len=9); all re flag constants (IGNORECASE, MULTILINE, DOTALL, VERBOSE, etc.) are members of the RegexFlag enum; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra195.ignorecase_class_module_eq:
  description: "re.IGNORECASE.__class__.__module__ == 're' — the RegexFlag enum is defined in the re module (len=2); the module attribute on the class confirms the public module ownership; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.IGNORECASE.__class__.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra195.multiline_class_name_eq:
  description: "re.MULTILINE.__class__.__name__ == 'RegexFlag' — MULTILINE is a member of the RegexFlag enum; all flag constants share the same class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.MULTILINE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra195.dotall_class_name_eq:
  description: "re.DOTALL.__class__.__name__ == 'RegexFlag' — DOTALL is a member of the RegexFlag enum; DOTALL makes '.' match any character including newlines; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.DOTALL.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra195.verbose_class_name_eq:
  description: "re.VERBOSE.__class__.__name__ == 'RegexFlag' — VERBOSE is a member of the RegexFlag enum; VERBOSE allows whitespace and comments in patterns; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.VERBOSE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra195.regexflag_name_eq:
  description: "re.RegexFlag.__name__ == 'RegexFlag' — the class name is 'RegexFlag' (len=9); re.RegexFlag is the enum class that all re flag constants belong to; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra195.regexflag_module_eq:
  description: "re.RegexFlag.__module__ == 're' — the RegexFlag class is defined in the re module (len=2); this is consistent with re.Pattern.__module__ which also reports 're'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra195.regexflag_base_name_eq:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from IntFlag (len=7); IntFlag is a subclass of int and Flag that allows bitwise combination of members and integer coercion; this means re flag constants can be combined with | and tested with & operators; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

