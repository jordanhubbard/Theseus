spec: concurrent_futures_extra1666
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "Theme: __new__ — object construction protocol; which concurrent.futures classes define custom __new__."
    - "concurrent.futures.Future is a pure-Python class; Future.__dict__.__contains__('__new__') is False — no custom __new__."
    - "concurrent.futures.Future.__dict__.__contains__('__init__') is True — Future.__init__ initialises _state, _result, _exception, _waiters, _done_callbacks, and internal locks."
    - "concurrent.futures.Executor is an abstract base class; Executor.__dict__.__contains__('__new__') is False — no custom __new__."
    - "concurrent.futures.Executor.__dict__.__contains__('__init__') is False — Executor provides no __init__; subclasses supply their own."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__new__') is False — pure Python, no custom __new__."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__init__') is True — ThreadPoolExecutor.__init__ sets max_workers, thread_name_prefix, initializer, and initargs."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__new__') is False — pure Python, no custom __new__."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__init__') is True — ProcessPoolExecutor.__init__ sets max_workers, mp_context, initializer, and initargs."
    - "Executor defines submit(), map(), and shutdown() as abstract or concrete methods, but no __init__."
    - "Both ThreadPoolExecutor and ProcessPoolExecutor inherit from Executor; none in the hierarchy override __new__."
    - "The consistent pattern across concurrent.futures is: __new__ is never customised; __init__ does all instance setup."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent_futures_extra1666.new_init_checks
#
# All four public classes: Future, Executor, ThreadPoolExecutor,
# ProcessPoolExecutor.  Checks __new__ (absent) and __init__ (present/absent).
# ---------------------------------------------------------------------------

table concurrent_futures_extra1666.new_init_checks:
  description: "concurrent.futures public classes — __new__ and __init__ presence in class __dict__: Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor all lack __new__ (False); Future, ThreadPoolExecutor, ProcessPoolExecutor define __init__ (True); Executor is abstract and lacks __init__ (False); the construction protocol for all concrete classes is object.__new__ followed by the class's own __init__; verified with Python 3.14.4"
  kind: python_call_eq
  category: new_init_presence
  id_prefix: cf1666ni

  columns: [id, function, args, expected]
  rows:
    - ["cf1666ni001", "concurrent.futures.Future.__dict__.__contains__",               ["__new__"],  false]
    - ["cf1666ni002", "concurrent.futures.Future.__dict__.__contains__",               ["__init__"], true]
    - ["cf1666ni003", "concurrent.futures.Executor.__dict__.__contains__",             ["__new__"],  false]
    - ["cf1666ni004", "concurrent.futures.Executor.__dict__.__contains__",             ["__init__"], false]
    - ["cf1666ni005", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["__new__"],  false]
    - ["cf1666ni006", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["__init__"], true]
    - ["cf1666ni007", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",  ["__new__"],  false]
    - ["cf1666ni008", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",  ["__init__"], true]
    - ["cf1666ni009", "concurrent.futures.Future.__dict__.__contains__",               ["cancel"],   true]
    - ["cf1666ni010", "concurrent.futures.Future.__dict__.__contains__",               ["result"],   true]
    - ["cf1666ni011", "concurrent.futures.Future.__dict__.__contains__,",              ["done"],     true]
    - ["cf1666ni012", "concurrent.futures.Future.__dict__.__contains__",               ["running"],  true]
    - ["cf1666ni013", "concurrent.futures.Executor.__dict__.__contains__",             ["submit"],   true]
    - ["cf1666ni014", "concurrent.futures.Executor.__dict__.__contains__",             ["map"],      true]
    - ["cf1666ni015", "concurrent.futures.Executor.__dict__.__contains__",             ["shutdown"], true]

# ---------------------------------------------------------------------------
# Table 2: concurrent_futures_extra1666.executor_method_presence
#
# ThreadPoolExecutor and ProcessPoolExecutor method presence, class name,
# and base class checks to confirm identity and inheritance.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1666.executor_method_presence:
  description: "ThreadPoolExecutor and ProcessPoolExecutor identity and method presence: both inherit from Executor; both define __init__, submit, and shutdown; class names are 'ThreadPoolExecutor' and 'ProcessPoolExecutor'; bases[0] is 'Executor' for both; neither overrides __new__; verified with Python 3.14.4"
  kind: python_call_eq
  category: executor_identity
  id_prefix: cf1666ex

  columns: [id, function, args, expected]
  rows:
    - ["cf1666ex001", "concurrent.futures.ThreadPoolExecutor.__name__.__eq__",                           ["ThreadPoolExecutor"],   true]
    - ["cf1666ex002", "concurrent.futures.ThreadPoolExecutor.__name__.__len__",                          [],                       18]
    - ["cf1666ex003", "concurrent.futures.ProcessPoolExecutor.__name__.__eq__",                          ["ProcessPoolExecutor"],  true]
    - ["cf1666ex004", "concurrent.futures.ProcessPoolExecutor.__name__.__len__",                         [],                       19]
    - ["cf1666ex005", "concurrent.futures.ThreadPoolExecutor.__bases__.__getitem__",                     [0],                      null]
    - ["cf1666ex006", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",                     ["submit"],               true]
    - ["cf1666ex007", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",                     ["shutdown"],             true]
    - ["cf1666ex008", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",                    ["submit"],               true]
    - ["cf1666ex009", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",                    ["shutdown"],             true]
    - ["cf1666ex010", "concurrent.futures.Future.__name__.__eq__",                                       ["Future"],               true]
    - ["cf1666ex011", "concurrent.futures.Future.__name__.__len__",                                      [],                       6]
    - ["cf1666ex012", "concurrent.futures.Executor.__name__.__eq__",                                     ["Executor"],             true]
    - ["cf1666ex013", "concurrent.futures.Executor.__name__.__len__",                                    [],                       8]
    - ["cf1666ex014", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",                     ["__new__"],              false]
    - ["cf1666ex015", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",                    ["__new__"],              false]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra1666
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1666.future_no_custom_new:
  description: "concurrent.futures.Future.__dict__.__contains__('__new__') returns False — concurrent.futures.Future is a pure-Python class defined in Lib/concurrent/futures/_base.py; it does not define a custom __new__; object.__new__ is used to allocate the instance; all state (locks, callbacks, result, exception, state machine) is set up in Future.__init__; the absence of __new__ in __dict__ is the canonical signal that no custom allocation protocol is used; verified with Python 3.14.4"
  category: new_absent
  kind: python_call_eq
  function: "concurrent.futures.Future.__dict__.__contains__"
  args: ["__new__"]
  expected: false

invariant concurrent_futures_extra1666.future_has_custom_init:
  description: "concurrent.futures.Future.__dict__.__contains__('__init__') returns True — Future.__init__ sets _condition (a threading.Condition), _state='PENDING', _result=None, _exception=None, _waiters=[], and _done_callbacks=[]; all observable state is initialised in __init__; __new__ is not involved; this is the standard two-phase (allocation + initialisation) pattern without customising allocation; verified with Python 3.14.4"
  category: init_present
  kind: python_call_eq
  function: "concurrent.futures.Future.__dict__.__contains__"
  args: ["__init__"]
  expected: true

invariant concurrent_futures_extra1666.executor_no_init:
  description: "concurrent.futures.Executor.__dict__.__contains__('__init__') returns False — Executor is an abstract base class that provides submit(), map(), and shutdown() but deliberately omits __init__; subclasses (ThreadPoolExecutor, ProcessPoolExecutor) supply their own __init__; Executor has no instance state to initialise; the absence of __init__ from Executor.__dict__ means calls to super().__init__() from subclasses fall through to object.__init__; verified with Python 3.14.4"
  category: init_absent
  kind: python_call_eq
  function: "concurrent.futures.Executor.__dict__.__contains__"
  args: ["__init__"]
  expected: false

invariant concurrent_futures_extra1666.thread_pool_executor_no_new:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__new__') returns False — ThreadPoolExecutor is a pure-Python subclass of Executor; it defines __init__(self, max_workers=None, thread_name_prefix='', initializer=None, initargs=()) to configure the thread pool; no custom __new__ is needed because the class has no need to control memory layout or alter the type of the constructed object; object.__new__ handles allocation; verified with Python 3.14.4"
  category: new_absent
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__"
  args: ["__new__"]
  expected: false

invariant concurrent_futures_extra1666.process_pool_executor_no_new:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__new__') returns False — ProcessPoolExecutor is a pure-Python subclass of Executor; it defines __init__(self, max_workers=None, mp_context=None, initializer=None, initargs=()) to configure the worker process pool; __new__ is absent from its class __dict__; object.__new__ is used for allocation; the two-executor design (ThreadPool and ProcessPool) follows the same protocol: no custom __new__, custom __init__ only; verified with Python 3.14.4"
  category: new_absent
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__"
  args: ["__new__"]
  expected: false
