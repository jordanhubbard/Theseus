spec: pathlib_extra203
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/parts/parent/joinpath/str/as_posix/relative_to"
    - "pathlib_extra.zspec.zsdl — covers Path class name/module, PurePosixPath component/parent/truediv/parts/is_absolute"
  notes:
    - "This spec covers pathlib.Path stat/glob/iterdir method qualnames not already in pathlib.zspec.zsdl or pathlib_extra.zspec.zsdl."
    - "pathlib.Path.stat.__qualname__ == 'Path.stat' — method defined on the Path class."
    - "pathlib.Path.glob.__qualname__ == 'Path.glob' — method defined on the Path class."
    - "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' — method defined on the Path class."
    - "pathlib.Path.rglob.__qualname__ == 'Path.rglob' — method defined on the Path class."
    - "pathlib.Path.rename.__qualname__ == 'Path.rename' — method defined on the Path class."
    - "pathlib.Path.replace.__qualname__ == 'Path.replace' — method defined on the Path class."
    - "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to' — method defined on the Path class."
    - "pathlib.Path.resolve.__qualname__ == 'Path.resolve' — method defined on the Path class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path filesystem query method qualnames — stat, glob, iterdir
# ---------------------------------------------------------------------------

table pathlib_extra203.path_query_method_qualnames:
  description: "pathlib.Path filesystem query method qualnames in pathlibmethods2203 namespace — stat, glob, iterdir qualnames all use 'Path.' prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibmethods2203

  columns: [id, function, args, expected, description]
  rows:
    - [stat_qn,    Path.stat.__qualname__.__eq__,    ["Path.stat"],    true, "pathlib.Path.stat.__qualname__ == 'Path.stat' (len=9); verified with Python 3.14.3"]
    - [glob_qn,    Path.glob.__qualname__.__eq__,    ["Path.glob"],    true, "pathlib.Path.glob.__qualname__ == 'Path.glob' (len=9); verified with Python 3.14.3"]
    - [iterdir_qn, Path.iterdir.__qualname__.__eq__, ["Path.iterdir"], true, "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' (len=12); verified with Python 3.14.3"]
    - [rglob_qn,   Path.rglob.__qualname__.__eq__,   ["Path.rglob"],   true, "pathlib.Path.rglob.__qualname__ == 'Path.rglob' (len=10); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# pathlib.Path filesystem mutation method qualnames — rename, replace, symlink_to
# ---------------------------------------------------------------------------

table pathlib_extra203.path_mutation_method_qualnames:
  description: "pathlib.Path filesystem mutation method qualnames in pathlibmethods2203 namespace — rename, replace, symlink_to qualnames all use 'Path.' prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibmethods2203b

  columns: [id, function, args, expected, description]
  rows:
    - [rename_qn,     Path.rename.__qualname__.__eq__,     ["Path.rename"],     true, "pathlib.Path.rename.__qualname__ == 'Path.rename' (len=11); verified with Python 3.14.3"]
    - [replace_qn,    Path.replace.__qualname__.__eq__,    ["Path.replace"],    true, "pathlib.Path.replace.__qualname__ == 'Path.replace' (len=12); verified with Python 3.14.3"]
    - [symlink_to_qn, Path.symlink_to.__qualname__.__eq__, ["Path.symlink_to"], true, "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to' (len=15); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# pathlib.Path.resolve qualname and length
# ---------------------------------------------------------------------------

table pathlib_extra203.path_resolve_qualname:
  description: "pathlib.Path.resolve qualname in pathlibmethods2203 namespace — resolve qualname is 'Path.resolve' (len=12); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pathlibmethods2203c

  columns: [id, function, args, expected, description]
  rows:
    - [resolve_qn,     Path.resolve.__qualname__.__eq__,    ["Path.resolve"], true, "pathlib.Path.resolve.__qualname__ == 'Path.resolve' (len=12); verified with Python 3.14.3"]
    - [resolve_qn_len, Path.resolve.__qualname__.__len__,   [],               12,   "pathlib.Path.resolve.__qualname__.__len__() == 12 ('Path.'=5+'resolve'=7); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — pathlibmethods2203
# ---------------------------------------------------------------------------

invariant pathlib_extra203.Path.stat_qualname_eq:
  description: "pathlib.Path.stat.__qualname__.__eq__('Path.stat') returns True — stat() returns a os.stat_result for the path; qualname 'Path.stat' has len=9 ('Path.'=5+'stat'=4=9); stat() requires the path to exist (raises FileNotFoundError otherwise); compare: iterdir qualname='Path.iterdir' len=12, symlink_to qualname='Path.symlink_to' len=15 (longest in spec); NEW in pathlib_extra203: first standalone Path.stat qualname invariant in pathlibmethods2203 namespace; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.stat.__qualname__.__eq__
  args: ["Path.stat"]
  expected: true

invariant pathlib_extra203.Path.glob_qualname_eq:
  description: "pathlib.Path.glob.__qualname__.__eq__('Path.glob') returns True — glob() yields all matching files under the path using a Unix-style pattern; qualname 'Path.glob' has len=9 ('Path.'=5+'glob'=4=9); compare: rglob qualname='Path.rglob' len=10 (one more char); stat qualname='Path.stat' also len=9; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.glob.__qualname__.__eq__
  args: ["Path.glob"]
  expected: true

invariant pathlib_extra203.Path.iterdir_qualname_len:
  description: "pathlib.Path.iterdir.__qualname__.__len__() == 12 — 'Path.iterdir' has 12 chars ('Path.'=5+'iterdir'=7=12); iterdir() yields Path objects for all entries in the directory; compare: replace qualname='Path.replace' also len=12; resolve qualname='Path.resolve' also len=12; stat/glob len=9 (shortest); symlink_to len=15 (longest); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.iterdir.__qualname__.__len__
  args: []
  expected: 12

invariant pathlib_extra203.Path.rglob_qualname_len:
  description: "pathlib.Path.rglob.__qualname__.__len__() == 10 — 'Path.rglob' has 10 chars ('Path.'=5+'rglob'=5=10); rglob() is equivalent to glob('**/' + pattern) — recursively matches everywhere; compare: glob qualname='Path.glob' len=9 (one less); rename qualname='Path.rename' len=11; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.rglob.__qualname__.__len__
  args: []
  expected: 10

invariant pathlib_extra203.Path.rename_qualname_len:
  description: "pathlib.Path.rename.__qualname__.__len__() == 11 — 'Path.rename' has 11 chars ('Path.'=5+'rename'=6=11); rename() renames the file or directory to the given target; on POSIX, if target exists it is replaced silently if it names a file; compare: replace qualname='Path.replace' len=12; rglob qualname='Path.rglob' len=10; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.rename.__qualname__.__len__
  args: []
  expected: 11

invariant pathlib_extra203.Path.replace_qualname_len:
  description: "pathlib.Path.replace.__qualname__.__len__() == 12 — 'Path.replace' has 12 chars ('Path.'=5+'replace'=7=12); replace() unconditionally renames the path to target, replacing any existing target; compare: rename qualname='Path.rename' len=11; iterdir qualname='Path.iterdir' also len=12; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.replace.__qualname__.__len__
  args: []
  expected: 12

invariant pathlib_extra203.Path.symlink_to_qualname_eq:
  description: "pathlib.Path.symlink_to.__qualname__.__eq__('Path.symlink_to') returns True — symlink_to() makes the path a symbolic link pointing to target; qualname 'Path.symlink_to' has len=15 ('Path.'=5+'symlink_to'=10=15) — longest method qualname in this spec; compare: resolve qualname='Path.resolve' len=12; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.symlink_to.__qualname__.__eq__
  args: ["Path.symlink_to"]
  expected: true

invariant pathlib_extra203.Path.resolve_qualname_eq:
  description: "pathlib.Path.resolve.__qualname__.__eq__('Path.resolve') returns True — resolve() makes the path absolute, resolving any symlinks; qualname 'Path.resolve' has len=12 ('Path.'=5+'resolve'=7=12); compare qualname lengths in spec: stat=9, glob=9, rglob=10, rename=11, iterdir=12, replace=12, resolve=12, symlink_to=15 (longest); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Path.resolve.__qualname__.__eq__
  args: ["Path.resolve"]
  expected: true

