spec: asyncio_extra217
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-protocol.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html — asyncio Protocols and Transports"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/protocols.py"
    - "CPython source: Lib/asyncio/transports.py"
  notes:
    - "asyncio.Protocol.__module__ == 'asyncio.protocols'."
    - "asyncio.BaseTransport.__module__ == 'asyncio.transports'."
    - "asyncio.Protocol.__bases__[0].__name__ == 'BaseProtocol'."
    - "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport'."
    - "verified with Python 3.14.3."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Protocol class identity — extra217 namespace
#
# asyncio.Protocol, DatagramProtocol, and SubprocessProtocol are defined in
# asyncio.protocols and each inherits from BaseProtocol.
# ---------------------------------------------------------------------------

table asyncio_extra217.protocol_names:
  description: "asyncio Protocol class __name__ checks in extra217 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio217protoname

  columns: [id, function, args, expected, description]
  rows:
    - [protocol_name,           Protocol.__name__.__eq__,           ["Protocol"],           true, "asyncio.Protocol.__name__ == 'Protocol'"]
    - [datagram_protocol_name,  DatagramProtocol.__name__.__eq__,   ["DatagramProtocol"],   true, "asyncio.DatagramProtocol.__name__ == 'DatagramProtocol'"]
    - [subprocess_protocol_name, SubprocessProtocol.__name__.__eq__, ["SubprocessProtocol"], true, "asyncio.SubprocessProtocol.__name__ == 'SubprocessProtocol'"]
    - [base_protocol_name,      BaseProtocol.__name__.__eq__,       ["BaseProtocol"],       true, "asyncio.BaseProtocol.__name__ == 'BaseProtocol'"]

# ---------------------------------------------------------------------------
# asyncio Protocol class module — extra217 namespace
#
# All Protocol classes live in the asyncio.protocols submodule.
# ---------------------------------------------------------------------------

table asyncio_extra217.protocol_modules:
  description: "asyncio Protocol class __module__ checks in extra217 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio217protomod

  columns: [id, function, args, expected, description]
  rows:
    - [protocol_module,           Protocol.__module__.__eq__,           ["asyncio.protocols"], true, "asyncio.Protocol.__module__ == 'asyncio.protocols'"]
    - [datagram_protocol_module,  DatagramProtocol.__module__.__eq__,   ["asyncio.protocols"], true, "asyncio.DatagramProtocol.__module__ == 'asyncio.protocols'"]
    - [subprocess_protocol_module, SubprocessProtocol.__module__.__eq__, ["asyncio.protocols"], true, "asyncio.SubprocessProtocol.__module__ == 'asyncio.protocols'"]
    - [base_protocol_module,      BaseProtocol.__module__.__eq__,       ["asyncio.protocols"], true, "asyncio.BaseProtocol.__module__ == 'asyncio.protocols'"]

# ---------------------------------------------------------------------------
# asyncio Protocol base class — extra217 namespace
#
# Protocol and DatagramProtocol both inherit directly from BaseProtocol.
# ---------------------------------------------------------------------------

table asyncio_extra217.protocol_bases:
  description: "asyncio Protocol __bases__[0].__name__ checks in extra217 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio217protobase

  columns: [id, function, args, expected, description]
  rows:
    - [protocol_base,          "Protocol.__bases__[0].__name__.__eq__",          ["BaseProtocol"], true, "asyncio.Protocol.__bases__[0] is BaseProtocol"]
    - [datagram_protocol_base, "DatagramProtocol.__bases__[0].__name__.__eq__",  ["BaseProtocol"], true, "asyncio.DatagramProtocol.__bases__[0] is BaseProtocol"]

# ---------------------------------------------------------------------------
# asyncio Transport class identity — extra217 namespace
#
# BaseTransport, ReadTransport, WriteTransport, and Transport live in
# asyncio.transports; Transport inherits from ReadTransport.
# ---------------------------------------------------------------------------

table asyncio_extra217.transport_names:
  description: "asyncio Transport class __name__ checks in extra217 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio217transname

  columns: [id, function, args, expected, description]
  rows:
    - [base_transport_name,  BaseTransport.__name__.__eq__,  ["BaseTransport"],  true, "asyncio.BaseTransport.__name__ == 'BaseTransport'"]
    - [read_transport_name,  ReadTransport.__name__.__eq__,  ["ReadTransport"],  true, "asyncio.ReadTransport.__name__ == 'ReadTransport'"]
    - [write_transport_name, WriteTransport.__name__.__eq__, ["WriteTransport"], true, "asyncio.WriteTransport.__name__ == 'WriteTransport'"]
    - [transport_name,       Transport.__name__.__eq__,      ["Transport"],      true, "asyncio.Transport.__name__ == 'Transport'"]

# ---------------------------------------------------------------------------
# asyncio Transport class module — extra217 namespace
# ---------------------------------------------------------------------------

table asyncio_extra217.transport_modules:
  description: "asyncio Transport class __module__ checks in extra217 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio217transmod

  columns: [id, function, args, expected, description]
  rows:
    - [base_transport_module, BaseTransport.__module__.__eq__, ["asyncio.transports"], true, "asyncio.BaseTransport.__module__ == 'asyncio.transports'"]

# ---------------------------------------------------------------------------
# asyncio.Transport base class — extra217 namespace
#
# asyncio.Transport inherits directly from ReadTransport (not WriteTransport
# as first base; check that __bases__[0].__name__ == 'ReadTransport').
# ---------------------------------------------------------------------------

invariant asyncio_extra217.transport_base:
  description: "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport'"
  category: identity
  kind: python_call_eq
  function: "asyncio.Transport.__bases__[0].__name__.__eq__"
  args: ["ReadTransport"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.BaseProtocol name standalone — extra217 namespace
# ---------------------------------------------------------------------------

invariant asyncio_extra217.base_protocol_name:
  description: "asyncio.BaseProtocol.__name__ == 'BaseProtocol'"
  category: identity
  kind: python_call_eq
  function: asyncio.BaseProtocol.__name__.__eq__
  args: ["BaseProtocol"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Protocol module standalone — extra217 namespace
# ---------------------------------------------------------------------------

invariant asyncio_extra217.protocol_module:
  description: "asyncio.Protocol.__module__ == 'asyncio.protocols'"
  category: identity
  kind: python_call_eq
  function: asyncio.Protocol.__module__.__eq__
  args: ["asyncio.protocols"]
  expected: true
