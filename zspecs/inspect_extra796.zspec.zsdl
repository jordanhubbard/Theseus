spec: inspect_extra796
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any third-party inspect extension"
  notes:
    - "Covers inspect.Parameter, Signature, and BoundArguments method qualnames"
    - "All checks are pure __qualname__ attribute reads — no instantiation required"
  created_at: "2026-04-12"

table inspect_extra796.name:
  description: "inspect.Parameter and Signature method qualname identity checks"
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: in796xx
  columns: [id, function, args, expected]
  rows:
    - [in796xx001, inspect.Parameter.__repr__.__qualname__.__eq__, ["Parameter.__repr__"], true]
    - [in796xx002, inspect.Parameter.__eq__.__qualname__.__eq__, ["Parameter.__eq__"], true]
    - [in796xx003, inspect.Parameter.__hash__.__qualname__.__eq__, ["Parameter.__hash__"], true]
    - [in796xx004, inspect.Parameter.__init__.__qualname__.__eq__, ["Parameter.__init__"], true]
    - [in796xx005, inspect.Parameter.replace.__qualname__.__eq__, ["Parameter.replace"], true]
    - [in796xx006, inspect.Signature.__repr__.__qualname__.__eq__, ["Signature.__repr__"], true]
    - [in796xx007, inspect.Signature.__eq__.__qualname__.__eq__, ["Signature.__eq__"], true]
    - [in796xx008, inspect.Signature.__init__.__qualname__.__eq__, ["Signature.__init__"], true]
    - [in796xx009, inspect.Signature.replace.__qualname__.__eq__, ["Signature.replace"], true]
    - [in796xx010, inspect.Signature.from_callable.__qualname__.__eq__, ["Signature.from_callable"], true]
    - [in796xx011, inspect.BoundArguments.__repr__.__qualname__.__eq__, ["BoundArguments.__repr__"], true]
    - [in796xx012, inspect.BoundArguments.apply_defaults.__qualname__.__eq__, ["BoundArguments.apply_defaults"], true]
