spec: abc_extra233
version: ">=3.3"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers abc.ABCMeta method contracts: register, __subclasscheck__, __instancecheck__."
    - "abc.ABCMeta.register.__name__ == 'register' (len=8); __qualname__ == 'ABCMeta.register' (len=16)."
    - "abc.ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__' (len=17); __qualname__ == 'ABCMeta.__subclasscheck__' (len=25)."
    - "abc.ABCMeta.__instancecheck__.__name__ == '__instancecheck__' (len=17); __qualname__ == 'ABCMeta.__instancecheck__' (len=25)."
    - "All three methods are plain Python functions (type.__name__ == 'function')."
    - "'register' in ABCMeta.__dict__ — the register method is stored directly on ABCMeta."
    - "'__subclasscheck__' in ABCMeta.__dict__ — __subclasscheck__ is defined directly on ABCMeta."
    - "'__instancecheck__' in ABCMeta.__dict__ — __instancecheck__ is defined directly on ABCMeta."
    - "ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' — the class dict is a mappingproxy."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABCMeta method __name__ contracts
#
# Verifies __name__ for register, __subclasscheck__, and __instancecheck__.
# All three are plain Python functions defined directly on ABCMeta.
# Also includes a __dict__ membership check for register.
# ---------------------------------------------------------------------------

table abc_extra233.abcmeta_method_names:
  description: "abc.ABCMeta method __name__ contracts: register, __subclasscheck__, __instancecheck__; new to extra233"
  kind: python_call_eq
  category: method_names
  id_prefix: abc233meth

  columns: [id, function, args, expected, description]
  rows:
    - [register_name_eq,
       ABCMeta.register.__name__.__eq__,
       ["register"],
       true,
       "abc.ABCMeta.register.__name__.__eq__('register') == True — method name is 'register' (len=8); new to extra233"]
    - [subclasscheck_name_eq,
       ABCMeta.__subclasscheck__.__name__.__eq__,
       ["__subclasscheck__"],
       true,
       "abc.ABCMeta.__subclasscheck__.__name__.__eq__('__subclasscheck__') == True — method name is '__subclasscheck__' (len=17); new to extra233"]
    - [instancecheck_name_eq,
       ABCMeta.__instancecheck__.__name__.__eq__,
       ["__instancecheck__"],
       true,
       "abc.ABCMeta.__instancecheck__.__name__.__eq__('__instancecheck__') == True — method name is '__instancecheck__' (len=17); new to extra233"]
    - [register_type_is_function,
       ABCMeta.register.__class__.__name__.__eq__,
       ["function"],
       true,
       "abc.ABCMeta.register.__class__.__name__.__eq__('function') == True — register is a plain Python function; new to extra233"]
    - [dict_has_register,
       ABCMeta.__dict__.__contains__,
       ["register"],
       true,
       "abc.ABCMeta.__dict__.__contains__('register') == True — register method is stored directly in ABCMeta.__dict__; new to extra233"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABCMeta method __qualname__ contracts
#
# For methods defined directly on ABCMeta, __qualname__ is
# 'ABCMeta.<method>'. Verifies register, __subclasscheck__, __instancecheck__.
# Also verifies __dict__ membership for __subclasscheck__ and __instancecheck__.
# ---------------------------------------------------------------------------

table abc_extra233.abcmeta_method_qualnames:
  description: "abc.ABCMeta method __qualname__ contracts; new to extra233"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: abc233methq

  columns: [id, function, args, expected, description]
  rows:
    - [register_qualname_eq,
       ABCMeta.register.__qualname__.__eq__,
       ["ABCMeta.register"],
       true,
       "abc.ABCMeta.register.__qualname__.__eq__('ABCMeta.register') == True — qualname is 'ABCMeta.register' (len=16); new to extra233"]
    - [subclasscheck_qualname_eq,
       ABCMeta.__subclasscheck__.__qualname__.__eq__,
       ["ABCMeta.__subclasscheck__"],
       true,
       "abc.ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__') == True — qualname is 'ABCMeta.__subclasscheck__' (len=25); new to extra233"]
    - [instancecheck_qualname_eq,
       ABCMeta.__instancecheck__.__qualname__.__eq__,
       ["ABCMeta.__instancecheck__"],
       true,
       "abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') == True — qualname is 'ABCMeta.__instancecheck__' (len=25); new to extra233"]
    - [dict_has_subclasscheck,
       ABCMeta.__dict__.__contains__,
       ["__subclasscheck__"],
       true,
       "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True — __subclasscheck__ is defined directly on ABCMeta; new to extra233"]
    - [dict_has_instancecheck,
       ABCMeta.__dict__.__contains__,
       ["__instancecheck__"],
       true,
       "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True — __instancecheck__ is defined directly on ABCMeta; new to extra233"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra233
# ---------------------------------------------------------------------------

invariant abc_extra233.ABCMeta.register_name:
  description: "abc.ABCMeta.register.__name__ == 'register'; new to extra233"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.register.__name__.__eq__
  args: ["register"]
  expected: true

invariant abc_extra233.ABCMeta.register_qualname:
  description: "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register'; new to extra233"
  category: method_qualnames
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

invariant abc_extra233.ABCMeta.subclasscheck_name:
  description: "abc.ABCMeta.__subclasscheck__.__name__ == '__subclasscheck__'; new to extra233"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__name__.__eq__
  args: ["__subclasscheck__"]
  expected: true

invariant abc_extra233.ABCMeta.subclasscheck_qualname:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'; new to extra233"
  category: method_qualnames
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true

invariant abc_extra233.ABCMeta.instancecheck_name:
  description: "abc.ABCMeta.__instancecheck__.__name__ == '__instancecheck__'; new to extra233"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__name__.__eq__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra233.ABCMeta.instancecheck_qualname:
  description: "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'; new to extra233"
  category: method_qualnames
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

invariant abc_extra233.ABCMeta.dict_has_register:
  description: "abc.ABCMeta.__dict__.__contains__('register') == True — register is in ABCMeta.__dict__; new to extra233"
  category: dict_membership
  kind: python_call_eq
  function: ABCMeta.__dict__.__contains__
  args: ["register"]
  expected: true

invariant abc_extra233.ABCMeta.dict_class_is_mappingproxy:
  description: "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'; new to extra233"
  category: dict_membership
  kind: python_call_eq
  function: ABCMeta.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
