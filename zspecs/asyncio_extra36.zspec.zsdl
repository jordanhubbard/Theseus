spec: asyncio_extra36
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio_extra35.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__() (C extension), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__() == 95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), create_task/run_coroutine_threadsafe __qualname__.__len__(), Queue.__mro__.__len__() == 3, BoundedSemaphore.__mro__.__len__() == 5, Queue method __qualname__.__len__() tables, wait_for/shield/sleep module/name lengths, timeout class identity, TaskGroup class identity, Task/Future MRO depths and base name lengths, PriorityQueue/LifoQueue/Lock/Semaphore/Condition/Event MRO depths and base name lengths, Queue/Lock/Event method __name__.__len__() tables, PriorityQueue/__name__.__len__()==13, LifoQueue/__name__.__len__()==9, QueueEmpty/__name__.__len__()==10, Lock.locked.__qualname__.__len__()==11."
    - "This spec covers: Semaphore.acquire.__name__.__len__()==7; Semaphore.release.__name__.__len__()==7; Semaphore.locked.__name__.__len__()==6; Semaphore.locked.__qualname__.__len__()==16; Condition.notify.__name__.__len__()==6; Condition.notify_all.__name__.__len__()==10; Condition.wait.__name__.__len__()==4; Condition.wait_for.__name__.__len__()==8; QueueFull.__name__.__len__()==9; QueueEmpty.__qualname__.__len__()==10; QueueFull.__qualname__.__len__()==9; ABC.__subclasshook__.__qualname__.__len__ is not asyncio — this spec stays in asyncio only."
    - "Semaphore.acquire and Semaphore.release share __name__ length 7 ('acquire' and 'release'); Semaphore.locked is one shorter at 6 ('locked')."
    - "Semaphore.locked.__qualname__ == 'Semaphore.locked' (16 chars): 'Semaphore' (9) + '.' (1) + 'locked' (6) = 16."
    - "Condition.notify.__name__ == 'notify' (6 chars); Condition.notify_all.__name__ == 'notify_all' (10 chars — includes underscore); Condition.wait.__name__ == 'wait' (4 chars); Condition.wait_for.__name__ == 'wait_for' (8 chars — includes underscore)."
    - "QueueFull.__name__.__len__() == 9 ('QueueFull'); QueueEmpty.__name__.__len__() == 10 ('QueueEmpty') was covered in extra19. QueueFull is one character shorter than QueueEmpty."
    - "QueueEmpty.__qualname__ == 'QueueEmpty' (10 chars); QueueFull.__qualname__ == 'QueueFull' (9 chars). For top-level exception classes, __qualname__ equals __name__."
    - "BoundedSemaphore.acquire.__qualname__ == 'Semaphore.acquire' (17 chars) — inherited from Semaphore; BoundedSemaphore does not override acquire, only release."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Semaphore method __name__.__len__() — extra36 namespace
#
# Semaphore.acquire and Semaphore.release have the same __name__ length (7);
# Semaphore.locked is one character shorter at 6. __name__ gives the short
# unqualified name (without the class prefix), so:
#   Semaphore.acquire.__name__ == 'acquire' (7 chars)
#   Semaphore.release.__name__ == 'release' (7 chars)
#   Semaphore.locked.__name__  == 'locked'  (6 chars)
# This contrasts with __qualname__ lengths:
#   Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (17 chars) — covered extra25
#   Semaphore.release.__qualname__ == 'Semaphore.release' (17 chars) — covered extra25
#   Semaphore.locked.__qualname__  == 'Semaphore.locked'  (16 chars) — novel
# ---------------------------------------------------------------------------

table asyncio_extra36.semaphore_method_name_lengths:
  description: "asyncio.Semaphore method __name__.__len__() in extra36 namespace — short names without class prefix"
  kind: python_call_eq
  category: method_names
  id_prefix: semmethodnamelen36

  columns: [id, function, args, expected]
  rows:
    - [acquire, Semaphore.acquire.__name__.__len__, [], 7]
    - [release, Semaphore.release.__name__.__len__, [], 7]
    - [locked,  Semaphore.locked.__name__.__len__,  [], 6]

# ---------------------------------------------------------------------------
# asyncio Semaphore.locked __qualname__.__len__() — extra36 namespace
#
# Semaphore.locked.__qualname__ == 'Semaphore.locked' (16 chars):
#   'Semaphore' (9) + '.' (1) + 'locked' (6) = 16
# Prior specs (extra25, extra31) covered acquire and release __qualname__.__len__()
# (both 17), but NOT locked.__qualname__.__len__() (16).
# The one-character difference distinguishes locked from the acquire/release pair.
# ---------------------------------------------------------------------------

invariant asyncio_extra36.Semaphore_locked_qualname_len:
  description: "asyncio.Semaphore.locked.__qualname__.__len__() == 16 — 'Semaphore.locked' has 16 characters; one shorter than acquire/release (17 each)"
  category: method_names
  kind: python_call_eq
  function: Semaphore.locked.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# asyncio Condition method __name__.__len__() — extra36 namespace
#
# Condition has four public methods. Their short __name__ lengths are:
#   Condition.wait.__name__       == 'wait'       (4 chars)
#   Condition.notify.__name__     == 'notify'     (6 chars)
#   Condition.notify_all.__name__ == 'notify_all' (10 chars, includes underscore)
#   Condition.wait_for.__name__   == 'wait_for'   (8 chars, includes underscore)
# Prior specs covered __qualname__.__len__() for all four (extra25, extra31) but
# not __name__.__len__(). The short names reveal the underlying function name
# without the class prefix.
# ---------------------------------------------------------------------------

table asyncio_extra36.condition_method_name_lengths:
  description: "asyncio.Condition method __name__.__len__() in extra36 namespace — short names without class prefix"
  kind: python_call_eq
  category: method_names
  id_prefix: condmethodnamelen36

  columns: [id, function, args, expected]
  rows:
    - [wait,       Condition.wait.__name__.__len__,       [], 4]
    - [notify,     Condition.notify.__name__.__len__,     [], 6]
    - [notify_all, Condition.notify_all.__name__.__len__, [], 10]
    - [wait_for,   Condition.wait_for.__name__.__len__,   [], 8]

# ---------------------------------------------------------------------------
# asyncio QueueFull.__name__.__len__() and QueueEmpty/QueueFull __qualname__ lengths
#
# QueueEmpty.__name__.__len__() == 10 was covered in extra19.
# QueueFull.__name__.__len__()  == 9  has NOT been covered in any prior spec.
# QueueFull is one character shorter than QueueEmpty because 'QueueFull' (9)
# lacks the 'y' that makes 'QueueEmpty' (10) longer than 'QueueFull' — actually
# 'Empty' (5) vs 'Full' (4), hence the one-character difference.
#
# For top-level exception classes, __qualname__ equals __name__:
#   QueueEmpty.__qualname__.__len__() == 10 (matches __name__.__len__())
#   QueueFull.__qualname__.__len__()  ==  9 (matches __name__.__len__())
# These __qualname__.__len__() values have not been captured in any prior spec.
# ---------------------------------------------------------------------------

table asyncio_extra36.queue_exception_name_lengths:
  description: "asyncio QueueEmpty/QueueFull __name__.__len__() and __qualname__.__len__() in extra36 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: qexcnamelen36

  columns: [id, function, args, expected]
  rows:
    - [QueueFull_name,        QueueFull.__name__.__len__,        [], 9]
    - [QueueEmpty_qualname,   QueueEmpty.__qualname__.__len__,   [], 10]
    - [QueueFull_qualname,    QueueFull.__qualname__.__len__,    [], 9]

# ---------------------------------------------------------------------------
# Standalone invariants — extra36
# ---------------------------------------------------------------------------

invariant asyncio_extra36.Semaphore_locked_name_len:
  description: "asyncio.Semaphore.locked.__name__.__len__() == 6 — 'locked' is 6 characters; one shorter than 'acquire'/'release' (7 each)"
  category: method_names
  kind: python_call_eq
  function: Semaphore.locked.__name__.__len__
  args: []
  expected: 6

invariant asyncio_extra36.Condition_notify_all_name_len:
  description: "asyncio.Condition.notify_all.__name__.__len__() == 10 — 'notify_all' is 10 characters including the underscore; the longest Condition method short name"
  category: method_names
  kind: python_call_eq
  function: Condition.notify_all.__name__.__len__
  args: []
  expected: 10

invariant asyncio_extra36.QueueFull_name_len:
  description: "asyncio.QueueFull.__name__.__len__() == 9 — 'QueueFull' has 9 characters; one fewer than QueueEmpty (10) because 'Full' (4) is shorter than 'Empty' (5)"
  category: class_names
  kind: python_call_eq
  function: QueueFull.__name__.__len__
  args: []
  expected: 9
