spec: itertools_extra244
version: ">=3.0"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra243.zspec.zsdl — covers filterfalse and starmap class identity"
    - "itertools_extra242.zspec.zsdl — covers islice and takewhile class identity"
    - "itertools_extra241.zspec.zsdl — covers dropwhile and chain class identity"
    - "itertools_extra.zspec.zsdl — covers combinations/permutations/product/compress/zip_longest names"
    - "itertools.zspec.zsdl — covers itertools class names and module identity"
  notes:
    - "This spec covers itertools.islice and itertools.compress class identity contracts."
    - "itertools.islice.__name__ == 'islice' (len=6) — islice is a C-level type in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.islice.__module__ == 'itertools' (len=9) — islice is exposed in the itertools namespace. Verified with Python 3.14.3."
    - "itertools.islice.__bases__[0].__name__ == 'object' — islice inherits directly from object. Verified with Python 3.14.3."
    - "itertools.islice.__class__.__name__ == 'type' — islice is a C extension type. Verified with Python 3.14.3."
    - "itertools.compress.__name__ == 'compress' (len=8) — compress is a C-level type in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.compress.__module__ == 'itertools' (len=9) — compress is exposed in the itertools namespace. Verified with Python 3.14.3."
    - "itertools.compress.__bases__[0].__name__ == 'object' — compress inherits directly from object. Verified with Python 3.14.3."
    - "itertools.compress.__class__.__name__ == 'type' — compress is a C extension type. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.islice class identity contracts
#
# itertools.islice.__name__ == 'islice' (len=6)
# itertools.islice.__module__ == 'itertools' (len=9)
# itertools.islice.__bases__[0].__name__ == 'object'
# itertools.islice.__class__.__name__ == 'type'
# itertools.islice.__name__.__len__() == 6
#
# islice is a C-level type in itertoolsmodule.c. New to extra244.
# ---------------------------------------------------------------------------

table itertools_extra244.islice244_identity:
  description: "itertools.islice class identity: name, module, bases, class; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: islice244

  columns: [id, function, args, expected, description]
  rows:
    - [isl_name_eq,
       islice.__name__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — islice is a C-level type in itertoolsmodule.c; __name__ is 'islice' (len=6); new to extra244"]
    - [isl_name_len_6,
       islice.__name__.__len__,
       [],
       6,
       "itertools.islice.__name__.__len__() == 6 — 'islice' has exactly 6 characters; str.__len__() returns 6; new to extra244"]
    - [isl_module_eq,
       islice.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — islice is exposed in the itertools namespace; __module__ is 'itertools' (len=9); new to extra244"]
    - [isl_module_len_9,
       islice.__module__.__len__,
       [],
       9,
       "itertools.islice.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra244"]
    - [isl_bases_0_is_object,
       "islice.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.islice.__bases__[0].__name__.__eq__('object') == True — islice inherits directly from object; __bases__[0] is object; new to extra244"]

# ---------------------------------------------------------------------------
# Table 2: itertools.islice class type and content checks
#
# itertools.islice.__class__.__name__ == 'type'
# itertools.islice.__name__.__contains__('slice') == True
# itertools.islice.__module__.__contains__('itertools') == True
# itertools.islice.__bases__[0].__name__.__len__() == 6
# itertools.islice.__class__.__module__ == 'builtins'
#
# New to extra244.
# ---------------------------------------------------------------------------

table itertools_extra244.islice244_class:
  description: "itertools.islice class type, name/module content checks; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: islice244c

  columns: [id, function, args, expected, description]
  rows:
    - [isl_class_is_type,
       islice.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.islice.__class__.__name__.__eq__('type') == True — islice is a C extension type; its metaclass is the built-in type; new to extra244"]
    - [isl_name_contains_slice,
       islice.__name__.__contains__,
       ["slice"],
       true,
       "itertools.islice.__name__.__contains__('slice') == True — 'islice' contains the suffix 'slice'; new to extra244"]
    - [isl_module_contains_itertools,
       islice.__module__.__contains__,
       ["itertools"],
       true,
       "itertools.islice.__module__.__contains__('itertools') == True — 'itertools' contains the substring 'itertools'; new to extra244"]
    - [isl_bases_0_len_6,
       "islice.__bases__[0].__name__.__len__",
       [],
       6,
       "itertools.islice.__bases__[0].__name__.__len__() == 6 — 'object' has exactly 6 characters; new to extra244"]
    - [isl_class_module_builtins,
       islice.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.islice.__class__.__module__.__eq__('builtins') == True — type is defined in the builtins module; new to extra244"]

# ---------------------------------------------------------------------------
# Table 3: itertools.compress class identity contracts
#
# itertools.compress.__name__ == 'compress' (len=8)
# itertools.compress.__module__ == 'itertools' (len=9)
# itertools.compress.__bases__[0].__name__ == 'object'
# itertools.compress.__class__.__name__ == 'type'
# itertools.compress.__name__.__len__() == 8
#
# compress is a C-level type in itertoolsmodule.c. New to extra244.
# ---------------------------------------------------------------------------

table itertools_extra244.compress244_identity:
  description: "itertools.compress class identity: name, module, bases, class; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: compress244

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_name_eq,
       compress.__name__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — compress is a C-level type in itertoolsmodule.c; __name__ is 'compress' (len=8); new to extra244"]
    - [cmp_name_len_8,
       compress.__name__.__len__,
       [],
       8,
       "itertools.compress.__name__.__len__() == 8 — 'compress' has exactly 8 characters; str.__len__() returns 8; new to extra244"]
    - [cmp_module_eq,
       compress.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.compress.__module__.__eq__('itertools') == True — compress is exposed in the itertools namespace; __module__ is 'itertools' (len=9); new to extra244"]
    - [cmp_module_len_9,
       compress.__module__.__len__,
       [],
       9,
       "itertools.compress.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra244"]
    - [cmp_bases_0_is_object,
       "compress.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.compress.__bases__[0].__name__.__eq__('object') == True — compress inherits directly from object; __bases__[0] is object; new to extra244"]

# ---------------------------------------------------------------------------
# Table 4: itertools.compress class type and content checks
#
# itertools.compress.__class__.__name__ == 'type'
# itertools.compress.__name__.__contains__('comp') == True
# itertools.compress.__module__.__contains__('itertools') == True
# itertools.compress.__bases__[0].__name__.__len__() == 6
# itertools.compress.__class__.__module__ == 'builtins'
#
# New to extra244.
# ---------------------------------------------------------------------------

table itertools_extra244.compress244_class:
  description: "itertools.compress class type, name/module content checks; new to extra244"
  kind: python_call_eq
  category: identity
  id_prefix: compress244c

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_class_is_type,
       compress.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.compress.__class__.__name__.__eq__('type') == True — compress is a C extension type; its metaclass is the built-in type; new to extra244"]
    - [cmp_name_contains_comp,
       compress.__name__.__contains__,
       ["comp"],
       true,
       "itertools.compress.__name__.__contains__('comp') == True — 'compress' contains the prefix 'comp'; new to extra244"]
    - [cmp_module_contains_itertools,
       compress.__module__.__contains__,
       ["itertools"],
       true,
       "itertools.compress.__module__.__contains__('itertools') == True — 'itertools' contains the substring 'itertools'; new to extra244"]
    - [cmp_bases_0_len_6,
       "compress.__bases__[0].__name__.__len__",
       [],
       6,
       "itertools.compress.__bases__[0].__name__.__len__() == 6 — 'object' has exactly 6 characters; new to extra244"]
    - [cmp_class_module_builtins,
       compress.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.compress.__class__.__module__.__eq__('builtins') == True — type is defined in the builtins module; new to extra244"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra244
# ---------------------------------------------------------------------------

invariant itertools_extra244.isl_name_eq:
  description: "itertools.islice.__name__ == 'islice' (len=6); new to extra244"
  kind: python_call_eq
  function: islice.__name__.__eq__
  args: ["islice"]
  expected: true

invariant itertools_extra244.isl_module_eq:
  description: "itertools.islice.__module__ == 'itertools' — C-level type in itertools namespace; new to extra244"
  kind: python_call_eq
  function: islice.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra244.isl_bases_0_is_object:
  description: "itertools.islice.__bases__[0].__name__ == 'object' — inherits from object; new to extra244"
  kind: python_call_eq
  function: "islice.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra244.isl_class_is_type:
  description: "itertools.islice.__class__.__name__ == 'type' — C extension type; new to extra244"
  kind: python_call_eq
  function: islice.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra244.isl_name_len_6:
  description: "itertools.islice.__name__.__len__() == 6; new to extra244"
  kind: python_call_eq
  function: islice.__name__.__len__
  args: []
  expected: 6

invariant itertools_extra244.cmp_name_eq:
  description: "itertools.compress.__name__ == 'compress' (len=8); new to extra244"
  kind: python_call_eq
  function: compress.__name__.__eq__
  args: ["compress"]
  expected: true

invariant itertools_extra244.cmp_module_eq:
  description: "itertools.compress.__module__ == 'itertools' — C-level type in itertools namespace; new to extra244"
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra244.cmp_bases_0_is_object:
  description: "itertools.compress.__bases__[0].__name__ == 'object' — inherits from object; new to extra244"
  kind: python_call_eq
  function: "compress.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra244.cmp_class_is_type:
  description: "itertools.compress.__class__.__name__ == 'type' — C extension type; new to extra244"
  kind: python_call_eq
  function: compress.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra244.cmp_name_len_8:
  description: "itertools.compress.__name__.__len__() == 8; new to extra244"
  kind: python_call_eq
  function: compress.__name__.__len__
  args: []
  expected: 8

invariant itertools_extra244.isl_name_contains_slice:
  description: "itertools.islice.__name__ contains 'slice'; new to extra244"
  kind: python_call_eq
  function: islice.__name__.__contains__
  args: ["slice"]
  expected: true

invariant itertools_extra244.cmp_name_contains_comp:
  description: "itertools.compress.__name__ contains 'comp'; new to extra244"
  kind: python_call_eq
  function: compress.__name__.__contains__
  args: ["comp"]
  expected: true
