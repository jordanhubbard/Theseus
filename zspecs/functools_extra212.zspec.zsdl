       ["int"],
       true,
       "functools.update_wrapper.__code__.co_flags.__class__.__name__ == 'int' — update_wrapper is a Python function; co_flags==67108867 is an int bitmask; str.__eq__('int') returns True; new to extra212"]
    - [cache_flags_class,
       "cache.__code__.co_flags.__class__.__name__.__eq__",
       ["int"],
       true,
       "functools.cache.__code__.co_flags.__class__.__name__ == 'int' — cache is a Python function (zero-arg lru_cache wrapper); co_flags==67108867 is an int bitmask; str.__eq__('int') returns True; new to extra212"]
    - [singledispatch_flags_class,
       "singledispatch.__code__.co_flags.__class__.__name__.__eq__",
       ["int"],
       true,
       "functools.singledispatch.__code__.co_flags.__class__.__name__ == 'int' — singledispatch is a Python function; co_flags==67108867 is an int bitmask; str.__eq__('int') returns True; new to extra212"]

# ---------------------------------------------------------------------------
# Table 2: co_stacksize.__class__.__name__ for Python-level functools functions
#
# co_stacksize is the maximum stack depth required when executing the
# function's bytecode. It is always an int.
# Verified values: lru_cache=6, wraps=7, update_wrapper=8, cache=4,
# singledispatch=6.
# ---------------------------------------------------------------------------

table functools_extra212.co_stacksize_class_name:
