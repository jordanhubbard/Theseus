       ["int"],
       true,
       "functools.wraps.__code__.co_flags.__class__.__name__ == 'int' — wraps is a Python function; co_flags==67108867 is an int bitmask; str.__eq__('int') returns True; new to extra212"]
    - [update_wrapper_flags_class,
