spec: functools_extra212
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "Python functools documentation — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra211.zspec.zsdl — covers __defaults__ class names and lengths for lru_cache, wraps, update_wrapper, recursive_repr, total_ordering, cache, singledispatch"
    - "functools_extra.zspec.zsdl — covers __name__ and __module__ checks for public functools symbols"
    - "functools_lru.zspec.zsdl — covers lru_cache and cache identity, qualname, module, and decorator behavior"
  notes:
    - "functools.lru_cache.__code__.co_flags.__class__.__name__ == 'int' — lru_cache is a Python-level function; co_flags is an integer bitmask encoding function attributes (e.g., OPTIMIZED, NEWLOCALS). Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_flags.__class__.__name__ == 'int' — wraps is a Python-level function; co_flags value is 67108867 (same as lru_cache). Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the maximum stack depth required by the function. wraps co_stacksize==7. Verified with Python 3.14.3."
    - "functools.update_wrapper.__code__.co_stacksize.__class__.__name__ == 'int' — update_wrapper co_stacksize==8. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_filename.__class__.__name__ == 'str' — co_filename is the path to the source file. Verified with Python 3.14.3."
    - "co_flags values for lru_cache, wraps, update_wrapper, cache, singledispatch are all 67108867. co_stacksize values differ: lru_cache=6, wraps=7, update_wrapper=8, cache=4, singledispatch=6. All verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: co_flags.__class__.__name__ for Python-level functools functions
#
# lru_cache, wraps, update_wrapper, cache, and singledispatch are all
# Python-level functions. Their __code__.co_flags is an integer bitmask.
# co_flags.__class__.__name__ == 'int' for all of them.
# Verified values: all co_flags == 67108867.
# ---------------------------------------------------------------------------

table functools_extra212.co_flags_class_name:
  description: "__code__.co_flags.__class__.__name__ == 'int' for Python-level functools functions; co_flags is an int bitmask encoding function attributes; all five functions have co_flags value 67108867; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_object
  id_prefix: functcoflags212

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_flags_class,
       "lru_cache.__code__.co_flags.__class__.__name__.__eq__",
       ["int"],
       true,
       "functools.lru_cache.__code__.co_flags.__class__.__name__ == 'int' — lru_cache is a Python function; co_flags==67108867 is an int bitmask; str.__eq__('int') returns True; new to extra212"]
    - [wraps_flags_class,
