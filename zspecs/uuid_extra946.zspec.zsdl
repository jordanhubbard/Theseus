spec: uuid_extra946
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid namespace constants, SafeUUID enum identity, and module attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra946.module_identity:
  description: "uuid module-level identity attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: uu946mi
  columns: [id, function, args, expected]
  rows:
    - [uu946mi001, uuid.__name__.__eq__,          ["uuid"], true]
    - [uu946mi002, uuid.__spec__.name.__eq__,     ["uuid"], true]
    - [uu946mi003, uuid.__name__.__class__.__name__.__eq__, ["str"], true]
    - [uu946mi004, uuid.__package__.__class__.__name__.__eq__, ["str"], true]
    - [uu946mi005, uuid.__spec__.name.__class__.__name__.__eq__, ["str"], true]

table uuid_extra946.namespace_constants:
  description: "uuid namespace UUID constant class identity"
  kind: python_call_eq
  category: namespace_constants
  id_prefix: uu946nc
  columns: [id, function, args, expected]
  rows:
    - [uu946nc001, uuid.NAMESPACE_DNS.__class__.__name__.__eq__,  ["UUID"], true]
    - [uu946nc002, uuid.NAMESPACE_URL.__class__.__name__.__eq__,  ["UUID"], true]
    - [uu946nc003, uuid.NAMESPACE_OID.__class__.__name__.__eq__,  ["UUID"], true]
    - [uu946nc004, uuid.NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true]
    - [uu946nc005, uuid.NAMESPACE_DNS.__class__.__module__.__eq__, ["uuid"], true]
    - [uu946nc006, uuid.NAMESPACE_URL.__class__.__module__.__eq__, ["uuid"], true]
    - [uu946nc007, uuid.NAMESPACE_OID.__class__.__module__.__eq__, ["uuid"], true]

table uuid_extra946.safeuuid_enum:
  description: "uuid.SafeUUID enum class identity and module membership"
  kind: python_call_eq
  category: safeuuid_enum
  id_prefix: uu946su
  columns: [id, function, args, expected]
  rows:
    - [uu946su001, uuid.SafeUUID.__name__.__eq__,                        ["SafeUUID"], true]
    - [uu946su002, uuid.SafeUUID.__module__.__eq__,                      ["uuid"],     true]
    - [uu946su003, uuid.SafeUUID.__name__.__class__.__name__.__eq__,     ["str"],      true]
    - [uu946su004, uuid.SafeUUID.__module__.__class__.__name__.__eq__,   ["str"],      true]
    - [uu946su005, uuid.SafeUUID.__qualname__.__eq__,                    ["SafeUUID"], true]
