spec: inspect_extra1516
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 548 theme: arithmetic/numeric operator protocol dict-presence checks — __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__ and reflected variants __radd__, __rmul__, __rsub__, __rtruediv__, __rfloordiv__, __rmod__, __rpow__ for inspect classes."
    - "inspect.Parameter: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "inspect.Signature: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "inspect.BoundArguments: no arithmetic operator methods in __dict__. Verified with Python 3.12."
    - "None of the inspect introspection classes are numeric types; they represent introspection objects (parameters, signatures, bound argument mappings) and have no arithmetic operator support."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter — arithmetic operator protocol absence checks
#
# Wave 548 theme: inspect.Parameter represents a parameter in a function
# signature, including name, kind, default value, and annotation.
#
# inspect.Parameter.__dict__.__contains__("__add__") == False
# inspect.Parameter.__dict__.__contains__("__mul__") == False
# inspect.Parameter.__dict__.__contains__("__sub__") == False
# inspect.Parameter.__dict__.__contains__("__truediv__") == False
# inspect.Parameter.__dict__.__contains__("__radd__") == False
# inspect.Parameter.__dict__.__contains__("__rpow__") == False
#
# Parameter is an introspection value object. It defines __eq__ and __hash__
# but no arithmetic operator methods. New to extra1516.
# ---------------------------------------------------------------------------

table inspect_extra1516.parameter_arithmetic_protocol_absence:
  description: "inspect.Parameter has no arithmetic operator methods in __dict__; Parameter is an introspection object representing a function parameter with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1516pa

  columns: [id, function, args, expected, description]
  rows:
    - [in1516pa001,
       "Parameter.__dict__.__contains__",
       ["__add__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__add__') == False — Parameter is an introspection object representing a single parameter in a function signature, including its name, kind, default, and annotation; it is not a numeric type and does not implement the addition operator protocol; __add__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516pa002,
       "Parameter.__dict__.__contains__",
       ["__mul__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__mul__') == False — Parameter does not implement the multiplication operator protocol; __mul__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516pa003,
       "Parameter.__dict__.__contains__",
       ["__sub__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__sub__') == False — Parameter does not implement the subtraction operator protocol; __sub__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516pa004,
       "Parameter.__dict__.__contains__",
       ["__truediv__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__truediv__') == False — Parameter does not implement the true division operator protocol; __truediv__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516pa005,
       "Parameter.__dict__.__contains__",
       ["__radd__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__radd__') == False — Parameter does not implement the reflected addition operator protocol; __radd__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516pa006,
       "Parameter.__dict__.__contains__",
       ["__rpow__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__rpow__') == False — Parameter does not implement the reflected exponentiation operator protocol; __rpow__ is not in Parameter.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516pa007,
       "Parameter.__dict__.__contains__",
       ["__eq__"],
       true,
       "inspect.Parameter.__dict__.__contains__('__eq__') == True — Parameter IS a value object and defines __eq__ in its __dict__ for equality comparison between parameters; this is a comparison protocol, not an arithmetic operator protocol; verified with Python 3.12; new to extra1516"]
    - [in1516pa008,
       "Parameter.__dict__.__contains__",
       ["__hash__"],
       true,
       "inspect.Parameter.__dict__.__contains__('__hash__') == True — Parameter defines __hash__ in its __dict__ making it hashable for use in sets and dict keys; __hash__ is a hashing protocol, wholly distinct from any absent arithmetic operator protocol; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Signature — arithmetic operator protocol absence checks
#
# Wave 548 theme: inspect.Signature represents the call signature of a
# callable object, containing an ordered mapping of Parameter objects.
#
# inspect.Signature.__dict__.__contains__("__add__") == False
# inspect.Signature.__dict__.__contains__("__mul__") == False
# inspect.Signature.__dict__.__contains__("__floordiv__") == False
# inspect.Signature.__dict__.__contains__("__mod__") == False
# inspect.Signature.__dict__.__contains__("__rmul__") == False
# inspect.Signature.__dict__.__contains__("__rfloordiv__") == False
#
# Signature is an introspection object. It defines __eq__ and __hash__
# but no arithmetic operator methods. New to extra1516.
# ---------------------------------------------------------------------------

table inspect_extra1516.signature_arithmetic_protocol_absence:
  description: "inspect.Signature has no arithmetic operator methods in __dict__; Signature is an introspection object representing a callable's call signature with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1516si

  columns: [id, function, args, expected, description]
  rows:
    - [in1516si001,
       "Signature.__dict__.__contains__",
       ["__add__"],
       false,
       "inspect.Signature.__dict__.__contains__('__add__') == False — Signature is an introspection object representing the complete call signature of a callable, containing an ordered mapping of Parameter objects; it is not a numeric type and does not implement the addition operator protocol; __add__ is not in Signature.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516si002,
       "Signature.__dict__.__contains__",
       ["__mul__"],
       false,
       "inspect.Signature.__dict__.__contains__('__mul__') == False — Signature does not implement the multiplication operator protocol; __mul__ is not in Signature.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516si003,
       "Signature.__dict__.__contains__",
       ["__floordiv__"],
       false,
       "inspect.Signature.__dict__.__contains__('__floordiv__') == False — Signature does not implement the floor division operator protocol; __floordiv__ is not in Signature.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516si004,
       "Signature.__dict__.__contains__",
       ["__mod__"],
       false,
       "inspect.Signature.__dict__.__contains__('__mod__') == False — Signature does not implement the modulo operator protocol; __mod__ is not in Signature.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516si005,
       "Signature.__dict__.__contains__",
       ["__rmul__"],
       false,
       "inspect.Signature.__dict__.__contains__('__rmul__') == False — Signature does not implement the reflected multiplication operator protocol; __rmul__ is not in Signature.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516si006,
       "Signature.__dict__.__contains__",
       ["__rfloordiv__"],
       false,
       "inspect.Signature.__dict__.__contains__('__rfloordiv__') == False — Signature does not implement the reflected floor division operator protocol; __rfloordiv__ is not in Signature.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516si007,
       "Signature.__dict__.__contains__",
       ["__eq__"],
       true,
       "inspect.Signature.__dict__.__contains__('__eq__') == True — Signature IS a value object and defines __eq__ in its __dict__ for equality comparison between signatures; this is a comparison protocol, not an arithmetic operator protocol; verified with Python 3.12; new to extra1516"]
    - [in1516si008,
       "Signature.__dict__.__contains__",
       ["__hash__"],
       true,
       "inspect.Signature.__dict__.__contains__('__hash__') == True — Signature defines __hash__ in its __dict__ making it hashable; __hash__ is a hashing protocol, wholly distinct from any absent arithmetic operator protocol; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Table 3: inspect.BoundArguments — arithmetic operator protocol absence checks
#
# Wave 548 theme: inspect.BoundArguments represents arguments bound to a
# function Signature via Signature.bind() or Signature.bind_partial().
#
# inspect.BoundArguments.__dict__.__contains__("__add__") == False
# inspect.BoundArguments.__dict__.__contains__("__sub__") == False
# inspect.BoundArguments.__dict__.__contains__("__pow__") == False
# inspect.BoundArguments.__dict__.__contains__("__rsub__") == False
# inspect.BoundArguments.__dict__.__contains__("__rtruediv__") == False
# inspect.BoundArguments.__dict__.__contains__("__rmod__") == False
#
# BoundArguments is an introspection result object. It has __eq__ and
# __hash__ but no arithmetic operator methods. New to extra1516.
# ---------------------------------------------------------------------------

table inspect_extra1516.boundarguments_arithmetic_protocol_absence:
  description: "inspect.BoundArguments has no arithmetic operator methods in __dict__; BoundArguments is an introspection result object with no numeric support; wave 548; new to extra1516"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1516ba

  columns: [id, function, args, expected, description]
  rows:
    - [in1516ba001,
       "BoundArguments.__dict__.__contains__",
       ["__add__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__add__') == False — BoundArguments is an introspection result object holding arguments bound to a function Signature via Signature.bind() or Signature.bind_partial(); it is not a numeric type and does not implement the addition operator protocol; __add__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516ba002,
       "BoundArguments.__dict__.__contains__",
       ["__sub__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__sub__') == False — BoundArguments does not implement the subtraction operator protocol; __sub__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516ba003,
       "BoundArguments.__dict__.__contains__",
       ["__pow__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__pow__') == False — BoundArguments does not implement the exponentiation operator protocol; __pow__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516ba004,
       "BoundArguments.__dict__.__contains__",
       ["__rsub__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__rsub__') == False — BoundArguments does not implement the reflected subtraction operator protocol; __rsub__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516ba005,
       "BoundArguments.__dict__.__contains__",
       ["__rtruediv__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__rtruediv__') == False — BoundArguments does not implement the reflected true division operator protocol; __rtruediv__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516ba006,
       "BoundArguments.__dict__.__contains__",
       ["__rmod__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__rmod__') == False — BoundArguments does not implement the reflected modulo operator protocol; __rmod__ is not in BoundArguments.__dict__; verified with Python 3.12; new to extra1516"]
    - [in1516ba007,
       "BoundArguments.__dict__.__contains__",
       ["__eq__"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('__eq__') == True — BoundArguments IS a value object and defines __eq__ in its __dict__ for equality comparison; this is a comparison protocol, not an arithmetic operator protocol; verified with Python 3.12; new to extra1516"]
    - [in1516ba008,
       "BoundArguments.__dict__.__contains__",
       ["__hash__"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('__hash__') == True — BoundArguments defines __hash__ in its __dict__ making it hashable; __hash__ is a hashing protocol, wholly distinct from any absent arithmetic operator protocol; verified with Python 3.12; new to extra1516"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1516
# ---------------------------------------------------------------------------

invariant inspect_extra1516.parameter_no_add:
  description: "inspect.Parameter.__dict__ does not contain '__add__' — Parameter is an introspection object, not a numeric type; wave 548; new to extra1516"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__add__"]
  expected: false

invariant inspect_extra1516.parameter_no_mul:
  description: "inspect.Parameter.__dict__ does not contain '__mul__' — Parameter does not implement the multiplication operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__mul__"]
  expected: false

invariant inspect_extra1516.signature_no_sub:
  description: "inspect.Signature.__dict__ does not contain '__sub__' — Signature does not implement the subtraction operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__sub__"]
  expected: false

invariant inspect_extra1516.signature_no_truediv:
  description: "inspect.Signature.__dict__ does not contain '__truediv__' — Signature does not implement the true division operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__truediv__"]
  expected: false

invariant inspect_extra1516.boundarguments_no_pow:
  description: "inspect.BoundArguments.__dict__ does not contain '__pow__' — BoundArguments is an introspection result object, not a numeric type; wave 548; new to extra1516"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__pow__"]
  expected: false

invariant inspect_extra1516.boundarguments_no_radd:
  description: "inspect.BoundArguments.__dict__ does not contain '__radd__' — BoundArguments does not implement the reflected addition operator protocol; wave 548; new to extra1516"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__radd__"]
  expected: false

invariant inspect_extra1516.parameter_has_eq:
  description: "inspect.Parameter.__dict__ contains '__eq__' — Parameter IS a value object with equality comparison; wave 548; new to extra1516"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__eq__"]
  expected: true
