spec: multiprocessing_extra208
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.connection.Connection — Connection class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/connection.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.Queue.__module__ == 'multiprocessing.context' on CPython 3.14 — the context wrapper."
    - "multiprocessing.SimpleQueue.__module__ == 'multiprocessing.context' — context wrapper."
    - "multiprocessing.JoinableQueue.__module__ == 'multiprocessing.context' — context wrapper."
    - "multiprocessing.Pipe.__module__ == 'multiprocessing.context' — context wrapper."
    - "multiprocessing.connection.Connection.__module__ == 'multiprocessing.connection' — pure-Python connection."
    - "multiprocessing.ProcessError.__module__ == 'multiprocessing.context' — context defines exceptions."
    - "multiprocessing.TimeoutError.__module__ == 'multiprocessing.context' — context defines TimeoutError."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Queue class identity — extra208 namespace
# ---------------------------------------------------------------------------

table multiprocessing_extra208.queue_class_identity:
  description: "multiprocessing.Queue, SimpleQueue, and JoinableQueue __name__ and __module__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: mp208queueident

  columns: [id, function, args, expected, description]
  rows:
    - [queue_name,          Queue.__name__.__eq__,          ["Queue"],                    true, "multiprocessing.Queue.__name__ == 'Queue'"]
    - [queue_module,        Queue.__module__.__eq__,        ["multiprocessing.context"],  true, "multiprocessing.Queue.__module__ == 'multiprocessing.context'"]
    - [simqueue_name,       SimpleQueue.__name__.__eq__,    ["SimpleQueue"],              true, "multiprocessing.SimpleQueue.__name__ == 'SimpleQueue'"]
    - [simqueue_module,     SimpleQueue.__module__.__eq__,  ["multiprocessing.context"],  true, "multiprocessing.SimpleQueue.__module__ == 'multiprocessing.context'"]
    - [joinqueue_name,      JoinableQueue.__name__.__eq__,  ["JoinableQueue"],            true, "multiprocessing.JoinableQueue.__name__ == 'JoinableQueue'"]
    - [joinqueue_module,    JoinableQueue.__module__.__eq__, ["multiprocessing.context"], true, "multiprocessing.JoinableQueue.__module__ == 'multiprocessing.context'"]

# ---------------------------------------------------------------------------
# multiprocessing.Pipe and Connection class identity — extra208 namespace
# ---------------------------------------------------------------------------

table multiprocessing_extra208.pipe_connection_identity:
  description: "multiprocessing.Pipe and Connection __name__ and __module__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: mp208pipeident

  columns: [id, function, args, expected, description]
  rows:
    - [pipe_name,       Pipe.__name__.__eq__,                                       ["Pipe"],                          true, "multiprocessing.Pipe.__name__ == 'Pipe'"]
    - [pipe_module,     Pipe.__module__.__eq__,                                     ["multiprocessing.context"],       true, "multiprocessing.Pipe.__module__ == 'multiprocessing.context'"]
    - [conn_name,       multiprocessing.connection.Connection.__name__.__eq__,      ["Connection"],                    true, "multiprocessing.connection.Connection.__name__ == 'Connection'"]
    - [conn_module,     multiprocessing.connection.Connection.__module__.__eq__,    ["multiprocessing.connection"],    true, "multiprocessing.connection.Connection.__module__ == 'multiprocessing.connection'"]

# ---------------------------------------------------------------------------
# multiprocessing exception class identity — extra208 namespace
# ---------------------------------------------------------------------------

table multiprocessing_extra208.exception_identity:
  description: "multiprocessing.ProcessError and TimeoutError __name__ and __module__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: mp208excident

  columns: [id, function, args, expected, description]
  rows:
    - [proc_err_name,   ProcessError.__name__.__eq__,   ["ProcessError"],             true, "multiprocessing.ProcessError.__name__ == 'ProcessError'"]
    - [proc_err_module, ProcessError.__module__.__eq__, ["multiprocessing.context"],  true, "multiprocessing.ProcessError.__module__ == 'multiprocessing.context'"]
    - [timeout_name,    TimeoutError.__name__.__eq__,   ["TimeoutError"],             true, "multiprocessing.TimeoutError.__name__ == 'TimeoutError'"]
    - [timeout_module,  TimeoutError.__module__.__eq__, ["multiprocessing.context"],  true, "multiprocessing.TimeoutError.__module__ == 'multiprocessing.context'"]
