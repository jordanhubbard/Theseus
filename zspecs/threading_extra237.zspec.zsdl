spec: threading_extra237
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading.Semaphore class identity and behavioral contracts."
    - "threading.Semaphore.__name__ == 'Semaphore' (len=9) — the class name. Verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading' (len=9) — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Semaphore.__qualname__ == 'Semaphore' (len=9). Verified with Python 3.14.3."
    - "threading.Semaphore.__class__.__name__ == 'type' — Semaphore is a Python class. Verified with Python 3.14.3."
    - "threading.Semaphore.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__name__ == 'acquire' (len=7). Verified with Python 3.14.3."
    - "threading.Semaphore.release.__name__ == 'release' (len=7). Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len=17). Verified with Python 3.14.3."
    - "threading.Semaphore.release.__qualname__ == 'Semaphore.release' (len=17). Verified with Python 3.14.3."
    - "threading.Semaphore.__doc__.__contains__('counter') == True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Semaphore class identity contracts
#
# threading.Semaphore.__name__ == 'Semaphore' (len=9)
# threading.Semaphore.__module__ == 'threading' (len=9)
# threading.Semaphore.__qualname__ == 'Semaphore' (len=9)
# threading.Semaphore.__class__.__name__ == 'type'
# threading.Semaphore.__bases__[0].__name__ == 'object'
#
# Semaphore is a Python class in Lib/threading.py. New to extra237.
# ---------------------------------------------------------------------------

table threading_extra237.semaphore_class_identity:
  description: "threading.Semaphore class identity: name, module, qualname, metaclass type, base object; new to extra237"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra237semclassid

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_name_eq,
       Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is a Python class in Lib/threading.py implementing counting semaphore synchronization; __name__ is 'Semaphore' (len=9); new to extra237"]
    - [semaphore_name_len_9,
       Semaphore.__name__.__len__,
       [],
       9,
       "threading.Semaphore.__name__.__len__() == 9 — 'Semaphore' has exactly 9 characters (S-e-m-a-p-h-o-r-e); str.__len__() returns 9; new to extra237"]
    - [semaphore_module_eq,
       Semaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra237"]
    - [semaphore_qualname_eq,
       Semaphore.__qualname__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__qualname__.__eq__('Semaphore') == True — Semaphore is a top-level class with unqualified qualname 'Semaphore'; new to extra237"]
    - [semaphore_class_is_type,
       Semaphore.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Semaphore.__class__.__name__.__eq__('type') == True — Semaphore is a Python class; its metaclass is the built-in type; new to extra237"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore base, MRO, and doc contracts
#
# threading.Semaphore.__bases__[0].__name__ == 'object'
# threading.Semaphore.__mro__[0].__name__ == 'Semaphore'
# threading.Semaphore.__mro__[1].__name__ == 'object'
# threading.Semaphore.__doc__.__contains__('counter') == True
# threading.Semaphore.__doc__.__contains__('acquire') == True
#
# Semaphore has a two-element MRO and a docstring describing counter semantics. New to extra237.
# ---------------------------------------------------------------------------

table threading_extra237.semaphore_mro_and_doc:
  description: "threading.Semaphore base is object; MRO slots; doc contains 'counter' and 'acquire'; new to extra237"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra237semmrodoc

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_base_is_object,
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — Semaphore inherits directly from object; __bases__[0].__name__ is 'object'; new to extra237"]
    - [semaphore_mro0_eq,
       "Semaphore.__mro__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__mro__[0].__name__.__eq__('Semaphore') == True — MRO slot 0 is the class itself; __mro__[0].__name__ is 'Semaphore'; new to extra237"]
    - [semaphore_mro1_eq,
       "Semaphore.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__mro__[1].__name__.__eq__('object') == True — MRO slot 1 is object; Semaphore has a two-element MRO; new to extra237"]
    - [semaphore_doc_contains_counter,
       Semaphore.__doc__.__contains__,
       ["counter"],
       true,
       "threading.Semaphore.__doc__.__contains__('counter') == True — docstring describes a counter representing the number of releases; str.__contains__('counter') returns True; new to extra237"]
    - [semaphore_doc_contains_acquire,
       Semaphore.__doc__.__contains__,
       ["acquire"],
       true,
       "threading.Semaphore.__doc__.__contains__('acquire') == True — docstring mentions acquire as a key operation on the semaphore; str.__contains__('acquire') returns True; new to extra237"]

# ---------------------------------------------------------------------------
# Table 3: threading.Semaphore.acquire and .release method identity contracts
#
# threading.Semaphore.acquire.__name__ == 'acquire' (len=7)
# threading.Semaphore.release.__name__ == 'release' (len=7)
# threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len=17)
# threading.Semaphore.release.__qualname__ == 'Semaphore.release' (len=17)
# threading.Semaphore.acquire.__class__.__name__ == 'function'
#
# acquire and release are Python methods on Semaphore. New to extra237.
# ---------------------------------------------------------------------------

table threading_extra237.semaphore_method_identity:
  description: "threading.Semaphore.acquire and release method identity: name, qualname, class is function; new to extra237"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra237semmethid

  columns: [id, function, args, expected, description]
  rows:
    - [acquire_name_eq,
       Semaphore.acquire.__name__.__eq__,
       ["acquire"],
       true,
       "threading.Semaphore.acquire.__name__.__eq__('acquire') == True — acquire is a method on Semaphore that decrements the counter; __name__ is 'acquire' (len=7); new to extra237"]
    - [release_name_eq,
       Semaphore.release.__name__.__eq__,
       ["release"],
       true,
       "threading.Semaphore.release.__name__.__eq__('release') == True — release is a method on Semaphore that increments the counter; __name__ is 'release' (len=7); new to extra237"]
    - [acquire_qualname_eq,
       Semaphore.acquire.__qualname__.__eq__,
       ["Semaphore.acquire"],
       true,
       "threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') == True — acquire qualname is 'Semaphore.acquire' (len=17) indicating it is a method of Semaphore; new to extra237"]
    - [release_qualname_eq,
       Semaphore.release.__qualname__.__eq__,
       ["Semaphore.release"],
       true,
       "threading.Semaphore.release.__qualname__.__eq__('Semaphore.release') == True — release qualname is 'Semaphore.release' (len=17) indicating it is a method of Semaphore; new to extra237"]
    - [acquire_class_is_function,
       Semaphore.acquire.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Semaphore.acquire.__class__.__name__.__eq__('function') == True — acquire is a Python function; __class__.__name__ is 'function'; new to extra237"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra237
# ---------------------------------------------------------------------------

invariant threading_extra237.semaphore_name_eq:
  description: "threading.Semaphore.__name__ == 'Semaphore' (len=9); new to extra237"
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra237.semaphore_name_len_9:
  description: "threading.Semaphore.__name__.__len__() == 9 — 'Semaphore' has 9 characters; new to extra237"
  kind: python_call_eq
  function: Semaphore.__name__.__len__
  args: []
  expected: 9

invariant threading_extra237.semaphore_module_eq:
  description: "threading.Semaphore.__module__ == 'threading'; new to extra237"
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra237.semaphore_module_len_9:
  description: "threading.Semaphore.__module__.__len__() == 9 — 'threading' has 9 characters; new to extra237"
  kind: python_call_eq
  function: Semaphore.__module__.__len__
  args: []
  expected: 9

invariant threading_extra237.semaphore_qualname_eq:
  description: "threading.Semaphore.__qualname__ == 'Semaphore'; new to extra237"
  kind: python_call_eq
  function: Semaphore.__qualname__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra237.semaphore_class_is_type:
  description: "threading.Semaphore.__class__.__name__ == 'type'; new to extra237"
  kind: python_call_eq
  function: Semaphore.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra237.semaphore_base_is_object:
  description: "threading.Semaphore.__bases__[0].__name__ == 'object'; new to extra237"
  kind: python_call_eq
  function: "Semaphore.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra237.semaphore_mro0_eq:
  description: "threading.Semaphore.__mro__[0].__name__ == 'Semaphore'; new to extra237"
  kind: python_call_eq
  function: "Semaphore.__mro__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant threading_extra237.semaphore_mro1_eq:
  description: "threading.Semaphore.__mro__[1].__name__ == 'object'; new to extra237"
  kind: python_call_eq
  function: "Semaphore.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra237.semaphore_doc_contains_counter:
  description: "threading.Semaphore.__doc__.__contains__('counter') == True; new to extra237"
  kind: python_call_eq
  function: Semaphore.__doc__.__contains__
  args: ["counter"]
  expected: true

invariant threading_extra237.semaphore_doc_contains_acquire:
  description: "threading.Semaphore.__doc__.__contains__('acquire') == True; new to extra237"
  kind: python_call_eq
  function: Semaphore.__doc__.__contains__
  args: ["acquire"]
  expected: true

invariant threading_extra237.acquire_name_eq:
  description: "threading.Semaphore.acquire.__name__ == 'acquire' (len=7); new to extra237"
  kind: python_call_eq
  function: Semaphore.acquire.__name__.__eq__
  args: ["acquire"]
  expected: true

invariant threading_extra237.release_name_eq:
  description: "threading.Semaphore.release.__name__ == 'release' (len=7); new to extra237"
  kind: python_call_eq
  function: Semaphore.release.__name__.__eq__
  args: ["release"]
  expected: true

invariant threading_extra237.acquire_qualname_eq:
  description: "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len=17); new to extra237"
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true

invariant threading_extra237.release_qualname_eq:
  description: "threading.Semaphore.release.__qualname__ == 'Semaphore.release' (len=17); new to extra237"
  kind: python_call_eq
  function: Semaphore.release.__qualname__.__eq__
  args: ["Semaphore.release"]
  expected: true
