spec: pathlib_extra78
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra77."
    - "Prior specs covered: PurePath/PurePosixPath/PureWindowsPath/Path/PosixPath/WindowsPath __name__/__module__/__qualname__; Path instance attributes; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes."
    - "pathlib_extra77 covers Path method __code__.co_name and co_argcount for open, read_text, write_text, iterdir, __init__."
    - "This spec covers: PurePath __dict__ membership; PurePath/PurePosixPath/PureWindowsPath/Path __bases__ and MRO length; PurePath class identity (__name__/__module__/__qualname__)."
    - "pathlib.PurePath.__name__ == 'PurePath'."
    - "pathlib.PurePath.__module__ == 'pathlib'."
    - "pathlib.PurePath.__qualname__ == 'PurePath'."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath directly subclasses object."
    - "pathlib.PurePath.__mro__.__len__() == 2 — PurePath MRO is [PurePath, object]."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath'."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — single base."
    - "pathlib.PurePosixPath.__mro__.__len__() == 3 — [PurePosixPath, PurePath, object]."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath'."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — single base."
    - "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path directly subclasses PurePath."
    - "pathlib.Path.__mro__.__len__() == 3 — [Path, PurePath, object]."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePath class identity — __name__, __module__, __qualname__
# Prior specs check names in various combinations; this table covers the exact
# identity triple for PurePath in the extra78 namespace.
# ---------------------------------------------------------------------------

table pathlib_extra78.PurePath_identity:
  description: "PurePath class identity: __name__, __module__, __qualname__"
  kind: python_call_eq
  category: class_names
  id_prefix: pathlibann78

  columns: [id, function, args, expected]
  rows:
    - [purepath_name,     PurePath.__name__.__eq__,     ["PurePath"], true]
    - [purepath_module,   PurePath.__module__.__eq__,   ["pathlib"],  true]
    - [purepath_qualname, PurePath.__qualname__.__eq__, ["PurePath"], true]

# ---------------------------------------------------------------------------
# PurePath, PurePosixPath, PureWindowsPath base class checks
# __bases__[0].__name__ for each concrete pure-path class.
# Function values with [ must be double-quoted.
# ---------------------------------------------------------------------------

table pathlib_extra78.PurePath_bases:
  description: "PurePath hierarchy __bases__[0].__name__ checks"
  kind: python_call_eq
  category: class_bases
  id_prefix: pathlibann78

  columns: [id, function, args, expected]
  rows:
    - [purepath_base,         "PurePath.__bases__[0].__name__.__eq__",         ["object"],    true]
    - [pureposixpath_base,    "PurePosixPath.__bases__[0].__name__.__eq__",    ["PurePath"],  true]
    - [purewindowspath_base,  "PureWindowsPath.__bases__[0].__name__.__eq__",  ["PurePath"],  true]
    - [path_base,             "Path.__bases__[0].__name__.__eq__",             ["PurePath"],  true]

# ---------------------------------------------------------------------------
# MRO length checks for PurePath hierarchy
# PurePath: 2 (PurePath, object)
# PurePosixPath: 3 (PurePosixPath, PurePath, object)
# PureWindowsPath: 3 (PureWindowsPath, PurePath, object)
# Path: 3 (Path, PurePath, object)
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra78.PurePath_mro_lengths:
  description: "PurePath hierarchy __mro__.__len__() values"
  kind: python_call_eq
  category: class_bases
  id_prefix: pathlibann78

  columns: [id, function, args, expected]
  rows:
    - [purepath_mro,        PurePath.__mro__.__len__,        [], 2]
    - [pureposixpath_mro,   PurePosixPath.__mro__.__len__,   [], 3]
    - [purewindowspath_mro, PureWindowsPath.__mro__.__len__, [], 3]
    - [path_mro,            Path.__mro__.__len__,            [], 3]

# ---------------------------------------------------------------------------
# PurePath.__dict__ membership checks
# PurePath defines joinpath, __new__, parser, with_segments in its __dict__.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra78.PurePath_dict_contains:
  description: "PurePath.__dict__ contains its key method and attribute definitions"
  kind: python_call_eq
  category: class_dict
  id_prefix: pathlibann78

  columns: [id, function, args, expected]
  rows:
    - [has_new,          "PurePath.__dict__.__contains__", ["__new__"],      true]
    - [has_joinpath,     "PurePath.__dict__.__contains__", ["joinpath"],     true]
    - [has_parser,       "PurePath.__dict__.__contains__", ["parser"],       true]
    - [has_with_segments,"PurePath.__dict__.__contains__", ["with_segments"],true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra78.PurePath.name_eq:
  description: "pathlib.PurePath.__name__ == 'PurePath'"
  category: class_names
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra78.PurePath.module_eq:
  description: "pathlib.PurePath.__module__ == 'pathlib'"
  category: class_names
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra78.PurePath.mro_len_2:
  description: "pathlib.PurePath.__mro__.__len__() == 2 — MRO is [PurePath, object]"
  category: class_bases
  kind: python_call_eq
  function: PurePath.__mro__.__len__
  args: []
  expected: 2

invariant pathlib_extra78.PurePosixPath.base_is_purepath:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath'"
  category: class_bases
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra78.Path.mro_len_3:
  description: "pathlib.Path.__mro__.__len__() == 3 — MRO is [Path, PurePath, object]"
  category: class_bases
  kind: python_call_eq
  function: Path.__mro__.__len__
  args: []
  expected: 3
