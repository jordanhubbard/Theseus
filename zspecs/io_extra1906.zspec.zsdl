spec: io_extra1906
version: ">=3.9"
backend: python_module(io)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper are C-level types implemented in _io module; __module__ == '_io'."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are Python abstract base classes; __module__ == 'io'."
    - "None of the io types define __reversed__, __missing__, or __match_args__ in their __dict__."
    - "io.IOBase.__dict__ contains __abstractmethods__ (True) because it is an ABC; concrete types like io.BytesIO do not."
    - "io.BytesIO.__qualname__ == 'BytesIO' — C-level type, top-level qualname."
    - "io.StringIO.__qualname__ == 'StringIO' — C-level type."
    - "io.FileIO.__qualname__ == 'FileIO' — C-level type."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — C-level type."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' — C-level type."
    - "io.BufferedRandom.__qualname__ == 'BufferedRandom' — C-level type."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — C-level type."
    - "io.RawIOBase.__qualname__ == 'RawIOBase' — Python ABC."
    - "io.BufferedIOBase.__qualname__ == 'BufferedIOBase' — Python ABC."
    - "io.TextIOBase.__qualname__ == 'TextIOBase' — Python ABC."
    - "io.IOBase.__qualname__ == 'IOBase' — Python ABC."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table io_extra1906.reversed_protocol:
  description: "io types __reversed__ dict-presence checks"
  kind: python_call_eq
  category: reversed_protocol
  id_prefix: io1906

  columns: [id, function, args, expected]
  rows:
    - ["io1906001", "io.BytesIO.__dict__.__contains__", ["__reversed__"], false]
    - ["io1906002", "io.StringIO.__dict__.__contains__", ["__reversed__"], false]
    - ["io1906003", "io.FileIO.__dict__.__contains__", ["__reversed__"], false]
    - ["io1906004", "io.BufferedReader.__dict__.__contains__", ["__reversed__"], false]
    - ["io1906005", "io.BufferedWriter.__dict__.__contains__", ["__reversed__"], false]
    - ["io1906006", "io.BufferedRandom.__dict__.__contains__", ["__reversed__"], false]
    - ["io1906007", "io.TextIOWrapper.__dict__.__contains__", ["__reversed__"], false]
    - ["io1906008", "io.RawIOBase.__dict__.__contains__", ["__reversed__"], false]
    - ["io1906009", "io.BufferedIOBase.__dict__.__contains__", ["__reversed__"], false]
    - ["io1906010", "io.IOBase.__dict__.__contains__", ["__reversed__"], false]

