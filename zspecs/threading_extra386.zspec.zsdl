spec: threading_extra386
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant set to the maximum value accepted by sleep and Lock.acquire; verified Python 3.14.4."
    - "threading.TIMEOUT_MAX > 0 evaluates to True — the value is a large positive float. Verified with Python 3.14.4."
    - "threading.excepthook.__name__ == '_excepthook', __module__ == '_thread' — the excepthook is a C builtin from the _thread extension. Verified with Python 3.14.4."
    - "threading.get_ident.__name__ == 'get_ident', __module__ == '_thread' — implemented in the _thread C extension. Verified with Python 3.14.4."
    - "threading.get_native_id.__name__ == 'get_native_id', __module__ == '_thread' — implemented in the _thread C extension (Python 3.8+). Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.TIMEOUT_MAX type and positivity
#
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.TIMEOUT_MAX > 0 == True
#
# TIMEOUT_MAX is a module-level float constant equal to the maximum value
# that the timeout parameter of blocking functions (threading.Lock.acquire,
# threading.Event.wait, etc.) will accept. It is a large positive float on
# all supported platforms.
# ---------------------------------------------------------------------------

table threading_extra386.timeout_max_identity:
  description: "threading.TIMEOUT_MAX class name ('float') and positivity; new to extra386"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtm386

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_class_name_eq,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a module-level float constant representing the maximum value accepted as a timeout by threading blocking functions such as Lock.acquire and Event.wait; __class__.__name__ is 'float'; str.__eq__('float') returns True; new to extra386"]
    - [timeout_max_positive,
       "TIMEOUT_MAX.__gt__",
       [0],
       true,
       "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float on all supported platforms; __gt__(0) returns True; new to extra386"]

# ---------------------------------------------------------------------------
# Table 2: threading.excepthook identity
#
# threading.excepthook.__name__ == '_excepthook'
# threading.excepthook.__module__ == '_thread'
#
# threading.excepthook is the function called when an unhandled exception
# occurs in a thread. Despite being exposed as threading.excepthook, the
# underlying object is the C builtin '_excepthook' from the _thread extension.
# ---------------------------------------------------------------------------

table threading_extra386.excepthook_identity:
  description: "threading.excepthook __name__ ('_excepthook') and __module__ ('_thread'); new to extra386"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingeh386

  columns: [id, function, args, expected, description]
  rows:
    - [excepthook_name_eq,
       "excepthook.__name__.__eq__",
       ["_excepthook"],
       true,
       "threading.excepthook.__name__.__eq__('_excepthook') == True — threading.excepthook is the C builtin '_excepthook' from the _thread extension that is called when an unhandled exception propagates out of a thread's run method; __name__ is '_excepthook'; str.__eq__('_excepthook') returns True; new to extra386"]
    - [excepthook_module_eq,
       "excepthook.__module__.__eq__",
       ["_thread"],
       true,
       "threading.excepthook.__module__.__eq__('_thread') == True — threading.excepthook is implemented in the _thread C extension; __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra386"]

# ---------------------------------------------------------------------------
# Table 3: threading.get_ident and threading.get_native_id identity
#
# threading.get_ident.__name__ == 'get_ident'
# threading.get_ident.__module__ == '_thread'
# threading.get_native_id.__name__ == 'get_native_id'
# threading.get_native_id.__module__ == '_thread'
#
# Both are C builtins from the _thread extension. get_ident returns the
# thread identifier of the current thread (a nonzero integer). get_native_id
# (Python 3.8+) returns the native OS thread ID.
# ---------------------------------------------------------------------------

table threading_extra386.thread_id_functions_identity:
  description: "threading.get_ident and threading.get_native_id __name__ and __module__ identity; new to extra386"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingid386

  columns: [id, function, args, expected, description]
  rows:
    - [get_ident_name_eq,
       "get_ident.__name__.__eq__",
       ["get_ident"],
       true,
       "threading.get_ident.__name__.__eq__('get_ident') == True — get_ident is a C builtin from the _thread extension that returns the thread identifier (a nonzero integer) of the calling thread; __name__ is 'get_ident'; str.__eq__('get_ident') returns True; new to extra386"]
    - [get_ident_module_eq,
       "get_ident.__module__.__eq__",
       ["_thread"],
       true,
       "threading.get_ident.__module__.__eq__('_thread') == True — get_ident is implemented in the _thread C extension; __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra386"]
    - [get_native_id_name_eq,
       "get_native_id.__name__.__eq__",
       ["get_native_id"],
       true,
       "threading.get_native_id.__name__.__eq__('get_native_id') == True — get_native_id is a C builtin added in Python 3.8 from the _thread extension that returns the native OS-level thread ID of the calling thread; __name__ is 'get_native_id'; str.__eq__('get_native_id') returns True; new to extra386"]
    - [get_native_id_module_eq,
       "get_native_id.__module__.__eq__",
       ["_thread"],
       true,
       "threading.get_native_id.__module__.__eq__('_thread') == True — get_native_id is implemented in the _thread C extension; __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra386"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra386
# ---------------------------------------------------------------------------

invariant threading_extra386.timeout_max_class_name:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — large positive float constant for max blocking timeout; new to extra386"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra386.timeout_max_positive:
  description: "threading.TIMEOUT_MAX > 0 — TIMEOUT_MAX is a large positive float on all supported platforms; new to extra386"
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [0]
  expected: true

invariant threading_extra386.excepthook_name:
  description: "threading.excepthook.__name__ == '_excepthook' — C builtin from _thread extension; new to extra386"
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["_excepthook"]
  expected: true

invariant threading_extra386.excepthook_module:
  description: "threading.excepthook.__module__ == '_thread' — implemented in the _thread C extension; new to extra386"
  kind: python_call_eq
  function: excepthook.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra386.get_ident_name:
  description: "threading.get_ident.__name__ == 'get_ident' — C builtin from _thread extension returning thread ID; new to extra386"
  kind: python_call_eq
  function: get_ident.__name__.__eq__
  args: ["get_ident"]
  expected: true

invariant threading_extra386.get_ident_module:
  description: "threading.get_ident.__module__ == '_thread' — implemented in the _thread C extension; new to extra386"
  kind: python_call_eq
  function: get_ident.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra386.get_native_id_name:
  description: "threading.get_native_id.__name__ == 'get_native_id' — C builtin from _thread extension returning native OS thread ID (Python 3.8+); new to extra386"
  kind: python_call_eq
  function: get_native_id.__name__.__eq__
  args: ["get_native_id"]
  expected: true

invariant threading_extra386.get_native_id_module:
  description: "threading.get_native_id.__module__ == '_thread' — implemented in the _thread C extension (Python 3.8+); new to extra386"
  kind: python_call_eq
  function: get_native_id.__module__.__eq__
  args: ["_thread"]
  expected: true
