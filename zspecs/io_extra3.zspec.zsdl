spec: io_extra3
version: ">=3.2"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "Python io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec extends io.zspec.zsdl, io_extra.zspec.zsdl, and io_extra2.zspec.zsdl; it does NOT duplicate invariants from those files."
    - "io.zspec.zsdl covers: StringIO.__name__, BytesIO.__name__, SEEK_* values, stream read/getvalue/tell/readable/writable/seekable/closed."
    - "io_extra.zspec.zsdl covers: DEFAULT_BUFFER_SIZE type/positive, SEEK_* type checks, TextIOWrapper/BufferedRandom class metadata, UnsupportedOperation name/module/type."
    - "io_extra2.zspec.zsdl covers: IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO/BufferedReader/BufferedWriter/BufferedRWPair/IncrementalNewlineDecoder class names."
    - "io.open is the same object as the built-in open function; io.open.__name__ == 'open'."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO extends the internal C-level _RawIOBase class."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO extends the internal C-level _TextIOBase class."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO extends the internal C-level _BufferedIOBase class."
    - "io.UnsupportedOperation has two direct base classes: OSError and ValueError (in that order)."
    - "io.DEFAULT_BUFFER_SIZE == 131072 on macOS/Darwin 25.4.0 with Python 3.14.3 (platform-specific; may differ on other systems)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.open — function name
# ---------------------------------------------------------------------------

invariant io_extra3.open.name:
  description: "io.open.__name__ == 'open' — io.open is the built-in open function"
  category: functions
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# UnsupportedOperation — dual inheritance from OSError and ValueError
# ---------------------------------------------------------------------------

invariant io_extra3.UnsupportedOperation.bases_count:
  description: "len(io.UnsupportedOperation.__bases__) == 2 — UnsupportedOperation inherits from both OSError and ValueError"
  category: class_metadata
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__len__
  args: []
  expected: 2

invariant io_extra3.UnsupportedOperation.base0_oserror:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError'"
  category: class_metadata
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "OSError"

invariant io_extra3.UnsupportedOperation.base1_valueerror:
  description: "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError'"
  category: class_metadata
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__getitem__
  args: [1]
  method: __name__
  method_args: []
  expected: "ValueError"

# ---------------------------------------------------------------------------
# FileIO — base class
# ---------------------------------------------------------------------------

invariant io_extra3.FileIO.base:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO extends the C-level _RawIOBase"
  category: class_metadata
  kind: python_call_eq
  function: FileIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_RawIOBase"

# ---------------------------------------------------------------------------
# StringIO — base class
# ---------------------------------------------------------------------------

invariant io_extra3.StringIO.base:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO extends the C-level _TextIOBase"
  category: class_metadata
  kind: python_call_eq
  function: StringIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_TextIOBase"

# ---------------------------------------------------------------------------
# BytesIO — base class
# ---------------------------------------------------------------------------

invariant io_extra3.BytesIO.base:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO extends the C-level _BufferedIOBase"
  category: class_metadata
  kind: python_call_eq
  function: BytesIO.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_BufferedIOBase"

# ---------------------------------------------------------------------------
# DEFAULT_BUFFER_SIZE — exact value on this platform
# ---------------------------------------------------------------------------

invariant io_extra3.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 on macOS/Darwin 25.4.0 with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true
