spec: abc_extra631
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Abstract Base Classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers ABCMeta and ABC MRO, abstractmethods, dict class identity; ABCMeta.__new__ qualname/module; abstractmethod and abstractproperty attributes"
  created_at: "2026-04-12T00:00:00Z"

table abc_extra631.mro_identity:
  description: "abc.ABCMeta and abc.ABC __mro__ and __abstractmethods__ class identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: ab631mk
  columns: [id, function, args, expected]
  rows:
    - [ab631mk001, abc.ABCMeta.__mro__.__class__.__name__.__eq__, ["tuple"], true]
    - [ab631mk002, abc.ABC.__mro__.__class__.__name__.__eq__, ["tuple"], true]
    - [ab631mk003, abc.ABCMeta.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true]
    - [ab631mk004, abc.ABC.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true]
    - [ab631mk005, abc.ABCMeta.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [ab631mk006, abc.ABC.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

table abc_extra631.callable_and_attr_identity:
  description: "abc utility function and decorator attribute identity checks"
  kind: python_call_eq
  category: attribute_identity
  id_prefix: ab631co
  columns: [id, function, args, expected]
  rows:
    - [ab631co001, abc.get_cache_token.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab631co002, abc.ABCMeta.__new__.__qualname__.__eq__, ["ABCMeta.__new__"], true]
    - [ab631co003, abc.ABCMeta.__new__.__module__.__eq__, ["abc"], true]
    - [ab631co004, abc.abstractmethod.__wrapped__.__class__.__name__.__eq__, ["NoneType"], true]
    - [ab631co005, abc.abstractproperty.__isabstractmethod__.__class__.__name__.__eq__, ["bool"], true]
