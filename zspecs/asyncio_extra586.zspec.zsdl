spec: asyncio_extra586
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio class and method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__ and __module__ identity for core asyncio classes and methods"
  created_at: "2026-04-12T00:00:00Z"

table asyncio_class_qualname:
  description: "__qualname__ identity for core asyncio classes"
  columns: [id, function, args, expected]
  rows:
    - [as586qn01, asyncio.AbstractEventLoop.__qualname__.__eq__, ["AbstractEventLoop"], true]
    - [as586qn02, asyncio.BaseEventLoop.__qualname__.__eq__, ["BaseEventLoop"], true]
    - [as586qn03, asyncio.Future.__qualname__.__eq__, ["Future"], true]
    - [as586qn04, asyncio.Task.__qualname__.__eq__, ["Task"], true]
    - [as586qn05, asyncio.Queue.__qualname__.__eq__, ["Queue"], true]
    - [as586qn06, asyncio.Lock.__qualname__.__eq__, ["Lock"], true]
    - [as586qn07, asyncio.Semaphore.__qualname__.__eq__, ["Semaphore"], true]
    - [as586qn08, asyncio.Event.__qualname__.__eq__, ["Event"], true]

table asyncio_class_module:
  description: "__module__ identity for core asyncio classes"
  columns: [id, function, args, expected]
  rows:
    - [as586md01, asyncio.AbstractEventLoop.__module__.__eq__, ["asyncio.events"], true]
    - [as586md02, asyncio.Future.__module__.__eq__, ["asyncio.futures"], true]
    - [as586md03, asyncio.Task.__module__.__eq__, ["asyncio.tasks"], true]
    - [as586md04, asyncio.Queue.__module__.__eq__, ["asyncio.queues"], true]
    - [as586md05, asyncio.Lock.__module__.__eq__, ["asyncio.locks"], true]

table asyncio_method_qualname:
  description: "__qualname__ identity for asyncio instance method objects"
  columns: [id, function, args, expected]
  rows:
    - [as586mq01, asyncio.Future.__init__.__qualname__.__eq__, ["Future.__init__"], true]
    - [as586mq02, asyncio.Task.__init__.__qualname__.__eq__, ["Task.__init__"], true]
