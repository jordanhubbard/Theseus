spec: urllib_extra3
version: ">=3.4"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html
rfcs:
  - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"
  - "RFC 1808 — Relative Uniform Resource Locators"

provenance:
  derived_from:
    - "Python 3 urllib.parse documentation — https://docs.python.org/3/library/urllib.parse.html"
    - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
    - "urllib.zspec.zsdl — covers urllib.parse function names (urlparse, urlunparse, urlencode, quote, unquote, urljoin, urlsplit)"
    - "urllib_extra.zspec.zsdl — covers urllib.parse.urlparse result fields (scheme, netloc, path), urllib.parse.quote behavior, urllib.parse.urlencode basic behavior"
    - "urllib_extra2.zspec.zsdl — covers urllib.error class names (URLError, HTTPError, ContentTooShortError), urllib.request class/function names, urllib.robotparser class name"
    - "urllib_parse.zspec.zsdl — covers urlparse components, quoting table, urljoin, urlencode.simple, parse_qs multi-value and single-value"
    - "urllib_parse_extra.zspec.zsdl — covers ParseResult/SplitResult/DefragResult class names and _fields, urldefrag, urlunparse, urlunsplit, parse_qsl"
    - "urllib_parse_extra2.zspec.zsdl — covers urlparse/urlencode/quote/unquote/urljoin/urlsplit __name__ checks"
    - "urllib_error.zspec.zsdl — covers URLError/HTTPError/ContentTooShortError class names, module checks, URLError.reason, HTTPError.code/reason/url, inheritance"
  notes:
    - "This spec focuses on: urlsplit SplitResult class name, parse_qs single-value result, parse_qsl result pairs, urlencode({'a':1})=='a=1', quote(' ')=='%20', quote('/')=='%2F', unquote('%20')==' ', urljoin path resolution, urlunparse with empty params/query/fragment."
    - "urllib.parse.urlsplit returns a SplitResult; SplitResult.__class__.__name__ == 'SplitResult'."
    - "urllib.parse.parse_qs({'a': ['1']}) — parse_qs on a plain string 'a=1' returns {'a': ['1']}."
    - "urllib.parse.parse_qsl('a=1&b=2') returns [('a','1'),('b','2')] as a list of 2-tuples."
    - "urllib.parse.urlencode({'a': 1}) == 'a=1' — single-entry dict with integer value."
    - "urllib.parse.quote(' ') == '%20' — space is always percent-encoded (not in default safe='/')."
    - "urllib.parse.quote('/') == '%2F' — slash encoded when safe=''."
    - "urllib.parse.unquote('%20') == ' ' — %20 decoded back to space."
    - "urllib.parse.urljoin('http://example.com/a', 'b') == 'http://example.com/b' — relative path replaces last segment."
    - "urllib.parse.urlunparse(('http','example.com','/',\"\",'','')) == 'http://example.com/' — minimal reconstruction."
    - "All expected values verified by running Python 3.14.3 urllib.parse module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# urlsplit — SplitResult class name
# ---------------------------------------------------------------------------

invariant urllib_extra3.urlsplit.result_class_name:
  description: "urlsplit('http://example.com/').__class__.__name__ == 'SplitResult'"
  category: urlsplit
  kind: python_call_eq
  function: urlsplit
  args: ["http://example.com/"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["SplitResult"]
  expected: true

# ---------------------------------------------------------------------------
# urlsplit — individual component values
# ---------------------------------------------------------------------------

invariant urllib_extra3.urlsplit.scheme:
  description: "urlsplit('http://example.com/path').scheme == 'http'"
  category: urlsplit
  kind: python_call_eq
  function: urlsplit
  args: ["http://example.com/path"]
  method: scheme
  expected: "http"

invariant urllib_extra3.urlsplit.netloc:
  description: "urlsplit('http://example.com/path').netloc == 'example.com'"
  category: urlsplit
  kind: python_call_eq
  function: urlsplit
  args: ["http://example.com/path"]
  method: netloc
  expected: "example.com"

# ---------------------------------------------------------------------------
# parse_qs — single-key query string returns dict with list value
# ---------------------------------------------------------------------------

invariant urllib_extra3.parse_qs.single_value:
  description: "parse_qs('a=1') == {'a': ['1']}"
  category: parse_qs
  kind: python_call_eq
  function: parse_qs
  args: ["a=1"]
  expected: {a: ["1"]}

# ---------------------------------------------------------------------------
# parse_qsl — returns list of (key, value) 2-tuples
# ---------------------------------------------------------------------------

invariant urllib_extra3.parse_qsl.two_pairs:
  description: "parse_qsl('a=1&b=2') returns a list of 2 pairs"
  category: parse_qsl
  kind: python_call_eq
  function: parse_qsl
  args: ["a=1&b=2"]
  method: __len__
  method_args: []
  expected: 2

invariant urllib_extra3.parse_qsl.first_pair:
  description: "parse_qsl('a=1&b=2')[0] == ('a', '1')"
  category: parse_qsl
  kind: python_call_eq
  function: parse_qsl
  args: ["a=1&b=2"]
  method: __getitem__
  method_args: [0]
  expected: ["a", "1"]

# ---------------------------------------------------------------------------
# urlencode — single-entry dict with integer value
# ---------------------------------------------------------------------------

invariant urllib_extra3.urlencode.single_int:
  description: "urlencode({'a': 1}) == 'a=1'"
  category: urlencode
  kind: python_call_eq
  function: urlencode
  args: [{a: 1}]
  expected: "a=1"

# ---------------------------------------------------------------------------
# quote — space and slash encoding
# ---------------------------------------------------------------------------

invariant urllib_extra3.quote.space:
  description: "quote(' ') == '%20' — space is percent-encoded (default safe='/')"
  category: quote
  kind: python_call_eq
  function: quote
  args: [" "]
  expected: "%20"

invariant urllib_extra3.quote.slash_empty_safe:
  description: "quote('/', safe='') == '%2F' — slash encoded when safe=''"
  category: quote
  kind: python_call_eq
  function: quote
  args: ["/"]
  kwargs: {safe: ""}
  expected: "%2F"

# ---------------------------------------------------------------------------
# unquote — percent-encoded space decoded to space
# ---------------------------------------------------------------------------

invariant urllib_extra3.unquote.space:
  description: "unquote('%20') == ' '"
  category: unquote
  kind: python_call_eq
  function: unquote
  args: ["%20"]
  expected: " "

# ---------------------------------------------------------------------------
# urljoin — relative path resolution
# ---------------------------------------------------------------------------

invariant urllib_extra3.urljoin.relative_sibling:
  description: "urljoin('http://example.com/a', 'b') == 'http://example.com/b'"
  category: urljoin
  kind: python_call_eq
  function: urljoin
  args: ["http://example.com/a", "b"]
  expected: "http://example.com/b"

# ---------------------------------------------------------------------------
# urlunparse — minimal six-tuple reconstruction
# ---------------------------------------------------------------------------

invariant urllib_extra3.urlunparse.minimal:
  description: "urlunparse(('http','example.com','/','','','')) == 'http://example.com/'"
  category: urlunparse
  kind: python_call_eq
  function: urlunparse
  args: [["http", "example.com", "/", "", "", ""]]
  expected: "http://example.com/"
