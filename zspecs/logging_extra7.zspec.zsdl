spec: logging_extra7
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl and prior extras through logging_extra6.zspec.zsdl."
    - "logging_extra5 covers: __name__ for Logger/Handler/Formatter/Filter/LogRecord/StreamHandler/FileHandler/NullHandler; __module__ for Logger/Handler/Formatter."
    - "logging_extra6 covers: __qualname__ for all major classes and getLogger/basicConfig; level constants."
    - "logging_extra4 covers: Filterer/__name__+__module__; Manager/__name__; PlaceHolder/__name__; PercentStyle/StrFormatStyle/StringTemplateStyle __name__; class hierarchy via __bases__."
    - "logging_extra3 covers: Handler/Formatter/Filter/LogRecord __module__; NullHandler __module__; getLogger/__module__; basicConfig/__module__."
    - "This spec adds __qualname__ for Filterer, Manager, PlaceHolder, and the three style classes (not covered in extra6)."
    - "This spec adds __module__ for the three style classes, NullHandler, StreamHandler, FileHandler, Filter, LogRecord (extra coverage of new axes from prior spec family)."
    - "logging.Filterer.__qualname__ == 'Filterer' — top-level class."
    - "logging.Manager.__qualname__ == 'Manager' — top-level class."
    - "logging.PlaceHolder.__qualname__ == 'PlaceHolder' — top-level class."
    - "logging.PercentStyle.__qualname__ == 'PercentStyle' — top-level formatting-style class."
    - "logging.StrFormatStyle.__qualname__ == 'StrFormatStyle' — top-level formatting-style class."
    - "logging.StringTemplateStyle.__qualname__ == 'StringTemplateStyle' — top-level formatting-style class."
    - "logging.PercentStyle.__module__ == 'logging'."
    - "logging.StrFormatStyle.__module__ == 'logging'."
    - "logging.StringTemplateStyle.__module__ == 'logging'."
    - "logging.NullHandler.__module__ == 'logging' — already covered in extra3; not duplicated here."
    - "logging.getLevelName.__module__ == 'logging' — function module, not previously checked."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for Filterer, Manager, PlaceHolder
#
# logging_extra6 covers __qualname__ for Logger/Handler/Formatter/Filter/
# LogRecord/StreamHandler/FileHandler/NullHandler/getLogger/basicConfig.
# Filterer, Manager, and PlaceHolder were not included there.
# ---------------------------------------------------------------------------

table logging_extra7.internal_class_qualnames:
  description: "Filterer, Manager, PlaceHolder have correct __qualname__"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Filterer,    Filterer.__qualname__.__eq__,    ["Filterer"],    true]
    - [Manager,     Manager.__qualname__.__eq__,     ["Manager"],     true]
    - [PlaceHolder, PlaceHolder.__qualname__.__eq__, ["PlaceHolder"], true]

# ---------------------------------------------------------------------------
# __qualname__ for the three Formatter style classes
#
# PercentStyle, StrFormatStyle, StringTemplateStyle are top-level classes in
# the logging module. Their __qualname__ equals their __name__.
# logging_extra4 checked __name__; this spec adds __qualname__.
# ---------------------------------------------------------------------------

table logging_extra7.style_class_qualnames:
  description: "Formatter style classes have correct __qualname__"
  kind: python_call_eq
  category: qualnames
  id_prefix: squname

  columns: [id, function, args, expected]
  rows:
    - [PercentStyle,        PercentStyle.__qualname__.__eq__,        ["PercentStyle"],        true]
    - [StrFormatStyle,      StrFormatStyle.__qualname__.__eq__,      ["StrFormatStyle"],      true]
    - [StringTemplateStyle, StringTemplateStyle.__qualname__.__eq__, ["StringTemplateStyle"], true]

# ---------------------------------------------------------------------------
# __module__ for the three Formatter style classes
#
# All three style classes are defined in logging/__init__.py; their __module__
# is 'logging'. Not previously verified in any prior logging spec.
# ---------------------------------------------------------------------------

table logging_extra7.style_class_modules:
  description: "Formatter style classes have __module__ == 'logging'"
  kind: python_call_eq
  category: class_modules
  id_prefix: smod

  columns: [id, function, args, expected]
  rows:
    - [PercentStyle,        PercentStyle.__module__.__eq__,        ["logging"], true]
    - [StrFormatStyle,      StrFormatStyle.__module__.__eq__,      ["logging"], true]
    - [StringTemplateStyle, StringTemplateStyle.__module__.__eq__, ["logging"], true]

# ---------------------------------------------------------------------------
# getLevelName.__module__ — function module, not previously verified
#
# logging.getLevelName is a plain Python function at module scope; its
# __module__ is 'logging'. Prior specs only checked __name__ and __qualname__.
# ---------------------------------------------------------------------------

invariant logging_extra7.getLevelName.module:
  description: "logging.getLevelName.__module__ == 'logging'"
  category: function_modules
  kind: python_call_eq
  function: getLevelName.__module__.__eq__
  args: ["logging"]
  expected: true
