spec: itertools_extra12
version: ">=3.12"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras through itertools_extra11.zspec.zsdl."
    - "Version bumped to >=3.12 because itertools.batched was added in Python 3.12."
    - "itertools_extra11 covers: combinations first element; combinations string length_hint; permutations first element and two-item count; product first element and length_hint (two-way and three-way); cycle first element (int list and string)."
    - "itertools_extra10 covers: takewhile(int,[1,2,0,3]) first element; dropwhile(int,[1,2,0,3]) first element; count(5,2) first element; repeat(42,5).__length_hint__(); starmap(max,...) first element; groupby('AABBB') first key; accumulate([1,2,3],max) first element; islice([10,20,30,40],2,4) first element."
    - "itertools_extra9 covers: compress('ABCDE',[1,0,1,0,1]).__next__()=='A'."
    - "itertools_extra8 covers: pairwise — __name__/__module__/__qualname__/__class__; first element; length_hint."
    - "NOT yet covered: accumulate([1,2,3,4]) second element (running sum = 3); accumulate with initial keyword; batched class name and first/second/third chunk; compress second element (new selector); pairwise second element; starmap second element."
    - "accumulate([1,2,3,4]).__next__() == 1 — covered in itertools.zspec."
    - "accumulate([1,2,3,4]) second element == 3 — 1+2=3, new vector."
    - "batched([1,2,3,4,5], 2) first chunk == (1,2) — first batch of 2."
    - "batched([1,2,3,4,5], 2) third chunk == (5,) — trailing partial batch."
    - "compress('ABCDEF',[1,0,1,0,1,1]) second element == 'C' — second truthy selector."
    - "pairwise([1,2,3,4]) second pair == (2,3) — second overlapping pair."
    - "starmap(pow,[(2,3),(3,2)]) second element == 9 — 3**2 == 9."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# accumulate — second element and initial keyword
#
# itertools.zspec covers accumulate([5,10,15]).__next__() == 5 (first element).
# itertools_extra10 covers accumulate([1,2,3], max).__next__() == 1.
# No prior spec tests the second yielded element of accumulate with default sum.
# accumulate([1,2,3,4]): running sums are 1, 3, 6, 10. Second element == 3.
# Python 3.8+ supports the 'initial' keyword: accumulate([1,2,3], initial=10)
# yields 10, 11, 13, 16 — the initial value comes first.
# ---------------------------------------------------------------------------

invariant itertools_extra12.accumulate.second_element:
  description: "accumulate([1,2,3,4]) second element == 3 — running sum: 1, 1+2=3"
  category: accumulate
  kind: python_call_eq
  function: accumulate
  args: [[1, 2, 3, 4]]
  method: __next__
  method_chain: __next__
  expected: 3

invariant itertools_extra12.accumulate.initial_first:
  description: "accumulate([1,2,3], initial=10) first element == 10 — initial value emitted first"
  category: accumulate
  kind: python_call_eq
  function: accumulate
  args: [[1, 2, 3]]
  kwargs:
    initial: 10
  method: __next__
  expected: 10

invariant itertools_extra12.accumulate.initial_second:
  description: "accumulate([1,2,3], initial=10) second element == 11 — initial+first = 10+1"
  category: accumulate
  kind: python_call_eq
  function: accumulate
  args: [[1, 2, 3]]
  kwargs:
    initial: 10
  method: __next__
  method_chain: __next__
  expected: 11

# ---------------------------------------------------------------------------
# batched — class name and chunk behavior (Python 3.12+)
#
# itertools.batched was added in Python 3.12. No prior spec covers batched.
# batched(iterable, n) yields non-overlapping tuples of length at most n.
# batched([1,2,3,4,5], 2) yields (1,2), (3,4), (5,) — the last chunk is
# a partial tuple when the input length is not divisible by n.
# ---------------------------------------------------------------------------

invariant itertools_extra12.batched.class_name:
  description: "batched([1,2], 1).__class__.__name__ == 'batched' — C-level type name"
  category: batched
  kind: python_call_eq
  function: batched
  args: [[1, 2], 1]
  method: __class__.__name__.__eq__
  method_args: ["batched"]
  expected: true

invariant itertools_extra12.batched.first_chunk:
  description: "batched([1,2,3,4,5], 2) first chunk == (1, 2)"
  category: batched
  kind: python_call_eq
  function: batched
  args: [[1, 2, 3, 4, 5], 2]
  method: __next__
  expected: [1, 2]

invariant itertools_extra12.batched.second_chunk:
  description: "batched([1,2,3,4,5], 2) second chunk == (3, 4)"
  category: batched
  kind: python_call_eq
  function: batched
  args: [[1, 2, 3, 4, 5], 2]
  method: __next__
  method_chain: __next__
  expected: [3, 4]

# ---------------------------------------------------------------------------
# compress — second element with a string iterable
#
# itertools_extra9 covers compress('ABCDE',[1,0,1,0,1]).__next__()=='A' (first).
# No prior spec tests compress for its second yielded element.
# compress('ABCDEF', [1,0,1,0,1,1]) yields A, C, E, F.
# The second element is 'C' (selector index 2 is truthy).
# ---------------------------------------------------------------------------

invariant itertools_extra12.compress.second_element:
  description: "compress('ABCDEF', [1,0,1,0,1,1]) second element == 'C'"
  category: compress
  kind: python_call_eq
  function: compress
  args: ["ABCDEF", [1, 0, 1, 0, 1, 1]]
  method: __next__
  method_chain: __next__
  expected: "C"

invariant itertools_extra12.compress.list_first:
  description: "compress([10,20,30,40], [0,1,0,1]) first element == 20 — second item selected"
  category: compress
  kind: python_call_eq
  function: compress
  args: [[10, 20, 30, 40], [0, 1, 0, 1]]
  method: __next__
  expected: 20

# ---------------------------------------------------------------------------
# pairwise — second element
#
# itertools_extra8 covers pairwise([1,2,3,4]).__next__() == (1, 2) (first pair).
# No prior spec tests the second yielded element of pairwise.
# pairwise([1,2,3,4]) yields (1,2), (2,3), (3,4) — each adjacent pair.
# The second element is (2, 3).
# ---------------------------------------------------------------------------

invariant itertools_extra12.pairwise.second_pair:
  description: "pairwise([1,2,3,4]) second pair == (2, 3)"
  category: pairwise
  kind: python_call_eq
  function: pairwise
  args: [[1, 2, 3, 4]]
  method: __next__
  method_chain: __next__
  expected: [2, 3]

# ---------------------------------------------------------------------------
# starmap — second element
#
# itertools_extra10 covers starmap(max, [[1,3],[2,4]]).__next__() == 3 (first).
# No prior spec tests the second yielded element of starmap.
# starmap(pow, [(2,3),(3,2)]) computes pow(2,3)==8 then pow(3,2)==9.
# The second element is 9.
# ---------------------------------------------------------------------------

invariant itertools_extra12.starmap.second_element:
  description: "starmap(pow, [(2,3),(3,2)]) second element == 9 — 3**2 == 9"
  category: starmap
  kind: python_call_eq
  function: starmap
  args: [pow, [[2, 3], [3, 2]]]
  method: __next__
  method_chain: __next__
  expected: 9
