spec: csv_extra19
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra18.zspec.zsdl."
    - "csv_extra18 covers: DictReader/DictWriter/Sniffer/excel/excel_tab/Dialect __qualname__ table; get_dialect/__module__; list_dialects/__module__."
    - "csv_extra16 covers: QUOTE_* __class__.__name__ (standalone for QUOTE_ALL, QUOTE_MINIMAL in csv_extra5)."
    - "csv_extra5 covers: reader/__qualname__; writer/__qualname__; Error/__qualname__."
    - "Focus: __qualname__.__class__.__name__ type axis for csv classes and functions — no prior csv spec checks this axis for any symbol."
    - "No prior csv spec checks __qualname__.__class__.__name__ for any symbol."
    - "csv.reader.__qualname__.__class__.__name__ == 'str' — qualname of C builtin type is a string."
    - "csv.writer.__qualname__.__class__.__name__ == 'str' — qualname of C builtin type is a string."
    - "csv.DictReader.__qualname__.__class__.__name__ == 'str' — qualname of pure-Python class is a string."
    - "csv.DictWriter.__qualname__.__class__.__name__ == 'str' — qualname of pure-Python class is a string."
    - "csv.Dialect.__qualname__.__class__.__name__ == 'str' — qualname of base dialect class is a string."
    - "csv.Sniffer.__qualname__.__class__.__name__ == 'str' — qualname of Sniffer class is a string."
    - "csv.Error.__qualname__.__class__.__name__ == 'str' — qualname of exception class is a string."
    - "csv.QUOTE_ALL.__class__.__qualname__ == 'int' — class object's qualname for the int type."
    - "csv.QUOTE_MINIMAL.__class__.__qualname__ == 'int' — class object's qualname for the int type."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class and type __qualname__.__class__.__name__ — type of qualname strings
#
# csv_extra5 checks reader/__qualname__, writer/__qualname__, Error/__qualname__.
# csv_extra18 checks DictReader/DictWriter/Sniffer/excel/excel_tab/Dialect __qualname__.
# No prior csv spec checks __qualname__.__class__.__name__ for any symbol.
# All qualname attributes are plain str objects, for both C types and
# pure-Python classes.
# ---------------------------------------------------------------------------

table csv_extra19.qualname_type:
  description: "csv symbols — __qualname__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: class_attrs
  id_prefix: cqt19

  columns: [id, function, args, expected]
  rows:
    - [reader_qn_type,    reader.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [writer_qn_type,    writer.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [DictReader_qn_type, DictReader.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [DictWriter_qn_type, DictWriter.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [Dialect_qn_type,   Dialect.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [Sniffer_qn_type,   Sniffer.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [Error_qn_type,     Error.__qualname__.__class__.__name__.__eq__,     ["str"], true]

# ---------------------------------------------------------------------------
# QUOTE_ALL and QUOTE_MINIMAL — __class__.__qualname__
#
# csv_extra5 and csv_extra16 check QUOTE_ALL/__class__.__name__ == 'int'.
# No prior csv spec checks __class__.__qualname__ for the QUOTE_* constants.
# For built-in types, __qualname__ == __name__, so int.__qualname__ == 'int'.
# ---------------------------------------------------------------------------

invariant csv_extra19.QUOTE_ALL.class_qualname:
  description: "csv.QUOTE_ALL.__class__.__qualname__ == 'int' — int type's qualname"
  category: module_attrs
  kind: python_call_eq
  function: QUOTE_ALL.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true

invariant csv_extra19.QUOTE_MINIMAL.class_qualname:
  description: "csv.QUOTE_MINIMAL.__class__.__qualname__ == 'int' — int type's qualname"
  category: module_attrs
  kind: python_call_eq
  function: QUOTE_MINIMAL.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true
