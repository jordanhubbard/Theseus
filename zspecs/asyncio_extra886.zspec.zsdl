spec: asyncio_extra886
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - asyncio stdlib documentation
    - CPython asyncio/tasks.py
    - CPython asyncio/futures.py
    - CPython asyncio/locks.py
  not_derived_from:
    - any third-party asyncio extensions
    - uvloop or other asyncio replacements
  notes:
    - Covers Task/Future/Lock/Semaphore/Event/Condition method qualnames
    - All qualname checks confirm CPython method identity strings
    - Stable across CPython 3.9+
  created_at: "2026-04-12"

table asyncio_extra886.task_future_lock_qualnames:
  description: Verify __qualname__ strings for asyncio Task, Future, Lock, Semaphore, Event, and Condition methods
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: as886xx
  columns: [id, function, args, expected]
  rows:
    - [as886xx001, asyncio.Task.__init__.__qualname__.__eq__, ["Task.__init__"], true]
    - [as886xx002, asyncio.Task.__repr__.__qualname__.__eq__, ["Task.__repr__"], true]
    - [as886xx003, asyncio.Task.get_coro.__qualname__.__eq__, ["Task.get_coro"], true]
    - [as886xx004, asyncio.Task.get_name.__qualname__.__eq__, ["Task.get_name"], true]
    - [as886xx005, asyncio.Task.set_name.__qualname__.__eq__, ["Task.set_name"], true]
    - [as886xx006, asyncio.Future.__init__.__qualname__.__eq__, ["Future.__init__"], true]
    - [as886xx007, asyncio.Future.__repr__.__qualname__.__eq__, ["Future.__repr__"], true]
    - [as886xx008, asyncio.Future.__await__.__qualname__.__eq__, ["Future.__await__"], true]
    - [as886xx009, asyncio.Lock.__init__.__qualname__.__eq__, ["Lock.__init__"], true]
    - [as886xx010, asyncio.Semaphore.__init__.__qualname__.__eq__, ["Semaphore.__init__"], true]
    - [as886xx011, asyncio.Event.__init__.__qualname__.__eq__, ["Event.__init__"], true]
    - [as886xx012, asyncio.Condition.__init__.__qualname__.__eq__, ["Condition.__init__"], true]
