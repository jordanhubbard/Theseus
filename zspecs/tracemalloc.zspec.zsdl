spec: tracemalloc
version: ">=3.4"
backend: python_module(tracemalloc)

docs: https://docs.python.org/3/library/tracemalloc.html

provenance:
  derived_from:
    - "Python tracemalloc documentation — https://docs.python.org/3/library/tracemalloc.html"
    - "Test vectors verified by running Python 3.14.3 tracemalloc module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tracemalloc.py"
    - "CPython source: Modules/_tracemalloc.c"
  notes:
    - "tracemalloc was added in Python 3.4 to trace memory block allocations."
    - "is_tracing() returns False before start() is called; tests must not call start() to avoid side effects."
    - "get_traceback_limit() returns 1 by default (one frame of traceback per allocation)."
    - "take_snapshot() raises RuntimeError if tracing is not active; function identity tested via __name__ only."
    - "Snapshot, Filter, DomainFilter, Statistic, StatisticDiff, Traceback, Frame are all pure-Python classes."
    - "All expected values verified by running Python 3.14.3 tracemalloc module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "take_snapshot() raises RuntimeError when tracing is not active"
  stderr: "null"
  stickiness: "N/A"
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table tracemalloc.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [start,                start.__name__.__eq__,                ["start"],                true]
    - [stop,                 stop.__name__.__eq__,                 ["stop"],                 true]
    - [is_tracing,           is_tracing.__name__.__eq__,           ["is_tracing"],           true]
    - [get_tracemalloc_mem,  get_tracemalloc_memory.__name__.__eq__,["get_tracemalloc_memory"],true]
    - [get_object_traceback, get_object_traceback.__name__.__eq__,  ["get_object_traceback"], true]
    - [get_traced_memory,    get_traced_memory.__name__.__eq__,    ["get_traced_memory"],    true]
    - [reset_peak,           reset_peak.__name__.__eq__,           ["reset_peak"],           true]
    - [take_snapshot,        take_snapshot.__name__.__eq__,        ["take_snapshot"],        true]
    - [clear_traces,         clear_traces.__name__.__eq__,         ["clear_traces"],         true]
    - [get_traceback_limit,  get_traceback_limit.__name__.__eq__,  ["get_traceback_limit"],  true]

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table tracemalloc.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [snapshot,        Snapshot.__name__.__eq__,       ["Snapshot"],       true]
    - [filter,          Filter.__name__.__eq__,         ["Filter"],         true]
    - [domain_filter,   DomainFilter.__name__.__eq__,   ["DomainFilter"],   true]
    - [statistic_diff,  StatisticDiff.__name__.__eq__,  ["StatisticDiff"],  true]
    - [statistic,       Statistic.__name__.__eq__,      ["Statistic"],      true]
    - [traceback,       Traceback.__name__.__eq__,      ["Traceback"],      true]
    - [frame,           Frame.__name__.__eq__,          ["Frame"],          true]

# ---------------------------------------------------------------------------
# Module membership
# ---------------------------------------------------------------------------

invariant tracemalloc.Snapshot.module:
  description: "tracemalloc.Snapshot.__module__ == 'tracemalloc'"
  category: classes
  kind: python_call_eq
  function: Snapshot.__module__.__eq__
  args: ["tracemalloc"]
  expected: true

# ---------------------------------------------------------------------------
# Behavioral — is_tracing() returns False before start() is called
# ---------------------------------------------------------------------------

invariant tracemalloc.is_tracing.initially_false:
  description: "tracemalloc.is_tracing() == False — tracing is off by default"
  category: behavioral
  kind: python_call_eq
  function: is_tracing
  args: []
  expected: false

# ---------------------------------------------------------------------------
# Behavioral — get_traceback_limit() returns 1 (default frame limit)
# ---------------------------------------------------------------------------

invariant tracemalloc.get_traceback_limit.default:
  description: "tracemalloc.get_traceback_limit() == 1 — default traceback depth is 1 frame"
  category: behavioral
  kind: python_call_eq
  function: get_traceback_limit
  args: []
  expected: 1
