spec: inspect_extra1726
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "inspect.Parameter defines __eq__ and __hash__ in its own __dict__ for equality checking, but not __lt__, __le__, __gt__, __ge__, or __ne__."
    - "inspect.Signature does not define any comparison operators in its own __dict__."
    - "inspect.BoundArguments does not define any comparison operators in its own __dict__."
    - "inspect._ParameterKind is an IntEnum and inherits comparison from int/IntEnum but does NOT define __lt__, __le__, __gt__, __ge__, or __ne__ in its own __dict__."
    - "inspect.Parameter.__dict__.__contains__('__eq__') is True — Parameter defines equality for use in signature comparison."
    - "inspect.Parameter.__dict__.__contains__('__hash__') is True — Parameter defines __hash__ alongside __eq__."
    - "inspect.Parameter.__dict__.__contains__('__lt__') is False — Parameter has no ordering despite having __eq__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra1726.comparison_protocol:
  description: "inspect types comparison protocol dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1726

  columns: [id, function, args, expected]
  rows:
    - ["in1726001", "inspect.Parameter.__dict__.__contains__", ["__lt__"], false]
    - ["in1726002", "inspect.Parameter.__dict__.__contains__", ["__le__"], false]
    - ["in1726003", "inspect.Parameter.__dict__.__contains__", ["__gt__"], false]
    - ["in1726004", "inspect.Parameter.__dict__.__contains__", ["__ge__"], false]
    - ["in1726005", "inspect.Parameter.__dict__.__contains__", ["__ne__"], false]
    - ["in1726006", "inspect.Signature.__dict__.__contains__", ["__lt__"], false]
    - ["in1726007", "inspect.Signature.__dict__.__contains__", ["__le__"], false]
    - ["in1726008", "inspect.Signature.__dict__.__contains__", ["__gt__"], false]
    - ["in1726009", "inspect.Signature.__dict__.__contains__", ["__ge__"], false]
    - ["in1726010", "inspect.Signature.__dict__.__contains__", ["__ne__"], false]
    - ["in1726011", "inspect.BoundArguments.__dict__.__contains__", ["__lt__"], false]
    - ["in1726012", "inspect.BoundArguments.__dict__.__contains__", ["__le__"], false]
    - ["in1726013", "inspect.BoundArguments.__dict__.__contains__", ["__gt__"], false]
    - ["in1726014", "inspect.BoundArguments.__dict__.__contains__", ["__ge__"], false]
    - ["in1726015", "inspect.BoundArguments.__dict__.__contains__", ["__ne__"], false]

table inspect_extra1726.eq_hash_protocol:
  description: "inspect types __eq__ and __hash__ dict-presence checks — Parameter defines both, others do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1726

  columns: [id, function, args, expected]
  rows:
    - ["in1726016", "inspect.Parameter.__dict__.__contains__", ["__eq__"], true]
    - ["in1726017", "inspect.Parameter.__dict__.__contains__", ["__hash__"], true]
    - ["in1726018", "inspect.Signature.__dict__.__contains__", ["__eq__"], false]
    - ["in1726019", "inspect.Signature.__dict__.__contains__", ["__hash__"], false]
    - ["in1726020", "inspect.BoundArguments.__dict__.__contains__", ["__eq__"], false]
    - ["in1726021", "inspect.BoundArguments.__dict__.__contains__", ["__hash__"], false]
    - ["in1726022", "inspect._ParameterKind.__dict__.__contains__", ["__lt__"], false]
    - ["in1726023", "inspect._ParameterKind.__dict__.__contains__", ["__le__"], false]
    - ["in1726024", "inspect._ParameterKind.__dict__.__contains__", ["__gt__"], false]
    - ["in1726025", "inspect._ParameterKind.__dict__.__contains__", ["__ge__"], false]
