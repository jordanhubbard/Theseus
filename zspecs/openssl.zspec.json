      "category": "md5_vector",
      "rfc_reference": "RFC 1321 A.5",
      "spec": {
        "args": [
          "dgst",
          "-md5"
        ],
        "stdin_b64": "",
        "expected_substring": "d41d8cd98f00b204e9800998ecf8427e"
      }
    },
    {
      "id": "openssl.dgst.md5.abc",
      "kind": "cli_stdout_contains",
      "description": "MD5 of b'abc' == 900150983cd24fb0d6963f7d28e17f72 — cross-checks hashlib.md5.abc",
      "category": "md5_vector",
      "rfc_reference": "RFC 1321 A.5",
      "spec": {
        "args": [
          "dgst",
          "-md5"
        ],
        "stdin_b64": "YWJj",
