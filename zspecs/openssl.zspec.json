      }
    },
    {
      "id": "openssl.dgst.sha512.empty",
      "kind": "cli_stdout_contains",
      "description": "SHA-512 of empty input — cross-checks hashlib.sha512.empty",
      "category": "sha512_vector",
      "rfc_reference": "FIPS 180-4",
      "spec": {
        "args": [
          "dgst",
          "-sha512"
        ],
        "stdin_b64": "",
        "expected_substring": "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e"
      }
    },
    {
      "id": "openssl.dgst.sha512.abc",
      "kind": "cli_stdout_contains",
      "description": "SHA-512 of b'abc' — cross-checks hashlib.sha512.abc",
      "category": "sha512_vector",
      "rfc_reference": "FIPS 180-4",
      "spec": {
        "args": [
          "dgst",
          "-sha512"
        ],
        "stdin_b64": "YWJj",
        "expected_substring": "ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f"
      }
    },
    {
      "id": "openssl.dgst.sha256.raw_format",
      "kind": "cli_stdout_matches",
      "description": "openssl dgst -sha256 -r outputs '<hexdigest> *stdin' on a single line (raw format, no algorithm prefix)",
      "category": "output_format",
      "spec": {
        "args": [
          "dgst",
          "-sha256",
          "-r"
        ],
        "stdin_b64": "YWJj",
        "pattern": "^ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad[ *]"
      }
    },
    {
      "id": "openssl.dgst.sha256.exits_zero",
      "kind": "cli_exits_with",
      "description": "openssl dgst -sha256 exits 0 on valid input",
      "category": "health",
      "spec": {
        "args": [
          "dgst",
          "-sha256"
        ],
        "stdin_b64": "YWJj",
        "expected_exit": 0
      }
    },
    {
      "id": "openssl.badcmd.exits_nonzero",
      "kind": "cli_exits_with",
      "description": "openssl with an invalid subcommand exits 1",
      "category": "error",
      "spec": {
        "args": [
          "no_such_subcommand_xyz"
