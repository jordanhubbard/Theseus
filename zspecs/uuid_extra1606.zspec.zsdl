spec: uuid_extra1606
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "uuid.UUID is a pure Python class defined in Lib/uuid.py that DOES use __slots__"
    - "__slots__ = ('int', 'is_safe', '__weakref__') — exactly three slots"
    - "The 'int' and 'is_safe' slots appear as member_descriptor in UUID.__dict__"
    - "The '__weakref__' slot appears as getset_descriptor (not member_descriptor)"
    - "Because __slots__ is defined, UUID instances do NOT have a per-instance __dict__"
    - "uuid.UUID.__dict__ does NOT contain '__dict__' (no instance dict slot)"
    - "uuid.UUID exposes many computed properties (hex, bytes, fields, version, etc.) — these are property objects, NOT slot descriptors"
    - "uuid.SafeUUID is an Enum subclass (not IntEnum) and does NOT define __slots__"
    - "member_descriptor supports __get__, __set__, and __delete__ protocols"
    - "UUID instances support weakref via the __weakref__ slot"
  created_at: "2026-04-12"
error_model: python_exceptions

table uuid_extra1606.uuid_has_slots:
  description: "uuid.UUID defines __slots__ with exactly three entries: 'int', 'is_safe', '__weakref__'"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1606hs

  columns: [id, function, args, expected]
  rows:
    - ["uu1606hs001", "uuid.UUID.__dict__.__contains__",                ["__slots__"],    true]
    - ["uu1606hs002", "uuid.UUID.__dict__.__contains__",                ["__dict__"],     false]
    - ["uu1606hs003", "type(uuid.UUID.__dict__['__slots__']).__name__.__eq__", ["tuple"], true]
    - ["uu1606hs004", "len(uuid.UUID.__slots__).__eq__",                [3],              true]
    - ["uu1606hs005", "uuid.UUID.__slots__.__contains__",               ["int"],          true]
    - ["uu1606hs006", "uuid.UUID.__slots__.__contains__",               ["is_safe"],      true]
    - ["uu1606hs007", "uuid.UUID.__slots__.__contains__",               ["__weakref__"],  true]
    - ["uu1606hs008", "uuid.UUID.__dict__.__contains__",                ["clock_seq"],    true]
    - ["uu1606hs009", "uuid.UUID.__name__.__eq__",                      ["UUID"],         true]
    - ["uu1606hs010", "uuid.UUID.__module__.__eq__",                    ["uuid"],         true]
    - ["uu1606hs011", "uuid.UUID.__class__.__name__.__eq__",            ["type"],         true]
    - ["uu1606hs012", "uuid.UUID.__bases__.__len__",                    [],               1]
    - ["uu1606hs013", "uuid.UUID.__dict__.__contains__",                ["__init__"],     true]
    - ["uu1606hs014", "uuid.UUID.__dict__.__contains__",                ["__repr__"],     true]
    - ["uu1606hs015", "uuid.UUID.__dict__.__contains__",                ["__str__"],      true]
    - ["uu1606hs016", "uuid.UUID.__dict__.__contains__",                ["__eq__"],       true]
    - ["uu1606hs017", "uuid.UUID.__dict__.__contains__",                ["__hash__"],     true]
    - ["uu1606hs018", "uuid.UUID.__dict__.__contains__",                ["__lt__"],       true]
    - ["uu1606hs019", "uuid.UUID.__dict__.__contains__",                ["__setattr__"],  true]
    - ["uu1606hs020", "uuid.UUID.__dict__.__contains__",                ["__int__"],      true]
    - ["uu1606hs021", "uuid.UUID.__dict__.__contains__",                ["__getstate__"], true]
    - ["uu1606hs022", "uuid.UUID.__dict__.__contains__",                ["__setstate__"], true]
    - ["uu1606hs023", "uuid.UUID.__dict__.__contains__",                ["_from_int"],    true]
    - ["uu1606hs024", "uuid.UUID.__dict__.__contains__",                ["hex"],          true]
    - ["uu1606hs025", "uuid.UUID.__dict__.__contains__",                ["bytes"],        true]

table uuid_extra1606.uuid_slot_descriptors:
  description: "Slot descriptors in uuid.UUID.__dict__: 'int' and 'is_safe' are member_descriptor; '__weakref__' is getset_descriptor; computed properties like hex/bytes/fields are property"
  kind: python_call_eq
  category: descriptor_type
  id_prefix: uu1606sd

  columns: [id, function, args, expected]
  rows:
    - ["uu1606sd001", "type(uuid.UUID.__dict__['int']).__name__.__eq__",         ["member_descriptor"],  true]
    - ["uu1606sd002", "type(uuid.UUID.__dict__['is_safe']).__name__.__eq__",     ["member_descriptor"],  true]
    - ["uu1606sd003", "type(uuid.UUID.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"],  true]
    - ["uu1606sd004", "type(uuid.UUID.__dict__['hex']).__name__.__eq__",         ["property"],           true]
    - ["uu1606sd005", "type(uuid.UUID.__dict__['bytes']).__name__.__eq__",       ["property"],           true]
    - ["uu1606sd006", "type(uuid.UUID.__dict__['bytes_le']).__name__.__eq__",    ["property"],           true]
    - ["uu1606sd007", "type(uuid.UUID.__dict__['fields']).__name__.__eq__",      ["property"],           true]
    - ["uu1606sd008", "type(uuid.UUID.__dict__['version']).__name__.__eq__",     ["property"],           true]
    - ["uu1606sd009", "type(uuid.UUID.__dict__['variant']).__name__.__eq__",     ["property"],           true]
    - ["uu1606sd010", "type(uuid.UUID.__dict__['urn']).__name__.__eq__",         ["property"],           true]
    - ["uu1606sd011", "type(uuid.UUID.__dict__['node']).__name__.__eq__",        ["property"],           true]
    - ["uu1606sd012", "type(uuid.UUID.__dict__['time']).__name__.__eq__",        ["property"],           true]
    - ["uu1606sd013", "type(uuid.UUID.__dict__['time_low']).__name__.__eq__",    ["property"],           true]
    - ["uu1606sd014", "type(uuid.UUID.__dict__['time_mid']).__name__.__eq__",    ["property"],           true]
    - ["uu1606sd015", "type(uuid.UUID.__dict__['clock_seq']).__name__.__eq__",   ["property"],           true]
    - ["uu1606sd016", "type(uuid.UUID.__dict__['__init__']).__name__.__eq__",    ["function"],           true]
    - ["uu1606sd017", "type(uuid.UUID.__dict__['__repr__']).__name__.__eq__",    ["function"],           true]
    - ["uu1606sd018", "type(uuid.UUID.__dict__['__hash__']).__name__.__eq__",    ["function"],           true]
    - ["uu1606sd019", "type(uuid.UUID.__dict__['__eq__']).__name__.__eq__",      ["function"],           true]
    - ["uu1606sd020", "type(uuid.UUID.__dict__['__setattr__']).__name__.__eq__", ["function"],           true]
    - ["uu1606sd021", "type(uuid.UUID.__dict__['clock_seq']).__name__.__eq__",          ["property"],          true]
    - ["uu1606sd022", "type(uuid.UUID.__dict__['clock_seq_hi_variant']).__name__.__eq__", ["property"],       true]
    - ["uu1606sd023", "type(uuid.UUID.__dict__['time_hi_version']).__name__.__eq__",   ["property"],          true]
    - ["uu1606sd024", "uuid.SafeUUID.__dict__.__contains__",                     ["__slots__"],          false]
    - ["uu1606sd025", "uuid.SafeUUID.__bases__.__len__",                         [],                     1]

table uuid_extra1606.uuid_no_instance_dict:
  description: "uuid.UUID instances have no per-instance __dict__ because __slots__ is defined; instances do support weakref"
  kind: python_call_eq
  category: instance_layout
  id_prefix: uu1606id

  columns: [id, function, args, expected]
  rows:
    - ["uu1606id001", "uuid.UUID.__dict__.__contains__",                    ["__dict__"],    false]
    - ["uu1606id002", "uuid.UUID.__dict__.__contains__",                    ["__weakref__"], true]
    - ["uu1606id003", "uuid.UUID.__dict__.__contains__",                    ["clock_seq_hi_variant"], true]
    - ["uu1606id004", "type(uuid.UUID.__dict__['__slots__']).__name__.__eq__", ["tuple"],   true]
    - ["uu1606id005", "uuid.UUID.__slots__.__len__",                        [],              3]
    - ["uu1606id006", "type(uuid.UUID.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"], true]
    - ["uu1606id007", "type(uuid.UUID.__dict__['int']).__name__.__eq__",    ["member_descriptor"], true]
    - ["uu1606id008", "type(uuid.UUID.__dict__['is_safe']).__name__.__eq__", ["member_descriptor"], true]
    - ["uu1606id009", "uuid.UUID.__dict__.__class__.__name__.__eq__",       ["mappingproxy"], true]
    - ["uu1606id010", "type(uuid.UUID.__dict__['time_low']).__name__.__eq__",  ["property"],   true]
    - ["uu1606id011", "type(uuid.UUID.__dict__['time_mid']).__name__.__eq__", ["property"],   true]
    - ["uu1606id012", "uuid.UUID.__dict__.__contains__",                    ["hex"],         true]
    - ["uu1606id013", "type(uuid.UUID.__dict__['hex']).__name__.__eq__",    ["property"],    true]
    - ["uu1606id014", "uuid.UUID.__dict__.__contains__",                    ["bytes"],       true]
    - ["uu1606id015", "type(uuid.UUID.__dict__['bytes']).__name__.__eq__",  ["property"],    true]
    - ["uu1606id016", "uuid.UUID.__dict__.__contains__",                    ["fields"],      true]
    - ["uu1606id017", "type(uuid.UUID.__dict__['fields']).__name__.__eq__", ["property"],    true]
    - ["uu1606id018", "uuid.UUID.__dict__.__contains__",                    ["version"],     true]
    - ["uu1606id019", "type(uuid.UUID.__dict__['version']).__name__.__eq__", ["property"],  true]
    - ["uu1606id020", "uuid.UUID.__dict__.__contains__",                    ["node"],        true]
    - ["uu1606id021", "type(uuid.UUID.__dict__['node']).__name__.__eq__",   ["property"],   true]
    - ["uu1606id022", "uuid.UUID.__dict__.__contains__",                    ["urn"],         true]
    - ["uu1606id023", "type(uuid.UUID.__dict__['urn']).__name__.__eq__",    ["property"],   true]
    - ["uu1606id024", "uuid.UUID.__dict__.__contains__",                    ["variant"],     true]
    - ["uu1606id025", "type(uuid.UUID.__dict__['variant']).__name__.__eq__", ["property"],  true]
