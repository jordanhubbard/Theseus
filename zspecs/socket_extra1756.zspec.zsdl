spec: socket_extra1756
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "socket.socket: C extension type — a network socket object; not a numeric type; no arithmetic operators in __dict__; all eight arithmetic dunders absent."
    - "socket.AddressFamily: Python IntEnum subclass — enum for address families (AF_INET etc.); no arithmetic operators defined in its own __dict__."
    - "socket.SocketKind: Python IntEnum subclass — enum for socket kinds (SOCK_STREAM etc.); no arithmetic operators defined in its own __dict__."
    - "Complementary checks: socket.gethostname.__class__.__name__ == 'builtin_function_or_method'; socket.gethostbyname.__class__.__name__ == 'builtin_function_or_method'; socket.getaddrinfo.__class__.__name__ == 'builtin_function_or_method'; socket.AF_INET.__class__.__name__ == 'AddressFamily'; socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for socket types
#
# Wave 564 theme: which socket types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# socket.socket: C extension type (Modules/socketmodule.c) — represents an
#   open network socket; not a numeric type; no arithmetic operators in __dict__.
# socket.AddressFamily: Python IntEnum subclass (Lib/socket.py) — enum for
#   address family constants (AF_INET, AF_INET6, AF_UNIX, etc.); enum members
#   support integer comparison but the class itself defines no arithmetic ops
#   in its own __dict__ (those are inherited from int/IntEnum).
# socket.SocketKind: Python IntEnum subclass (Lib/socket.py) — enum for socket
#   type constants (SOCK_STREAM, SOCK_DGRAM, SOCK_RAW, etc.); same as
#   AddressFamily: no arithmetic operators defined in its own __dict__.
# ---------------------------------------------------------------------------

table socket_extra1756.arithmetic_operators:
  description: "socket types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1756

  columns: [id, function, args, expected]
  rows:
    - ["sk1756001", "socket.socket.__dict__.__contains__", ["__add__"], false]
    - ["sk1756002", "socket.socket.__dict__.__contains__", ["__sub__"], false]
    - ["sk1756003", "socket.socket.__dict__.__contains__", ["__mul__"], false]
    - ["sk1756004", "socket.socket.__dict__.__contains__", ["__truediv__"], false]
    - ["sk1756005", "socket.socket.__dict__.__contains__", ["__floordiv__"], false]
    - ["sk1756006", "socket.socket.__dict__.__contains__", ["__pow__"], false]
    - ["sk1756007", "socket.socket.__dict__.__contains__", ["__neg__"], false]
    - ["sk1756008", "socket.socket.__dict__.__contains__", ["__pos__"], false]
    - ["sk1756009", "socket.AddressFamily.__dict__.__contains__", ["__add__"], false]
    - ["sk1756010", "socket.AddressFamily.__dict__.__contains__", ["__sub__"], false]
    - ["sk1756011", "socket.AddressFamily.__dict__.__contains__", ["__mul__"], false]
    - ["sk1756012", "socket.AddressFamily.__dict__.__contains__", ["__neg__"], false]
    - ["sk1756013", "socket.SocketKind.__dict__.__contains__", ["__add__"], false]
    - ["sk1756014", "socket.SocketKind.__dict__.__contains__", ["__truediv__"], false]
    - ["sk1756015", "socket.SocketKind.__dict__.__contains__", ["__pow__"], false]
    - ["sk1756016", "socket.SocketKind.__dict__.__contains__", ["__neg__"], false]

# ---------------------------------------------------------------------------
# Table 2: complementary module-level attribute checks for socket
#
# Unique checks not covered in earlier waves:
# - socket.gethostname.__class__.__name__ == 'builtin_function_or_method'
# - socket.gethostbyname.__class__.__name__ == 'builtin_function_or_method'
# - socket.getaddrinfo.__class__.__name__ == 'builtin_function_or_method'
# - socket.AF_INET.__class__.__name__ == 'AddressFamily'
# - socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'
# These confirm the type identity of well-known socket module attributes,
# contrasting with the class __dict__ checks above.
# ---------------------------------------------------------------------------

table socket_extra1756.module_level_attributes:
  description: "socket module-level function/constant class name checks — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1756

  columns: [id, function, args, expected]
  rows:
    - ["sk1756017", "socket.gethostname.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["sk1756018", "socket.gethostbyname.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["sk1756019", "socket.getaddrinfo.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["sk1756020", "socket.AF_INET.__class__.__name__.__eq__", ["AddressFamily"], true]
    - ["sk1756021", "socket.SOCK_STREAM.__class__.__name__.__eq__", ["SocketKind"], true]
    - ["sk1756022", "socket.socket.__dict__.__contains__", ["__add__"], false]
    - ["sk1756023", "socket.SocketKind.__dict__.__contains__", ["__floordiv__"], false]
