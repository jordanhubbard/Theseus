spec: sentence_case
version: ">=3.0.0"
backend: node(sentence-case)

docs: https://www.npmjs.com/package/sentence-case

provenance:
  derived_from:
    - "sentence-case README — https://www.npmjs.com/package/sentence-case"
    - "Test vectors verified with sentence-case@3.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "sentence-case source"
  notes:
    - "sentence-case exports {sentenceCase} named function."
    - "sentenceCase converts string to Sentence case (first letter capitalized)."
    - "Splits camelCase, PascalCase, snake_case, and kebab-case inputs."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns sentence case string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table sentence_case.sentence_case:
  kind: node_module_call_eq
  function: sentenceCase
  category: sentenceCase
  id_prefix: scase

  columns: [id, args, expected]
  rows:
    - [camel,   ["fooBar"],     "Foo bar"]
    - [pascal,  ["FooBar"],     "Foo bar"]
    - [snake,   ["foo_bar"],    "Foo bar"]
    - [multi,   ["fooBarBaz"],  "Foo bar baz"]
