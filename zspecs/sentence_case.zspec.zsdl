spec: sentence_case
version: ">=4.0.0"
backend: node(sentence-case)

docs: https://www.npmjs.com/package/sentence-case

provenance:
  derived_from:
    - "sentence-case README — https://www.npmjs.com/package/sentence-case"
    - "Test vectors verified with sentence-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "sentence-case source"
  notes:
    - "sentence-case is an npm package. Install: npm install sentence-case"
    - "sentenceCase(str) converts a string to sentence case (first letter uppercase, rest lowercase)."
    - "Handles camelCase, UPPER_CASE, and space-separated input."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns sentence-cased string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table sentence_case.sentenceCase:
  kind: node_module_call_eq
  function: sentenceCase
  category: transform
  id_prefix: sc

  columns: [id, args, expected]
  rows:
    - [spaced,     ["hello world"], "Hello world"]
    - [camel,      ["helloWorld"],  "Hello world"]
    - [upper,      ["THE_FOX"],     "The fox"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:32:45Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
