spec: tokenize_extra2
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize.zspec.zsdl — covers core token type constants and function names"
    - "tokenize_extra.zspec.zsdl — covers TokenInfo.__name__/__module__, TokenError name/base, function __name__ checks for tokenize/generate_tokens/detect_encoding/open/untokenize, and token constant type checks"
  notes:
    - "This spec covers tokenize aspects not in tokenize.zspec.zsdl or tokenize_extra.zspec.zsdl."
    - "TokenInfo is a named tuple with exactly 5 fields: type, string, start, end, line."
    - "TokenInfo._fields is a tuple of strings; each field name can be verified via __contains__."
    - "TokenInfo._fields.__len__() == 5 — the field count is stable across all Python 3.x."
    - "tokenize.tokenize.__name__ == 'tokenize' — the function shares the module name."
    - "tokenize.generate_tokens.__name__ == 'generate_tokens' — accepts a readline callable."
    - "tokenize.detect_encoding.__name__ == 'detect_encoding' — reads BOM/coding comment."
    - "tokenize.open.__name__ == 'open' — opens a Python source file with detected encoding."
    - "tokenize.COMMENT is a plain int (re-exported from token or defined in tokenize)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TokenInfo — named tuple class name
# ---------------------------------------------------------------------------

invariant tokenize_extra2.TokenInfo.name:
  description: "tokenize.TokenInfo.__name__ == 'TokenInfo'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo.__name__.__eq__
  args: ["TokenInfo"]
  expected: true

# ---------------------------------------------------------------------------
# TokenInfo._fields — exactly 5 fields: type, string, start, end, line
# ---------------------------------------------------------------------------

invariant tokenize_extra2.TokenInfo.fields_len:
  description: "len(tokenize.TokenInfo._fields) == 5"
  category: token_info
  kind: python_call_eq
  function: TokenInfo._fields.__len__
  args: []
  expected: 5

table tokenize_extra2.TokenInfo.fields_contains:
  kind: python_call_eq
  category: token_info
  id_prefix: field

  columns: [id, function, args, expected]
  rows:
    - [type,   TokenInfo._fields.__contains__, ["type"],   true]
    - [string, TokenInfo._fields.__contains__, ["string"], true]
    - [start,  TokenInfo._fields.__contains__, ["start"],  true]
    - [end,    TokenInfo._fields.__contains__, ["end"],    true]
    - [line,   TokenInfo._fields.__contains__, ["line"],   true]

# ---------------------------------------------------------------------------
# TokenInfo._fields — field order (positional access)
# ---------------------------------------------------------------------------

invariant tokenize_extra2.TokenInfo.fields_type_at_zero:
  description: "tokenize.TokenInfo._fields[0] == 'type'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo._fields.__getitem__
  args: [0]
  expected: "type"

invariant tokenize_extra2.TokenInfo.fields_string_at_one:
  description: "tokenize.TokenInfo._fields[1] == 'string'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo._fields.__getitem__
  args: [1]
  expected: "string"

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

table tokenize_extra2.func_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [tokenize,         tokenize.__name__.__eq__,         ["tokenize"],         true]
    - [generate_tokens,  generate_tokens.__name__.__eq__,  ["generate_tokens"],  true]
    - [detect_encoding,  detect_encoding.__name__.__eq__,  ["detect_encoding"],  true]
    - [open,             open.__name__.__eq__,             ["open"],             true]

# ---------------------------------------------------------------------------
# COMMENT constant — is a plain int
# ---------------------------------------------------------------------------

invariant tokenize_extra2.COMMENT.is_int:
  description: "tokenize.COMMENT.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: COMMENT.__class__.__name__.__eq__
  args: ["int"]
  expected: true
