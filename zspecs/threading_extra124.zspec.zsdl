spec: threading_extra124
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra123.zspec.zsdl."
    - "This spec covers: threading.Event class method __code__.co_varnames elements not previously covered — Event.__init__ co_varnames[0]='self'(4), co_varnames len=1; Event.set co_varnames[0]='self'(4), co_varnames len=1; Event.clear co_varnames[0]='self'(4), co_varnames len=1; Event.wait co_varnames[0]='self'(4), co_varnames[1]='timeout'(7), co_varnames[2]='signaled'(8), co_varnames len=3; wave 274."
    - "Prior spec extra72 covered Event.set.__code__.co_name=='set', Event.clear.__code__.co_name=='clear', Event.wait.__code__.co_name=='wait', Event.wait.__code__.co_argcount==2. New here: the individual co_varnames elements for Event.__init__, Event.set, Event.clear, and Event.wait."
    - "threading.Event.__init__.__code__.co_varnames[0] == 'self' (len 4). Verified with Python 3.14.3."
    - "threading.Event.__init__.__code__.co_varnames.__len__() == 1. Verified with Python 3.14.3."
    - "threading.Event.set.__code__.co_varnames[0] == 'self' (len 4). Verified with Python 3.14.3."
    - "threading.Event.set.__code__.co_varnames.__len__() == 1. Verified with Python 3.14.3."
    - "threading.Event.clear.__code__.co_varnames[0] == 'self' (len 4). Verified with Python 3.14.3."
    - "threading.Event.clear.__code__.co_varnames.__len__() == 1. Verified with Python 3.14.3."
    - "threading.Event.wait.__code__.co_varnames[0] == 'self' (len 4). Verified with Python 3.14.3."
    - "threading.Event.wait.__code__.co_varnames[1] == 'timeout' (len 7). Verified with Python 3.14.3."
    - "threading.Event.wait.__code__.co_varnames[2] == 'signaled' (len 8). Verified with Python 3.14.3."
    - "threading.Event.wait.__code__.co_varnames.__len__() == 3. Verified with Python 3.14.3."
    - "Event.__init__, set, and clear each have co_varnames=('self',) len=1 — minimal self-only co_varnames; these methods do not declare additional locals. Event.wait has 3 entries: 'self' (param), 'timeout' (param with default None), 'signaled' (internal local for the result of self._cond.wait)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Event.__init__, set, and clear co_varnames[0] and lengths
#
# Wave 274 theme: threading.Event.__init__(self), Event.set(self), and
# Event.clear(self) are all pure-Python methods with a single local variable:
# co_varnames[0] == 'self' (4 chars). Each has co_varnames.__len__() == 1.
# They are the simplest possible Python methods: no keyword arguments, no
# internal locals. Event.__init__ initializes the internal Condition;
# Event.set sets the flag and notifies waiters; Event.clear resets the flag.
# All three share the same co_varnames structure. Prior extra72 covered
# the co_name strings for set, clear, and wait. New here: the co_varnames
# values and tuple lengths.
#
# Event.__init__.__code__.co_varnames[0] == 'self'  (len 4)
# Event.__init__.__code__.co_varnames.__len__() == 1
# Event.set.__code__.co_varnames[0]    == 'self'  (len 4)
# Event.set.__code__.co_varnames.__len__() == 1
# Event.clear.__code__.co_varnames[0]  == 'self'  (len 4)
# Event.clear.__code__.co_varnames.__len__() == 1
#
# New to extra124.
# ---------------------------------------------------------------------------

table threading_extra124.event_init_set_clear_co_varnames:
  description: "threading.Event.__init__/set/clear co_varnames[0]='self'(4); all tuple len=1; simplest co_varnames (self-only); prior extra72 covered co_name for set/clear/wait; wave 274; new to extra124"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingevcv124

  columns: [id, function, args, expected, description]
  rows:
    - [ev_init_cv0_eq,
       "Event.__init__.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Event.__init__.__code__.co_varnames[0] == 'self' — the instance parameter; Event.__init__(self) initializes the internal Condition object; tuple.__getitem__(0) returns 'self'; new to extra124"]
    - [ev_init_cv_len,
       "Event.__init__.__code__.co_varnames.__len__",
       [],
       1,
       "threading.Event.__init__.__code__.co_varnames.__len__() == 1 — Event.__init__ has only 'self' as a local; no keyword parameters; no internal locals; tuple.__len__() returns 1; new to extra124"]
    - [ev_set_cv0_eq,
       "Event.set.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Event.set.__code__.co_varnames[0] == 'self' — the instance parameter; Event.set(self) sets the internal flag to True and notifies all waiters; tuple.__getitem__(0) returns 'self'; new to extra124"]
    - [ev_set_cv_len,
       "Event.set.__code__.co_varnames.__len__",
       [],
       1,
       "threading.Event.set.__code__.co_varnames.__len__() == 1 — Event.set has only 'self' as a local; no additional parameters; tuple.__len__() returns 1; new to extra124"]
    - [ev_clear_cv0_eq,
       "Event.clear.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Event.clear.__code__.co_varnames[0] == 'self' — the instance parameter; Event.clear(self) resets the internal flag to False; tuple.__getitem__(0) returns 'self'; new to extra124"]
    - [ev_clear_cv_len,
       "Event.clear.__code__.co_varnames.__len__",
       [],
       1,
       "threading.Event.clear.__code__.co_varnames.__len__() == 1 — Event.clear has only 'self' as a local; no additional parameters; tuple.__len__() returns 1; new to extra124"]

# ---------------------------------------------------------------------------
# Table 2: threading.Event.wait co_varnames[0], [1], [2] and tuple length
#
# Wave 274 theme: threading.Event.wait(self, timeout=None) is more complex than
# Event.__init__/set/clear. Its co_varnames has 3 entries:
#   co_varnames[0] == 'self'     (4 chars) — the instance
#   co_varnames[1] == 'timeout'  (7 chars) — the optional wait timeout
#   co_varnames[2] == 'signaled' (8 chars) — internal local for result
# 'signaled' is an internal local (not a declared parameter) that holds the
# return value of self._cond.wait(timeout). co_argcount == 2 (self and timeout
# are positional), confirming 'signaled' is a purely local variable.
# 'signaled' has 8 chars — 1 more than 'timeout' (7) and 4 more than 'self' (4).
#
# Event.wait.__code__.co_varnames[0] == 'self'     (len 4)
# Event.wait.__code__.co_varnames[1] == 'timeout'  (len 7)
# Event.wait.__code__.co_varnames[2] == 'signaled' (len 8)
# Event.wait.__code__.co_varnames.__len__() == 3
#
# New to extra124.
# ---------------------------------------------------------------------------

table threading_extra124.event_wait_co_varnames:
  description: "threading.Event.wait co_varnames[0]='self'(4), [1]='timeout'(7), [2]='signaled'(8); tuple len=3; co_argcount=2 (self+timeout); 'signaled' is internal local for wait result; more complex than set/clear/init (len=1); wave 274; new to extra124"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingewcv124

  columns: [id, function, args, expected, description]
  rows:
    - [ev_wait_cv0_eq,
       "Event.wait.__code__.co_varnames.__getitem__",
       [0],
       "self",
       "threading.Event.wait.__code__.co_varnames[0] == 'self' — the instance parameter; first positional in Event.wait(self, timeout=None); tuple.__getitem__(0) returns 'self'; new to extra124"]
    - [ev_wait_cv1_eq,
       "Event.wait.__code__.co_varnames.__getitem__",
       [1],
       "timeout",
       "threading.Event.wait.__code__.co_varnames[1] == 'timeout' — the optional timeout parameter; Event.wait(self, timeout=None) blocks until the event is set or timeout expires; tuple.__getitem__(1) returns 'timeout'; new to extra124"]
    - [ev_wait_cv1_len,
       "Event.wait.__code__.co_varnames.__getitem__(1).__len__",
       [],
       7,
       "threading.Event.wait.__code__.co_varnames[1].__len__() == 7 — 'timeout' has 7 chars: t-i-m-e-o-u-t; 1 less than 'signaled' (8) and 3 more than 'self' (4); str.__len__() returns 7; new to extra124"]
    - [ev_wait_cv2_eq,
       "Event.wait.__code__.co_varnames.__getitem__",
       [2],
       "signaled",
       "threading.Event.wait.__code__.co_varnames[2] == 'signaled' — internal local holding the boolean return value of self._cond.wait(timeout); True if the event was set before timeout; tuple.__getitem__(2) returns 'signaled'; new to extra124"]
    - [ev_wait_cv2_len,
       "Event.wait.__code__.co_varnames.__getitem__(2).__len__",
       [],
       8,
       "threading.Event.wait.__code__.co_varnames[2].__len__() == 8 — 'signaled' has 8 chars: s-i-g-n-a-l-e-d; 1 more than 'timeout' (7) and 4 more than 'self' (4); the longest co_varnames entry for Event.wait; str.__len__() returns 8; new to extra124"]
    - [ev_wait_cv_len,
       "Event.wait.__code__.co_varnames.__len__",
       [],
       3,
       "threading.Event.wait.__code__.co_varnames.__len__() == 3 — Event.wait has 3 local variable names: 'self' (param), 'timeout' (param), 'signaled' (internal local); more than Event.__init__/set/clear (all len=1); tuple.__len__() returns 3; new to extra124"]

# ---------------------------------------------------------------------------
# Table 3: threading.Event method co_varnames length comparison
#
# Wave 274 theme: The four Event methods have different co_varnames lengths:
#   Event.__init__.__code__.co_varnames.__len__() == 1
#   Event.set.__code__.co_varnames.__len__()      == 1
#   Event.clear.__code__.co_varnames.__len__()    == 1
#   Event.wait.__code__.co_varnames.__len__()     == 3
# The three simple methods (__init__, set, clear) all have length 1 — just
# 'self'. Event.wait has length 3 because it has an additional parameter
# ('timeout') and an internal local ('signaled'). This table confirms the
# distinction and provides cross-checks.
#
# New to extra124.
# ---------------------------------------------------------------------------

table threading_extra124.event_method_co_varnames_len_comparison:
  description: "threading.Event method co_varnames len: __init__=1, set=1, clear=1, wait=3; wait is more complex; 'signaled' is unique to wait; co_varnames[0]='self' is shared by all four methods; wave 274; new to extra124"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingevcvlc124

  columns: [id, function, args, expected, description]
  rows:
    - [ev_init_cv_len_1,
       "Event.__init__.__code__.co_varnames.__len__",
       [],
       1,
       "threading.Event.__init__.__code__.co_varnames.__len__() == 1 — the simplest Event method; only 'self'; consistent with set and clear (both also len=1); tuple.__len__() returns 1; new to extra124"]
    - [ev_set_cv_len_1,
       "Event.set.__code__.co_varnames.__len__",
       [],
       1,
       "threading.Event.set.__code__.co_varnames.__len__() == 1 — Event.set has only 'self'; same as __init__ and clear; all three simple Event methods have co_varnames len=1; tuple.__len__() returns 1; new to extra124"]
    - [ev_clear_cv_len_1,
       "Event.clear.__code__.co_varnames.__len__",
       [],
       1,
       "threading.Event.clear.__code__.co_varnames.__len__() == 1 — Event.clear has only 'self'; consistent with __init__ and set; tuple.__len__() returns 1; new to extra124"]
    - [ev_wait_cv_len_3,
       "Event.wait.__code__.co_varnames.__len__",
       [],
       3,
       "threading.Event.wait.__code__.co_varnames.__len__() == 3 — Event.wait has 'self', 'timeout', 'signaled'; 3x more entries than __init__/set/clear (all len=1); the additional complexity comes from the timeout parameter and the signaled local; tuple.__len__() returns 3; new to extra124"]
    - [ev_wait_cv_len_gt_set,
       "Event.wait.__code__.co_varnames.__len__().__gt__",
       [1],
       true,
       "threading.Event.wait.__code__.co_varnames.__len__().__gt__(1) == True — Event.wait co_varnames len (3) is greater than Event.set co_varnames len (1); int.__gt__(1) returns True; new to extra124"]

