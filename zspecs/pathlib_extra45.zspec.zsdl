spec: pathlib_extra45
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra44.zspec.zsdl — covers UnsupportedOperation __module__.__len__()==7/__bases__[0].__name__.__len__()==19/__mro__.__len__()==6; pathlib module-level __name__/__package__/__file__ type lengths; Path.__slots__.__len__()==1; PosixPath.__slots__.__len__()==0; Path.readlink/__qualname__.__len__()==13; PurePath.full_match/__qualname__.__len__()==19."
    - "pathlib_extra43.zspec.zsdl — covers PurePath.__new__(16)/__init__(17)/__qualname__.__len__(); Path.__new__(12)/__qualname__.__len__(); PurePath.__slots__.__len__()==8."
    - "pathlib_extra40.zspec.zsdl — covers Path/PurePath/PurePosixPath __dict__.__len__(); PurePosixPath.__dict__.__len__()==6; Path.__dict__.__len__()==62; PurePath.__dict__.__len__()==61."
    - "pathlib_extra38.zspec.zsdl — covers PurePosixPath/PureWindowsPath/__bases__[0].__name__.__len__()==8; PosixPath/WindowsPath/__bases__[0].__name__.__len__()==4; PureWindowsPath/__mro__.__len__()==3."
    - "pathlib_extra37.zspec.zsdl — covers PurePosixPath/PureWindowsPath __dict__.__class__.__name__.__len__()==12."
    - "pathlib_extra34.zspec.zsdl — covers PurePath/PurePosixPath/PureWindowsPath __name__.__len__() and __module__.__len__()==7."
    - "pathlib_extra31.zspec.zsdl — covers PurePath.__bases__[0].__name__=='object'; Path.__bases__[0].__name__=='PurePath'."
    - "pathlib_extra11.zspec.zsdl — covers PurePath.__module__=='pathlib'; PurePosixPath/PureWindowsPath __bases__.__len__()==1."
  notes:
    - "This spec extends pathlib_extra44.zspec.zsdl."
    - "Prior specs collectively covered: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__ and lengths; MRO depths for all six classes and UnsupportedOperation; __bases__[0].__name__ and __len__() for all six classes; all major Path/PurePath method __qualname__.__len__(); PurePath property fget __qualname__.__len__(); Path/PurePath __init_subclass__.__qualname__.__len__(); PurePath/__slots__.__len__()==8; Path/__slots__.__len__()==1; PosixPath/__slots__.__len__()==0; Path/PurePath/PurePosixPath __dict__.__len__(); UnsupportedOperation identity attributes."
    - "This spec covers: PureWindowsPath.__dict__.__len__()==6 (NOVEL — pathlib_extra40 covers PurePosixPath.__dict__.__len__()==6 and Path/PurePath __dict__.__len__(), but NOT PureWindowsPath.__dict__.__len__()); PosixPath.__dict__.__len__()==5 (NOVEL — no prior pathlib spec checks PosixPath.__dict__.__len__()); WindowsPath.__dict__.__len__()==6 (NOVEL — no prior pathlib spec checks WindowsPath.__dict__.__len__()); PurePath.__bases__.__len__()==1 (NOVEL — extra11 covers PurePosixPath/PureWindowsPath __bases__.__len__()==1 but NOT PurePath.__bases__.__len__(); PurePath has exactly one base: object); Path.__bases__.__len__()==1 (NOVEL — extra11 covers PurePosixPath/PureWindowsPath but not Path; Path has one base: PurePath)."
    - "PureWindowsPath.__dict__.__len__() == 6. pathlib_extra40 covers PurePosixPath.__dict__.__len__()==6 (the same value) but NOT PureWindowsPath. PureWindowsPath adds the same 6 entries as PurePosixPath: _flavour, __new__, __str__, __bytes__, __rtruediv__, and __reduce__. Both concrete PurePath subclasses have identical dict sizes. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "PosixPath.__dict__.__len__() == 5. No prior pathlib spec checks PosixPath.__dict__.__len__(). PosixPath is a concrete POSIX path class; it adds fewer entries than its Windows counterpart because it can rely on the underlying OS. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "WindowsPath.__dict__.__len__() == 6. No prior pathlib spec checks WindowsPath.__dict__.__len__(). WindowsPath adds 6 entries to its dict. Equals PureWindowsPath (6) but not PosixPath (5). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "PurePath.__bases__.__len__() == 1. pathlib_extra11 checks PurePosixPath.__bases__.__len__()==1 and PureWindowsPath.__bases__.__len__()==1 but does NOT check PurePath.__bases__.__len__(). PurePath has exactly one base: object (it is the root of the pathlib hierarchy). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Path.__bases__.__len__() == 1. No prior pathlib spec checks Path.__bases__.__len__(). Path has exactly one direct base: PurePath. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PureWindowsPath, PosixPath, and WindowsPath __dict__.__len__()
#
# pathlib_extra40 covers Path/PurePath/PurePosixPath __dict__.__len__():
#   Path.__dict__.__len__()         == 62
#   PurePath.__dict__.__len__()     == 61
#   PurePosixPath.__dict__.__len__() == 6   (minimal: 6 entries)
#
# No prior pathlib spec checks __dict__.__len__() for:
#   PureWindowsPath — the Windows-flavoured pure path class (also 6 entries)
#   PosixPath       — the concrete POSIX path class (5 entries)
#   WindowsPath     — the concrete Windows path class (6 entries)
#
# Cluster observations:
#   6 entries — PurePosixPath (extra40), PureWindowsPath, WindowsPath (this spec)
#   5 entries — PosixPath (smallest concrete subclass dict)
#
# PureWindowsPath == PurePosixPath (both 6): both minimal PurePath subclasses
# add the same number of entries. PosixPath has 5 because it relies more on
# POSIX OS facilities. All three novel. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra45.concrete_subclass_dict_lens:
  description: "pathlib concrete subclass __dict__.__len__(): PureWindowsPath(6)/PosixPath(5)/WindowsPath(6) — pathlib_extra40 covers PurePosixPath(6)/Path(62)/PurePath(61) but not these three; all novel"
  kind: python_call_eq
  category: class_structure
  id_prefix: pcdl45

  columns: [id, function, args, expected]
  rows:
    - [PureWindowsPath_dict, PureWindowsPath.__dict__.__len__, [], 6]
    - [PosixPath_dict,       PosixPath.__dict__.__len__,       [], 5]
    - [WindowsPath_dict,     WindowsPath.__dict__.__len__,     [], 6]

# ---------------------------------------------------------------------------
# PurePath and Path __bases__.__len__()
#
# pathlib_extra11 checks PurePosixPath.__bases__.__len__()==1 and
# PureWindowsPath.__bases__.__len__()==1. No prior pathlib spec checks
# __bases__.__len__() for PurePath or Path.
#
#   PurePath.__bases__.__len__() == 1   (only base: object)
#   Path.__bases__.__len__()     == 1   (only base: PurePath)
#
# Both are single-inheritance classes. PurePath sits at the root of the
# pathlib class hierarchy, inheriting only from object. Path inherits only
# from PurePath. Both novel. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra45.PurePath_bases_len:
  description: "len(pathlib.PurePath.__bases__) == 1 — PurePath has exactly one base: object; pathlib_extra11 checks PurePosixPath/PureWindowsPath __bases__.__len__()==1 but not PurePath itself; novel"
  category: class_structure
  kind: python_call_eq
  function: PurePath.__bases__.__len__
  args: []
  expected: 1

invariant pathlib_extra45.Path_bases_len:
  description: "len(pathlib.Path.__bases__) == 1 — Path has exactly one direct base: PurePath; no prior pathlib spec checks Path.__bases__.__len__(); novel"
  category: class_structure
  kind: python_call_eq
  function: Path.__bases__.__len__
  args: []
  expected: 1
