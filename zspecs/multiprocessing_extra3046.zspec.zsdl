# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# No multiprocessing class defines __aenter__ in its own __dict__; all false.
# multiprocessing is a synchronous process-based concurrency library and has
# no async context manager support anywhere in its class hierarchy.
# ---------------------------------------------------------------------------

