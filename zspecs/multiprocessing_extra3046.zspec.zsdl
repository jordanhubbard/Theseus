spec: mp3046
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.managers.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (mp3046): __enter__, __exit__, __aenter__ dict-presence for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Key finding: multiprocessing.pool.Pool defines __enter__ and __exit__ (true) — Pool is a synchronous context manager."
    - "multiprocessing.Process, pool.AsyncResult, pool.MapResult do not define context manager protocol methods."
    - "managers.SyncManager, managers.BaseListProxy, managers._BaseDictProxy, managers._BaseSetProxy define none of these methods in their own __dict__."
    - "The concrete lock/synchronization types (type(multiprocessing.Lock()), type(multiprocessing.RLock()), type(multiprocessing.Semaphore()), type(multiprocessing.Event())) do NOT define __enter__/__exit__ in their own __dict__ — these are C extension types that acquire/release via a different code path."
    - "No multiprocessing class defines __aenter__ in its own __dict__ (all false) — multiprocessing has no async context manager support."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# multiprocessing.pool.Pool defines __enter__ directly (true) — Pool supports
# the 'with Pool(...) as p:' pattern for resource management.
# All other multiprocessing classes return false.
# The concrete sync types (Lock, RLock, Semaphore, Event) are C extension types;
# their __enter__ is not found in their own __dict__ via this check.
# ---------------------------------------------------------------------------

table mp3046.enter:
  description: "multiprocessing types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3046

  columns: [id, function, args, expected]
  rows:
    - ["mp3046001", operator.contains, [multiprocessing.Process.__dict__,                 "__enter__"], false]
    - ["mp3046002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__enter__"], true]
    - ["mp3046003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__enter__"], false]
    - ["mp3046004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__enter__"], false]
    - ["mp3046005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__enter__"], false]
    - ["mp3046006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__enter__"], false]
    - ["mp3046007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__enter__"], false]
    - ["mp3046008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__enter__"], false]
    - ["mp3046009", operator.contains, [type(multiprocessing.Lock()).__dict__,            "__enter__"], false]
    - ["mp3046010", operator.contains, [type(multiprocessing.RLock()).__dict__,           "__enter__"], false]
    - ["mp3046011", operator.contains, [type(multiprocessing.Semaphore()).__dict__,       "__enter__"], false]
    - ["mp3046012", operator.contains, [type(multiprocessing.Event()).__dict__,           "__enter__"], false]

# ---------------------------------------------------------------------------
# __exit__ dict-presence — operator.contains(Cls.__dict__, '__exit__')
#
# multiprocessing.pool.Pool defines __exit__ directly (true) — paired with
# __enter__ to complete the synchronous context manager protocol for Pool.
# All other multiprocessing classes return false.
# ---------------------------------------------------------------------------

