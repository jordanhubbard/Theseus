spec: threading_extra1486
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 546 theme: __enter__ and __exit__ context manager protocol checks for threading classes."
    - "threading.Lock: __enter__ and __exit__ ARE in __dict__ with type method_descriptor (C-implemented). Verified with Python 3.12."
    - "threading.Semaphore: __enter__ and __exit__ ARE in __dict__ with type function (Python-implemented). Verified with Python 3.12."
    - "threading.Condition: __enter__ and __exit__ ARE in __dict__ with type function (Python-implemented). Verified with Python 3.12."
    - "threading.BoundedSemaphore: __enter__ and __exit__ are NOT in __dict__; it inherits from Semaphore. Verified with Python 3.12."
    - "threading.Thread: no __enter__, no __exit__ in __dict__. Verified with Python 3.12."
    - "threading.Event: no __enter__, no __exit__ in __dict__. Verified with Python 3.12."
    - "threading.Barrier: no __enter__, no __exit__ in __dict__. Verified with Python 3.12."
    - "Lock.__enter__ and Lock.__exit__ are method_descriptor because Lock is backed by a C extension type (_thread.lock)."
    - "Semaphore.__enter__ and Semaphore.__exit__ are function because Semaphore is a pure-Python class in Lib/threading.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Lock — __enter__ and __exit__ presence and type checks
#
# Wave 546 theme: threading.Lock — the fundamental mutual-exclusion lock.
#
# threading.Lock.__dict__.__contains__("__enter__") == True
# threading.Lock.__dict__.__contains__("__exit__") == True
# threading.Lock.__enter__.__class__.__name__.__eq__("method_descriptor") == True
# threading.Lock.__exit__.__class__.__name__.__eq__("method_descriptor") == True
#
# Lock is backed by the C-level _thread.lock type. Its __enter__ and __exit__
# are therefore method_descriptors — C-implemented methods. Lock is a true
# context manager: entering acquires the lock; exiting releases it.
# New to extra1486.
# ---------------------------------------------------------------------------

table threading_extra1486.lock_context_manager_presence:
  description: "threading.Lock defines __enter__ and __exit__ in __dict__ as method_descriptor; Lock is a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1486lk

  columns: [id, function, args, expected, description]
  rows:
    - [th1486lk001,
       "Lock.__dict__.__contains__",
       ["__enter__"],
       true,
       "threading.Lock.__dict__.__contains__('__enter__') == True — Lock is the fundamental mutual-exclusion primitive backed by the C-level _thread.lock type; it IS a context manager and defines __enter__ directly in its __dict__; entering the context acquires the lock; verified with Python 3.12; new to extra1486"]
    - [th1486lk002,
       "Lock.__dict__.__contains__",
       ["__exit__"],
       true,
       "threading.Lock.__dict__.__contains__('__exit__') == True — Lock defines __exit__ directly in its __dict__; exiting the context releases the lock unconditionally, ensuring correct cleanup even when exceptions occur; verified with Python 3.12; new to extra1486"]
    - [th1486lk003,
       "Lock.__enter__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.__enter__.__class__.__name__.__eq__('method_descriptor') == True — Lock is backed by the C extension _thread.lock; its __enter__ is a method_descriptor, not a Python function; method_descriptor is the type given to methods defined in C extension types; verified with Python 3.12; new to extra1486"]
    - [th1486lk004,
       "Lock.__exit__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.__exit__.__class__.__name__.__eq__('method_descriptor') == True — Lock.__exit__ is also a method_descriptor because Lock is a C extension type; the C implementation handles release logic directly; verified with Python 3.12; new to extra1486"]
    - [th1486lk005,
       "Lock.__dict__.__contains__",
       ["acquire"],
       true,
       "threading.Lock.__dict__.__contains__('acquire') == True — Lock defines 'acquire' in its __dict__; this is the method called by __enter__ to acquire the lock; it supports optional timeout and blocking arguments; verified with Python 3.12; new to extra1486"]
    - [th1486lk006,
       "Lock.__dict__.__contains__",
       ["release"],
       true,
       "threading.Lock.__dict__.__contains__('release') == True — Lock defines 'release' in its __dict__; this is the method called by __exit__ to release the lock; verified with Python 3.12; new to extra1486"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore and Condition — __enter__ and __exit__ presence
#
# Wave 546 theme: threading.Semaphore and threading.Condition — counting
# semaphore and condition variable; both are Python-implemented context
# managers.
#
# threading.Semaphore.__dict__.__contains__("__enter__") == True
# threading.Semaphore.__dict__.__contains__("__exit__") == True
# threading.Semaphore.__enter__.__class__.__name__.__eq__("function") == True
# threading.Semaphore.__exit__.__class__.__name__.__eq__("function") == True
# threading.Condition.__dict__.__contains__("__enter__") == True
# threading.Condition.__dict__.__contains__("__exit__") == True
# threading.Condition.__enter__.__class__.__name__.__eq__("function") == True
# threading.Condition.__exit__.__class__.__name__.__eq__("function") == True
#
# Semaphore and Condition are both pure-Python classes in Lib/threading.py;
# their __enter__ and __exit__ are Python functions, not C method_descriptors.
# New to extra1486.
# ---------------------------------------------------------------------------

table threading_extra1486.semaphore_condition_context_manager_presence:
  description: "threading.Semaphore and Condition define __enter__ and __exit__ in __dict__ as function; both are Python-implemented context managers; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1486sc

  columns: [id, function, args, expected, description]
  rows:
    - [th1486sc001,
       "Semaphore.__dict__.__contains__",
       ["__enter__"],
       true,
       "threading.Semaphore.__dict__.__contains__('__enter__') == True — Semaphore is a counting synchronization primitive implemented in pure Python (Lib/threading.py); it IS a context manager and defines __enter__ in its __dict__; __enter__ calls acquire() to decrement the counter; verified with Python 3.12; new to extra1486"]
    - [th1486sc002,
       "Semaphore.__dict__.__contains__",
       ["__exit__"],
       true,
       "threading.Semaphore.__dict__.__contains__('__exit__') == True — Semaphore defines __exit__ in its __dict__; __exit__ calls release() to increment the counter, unblocking waiting threads; verified with Python 3.12; new to extra1486"]
    - [th1486sc003,
       "Semaphore.__enter__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Semaphore.__enter__.__class__.__name__.__eq__('function') == True — Semaphore is a pure-Python class; its __enter__ is a Python function object, not a C method_descriptor; this contrasts with threading.Lock whose __enter__ is a method_descriptor; verified with Python 3.12; new to extra1486"]
    - [th1486sc004,
       "Condition.__dict__.__contains__",
       ["__enter__"],
       true,
       "threading.Condition.__dict__.__contains__('__enter__') == True — Condition is a synchronization primitive that combines a lock with the ability to wait for and signal state changes; it IS a context manager and defines __enter__ in its __dict__; __enter__ acquires the underlying lock; verified with Python 3.12; new to extra1486"]
    - [th1486sc005,
       "Condition.__dict__.__contains__",
       ["__exit__"],
       true,
       "threading.Condition.__dict__.__contains__('__exit__') == True — Condition defines __exit__ in its __dict__; __exit__ releases the underlying lock, allowing other threads to proceed; verified with Python 3.12; new to extra1486"]
    - [th1486sc006,
       "Condition.__enter__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Condition.__enter__.__class__.__name__.__eq__('function') == True — Condition is a pure-Python class; its __enter__ is a Python function object, not a C method_descriptor; Condition delegates locking to an internal Lock or RLock; verified with Python 3.12; new to extra1486"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread, Event, Barrier — __enter__ and __exit__ absence
#
# Wave 546 theme: threading.Thread, Event, Barrier — thread object and
# synchronization primitives that do NOT implement the context manager protocol.
#
# threading.Thread.__dict__.__contains__("__enter__") == False
# threading.Thread.__dict__.__contains__("__exit__") == False
# threading.Event.__dict__.__contains__("__enter__") == False
# threading.Event.__dict__.__contains__("__exit__") == False
# threading.Barrier.__dict__.__contains__("__enter__") == False
# threading.Barrier.__dict__.__contains__("__exit__") == False
#
# Thread represents an OS-level thread. Event is a simple boolean flag
# primitive. Barrier makes threads wait at a synchronization point. None
# of these three defines __enter__ or __exit__ in its own __dict__.
# New to extra1486.
# ---------------------------------------------------------------------------

table threading_extra1486.thread_event_barrier_context_manager_absence:
  description: "threading.Thread, Event, and Barrier have no __enter__ or __exit__ in __dict__; none of these three implements the context manager protocol; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1486tb

  columns: [id, function, args, expected, description]
  rows:
    - [th1486tb001,
       "Thread.__dict__.__contains__",
       ["__enter__"],
       false,
       "threading.Thread.__dict__.__contains__('__enter__') == False — Thread represents an OS-level thread of execution; it is started with start() and joined with join(); it does not implement the context manager protocol and cannot be used in a 'with' statement; __enter__ is not in Thread.__dict__; verified with Python 3.12; new to extra1486"]
    - [th1486tb002,
       "Thread.__dict__.__contains__",
       ["__exit__"],
       false,
       "threading.Thread.__dict__.__contains__('__exit__') == False — Thread does not define __exit__; it cannot be used as a context manager; __exit__ is not in Thread.__dict__; verified with Python 3.12; new to extra1486"]
    - [th1486tb003,
       "Event.__dict__.__contains__",
       ["__enter__"],
       false,
       "threading.Event.__dict__.__contains__('__enter__') == False — Event is a simple boolean-flag synchronization primitive with set(), clear(), and wait() methods; it does not implement the context manager protocol; __enter__ is not in Event.__dict__; verified with Python 3.12; new to extra1486"]
    - [th1486tb004,
       "Event.__dict__.__contains__",
       ["__exit__"],
       false,
       "threading.Event.__dict__.__contains__('__exit__') == False — Event does not define __exit__; it cannot be used as a context manager; __exit__ is not in Event.__dict__; verified with Python 3.12; new to extra1486"]
    - [th1486tb005,
       "Barrier.__dict__.__contains__",
       ["__enter__"],
       false,
       "threading.Barrier.__dict__.__contains__('__enter__') == False — Barrier synchronizes a fixed number of threads at a common point using wait(); threads block until the required count arrive; it does not implement the context manager protocol; __enter__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1486"]
    - [th1486tb006,
       "Barrier.__dict__.__contains__",
       ["__exit__"],
       false,
       "threading.Barrier.__dict__.__contains__('__exit__') == False — Barrier does not define __exit__; it cannot be used as a context manager; __exit__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1486"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1486
# ---------------------------------------------------------------------------

invariant threading_extra1486.lock_has_enter:
  description: "threading.Lock.__dict__ contains '__enter__' — Lock IS a context manager; entering acquires the lock; wave 546; new to extra1486"
  kind: python_call_eq
  function: Lock.__dict__.__contains__
  args: ["__enter__"]
  expected: true

invariant threading_extra1486.lock_has_exit:
  description: "threading.Lock.__dict__ contains '__exit__' — Lock IS a context manager; exiting releases the lock; wave 546; new to extra1486"
  kind: python_call_eq
  function: Lock.__dict__.__contains__
  args: ["__exit__"]
  expected: true

invariant threading_extra1486.lock_enter_is_method_descriptor:
  description: "threading.Lock.__enter__.__class__.__name__ == 'method_descriptor' — Lock is C-backed so __enter__ is a C method_descriptor, not a Python function; wave 546; new to extra1486"
  kind: python_call_eq
  function: Lock.__enter__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant threading_extra1486.semaphore_has_enter:
  description: "threading.Semaphore.__dict__ contains '__enter__' — Semaphore IS a context manager; __enter__ calls acquire(); wave 546; new to extra1486"
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["__enter__"]
  expected: true

invariant threading_extra1486.semaphore_enter_is_function:
  description: "threading.Semaphore.__enter__.__class__.__name__ == 'function' — Semaphore is pure-Python so __enter__ is a Python function, unlike Lock's method_descriptor; wave 546; new to extra1486"
  kind: python_call_eq
  function: Semaphore.__enter__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra1486.thread_no_enter:
  description: "threading.Thread.__dict__ does not contain '__enter__' — Thread is a thread object, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__enter__"]
  expected: false
