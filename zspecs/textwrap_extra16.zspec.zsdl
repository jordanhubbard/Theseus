spec: textwrap_extra16
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra15.zspec.zsdl."
    - "textwrap_extra15 covers: wrap('', 70)==[]; wrap('word', 70)==['word']; wrap('   leading spaces', 70)==['leading spaces']; fill('a b c', 2)=='a\\nb\\nc'; fill('hello', 70)=='hello'; dedent('')==''; dedent('no indent')=='no indent'; indent tab prefix; shorten capital-T width=10."
    - "textwrap_extra14 covers: TextWrapper().tabsize==8; TextWrapper.__qualname__; wrap('hello world', 100); wrap('a b', 1); fill('a b c', 3); dedent('\\thello\\n\\tworld'); indent('foo\\nbar', '-- '); shorten('the quick brown fox', 10)."
    - "textwrap_extra13 covers: TextWrapper().expand_tabs/max_lines/width; wrap/fill at width=5; dedent three-line two-space; shorten default placeholder width=8."
    - "textwrap_extra.zspec covers: indent('hello\\nworld', '  ') == '  hello\\n  world' — two-space prefix."
    - "This spec covers: wrap('hello world', width=5)==['hello','world']; fill('hello world', width=5)=='hello\\nworld'; shorten('hello world foo bar', width=15, placeholder='...')=='hello world...'; indent('hello\\nworld', '  ')=='  hello\\n  world'; dedent('  hello\\n  world')=='hello\\nworld'."
    - "textwrap.wrap('hello world', width=5) == ['hello', 'world'] — two words of width 5 each, no wrapping needed beyond one per line. Verified at runtime."
    - "textwrap.fill('hello world', width=5) == 'hello\\nworld' — same split joined with newline. Verified at runtime."
    - "textwrap.shorten('hello world foo bar', width=15, placeholder='...') == 'hello world...' — 'hello world' (11) + '...' (3) = 14 <= 15. Verified at runtime."
    - "textwrap.indent('hello\\nworld', '  ') == '  hello\\n  world' — two-space prefix on each line. Verified at runtime."
    - "textwrap.dedent('  hello\\n  world') == 'hello\\nworld' — two-space common indent stripped. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.wrap — 'hello world' at width=5
#
# textwrap_extra13 covers wrap/fill at width=5 via TextWrapper indirectly.
# textwrap_extra14 covers wrap('hello world', 100) and wrap('a b', 1).
# textwrap_extra15 covers wrap edge cases (empty, single word, leading spaces).
# No prior spec verifies wrap('hello world', width=5) == ['hello', 'world']
# as a standalone invariant under the extra16 namespace.
# 'hello' is exactly 5 chars; 'world' is exactly 5 chars. Both fit.
# Verified: textwrap.wrap('hello world', width=5) == ['hello', 'world'].
# ---------------------------------------------------------------------------

invariant textwrap_extra16.wrap.hello_world_width5:
  description: "textwrap.wrap('hello world', width=5) == ['hello', 'world'] — two words each fitting width=5"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["hello world", 5]
  expected: ["hello", "world"]

# ---------------------------------------------------------------------------
# textwrap.fill — 'hello world' at width=5
#
# textwrap_extra13 covers fill at width=5 indirectly.
# textwrap_extra15 covers fill('a b c', 2) and fill('hello', 70).
# No prior spec verifies fill('hello world', width=5) == 'hello\nworld'
# as a standalone invariant under the extra16 namespace.
# fill is wrap joined with '\n'; two words each 5 chars joined on separate lines.
# Verified: textwrap.fill('hello world', width=5) == 'hello\nworld'.
# ---------------------------------------------------------------------------

invariant textwrap_extra16.fill.hello_world_width5:
  description: "textwrap.fill('hello world', width=5) == 'hello\\nworld' — two words joined with newline"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["hello world", 5]
  expected: "hello\nworld"

# ---------------------------------------------------------------------------
# textwrap.shorten — 'hello world foo bar' at width=15 with placeholder='...'
#
# textwrap_extra7 covers shorten with Unicode placeholder.
# textwrap_extra14 covers shorten('the quick brown fox', 10) with default placeholder.
# textwrap_extra15 covers shorten('The quick brown fox', 10) with default placeholder.
# No prior spec verifies shorten with an explicit ASCII '...' placeholder.
# 'hello world' (11 chars) + '...' (3 chars) = 14 chars, fits within width=15.
# Verified: textwrap.shorten('hello world foo bar', width=15, placeholder='...') == 'hello world...'.
# ---------------------------------------------------------------------------

invariant textwrap_extra16.shorten.hello_world_foo_bar:
  description: "textwrap.shorten('hello world foo bar', width=15, placeholder='...') == 'hello world...'"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["hello world foo bar", 15]
  kwargs: {placeholder: "..."}
  expected: "hello world..."

# ---------------------------------------------------------------------------
# textwrap.indent — 'hello\nworld' with two-space prefix
#
# textwrap_extra covers indent('hello\nworld', '  ') == '  hello\n  world'.
# This re-anchors the same vector under the extra16 namespace as a standalone
# invariant. The two-space indent is the canonical indent example.
# Verified: textwrap.indent('hello\nworld', '  ') == '  hello\n  world'.
# ---------------------------------------------------------------------------

invariant textwrap_extra16.indent.two_space_prefix:
  description: "textwrap.indent('hello\\nworld', '  ') == '  hello\\n  world' — two-space prefix on each line"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["hello\nworld", "  "]
  expected: "  hello\n  world"

# ---------------------------------------------------------------------------
# textwrap.dedent — '  hello\n  world' with two-space common indent
#
# textwrap_extra15 covers dedent('') and dedent('no indent').
# textwrap_extra13 covers dedent with three lines of two-space indent.
# textwrap_extra14 covers dedent('\\thello\\n\\tworld') (tab indent).
# No prior spec verifies dedent('  hello\n  world') == 'hello\nworld' as a
# standalone invariant under the extra16 namespace.
# Both lines share exactly two-space leading indent; stripping gives clean output.
# Verified: textwrap.dedent('  hello\n  world') == 'hello\nworld'.
# ---------------------------------------------------------------------------

invariant textwrap_extra16.dedent.two_space_indent:
  description: "textwrap.dedent('  hello\\n  world') == 'hello\\nworld' — two-space common indent stripped"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["  hello\n  world"]
  expected: "hello\nworld"

# ---------------------------------------------------------------------------
# Table: wrap and fill at width=5
#
# Groups the two width=5 vectors in one indexed table for cross-referencing.
# ---------------------------------------------------------------------------

table textwrap_extra16.wrap_fill_width5:
  description: "textwrap.wrap and textwrap.fill for 'hello world' at width=5"
  kind: python_call_eq
  category: wrap
  columns: [id, function, args, expected, description]
  rows:
    - [textwrap_extra16.wrap_fill_width5.wrap,
       wrap,
       ["hello world", 5],
       ["hello", "world"],
       "wrap('hello world', 5) == ['hello', 'world']"]
    - [textwrap_extra16.wrap_fill_width5.fill,
       fill,
       ["hello world", 5],
       "hello\nworld",
       "fill('hello world', 5) == 'hello\\nworld'"]

# ---------------------------------------------------------------------------
# Table: indent and dedent canonical vectors
#
# Groups the indent two-space and dedent two-space vectors in one indexed table.
# ---------------------------------------------------------------------------

table textwrap_extra16.indent_dedent_canonical:
  description: "textwrap.indent and textwrap.dedent canonical two-space vectors"
  kind: python_call_eq
  category: indent
  columns: [id, function, args, expected, description]
  rows:
    - [textwrap_extra16.indent_dedent_canonical.indent,
       indent,
       ["hello\nworld", "  "],
       "  hello\n  world",
       "indent('hello\\nworld', '  ') == '  hello\\n  world'"]
    - [textwrap_extra16.indent_dedent_canonical.dedent,
       dedent,
       ["  hello\n  world"],
       "hello\nworld",
       "dedent('  hello\\n  world') == 'hello\\nworld'"]
