spec: decimal_extra946
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module rounding constants and limits"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal rounding constant class names and integer precision limit class names"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra946.rounding_constants:
  description: "decimal rounding constant __class__.__name__ identity"
  kind: python_call_eq
  category: rounding_constants
  id_prefix: dc946r
  columns: [id, function, args, expected]
  rows:
    - [dc946r001, decimal.ROUND_UP.__class__.__name__.__eq__,        ["str"], true]
    - [dc946r002, decimal.ROUND_DOWN.__class__.__name__.__eq__,      ["str"], true]
    - [dc946r003, decimal.ROUND_CEILING.__class__.__name__.__eq__,   ["str"], true]
    - [dc946r004, decimal.ROUND_FLOOR.__class__.__name__.__eq__,     ["str"], true]
    - [dc946r005, decimal.ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true]
    - [dc946r006, decimal.ROUND_HALF_DOWN.__class__.__name__.__eq__, ["str"], true]
    - [dc946r007, decimal.ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"], true]
    - [dc946r008, decimal.ROUND_05UP.__class__.__name__.__eq__,      ["str"], true]

table decimal_extra946.rounding_values:
  description: "decimal rounding constant string value identity"
  kind: python_call_eq
  category: rounding_values
  id_prefix: dc946v
  columns: [id, function, args, expected]
  rows:
    - [dc946v001, decimal.ROUND_UP.__eq__,        ["ROUND_UP"],        true]
    - [dc946v002, decimal.ROUND_DOWN.__eq__,      ["ROUND_DOWN"],      true]
    - [dc946v003, decimal.ROUND_CEILING.__eq__,   ["ROUND_CEILING"],   true]
    - [dc946v004, decimal.ROUND_FLOOR.__eq__,     ["ROUND_FLOOR"],     true]
    - [dc946v005, decimal.ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true]
    - [dc946v006, decimal.ROUND_HALF_DOWN.__eq__, ["ROUND_HALF_DOWN"], true]
    - [dc946v007, decimal.ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true]

table decimal_extra946.precision_limits:
  description: "decimal precision and exponent limit class identity"
  kind: python_call_eq
  category: precision_limits
  id_prefix: dc946l
  columns: [id, function, args, expected]
  rows:
    - [dc946l001, decimal.MAX_PREC.__class__.__name__.__eq__,  ["int"], true]
    - [dc946l002, decimal.MAX_EMAX.__class__.__name__.__eq__,  ["int"], true]
    - [dc946l003, decimal.MIN_EMIN.__class__.__name__.__eq__,  ["int"], true]
    - [dc946l004, decimal.MIN_ETINY.__class__.__name__.__eq__, ["int"], true]
    - [dc946l005, decimal.MAX_PREC.__class__.__name__.__eq__,  ["str"], false]
