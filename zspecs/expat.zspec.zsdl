spec: expat
version: ">=2.0"
backend: ctypes(expat)
version_function: XML_ExpatVersion
min_version_prefix: "expat_"

api_header: expat.h
docs: https://libexpat.github.io/doc/api/latest/

provenance:
  derived_from:
    - "Expat documentation — https://libexpat.github.io/doc/api/latest/"
    - "Expat header expat.h — function signatures and error code enumeration"
    - "Verified with expat 2.7.3 on macOS Darwin 25.4.0, 2026-04-08"
  not_derived_from:
    - "Expat source: lib/xmlparse.c"
  notes:
    - "XML_ExpatVersion() returns a char* of the form 'expat_M.m.p' (e.g. 'expat_2.7.3')."
    - "Expat exposes no numeric version function; all version invariants use version_prefix."
    - "Invariants use progressively longer prefixes of the version string to confirm format."
    - "XML_ErrorString(enum) returns char* error descriptions; not suitable for call_eq (pointer return)."
    - "Parser-scoped functions (XML_Parse, XML_GetErrorCode) require a live parser handle which the harness cannot construct inline."
  created_at: "2026-04-08T00:00:00Z"

# ---------------------------------------------------------------------------
# version (category: version)
# Verify XML_ExpatVersion() returns a correctly formatted version string.
# All invariants call the same zero-argument function but verify successively
# longer prefixes, confirming both the 'expat_' sentinel and the major.minor.
# ---------------------------------------------------------------------------

invariant expat.version.prefix_e:
  description: "XML_ExpatVersion() starts with 'e' — basic sanity that a string is returned"
  category: version
  kind: version_prefix
  function: XML_ExpatVersion
  expected_prefix_b64: ZQ==

invariant expat.version.prefix_ex:
  description: "XML_ExpatVersion() starts with 'ex'"
  category: version
  kind: version_prefix
  function: XML_ExpatVersion
  expected_prefix_b64: ZXg=

invariant expat.version.prefix_exp:
  description: "XML_ExpatVersion() starts with 'exp'"
  category: version
  kind: version_prefix
  function: XML_ExpatVersion
  expected_prefix_b64: ZXhw

invariant expat.version.prefix_expa:
  description: "XML_ExpatVersion() starts with 'expa'"
  category: version
  kind: version_prefix
  function: XML_ExpatVersion
  expected_prefix_b64: ZXhwYQ==

invariant expat.version.prefix_expat:
  description: "XML_ExpatVersion() starts with 'expat'"
  category: version
  kind: version_prefix
  function: XML_ExpatVersion
  expected_prefix_b64: ZXhwYXQ=

invariant expat.version.prefix_expat_:
  description: "XML_ExpatVersion() starts with 'expat_' — confirms the underscore separator"
  category: version
  kind: version_prefix
  function: XML_ExpatVersion
  expected_prefix_b64: ZXhwYXRf

invariant expat.version.prefix_expat_major2:
  description: "XML_ExpatVersion() starts with 'expat_2' — confirms major version 2"
  category: version
  kind: version_prefix
  function: XML_ExpatVersion
  expected_prefix_b64: ZXhwYXRfMg==

invariant expat.version.prefix_expat_2dot:
  description: "XML_ExpatVersion() starts with 'expat_2.' — confirms major.dot separator"
  category: version
  kind: version_prefix
  function: XML_ExpatVersion
  expected_prefix_b64: ZXhwYXRfMi4=

invariant expat.version.prefix_expat_2dot7:
  description: "XML_ExpatVersion() starts with 'expat_2.7' — confirms minor version 7"
  category: version
  kind: version_prefix
  function: XML_ExpatVersion
  expected_prefix_b64: ZXhwYXRfMi43

invariant expat.version.prefix_expat_2dot7dot:
  description: "XML_ExpatVersion() starts with 'expat_2.7.' — confirms minor.dot separator"
  category: version
  kind: version_prefix
  function: XML_ExpatVersion
  expected_prefix_b64: ZXhwYXRfMi43Lg==

invariant expat.version.prefix_expat_2dot7dot3:
  description: "XML_ExpatVersion() starts with 'expat_2.7.3' — full version string for 2.7.3"
  category: version
  kind: version_prefix
  function: XML_ExpatVersion
  expected_prefix_b64: ZXhwYXRfMi43LjM=

# ---------------------------------------------------------------------------
# version (category: version)
# Additional structural checks via tables
# ---------------------------------------------------------------------------

table expat.version.minor_prefixes:
  kind: version_prefix
  category: version
  id_prefix: mp
  describe: "XML_ExpatVersion() starts with prefix confirming 'expat_2.7' family"

  columns: [id, function, expected_prefix_b64]
  rows:
    - [e2,  XML_ExpatVersion, ZXhwYXRfMg==   ]
    - [e2d, XML_ExpatVersion, ZXhwYXRfMi4=   ]

