spec: password_validator
version: ">=5.0.0"
backend: node(password-validator)

docs: https://github.com/tarunbatra/password-validator#readme

provenance:
  derived_from:
    - "password-validator README — https://github.com/tarunbatra/password-validator#readme"
    - "Test vectors verified with password-validator via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "password-validator source"
  notes:
    - "Composable password-policy validator with chainable predicate builders."
    - "Install: npm install password-validator"
    - "Pattern: new PasswordValidator().is().min(N).has().uppercase().has().digits().validate(pwd)"
    - "Each builder method returns the schema (chainable). Final .validate(s) returns boolean."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure construction; .validate is a boolean predicate."
  stderr: "null"
  stickiness: "Each invariant constructs a fresh schema."
  codes: {}

# min length only
invariant password_validator.min_length_passes:
  description: "min(8) accepts 8+ chars"
  category: length
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: is, args: []}
    - {method: min, args: [8]}
    - {method: validate, args: ["12345678"]}
  expected: true

invariant password_validator.min_length_rejects_short:
  description: "min(8) rejects shorter strings"
  category: length
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: is, args: []}
    - {method: min, args: [8]}
    - {method: validate, args: ["short"]}
  expected: false

# Uppercase requirement
invariant password_validator.uppercase_required:
  description: "has().uppercase() requires at least one uppercase letter"
  category: rules
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: has, args: []}
    - {method: uppercase, args: []}
    - {method: validate, args: ["Hello"]}
  expected: true

invariant password_validator.uppercase_rejected_when_missing:
  description: "uppercase() rejects all-lowercase strings"
  category: rules
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: has, args: []}
    - {method: uppercase, args: []}
    - {method: validate, args: ["hello"]}
  expected: false

# Digit requirement
invariant password_validator.digits_required:
  description: "has().digits() requires at least one digit"
  category: rules
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: has, args: []}
    - {method: digits, args: []}
    - {method: validate, args: ["abc123"]}
  expected: true

invariant password_validator.digits_rejected_when_missing:
  description: "digits() rejects strings without digits"
  category: rules
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: has, args: []}
    - {method: digits, args: []}
    - {method: validate, args: ["abcdef"]}
  expected: false

# Composite policy: 8+ chars AND uppercase AND digit
invariant password_validator.composite_passes:
  description: "Composite policy (min 8, uppercase, digit) accepts 'Hello123'"
  category: composite
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: is, args: []}
    - {method: min, args: [8]}
    - {method: has, args: []}
    - {method: uppercase, args: []}
    - {method: has, args: []}
    - {method: digits, args: []}
    - {method: validate, args: ["Hello123"]}
  expected: true

invariant password_validator.composite_rejects_no_digit:
  description: "Composite policy rejects 'HelloWorld' (no digit)"
  category: composite
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: is, args: []}
    - {method: min, args: [8]}
    - {method: has, args: []}
    - {method: uppercase, args: []}
    - {method: has, args: []}
    - {method: digits, args: []}
    - {method: validate, args: ["HelloWorld"]}
  expected: false

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:38:05Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
