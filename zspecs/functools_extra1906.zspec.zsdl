spec: functools_extra1906
version: ">=3.9"
backend: python_module(functools)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "Wave 574: __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "functools.partial is a C-level type; its __dict__ does not contain __reversed__, __missing__, __match_args__, __type_params__, or __abstractmethods__."
    - "functools.cached_property is a Python class; its __dict__ does not contain __reversed__, __missing__, __match_args__, or __type_params__."
    - "functools.partialmethod is a Python class; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "functools.lru_cache is a Python function; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "functools.partial.__qualname__ == 'partial' — top-level C type."
    - "functools.cached_property.__qualname__ == 'cached_property' — top-level Python class."
    - "functools.partialmethod.__qualname__ == 'partialmethod' — top-level Python class."
    - "functools.lru_cache.__qualname__ == 'lru_cache' — top-level Python function."
    - "functools.reduce.__qualname__ == 'reduce' — C-level builtin function."
    - "functools.wraps.__qualname__ == 'wraps' — top-level Python function."
    - "functools.partial.__module__ == 'functools'."
    - "functools.cached_property.__module__ == 'functools'."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table functools_extra1906.reversed_missing_protocol:
  kind: python_call_eq
  category: reversed_missing_protocol
  id_prefix: fu1906

  columns: [id, function, args, expected]
  rows:
    - ["fu1906001", "functools.partial.__dict__.__contains__", ["__reversed__"], false]
    - ["fu1906002", "functools.partial.__dict__.__contains__", ["__missing__"], false]
    - ["fu1906003", "functools.cached_property.__dict__.__contains__", ["__reversed__"], false]
    - ["fu1906004", "functools.cached_property.__dict__.__contains__", ["__missing__"], false]
    - ["fu1906005", "functools.partialmethod.__dict__.__contains__", ["__reversed__"], false]
    - ["fu1906006", "functools.partialmethod.__dict__.__contains__", ["__missing__"], false]
    - ["fu1906007", "functools.lru_cache.__dict__.__contains__", ["__reversed__"], false]
    - ["fu1906008", "functools.lru_cache.__dict__.__contains__", ["__missing__"], false]

