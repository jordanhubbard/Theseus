spec: tinypool
version: ">=2.0.0"
backend: node(tinypool)

docs: https://github.com/tinylibs/tinypool#readme

provenance:
  derived_from:
    - "tinypool README — https://github.com/tinylibs/tinypool#readme"
    - "Test vectors verified with tinypool via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "tinypool source"
  notes:
    - "Tiny worker-thread pool — used by Vitest for test parallelisation. piscina-compatible API."
    - "Install: npm install tinypool"
    - "v2 ESM only; named export Tinypool class."
    - "Spec covers the synchronous post-construction shape (options preserved, queueSize/completed/threads). Actually running workers is async."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Constructor throws on missing 'filename'."
  stderr: "null"
  stickiness: "Pool persists workers; .destroy() shuts them down."
  codes: {}

invariant tinypool.options_minThreads_preserved:
  description: "Constructor options.minThreads carried through to .options"
  category: options
  kind: node_chain_eq
  entry: constructor
  class: Tinypool
  entry_args: [{filename: "/dev/null", minThreads: 0, maxThreads: 1}]
  chain:
    - {get: "options.minThreads"}
  expected: 0

invariant tinypool.options_maxThreads_preserved:
  description: "Constructor options.maxThreads carried through to .options"
  category: options
  kind: node_chain_eq
  entry: constructor
  class: Tinypool
  entry_args: [{filename: "/dev/null", minThreads: 0, maxThreads: 1}]
  chain:
    - {get: "options.maxThreads"}
  expected: 1

invariant tinypool.fresh_queueSize_zero:
  description: "Fresh pool has queueSize 0"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: Tinypool
  entry_args: [{filename: "/dev/null", minThreads: 0, maxThreads: 1}]
  chain:
    - {get: queueSize}
  expected: 0

invariant tinypool.fresh_completed_zero:
  description: "Fresh pool has completed 0 (no tasks finished)"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: Tinypool
  entry_args: [{filename: "/dev/null", minThreads: 0, maxThreads: 1}]
  chain:
    - {get: completed}
  expected: 0

invariant tinypool.fresh_threads_empty:
  description: "Fresh pool with minThreads:0 has zero threads"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: Tinypool
  entry_args: [{filename: "/dev/null", minThreads: 0, maxThreads: 1}]
  chain:
    - {get: threads}
    - {get: length}
  expected: 0

invariant tinypool.options_maxThreads_two:
  description: "{maxThreads: 2} is preserved"
  category: options
  kind: node_chain_eq
  entry: constructor
  class: Tinypool
  entry_args: [{filename: "/dev/null", minThreads: 0, maxThreads: 2}]
  chain:
    - {get: "options.maxThreads"}
  expected: 2

invariant tinypool.has_run_method:
  description: "pool.run is a function"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: Tinypool
  entry_args: [{filename: "/dev/null", minThreads: 0, maxThreads: 1}]
  chain:
    - {get: "run.constructor.name"}
  expected: "Function"

invariant tinypool.has_destroy_method:
  description: "pool.destroy is an async function"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: Tinypool
  entry_args: [{filename: "/dev/null", minThreads: 0, maxThreads: 1}]
  chain:
    - {get: "destroy.constructor.name"}
  expected: "AsyncFunction"
