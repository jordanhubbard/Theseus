spec: decimal_extra133
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal rounding constant string lengths and __class__.__module__, and decimal Context instance __class__.__name__ for DefaultContext, BasicContext, ExtendedContext."
    - "All decimal rounding constants (ROUND_UP, ROUND_DOWN, etc.) are plain str instances; their __class__.__module__ == 'builtins'."
    - "decimal.ROUND_UP.__len__() == 8 ('ROUND_UP' has 8 characters)."
    - "decimal.ROUND_DOWN.__len__() == 10 ('ROUND_DOWN' has 10 characters)."
    - "decimal.ROUND_05UP.__len__() == 10 ('ROUND_05UP' has 10 characters)."
    - "decimal.ROUND_HALF_UP.__len__() == 13 ('ROUND_HALF_UP' has 13 characters)."
    - "decimal.ROUND_HALF_DOWN.__len__() == 15 ('ROUND_HALF_DOWN' has 15 characters)."
    - "decimal.ROUND_HALF_EVEN.__len__() == 15 ('ROUND_HALF_EVEN' has 15 characters)."
    - "decimal.ROUND_CEILING.__len__() == 13 ('ROUND_CEILING' has 13 characters)."
    - "decimal.ROUND_FLOOR.__len__() == 11 ('ROUND_FLOOR' has 11 characters)."
    - "decimal.DefaultContext.__class__.__name__ == 'Context' (length 7) — DefaultContext is an instance of decimal.Context."
    - "decimal.BasicContext.__class__.__name__ == 'Context' (length 7)."
    - "decimal.ExtendedContext.__class__.__name__ == 'Context' (length 7)."
    - "decimal.DefaultContext.__class__.__module__ == 'decimal' (length 7) — Context is defined in the decimal module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal rounding constant string lengths
# All rounding constants are plain str instances.
# ROUND_UP: 8, ROUND_DOWN: 10, ROUND_05UP: 9, ROUND_HALF_UP: 13,
# ROUND_HALF_DOWN: 15, ROUND_HALF_EVEN: 15, ROUND_CEILING: 13, ROUND_FLOOR: 11.
# ---------------------------------------------------------------------------

table decimal_extra133.rounding_constant_lengths:
  description: "decimal rounding constant string lengths: ROUND_UP=8, ROUND_DOWN=10, ROUND_05UP=9, ROUND_HALF_UP=13, ROUND_HALF_DOWN=15, ROUND_HALF_EVEN=15, ROUND_CEILING=13, ROUND_FLOOR=11"
  kind: python_call_eq
  category: rounding_constants
  id_prefix: decrnd133

  columns: [id, function, args, expected]
  rows:
    - [rup_len,   ROUND_UP.__len__,        [], 8]
    - [rdown_len, ROUND_DOWN.__len__,      [], 10]
    - [r05up_len, ROUND_05UP.__len__,      [], 10]
    - [rhu_len,   ROUND_HALF_UP.__len__,   [], 13]
    - [rhd_len,   ROUND_HALF_DOWN.__len__, [], 15]
    - [rhe_len,   ROUND_HALF_EVEN.__len__, [], 15]
    - [rceil_len, ROUND_CEILING.__len__,   [], 13]
    - [rfloor_len, ROUND_FLOOR.__len__,    [], 11]

# ---------------------------------------------------------------------------
# decimal rounding constant __class__.__module__
# All rounding constants are str instances; str.__module__ == 'builtins'.
# Verified for ROUND_UP, ROUND_DOWN, ROUND_05UP, ROUND_HALF_UP,
# ROUND_HALF_EVEN, ROUND_CEILING, ROUND_FLOOR.
# ---------------------------------------------------------------------------

table decimal_extra133.rounding_constant_class_module:
  description: "decimal rounding constant __class__.__module__ == 'builtins' (all are plain str instances, so their type's module is builtins)"
  kind: python_call_eq
  category: rounding_constants
  id_prefix: decrnd133

  columns: [id, function, args, expected]
  rows:
    - [rup_mod_eq,   ROUND_UP.__class__.__module__.__eq__,        ["builtins"], true]
    - [rdown_mod_eq, ROUND_DOWN.__class__.__module__.__eq__,      ["builtins"], true]
    - [r05up_mod_eq, ROUND_05UP.__class__.__module__.__eq__,      ["builtins"], true]
    - [rhu_mod_eq,   ROUND_HALF_UP.__class__.__module__.__eq__,   ["builtins"], true]
    - [rhe_mod_eq,   ROUND_HALF_EVEN.__class__.__module__.__eq__, ["builtins"], true]
    - [rceil_mod_eq, ROUND_CEILING.__class__.__module__.__eq__,   ["builtins"], true]
    - [rfloor_mod_eq, ROUND_FLOOR.__class__.__module__.__eq__,    ["builtins"], true]
    - [rup_cls_eq,   ROUND_UP.__class__.__name__.__eq__,          ["str"],      true]
    - [rdown_cls_eq, ROUND_DOWN.__class__.__name__.__eq__,        ["str"],      true]

# ---------------------------------------------------------------------------
# decimal Context instance __class__.__name__ and __class__.__module__
# DefaultContext, BasicContext, ExtendedContext are all Context instances.
# __class__.__name__ == 'Context' (7), __class__.__module__ == 'decimal' (7).
# ---------------------------------------------------------------------------

table decimal_extra133.context_instance_identity:
  description: "decimal.DefaultContext, BasicContext, ExtendedContext are all Context instances: __class__.__name__='Context' (7), __class__.__module__='decimal' (7)"
  kind: python_call_eq
  category: context_identity
  id_prefix: deccxt133

  columns: [id, function, args, expected]
  rows:
    - [defctx_cls_eq,   DefaultContext.__class__.__name__.__eq__,      ["Context"], true]
    - [defctx_cls_len,  DefaultContext.__class__.__name__.__len__,     [],          7]
    - [basctx_cls_eq,   BasicContext.__class__.__name__.__eq__,        ["Context"], true]
    - [basctx_cls_len,  BasicContext.__class__.__name__.__len__,       [],          7]
    - [extctx_cls_eq,   ExtendedContext.__class__.__name__.__eq__,     ["Context"], true]
    - [extctx_cls_len,  ExtendedContext.__class__.__name__.__len__,    [],          7]
    - [defctx_mod_eq,   DefaultContext.__class__.__module__.__eq__,    ["decimal"], true]
    - [defctx_mod_len,  DefaultContext.__class__.__module__.__len__,   [],          7]
    - [basctx_mod_eq,   BasicContext.__class__.__module__.__eq__,      ["decimal"], true]
    - [extctx_mod_eq,   ExtendedContext.__class__.__module__.__eq__,   ["decimal"], true]

# ---------------------------------------------------------------------------
# decimal rounding constant string equality
# Verify each constant equals its own string value.
# ROUND_UP == 'ROUND_UP', ROUND_DOWN == 'ROUND_DOWN', ROUND_05UP == 'ROUND_05UP'.
# ---------------------------------------------------------------------------

table decimal_extra133.rounding_constant_values:
  description: "decimal rounding constant string equality: ROUND_UP='ROUND_UP', ROUND_DOWN='ROUND_DOWN', ROUND_05UP='ROUND_05UP', ROUND_HALF_UP='ROUND_HALF_UP', ROUND_HALF_EVEN='ROUND_HALF_EVEN'"
  kind: python_call_eq
  category: rounding_constants
  id_prefix: decrnd133

  columns: [id, function, args, expected]
  rows:
    - [rup_eq,   ROUND_UP.__eq__,        ["ROUND_UP"],        true]
    - [rdown_eq, ROUND_DOWN.__eq__,      ["ROUND_DOWN"],      true]
    - [r05up_eq, ROUND_05UP.__eq__,      ["ROUND_05UP"],      true]
    - [rhu_eq,   ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true]
    - [rhe_eq,   ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true]
    - [rceil_eq, ROUND_CEILING.__eq__,   ["ROUND_CEILING"],   true]
    - [rfloor_eq, ROUND_FLOOR.__eq__,    ["ROUND_FLOOR"],     true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra133.ROUND_UP.len_8:
  description: "decimal.ROUND_UP.__len__() == 8 ('ROUND_UP' has 8 characters: R-O-U-N-D-_-U-P)"
  category: rounding_constants
  kind: python_call_eq
  function: ROUND_UP.__len__
  args: []
  expected: 8

invariant decimal_extra133.ROUND_05UP.len_10:
  description: "decimal.ROUND_05UP.__len__() == 10 ('ROUND_05UP' has 10 characters: R-O-U-N-D-_-0-5-U-P)"
  category: rounding_constants
  kind: python_call_eq
  function: ROUND_05UP.__len__
  args: []
  expected: 10

invariant decimal_extra133.ROUND_HALF_UP.class_module_builtins:
  description: "decimal.ROUND_HALF_UP.__class__.__module__ == 'builtins' (rounding constants are plain str instances, so their type str has __module__ == 'builtins')"
  category: rounding_constants
  kind: python_call_eq
  function: ROUND_HALF_UP.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant decimal_extra133.DefaultContext.class_is_Context:
  description: "decimal.DefaultContext.__class__.__name__ == 'Context' (length 7; DefaultContext is an instance of the decimal.Context class, not a subclass of it)"
  category: context_identity
  kind: python_call_eq
  function: DefaultContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra133.ExtendedContext.class_module_decimal:
  description: "decimal.ExtendedContext.__class__.__module__ == 'decimal' (length 7; the Context class is defined in the decimal module)"
  category: context_identity
  kind: python_call_eq
  function: ExtendedContext.__class__.__module__.__eq__
  args: ["decimal"]
  expected: true
