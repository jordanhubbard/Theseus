spec: inspect_extra241
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra240.zspec.zsdl — covers FrameInfo/Traceback/ArgInfo named tuple identity"
    - "inspect.zspec.zsdl — covers isfunction/isbuiltin/isclass/ismodule/isroutine; Signature/Parameter classnames; CO_* constants; Parameter kind values and names"
    - "inspect_extra.zspec.zsdl — covers ismethod/isgenerator/iscoroutine/getsourcefile __name__; function modules; isclass(int)/isclass(str)/isbuiltin(len)/isfunction(len)"
    - "inspect_signature.zspec.zsdl — covers BoundArguments/__name__/__module__; Parameter/__module__/__name__; Parameter kind names; Signature.empty"
  notes:
    - "This spec covers inspect.Parameter parameter-kind constants: POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD."
    - "Each constant is an instance of inspect._ParameterKind, an IntEnum subclass. Verified with Python 3.14.3."
    - "Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "Integer values: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter kind constants — class name checks
#
# Each constant's __class__.__name__ == '_ParameterKind'
# because they are instances of the _ParameterKind IntEnum.
#
# New to extra241.
# ---------------------------------------------------------------------------

table inspect_extra241.inspparamk241_classnames:
  description: "inspect.Parameter kind constants __class__.__name__ checks; new to extra241"
  kind: python_call_eq
  category: parameter_kinds
  id_prefix: inspparamk241

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_classname,
       Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is an instance of _ParameterKind (IntEnum); new to extra241"]
    - [positional_or_keyword_classname,
       Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD is an instance of _ParameterKind (IntEnum); new to extra241"]
    - [var_positional_classname,
       Parameter.VAR_POSITIONAL.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — VAR_POSITIONAL is an instance of _ParameterKind (IntEnum); new to extra241"]
    - [keyword_only_classname,
       Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY is an instance of _ParameterKind (IntEnum); new to extra241"]
    - [var_keyword_classname,
       Parameter.VAR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD is an instance of _ParameterKind (IntEnum); new to extra241"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter kind constants — integer values
#
# POSITIONAL_ONLY == 0
# POSITIONAL_OR_KEYWORD == 1
# VAR_POSITIONAL == 2
# KEYWORD_ONLY == 3
# VAR_KEYWORD == 4
#
# Verified with Python 3.14.3. New to extra241.
# ---------------------------------------------------------------------------

table inspect_extra241.inspparamk241_intvalues:
  description: "inspect.Parameter kind constants integer value checks; new to extra241"
  kind: python_call_eq
  category: parameter_kinds
  id_prefix: inspparamk241int

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_int,
       Parameter.POSITIONAL_ONLY.__int__,
       [],
       0,
       "inspect.Parameter.POSITIONAL_ONLY.__int__() == 0 — POSITIONAL_ONLY has integer value 0; IntEnum __int__ returns 0; new to extra241"]
    - [positional_or_keyword_int,
       Parameter.POSITIONAL_OR_KEYWORD.__int__,
       [],
       1,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__int__() == 1 — POSITIONAL_OR_KEYWORD has integer value 1; IntEnum __int__ returns 1; new to extra241"]
    - [var_positional_int,
       Parameter.VAR_POSITIONAL.__int__,
       [],
       2,
       "inspect.Parameter.VAR_POSITIONAL.__int__() == 2 — VAR_POSITIONAL has integer value 2; IntEnum __int__ returns 2; new to extra241"]
    - [keyword_only_int,
       Parameter.KEYWORD_ONLY.__int__,
       [],
       3,
       "inspect.Parameter.KEYWORD_ONLY.__int__() == 3 — KEYWORD_ONLY has integer value 3; IntEnum __int__ returns 3; new to extra241"]
    - [var_keyword_int,
       Parameter.VAR_KEYWORD.__int__,
       [],
       4,
       "inspect.Parameter.VAR_KEYWORD.__int__() == 4 — VAR_KEYWORD has integer value 4; IntEnum __int__ returns 4; new to extra241"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter kind constants — name string checks
#
# Each constant's .name attribute returns the string name of the enum member.
# POSITIONAL_ONLY.name == 'POSITIONAL_ONLY', etc.
#
# New to extra241.
# ---------------------------------------------------------------------------

table inspect_extra241.inspparamk241_names:
  description: "inspect.Parameter kind constants .name string checks; new to extra241"
  kind: python_call_eq
  category: parameter_kinds
  id_prefix: inspparamk241nm

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_name,
       Parameter.POSITIONAL_ONLY.name.__eq__,
       ["POSITIONAL_ONLY"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True — enum member name is 'POSITIONAL_ONLY' (len=15); new to extra241"]
    - [positional_or_keyword_name,
       Parameter.POSITIONAL_OR_KEYWORD.name.__eq__,
       ["POSITIONAL_OR_KEYWORD"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True — enum member name is 'POSITIONAL_OR_KEYWORD' (len=21); new to extra241"]
    - [var_positional_name,
       Parameter.VAR_POSITIONAL.name.__eq__,
       ["VAR_POSITIONAL"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True — enum member name is 'VAR_POSITIONAL' (len=14); new to extra241"]
    - [keyword_only_name,
       Parameter.KEYWORD_ONLY.name.__eq__,
       ["KEYWORD_ONLY"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True — enum member name is 'KEYWORD_ONLY' (len=12); new to extra241"]
    - [var_keyword_name,
       Parameter.VAR_KEYWORD.name.__eq__,
       ["VAR_KEYWORD"],
       true,
       "inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True — enum member name is 'VAR_KEYWORD' (len=11); new to extra241"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra241
# ---------------------------------------------------------------------------

invariant inspect_extra241.positional_only_classname:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'; new to extra241"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra241.positional_or_keyword_classname:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'; new to extra241"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

