spec: abc_extra48
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra47.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), ABCMeta/__subclasshook__/__qualname__.__len__()==24, update_abstractmethods/__qualname__.__len__()==22, ABC/__abstractmethods__/__class__/__name__.__len__()==9, ABC/__name__.__len__()==3, abstractmethod/__name__.__len__()==14, get_cache_token/__name__.__len__()==15, abc/__name__.__len__()==3, ABCMeta mro entry name/qualname lengths, ABC/__subclasshook__/__qualname__.__len__()==20, issubclass/isinstance behavioral invariants, abstractmethod/__class__/__name__.__len__()==8, ABC/__doc__/__class__/__name__.__len__()==3, ABCMeta protocol method lengths, metaclass chain tables, abstractmethod/__annotations__/__class__/__name__.__len__()==4 (extra32), get_cache_token/__class__/__name__.__len__()==26, ABCMeta/__bases__[0]/__module__.__len__()==8/'builtins' and __qualname__.__len__()==4/'type' (extra33), abstractmethod/__class__.__module__.__len__()==8 (extra33), ABCMeta MRO __module__/__qualname__.__len__() tables (extra33), abstractmethod/__name__=='abstractmethod', get_cache_token/__module__=='_abc', ABC/__name__=='ABC', ABC/__bases__[0].__name__=='object' (extra34), ABCMeta/__name__=='ABCMeta'/__module__=='abc'/__bases__[0].__name__=='type'/__mro__.__len__()==3, ABC/__mro__.__len__()==2, ABC/__mro__[1].__name__=='object', ABCMeta.register/__qualname__.__len__()==16 (extra35), abstractproperty/__qualname__=='abstractproperty', abstractclassmethod/__qualname__=='abstractclassmethod', abstractstaticmethod/__qualname__=='abstractstaticmethod', ABCMeta.register/__qualname__=='ABCMeta.register', ABC/__abstractmethods__/__class__/__name__=='frozenset', ABC/__abstractmethods__/__len__()==0, ABCMeta/__call__/__qualname__=='type.__call__' (extra38–extra39), abstractmethod/__qualname__=='abstractmethod', ABCMeta/__qualname__=='ABCMeta', ABC/__qualname__=='ABC', get_cache_token/__qualname__=='get_cache_token' (extra39), abstractproperty/__mro__.__len__()==3, abstractclassmethod/__mro__.__len__()==3, abstractstaticmethod/__mro__.__len__()==3, abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta' (extra40), __class__.__qualname__ string equality for all abc exports (extra41–extra43), abstractmethod/__doc__/__class__/__name__=='str', ABCMeta/__doc__/__class__.__name__=='str', ABC/__doc__/__class__.__name__=='str', ABCMeta/__doc__/__class__/__module__=='builtins', abstractmethod/__doc__/__class__/__module__=='builtins' (extra44), ABCMeta method __doc__/__class__/__name__=='str' tables (extra45–extra46), abstractmethod/__code__/__class__/__name__=='code' (extra46), abstractmethod/__code__/__class__/__qualname__=='code', abstractmethod/__code__/__class__.__module__=='builtins', abstractmethod/__defaults__/__class__/__name__=='NoneType', abstractmethod/__kwdefaults__/__class__/__name__=='NoneType' (extra47). ABCMeta/__bases__[0].__qualname__.__len__()==4 (extra33 — length only, NOT string equality)."
    - "This spec covers: ABCMeta.__bases__[0].__qualname__.__eq__('type') — string equality of the base class __qualname__ (prior extra33 captured only the length==4; extra48 captures the full string equality); ABCMeta.__bases__[0].__module__.__eq__('builtins') — string equality of the base class __module__ (prior extra33 captured __module__.__len__()==8 but not the string equality). Also: abstractmethod.__annotations__.__class__.__name__.__eq__('dict') — string equality (prior extra32 captured __len__()==4 but not the equality); abstractmethod.__annotations__.__class__.__qualname__.__eq__('dict') — qualname check for the dict type; abstractmethod.__annotations__.__len__()==0 — abstractmethod has no annotations; abstractmethod.__annotations__.__class__.__module__.__eq__('builtins') — dict is a built-in type. Also: abstractmethod.__globals__.__class__.__name__.__eq__('dict') — __globals__ of a Python function is a plain dict; abstractmethod.__globals__.__class__.__qualname__.__eq__('dict') — dict qualname."
    - "abc.ABCMeta.__bases__[0].__qualname__ == 'type'. ABCMeta's first base class is the built-in 'type' metaclass. 'type' is a built-in type with no enclosing class, so __qualname__ == __name__ == 'type'. Prior spec extra33 captured __bases__[0].__qualname__.__len__()==4 (the length of 'type') but not the string equality. Extra48 supplies the complementary string equality check: ABCMeta.__bases__[0].__qualname__.__eq__('type') == true. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__bases__[0].__module__ == 'builtins'. The 'type' metaclass is a built-in type defined in the builtins module; therefore ABCMeta.__bases__[0].__module__ == 'builtins'. Prior spec extra33 captured __bases__[0].__module__.__len__()==8 (the length of 'builtins') but not the string equality. Extra48 supplies the complementary string equality check. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__annotations__.__class__.__name__ == 'dict'. abstractmethod is defined as 'def abstractmethod(funcobj): ...' with no annotations; Python represents the empty annotations as an empty dict ({}). The dict type's __name__ == 'dict' (4 chars). Prior spec extra32 captured __annotations__.__class__.__name__.__len__()==4 (length only). Extra48 supplies the string equality check: __annotations__.__class__.__name__.__eq__('dict') == true. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__annotations__.__class__.__qualname__ == 'dict'. The built-in dict type has no enclosing class or function scope, so __qualname__ == __name__ == 'dict'. This parallels the pattern for str, list, and other built-in types: all have __qualname__ == __name__. No prior abc spec has captured the __qualname__ string equality for the annotations container class. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__annotations__.__len__() == 0. abstractmethod has no parameter or return annotations; Python initializes __annotations__ to an empty dict. The empty dict has __len__() == 0. No prior abc spec has captured this __len__()==0 integer invariant for the annotations dict itself (as distinct from the class name length). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__annotations__.__class__.__module__ == 'builtins'. The dict type is a built-in type defined in the builtins module; every dict instance has __class__.__module__ == 'builtins'. This is consistent with the pattern observed for str (docstrings), code (code objects), and NoneType (defaults) in prior abc specs. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__globals__.__class__.__name__ == 'dict'. Every Python function's __globals__ attribute is the global namespace dictionary of the module in which the function was defined. This dict object's __class__.__name__ == 'dict'. No prior abc spec has examined abstractmethod.__globals__. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__globals__.__class__.__qualname__ == 'dict'. The global namespace is a plain dict instance; dict.__qualname__ == 'dict' (same as __name__; dict is a built-in type with no enclosing scope). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.__bases__[0] __qualname__ and __module__ string equality — extra48
#
# ABCMeta's first (and only) base class is the built-in 'type' metaclass.
# 'type' is defined in the builtins module with no enclosing class:
#   ABCMeta.__bases__[0].__qualname__ == 'type'     (4 chars)
#   ABCMeta.__bases__[0].__module__   == 'builtins' (8 chars)
#
# Prior spec extra33 captured:
#   ABCMeta.__bases__[0].__qualname__.__len__() == 4  (length only)
#   ABCMeta.__bases__[0].__module__.__len__()   == 8  (length only)
#
# Extra48 adds the complementary string equality checks in the abcmeta48 namespace.
# ---------------------------------------------------------------------------

table abc_extra48.ABCMeta_base_attrs_eq:
  description: "abc.ABCMeta.__bases__[0] __qualname__ and __module__ string equality in extra48 namespace — base class is built-in 'type'; prior extra33 captured lengths only"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: abcmeta48baseattr

  columns: [id, function, args, expected, description]
  rows:
    - [base_qualname, "ABCMeta.__bases__[0].__qualname__.__eq__", ["type"],     true, "ABCMeta.__bases__[0].__qualname__ == 'type' — built-in type metaclass; __qualname__ == __name__ == 'type' (4 chars); prior extra33 captured __len__()==4, extra48 adds the string equality"]
    - [base_module,   "ABCMeta.__bases__[0].__module__.__eq__",   ["builtins"], true, "ABCMeta.__bases__[0].__module__ == 'builtins' — 'type' is a built-in type defined in builtins (8 chars); prior extra33 captured __len__()==8, extra48 adds the string equality"]

# ---------------------------------------------------------------------------
# abc.abstractmethod.__annotations__ class attributes — extra48
#
# abstractmethod is defined without annotations; __annotations__ is an empty
# dict ({}). The dict type provides the following attributes:
#   __annotations__.__class__.__name__     == 'dict'     (4 chars)
#   __annotations__.__class__.__qualname__ == 'dict'     (4 chars)
#   __annotations__.__class__.__module__   == 'builtins' (8 chars)
#   __annotations__.__len__()              == 0           (empty dict)
#
# Prior spec extra32 captured __annotations__.__class__.__name__.__len__()==4.
# Extra48 introduces the string equality for __name__ and the novel checks for
# __qualname__, __module__, and the dict's own __len__()==0.
# ---------------------------------------------------------------------------

table abc_extra48.abstractmethod_annotations_class_attrs:
  description: "abc.abstractmethod.__annotations__.__class__ attributes in extra48 namespace — dict type has __name__/__qualname__=='dict' and __module__=='builtins'"
  kind: python_call_eq
  category: class_names
  id_prefix: abcmeta48annotsclsattr

  columns: [id, function, args, expected, description]
  rows:
    - [name,     abstractmethod.__annotations__.__class__.__name__.__eq__,     ["dict"],     true, "abstractmethod.__annotations__.__class__.__name__ == 'dict' — annotations is an empty dict; dict.__name__ == 'dict' (4 chars); string equality complement to __len__()==4 from extra32"]
    - [qualname, abstractmethod.__annotations__.__class__.__qualname__.__eq__, ["dict"],     true, "abstractmethod.__annotations__.__class__.__qualname__ == 'dict' — built-in dict has no enclosing scope; __qualname__ == __name__ == 'dict'; novel in extra48"]
    - [module,   abstractmethod.__annotations__.__class__.__module__.__eq__,   ["builtins"], true, "abstractmethod.__annotations__.__class__.__module__ == 'builtins' — dict is a built-in type defined in builtins; every dict instance has __class__.__module__ == 'builtins'"]

# ---------------------------------------------------------------------------
# abc.abstractmethod.__annotations__.__len__() — extra48
#
# abstractmethod has no parameter or return annotations. Python initializes
# the __annotations__ dict to empty ({}), so __len__() == 0.
# No prior abc spec has captured this integer invariant.
# ---------------------------------------------------------------------------

invariant abc_extra48.abstractmethod_annotations_len:
  description: "abc.abstractmethod.__annotations__.__len__() == 0 — abstractmethod has no parameter or return annotations; Python represents the empty annotations as an empty dict; empty dict.__len__() == 0"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__annotations__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# abc.abstractmethod.__globals__ class attributes — extra48
#
# Every Python function's __globals__ attribute is the global namespace
# dictionary of the module where the function was defined. For abstractmethod,
# __globals__ is the global namespace dict of Lib/abc.py. The dict type provides:
#   __globals__.__class__.__name__     == 'dict'     (4 chars)
#   __globals__.__class__.__qualname__ == 'dict'     (4 chars)
#
# No prior abc spec has examined abstractmethod.__globals__. These checks
# confirm that the global namespace is a plain dict (the universal Python
# convention for module-level namespaces).
# ---------------------------------------------------------------------------

table abc_extra48.abstractmethod_globals_class_attrs:
  description: "abc.abstractmethod.__globals__.__class__ attributes in extra48 namespace — global namespace is a plain dict; novel attribute path not covered by prior abc specs"
  kind: python_call_eq
  category: class_names
  id_prefix: abcmeta48globalsclsattr

  columns: [id, function, args, expected, description]
  rows:
    - [name,     abstractmethod.__globals__.__class__.__name__.__eq__,     ["dict"], true, "abstractmethod.__globals__.__class__.__name__ == 'dict' — __globals__ is the module global namespace dict; dict.__name__ == 'dict' (4 chars); first __globals__ check in abc specs"]
    - [qualname, abstractmethod.__globals__.__class__.__qualname__.__eq__, ["dict"], true, "abstractmethod.__globals__.__class__.__qualname__ == 'dict' — global namespace dict; dict is a built-in type with __qualname__ == __name__ == 'dict' (no enclosing scope)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra48
# ---------------------------------------------------------------------------

invariant abc_extra48.ABCMeta_base_qualname_eq:
  description: "abc.ABCMeta.__bases__[0].__qualname__ == 'type' — ABCMeta's base is the built-in 'type' metaclass; 'type' is a built-in with no enclosing scope: __qualname__ == __name__ == 'type' (4 chars); prior extra33 captured __len__()==4, extra48 adds string equality"
  category: class_hierarchy
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__qualname__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra48.ABCMeta_base_module_eq:
  description: "abc.ABCMeta.__bases__[0].__module__ == 'builtins' — 'type' is a built-in type defined in the builtins module; __module__ == 'builtins' (8 chars); prior extra33 captured __len__()==8, extra48 adds string equality"
  category: class_hierarchy
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__module__.__eq__"
  args: ["builtins"]
  expected: true

invariant abc_extra48.abstractmethod_annotations_class_name_eq:
  description: "abc.abstractmethod.__annotations__.__class__.__name__ == 'dict' — abstractmethod has no annotations; Python represents empty annotations as {}; dict.__name__ == 'dict' (4 chars); string equality complement to __len__()==4 from extra32"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant abc_extra48.abstractmethod_annotations_class_qualname_eq:
  description: "abc.abstractmethod.__annotations__.__class__.__qualname__ == 'dict' — built-in dict type has no enclosing scope; __qualname__ == __name__ == 'dict'; novel check not present in prior abc specs"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__annotations__.__class__.__qualname__.__eq__
  args: ["dict"]
  expected: true

invariant abc_extra48.abstractmethod_annotations_class_module_eq:
  description: "abc.abstractmethod.__annotations__.__class__.__module__ == 'builtins' — dict is a built-in type defined in builtins; every dict instance has __class__.__module__ == 'builtins'"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__annotations__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant abc_extra48.abstractmethod_globals_class_name_eq:
  description: "abc.abstractmethod.__globals__.__class__.__name__ == 'dict' — every Python function's __globals__ is the module global namespace dict; dict.__name__ == 'dict' (4 chars); first __globals__ invariant in abc specs"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__globals__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant abc_extra48.abstractmethod_globals_class_qualname_eq:
  description: "abc.abstractmethod.__globals__.__class__.__qualname__ == 'dict' — the global namespace dict is a plain built-in dict type; dict.__qualname__ == 'dict' (no enclosing scope)"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__globals__.__class__.__qualname__.__eq__
  args: ["dict"]
  expected: true
