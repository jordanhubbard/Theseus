# ---------------------------------------------------------------------------
# Standalone invariants — extra108
# ---------------------------------------------------------------------------

invariant multiprocessing_extra108.JoinableQueue_base_is_Queue:
  description: "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__('Queue') returns True — JoinableQueue inherits from Queue giving MRO [JoinableQueue, Queue, object] (length=3, longest MRO in spec); JoinableQueue.__name__=='JoinableQueue' (len=13, longest class name in spec); JoinableQueue.__module__=='multiprocessing.queues'; JoinableQueue adds join() and task_done() to Queue for tracking when all items have been processed; compare bases: Queue.__bases__[0].__name__=='object' (Queue inherits from object, mro len=2); SimpleQueue.__bases__[0].__name__=='object' (also inherits from object, mro len=2); JoinableQueue is the only queue class in the spec that inherits from another queue class (Queue); mro len=3 vs Queue=SimpleQueue=2; NEW in extra108: first standalone JoinableQueue base invariant in mpqueues108 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra108.Queue_base_is_object:
  description: "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__('object') returns True — Queue inherits directly from object (MRO=[Queue, object], length=2, shortest possible MRO); Queue.__module__=='multiprocessing.queues'; Queue.__name__=='Queue' (len=5, shortest class name in spec); SimpleQueue also has base=object, mro len=2 (tied with Queue for shortest); JoinableQueue has base=Queue (mro len=3, longer); Queue.get.__code__.co_argcount==3 (self, block, timeout); Queue.put.__code__.co_argcount==4 (self, obj, block, timeout — put takes one more arg than get); Queue.get.__qualname__=='Queue.get' (len=9, tied shortest qualname in spec with put); Queue is the core multiprocessing queue class (full-featured, process-safe); NEW in extra108: first standalone Queue base invariant in mpqueues108 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.queues.Queue.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra108.Queue_put_co_argcount_4:
  description: "multiprocessing.queues.Queue.put.__code__.co_argcount == 4 — put takes self, obj, block, timeout (4 positional args); compare: Queue.get.__code__.co_argcount==3 (self, block, timeout — one fewer arg since get does not take the object to retrieve); put co_argcount=4 > get co_argcount=3; put has the most positional args in this spec; JoinableQueue.join co_argcount=1 (self only); JoinableQueue.task_done co_argcount=1 (self only); Queue.put.__qualname__=='Queue.put' (len=9, tied shortest with get); Queue.put is the method to enqueue an item; the extra obj arg (vs get) makes put co_argcount=4 the highest in spec; block and timeout control blocking behavior (default block=True, timeout=None); NEW in extra108: first standalone Queue.put argcount invariant in mpqueues108 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.queues.Queue.put.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant multiprocessing_extra108.JoinableQueue_task_done_qualname_len_23:
  description: "multiprocessing.queues.JoinableQueue.task_done.__qualname__.__len__() == 23 — 'JoinableQueue.task_done' = 'JoinableQueue.'=14 + 'task_done'=9 = 23; this is the longest qualname in this spec; compare: Queue.get=Queue.put=9 (shortest) < JoinableQueue.join=18 < JoinableQueue.task_done=23 (longest); JoinableQueue.task_done.__code__.co_argcount==1 (self only); task_done signals that a formerly enqueued task is complete; each call decrements the count of unfinished tasks; when the count drops to zero, join() unblocks; JoinableQueue.task_done.__qualname__=='JoinableQueue.task_done'; 'task_done'=9 chars is the longest method name in spec; 'JoinableQueue'=13 chars (longest class name in spec); NEW in extra108: first standalone JoinableQueue.task_done qualname length invariant in mpqueues108 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: multiprocessing.queues.JoinableQueue.task_done.__qualname__.__len__
  args: []
  expected: 23

invariant multiprocessing_extra108.SimpleQueue_mro_len_2:
  description: "multiprocessing.queues.SimpleQueue.__mro__.__len__() == 2 — SimpleQueue inherits directly from object (MRO=[SimpleQueue, object], length=2, tied with Queue for shortest MRO in spec); SimpleQueue.__name__=='SimpleQueue' (len=11); SimpleQueue.__module__=='multiprocessing.queues'; compare class identities: Queue mro len=2 (base=object), SimpleQueue mro len=2 (base=object), JoinableQueue mro len=3 (base=Queue); SimpleQueue and Queue both have mro len=2 but are independent classes (neither inherits from the other — both inherit from object); SimpleQueue is a simplified implementation with fewer features than Queue (no timeout support, smaller API surface); SimpleQueue.__name__.__len__()==11 (middle length: Queue=5 < SimpleQueue=11 < JoinableQueue=13); NEW in extra108: first standalone SimpleQueue MRO length invariant in mpqueues108 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: multiprocessing.queues.SimpleQueue.__mro__.__len__
  args: []
  expected: 2

