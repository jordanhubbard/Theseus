    - [jq_name_eq,        multiprocessing.queues.JoinableQueue.__name__.__eq__,           ["JoinableQueue"],     true, "JoinableQueue.__name__ == 'JoinableQueue' (len=13, longest class name in spec); verified with Python 3.14.3"]
    - [jq_name_len,       multiprocessing.queues.JoinableQueue.__name__.__len__,          [],                    13,   "JoinableQueue.__name__.__len__() == 13 ('JoinableQueue'=13, longest class name in spec); verified with Python 3.14.3"]
    - [jq_base_eq,        "multiprocessing.queues.JoinableQueue.__bases__[0].__name__.__eq__", ["Queue"],         true, "JoinableQueue.__bases__[0].__name__ == 'Queue' (JoinableQueue inherits from Queue); verified with Python 3.14.3"]
    - [jq_mro_len,        multiprocessing.queues.JoinableQueue.__mro__.__len__,           [],                    3,    "JoinableQueue.__mro__.__len__() == 3 ([JoinableQueue, Queue, object], longest MRO in spec); verified with Python 3.14.3"]
