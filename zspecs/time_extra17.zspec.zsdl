spec: time_extra17
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time_extra10.zspec.zsdl — covers __module__ table for core timing functions"
    - "time_extra15.zspec.zsdl — covers __module__ standalone invariants for sleep/time/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime"
    - "time_extra16.zspec.zsdl — covers __qualname__ for core timing and conversion functions; monotonic_ns/__name__"
  notes:
    - "This spec extends time_extra16.zspec.zsdl."
    - "Prior specs covered: time/sleep/monotonic/perf_counter/process_time/localtime/gmtime/mktime/strftime/strptime/ctime __name__/__module__/__qualname__, struct_time/__name__/__module__, time.timezone/altzone/daylight __class__.__name__, monotonic_ns/__name__."
    - "This spec covers: __module__.__len__() for time/sleep/monotonic/perf_counter/process_time/struct_time; __name__.__len__() for time/sleep/monotonic/perf_counter/process_time/struct_time."
    - "time.time.__module__ == 'time' (len 4) — verified Python 3.12."
    - "time.sleep.__module__ == 'time' (len 4) — verified Python 3.12."
    - "time.monotonic.__module__ == 'time' (len 4) — verified Python 3.12."
    - "time.perf_counter.__module__ == 'time' (len 4) — verified Python 3.12."
    - "time.process_time.__module__ == 'time' (len 4) — verified Python 3.12."
    - "time.struct_time.__module__ == 'time' (len 4) — verified Python 3.12."
    - "time.time.__name__ == 'time' (len 4) — verified Python 3.12."
    - "time.sleep.__name__ == 'sleep' (len 5) — verified Python 3.12."
    - "time.monotonic.__name__ == 'monotonic' (len 9) — verified Python 3.12."
    - "time.perf_counter.__name__ == 'perf_counter' (len 12) — verified Python 3.12."
    - "time.process_time.__name__ == 'process_time' (len 12) — verified Python 3.12."
    - "time.struct_time.__name__ == 'struct_time' (len 11) — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for core timing functions and struct_time
#
# The time module is a C extension; all functions and struct_time are
# registered under the module named 'time' (4 characters). Calling
# __len__() on that string returns 4 for every entry in this table.
# Prior specs establish __module__ equality (extra10, extra15); these
# invariants anchor the derived length values in the extra17 namespace.
# ---------------------------------------------------------------------------

table time_extra17.function_module_lengths:
  description: "__module__.__len__() for time/sleep/monotonic/perf_counter/process_time/struct_time — all 4 (module name 'time')"
  kind: python_call_eq
  category: function_identity
  id_prefix: fml17

  columns: [id, function, args, expected]
  rows:
    - [time,         time.__module__.__len__,         [], 4]
    - [sleep,        sleep.__module__.__len__,        [], 4]
    - [monotonic,    monotonic.__module__.__len__,    [], 4]
    - [perf_counter, perf_counter.__module__.__len__, [], 4]
    - [process_time, process_time.__module__.__len__, [], 4]
    - [struct_time,  struct_time.__module__.__len__,  [], 4]

# ---------------------------------------------------------------------------
# __name__.__len__() for core timing functions and struct_time
#
# Each function's __name__ string has a distinct length:
#   time         -> 'time'         -> 4
#   sleep        -> 'sleep'        -> 5
#   monotonic    -> 'monotonic'    -> 9
#   perf_counter -> 'perf_counter' -> 12
#   process_time -> 'process_time' -> 12
#   struct_time  -> 'struct_time'  -> 11
# Prior specs establish the __name__ string values (extra4, extra7, extra16);
# these invariants anchor the derived length values in the extra17 namespace.
# ---------------------------------------------------------------------------

table time_extra17.function_name_lengths:
  description: "__name__.__len__() for time/sleep/monotonic/perf_counter/process_time/struct_time"
  kind: python_call_eq
  category: function_identity
  id_prefix: fnl17

  columns: [id, function, args, expected]
  rows:
    - [time,         time.__name__.__len__,         [], 4]
    - [sleep,        sleep.__name__.__len__,        [], 5]
    - [monotonic,    monotonic.__name__.__len__,    [], 9]
    - [perf_counter, perf_counter.__name__.__len__, [], 12]
    - [process_time, process_time.__name__.__len__, [], 12]
    - [struct_time,  struct_time.__name__.__len__,  [], 11]

# ---------------------------------------------------------------------------
# time.struct_time — __module__.__len__() and __name__.__len__() standalone
#
# struct_time is the named-tuple-like C type that represents a broken-down
# time value. Its __module__ is 'time' (len 4) and its __name__ is
# 'struct_time' (len 11). These invariants establish the length facts as
# extra17-namespace standalone invariants to complement the table rows above.
# ---------------------------------------------------------------------------

invariant time_extra17.struct_time.module_len:
  description: "time.struct_time.__module__.__len__() == 4 — module name 'time' has 4 characters"
  category: class_identity
  kind: python_call_eq
  function: struct_time.__module__.__len__
  args: []
  expected: 4

invariant time_extra17.struct_time.name_len:
  description: "time.struct_time.__name__.__len__() == 11 — name 'struct_time' has 11 characters"
  category: class_identity
  kind: python_call_eq
  function: struct_time.__name__.__len__
  args: []
  expected: 11
