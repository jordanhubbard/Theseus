spec: decimal_extra2761
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "decimal_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "decimal_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 631 (decimal_extra2761) theme: __matmul__, __truediv__, and __iadd__ dict-presence checks."
    - "decimal.Decimal defines __truediv__ in its own __dict__ — Decimal implements true division (/) with full decimal precision."
    - "decimal.Decimal does NOT define __matmul__ or __iadd__ in its own __dict__."
    - "decimal.Context and decimal.DecimalException do NOT define __matmul__, __truediv__, or __iadd__ in their own __dict__."
    - "__matmul__ supports the @ operator; Decimal is a numeric type but does not implement matrix multiplication semantics."
    - "__truediv__ on Decimal supports the / operator; returns a Decimal result using the active context precision."
    - "__iadd__ supports the += operator; Decimal is immutable and does not implement in-place addition."
    - "decimal.Context provides context-level control for arithmetic but does not itself support these operator protocols."
    - "decimal.DecimalException is an exception base class with no numeric operator semantics."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __matmul__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2761.no_matmul_in_decimal_classes:
  description: "__matmul__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal does not implement matrix multiplication"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2761

  columns: [id, function, args, expected]
  rows:
    - ["dc2761001", "decimal.Decimal.__dict__.__contains__",          ["__matmul__"], false]
    - ["dc2761002", "decimal.Context.__dict__.__contains__",          ["__matmul__"], false]
    - ["dc2761003", "decimal.DecimalException.__dict__.__contains__", ["__matmul__"], false]

# ---------------------------------------------------------------------------
# __truediv__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# Decimal defines __truediv__; Context and DecimalException do not
# ---------------------------------------------------------------------------

table decimal_extra2761.truediv_presence_in_decimal_classes:
  description: "__truediv__ is present in decimal.Decimal __dict__ (true division with decimal precision) but absent from decimal.Context and decimal.DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2761

  columns: [id, function, args, expected]
  rows:
    - ["dc2761004", "decimal.Decimal.__dict__.__contains__",          ["__truediv__"], true]
    - ["dc2761005", "decimal.Context.__dict__.__contains__",          ["__truediv__"], false]
    - ["dc2761006", "decimal.DecimalException.__dict__.__contains__", ["__truediv__"], false]

# ---------------------------------------------------------------------------
# __iadd__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2761.no_iadd_in_decimal_classes:
  description: "__iadd__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal is immutable and does not implement += in-place addition"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2761

  columns: [id, function, args, expected]
  rows:
    - ["dc2761007", "decimal.Decimal.__dict__.__contains__",          ["__iadd__"], false]
    - ["dc2761008", "decimal.Context.__dict__.__contains__",          ["__iadd__"], false]
    - ["dc2761009", "decimal.DecimalException.__dict__.__contains__", ["__iadd__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal has __truediv__ but not __matmul__ or __iadd__
# Contrasts Decimal's selective arithmetic hooks with the absent @ and += on all three classes
# ---------------------------------------------------------------------------

table decimal_extra2761.decimal_has_truediv_but_not_matmul_or_iadd:
  description: "decimal.Decimal defines __add__/__sub__/__mul__/__truediv__ but NOT __matmul__/__iadd__; decimal.Context and decimal.DecimalException define none of __matmul__/__truediv__/__iadd__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2761

  columns: [id, function, args, expected]
  rows:
    - ["dc2761010", "decimal.Decimal.__dict__.__contains__", ["__add__"],     true]
    - ["dc2761011", "decimal.Decimal.__dict__.__contains__", ["__sub__"],     true]
    - ["dc2761012", "decimal.Decimal.__dict__.__contains__", ["__mul__"],     true]
    - ["dc2761013", "decimal.Decimal.__dict__.__contains__", ["__truediv__"], true]
    - ["dc2761014", "decimal.Decimal.__dict__.__contains__", ["__matmul__"],  false]
    - ["dc2761015", "decimal.Decimal.__dict__.__contains__", ["__iadd__"],    false]
    - ["dc2761016", "decimal.Context.__dict__.__contains__", ["__matmul__"],  false]
    - ["dc2761017", "decimal.Context.__dict__.__contains__", ["__truediv__"], false]
    - ["dc2761018", "decimal.Context.__dict__.__contains__", ["__iadd__"],    false]
    - ["dc2761019", "decimal.DecimalException.__dict__.__contains__", ["__matmul__"],  false]
    - ["dc2761020", "decimal.DecimalException.__dict__.__contains__", ["__truediv__"], false]
    - ["dc2761021", "decimal.DecimalException.__dict__.__contains__", ["__iadd__"],    false]
