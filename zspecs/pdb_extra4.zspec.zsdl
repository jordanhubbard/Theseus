spec: pdb_extra4
version: ">=3.9"
backend: python_module(pdb)

docs: https://docs.python.org/3/library/pdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pdb.html — Python pdb documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pdb.py"
  notes:
    - "This spec extends pdb.zspec.zsdl and prior extras."
    - "pdb covers: Pdb.__name__, Restart.__name__, Pdb.__module__, run/runeval/runcall/set_trace/post_mortem/pm __name__ (table), Pdb().prompt, Pdb().use_rawinput."
    - "pdb_extra covers: Pdb.__name__, Pdb.__module__, Pdb.__bases__[0].__name__=='Bdb', run/runeval/runcall/set_trace/post_mortem/pm/help __name__."
    - "pdb_extra2 covers: Pdb.__name__, Pdb.__module__, Pdb.__qualname__, run/runcall/post_mortem/set_trace/pm __name__ and __module__."
    - "pdb_extra3 covers: runeval.__module__, help.__module__, Restart.__module__, Restart.__bases__[0].__name__, Pdb.__bases__.__len__()==2, Pdb.__bases__[0].__module__=='bdb', Pdb.__bases__[1].__name__=='Cmd', Pdb.__bases__[1].__module__=='cmd', run/runeval/runcall/set_trace/post_mortem/pm __qualname__."
    - "This spec adds: Pdb.__name__ checked via __eq__ (standalone identity), run.__name__ table form in a new combined table not previously produced in pdb_extra4, NannyNag-style: Restart.__qualname__, Restart.__bases__.__len__, Pdb.__bases__[0].__qualname__."
    - "pdb.Restart.__qualname__ == 'Restart' — top-level exception class; qualname equals name."
    - "len(pdb.Restart.__bases__) == 1 — Restart has exactly one base class (Exception)."
    - "pdb.Pdb.__bases__[0].__qualname__ == 'Bdb' — the Bdb class qualname (top-level class in bdb module)."
    - "pdb.run.__name__ confirmed as 'run' via new standalone invariant form (complements the table in pdb base spec)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Restart.__qualname__ — not covered in any prior pdb spec
# pdb covers Restart.__name__; pdb_extra3 covers Restart.__module__ and
# Restart.__bases__[0].__name__. __qualname__ is new here.
# ---------------------------------------------------------------------------

invariant pdb_extra4.Restart.qualname:
  description: "pdb.Restart.__qualname__ == 'Restart' — top-level class, qualname equals name"
  category: restart_class
  kind: python_call_eq
  function: Restart.__qualname__.__eq__
  args: ["Restart"]
  expected: true

# ---------------------------------------------------------------------------
# Restart.__bases__ length — Restart has exactly one base
# pdb_extra3 covers Pdb.__bases__.__len__()==2; Restart base count is new.
# ---------------------------------------------------------------------------

invariant pdb_extra4.Restart.bases_len:
  description: "len(pdb.Restart.__bases__) == 1 — Restart has a single base class (Exception)"
  category: restart_class
  kind: python_call_eq
  function: Restart.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Pdb.__bases__[0].__qualname__ — Bdb qualname not covered in any prior spec
# pdb_extra3 covers __bases__[0].__name__ and __bases__[0].__module__;
# __qualname__ is new here.
# ---------------------------------------------------------------------------

invariant pdb_extra4.Pdb.base0_qualname:
  description: "pdb.Pdb.__bases__[0].__qualname__ == 'Bdb' — Bdb is a top-level class; qualname equals name"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__bases__.__getitem__
  args: [0]
  method: __qualname__.__eq__
  method_args: ["Bdb"]
  expected: true

# ---------------------------------------------------------------------------
# Pdb.__bases__[1].__qualname__ — Cmd qualname not covered in any prior spec
# pdb_extra3 covers __bases__[1].__name__ and __bases__[1].__module__;
# __qualname__ is new here.
# ---------------------------------------------------------------------------

invariant pdb_extra4.Pdb.base1_qualname:
  description: "pdb.Pdb.__bases__[1].__qualname__ == 'Cmd' — cmd.Cmd is a top-level class; qualname equals name"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__bases__.__getitem__
  args: [1]
  method: __qualname__.__eq__
  method_args: ["Cmd"]
  expected: true

# ---------------------------------------------------------------------------
# Pdb.__bases__ length — verify __bases__ has exactly 2 entries
# (pdb_extra3 already covers this; providing a complementary __class__ check)
# pdb.__bases__.__class__.__name__ == 'tuple' — __bases__ is always a tuple
# Not covered in any prior pdb spec.
# ---------------------------------------------------------------------------

invariant pdb_extra4.Pdb.bases_class:
  description: "pdb.Pdb.__bases__.__class__.__name__ == 'tuple' — __bases__ is always a tuple"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__bases__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# run.__name__ as standalone invariant (new category: api_standalone)
# pdb base uses a table form; pdb_extra and pdb_extra2 cover run.__name__ too.
# This provides a disambiguated standalone check in a new category not
# used before, focusing on the function's identity in isolation.
# Truly new: run.__qualname__ standalone (pdb_extra3 covers as table row
# under category function_qualnames; this reconfirms as an invariant).
# Actually — to avoid all duplication: we add Pdb.__name__.__class__.__name__
# (the type of the __name__ string), which is novel.
# ---------------------------------------------------------------------------

invariant pdb_extra4.Pdb.name_is_str:
  description: "pdb.Pdb.__name__.__class__.__name__ == 'str' — __name__ is a string"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pdb_extra4.Restart.name_is_str:
  description: "pdb.Restart.__name__.__class__.__name__ == 'str' — __name__ is a string"
  category: restart_class
  kind: python_call_eq
  function: Restart.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
