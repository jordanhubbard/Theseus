spec: functools_extra293
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module __all__ list membership and metadata"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.__all__ has exactly 15 members in Python 3.14.3 including Placeholder"
    - "Placeholder was added in Python 3.14 as a sentinel for partial argument slots"
    - "WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES are tuple constants exported in __all__"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra293.all_membership:
  description: "Check that key public names are present in functools.__all__"
  kind: python_call_eq
  category: identity
  id_prefix: ftex293

  columns: [id, function, args, expected, description]
  rows:
    - [ftex293_001, functools.__all__.__contains__, ["reduce"], true, "reduce is in __all__"]
    - [ftex293_002, functools.__all__.__contains__, ["partial"], true, "partial is in __all__"]
    - [ftex293_003, functools.__all__.__contains__, ["lru_cache"], true, "lru_cache is in __all__"]
    - [ftex293_004, functools.__all__.__contains__, ["cache"], true, "cache is in __all__"]
    - [ftex293_005, functools.__all__.__contains__, ["total_ordering"], true, "total_ordering is in __all__"]
    - [ftex293_006, functools.__all__.__contains__, ["singledispatch"], true, "singledispatch is in __all__"]
    - [ftex293_007, functools.__all__.__contains__, ["singledispatchmethod"], true, "singledispatchmethod is in __all__"]
    - [ftex293_008, functools.__all__.__contains__, ["wraps"], true, "wraps is in __all__"]
    - [ftex293_009, functools.__all__.__contains__, ["cached_property"], true, "cached_property is in __all__"]
    - [ftex293_010, functools.__all__.__contains__, ["cmp_to_key"], true, "cmp_to_key is in __all__"]
    - [ftex293_011, functools.__all__.__contains__, ["partialmethod"], true, "partialmethod is in __all__"]
    - [ftex293_012, functools.__all__.__contains__, ["update_wrapper"], true, "update_wrapper is in __all__"]
    - [ftex293_013, functools.__all__.__contains__, ["Placeholder"], true, "Placeholder sentinel is in __all__ (added Python 3.14)"]
    - [ftex293_014, functools.__all__.__contains__, ["WRAPPER_ASSIGNMENTS"], true, "WRAPPER_ASSIGNMENTS tuple is in __all__"]
    - [ftex293_015, functools.__all__.__contains__, ["WRAPPER_UPDATES"], true, "WRAPPER_UPDATES tuple is in __all__"]

table functools_extra293.all_metadata:
  description: "Metadata checks for functools.__all__: type and length"
  kind: python_call_eq
  category: identity
  id_prefix: ftex293m

  columns: [id, function, args, expected, description]
  rows:
    - [ftex293m_001, functools.__all__.__class__.__name__.__eq__, ["list"], true, "__all__ is a list"]
    - [ftex293m_002, functools.__all__.__len__, [], 15, "__all__ has exactly 15 members"]

invariant functools_extra293.inv_reduce_in_all:
  description: "reduce is exported from functools.__all__"
  category: identity
  kind: python_call_eq
  function: functools.__all__.__contains__
  args: ["reduce"]
  expected: true

invariant functools_extra293.inv_lru_cache_in_all:
  description: "lru_cache is exported from functools.__all__"
  category: identity
  kind: python_call_eq
  function: functools.__all__.__contains__
  args: ["lru_cache"]
  expected: true

invariant functools_extra293.inv_all_len:
  description: "functools.__all__ has exactly 15 members"
  category: identity
  kind: python_call_eq
  function: functools.__all__.__len__
  args: []
  expected: 15

invariant functools_extra293.inv_wraps_in_all:
  description: "wraps is exported from functools.__all__"
  category: identity
  kind: python_call_eq
  function: functools.__all__.__contains__
  args: ["wraps"]
  expected: true
