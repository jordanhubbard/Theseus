spec: numpy_linalg_rust
version: ">=3.9"
backend: rust_module(numpy_linalg_rust)

docs: https://numpy.org/doc/stable/reference/routines.linalg.html

provenance:
  derived_from:
    - "https://numpy.org/doc/stable/reference/routines.linalg.html — NumPy linalg documentation"
  not_derived_from:
    - "NumPy source: numpy/linalg/linalg.py"
  notes:
    - "numpy.linalg functions for exact or near-exact values."
    - "linalg.norm([3, 4]) == 5.0 — Euclidean norm of [3,4] = sqrt(25) = 5 (exact)."
    - "linalg.norm([0, 0]) == 0.0 (exact)."
    - "linalg.norm([1, 0]) == 1.0 (exact)."
    - "linalg.det([[1,0],[0,1]]) == 1.0 — identity matrix determinant (exact)."
    - "linalg.det([[2,0],[0,3]]) == 6.0 — diagonal matrix (exact)."
    - "linalg.det([[1,2],[3,4]]) == -2.0 — 1*4 - 2*3 = -2 (exact)."
    - "linalg.det([[0,0],[0,0]]) == 0.0 (exact)."
    - "np.trace([[1,2],[3,4]]) == 5.0 — sum of diagonal elements (exact)."
    - "All test vectors verified against numpy 2.2.4."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# linalg.norm — Euclidean norm for exact Pythagorean triples
table numpy_linalg_rust.norm.vectors:
  kind: python_call_eq
  category: norm
  id_prefix: nl_norm
  function: norm

  columns: [id, args, expected]
  rows:
    - [three_four_five, [[3, 4]],    5.0]
    - [unit_x,          [[1, 0]],    1.0]
    - [unit_y,          [[0, 1]],    1.0]
    - [zero_vec,        [[0, 0]],    0.0]
    - [five_twelve,     [[5, 12]],   13.0]

# linalg.det — matrix determinant for exact cases
table numpy_linalg_rust.det.vectors:
  kind: python_call_eq
  category: det
  id_prefix: nl_det
  function: det

  columns: [id, args, expected]
  rows:
    - [identity,   [[[1, 0], [0, 1]]],  1.0]
    - [diagonal,   [[[2, 0], [0, 3]]],  6.0]
    - [simple,     [[[1, 2], [3, 4]]], -2.0]
    - [zero_mat,   [[[0, 0], [0, 0]]],  0.0]
    - [neg_diag,   [[[-1, 0], [0, -1]]], 1.0]

# np.trace — sum of diagonal elements
table numpy_linalg_rust.trace.vectors:
  kind: python_call_eq
  category: trace
  id_prefix: nl_tr
  function: trace

  columns: [id, args, expected]
  rows:
    - [two_by_two,  [[[1, 2], [3, 4]]],   5.0]
    - [identity,    [[[1, 0], [0, 1]]],   2.0]
    - [zeros,       [[[0, 0], [0, 0]]],   0.0]
    - [three_by_three, [[[1,0,0],[0,2,0],[0,0,3]]], 6.0]

