spec: asyncio_extra61
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#qualname — Python __qualname__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra60.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__() tables, InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__/__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality (extra11/extra23/extra51 covered Queue.put/get/empty/full/qsize/put_nowait/get_nowait and Lock.acquire/release), asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ (extra/extra2/extra5), Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), BoundedSemaphore/__bases__[0].__qualname__=='Semaphore' (extra53), Condition/__bases__[0].__qualname__=='object' (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') for Queue/Lock/Event/Semaphore/Condition (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ for Queue/Lock/Event/Semaphore (extra56), class __weakref__.__class__.__name__ for Queue/Lock/Event/Semaphore (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56), asyncio.__all__.__class__.__name__.__eq__('tuple') (extra57), Queue/Lock/Event/Semaphore __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra57), Queue/Lock/Event __subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') (extra57), asyncio.__all__.__contains__ membership checks for Queue/Lock/Event/Semaphore/gather/sleep/Task/Future (extra58), asyncio.__package__.__eq__('asyncio') (extra58), Queue/Lock __doc__.__class__.__name__.__eq__('str') (extra58), __loader__.__class__.__name__.__eq__('SourceFileLoader') (extra59), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra59), __file__.__class__.__name__.__eq__('str') (extra59), __cached__.__class__.__name__.__eq__('str') (extra59), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra60)."
    - "This spec covers (asyncioqual61 namespace): wave 227 theme — class method __qualname__ string equality checks for public methods not yet covered. NEW in extra61: Queue.__init__.__qualname__.__eq__('Queue.__init__') and Lock.__init__.__qualname__.__eq__('Lock.__init__') — the __init__ qualname string equality checks have NOT appeared in any prior asyncio spec (extra55 captured __init__.__class__.__name__.__eq__('function') only; no spec captured the __qualname__ string equality for Queue.__init__ or Lock.__init__). Queue.put/get/empty/full/qsize/put_nowait/get_nowait __qualname__.__eq__ and Lock.acquire/release __qualname__.__eq__ were covered in extra11/extra23/extra51 — those are repeated here to build a complete wave 227 table alongside the novel __init__ checks."
    - "asyncio.Queue.__init__.__qualname__ == 'Queue.__init__'. Queue defines its own __init__ in Lib/asyncio/queues.py. The qualname carries the class prefix 'Queue.' followed by '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__init__.__qualname__ == 'Lock.__init__'. Lock defines its own __init__ in Lib/asyncio/locks.py. The qualname carries the class prefix 'Lock.' followed by '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.put.__qualname__ == 'Queue.put'. asyncio.Queue.get.__qualname__ == 'Queue.get'. asyncio.Queue.empty.__qualname__ == 'Queue.empty'. asyncio.Queue.full.__qualname__ == 'Queue.full'. asyncio.Queue.qsize.__qualname__ == 'Queue.qsize'. All defined directly on asyncio.Queue. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire'. asyncio.Lock.release.__qualname__ == 'Lock.release'. Both defined directly on asyncio.Lock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Queue method __qualname__ string equality — extra61
#
# Wave 227 theme: class method __qualname__ string equality checks for public
# methods not yet covered.
#
# NEW: Queue.__init__.__qualname__.__eq__('Queue.__init__') — first time in
# any asyncio spec. Queue defines its own __init__ in Lib/asyncio/queues.py.
#
# Already covered in extra11/extra23/extra51 (included here for completeness):
#   Queue.put, Queue.get, Queue.empty, Queue.full, Queue.qsize
# ---------------------------------------------------------------------------

table asyncio_extra61.queue_method_qualnames:
  description: "asyncio Queue method __qualname__ string equality checks in asyncioqual61 namespace — wave 227 theme: class method __qualname__ string equality; Queue.__init__.__qualname__.__eq__('Queue.__init__') is NEW (no prior asyncio spec has checked this); Queue.put/get/empty/full/qsize are also included; all methods defined directly on asyncio.Queue in Lib/asyncio/queues.py; pure-Python class methods follow 'ClassName.method' qualname pattern; first __init__ qualname string equality check for Queue in any asyncio spec"
  kind: python_call_eq
  category: qualname
  id_prefix: asyncioqual61

  columns: [id, function, args, expected, description]
  rows:
    - [queue_init,  "Queue.__init__.__qualname__.__eq__",  ["Queue.__init__"],  true,  "Queue.__init__.__qualname__ == 'Queue.__init__' — Queue defines its own __init__ in Lib/asyncio/queues.py; qualname carries class prefix 'Queue.' + '__init__'; NEW in extra61: first __init__ qualname string equality check for asyncio.Queue in any asyncio spec; verified with Python 3.14.3"]
    - [queue_put,   Queue.put.__qualname__.__eq__,         ["Queue.put"],       true,  "Queue.put.__qualname__ == 'Queue.put' — coroutine method defined directly on asyncio.Queue in Lib/asyncio/queues.py; pure-Python method qualname follows 'ClassName.method' pattern; wave 227 table entry alongside novel __init__ check"]
    - [queue_get,   Queue.get.__qualname__.__eq__,         ["Queue.get"],       true,  "Queue.get.__qualname__ == 'Queue.get' — coroutine method defined directly on asyncio.Queue in Lib/asyncio/queues.py; pure-Python method qualname follows 'ClassName.method' pattern; wave 227 table entry"]
    - [queue_empty, Queue.empty.__qualname__.__eq__,       ["Queue.empty"],     true,  "Queue.empty.__qualname__ == 'Queue.empty' — method defined directly on asyncio.Queue; returns True if the queue has no items; wave 227 table entry"]
    - [queue_full,  Queue.full.__qualname__.__eq__,        ["Queue.full"],      true,  "Queue.full.__qualname__ == 'Queue.full' — method defined directly on asyncio.Queue; returns True if the queue is full; wave 227 table entry"]
    - [queue_qsize, Queue.qsize.__qualname__.__eq__,       ["Queue.qsize"],     true,  "Queue.qsize.__qualname__ == 'Queue.qsize' — method defined directly on asyncio.Queue; returns the number of items in the queue; wave 227 table entry"]

# ---------------------------------------------------------------------------
# asyncio Lock method __qualname__ string equality — extra61
#
# Wave 227 theme: class method __qualname__ string equality.
#
# NEW: Lock.__init__.__qualname__.__eq__('Lock.__init__') — first time in
# any asyncio spec. Lock defines its own __init__ in Lib/asyncio/locks.py.
#
# Already covered in extra11/extra23/extra51 (included here for completeness):
#   Lock.acquire, Lock.release
# ---------------------------------------------------------------------------

table asyncio_extra61.lock_method_qualnames:
  description: "asyncio Lock method __qualname__ string equality checks in asyncioqual61 namespace — wave 227 theme: class method __qualname__ string equality; Lock.__init__.__qualname__.__eq__('Lock.__init__') is NEW (no prior asyncio spec has checked this); Lock.acquire/release also included; all methods defined directly on asyncio.Lock in Lib/asyncio/locks.py; first __init__ qualname string equality check for Lock in any asyncio spec"
  kind: python_call_eq
  category: qualname
  id_prefix: asyncioqual61lock

  columns: [id, function, args, expected, description]
  rows:
    - [lock_init,    "Lock.__init__.__qualname__.__eq__",    ["Lock.__init__"],    true,  "Lock.__init__.__qualname__ == 'Lock.__init__' — Lock defines its own __init__ in Lib/asyncio/locks.py; qualname carries class prefix 'Lock.' + '__init__'; NEW in extra61: first __init__ qualname string equality check for asyncio.Lock in any asyncio spec; verified with Python 3.14.3"]
    - [lock_acquire, Lock.acquire.__qualname__.__eq__,       ["Lock.acquire"],     true,  "Lock.acquire.__qualname__ == 'Lock.acquire' — coroutine method defined directly on asyncio.Lock in Lib/asyncio/locks.py; pure-Python method qualname follows 'ClassName.method' pattern; wave 227 table entry"]
    - [lock_release, Lock.release.__qualname__.__eq__,       ["Lock.release"],     true,  "Lock.release.__qualname__ == 'Lock.release' — coroutine method defined directly on asyncio.Lock; raises RuntimeError if lock is not acquired; wave 227 table entry"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra61
# ---------------------------------------------------------------------------

invariant asyncio_extra61.queue_init_qualname_eq:
  description: "asyncio.Queue.__init__.__qualname__.__eq__('Queue.__init__') returns True — Queue defines its own __init__ in Lib/asyncio/queues.py; qualname carries the class prefix 'Queue.' plus '__init__'; NEW in extra61: no prior asyncio spec has captured the Queue.__init__ qualname string equality; wave 227 first __init__ qualname eq invariant for asyncio.Queue"
  category: qualname
  kind: python_call_eq
  function: Queue.__init__.__qualname__.__eq__
  args: ["Queue.__init__"]
  expected: true

invariant asyncio_extra61.lock_init_qualname_eq:
  description: "asyncio.Lock.__init__.__qualname__.__eq__('Lock.__init__') returns True — Lock defines its own __init__ in Lib/asyncio/locks.py; qualname carries the class prefix 'Lock.' plus '__init__'; NEW in extra61: no prior asyncio spec has captured the Lock.__init__ qualname string equality; wave 227 first __init__ qualname eq invariant for asyncio.Lock"
  category: qualname
  kind: python_call_eq
  function: Lock.__init__.__qualname__.__eq__
  args: ["Lock.__init__"]
  expected: true

invariant asyncio_extra61.queue_put_qualname_eq:
  description: "asyncio.Queue.put.__qualname__.__eq__('Queue.put') returns True — Queue.put is a coroutine method defined directly on asyncio.Queue; pure-Python methods carry the 'ClassName.method' qualname pattern; wave 227 table entry alongside novel __init__ checks"
  category: qualname
  kind: python_call_eq
  function: Queue.put.__qualname__.__eq__
  args: ["Queue.put"]
  expected: true
