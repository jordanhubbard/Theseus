spec: types_extra29
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "This spec extends types_extra28.zspec.zsdl."
    - "Prior specs covered: FunctionType/LambdaType/MethodType/GeneratorType/CodeType/ModuleType/__name__/__module__/__qualname__, SimpleNamespace/__name__/__module__/__qualname__, MappingProxyType/__name__, DynamicClassAttribute/__name__, GenericAlias/__name__, UnionType/__name__, various __bases__[0].__name__ checks, NoneType/EllipsisType/NotImplementedType, __module__.__len__() and __name__.__len__() for many types, __qualname__.__len__() for SimpleNamespace/__init__/__repr__/__eq__ and ModuleType/__init__/__repr__, __mro__.__len__() for MappingProxyType/NoneType/EllipsisType, NoneType.__module__.__len__() == 8, new_class.__qualname__.__len__() == 9, types.__all__.__len__() (33) and .__class__.__name__.__len__() (4), __dict__.__class__.__name__.__len__() for seven classes (all mappingproxy=12), __qualname__.__len__() for SimpleNamespace(15)/MappingProxyType(12)/NoneType(8)/GeneratorType(9)/CoroutineType(9)/FunctionType(8)/MethodType(6), __bases__[0].__name__.__len__() for SimpleNamespace(6) and MappingProxyType(6)."
    - "This spec covers: __mro__.__len__() for SimpleNamespace/MappingProxyType/FunctionType/MethodType/GeneratorType/CoroutineType (all 2 — all directly subclass object); __bases__[0].__name__.__len__() for FunctionType/MethodType/GeneratorType/CoroutineType (all 6 — 'object'); CodeType __dict__.__class__.__name__.__len__() (12), __qualname__.__len__() (4), __mro__.__len__() (2), __bases__[0].__name__.__len__() (6); types.__name__.__len__() (5 — 'types')."
    - "Key findings: All six C-level and Python-level types in this spec (SimpleNamespace, MappingProxyType, FunctionType, MethodType, GeneratorType, CoroutineType) have __mro__ length 2 — each is a direct subclass of object with no intermediate base. CodeType.__qualname__ == 'code' (length 4) — the C internal short name. types.__name__ == 'types' (length 5)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() table — core types-module classes
#
# SimpleNamespace, MappingProxyType, FunctionType, MethodType, GeneratorType,
# and CoroutineType all have __mro__ length 2. Each class is a direct subclass
# of object with no intermediate base in its MRO. This holds for both the
# Python-level class (SimpleNamespace) and all five C-level types. No prior
# types spec records __mro__.__len__() for any of these six classes.
# ---------------------------------------------------------------------------

table types_extra29.core_type_mro_lens:
  description: "__mro__.__len__() for six types-module classes — all 2 (each directly subclasses object)"
  kind: python_call_eq
  category: mro_lengths
  id_prefix: mro_len

  columns: [id, function, args, expected, description]
  rows:
    - [SimpleNamespace,
       SimpleNamespace.__mro__.__len__,
       [],
       2,
       "len(types.SimpleNamespace.__mro__) == 2 — (SimpleNamespace, object)"]
    - [MappingProxyType,
       MappingProxyType.__mro__.__len__,
       [],
       2,
       "len(types.MappingProxyType.__mro__) == 2 — (mappingproxy, object)"]
    - [FunctionType,
       FunctionType.__mro__.__len__,
       [],
       2,
       "len(types.FunctionType.__mro__) == 2 — (function, object)"]
    - [MethodType,
       MethodType.__mro__.__len__,
       [],
       2,
       "len(types.MethodType.__mro__) == 2 — (method, object)"]
    - [GeneratorType,
       GeneratorType.__mro__.__len__,
       [],
       2,
       "len(types.GeneratorType.__mro__) == 2 — (generator, object)"]
    - [CoroutineType,
       CoroutineType.__mro__.__len__,
       [],
       2,
       "len(types.CoroutineType.__mro__) == 2 — (coroutine, object)"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() table — FunctionType/MethodType/
# GeneratorType/CoroutineType
#
# FunctionType, MethodType, GeneratorType, and CoroutineType each have
# 'object' (length 6) as their sole direct base class. This is consistent
# with the flat MRO depth of 2 for all four types. Prior specs established
# SimpleNamespace.__bases__[0].__name__.__len__() == 6 (extra28) and
# MappingProxyType.__bases__[0].__name__.__len__() == 6 (extra28). This table
# extends the pattern to the remaining four core C-level types in the module.
# ---------------------------------------------------------------------------

table types_extra29.ctype_bases0_name_lens:
  description: "__bases__[0].__name__.__len__() for FunctionType/MethodType/GeneratorType/CoroutineType — all 6 ('object')"
  kind: python_call_eq
  category: base_class_names
  id_prefix: bases0_name_len

  columns: [id, function, args, expected, description]
  rows:
    - [FunctionType,
       "FunctionType.__bases__[0].__name__.__len__",
       [],
       6,
       "types.FunctionType.__bases__[0].__name__ == 'object' (length 6)"]
    - [MethodType,
       "MethodType.__bases__[0].__name__.__len__",
       [],
       6,
       "types.MethodType.__bases__[0].__name__ == 'object' (length 6)"]
    - [GeneratorType,
       "GeneratorType.__bases__[0].__name__.__len__",
       [],
       6,
       "types.GeneratorType.__bases__[0].__name__ == 'object' (length 6)"]
    - [CoroutineType,
       "CoroutineType.__bases__[0].__name__.__len__",
       [],
       6,
       "types.CoroutineType.__bases__[0].__name__ == 'object' (length 6)"]

# ---------------------------------------------------------------------------
# types.CodeType class introspection — standalone invariants
#
# types.CodeType is the C-level type for Python bytecode objects.
# Its internal C name is 'code' (length 4), shorter than the Python attribute
# name 'CodeType' (8). Its __dict__ is a mappingproxy (length 12), consistent
# with all other classes in the types module. Its __mro__ has length 2
# (code, object), and its sole base class is 'object' (length 6).
# No prior types spec records any of these four invariants for CodeType.
# ---------------------------------------------------------------------------

invariant types_extra29.CodeType.qualname_len:
  description: "types.CodeType.__qualname__.__len__() == 4 — C internal name 'code' has length 4; Python attribute name 'CodeType' has length 8"
  category: qualname_attr_lengths
  kind: python_call_eq
  function: CodeType.__qualname__.__len__
  args: []
  expected: 4

invariant types_extra29.CodeType.dict_class_name_len:
  description: "types.CodeType.__dict__.__class__.__name__.__len__() == 12 — class namespace is 'mappingproxy' (length 12)"
  category: dict_type_checks
  kind: python_call_eq
  function: CodeType.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant types_extra29.CodeType.mro_len:
  description: "types.CodeType.__mro__.__len__() == 2 — MRO is (code, object); CodeType directly subclasses object"
  category: mro_lengths
  kind: python_call_eq
  function: CodeType.__mro__.__len__
  args: []
  expected: 2

invariant types_extra29.CodeType.bases0_name_len:
  description: "types.CodeType.__bases__[0].__name__.__len__() == 6 — sole base class is 'object' (length 6)"
  category: base_class_names
  kind: python_call_eq
  function: "CodeType.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# types.__name__.__len__() — standalone invariant
#
# types.__name__ == 'types' (length 5). This anchors the module identity
# string and provides a cross-module comparison point: 'types' (5) vs
# 'operator' (8), 'typing' (6), 'weakref' (7), 'inspect' (7), etc.
# No prior types spec records types.__name__.__len__() as a standalone.
# ---------------------------------------------------------------------------

invariant types_extra29.module_name_len:
  description: "types.__name__.__len__() == 5 — module name is 'types' (5 characters)"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 5
