spec: emittery
version: ">=1.0.0"
backend: node(emittery)

docs: https://github.com/sindresorhus/emittery#readme

provenance:
  derived_from:
    - "Emittery README — https://github.com/sindresorhus/emittery#readme"
    - "Test vectors verified with emittery via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "emittery source"
  notes:
    - "Async event emitter for Node — alternative to EventEmitter with promise-based API."
    - "Install: npm install emittery"
    - "v1 ESM only; default export is the Emittery class."
    - "Spec covers shape — actual emit/listen flow needs JS function arguments which can't be threaded through JSON."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Constructor never throws on valid options."
  stderr: "null"
  stickiness: "N/A — each emitter independent."
  codes: {}

invariant emittery.has_emit_method:
  description: "Emittery instance has .emit"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: []
  chain:
    - {get: "emit.constructor.name"}
  expected: "AsyncFunction"

invariant emittery.has_on_method:
  description: "Emittery instance has .on"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: []
  chain:
    - {get: "on.constructor.name"}
  expected: "Function"

invariant emittery.has_off_method:
  description: "Emittery instance has .off"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: []
  chain:
    - {get: "off.constructor.name"}
  expected: "Function"

invariant emittery.has_once_method:
  description: "Emittery instance has .once"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: []
  chain:
    - {get: "once.constructor.name"}
  expected: "Function"

invariant emittery.has_clearListeners_method:
  description: "Emittery instance has .clearListeners"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: []
  chain:
    - {get: "clearListeners.constructor.name"}
  expected: "Function"

invariant emittery.listenerAdded_is_symbol:
  description: "Emittery.listenerAdded is a Symbol (used as event name)"
  category: symbols
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.listenerAdded.constructor.name"}
  expected: "Symbol"

invariant emittery.listenerRemoved_is_symbol:
  description: "Emittery.listenerRemoved is a Symbol"
  category: symbols
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.listenerRemoved.constructor.name"}
  expected: "Symbol"

invariant emittery.isDebugEnabled_default_false:
  description: "Emittery.isDebugEnabled defaults to false"
  category: debug
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.isDebugEnabled"}
  expected: false

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:36:18Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
