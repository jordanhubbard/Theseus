spec: struct_extra1771
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python struct documentation — https://docs.python.org/3/library/struct.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl — covers pack/unpack/calcsize vectors and roundtrip invariants"
    - "struct_extra.zspec.zsdl — covers additional struct format and error checks"
  notes:
    - "Wave 565 (_extra1771): async protocol dict-presence checks."
    - "Theme: which struct stdlib types define __aenter__, __aexit__, __aiter__, __anext__, __await__ in their own __dict__."
    - "struct.Struct: a compiled format-string object caching pack/unpack operations. Purely synchronous C-level type -> all False."
    - "Rationale: struct.Struct implements the binary packing protocol (pack, unpack, pack_into, unpack_from, iter_unpack, size, format), not the async protocol."
    - "Complementary checks confirm that Struct defines 'size' and 'format' as descriptors in its own __dict__."
    - "struct.Struct.__dict__.__contains__('size') -> True — size is a C-level descriptor defined on Struct."
    - "struct.Struct.__dict__.__contains__('format') -> True — format is a C-level descriptor defined on Struct."
    - "struct.calcsize.__class__.__name__ -> 'builtin_function_or_method' — calcsize is a C function."
    - "struct.pack.__class__.__name__ -> 'builtin_function_or_method' — pack is a C function."
    - "struct.unpack.__class__.__name__ -> 'builtin_function_or_method' — unpack is a C function."
    - "All expected values verified by running Python 3.14 struct module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: async protocol dict-presence checks for struct.Struct
#
# Wave 565 theme: which struct types define __aenter__, __aexit__,
# __aiter__, __anext__, __await__ in their own __dict__.
#
# struct.Struct: a compiled binary format-string type implemented in C.
# It provides pack, unpack, pack_into, unpack_from, iter_unpack, size,
# and format. It does not implement any async protocol -> all False.
# ---------------------------------------------------------------------------

table struct_extra1771.async_protocol:
  description: "struct.Struct async protocol dict-presence checks — all False — wave 565 _extra1771"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1771

  columns: [id, function, args, expected]
  rows:
    - ["st1771001", "struct.Struct.__dict__.__contains__", ["__aenter__"], false]
    - ["st1771002", "struct.Struct.__dict__.__contains__", ["__aexit__"],  false]
    - ["st1771003", "struct.Struct.__dict__.__contains__", ["__aiter__"],  false]
    - ["st1771004", "struct.Struct.__dict__.__contains__", ["__anext__"],  false]
    - ["st1771005", "struct.Struct.__dict__.__contains__", ["__await__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for struct module
#
# The async theme is all-False for struct.Struct. Complementary checks
# confirm genuine struct-specific structural properties:
# - Struct.__dict__ contains 'size', 'format', 'pack', 'unpack',
#   'pack_into', 'unpack_from', 'iter_unpack' (all defined on Struct)
# - struct module-level functions are builtin_function_or_method (C-level)
# ---------------------------------------------------------------------------

table struct_extra1771.complementary_checks:
  description: "struct.Struct and module-level function structural property checks — wave 565 _extra1771"
  kind: python_call_eq
  category: complementary
  id_prefix: st1771

  columns: [id, function, args, expected]
  rows:
    - ["st1771006", "struct.Struct.__dict__.__contains__",                    ["size"],                         true]
    - ["st1771007", "struct.Struct.__dict__.__contains__",                    ["format"],                       true]
    - ["st1771008", "struct.Struct.__dict__.__contains__",                    ["pack"],                         true]
    - ["st1771009", "struct.Struct.__dict__.__contains__",                    ["unpack"],                       true]
    - ["st1771010", "struct.Struct.__dict__.__contains__",                    ["pack_into"],                    true]
    - ["st1771011", "struct.Struct.__dict__.__contains__",                    ["unpack_from"],                  true]
    - ["st1771012", "struct.Struct.__dict__.__contains__",                    ["iter_unpack"],                  true]
    - ["st1771013", "struct.calcsize.__class__.__name__.__eq__",              ["builtin_function_or_method"],   true]
    - ["st1771014", "struct.pack.__class__.__name__.__eq__",                  ["builtin_function_or_method"],   true]
    - ["st1771015", "struct.unpack.__class__.__name__.__eq__",                ["builtin_function_or_method"],   true]
