spec: os_extra30
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "os_extra8.zspec.zsdl — covers __qualname__ equality for getpid/getuid/getcwd/listdir/makedirs/getenv/strerror in a table; urandom/cpu_count standalone"
    - "os_extra18.zspec.zsdl — covers stat/getuid/getgid/getenv __qualname__ as standalone invariants"
    - "os_extra27.zspec.zsdl — covers __qualname__ equality table for getcwd/listdir/makedirs/remove/rename/mkdir/rmdir/stat/walk; qualname length standalone invariants for getcwd/listdir/makedirs/remove/walk/rename"
    - "os_extra28.zspec.zsdl — covers getenv/mkdir/rmdir/stat __qualname__ equality table and length standalone invariants"
    - "os_extra29.zspec.zsdl — covers getppid qualname equality and qualname length invariants for getpid/getppid/getuid/cpu_count/putenv/urandom"
  notes:
    - "This spec extends os.zspec.zsdl and all prior os_extra specs through os_extra29.zspec.zsdl."
    - "Focus: standalone __qualname__ equality invariants for getcwd, listdir, makedirs, remove, rename, mkdir, and getpid."
    - "os_extra27 covers these in a table but provides no standalone equality invariants for getcwd/listdir/makedirs/remove/rename/mkdir."
    - "os_extra8 covers getpid in a table but provides no standalone equality invariant for getpid.__qualname__."
    - "os.getcwd.__qualname__ == 'getcwd' — standalone invariant not previously written."
    - "os.listdir.__qualname__ == 'listdir' — standalone invariant not previously written."
    - "os.makedirs.__qualname__ == 'makedirs' — standalone invariant not previously written."
    - "os.remove.__qualname__ == 'remove' — standalone invariant not previously written."
    - "os.rename.__qualname__ == 'rename' — standalone invariant not previously written."
    - "os.mkdir.__qualname__ == 'mkdir' — standalone invariant not previously written."
    - "os.getpid.__qualname__ == 'getpid' — standalone invariant not previously written."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ equality table — getcwd, listdir, makedirs, remove, rename,
# mkdir, getpid
#
# os_extra27 covers getcwd/listdir/makedirs/remove/rename/mkdir in a table but
# does not provide standalone equality invariants. os_extra8 covers getpid in a
# table but not as a standalone invariant. This table groups these seven
# functions as a compact cross-reference in the extra30 namespace, enabling
# the standalone invariants below to cite a shared table anchor.
# ---------------------------------------------------------------------------

table os_extra30.function_qualnames:
  description: "__qualname__ equality for core os file-system and process functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname30

  columns: [id, function, args, expected]
  rows:
    - [getcwd,   getcwd.__qualname__.__eq__,   ["getcwd"],   true]
    - [listdir,  listdir.__qualname__.__eq__,  ["listdir"],  true]
    - [makedirs, makedirs.__qualname__.__eq__, ["makedirs"], true]
    - [remove,   remove.__qualname__.__eq__,   ["remove"],   true]
    - [rename,   rename.__qualname__.__eq__,   ["rename"],   true]
    - [mkdir,    mkdir.__qualname__.__eq__,    ["mkdir"],    true]
    - [getpid,   getpid.__qualname__.__eq__,   ["getpid"],   true]

# ---------------------------------------------------------------------------
# Standalone __qualname__ equality invariants
#
# Each invariant below is individually addressable and provides a named
# check for one function's qualname equality — complementing the table rows
# above with standalone coverage in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant os_extra30.getcwd.qualname:
  description: "os.getcwd.__qualname__ == 'getcwd' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: getcwd.__qualname__.__eq__
  args: ["getcwd"]
  expected: true

invariant os_extra30.listdir.qualname:
  description: "os.listdir.__qualname__ == 'listdir' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: listdir.__qualname__.__eq__
  args: ["listdir"]
  expected: true

invariant os_extra30.makedirs.qualname:
  description: "os.makedirs.__qualname__ == 'makedirs' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: makedirs.__qualname__.__eq__
  args: ["makedirs"]
  expected: true

invariant os_extra30.remove.qualname:
  description: "os.remove.__qualname__ == 'remove' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: remove.__qualname__.__eq__
  args: ["remove"]
  expected: true

invariant os_extra30.rename.qualname:
  description: "os.rename.__qualname__ == 'rename' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: rename.__qualname__.__eq__
  args: ["rename"]
  expected: true

invariant os_extra30.mkdir.qualname:
  description: "os.mkdir.__qualname__ == 'mkdir' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: mkdir.__qualname__.__eq__
  args: ["mkdir"]
  expected: true

invariant os_extra30.getpid.qualname:
  description: "os.getpid.__qualname__ == 'getpid' — standalone qualname equality invariant"
  category: function_identity
  kind: python_call_eq
  function: getpid.__qualname__.__eq__
  args: ["getpid"]
  expected: true
