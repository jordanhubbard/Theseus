spec: re_extra2056
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "re.Match defines __getitem__ (True) for match[group] subscription syntax (PEP 572 / Python 3.8+)."
    - "re.Match does NOT define __setitem__, __delitem__, or __len__ in its own __dict__."
    - "re.Pattern is a C type from _sre; it does not define __getitem__ or any mapping/sequence protocol."
    - "re.RegexFlag is an IntFlag subclass; it does not define __getitem__, __len__, __getattr__, __setattr__, or __delattr__."
    - "re.error is an exception subclass; no item-access or attribute-hook operators are defined in its own __dict__."
    - "re.Scanner is an internal helper class; it defines none of the item-access or attribute-hook operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __getitem__ — sequence/mapping subscription protocol
# re.Match defines __getitem__ (True); all others False
# ---------------------------------------------------------------------------

table re_extra2056.getitem_protocol:
  description: "re types __getitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2056

  columns: [id, function, args, expected]
  rows:
    - ["re2056001", "re.Match.__dict__.__contains__",     ["__getitem__"], true]
    - ["re2056002", "re.Pattern.__dict__.__contains__",   ["__getitem__"], false]
    - ["re2056003", "re.error.__dict__.__contains__",     ["__getitem__"], false]
    - ["re2056004", "re.RegexFlag.__dict__.__contains__", ["__getitem__"], false]
    - ["re2056029", "re.Scanner.__dict__.__contains__",   ["__getitem__"], false]

