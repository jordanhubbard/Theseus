spec: asyncio_extra1321
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ method class checks for asyncio primitives."
    - "asyncio.Queue.__repr__.__qualname__ == 'Queue.__repr__' — defines its own __repr__."
    - "asyncio.Queue.__repr__.__class__.__name__ == 'function' — defined as a Python function."
    - "asyncio.Queue.__str__.__class__.__name__ == 'function' — Queue also defines __str__."
    - "asyncio.Lock.__repr__.__qualname__ == 'Lock.__repr__' and is a Python function."
    - "asyncio.Semaphore.__repr__.__qualname__ == 'Semaphore.__repr__' and is a Python function."
    - "asyncio.Event.__repr__.__qualname__ == 'Event.__repr__' and is a Python function."
    - "asyncio.Task.__repr__.__class__.__name__ == 'wrapper_descriptor' — C-level slot."
    - "asyncio.Future.__repr__.__class__.__name__ == 'wrapper_descriptor' — C-level slot."
    - "asyncio.Task.__str__ and asyncio.Future.__str__ inherit from object — wrapper_descriptor."
    - "repr(asyncio.Queue).__class__.__name__ == 'str' — repr of class object is always str."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra1321.repr_qualnames:
  description: "asyncio primitive classes that define their own __repr__: qualname identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: as1321rq
  columns: [id, function, args, expected]
  rows:
    - [as1321rq001, asyncio.Queue.__repr__.__qualname__.__eq__,     ["Queue.__repr__"],     true]
    - [as1321rq002, asyncio.Lock.__repr__.__qualname__.__eq__,      ["Lock.__repr__"],      true]
    - [as1321rq003, asyncio.Semaphore.__repr__.__qualname__.__eq__, ["Semaphore.__repr__"], true]
    - [as1321rq004, asyncio.Event.__repr__.__qualname__.__eq__,     ["Event.__repr__"],     true]
    - [as1321rq005, asyncio.Task.__repr__.__qualname__.__eq__,      ["Task.__repr__"],      true]
    - [as1321rq006, asyncio.Future.__repr__.__qualname__.__eq__,    ["Future.__repr__"],    true]

table asyncio_extra1321.repr_class_names:
  description: "asyncio primitive __repr__ method class checks: Python function vs C wrapper_descriptor"
  kind: python_call_eq
  category: identity
  id_prefix: as1321rc
  columns: [id, function, args, expected]
  rows:
    - [as1321rc001, asyncio.Queue.__repr__.__class__.__name__.__eq__,     ["function"],          true]
    - [as1321rc002, asyncio.Lock.__repr__.__class__.__name__.__eq__,      ["function"],          true]
    - [as1321rc003, asyncio.Semaphore.__repr__.__class__.__name__.__eq__, ["function"],          true]
    - [as1321rc004, asyncio.Event.__repr__.__class__.__name__.__eq__,     ["function"],          true]
    - [as1321rc005, asyncio.Task.__repr__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true]
    - [as1321rc006, asyncio.Future.__repr__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]

table asyncio_extra1321.str_inheritance_and_repr_of_class:
  description: "asyncio primitives: __str__ inheritance from object and repr(cls) is always str"
  kind: python_call_eq
  category: identity
  id_prefix: as1321si
  columns: [id, function, args, expected]
  rows:
    - [as1321si001, asyncio.Lock.__str__.__qualname__.__eq__,              ["object.__str__"],    true]
    - [as1321si002, asyncio.Semaphore.__str__.__qualname__.__eq__,         ["object.__str__"],    true]
    - [as1321si003, asyncio.Event.__str__.__qualname__.__eq__,             ["object.__str__"],    true]
    - [as1321si004, asyncio.Task.__str__.__qualname__.__eq__,              ["object.__str__"],    true]
    - [as1321si005, asyncio.Future.__str__.__qualname__.__eq__,            ["object.__str__"],    true]
    - [as1321si006, asyncio.Lock.__str__.__class__.__name__.__eq__,        ["wrapper_descriptor"], true]
