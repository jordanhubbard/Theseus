spec: functools_extra251
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
    - "functools_extra110.zspec.zsdl — covers __module__ and co_qualname for functools functions"
  notes:
    - "This spec covers functools.lru_cache behavioral contracts: cached function identity and wrapper class."
    - "functools.lru_cache(maxsize=128)(lambda x: x).__class__.__name__ == '_lru_cache_wrapper'. Verified with Python 3.14.3."
    - "functools.lru_cache(maxsize=128)(lambda x: x).__class__.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__name__ == '_lru_cache_wrapper' (len=18). Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "functools.lru_cache.__name__ == 'lru_cache' (len=9). Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__contains__('maxsize') == True. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' (len=9). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools._lru_cache_wrapper class identity contracts
#
# functools._lru_cache_wrapper.__name__ == '_lru_cache_wrapper' (len=18)
# functools._lru_cache_wrapper.__module__ == 'functools'
# functools._lru_cache_wrapper.__bases__[0].__name__ == 'object'
# functools._lru_cache_wrapper.__qualname__ == '_lru_cache_wrapper'
# functools._lru_cache_wrapper.__name__.__len__() == 18
#
# _lru_cache_wrapper is the C-level class used internally by lru_cache.
# New to extra251.
# ---------------------------------------------------------------------------

table functools_extra251.lrucache251b_wrapper_identity:
  description: "functools._lru_cache_wrapper class identity: name, module, bases, qualname; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: lrucache251b

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_name_eq,
       _lru_cache_wrapper.__name__.__eq__,
       ["_lru_cache_wrapper"],
       true,
       "functools._lru_cache_wrapper.__name__.__eq__('_lru_cache_wrapper') == True — _lru_cache_wrapper is the internal C-level class created by lru_cache; __name__ is '_lru_cache_wrapper' (len=18); new to extra251"]
    - [wrapper_name_len_18,
       _lru_cache_wrapper.__name__.__len__,
       [],
       18,
       "functools._lru_cache_wrapper.__name__.__len__() == 18 — '_lru_cache_wrapper' has exactly 18 characters; str.__len__() returns 18; new to extra251"]
    - [wrapper_module_functools,
       _lru_cache_wrapper.__module__.__eq__,
       ["functools"],
       true,
       "functools._lru_cache_wrapper.__module__.__eq__('functools') == True — _lru_cache_wrapper is registered under the functools module; __module__ is 'functools'; new to extra251"]
    - [wrapper_bases0_object,
       "_lru_cache_wrapper.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools._lru_cache_wrapper.__bases__[0].__name__.__eq__('object') == True — _lru_cache_wrapper directly inherits from object; bases[0].__name__ is 'object'; new to extra251"]
    - [wrapper_qualname_eq,
       _lru_cache_wrapper.__qualname__.__eq__,
       ["_lru_cache_wrapper"],
       true,
       "functools._lru_cache_wrapper.__qualname__.__eq__('_lru_cache_wrapper') == True — __qualname__ equals __name__ for a top-level class; '_lru_cache_wrapper'; new to extra251"]

# ---------------------------------------------------------------------------
# Table 2: functools.lru_cache function identity contracts
#
# functools.lru_cache.__name__ == 'lru_cache' (len=9)
# functools.lru_cache.__module__ == 'functools'
# functools.lru_cache.__qualname__ == 'lru_cache' (len=9)
# functools.lru_cache.__qualname__.__len__() == 9
# functools.lru_cache.__name__.__len__() == 9
#
# lru_cache is a pure-Python decorator factory in Lib/functools.py. New to extra251.
# ---------------------------------------------------------------------------

table functools_extra251.lrucache251b_lrucache_identity:
  description: "functools.lru_cache function identity: name, module, qualname, lengths; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: lrucache251bfn

  columns: [id, function, args, expected, description]
  rows:
    - [lrucache_name_eq,
       lru_cache.__name__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache is a pure-Python decorator factory in Lib/functools.py; __name__ is 'lru_cache' (len=9); new to extra251"]
    - [lrucache_name_len_9,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has exactly 9 characters; str.__len__() returns 9; new to extra251"]
    - [lrucache_module_functools,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in Lib/functools.py; __module__ is 'functools'; new to extra251"]
    - [lrucache_qualname_eq,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — __qualname__ equals __name__ for top-level function; 'lru_cache' (len=9); new to extra251"]
    - [lrucache_qualname_len_9,
       lru_cache.__qualname__.__len__,
       [],
       9,
       "functools.lru_cache.__qualname__.__len__() == 9 — 'lru_cache' has exactly 9 characters; str.__len__() returns 9; new to extra251"]

# ---------------------------------------------------------------------------
# Table 3: functools.lru_cache __doc__ content contracts
#
# functools.lru_cache.__doc__.__contains__('maxsize') == True
# functools.lru_cache.__doc__.__contains__('lru') == True
# functools.lru_cache.__name__.__contains__('cache') == True
# functools.lru_cache.__name__.__contains__('lru') == True
# functools._lru_cache_wrapper.__name__.__contains__('cache') == True
#
# New to extra251.
# ---------------------------------------------------------------------------

table functools_extra251.lrucache251b_doc_content:
  description: "functools.lru_cache __doc__ and __name__ content checks; new to extra251"
  kind: python_call_eq
  category: string_identity
  id_prefix: lrucache251bdoc

  columns: [id, function, args, expected, description]
  rows:
    - [lrucache_doc_contains_maxsize,
       lru_cache.__doc__.__contains__,
       ["maxsize"],
       true,
       "functools.lru_cache.__doc__.__contains__('maxsize') == True — the docstring for lru_cache documents the maxsize parameter; str.__contains__('maxsize') returns True; new to extra251"]
    - [lrucache_doc_contains_lru,
       lru_cache.__doc__.__contains__,
       ["lru"],
       true,
       "functools.lru_cache.__doc__.__contains__('lru') == True — the docstring for lru_cache mentions 'lru' (least recently used); str.__contains__('lru') returns True; new to extra251"]
    - [lrucache_name_contains_cache,
       lru_cache.__name__.__contains__,
       ["cache"],
       true,
       "functools.lru_cache.__name__.__contains__('cache') == True — 'lru_cache' contains 'cache'; new to extra251"]
    - [lrucache_name_contains_lru,
       lru_cache.__name__.__contains__,
       ["lru"],
       true,
       "functools.lru_cache.__name__.__contains__('lru') == True — 'lru_cache' contains 'lru'; new to extra251"]
    - [wrapper_name_contains_cache,
       _lru_cache_wrapper.__name__.__contains__,
       ["cache"],
       true,
       "functools._lru_cache_wrapper.__name__.__contains__('cache') == True — '_lru_cache_wrapper' contains 'cache'; new to extra251"]

# ---------------------------------------------------------------------------
# Table 4: functools._lru_cache_wrapper class extra checks
#
# functools._lru_cache_wrapper.__bases__[0].__module__ == 'builtins'
# functools._lru_cache_wrapper.__class__.__name__ == 'type'
# functools._lru_cache_wrapper.__name__.__contains__('wrapper') == True
# functools._lru_cache_wrapper.__name__.__contains__('lru') == True
# functools._lru_cache_wrapper.__module__.__len__() == 9
#
# New to extra251.
# ---------------------------------------------------------------------------

table functools_extra251.lrucache251b_wrapper_extra:
  description: "functools._lru_cache_wrapper extra class checks: bases module, class type, name content; new to extra251"
  kind: python_call_eq
  category: identity
  id_prefix: lrucache251bx

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_bases0_module_builtins,
       "_lru_cache_wrapper.__bases__[0].__module__.__eq__",
       ["builtins"],
       true,
       "functools._lru_cache_wrapper.__bases__[0].__module__.__eq__('builtins') == True — object is defined in builtins; bases[0].__module__ is 'builtins'; new to extra251"]
    - [wrapper_class_is_type,
       _lru_cache_wrapper.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools._lru_cache_wrapper.__class__.__name__.__eq__('type') == True — _lru_cache_wrapper is a class, so __class__ is 'type'; new to extra251"]
    - [wrapper_name_contains_wrapper,
       _lru_cache_wrapper.__name__.__contains__,
       ["wrapper"],
       true,
       "functools._lru_cache_wrapper.__name__.__contains__('wrapper') == True — '_lru_cache_wrapper' contains 'wrapper'; new to extra251"]
    - [wrapper_name_contains_lru,
       _lru_cache_wrapper.__name__.__contains__,
       ["lru"],
       true,
       "functools._lru_cache_wrapper.__name__.__contains__('lru') == True — '_lru_cache_wrapper' contains 'lru'; new to extra251"]
    - [wrapper_module_len_9,
       _lru_cache_wrapper.__module__.__len__,
       [],
       9,
       "functools._lru_cache_wrapper.__module__.__len__() == 9 — 'functools' has exactly 9 characters; str.__len__() returns 9; new to extra251"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra251
# ---------------------------------------------------------------------------

invariant functools_extra251.wrapper_name_eq:
  description: "functools._lru_cache_wrapper.__name__ == '_lru_cache_wrapper' (len=18); new to extra251"
  kind: python_call_eq
  function: _lru_cache_wrapper.__name__.__eq__
  args: ["_lru_cache_wrapper"]
  expected: true

invariant functools_extra251.wrapper_module_functools:
  description: "functools._lru_cache_wrapper.__module__ == 'functools'; new to extra251"
  kind: python_call_eq
  function: _lru_cache_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra251.wrapper_bases0_object:
  description: "functools._lru_cache_wrapper.__bases__[0].__name__ == 'object'; new to extra251"
  kind: python_call_eq
  function: "_lru_cache_wrapper.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra251.lrucache_name_len_9:
  description: "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters; new to extra251"
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9

invariant functools_extra251.lrucache_doc_contains_maxsize:
  description: "functools.lru_cache.__doc__.__contains__('maxsize') == True — docstring documents maxsize param; new to extra251"
  kind: python_call_eq
  function: lru_cache.__doc__.__contains__
  args: ["maxsize"]
  expected: true

invariant functools_extra251.wrapper_name_len_18:
  description: "functools._lru_cache_wrapper.__name__.__len__() == 18 — '_lru_cache_wrapper' has 18 characters; new to extra251"
  kind: python_call_eq
  function: _lru_cache_wrapper.__name__.__len__
  args: []
  expected: 18

invariant functools_extra251.wrapper_class_is_type:
  description: "functools._lru_cache_wrapper.__class__.__name__ == 'type' — _lru_cache_wrapper is a class; new to extra251"
  kind: python_call_eq
  function: _lru_cache_wrapper.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra251.lrucache_module_functools:
  description: "functools.lru_cache.__module__ == 'functools' — pure-Python function in Lib/functools.py; new to extra251"
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true
