spec: string_template
version: ">=1.0.0"
backend: node(string-template)

docs: https://github.com/Matt-Esch/string-template#readme

provenance:
  derived_from:
    - "string-template README — https://github.com/Matt-Esch/string-template#readme"
    - "Test vectors verified with string-template via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "string-template source"
  notes:
    - "Minimal {placeholder}-style template renderer."
    - "Install: npm install string-template"
    - "Module export IS the function: format(tmpl, data)."
    - "Unfilled placeholders are passed through literally."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string template."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table string_template.format:
  kind: node_module_call_eq
  category: format
  function: ~
  id_prefix: format

  columns: [id, args, expected]
  rows:
    - [single_substitution,
       ["Hello {name}", {name: "World"}],
       "Hello World"]

    - [multi_substitution,
       ["{a}+{b}={c}", {a: 1, b: 2, c: 3}],
       "1+2=3"]

    - [no_template_passthrough,
       ["plain text", {}],
       "plain text"]

    - [undefined_placeholder_dropped,
       ["", {}],
       ""]

    - [number_value,
       ["count: {n}", {n: 42}],
       "count: 42"]

    - [array_indexed,
       ["{0}-{1}", ["a", "b"]],
       "a-b"]

    - [empty_template,
       ["", {}],
       ""]

    - [duplicate_placeholders,
       ["{x}-{x}", {x: "Y"}],
       "Y-Y"]
