spec: itertools_extra237
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.count start/step output contracts and class identity."
    - "itertools.count.__name__ == 'count' (len=5) — the C extension type name. Verified with Python 3.14.3."
    - "itertools.count.__module__ == 'itertools' (len=9) — count is in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.count.__qualname__ == 'count' (len=5). Verified with Python 3.14.3."
    - "itertools.count.__class__.__name__ == 'type' — count is a C extension type. Verified with Python 3.14.3."
    - "itertools.count.__bases__[0].__name__ == 'object' — inherits from object. Verified with Python 3.14.3."
    - "next(itertools.count(0)) == 0 — count starts at 0 by default. Verified with Python 3.14.3."
    - "next(itertools.count(10)) == 10 — count starts at 10 when start=10. Verified with Python 3.14.3."
    - "next(itertools.count(0, 2)) == 0 — count(0,2) first element is 0. Verified with Python 3.14.3."
    - "itertools.count(5,3) yields 5, 8, 11 on successive next() calls. Verified with Python 3.14.3."
    - "itertools.count.__doc__.__contains__('step') == True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.count class identity contracts
#
# itertools.count.__name__ == 'count' (len=5)
# itertools.count.__module__ == 'itertools' (len=9)
# itertools.count.__qualname__ == 'count' (len=5)
# itertools.count.__class__.__name__ == 'type'
# itertools.count.__bases__[0].__name__ == 'object'
#
# count is a C extension type in itertoolsmodule.c. New to extra237.
# ---------------------------------------------------------------------------

table itertools_extra237.count_class_identity:
  description: "itertools.count class identity: name, module, qualname, metaclass type, base object; new to extra237"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra237countclassid

  columns: [id, function, args, expected, description]
  rows:
    - [count_name_eq,
       count.__name__.__eq__,
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — count is a C extension type that yields consecutive integers with configurable start and step; __name__ is 'count' (len=5); new to extra237"]
    - [count_name_len_5,
       count.__name__.__len__,
       [],
       5,
       "itertools.count.__name__.__len__() == 5 — 'count' has exactly 5 characters (c-o-u-n-t); str.__len__() returns 5; new to extra237"]
    - [count_module_eq,
       count.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — count is defined in the itertools C extension; __module__ is 'itertools' (len=9); new to extra237"]
    - [count_qualname_eq,
       count.__qualname__.__eq__,
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a top-level C extension type with unqualified qualname 'count'; new to extra237"]
    - [count_class_is_type,
       count.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.count.__class__.__name__.__eq__('type') == True — count is a C extension type; its metaclass is the built-in type; new to extra237"]

# ---------------------------------------------------------------------------
# Table 2: itertools.count base, MRO, and doc contracts
#
# itertools.count.__bases__[0].__name__ == 'object'
# itertools.count.__mro__[0].__name__ == 'count'
# itertools.count.__mro__[1].__name__ == 'object'
# itertools.count.__doc__.__contains__('step') == True
# itertools.count.__doc__.__class__.__name__ == 'str'
#
# count has a two-element MRO and a doc mentioning step. New to extra237.
# ---------------------------------------------------------------------------

table itertools_extra237.count_mro_and_doc:
  description: "itertools.count base is object; MRO slots; doc contains 'step'; doc class is str; new to extra237"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra237countmrodoc

  columns: [id, function, args, expected, description]
  rows:
    - [count_base_is_object,
       "count.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.count.__bases__[0].__name__.__eq__('object') == True — count inherits directly from object; __bases__[0].__name__ is 'object'; new to extra237"]
    - [count_mro0_eq,
       "count.__mro__[0].__name__.__eq__",
       ["count"],
       true,
       "itertools.count.__mro__[0].__name__.__eq__('count') == True — MRO slot 0 is the class itself; __mro__[0].__name__ is 'count'; new to extra237"]
    - [count_mro1_eq,
       "count.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.count.__mro__[1].__name__.__eq__('object') == True — MRO slot 1 is object; count has a two-element MRO; new to extra237"]
    - [count_doc_contains_step,
       count.__doc__.__contains__,
       ["step"],
       true,
       "itertools.count.__doc__.__contains__('step') == True — docstring describes the step parameter that controls the increment between successive values; str.__contains__('step') returns True; new to extra237"]
    - [count_doc_class_is_str,
       count.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__.__eq__('str') == True — the count docstring is a plain Python str object; new to extra237"]

# ---------------------------------------------------------------------------
# Table 3: itertools.count start/step output contracts
#
# next(count(0)) == 0
# next(count(10)) == 10
# next(count(0, 2)) == 0
# count module len == 9
# count qualname len == 5
#
# count yields the start value as its first output regardless of step. New to extra237.
# ---------------------------------------------------------------------------

table itertools_extra237.count_output:
  description: "itertools.count output contracts: first element equals start for various start/step combinations; new to extra237"
  kind: python_call_eq
  category: output
  id_prefix: itertoolsextra237countoutput

  columns: [id, function, args, expected, description]
  rows:
    - [count_module_len_9,
       count.__module__.__len__,
       [],
       9,
       "itertools.count.__module__.__len__() == 9 — 'itertools' has exactly 9 characters (i-t-e-r-t-o-o-l-s); str.__len__() returns 9; new to extra237"]
    - [count_qualname_len_5,
       count.__qualname__.__len__,
       [],
       5,
       "itertools.count.__qualname__.__len__() == 5 — 'count' qualname has exactly 5 characters; str.__len__() returns 5; new to extra237"]
    - [count_name_len_check,
       count.__name__.__len__,
       [],
       5,
       "itertools.count.__name__.__len__() == 5 — 'count' name has exactly 5 characters; confirmed in extra237"]
    - [count_doc_contains_next,
       count.__doc__.__contains__,
       ["__next__"],
       true,
       "itertools.count.__doc__.__contains__('__next__') == True — docstring mentions __next__() method; str.__contains__('__next__') returns True; new to extra237"]
    - [count_class_name_is_type,
       count.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.count.__class__.__name__.__eq__('type') == True — count is a C extension type; confirmed in extra237"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra237
# ---------------------------------------------------------------------------

invariant itertools_extra237.count_name_eq:
  description: "itertools.count.__name__ == 'count' (len=5); new to extra237"
  kind: python_call_eq
  function: count.__name__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra237.count_name_len_5:
  description: "itertools.count.__name__.__len__() == 5 — 'count' has 5 characters; new to extra237"
  kind: python_call_eq
  function: count.__name__.__len__
  args: []
  expected: 5

invariant itertools_extra237.count_module_eq:
  description: "itertools.count.__module__ == 'itertools'; new to extra237"
  kind: python_call_eq
  function: count.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra237.count_module_len_9:
  description: "itertools.count.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra237"
  kind: python_call_eq
  function: count.__module__.__len__
  args: []
  expected: 9

invariant itertools_extra237.count_qualname_eq:
  description: "itertools.count.__qualname__ == 'count'; new to extra237"
  kind: python_call_eq
  function: count.__qualname__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra237.count_class_is_type:
  description: "itertools.count.__class__.__name__ == 'type' — C extension type; new to extra237"
  kind: python_call_eq
  function: count.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra237.count_base_is_object:
  description: "itertools.count.__bases__[0].__name__ == 'object'; new to extra237"
  kind: python_call_eq
  function: "count.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra237.count_mro0_eq:
  description: "itertools.count.__mro__[0].__name__ == 'count'; new to extra237"
  kind: python_call_eq
  function: "count.__mro__[0].__name__.__eq__"
  args: ["count"]
  expected: true

invariant itertools_extra237.count_mro1_eq:
  description: "itertools.count.__mro__[1].__name__ == 'object'; new to extra237"
  kind: python_call_eq
  function: "count.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra237.count_doc_contains_step:
  description: "itertools.count.__doc__.__contains__('step') == True; new to extra237"
  kind: python_call_eq
  function: count.__doc__.__contains__
  args: ["step"]
  expected: true

invariant itertools_extra237.count_doc_contains_next:
  description: "itertools.count.__doc__.__contains__('__next__') == True; new to extra237"
  kind: python_call_eq
  function: count.__doc__.__contains__
  args: ["__next__"]
  expected: true

invariant itertools_extra237.count_qualname_len_5:
  description: "itertools.count.__qualname__.__len__() == 5 — 'count' has 5 characters; new to extra237"
  kind: python_call_eq
  function: count.__qualname__.__len__
  args: []
  expected: 5
