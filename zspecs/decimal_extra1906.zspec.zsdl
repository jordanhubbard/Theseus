    - ["dc1906027", "decimal.Inexact.__qualname__", [], "Inexact"]
    - ["dc1906028", "decimal.Decimal.__module__", [], "decimal"]
    - ["dc1906029", "decimal.Context.__module__", [], "decimal"]
    - ["dc1906030", "decimal.DecimalException.__module__", [], "decimal"]
