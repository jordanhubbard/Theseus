  columns: [id, function, args, expected]
  rows:
    - ["dc1906011", "decimal.Decimal.__dict__.__contains__", ["__match_args__"], false]
    - ["dc1906012", "decimal.Context.__dict__.__contains__", ["__match_args__"], false]
    - ["dc1906013", "decimal.DecimalException.__dict__.__contains__", ["__match_args__"], false]
    - ["dc1906014", "decimal.InvalidOperation.__dict__.__contains__", ["__match_args__"], false]
    - ["dc1906015", "decimal.DivisionByZero.__dict__.__contains__", ["__match_args__"], false]
    - ["dc1906016", "decimal.Overflow.__dict__.__contains__", ["__match_args__"], false]
    - ["dc1906017", "decimal.Inexact.__dict__.__contains__", ["__match_args__"], false]
    - ["dc1906018", "decimal.Decimal.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["dc1906019", "decimal.Context.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["dc1906020", "decimal.Decimal.__dict__.__contains__", ["__type_params__"], false]

