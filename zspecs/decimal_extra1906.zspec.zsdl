spec: decimal_extra1906
version: ">=3.9"
backend: python_module(decimal)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "decimal.Decimal and decimal.Context are C-level types in the _decimal module; __module__ == 'decimal'."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.DivisionByZero, decimal.Overflow, decimal.Underflow, decimal.Inexact are Python exception classes."
    - "None of these decimal types define __reversed__, __missing__, or __match_args__ in their __dict__."
    - "None define __abstractmethods__ or __type_params__ in their own __dict__."
    - "decimal.Decimal.__qualname__ == 'Decimal' — C-level type, top-level qualname."
    - "decimal.Context.__qualname__ == 'Context' — C-level type, top-level qualname."
    - "decimal.DecimalException.__qualname__ == 'DecimalException' — Python exception class."
    - "decimal.InvalidOperation.__qualname__ == 'InvalidOperation' — Python exception class."
    - "decimal.DivisionByZero.__qualname__ == 'DivisionByZero' — Python exception class."
    - "decimal.Overflow.__qualname__ == 'Overflow' — Python exception class."
    - "decimal.Inexact.__qualname__ == 'Inexact' — Python exception class."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table decimal_extra1906.reversed_protocol:
  description: "decimal types __reversed__ dict-presence checks"
  kind: python_call_eq
  category: reversed_protocol
  id_prefix: dc1906

  columns: [id, function, args, expected]
  rows:
    - ["dc1906001", "decimal.Decimal.__dict__.__contains__", ["__reversed__"], false]
    - ["dc1906002", "decimal.Context.__dict__.__contains__", ["__reversed__"], false]
    - ["dc1906003", "decimal.DecimalException.__dict__.__contains__", ["__reversed__"], false]
    - ["dc1906004", "decimal.InvalidOperation.__dict__.__contains__", ["__reversed__"], false]
    - ["dc1906005", "decimal.DivisionByZero.__dict__.__contains__", ["__reversed__"], false]
    - ["dc1906006", "decimal.Overflow.__dict__.__contains__", ["__reversed__"], false]
    - ["dc1906007", "decimal.Inexact.__dict__.__contains__", ["__reversed__"], false]
    - ["dc1906008", "decimal.Decimal.__dict__.__contains__", ["__missing__"], false]
    - ["dc1906009", "decimal.Context.__dict__.__contains__", ["__missing__"], false]
    - ["dc1906010", "decimal.DecimalException.__dict__.__contains__", ["__missing__"], false]

