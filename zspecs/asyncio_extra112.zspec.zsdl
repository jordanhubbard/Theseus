spec: asyncio_extra112
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio_extra111.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio.Queue __init__ code attributes and asyncio.Queue method code attributes (put, get, task_done, join, put_nowait, get_nowait, qsize co_argcounts). NEW in extra112: asyncio.Queue.__init__.__code__.co_name=='__init__' (co_argcount=2: self and maxsize); asyncio.Queue.put.__code__.co_name=='put' (co_argcount=2: self and item); asyncio.Queue.get.__code__.co_name=='get' (co_argcount=1: self only); asyncio.Queue.task_done.__code__.co_name=='task_done' (co_argcount=1: self only); asyncio.Queue.join.__code__.co_name=='join' (co_argcount=1: self only); asyncio.Queue.put_nowait.__code__.co_name=='put_nowait' (co_argcount=2: self and item); asyncio.Queue.get_nowait.__code__.co_name=='get_nowait' (co_argcount=1: self only); asyncio.Queue.qsize.__code__.co_name=='qsize' (co_argcount=1: self only). asyncio.Queue.__name__=='Queue' (len=5); asyncio.Queue.__module__=='asyncio.queues'; asyncio.Queue.__mro__.__len__()==3 ([Queue, _LoopBoundMixin, object]); asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__init__.__code__.co_name == '__init__' (co_argcount=2: self and maxsize — maxsize is the max number of items allowed in the queue, 0 means unlimited). asyncio.Queue.put.__code__.co_name == 'put' (co_argcount=2: self and item — put() is a coroutine that blocks when the queue is full). asyncio.Queue.get.__code__.co_name == 'get' (co_argcount=1: self only — get() is a coroutine that blocks when the queue is empty). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.task_done.__code__.co_name == 'task_done' (co_argcount=1: self only — signals one item has been processed). asyncio.Queue.join.__code__.co_name == 'join' (co_argcount=1: self only — blocks until all items have been processed via task_done). asyncio.Queue.put_nowait.__code__.co_name == 'put_nowait' (co_argcount=2: self and item — non-blocking, raises QueueFull when full). asyncio.Queue.get_nowait.__code__.co_name == 'get_nowait' (co_argcount=1: self only — non-blocking, raises QueueEmpty when empty). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue __init__ and put/get method code attributes — extra112
#
# Wave 254 theme: Queue __init__ and core put/get method co_name and co_argcount.
#
# asyncio.Queue.__init__.__code__.co_name    == '__init__'   (co_argcount=2: self and maxsize)
# asyncio.Queue.put.__code__.co_name         == 'put'        (co_argcount=2: self and item)
# asyncio.Queue.get.__code__.co_name         == 'get'        (co_argcount=1: self only)
# asyncio.Queue.__qualname__                 == 'Queue'      (len=5)
# asyncio.Queue.__module__                   == 'asyncio.queues'
# asyncio.Queue.__mro__.__len__()            == 3
# ---------------------------------------------------------------------------

table asyncio_extra112.asyncio_queue_init_put_get_attrs:
  description: "asyncio.Queue __init__, put, and get method code attribute checks in asyncioqueue112 namespace — wave 254 theme: asyncio.Queue.__init__.__code__.co_name.__eq__('__init__')==True (the code object name matches the function name; co_argcount=2: self and maxsize — maxsize controls the queue capacity, 0=unlimited); type(asyncio.Queue.__init__).__name__.__eq__('function')==True (Python-defined); asyncio.Queue.__init__.__code__.co_argcount==2 (self and maxsize); asyncio.Queue.put.__code__.co_name.__eq__('put')==True (co_argcount=2: self and item — put() is a coroutine that waits when queue is full); type(asyncio.Queue.put).__name__.__eq__('function')==True; asyncio.Queue.put.__code__.co_argcount==2 (self and item); asyncio.Queue.get.__code__.co_name.__eq__('get')==True (co_argcount=1: self only — get() is a coroutine that waits when queue is empty); type(asyncio.Queue.get).__name__.__eq__('function')==True; asyncio.Queue.get.__code__.co_argcount==1 (self only); asyncio.Queue.__name__.__eq__('Queue')==True (len=5); asyncio.Queue.__module__.__eq__('asyncio.queues')==True; asyncio.Queue.__qualname__.__eq__('Queue')==True (len=5); asyncio.Queue.__mro__.__len__()==3 ([Queue, _LoopBoundMixin, object]); compare co_argcount: __init__=put=2 (both take extra arg) vs get=1 (self only); compare co_name lengths: 'get'=3 (shortest) < 'put'=3 (tied with get) < '__init__'=8 (longest in table); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: asyncioqueue112

  columns: [id, function, args, expected, description]
  rows:
    - [init_co_name_eq,    asyncio.Queue.__init__.__code__.co_name.__eq__,              ["__init__"],           true, "Queue.__init__.__code__.co_name == '__init__' (co_argcount=2); verified with Python 3.14.3"]
    - [init_argc,          asyncio.Queue.__init__.__code__.co_argcount.__eq__,           [2],                    true, "Queue.__init__.__code__.co_argcount == 2 (self and maxsize); verified with Python 3.14.3"]
    - [init_type_eq,       type(asyncio.Queue.__init__).__name__.__eq__,                 ["function"],           true, "type(Queue.__init__).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [put_co_name_eq,     asyncio.Queue.put.__code__.co_name.__eq__,                   ["put"],                 true, "Queue.put.__code__.co_name == 'put' (co_argcount=2: self and item); verified with Python 3.14.3"]
    - [put_argc,           asyncio.Queue.put.__code__.co_argcount.__eq__,                [2],                    true, "Queue.put.__code__.co_argcount == 2 (self and item); verified with Python 3.14.3"]
    - [put_type_eq,        type(asyncio.Queue.put).__name__.__eq__,                      ["function"],           true, "type(Queue.put).__name__ == 'function' (Python-defined coroutine); verified with Python 3.14.3"]
    - [get_co_name_eq,     asyncio.Queue.get.__code__.co_name.__eq__,                   ["get"],                 true, "Queue.get.__code__.co_name == 'get' (co_argcount=1: self only); verified with Python 3.14.3"]
    - [get_argc,           asyncio.Queue.get.__code__.co_argcount.__eq__,                [1],                    true, "Queue.get.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [get_type_eq,        type(asyncio.Queue.get).__name__.__eq__,                      ["function"],           true, "type(Queue.get).__name__ == 'function' (Python-defined coroutine); verified with Python 3.14.3"]
    - [queue_name_eq,      asyncio.Queue.__name__.__eq__,                                ["Queue"],              true, "Queue.__name__ == 'Queue' (len=5); verified with Python 3.14.3"]
    - [queue_module_eq,    asyncio.Queue.__module__.__eq__,                              ["asyncio.queues"],     true, "Queue.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]

