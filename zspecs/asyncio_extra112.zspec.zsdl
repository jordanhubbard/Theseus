invariant asyncio_extra112.Queue_put_co_argcount_2:
  description: "asyncio.Queue.put.__code__.co_argcount == 2 — put takes self and item (item is the object to place in the queue; put() is a coroutine that blocks when the queue is full until a free slot is available); Queue.put.__qualname__=='Queue.put' (len=9); type(asyncio.Queue.put).__name__=='function' (Python-defined coroutine); compare co_argcount: put=2 (takes item) == put_nowait=2 (also takes item) == __init__=2 (takes maxsize); put differs from get (co_argcount=1, self only): the producer takes an item arg, the consumer does not; asyncio.Queue.put is a coroutine awaited in producer tasks; asyncio.Queue.__module__=='asyncio.queues'; asyncio.Queue.__mro__.__len__()==3 ([Queue, _LoopBoundMixin, object]); NEW in extra112: first standalone Queue.put co_argcount invariant in asyncioqueue112 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Queue.put.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant asyncio_extra112.Queue_get_co_argcount_1:
  description: "asyncio.Queue.get.__code__.co_argcount == 1 — get takes self only (get() is a coroutine that blocks when the queue is empty until an item is available; no item argument since it removes and returns from the queue itself); Queue.get.__qualname__=='Queue.get' (len=9); type(asyncio.Queue.get).__name__=='function' (Python-defined coroutine); compare co_argcount: get=1 (self only) vs put=2 (self and item); get=get_nowait=task_done=join=qsize all have co_argcount=1 (self only); asyncio.Queue.get is a coroutine awaited in consumer tasks; asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin'; asyncio.Queue.__module__=='asyncio.queues'; NEW in extra112: first standalone Queue.get co_argcount invariant in asyncioqueue112 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Queue.get.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant asyncio_extra112.Queue_put_nowait_qualname_len_16:
  description: "asyncio.Queue.put_nowait.__qualname__.__len__() == 16 — 'Queue.put_nowait' = 'Queue.'=6 + 'put_nowait'=9 = 15... wait: 'Queue.'=6+'put_nowait'=9=15? No: 'Queue.put_nowait' = Q-u-e-u-e-.-p-u-t-_-n-o-w-a-i-t = 16 chars; verified: len('Queue.put_nowait')==16; tied with Queue.get_nowait=16 (both are the longest method qualnames in spec); compare: put=get=9 (shortest) < join=10 < qsize=11 < __init__=14 < task_done=15 < put_nowait=get_nowait=16 (longest); asyncio.Queue.put_nowait.__code__.co_argcount==2 (self and item — non-blocking put; raises QueueFull if queue is at capacity); asyncio.Queue.put_nowait.__code__.co_name=='put_nowait'; asyncio.Queue.__mro__.__len__()==3; asyncio.Queue.__module__=='asyncio.queues'; NEW in extra112: first standalone Queue.put_nowait qualname length invariant in asyncioqueue112 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Queue.put_nowait.__qualname__.__len__
  args: []
  expected: 16

invariant asyncio_extra112.Queue_task_done_co_name_eq:
  description: "asyncio.Queue.task_done.__code__.co_name.__eq__('task_done') returns True — the code object's co_name matches the function name 'task_done'; Queue.task_done.__code__.co_argcount==1 (self only); Queue.task_done.__qualname__=='Queue.task_done' (len=15); type(asyncio.Queue.task_done).__name__=='function' (Python-defined); task_done() signals that a formerly enqueued item has been processed — it decrements the count of unfinished tasks; calling task_done() more times than items placed in the queue raises ValueError; join() blocks until task_done() has been called for every item; task_done and join form the producer-consumer synchronization pattern in asyncio; asyncio.Queue.join.__code__.co_argcount==1 (self only — join also takes no args beyond self); compare: task_done qualname len=15 > join qualname len=10; NEW in extra112: first standalone Queue.task_done co_name invariant in asyncioqueue112 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Queue.task_done.__code__.co_name.__eq__
  args: ["task_done"]
  expected: true

invariant asyncio_extra112.Queue_mro_len_3:
  description: "asyncio.Queue.__mro__.__len__() == 3 — Queue's MRO is [Queue, _LoopBoundMixin, object] (length=3); asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (Queue's direct base class); asyncio.Queue.__name__=='Queue' (len=5); asyncio.Queue.__qualname__=='Queue' (len=5, same as __name__); asyncio.Queue.__module__=='asyncio.queues'; compare Queue MRO (len=3) to Condition MRO (len=4) from extra111 — Condition has a deeper hierarchy with both _ContextManagerMixin and _LoopBoundMixin; Queue is simpler: it inherits directly from _LoopBoundMixin (only the event-loop binding mixin, no context manager support); asyncio.Queue.__init__.__code__.co_argcount==2 (self and maxsize); asyncio.Queue.put.__code__.co_argcount==2 (self and item); asyncio.Queue.get.__code__.co_argcount==1 (self only); the 3-level MRO [Queue, _LoopBoundMixin, object] reflects Queue as a standalone first-class asyncio primitive; NEW in extra112: first standalone Queue MRO length invariant in asyncioqueue112 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: asyncio.Queue.__mro__.__len__
  args: []
  expected: 3

