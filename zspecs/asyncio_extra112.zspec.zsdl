    - [queue_base_eq,      "asyncio.Queue.__bases__[0].__name__.__eq__",                 ["_LoopBoundMixin"],    true, "Queue.__bases__[0].__name__ == '_LoopBoundMixin'; verified with Python 3.14.3"]
