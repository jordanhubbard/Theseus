    - [pnw_co_name_eq,     asyncio.Queue.put_nowait.__code__.co_name.__eq__,            ["put_nowait"],          true, "Queue.put_nowait.__code__.co_name == 'put_nowait' (co_argcount=2: self and item); verified with Python 3.14.3"]
