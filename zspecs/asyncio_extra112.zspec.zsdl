# asyncio.Queue task_done, join, put_nowait, get_nowait, qsize code attributes — extra112
#
# Wave 254 theme: Queue task_done/join/put_nowait/get_nowait/qsize co_argcounts.
#
# asyncio.Queue.task_done.__code__.co_name  == 'task_done'  (co_argcount=1: self only)
# asyncio.Queue.join.__code__.co_name       == 'join'       (co_argcount=1: self only)
# asyncio.Queue.put_nowait.__code__.co_name == 'put_nowait' (co_argcount=2: self and item)
# asyncio.Queue.get_nowait.__code__.co_name == 'get_nowait' (co_argcount=1: self only)
# asyncio.Queue.qsize.__code__.co_name      == 'qsize'      (co_argcount=1: self only)
# ---------------------------------------------------------------------------

table asyncio_extra112.asyncio_queue_task_join_nowait_qsize_attrs:
  description: "asyncio.Queue task_done, join, put_nowait, get_nowait, qsize method code attribute checks in asyncioqueue112 namespace — wave 254 theme: asyncio.Queue.task_done.__code__.co_name.__eq__('task_done')==True (co_argcount=1: self only — signals that a formerly enqueued task is complete; must be paired with get()); type(asyncio.Queue.task_done).__name__.__eq__('function')==True; asyncio.Queue.task_done.__code__.co_argcount==1 (self only); asyncio.Queue.join.__code__.co_name.__eq__('join')==True (co_argcount=1: self only — blocks until task_done has been called for every item placed in the queue); type(asyncio.Queue.join).__name__.__eq__('function')==True; asyncio.Queue.join.__code__.co_argcount==1 (self only); asyncio.Queue.put_nowait.__code__.co_name.__eq__('put_nowait')==True (co_argcount=2: self and item — non-blocking put, raises QueueFull if queue is full); type(asyncio.Queue.put_nowait).__name__.__eq__('function')==True; asyncio.Queue.put_nowait.__code__.co_argcount==2 (self and item; matches put=2); asyncio.Queue.get_nowait.__code__.co_name.__eq__('get_nowait')==True (co_argcount=1: self only — non-blocking get, raises QueueEmpty if empty; matches get=1); type(asyncio.Queue.get_nowait).__name__.__eq__('function')==True; asyncio.Queue.get_nowait.__code__.co_argcount==1 (self only); asyncio.Queue.qsize.__code__.co_name.__eq__('qsize')==True (co_argcount=1: self only — returns number of items in queue); asyncio.Queue.qsize.__code__.co_argcount==1 (self only); compare co_argcount: put=put_nowait=__init__=2 (all take an item/maxsize arg) vs get=get_nowait=task_done=join=qsize=1 (self only); verified with Python 3.14.3"
