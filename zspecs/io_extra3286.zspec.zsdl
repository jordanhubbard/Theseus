spec: io3286
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 666 (io3286): __iadd__, __isub__, __imul__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __iadd__, __isub__, __imul__ dict-presence (in-place augmented assignment)."
    - "No io class defines __iadd__ in its own __dict__: stream I/O classes are sequential I/O abstractions, not numeric types, and do not implement in-place addition."
    - "No io class defines __isub__ in its own __dict__: stream I/O classes do not implement in-place subtraction; arithmetic is not part of the stream I/O protocol."
    - "No io class defines __imul__ in its own __dict__: stream I/O classes do not implement in-place multiplication; augmented assignment operators have no meaning for I/O streams."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iadd__ dict-presence — operator.contains(Cls.__dict__, '__iadd__')
#
# No io class defines __iadd__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not numeric types,
# and do not implement the in-place addition operator (+=).
# ---------------------------------------------------------------------------

table io3286.iadd:
  description: "io types __iadd__ dict-presence checks; wave 666"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3286

  columns: [id, function, args, expected]
  rows:
    - ["io3286001", operator.contains, [io.RawIOBase.__dict__,       "__iadd__"], false]
    - ["io3286002", operator.contains, [io.BufferedIOBase.__dict__,  "__iadd__"], false]
