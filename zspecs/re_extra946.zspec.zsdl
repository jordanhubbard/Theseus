spec: re_extra946
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module flag and exception documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.RegexFlag enum member class names and re.error exception identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra946.flag_class_names:
  description: "re flag enum member __class__.__name__ identity"
  kind: python_call_eq
  category: flag_class_names
  id_prefix: re946f
  columns: [id, function, args, expected]
  rows:
    - [re946f001, re.IGNORECASE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [re946f002, re.MULTILINE.__class__.__name__.__eq__,  ["RegexFlag"], true]
    - [re946f003, re.DOTALL.__class__.__name__.__eq__,     ["RegexFlag"], true]
    - [re946f004, re.VERBOSE.__class__.__name__.__eq__,    ["RegexFlag"], true]
    - [re946f005, re.ASCII.__class__.__name__.__eq__,      ["RegexFlag"], true]
    - [re946f006, re.UNICODE.__class__.__name__.__eq__,    ["RegexFlag"], true]
    - [re946f007, re.LOCALE.__class__.__name__.__eq__,     ["RegexFlag"], true]

table re_extra946.flag_module_identity:
  description: "re RegexFlag class module identity"
  kind: python_call_eq
  category: flag_module_identity
  id_prefix: re946m
  columns: [id, function, args, expected]
  rows:
    - [re946m001, re.RegexFlag.__name__.__eq__,    ["RegexFlag"], true]
    - [re946m002, re.RegexFlag.__module__.__eq__,  ["re"],        true]
    - [re946m003, re.RegexFlag.__qualname__.__eq__, ["RegexFlag"], true]
    - [re946m004, re.IGNORECASE.__class__.__name__.__eq__, ["int"], false]

table re_extra946.error_class_identity:
  description: "re.error exception class attribute identity"
  kind: python_call_eq
  category: error_class_identity
  id_prefix: re946e
  columns: [id, function, args, expected]
  rows:
    - [re946e001, re.error.__name__.__eq__,     ["error"], true]
    - [re946e002, re.error.__module__.__eq__,   ["re"],    true]
    - [re946e003, re.error.__qualname__.__eq__, ["error"], true]
    - [re946e004, re.error.__name__.__eq__,     ["Error"], false]
    - [re946e005, re.error.__module__.__eq__,   ["regex"], false]
