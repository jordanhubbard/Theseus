spec: hashlib_extra102
version: ">=3.9"
backend: python_module(hashlib)
extends: hashlib_extra99

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__=='builtin_function_or_method' / __name__ equality / blake2b/blake2s class identity and __module__/__qualname__ / new __class__.__name__=='function' / algorithms_guaranteed length (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / algorithms_available membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib module identity attributes (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra99; it does NOT duplicate invariants present in those files."
    - "Wave 262 theme: hashlib algorithm constructor __qualname__.__len__() values — md5/sha1/sha224/sha256/sha384/sha512/sha3_256/sha3_512/shake_128/blake2b/new __qualname__ lengths."
    - "hashlib.md5.__qualname__.__len__() == 11 ('openssl_md5'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__.__len__() == 12 ('openssl_sha1'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__qualname__.__len__() == 14 ('openssl_sha224'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__qualname__.__len__() == 14 ('openssl_sha256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__.__len__() == 14 ('openssl_sha384'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__qualname__.__len__() == 14 ('openssl_sha512'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__.__len__() == 16 ('openssl_sha3_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__qualname__.__len__() == 16 ('openssl_sha3_512'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__qualname__.__len__() == 17 ('openssl_shake_128'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__qualname__.__len__() == 7 ('blake2b'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__.__len__() == 10 ('__hash_new'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: OpenSSL-backed constructors carry 'openssl_' prefix in __qualname__. md5 adds 3-char name (11 total), sha1 adds 4-char (12), sha2xx adds 6-char (14), sha3_xxx adds 8-char (16), shake_128 adds 9-char (17)."
    - "Note: blake2b and blake2s lack the 'openssl_' prefix because they are from the _blake2 C extension, not _hashlib."
    - "Note: hashlib.new.__qualname__ is '__hash_new' (10 chars), not 'new', reflecting the internal implementation name in Lib/hashlib.py."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__len__()==11
# hashlib.sha1.__qualname__.__len__()==12
# hashlib.sha224.__qualname__.__len__()==14
# hashlib.sha256.__qualname__.__len__()==14
# hashlib.sha384.__qualname__.__len__()==14
# hashlib.sha512.__qualname__.__len__()==14
#
# Wave 262 theme: OpenSSL-backed SHA-1/SHA-2 constructor __qualname__.__len__().
#
# All six constructors carry the 'openssl_' prefix (8 chars). md5 (3 chars) gives
# 11 total; sha1 (4) gives 12; sha224/sha256/sha384/sha512 (all 6) give 14.
# Prior specs (extra95/extra99) anchor __qualname__.__eq__; this table first
# anchors __qualname__.__len__() for the six core SHA-family constructors under
# hashlibqlen102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra102.sha12_constructor_qualname_lengths:
  description: "hashlib.md5/__qualname__/__len__()==11 / sha1/__qualname__/__len__()==12 / sha224/__qualname__/__len__()==14 / sha256/__qualname__/__len__()==14 / sha384/__qualname__/__len__()==14 / sha512/__qualname__/__len__()==14 — all carry 'openssl_' prefix (8 chars); md5 ('openssl_md5', 11), sha1 ('openssl_sha1', 12), sha224-sha512 ('openssl_sha2xx', 14); extra95/extra99 anchor __qualname__.__eq__; first hashlibqlen102 anchor for SHA-1/SHA-2 qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen102

  columns: [id, function, args, expected, description]
  rows:
    - [md5_qlen,    md5.__qualname__.__len__,    [], 11, "'openssl_md5' is 8 + 3 = 11 chars"]
    - [sha1_qlen,   sha1.__qualname__.__len__,   [], 12, "'openssl_sha1' is 8 + 4 = 12 chars"]
    - [sha224_qlen, sha224.__qualname__.__len__,  [], 14, "'openssl_sha224' is 8 + 6 = 14 chars"]
    - [sha256_qlen, sha256.__qualname__.__len__,  [], 14, "'openssl_sha256' is 8 + 6 = 14 chars"]
    - [sha384_qlen, sha384.__qualname__.__len__,  [], 14, "'openssl_sha384' is 8 + 6 = 14 chars"]
    - [sha512_qlen, sha512.__qualname__.__len__,  [], 14, "'openssl_sha512' is 8 + 6 = 14 chars"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__qualname__.__len__()==16
# hashlib.sha3_512.__qualname__.__len__()==16
# hashlib.shake_128.__qualname__.__len__()==17
# hashlib.blake2b.__qualname__.__len__()==7
# hashlib.new.__qualname__.__len__()==10
#
# Wave 262 theme: SHA-3 / shake / blake2b / new __qualname__.__len__().
#
# sha3_256 and sha3_512 both have 16-char qualnames ('openssl_sha3_256/512').
# shake_128 has 17 ('openssl_shake_128': 8 + 9 = 17).
# blake2b has 7 ('blake2b', no prefix — from _blake2 extension).
# new.__qualname__ is '__hash_new' (10 chars), the internal Python wrapper name.
# Prior specs anchor __qualname__.__eq__; first hashlibqlen102 anchor for these
# lengths. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra102.sha3_shake_blake_new_qualname_lengths:
  description: "hashlib.sha3_256/__qualname__/__len__()==16 / sha3_512/__qualname__/__len__()==16 / shake_128/__qualname__/__len__()==17 / blake2b/__qualname__/__len__()==7 / new/__qualname__/__len__()==10 — sha3_256/sha3_512 are 'openssl_sha3_xxx' (16); shake_128 is 'openssl_shake_128' (17); blake2b is 'blake2b' (7, no openssl prefix); new is '__hash_new' (10, internal name); first hashlibqlen102 anchor for these qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen102

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_qlen, sha3_256.__qualname__.__len__, [], 16, "'openssl_sha3_256' is 8 + 8 = 16 chars"]
    - [sha3_512_qlen, sha3_512.__qualname__.__len__, [], 16, "'openssl_sha3_512' is 8 + 8 = 16 chars"]
    - [shake_128_qlen, shake_128.__qualname__.__len__, [], 17, "'openssl_shake_128' is 8 + 9 = 17 chars"]
    - [blake2b_qlen, blake2b.__qualname__.__len__, [], 7, "'blake2b' is 7 chars — no 'openssl_' prefix, from _blake2 extension"]
    - [new_qlen, new.__qualname__.__len__, [], 10, "'__hash_new' is 10 chars — internal Python wrapper name"]

# ---------------------------------------------------------------------------
# hashlib qualname equality cross-checks
# hashlib.md5.__qualname__.__eq__('openssl_md5')
# hashlib.sha1.__qualname__.__eq__('openssl_sha1')
# hashlib.sha3_256.__qualname__.__eq__('openssl_sha3_256')
# hashlib.shake_128.__qualname__.__eq__('openssl_shake_128')
# hashlib.blake2b.__qualname__.__eq__('blake2b')
# hashlib.new.__qualname__.__eq__('__hash_new')
#
# Wave 262 supplemental: qualname equality anchors for new ids.
#
# These equality anchors provide cross-checks on the __qualname__ string values
# that correspond to the length anchors above. Prior specs establish qualname
# equality for md5/sha1/sha3_256/shake_128/blake2b/new, but this table provides
# additional anchors for new ids under hashlibqlen102.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra102.qualname_equality_crosschecks:
  description: "hashlib.md5/__qualname__/__eq__('openssl_md5')==True / sha1/__qualname__/__eq__('openssl_sha1')==True / sha3_256/__qualname__/__eq__('openssl_sha3_256')==True / shake_128/__qualname__/__eq__('openssl_shake_128')==True / blake2b/__qualname__/__eq__('blake2b')==True / new/__qualname__/__eq__('__hash_new')==True — qualname equality cross-checks corresponding to the length anchors; first hashlibqlen102 anchor for these equality ids"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen102

  columns: [id, function, args, expected, description]
  rows:
    - [md5_qeq,       md5.__qualname__.__eq__,       ["openssl_md5"],       true, "md5.__qualname__ is 'openssl_md5', OpenSSL-backed constructor"]
    - [sha1_qeq,      sha1.__qualname__.__eq__,      ["openssl_sha1"],      true, "sha1.__qualname__ is 'openssl_sha1'"]
    - [sha3_256_qeq,  sha3_256.__qualname__.__eq__,  ["openssl_sha3_256"],  true, "sha3_256.__qualname__ is 'openssl_sha3_256'"]
    - [shake_128_qeq, shake_128.__qualname__.__eq__,  ["openssl_shake_128"], true, "shake_128.__qualname__ is 'openssl_shake_128'"]
    - [blake2b_qeq,   blake2b.__qualname__.__eq__,   ["blake2b"],           true, "blake2b.__qualname__ is 'blake2b' — no openssl prefix, from _blake2"]
    - [new_qeq,       new.__qualname__.__eq__,        ["__hash_new"],        true, "new.__qualname__ is '__hash_new', internal name of the Python wrapper"]

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__len__()==11 — standalone
#
# hashlib.md5.__qualname__.__len__() is 11. md5.__qualname__ is 'openssl_md5':
# 'openssl_' (8 chars) + 'md5' (3 chars) = 11. The 'openssl_' prefix identifies
# the constructor as an OpenSSL-backed C builtin from the _hashlib extension.
# Prior specs (extra95/extra99) anchor __qualname__.__eq__('openssl_md5');
# no prior hashlib spec anchors md5.__qualname__.__len__()==11 as a standalone
# under hashlibqlen102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra102.md5_qualname_len_11:
  description: "hashlib.md5.__qualname__.__len__() == 11 — md5.__qualname__ is 'openssl_md5': 'openssl_' (8) + 'md5' (3) = 11; the 'openssl_' prefix identifies the OpenSSL-backed C builtin from _hashlib; extra95/extra99 anchor __qualname__.__eq__; first standalone for md5.__qualname__.__len__() under hashlibqlen102"
  category: qualname_lengths
  kind: python_call_eq
  function: md5.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__.__len__()==10 — standalone
#
# hashlib.new.__qualname__.__len__() is 10. new.__qualname__ is '__hash_new'
# (10 chars). The internal name '__hash_new' reflects that hashlib.new is
# implemented as a private function __hash_new in Lib/hashlib.py, then exposed
# as the public 'new' attribute. This distinguishes it from simple wrappers:
# the double-underscore prefix signals an internal naming convention.
# No prior hashlib spec anchors new.__qualname__.__len__()==10 as a standalone
# under hashlibqlen102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra102.new_qualname_len_10:
  description: "hashlib.new.__qualname__.__len__() == 10 — new.__qualname__ is '__hash_new' (10 chars); this is the internal implementation name in Lib/hashlib.py, exposed as the public 'new' attribute; the double-underscore prefix signals internal naming; no prior hashlib spec anchors new.__qualname__.__len__() as a standalone under hashlibqlen102"
  category: qualname_lengths
  kind: python_call_eq
  function: new.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# hashlib.blake2b.__qualname__.__len__()==7 — standalone
#
# hashlib.blake2b.__qualname__.__len__() is 7. blake2b.__qualname__ is 'blake2b'
# (7 chars). Unlike the OpenSSL-backed constructors which carry the 'openssl_'
# prefix in __qualname__, blake2b comes from the _blake2 C extension and uses
# its simple class name as __qualname__. This makes it the shortest algorithm
# __qualname__ in the hashlib namespace. Prior specs anchor __qualname__.__eq__;
# no prior spec anchors blake2b.__qualname__.__len__()==7 as a standalone under
# hashlibqlen102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra102.blake2b_qualname_len_7:
  description: "hashlib.blake2b.__qualname__.__len__() == 7 — blake2b.__qualname__ is 'blake2b' (7 chars); unlike OpenSSL-backed constructors with 'openssl_' prefix, blake2b uses its simple class name from the _blake2 C extension; 7 is the shortest algorithm __qualname__ length in hashlib; no prior hashlib spec anchors blake2b.__qualname__.__len__() as a standalone under hashlibqlen102"
  category: qualname_lengths
  kind: python_call_eq
  function: blake2b.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# hashlib.shake_128.__qualname__.__len__()==17 — standalone
#
# hashlib.shake_128.__qualname__.__len__() is 17. shake_128.__qualname__ is
# 'openssl_shake_128' (17 chars): 'openssl_' (8) + 'shake_128' (9) = 17.
# The XOF (extendable-output function) algorithms shake_128 and shake_256 are
# OpenSSL-backed and carry the full 'openssl_' prefix. shake_128 has the longest
# qualname length (17) among the shake algorithms considered here. Prior specs
# anchor __qualname__.__eq__; no prior spec anchors shake_128.__qualname__.__len__()
# as a standalone under hashlibqlen102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra102.shake_128_qualname_len_17:
  description: "hashlib.shake_128.__qualname__.__len__() == 17 — shake_128.__qualname__ is 'openssl_shake_128': 'openssl_' (8) + 'shake_128' (9) = 17; XOF algorithms like shake_128/shake_256 carry the full 'openssl_' prefix as OpenSSL-backed builtins; 17 is the qualname length for both shake variants; no prior hashlib spec anchors shake_128.__qualname__.__len__() as a standalone under hashlibqlen102"
  category: qualname_lengths
  kind: python_call_eq
  function: shake_128.__qualname__.__len__
  args: []
  expected: 17

