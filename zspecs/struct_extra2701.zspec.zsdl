spec: struct_extra2701
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 627: checks struct.Struct and struct.error __dict__ for __lshift__, __rshift__, __invert__ presence. All return False — neither struct.Struct nor struct.error defines __lshift__, __rshift__, or __invert__ in its own __dict__."]
  created_at: "2026-04-13"
error_model: python_exceptions

table struct_extra2701.Struct_dict_presence:
  description: "struct.Struct __dict__ does not contain __lshift__, __rshift__, or __invert__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2701sd
  columns: [id, function, args, expected]
  rows:
    - ["st2701sd001", struct.Struct.__dict__.__contains__, ["__lshift__"], false]
    - ["st2701sd002", struct.Struct.__dict__.__contains__, ["__rshift__"], false]
    - ["st2701sd003", struct.Struct.__dict__.__contains__, ["__invert__"], false]

