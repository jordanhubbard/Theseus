spec: io_extra214
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* constants, TextIOWrapper, BufferedRandom, UnsupportedOperation class metadata"
    - "io_extra210.zspec.zsdl — covers io.__all__ membership and length"
  notes:
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are abstract base classes defined in _io (C extension) and re-exported through io."
    - "In Python 3.14.3 these ABCs have no I/O method implementations in their __dict__; methods like read/readline/write are abstract and live only in the C layer."
    - "io.IOBase.__dict__ keys are: __module__, __firstlineno__, __doc__, __static_attributes__, __abstractmethods__, _abc_impl — confirmed Python 3.14.3 macOS."
    - "io.IOBase.__dict__.__contains__('read') == False; 'read' is not defined at the Python level on IOBase; confirmed Python 3.14.3 macOS."
    - "io.IOBase.__dict__.__contains__('readline') == False; same reason; confirmed Python 3.14.3 macOS."
    - "io.IOBase.__dict__.__contains__('readlines') == False; same reason; confirmed Python 3.14.3 macOS."
    - "io.IOBase.__dict__.__contains__('writelines') == False; same reason; confirmed Python 3.14.3 macOS."
    - "io.IOBase.__dict__.__contains__('close') == False; same reason; confirmed Python 3.14.3 macOS."
    - "io.RawIOBase.__dict__.__contains__('read') == False; confirmed Python 3.14.3 macOS."
    - "io.BufferedIOBase.__dict__.__contains__('read') == False; confirmed Python 3.14.3 macOS."
    - "io.TextIOBase.__dict__.__contains__('read') == False; confirmed Python 3.14.3 macOS."
    - "All four ABCs do contain '__abstractmethods__' and '_abc_impl' in their __dict__; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.IOBase.__dict__ membership — I/O method names absent (all False)
# read, readline, readlines, writelines, close are NOT in IOBase.__dict__
# ---------------------------------------------------------------------------

table io_extra214.iobase_dict_absent_io_methods:
  description: "io.IOBase.__dict__ does not contain I/O method names — all abstract, not in Python-level dict"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iodict214

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_no_read,       io.IOBase.__dict__.__contains__,  ["read"],       false,  "io.IOBase.__dict__.__contains__('read') == False; 'read' is abstract and not in Python-level __dict__; confirmed Python 3.14.3 macOS"]
    - [iobase_no_readline,   io.IOBase.__dict__.__contains__,  ["readline"],   false,  "io.IOBase.__dict__.__contains__('readline') == False; 'readline' is abstract and absent from Python-level __dict__; confirmed Python 3.14.3 macOS"]
    - [iobase_no_readlines,  io.IOBase.__dict__.__contains__,  ["readlines"],  false,  "io.IOBase.__dict__.__contains__('readlines') == False; 'readlines' is abstract and absent from Python-level __dict__; confirmed Python 3.14.3 macOS"]
    - [iobase_no_writelines, io.IOBase.__dict__.__contains__,  ["writelines"], false,  "io.IOBase.__dict__.__contains__('writelines') == False; 'writelines' is abstract and absent from Python-level __dict__; confirmed Python 3.14.3 macOS"]
    - [iobase_no_close,      io.IOBase.__dict__.__contains__,  ["close"],      false,  "io.IOBase.__dict__.__contains__('close') == False; 'close' is abstract and absent from Python-level __dict__; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.IOBase.__dict__ membership — infrastructure keys present (all True)
# __abstractmethods__, _abc_impl, __doc__, __module__ ARE in IOBase.__dict__
# ---------------------------------------------------------------------------

table io_extra214.iobase_dict_present_infra_keys:
  description: "io.IOBase.__dict__ contains ABC infrastructure keys"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iodict214

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_has_abstractmethods, io.IOBase.__dict__.__contains__,  ["__abstractmethods__"],    true,  "io.IOBase.__dict__.__contains__('__abstractmethods__') == True; all ABCs carry this frozenset; confirmed Python 3.14.3 macOS"]
    - [iobase_has_abc_impl,        io.IOBase.__dict__.__contains__,  ["_abc_impl"],              true,  "io.IOBase.__dict__.__contains__('_abc_impl') == True; _abc_impl is the internal ABCMeta cache; confirmed Python 3.14.3 macOS"]
    - [iobase_has_doc,             io.IOBase.__dict__.__contains__,  ["__doc__"],                true,  "io.IOBase.__dict__.__contains__('__doc__') == True; IOBase has a docstring; confirmed Python 3.14.3 macOS"]
    - [iobase_has_module,          io.IOBase.__dict__.__contains__,  ["__module__"],             true,  "io.IOBase.__dict__.__contains__('__module__') == True; __module__ records where the class was defined; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.RawIOBase, BufferedIOBase, TextIOBase — 'read' absent from each
# All three subclass ABCs also lack 'read' in their Python-level __dict__
# ---------------------------------------------------------------------------

table io_extra214.subclass_abc_dict_no_read:
  description: "io.RawIOBase, BufferedIOBase, TextIOBase all lack 'read' in their Python-level __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iodict214

  columns: [id, function, args, expected, description]
  rows:
    - [rawiobase_no_read,      io.RawIOBase.__dict__.__contains__,      ["read"],  false,  "io.RawIOBase.__dict__.__contains__('read') == False; read is abstract and not in Python-level __dict__; confirmed Python 3.14.3 macOS"]
    - [bufferediobase_no_read, io.BufferedIOBase.__dict__.__contains__,  ["read"],  false,  "io.BufferedIOBase.__dict__.__contains__('read') == False; read is abstract and not in Python-level __dict__; confirmed Python 3.14.3 macOS"]
    - [textiobase_no_read,     io.TextIOBase.__dict__.__contains__,      ["read"],  false,  "io.TextIOBase.__dict__.__contains__('read') == False; read is abstract and not in Python-level __dict__; confirmed Python 3.14.3 macOS"]
    - [rawiobase_has_abstractmethods, io.RawIOBase.__dict__.__contains__, ["__abstractmethods__"], true, "io.RawIOBase.__dict__.__contains__('__abstractmethods__') == True; ABC infrastructure key present; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra214.iobase_no_read:
  description: "io.IOBase.__dict__.__contains__('read') == False — 'read' is abstract and not present in IOBase Python-level __dict__; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: io.IOBase.__dict__.__contains__
  args: ["read"]
  expected: false

invariant io_extra214.iobase_no_readline:
  description: "io.IOBase.__dict__.__contains__('readline') == False — 'readline' is abstract and absent from IOBase Python-level __dict__; confirmed Python 3.14.3 macOS"
  category: dict_membership
  kind: python_call_eq
  function: io.IOBase.__dict__.__contains__
