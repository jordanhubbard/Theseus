spec: pascal_case
version: ">=3.0.0"
backend: node(pascal-case)

docs: https://www.npmjs.com/package/pascal-case

provenance:
  derived_from:
    - "pascal-case README — https://www.npmjs.com/package/pascal-case"
    - "Test vectors verified with pascal-case@3.1.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "pascal-case source"
  notes:
    - "pascal-case exports {pascalCase} named function."
    - "pascalCase converts string to PascalCase (UpperCamelCase)."
    - "Handles spaces, dashes, underscores, and camelCase inputs."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns PascalCased string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table pascal_case.pascal_case:
  kind: node_module_call_eq
  function: pascalCase
  category: pascalCase
  id_prefix: pascase

  columns: [id, args, expected]
  rows:
    - [space,   ["foo bar"],     "FooBar"]
    - [dash,    ["foo-bar-baz"], "FooBarBaz"]
    - [snake,   ["foo_bar"],     "FooBar"]
    - [camel,   ["fooBar"],      "FooBar"]
