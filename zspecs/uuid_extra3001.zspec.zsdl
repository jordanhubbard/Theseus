spec: uu3001
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid: UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 647 (uu3001): __getitem__, __setitem__, __delitem__ dict-presence checks for uuid types."
    - "uuid.UUID fields are accessed via named attributes (e.g. .hex, .bytes, .int), not subscript — no item access protocol is defined."
    - "uuid.SafeUUID is an Enum subclass — not a mapping or sequence type."
    - "None of the uuid types define __getitem__, __setitem__, or __delitem__ in their own __dict__."
    - "Verified types: uuid.UUID, uuid.SafeUUID."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu3001.getitem:
  description: "uuid types __getitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu3001
  columns: [id, function, args, expected]
  rows:
    - ["uu3001001", operator.contains, [uuid.UUID.__dict__,     "__getitem__"], false]
    - ["uu3001002", operator.contains, [uuid.SafeUUID.__dict__, "__getitem__"], false]

