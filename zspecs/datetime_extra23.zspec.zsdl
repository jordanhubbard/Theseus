spec: datetime_extra23
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
    - "datetime_extra21.zspec.zsdl — covers __module__.__len__() and __name__.__len__() for date/time/datetime/timedelta/timezone; date.today.__qualname__.__len__() and datetime.now.__qualname__.__len__()"
    - "datetime_extra22.zspec.zsdl — covers __qualname__.__len__() for date/time/datetime/timedelta/timezone/tzinfo; __module__.__len__() and __name__.__len__() for tzinfo; __qualname__.__len__() for datetime.fromisoformat/datetime.strptime/date.fromisoformat/timedelta.__repr__"
  notes:
    - "This spec extends datetime_extra22.zspec.zsdl."
    - "Prior specs covered: date/time/datetime/timedelta/timezone/tzinfo __name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() for all six classes, __qualname__.__len__() for class names, date.today/__qualname__.__len__(), datetime.now/__qualname__.__len__(), datetime.fromisoformat/strptime/date.fromisoformat/timedelta.__repr__ qualname lengths."
    - "This spec covers: __mro__.__len__() for datetime, date, timedelta, timezone, tzinfo; __bases__[0].__name__ for datetime, timezone, date, timedelta, tzinfo; __qualname__.__len__() for datetime.utcnow, datetime.combine, datetime.isoformat, date.isoformat."
    - "datetime.datetime.__mro__ == ['datetime', 'date', 'object'] (len 3) — verified Python 3.12."
    - "datetime.date.__mro__ == ['date', 'object'] (len 2) — verified Python 3.12."
    - "datetime.timedelta.__mro__ == ['timedelta', 'object'] (len 2) — verified Python 3.12."
    - "datetime.timezone.__mro__ == ['timezone', 'tzinfo', 'object'] (len 3) — verified Python 3.12."
    - "datetime.tzinfo.__mro__ == ['tzinfo', 'object'] (len 2) — verified Python 3.12."
    - "datetime.datetime.__bases__[0].__name__ == 'date' — verified Python 3.12."
    - "datetime.timezone.__bases__[0].__name__ == 'tzinfo' — verified Python 3.12."
    - "datetime.date.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "datetime.timedelta.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "datetime.tzinfo.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "datetime.datetime.utcnow.__qualname__ == 'datetime.utcnow' (len 15) — verified Python 3.12."
    - "datetime.datetime.combine.__qualname__ == 'datetime.combine' (len 16) — verified Python 3.12."
    - "datetime.datetime.isoformat.__qualname__ == 'datetime.isoformat' (len 18) — verified Python 3.12."
    - "datetime.date.isoformat.__qualname__ == 'date.isoformat' (len 14) — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for datetime, date, timedelta, timezone, tzinfo
#
# The MRO depth reflects the C-extension class inheritance hierarchy:
#   date      -> [date, object]                   -> 2
#   timedelta -> [timedelta, object]               -> 2
#   tzinfo    -> [tzinfo, object]                  -> 2
#   datetime  -> [datetime, date, object]          -> 3
#   timezone  -> [timezone, tzinfo, object]        -> 3
# No prior datetime spec checks __mro__.__len__() for any of these classes.
# ---------------------------------------------------------------------------

table datetime_extra23.class_mro_depths:
  description: "__mro__.__len__() for datetime, date, timedelta, timezone, tzinfo"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: dte23

  columns: [id, function, args, expected]
  rows:
    - [date,      date.__mro__.__len__,      [], 2]
    - [timedelta, timedelta.__mro__.__len__, [], 2]
    - [tzinfo,    tzinfo.__mro__.__len__,    [], 2]
    - [datetime,  datetime.__mro__.__len__,  [], 3]
    - [timezone,  timezone.__mro__.__len__,  [], 3]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for datetime, timezone, date, timedelta, tzinfo
#
# The immediate base class of each datetime class:
#   date      -> object   (date directly extends object)
#   timedelta -> object   (timedelta directly extends object)
#   tzinfo    -> object   (tzinfo directly extends object)
#   datetime  -> date     (datetime extends date)
#   timezone  -> tzinfo   (timezone extends tzinfo)
# Note: __bases__[0].__name__ contains '[' in the function path, so MUST be quoted.
# No prior datetime spec checks __bases__[0].__name__ for any of these five classes.
# ---------------------------------------------------------------------------

table datetime_extra23.class_bases_names:
  description: "__bases__[0].__name__ for datetime, timezone, date, timedelta, tzinfo"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: dbn23

  columns: [id, function, args, expected, method, method_args]
  rows:
    - [datetime_base,  "datetime.__bases__[0].__name__.__eq__",  ["date"],   true, __len__, []]
    - [timezone_base,  "timezone.__bases__[0].__name__.__eq__",  ["tzinfo"], true, __len__, []]
    - [date_base,      "date.__bases__[0].__name__.__eq__",      ["object"], true, __len__, []]
    - [timedelta_base, "timedelta.__bases__[0].__name__.__eq__", ["object"], true, __len__, []]
    - [tzinfo_base,    "tzinfo.__bases__[0].__name__.__eq__",    ["object"], true, __len__, []]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for additional datetime and date method qualnames
#
# These methods have not been covered by prior datetime specs:
#   datetime.utcnow    -> 'datetime.utcnow'    -> 15
#   datetime.combine   -> 'datetime.combine'   -> 16
#   datetime.isoformat -> 'datetime.isoformat' -> 18
#   date.isoformat     -> 'date.isoformat'     -> 14
# datetime_extra22 covered datetime.fromisoformat (22), datetime.strptime (17),
# date.fromisoformat (18), timedelta.__repr__ (18). datetime_extra21 covered
# datetime.now (12) and date.today (11). None of the four below are covered yet.
# ---------------------------------------------------------------------------

invariant datetime_extra23.datetime.utcnow.qualname_len:
  description: "datetime.datetime.utcnow.__qualname__.__len__() == 15 — 'datetime.utcnow' has 15 characters"
  category: method_identity
  kind: python_call_eq
  function: datetime.utcnow.__qualname__.__len__
  args: []
  expected: 15

invariant datetime_extra23.datetime.combine.qualname_len:
  description: "datetime.datetime.combine.__qualname__.__len__() == 16 — 'datetime.combine' has 16 characters"
  category: method_identity
  kind: python_call_eq
  function: datetime.combine.__qualname__.__len__
  args: []
  expected: 16

invariant datetime_extra23.datetime.isoformat.qualname_len:
  description: "datetime.datetime.isoformat.__qualname__.__len__() == 18 — 'datetime.isoformat' has 18 characters"
  category: method_identity
  kind: python_call_eq
  function: datetime.isoformat.__qualname__.__len__
  args: []
  expected: 18

invariant datetime_extra23.date.isoformat.qualname_len:
  description: "datetime.date.isoformat.__qualname__.__len__() == 14 — 'date.isoformat' has 14 characters"
  category: method_identity
  kind: python_call_eq
  function: date.isoformat.__qualname__.__len__
  args: []
  expected: 14
