spec: inspect_extra136
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getattr_static, inspect.classify_class_attrs, inspect.getmro — qualname, co_argcount, co_varnames (Wave 264)."
    - "inspect.getattr_static.__qualname__ == 'getattr_static' (len 14) — defined at module scope in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.getattr_static.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.getattr_static.__code__.co_argcount == 3 — takes obj, attr, default. Verified with Python 3.14.3."
    - "len(inspect.getattr_static.__code__.co_varnames) == 9 — local variables: obj, attr, default, instance_result, objtype, klass, dict_attr, klass_result, entry. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__qualname__ == 'classify_class_attrs' (len 20). Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__code__.co_argcount == 1 — takes cls. Verified with Python 3.14.3."
    - "len(inspect.classify_class_attrs.__code__.co_varnames) == 20. Verified with Python 3.14.3."
    - "inspect.getmro.__qualname__ == 'getmro' (len 6). Verified with Python 3.14.3."
    - "inspect.getmro.__code__.co_argcount == 1 — takes cls. Verified with Python 3.14.3."
    - "len(inspect.getmro.__code__.co_varnames) == 1 — only 'cls'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getattr_static function identity and code attributes
#
# Wave 264 theme: inspect.getattr_static qualname, module, co_argcount, co_varnames.
#
# inspect.getattr_static.__qualname__ == 'getattr_static' (len 14)
# inspect.getattr_static.__module__ == 'inspect'
# inspect.getattr_static.__code__.co_argcount == 3
# len(inspect.getattr_static.__code__.co_varnames) == 9
# co_varnames[0] == 'obj', co_varnames[1] == 'attr', co_varnames[2] == 'default'
#
# getattr_static is a Python function defined at module scope in Lib/inspect.py.
# It retrieves attributes without triggering descriptor protocol. New to extra136.
# ---------------------------------------------------------------------------

table inspect_extra136.getattr_static_identity:
  description: "inspect.getattr_static: __qualname__ len 14, __module__=='inspect', co_argcount==3, co_varnames len 9; wave 264; new to extra136"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetattrstatic136

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static_qualname_eq,
       "getattr_static.__qualname__.__eq__",
       ["getattr_static"],
       true,
       "inspect.getattr_static.__qualname__.__eq__('getattr_static') == True — getattr_static is defined at module scope in Lib/inspect.py; its __qualname__ is 'getattr_static'; str.__eq__('getattr_static') returns True; new to extra136"]
    - [getattr_static_qualname_len_eq_14,
       "getattr_static.__qualname__.__len__",
       [],
       14,
       "inspect.getattr_static.__qualname__.__len__() == 14 — __qualname__ is 'getattr_static' which has 14 characters; len('getattr_static') == 14; new to extra136"]
    - [getattr_static_module_eq_inspect,
       "getattr_static.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getattr_static.__module__.__eq__('inspect') == True — getattr_static is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra136"]
    - [getattr_static_co_argcount_eq_3,
       "getattr_static.__code__.co_argcount.__eq__",
       [3],
       true,
       "inspect.getattr_static.__code__.co_argcount.__eq__(3) == True — getattr_static takes 3 positional-or-keyword arguments: obj, attr, default; co_argcount is 3; int.__eq__(3) returns True; new to extra136"]
    - [getattr_static_co_varnames_len_eq_9,
       "getattr_static.__code__.co_varnames.__len__",
       [],
       9,
       "inspect.getattr_static.__code__.co_varnames.__len__() == 9 — co_varnames has 9 entries: obj, attr, default, instance_result, objtype, klass, dict_attr, klass_result, entry; len() == 9; new to extra136"]
    - [getattr_static_co_varnames_0_eq_obj,
       "getattr_static.__code__.co_varnames[0].__eq__",
       ["obj"],
       true,
       "inspect.getattr_static.__code__.co_varnames[0].__eq__('obj') == True — the first local variable is 'obj', the object whose attribute is retrieved; str.__eq__('obj') returns True; new to extra136"]
    - [getattr_static_co_varnames_1_eq_attr,
       "getattr_static.__code__.co_varnames[1].__eq__",
       ["attr"],
       true,
       "inspect.getattr_static.__code__.co_varnames[1].__eq__('attr') == True — the second local variable is 'attr', the attribute name to look up; str.__eq__('attr') returns True; new to extra136"]
    - [getattr_static_co_varnames_2_eq_default,
       "getattr_static.__code__.co_varnames[2].__eq__",
       ["default"],
       true,
       "inspect.getattr_static.__code__.co_varnames[2].__eq__('default') == True — the third local variable is 'default', the fallback value returned if the attribute is not found; str.__eq__('default') returns True; new to extra136"]

# ---------------------------------------------------------------------------
# Table 2: inspect.classify_class_attrs function identity and code attributes
#
# Wave 264 theme: inspect.classify_class_attrs qualname, module, co_argcount, co_varnames.
#
# inspect.classify_class_attrs.__qualname__ == 'classify_class_attrs' (len 20)
# inspect.classify_class_attrs.__module__ == 'inspect'
# inspect.classify_class_attrs.__code__.co_argcount == 1
# len(inspect.classify_class_attrs.__code__.co_varnames) == 20
# co_varnames[0] == 'cls', co_varnames[1] == 'mro'
#
# classify_class_attrs takes a class and returns a list of (name, kind, defining_class, object)
# tuples classifying every attribute. New to extra136.
# ---------------------------------------------------------------------------

table inspect_extra136.classify_class_attrs_identity:
  description: "inspect.classify_class_attrs: __qualname__ len 20, co_argcount==1, co_varnames len 20; wave 264; new to extra136"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectclassify136

  columns: [id, function, args, expected, description]
  rows:
    - [classify_qualname_eq,
       "classify_class_attrs.__qualname__.__eq__",
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__qualname__.__eq__('classify_class_attrs') == True — classify_class_attrs is defined at module scope in Lib/inspect.py; its __qualname__ is 'classify_class_attrs'; str.__eq__('classify_class_attrs') returns True; new to extra136"]
    - [classify_qualname_len_eq_20,
       "classify_class_attrs.__qualname__.__len__",
       [],
       20,
       "inspect.classify_class_attrs.__qualname__.__len__() == 20 — __qualname__ is 'classify_class_attrs' which has 20 characters; len('classify_class_attrs') == 20; new to extra136"]
    - [classify_module_eq_inspect,
       "classify_class_attrs.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.classify_class_attrs.__module__.__eq__('inspect') == True — classify_class_attrs is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra136"]
    - [classify_co_argcount_eq_1,
       "classify_class_attrs.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.classify_class_attrs.__code__.co_argcount.__eq__(1) == True — classify_class_attrs takes 1 positional-or-keyword argument: cls; co_argcount is 1; int.__eq__(1) returns True; new to extra136"]
    - [classify_co_varnames_len_eq_20,
       "classify_class_attrs.__code__.co_varnames.__len__",
       [],
       20,
       "inspect.classify_class_attrs.__code__.co_varnames.__len__() == 20 — co_varnames has 20 entries including cls, mro, metamro, class_bases, all_bases, names, and other loop variables; len() == 20; new to extra136"]
    - [classify_co_varnames_0_eq_cls,
       "classify_class_attrs.__code__.co_varnames[0].__eq__",
       ["cls"],
       true,
       "inspect.classify_class_attrs.__code__.co_varnames[0].__eq__('cls') == True — the first local variable is 'cls', the class whose attributes are classified; str.__eq__('cls') returns True; new to extra136"]
    - [classify_co_varnames_1_eq_mro,
       "classify_class_attrs.__code__.co_varnames[1].__eq__",
       ["mro"],
       true,
       "inspect.classify_class_attrs.__code__.co_varnames[1].__eq__('mro') == True — the second local variable is 'mro', the method resolution order of the class; str.__eq__('mro') returns True; new to extra136"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getmro function identity and code attributes
#
# Wave 264 theme: inspect.getmro qualname, module, co_argcount, co_varnames.
#
# inspect.getmro.__qualname__ == 'getmro' (len 6)
# inspect.getmro.__module__ == 'inspect'
# inspect.getmro.__code__.co_argcount == 1
# len(inspect.getmro.__code__.co_varnames) == 1
# co_varnames[0] == 'cls'
#
# getmro is a thin wrapper around cls.__mro__. New to extra136.
# ---------------------------------------------------------------------------

table inspect_extra136.getmro_identity:
  description: "inspect.getmro: __qualname__ len 6, co_argcount==1, co_varnames len 1, co_varnames[0]=='cls'; wave 264; new to extra136"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectgetmro136

  columns: [id, function, args, expected, description]
  rows:
    - [getmro_qualname_eq,
       "getmro.__qualname__.__eq__",
       ["getmro"],
       true,
       "inspect.getmro.__qualname__.__eq__('getmro') == True — getmro is defined at module scope in Lib/inspect.py; its __qualname__ is 'getmro'; str.__eq__('getmro') returns True; new to extra136"]
    - [getmro_qualname_len_eq_6,
       "getmro.__qualname__.__len__",
       [],
       6,
       "inspect.getmro.__qualname__.__len__() == 6 — __qualname__ is 'getmro' which has 6 characters; len('getmro') == 6; new to extra136"]
    - [getmro_module_eq_inspect,
       "getmro.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmro.__module__.__eq__('inspect') == True — getmro is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra136"]
    - [getmro_co_argcount_eq_1,
       "getmro.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getmro.__code__.co_argcount.__eq__(1) == True — getmro takes 1 positional-or-keyword argument: cls; co_argcount is 1; int.__eq__(1) returns True; new to extra136"]
    - [getmro_co_varnames_len_eq_1,
       "getmro.__code__.co_varnames.__len__",
       [],
       1,
       "inspect.getmro.__code__.co_varnames.__len__() == 1 — co_varnames has 1 entry: cls; getmro is a thin wrapper that returns cls.__mro__; len() == 1; new to extra136"]
    - [getmro_co_varnames_0_eq_cls,
       "getmro.__code__.co_varnames[0].__eq__",
       ["cls"],
       true,
       "inspect.getmro.__code__.co_varnames[0].__eq__('cls') == True — the only local variable of getmro is 'cls', the class whose MRO is returned; str.__eq__('cls') returns True; new to extra136"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra136
# ---------------------------------------------------------------------------

invariant inspect_extra136.getattr_static_qualname_len:
  description: "len(inspect.getattr_static.__qualname__) == 14 — __qualname__ is 'getattr_static'; wave 264; new to extra136"
  kind: python_call_eq
  function: getattr_static.__qualname__.__len__
  args: []
  expected: 14

invariant inspect_extra136.getattr_static_co_argcount:
  description: "inspect.getattr_static.__code__.co_argcount == 3 — takes obj, attr, default; wave 264; new to extra136"
  kind: python_call_eq
  function: getattr_static.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant inspect_extra136.classify_class_attrs_qualname_len:
  description: "len(inspect.classify_class_attrs.__qualname__) == 20 — __qualname__ is 'classify_class_attrs'; wave 264; new to extra136"
  kind: python_call_eq
  function: classify_class_attrs.__qualname__.__len__
  args: []
  expected: 20

invariant inspect_extra136.getmro_co_varnames_len:
  description: "len(inspect.getmro.__code__.co_varnames) == 1 — only 'cls'; wave 264; new to extra136"
  kind: python_call_eq
  function: getmro.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant inspect_extra136.getmro_co_argcount:
  description: "inspect.getmro.__code__.co_argcount == 1 — takes cls; wave 264; new to extra136"
  kind: python_call_eq
  function: getmro.__code__.co_argcount.__eq__
  args: [1]
  expected: true
