spec: pp3256
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 664 (pp3256): __rpow__, __rlshift__, __rrshift__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __rpow__, __rlshift__, __rrshift__ dict-presence (reflected power/shift)."
    - "No pathlib class defines __rpow__ in its own __dict__: path objects represent filesystem paths, not numeric types, and do not implement reflected exponentiation."
    - "No pathlib class defines __rlshift__ in its own __dict__: path objects do not implement reflected left-shift; bitwise shift is not part of the path protocol."
    - "No pathlib class defines __rrshift__ in its own __dict__: path objects do not implement reflected right-shift."
    - "pathlib defines __truediv__ (wave 659) for path joining but defines no reflected power or shift operators on any class."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "Key finding: decimal.Decimal.__rpow__ = true (consistent with wave 660 __pow__ = true); __rlshift__/__rrshift__ = false (no bitwise shift on Decimal)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rpow__ dict-presence — operator.contains(Cls.__dict__, '__rpow__')
#
# No pathlib class defines __rpow__ in its own __dict__; all false.
# pathlib types represent immutable filesystem paths, not numeric operands.
# ---------------------------------------------------------------------------

table pp3256.rpow:
  description: "pathlib types __rpow__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3256

  columns: [id, function, args, expected]
  rows:
    - ["pp3256001", operator.contains, [pathlib.PurePath.__dict__,         "__rpow__"], false]
    - ["pp3256002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__rpow__"], false]
    - ["pp3256003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__rpow__"], false]
    - ["pp3256004", operator.contains, [pathlib.Path.__dict__,             "__rpow__"], false]
    - ["pp3256005", operator.contains, [pathlib.PosixPath.__dict__,        "__rpow__"], false]

