spec: theseus_pydoc_data_cr
version: ">=3.0"
backend: python_cleanroom(theseus_pydoc_data_cr)
blocks: pydoc_data

docs: https://docs.python.org/3/library/pydoc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pydoc.html"
  not_derived_from:
    - "CPython source: Lib/pydoc_data/"
  notes:
    - "Clean-room pydoc_data package stub. Do NOT import pydoc_data."

error_model: python_exceptions

invariant theseus_pydoc_data_cr.pydoc_data2_package:
  description: "pydoc_data package is importable"
  category: behavior
  kind: python_call_eq
  function: pydoc_data2_package
  args: []
  expected: true

invariant theseus_pydoc_data_cr.pydoc_data2_topics:
  description: "pydoc_data.topics is a dict"
  category: behavior
  kind: python_call_eq
  function: pydoc_data2_topics
  args: []
  expected: true

invariant theseus_pydoc_data_cr.pydoc_data2_name:
  description: "pydoc_data package has correct __name__"
  category: behavior
  kind: python_call_eq
  function: pydoc_data2_name
  args: []
  expected: true
