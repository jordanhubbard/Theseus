spec: tty_extra3
version: ">=3.12"
backend: python_module(tty)

docs: https://docs.python.org/3/library/tty.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tty.html — Python tty module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tty.py"
  notes:
    - "This spec extends tty.zspec.zsdl, tty_extra.zspec.zsdl, and tty_extra2.zspec.zsdl."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "tty.__name__ == 'tty' is the module-level identity check — not covered in prior specs."
    - "tty.__package__ == '' — tty is a top-level module with no parent package."
    - "cfmakeraw and cfmakecbreak were added in Python 3.12; not present in tty_extra or tty_extra2."
    - "cfmakeraw.__module__ == 'tty' and cfmakecbreak.__module__ == 'tty' — pure Python functions."
    - "cfmakeraw.__qualname__ == 'cfmakeraw' — top-level function, qualname matches name."
    - "CFLAG + 1 == LFLAG is a structural relationship (CFLAG=2, LFLAG=3) not pinned in prior specs."
    - "LFLAG < ISPEED (3 < 4) — ordering relationship not previously checked."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level identity — tty.__name__ == 'tty'
# This is the module object's own __name__, not a function attribute.
# Not covered in any prior tty spec.
# ---------------------------------------------------------------------------

invariant tty_extra3.module.name:
  description: "tty module's __name__ attribute == 'tty'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["tty"]
  expected: true

invariant tty_extra3.module.package:
  description: "tty.__package__ == '' — tty is a top-level module with no parent package"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# cfmakeraw and cfmakecbreak — added in Python 3.12
# Not present in tty.zspec.zsdl, tty_extra.zspec.zsdl, or tty_extra2.zspec.zsdl.
# ---------------------------------------------------------------------------

invariant tty_extra3.cfmakeraw.name:
  description: "tty.cfmakeraw.__name__ == 'cfmakeraw' — Python 3.12+ helper function"
  category: function_names
  kind: python_call_eq
  function: cfmakeraw.__name__.__eq__
  args: ["cfmakeraw"]
  expected: true

invariant tty_extra3.cfmakecbreak.name:
  description: "tty.cfmakecbreak.__name__ == 'cfmakecbreak' — Python 3.12+ helper function"
  category: function_names
  kind: python_call_eq
  function: cfmakecbreak.__name__.__eq__
  args: ["cfmakecbreak"]
  expected: true

invariant tty_extra3.cfmakeraw.module:
  description: "tty.cfmakeraw.__module__ == 'tty'"
  category: module_affiliation
  kind: python_call_eq
  function: cfmakeraw.__module__.__eq__
  args: ["tty"]
  expected: true

invariant tty_extra3.cfmakecbreak.module:
  description: "tty.cfmakecbreak.__module__ == 'tty'"
  category: module_affiliation
  kind: python_call_eq
  function: cfmakecbreak.__module__.__eq__
  args: ["tty"]
  expected: true

invariant tty_extra3.cfmakeraw.qualname:
  description: "tty.cfmakeraw.__qualname__ == 'cfmakeraw' — top-level function, qualname matches name"
  category: function_names
  kind: python_call_eq
  function: cfmakeraw.__qualname__.__eq__
  args: ["cfmakeraw"]
  expected: true

invariant tty_extra3.cfmakecbreak.qualname:
  description: "tty.cfmakecbreak.__qualname__ == 'cfmakecbreak' — top-level function, qualname matches name"
  category: function_names
  kind: python_call_eq
  function: cfmakecbreak.__qualname__.__eq__
  args: ["cfmakecbreak"]
  expected: true

table tty_extra3.cfmake_function_types:
  kind: python_call_eq
  category: function_types
  id_prefix: cftype

  columns: [id, function, args, expected]
  rows:
    - [cfmakeraw,    cfmakeraw.__class__.__name__.__eq__,    ["function"], true]
    - [cfmakecbreak, cfmakecbreak.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# Structural relationships between index constants
# tty_extra pins individual values; these cross-constant checks are new.
# CFLAG=2, LFLAG=3: CFLAG + 1 == LFLAG
# LFLAG=3, ISPEED=4: LFLAG < ISPEED
# ---------------------------------------------------------------------------

invariant tty_extra3.CFLAG.plus_one_is_LFLAG:
  description: "tty.CFLAG + 1 == tty.LFLAG — CFLAG(2) and LFLAG(3) are adjacent indices"
  category: constants
  kind: python_call_eq
  function: CFLAG.__add__
  args: [1]
  method: __eq__
  method_args: [3]
  expected: true

invariant tty_extra3.LFLAG.less_than_ISPEED:
  description: "tty.LFLAG < tty.ISPEED — LFLAG(3) precedes ISPEED(4) in the termios list"
  category: constants
  kind: python_call_eq
  function: LFLAG.__lt__
  args: [4]
  expected: true
