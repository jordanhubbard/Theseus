spec: threading_extra31
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra30.zspec.zsdl."
    - "Prior specs covered: Thread.__name__/__module__/__qualname__, Lock/RLock/Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier class names/modules, current_thread/main_thread/active_count/__name__, TIMEOUT_MAX, local().__class__.__name__, threading.excepthook/__name__, class __module__/__name__/__qualname__ length tables, Lock.__module__.__len__()==7 (C extension), current_thread/__name__.__len__()=14, main_thread/__name__.__len__()=11."
    - "This spec covers: Thread method __qualname__.__len__() for start/run/join/is_alive; Thread.daemon property fget __qualname__.__len__(); Event method __qualname__.__len__() for set/clear/wait/is_set; Condition method __qualname__.__len__() for wait/notify/notify_all/wait_for; Semaphore method __qualname__.__len__() for acquire/release; class __bases__[0].__name__ for Thread/Event/Semaphore/BoundedSemaphore/Timer; class __mro__.__len__() for Thread/Event/Semaphore/BoundedSemaphore."
    - "Thread.start.__qualname__ == 'Thread.start' — length 12."
    - "Thread.run.__qualname__ == 'Thread.run' — length 10."
    - "Thread.join.__qualname__ == 'Thread.join' — length 11."
    - "Thread.is_alive.__qualname__ == 'Thread.is_alive' — length 15."
    - "Thread.daemon property fget.__qualname__ == 'Thread.daemon' — length 13."
    - "Event.set.__qualname__ == 'Event.set' — length 9."
    - "Event.clear.__qualname__ == 'Event.clear' — length 11."
    - "Event.wait.__qualname__ == 'Event.wait' — length 10."
    - "Event.is_set.__qualname__ == 'Event.is_set' — length 12."
    - "Condition.wait.__qualname__ == 'Condition.wait' — length 14."
    - "Condition.notify.__qualname__ == 'Condition.notify' — length 16."
    - "Condition.notify_all.__qualname__ == 'Condition.notify_all' — length 20."
    - "Condition.wait_for.__qualname__ == 'Condition.wait_for' — length 18."
    - "Semaphore.acquire.__qualname__ == 'Semaphore.acquire' — length 17."
    - "Semaphore.release.__qualname__ == 'Semaphore.release' — length 17."
    - "Thread.__bases__[0].__name__ == 'object' — Thread inherits directly from object."
    - "Event.__bases__[0].__name__ == 'object' — Event inherits directly from object."
    - "Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits directly from object."
    - "BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore extends Semaphore."
    - "Timer.__bases__[0].__name__ == 'Thread' — Timer extends Thread."
    - "Thread.__mro__.__len__() == 2 — [Thread, object]."
    - "BoundedSemaphore.__mro__.__len__() == 3 — [BoundedSemaphore, Semaphore, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread method __qualname__ length table — extra31 namespace
#
# threading.Thread methods carry 'Thread.' as their __qualname__ prefix.
# The daemon attribute is a property; its fget also has __qualname__:
#   Thread.start.__qualname__          == 'Thread.start'    (12)
#   Thread.run.__qualname__            == 'Thread.run'      (10)
#   Thread.join.__qualname__           == 'Thread.join'     (11)
#   Thread.is_alive.__qualname__       == 'Thread.is_alive' (15)
# No prior spec has measured __qualname__.__len__() for Thread instance methods.
# ---------------------------------------------------------------------------

table threading_extra31.thread_method_qualname_lengths:
  description: "threading.Thread method __qualname__ lengths for start/run/join/is_alive in extra31 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: threadmqualnamelen31

  columns: [id, function, args, expected]
  rows:
    - [start,    Thread.start.__qualname__.__len__,    [], 12]
    - [run,      Thread.run.__qualname__.__len__,      [], 10]
    - [join,     Thread.join.__qualname__.__len__,     [], 11]
    - [is_alive, Thread.is_alive.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# Event method __qualname__ length table — extra31 namespace
#
# threading.Event methods carry 'Event.' as their __qualname__ prefix:
#   Event.set.__qualname__    == 'Event.set'    (9)
#   Event.clear.__qualname__  == 'Event.clear'  (11)
#   Event.wait.__qualname__   == 'Event.wait'   (10)
#   Event.is_set.__qualname__ == 'Event.is_set' (12)
# No prior spec has measured __qualname__.__len__() for Event instance methods.
# ---------------------------------------------------------------------------

table threading_extra31.event_method_qualname_lengths:
  description: "threading.Event method __qualname__ lengths for set/clear/wait/is_set in extra31 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: eventmqualnamelen31

  columns: [id, function, args, expected]
  rows:
    - [set,    Event.set.__qualname__.__len__,    [], 9]
    - [clear,  Event.clear.__qualname__.__len__,  [], 11]
    - [wait,   Event.wait.__qualname__.__len__,   [], 10]
    - [is_set, Event.is_set.__qualname__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Condition method __qualname__ length table — extra31 namespace
#
# threading.Condition methods carry 'Condition.' as their __qualname__ prefix.
# Note: Condition does not expose acquire/release directly (no such attrs).
#   Condition.wait.__qualname__       == 'Condition.wait'       (14)
#   Condition.notify.__qualname__     == 'Condition.notify'     (16)
#   Condition.notify_all.__qualname__ == 'Condition.notify_all' (20)
#   Condition.wait_for.__qualname__   == 'Condition.wait_for'   (18)
# ---------------------------------------------------------------------------

table threading_extra31.condition_method_qualname_lengths:
  description: "threading.Condition method __qualname__ lengths for wait/notify/notify_all/wait_for in extra31 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: condmqualnamelen31

  columns: [id, function, args, expected]
  rows:
    - [wait,       Condition.wait.__qualname__.__len__,       [], 14]
    - [notify,     Condition.notify.__qualname__.__len__,     [], 16]
    - [notify_all, Condition.notify_all.__qualname__.__len__, [], 20]
    - [wait_for,   Condition.wait_for.__qualname__.__len__,   [], 18]

# ---------------------------------------------------------------------------
# Class __bases__[0].__name__ table — extra31 namespace
#
# threading class hierarchy via __bases__[0].__name__:
#   Thread.__bases__[0].__name__            == 'object'    — direct object subclass
#   Event.__bases__[0].__name__             == 'object'    — direct object subclass
#   Semaphore.__bases__[0].__name__         == 'object'    — direct object subclass
#   BoundedSemaphore.__bases__[0].__name__  == 'Semaphore' — extends Semaphore
#   Timer.__bases__[0].__name__             == 'Thread'    — extends Thread
# BoundedSemaphore and Timer both extend existing threading classes rather
# than object, while the others are flat hierarchies.
# ---------------------------------------------------------------------------

table threading_extra31.class_bases_names:
  description: "threading class __bases__[0].__name__ for Thread/Event/Semaphore/BoundedSemaphore/Timer in extra31 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: clsbasename31

  columns: [id, function, args, expected]
  rows:
    - [Thread,           "Thread.__bases__[0].__name__.__eq__",           ["object"],    true]
    - [Event,            "Event.__bases__[0].__name__.__eq__",            ["object"],    true]
    - [Semaphore,        "Semaphore.__bases__[0].__name__.__eq__",        ["object"],    true]
    - [BoundedSemaphore, "BoundedSemaphore.__bases__[0].__name__.__eq__", ["Semaphore"], true]
    - [Timer,            "Timer.__bases__[0].__name__.__eq__",            ["Thread"],    true]

# ---------------------------------------------------------------------------
# Semaphore method __qualname__ length — extra31 standalone invariant
#
# threading.Semaphore.acquire and release share the same __qualname__ length
# (17) since 'Semaphore.' (10) + 'acquire'/'release' (7 chars each) = 17.
# This invariant confirms Semaphore.acquire.__qualname__.__len__() == 17.
# ---------------------------------------------------------------------------

invariant threading_extra31.Semaphore.acquire_qualname_len:
  description: "threading.Semaphore.acquire.__qualname__.__len__() == 17 — 'Semaphore.acquire' has seventeen characters"
  category: method_names
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# BoundedSemaphore.__bases__[0].__name__ string equality — extra31 standalone
#
# Confirms that BoundedSemaphore subclasses Semaphore (not object), making
# it the only standard threading sync class with a non-object base class
# other than Timer and BoundedSemaphore itself.
# ---------------------------------------------------------------------------

invariant threading_extra31.BoundedSemaphore.base_name_eq:
  description: "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore extends Semaphore"
  category: class_hierarchy
  kind: python_call_eq
  function: BoundedSemaphore.__bases__[0].__name__.__eq__
  args: ["Semaphore"]
  expected: true

# ---------------------------------------------------------------------------
# Timer.__bases__[0].__name__ string equality — extra31 standalone invariant
#
# Confirms that Timer subclasses Thread, which means Timer has MRO length 3
# ([Timer, Thread, object]) rather than 2 like standalone threading classes.
# ---------------------------------------------------------------------------

invariant threading_extra31.Timer.base_name_eq:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer extends Thread"
  category: class_hierarchy
  kind: python_call_eq
  function: Timer.__bases__[0].__name__.__eq__
  args: ["Thread"]
  expected: true
