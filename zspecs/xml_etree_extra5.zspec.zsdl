spec: xml_etree_extra5
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xml.etree.elementtree.html — Python xml.etree.ElementTree documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py"
    - "elementtree.zspec.zsdl — covers fromstring tag/text/attrib/get/findtext, Element constructor, tostring, SubElement, ParseError raise behavior"
    - "xml_parse.zspec.zsdl — covers ElementTree/XMLParser/ParseError __module__, ParseError base, XMLParser feed/close, ElementTree __name__/bases"
    - "xml_extra.zspec.zsdl — covers Element/ElementTree/SubElement/ParseError/parse/fromstring/tostring __name__; ParseError base; fromstring result class"
    - "xml_extra2.zspec.zsdl — covers fromstring tag/attrib; Element tag/attrib; tostring result class; ParseError class_name; VERSION/XML_VERSION"
    - "xml_extra3.zspec.zsdl — covers Element/ElementTree/XMLParser/ParseError __qualname__; function __qualname__ (tostring/indent/iterparse/parse); Element/XMLParser base == 'object'; function type checks; ParseError/Element is_type; Element.__module__; XMLParser.__module__"
    - "xml_etree_extra.zspec.zsdl — covers Element/__name__, SubElement/__name__, parse/fromstring/tostring/indent/iterparse/register_namespace __name__, Comment/ProcessingInstruction __name__, ParseError name/base, fromstring result class, Element.__module__ is str"
    - "xml_etree_extra2.zspec.zsdl — covers SubElement/__qualname__, fromstring/__qualname__, SubElement/fromstring/tostring/parse/indent/iterparse __module__, ParseError.__module__, SubElement callable check"
    - "xml_etree_extra3.zspec.zsdl — covers register_namespace/__qualname__/__module__, Comment/__qualname__/__module__, ProcessingInstruction/__qualname__/__module__, fromstring text/tag with text, ElementTree is_type, fromstring class_name, register_namespace class_name"
    - "xml_etree_extra4.zspec.zsdl — covers Element instance method __name__ and __qualname__ (get/set/find/findall/append/remove/iter/keys/items)"
  notes:
    - "This spec extends all prior xml.etree.ElementTree specs."
    - "Focus: ElementTree instance method __name__ and __qualname__; XMLParser method __qualname__."
    - "No prior spec checks the __name__ of instance methods on ElementTree (write/find/findall/findtext/getroot/iter)."
    - "No prior spec checks __qualname__ for ElementTree's instance methods."
    - "xml_parse.zspec.zsdl tests XMLParser.feed and XMLParser.close behavior (calling them) but not their __name__ or __qualname__ attributes."
    - "ElementTree.write.__name__ == 'write' — serialises the tree to a file-like object."
    - "ElementTree.find.__name__ == 'find' — finds first subelement matching a path in the tree."
    - "ElementTree.findall.__name__ == 'findall' — finds all subelements matching a path."
    - "ElementTree.findtext.__name__ == 'findtext' — finds text of first subelement matching a path."
    - "ElementTree.getroot.__name__ == 'getroot' — returns the root element of the tree."
    - "ElementTree.iter.__name__ == 'iter' — creates a tree iterator over all elements."
    - "XMLParser.feed.__name__ == 'feed' — feeds data to the parser."
    - "XMLParser.close.__name__ == 'close' — closes the parser and returns the root element."
    - "All __qualname__ values follow the 'ClassName.method_name' pattern."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ElementTree instance method __name__ checks
#
# xml_etree_extra4 covers Element instance method __name__ values.
# No prior spec verifies __name__ for ElementTree's own instance methods.
# ---------------------------------------------------------------------------

table xml_etree_extra5.elementtree_method_names:
  kind: python_call_eq
  category: function_names
  id_prefix: etmname

  columns: [id, function, args, expected]
  rows:
    - [write,    ElementTree.write.__name__.__eq__,    ["write"],    true]
    - [find,     ElementTree.find.__name__.__eq__,     ["find"],     true]
    - [findall,  ElementTree.findall.__name__.__eq__,  ["findall"],  true]
    - [findtext, ElementTree.findtext.__name__.__eq__, ["findtext"], true]
    - [getroot,  ElementTree.getroot.__name__.__eq__,  ["getroot"],  true]
    - [iter,     ElementTree.iter.__name__.__eq__,     ["iter"],     true]

# ---------------------------------------------------------------------------
# ElementTree instance method __qualname__ checks
#
# xml_etree_extra4 checks Element method qualnames ('Element.method').
# No prior spec checks ElementTree method qualnames ('ElementTree.method').
# ---------------------------------------------------------------------------

table xml_etree_extra5.elementtree_method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: etmqname

  columns: [id, function, args, expected]
  rows:
    - [write,    ElementTree.write.__qualname__.__eq__,    ["ElementTree.write"],    true]
    - [find,     ElementTree.find.__qualname__.__eq__,     ["ElementTree.find"],     true]
    - [findall,  ElementTree.findall.__qualname__.__eq__,  ["ElementTree.findall"],  true]
    - [findtext, ElementTree.findtext.__qualname__.__eq__, ["ElementTree.findtext"], true]
    - [getroot,  ElementTree.getroot.__qualname__.__eq__,  ["ElementTree.getroot"],  true]
    - [iter,     ElementTree.iter.__qualname__.__eq__,     ["ElementTree.iter"],     true]

# ---------------------------------------------------------------------------
# XMLParser instance method __name__ and __qualname__ checks
#
# xml_parse.zspec.zsdl calls XMLParser.feed() and XMLParser.close() to test
# behavior. No prior spec checks the __name__ or __qualname__ of these
# methods as attributes.
# ---------------------------------------------------------------------------

invariant xml_etree_extra5.xmlparser.feed.name:
  description: "XMLParser.feed.__name__ == 'feed'"
  category: function_names
  kind: python_call_eq
  function: XMLParser.feed.__name__.__eq__
  args: ["feed"]
  expected: true

invariant xml_etree_extra5.xmlparser.close.name:
  description: "XMLParser.close.__name__ == 'close'"
  category: function_names
  kind: python_call_eq
  function: XMLParser.close.__name__.__eq__
  args: ["close"]
  expected: true

invariant xml_etree_extra5.xmlparser.feed.qualname:
  description: "XMLParser.feed.__qualname__ == 'XMLParser.feed'"
  category: qualnames
  kind: python_call_eq
  function: XMLParser.feed.__qualname__.__eq__
  args: ["XMLParser.feed"]
  expected: true

invariant xml_etree_extra5.xmlparser.close.qualname:
  description: "XMLParser.close.__qualname__ == 'XMLParser.close'"
  category: qualnames
  kind: python_call_eq
  function: XMLParser.close.__qualname__.__eq__
  args: ["XMLParser.close"]
  expected: true
