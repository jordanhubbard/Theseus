spec: collections_extra2
version: ">=3.3"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "Python collections documentation — https://docs.python.org/3/library/collections.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec covers collections invariants not already in collections.zspec.zsdl, collections_extra.zspec.zsdl, or collections_ordereddict.zspec.zsdl."
    - "OrderedDict.__name__ == 'OrderedDict' — ordered mapping preserving insertion order."
    - "Counter.__name__ == 'Counter' — multiset / frequency counter."
    - "defaultdict.__name__ == 'defaultdict' — dict subclass with default factory."
    - "ChainMap.__name__ == 'ChainMap' — groups multiple dicts into a single view."
    - "Counter({'a': 3, 'b': 1}).most_common(1) returns [('a', 3)]; index [0][0] == 'a'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# OrderedDict — class name
# ---------------------------------------------------------------------------

invariant collections_extra2.OrderedDict.name:
  description: "collections.OrderedDict.__name__ == 'OrderedDict'"
  category: class_identity
  kind: python_call_eq
  function: OrderedDict.__name__.__eq__
  args: ["OrderedDict"]
  expected: true

# ---------------------------------------------------------------------------
# Counter — class name
# ---------------------------------------------------------------------------

invariant collections_extra2.Counter.name:
  description: "collections.Counter.__name__ == 'Counter'"
  category: class_identity
  kind: python_call_eq
  function: Counter.__name__.__eq__
  args: ["Counter"]
  expected: true

# ---------------------------------------------------------------------------
# defaultdict — class name
# ---------------------------------------------------------------------------

invariant collections_extra2.defaultdict.name:
  description: "collections.defaultdict.__name__ == 'defaultdict'"
  category: class_identity
  kind: python_call_eq
  function: defaultdict.__name__.__eq__
  args: ["defaultdict"]
  expected: true

# ---------------------------------------------------------------------------
# ChainMap — class name
# ---------------------------------------------------------------------------

invariant collections_extra2.ChainMap.name:
  description: "collections.ChainMap.__name__ == 'ChainMap'"
  category: class_identity
  kind: python_call_eq
  function: ChainMap.__name__.__eq__
  args: ["ChainMap"]
  expected: true

# ---------------------------------------------------------------------------
# Counter.most_common — top-1 result from a dict-initialized Counter
#
# Counter({'a': 3, 'b': 1}).most_common(1) returns exactly one element.
# The length is 1, confirming that most_common correctly limits to the top entry.
# The element 'a' has the highest count (3 > 1), so it is the top entry.
# Checked with method_chain: __len__ because the harness calls method_chain with
# no arguments, making attribute/zero-arg methods the only viable chain targets.
# ---------------------------------------------------------------------------

invariant collections_extra2.Counter.most_common_length:
  description: "Counter({'a': 3, 'b': 1}).most_common(1) has length 1"
  category: counter
  kind: python_call_eq
  function: Counter
  args: [{"a": 3, "b": 1}]
  method: most_common
  method_args: [1]
  method_chain: __len__
  expected: 1
