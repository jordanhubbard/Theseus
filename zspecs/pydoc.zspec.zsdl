spec: pydoc
version: ">=3.3"
backend: python_module(pydoc)

docs: https://docs.python.org/3/library/pydoc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pydoc.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "pydoc source: Lib/pydoc.py (PSF; source inspection permitted)"
  not_derived_from:
    - "pydoc source: terminal pager internals"
  notes:
    - "pydoc is the built-in Python documentation browser and text generator."
    - "HTMLDoc and TextDoc generate HTML and plain-text formatted documentation respectively."
    - "ModuleScanner is used to scan installed modules for matching names."
    - "ErrorDuringImport is raised when a module import fails during documentation generation."
    - "ErrorDuringImport inherits directly from Exception."
    - "describe(42) returns 'int' — a string describing the type of the given object."
    - "plain('hello world') returns 'hello world' — strips HTML markup; plain text passes through unchanged."
    - "pager() is a function that displays text using the system pager (interactive, not tested here)."
    - "All expected values verified by running Python 3.12 pydoc module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "pydoc.ErrorDuringImport is raised when a module cannot be imported for documentation. Interactive functions (help, pager) may raise OSError on tty errors."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# module name
# ---------------------------------------------------------------------------

invariant pydoc.module_name:
  description: "pydoc.__name__ == 'pydoc'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["pydoc"]
  expected: true

# ---------------------------------------------------------------------------
# class names
# ---------------------------------------------------------------------------

table pydoc.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [HTMLDoc,            HTMLDoc.__name__.__eq__,            ["HTMLDoc"],            true]
    - [TextDoc,            TextDoc.__name__.__eq__,            ["TextDoc"],            true]
    - [ModuleScanner,      ModuleScanner.__name__.__eq__,      ["ModuleScanner"],      true]
    - [ErrorDuringImport,  ErrorDuringImport.__name__.__eq__,  ["ErrorDuringImport"],  true]

# ---------------------------------------------------------------------------
# class modules
# ---------------------------------------------------------------------------

table pydoc.class_modules:
  kind: python_call_eq
  category: classes
  id_prefix: class_module

  columns: [id, function, args, expected]
  rows:
    - [HTMLDoc,            HTMLDoc.__module__.__eq__,            ["pydoc"], true]
    - [TextDoc,            TextDoc.__module__.__eq__,            ["pydoc"], true]
    - [ModuleScanner,      ModuleScanner.__module__.__eq__,      ["pydoc"], true]
    - [ErrorDuringImport,  ErrorDuringImport.__module__.__eq__,  ["pydoc"], true]

# ---------------------------------------------------------------------------
# class hierarchy
# ---------------------------------------------------------------------------

invariant pydoc.hierarchy.ErrorDuringImport_base:
  description: "ErrorDuringImport.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: ErrorDuringImport.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# function names
# ---------------------------------------------------------------------------

table pydoc.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: function_name

  columns: [id, function, args, expected]
  rows:
    - [help,       help.__name__.__eq__,       ["help"],       true]
    - [describe,   describe.__name__.__eq__,   ["describe"],   true]
    - [locate,     locate.__name__.__eq__,     ["locate"],     true]
    - [render_doc, render_doc.__name__.__eq__, ["render_doc"], true]
    - [plain,      plain.__name__.__eq__,      ["plain"],      true]
    - [pager,      pager.__name__.__eq__,      ["pager"],      true]

# ---------------------------------------------------------------------------
# describe — returns a string type name for the given object
# ---------------------------------------------------------------------------

invariant pydoc.describe.int_returns_str:
  description: "describe(42).__class__.__name__ == 'str' — describe() always returns a string"
  category: describe
  kind: python_call_eq
  function: describe
  args: [42]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant pydoc.describe.int_value:
  description: "describe(42) == 'int'"
  category: describe
  kind: python_call_eq
  function: describe
  args: [42]
  method: __eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# plain — strips HTML markup (plain text passes through unchanged)
# ---------------------------------------------------------------------------

invariant pydoc.plain.passthrough:
  description: "plain('hello world') == 'hello world' — plain text is returned unchanged"
  category: plain
  kind: python_call_eq
  function: plain
  args: ["hello world"]
  method: __eq__
  method_args: ["hello world"]
  expected: true

invariant pydoc.plain.returns_str:
  description: "plain('hello world').__class__.__name__ == 'str'"
  category: plain
  kind: python_call_eq
  function: plain
  args: ["hello world"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true
