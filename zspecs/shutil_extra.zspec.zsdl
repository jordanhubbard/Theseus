spec: shutil_extra
version: ">=3.0"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil module documentation"
    - "Test vectors verified by running Python 3.12 shutil module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
  notes:
    - "This spec covers module membership and base-class hierarchy not present in shutil.zspec.zsdl."
    - "copy.__module__ == 'shutil' — the function is defined in the shutil module."
    - "shutil.Error.__bases__[0].__name__ == 'OSError' — Error inherits from OSError."
    - "get_archive_formats() returns a list; get_unpack_formats() returns a list."
    - "All function __name__ checks here are in addition to those in shutil.zspec.zsdl."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks — __name__ attributes for public shutil functions
# ---------------------------------------------------------------------------

invariant shutil_extra.function_names.copy:
  description: "shutil.copy.__name__ == 'copy'"
  category: function_names
  kind: python_call_eq
  function: copy.__name__.__eq__
  args: ["copy"]
  expected: true

invariant shutil_extra.function_names.copy2:
  description: "shutil.copy2.__name__ == 'copy2'"
  category: function_names
  kind: python_call_eq
  function: copy2.__name__.__eq__
  args: ["copy2"]
  expected: true

invariant shutil_extra.function_names.copyfile:
  description: "shutil.copyfile.__name__ == 'copyfile'"
  category: function_names
  kind: python_call_eq
  function: copyfile.__name__.__eq__
  args: ["copyfile"]
  expected: true

invariant shutil_extra.function_names.copyfileobj:
  description: "shutil.copyfileobj.__name__ == 'copyfileobj'"
  category: function_names
  kind: python_call_eq
  function: copyfileobj.__name__.__eq__
  args: ["copyfileobj"]
  expected: true

invariant shutil_extra.function_names.copytree:
  description: "shutil.copytree.__name__ == 'copytree'"
  category: function_names
  kind: python_call_eq
  function: copytree.__name__.__eq__
  args: ["copytree"]
  expected: true

invariant shutil_extra.function_names.rmtree:
  description: "shutil.rmtree.__name__ == 'rmtree'"
  category: function_names
  kind: python_call_eq
  function: rmtree.__name__.__eq__
  args: ["rmtree"]
  expected: true

invariant shutil_extra.function_names.move:
  description: "shutil.move.__name__ == 'move'"
  category: function_names
  kind: python_call_eq
  function: move.__name__.__eq__
  args: ["move"]
  expected: true

invariant shutil_extra.function_names.make_archive:
  description: "shutil.make_archive.__name__ == 'make_archive'"
  category: function_names
  kind: python_call_eq
  function: make_archive.__name__.__eq__
  args: ["make_archive"]
  expected: true

invariant shutil_extra.function_names.unpack_archive:
  description: "shutil.unpack_archive.__name__ == 'unpack_archive'"
  category: function_names
  kind: python_call_eq
  function: unpack_archive.__name__.__eq__
  args: ["unpack_archive"]
  expected: true

invariant shutil_extra.function_names.disk_usage:
  description: "shutil.disk_usage.__name__ == 'disk_usage'"
  category: function_names
  kind: python_call_eq
  function: disk_usage.__name__.__eq__
  args: ["disk_usage"]
  expected: true

invariant shutil_extra.function_names.which:
  description: "shutil.which.__name__ == 'which'"
  category: function_names
  kind: python_call_eq
  function: which.__name__.__eq__
  args: ["which"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership — copy.__module__ == 'shutil'
# ---------------------------------------------------------------------------

invariant shutil_extra.module.copy:
  description: "shutil.copy.__module__ == 'shutil'"
  category: module
  kind: python_call_eq
  function: copy.__module__.__eq__
  args: ["shutil"]
  expected: true

# ---------------------------------------------------------------------------
# get_archive_formats — returns a list
# ---------------------------------------------------------------------------

invariant shutil_extra.archive_formats.returns_list:
  description: "shutil.get_archive_formats().__class__.__name__ == 'list'"
  category: archive_formats
  kind: python_call_eq
  function: get_archive_formats().__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# get_unpack_formats — returns a list
# ---------------------------------------------------------------------------

invariant shutil_extra.unpack_formats.returns_list:
  description: "shutil.get_unpack_formats().__class__.__name__ == 'list'"
  category: unpack_formats
  kind: python_call_eq
  function: get_unpack_formats().__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class identity — Error name and base class
# ---------------------------------------------------------------------------

invariant shutil_extra.exceptions.error_name:
  description: "shutil.Error.__name__ == 'Error'"
  category: exceptions
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant shutil_extra.exceptions.error_base:
  description: "shutil.Error.__bases__[0].__name__ == 'OSError'"
  category: exceptions
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"
