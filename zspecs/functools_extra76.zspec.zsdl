spec: functools_extra76
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra75.zspec.zsdl."
    - "Wave 237 theme: functools function __code__ attribute deep chains — first __code__ coverage for functools."
    - "partial.__class__.__name__ == 'type' — partial is a C extension type defined in Modules/_functoolsmodule.c, so its __class__ is the built-in type. Verified with Python 3.14.3."
    - "lru_cache.__code__.co_name == 'lru_cache' — lru_cache is a pure-Python function in Lib/functools.py; co_name records the name given in the def statement. Verified with Python 3.14.3."
    - "lru_cache.__code__.co_argcount == 2 — lru_cache is defined as 'def lru_cache(maxsize=128, typed=False)' with two positional parameters; co_argcount counts positional parameters only. Verified with Python 3.14.3."
    - "cache.__code__.co_name == 'cache' — cache is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "cache.__code__.co_argcount == 1 — cache is defined as 'def cache(user_function)' with one positional parameter. Verified with Python 3.14.3."
    - "singledispatch.__code__.co_name == 'singledispatch' — singledispatch is a pure-Python function in Lib/functools.py. Verified with Python 3.14.3."
    - "singledispatch.__code__.co_argcount == 1 — singledispatch is defined as 'def singledispatch(func)' with one positional parameter. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partial class identity — extra76
#
# Wave 237 theme: partial is a C extension type.
#
# functools.partial is implemented in C (_functoolsmodule.c). As a C type
# its __class__ is the built-in type, and __class__.__name__ == 'type'.
#
# partial.__class__.__name__ == 'type'
#
# No prior functools spec checks partial.__class__.__name__ via functoolsmore76. New to extra76.
# ---------------------------------------------------------------------------

table functools_extra76.partial_class_identity:
  description: "partial.__class__.__name__=='type' — partial is a C extension type; wave 237 partial class identity; new to extra76"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore76

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_name_eq_type,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C extension type defined in Modules/_functoolsmodule.c that creates a new partial object which when called will behave like func called with the positional arguments args and keyword arguments keywords; C extension types created via PyType_Ready() use the built-in type as their metaclass; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior functools spec checks partial.__class__.__name__ via functoolsmore76; new to extra76"]

# ---------------------------------------------------------------------------
# lru_cache __code__ attributes — extra76
#
# Wave 237 theme: lru_cache is a pure-Python function with __code__.
#
# functools.lru_cache is defined in Lib/functools.py as:
#   def lru_cache(maxsize=128, typed=False):
#
# Its __code__ object has:
#   co_name      == 'lru_cache'
#   co_argcount  == 2   (maxsize and typed are both positional, not keyword-only)
#
# No prior functools spec checks lru_cache.__code__ attributes via functoolsmore76. New to extra76.
# ---------------------------------------------------------------------------

table functools_extra76.lru_cache_code:
  description: "lru_cache.__code__.co_name=='lru_cache', co_argcount==2; wave 237 lru_cache __code__ attributes; new to extra76"
  kind: python_call_eq
  category: code_attributes
  id_prefix: functoolsmore76

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_co_name_eq_lru_cache,
       lru_cache.__code__.co_name.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — lru_cache is a pure-Python function in Lib/functools.py defined with 'def lru_cache(maxsize=128, typed=False):'; the code object's co_name attribute stores the name from the def statement which is 'lru_cache' (9 chars); str.__eq__('lru_cache') returns True; no prior functools spec checks lru_cache.__code__.co_name via functoolsmore76; new to extra76"]
    - [lru_cache_co_argcount_eq_2,
       lru_cache.__code__.co_argcount.__eq__,
       [2],
       true,
       "functools.lru_cache.__code__.co_argcount.__eq__(2) == True — lru_cache is defined as 'def lru_cache(maxsize=128, typed=False):' with two positional parameters maxsize and typed (both have defaults but neither is keyword-only); co_argcount counts positional parameters including those with defaults but excluding keyword-only, *args, and **kwargs; for lru_cache co_argcount == 2; int.__eq__(2) returns True; no prior functools spec checks lru_cache.__code__.co_argcount via functoolsmore76; new to extra76"]

# ---------------------------------------------------------------------------
# cache __code__ attributes — extra76
#
# Wave 237 theme: cache is a pure-Python function with __code__.
#
# functools.cache was added in Python 3.9 as a simple unbounded cache.
# It is defined in Lib/functools.py as:
#   def cache(user_function):
#
# Its __code__ object has:
#   co_name      == 'cache'
#   co_argcount  == 1   (only user_function is positional)
#
# No prior functools spec checks cache.__code__ attributes via functoolsmore76. New to extra76.
# ---------------------------------------------------------------------------

table functools_extra76.cache_code:
  description: "cache.__code__.co_name=='cache', co_argcount==1; wave 237 cache __code__ attributes; new to extra76"
  kind: python_call_eq
  category: code_attributes
  id_prefix: functoolsmore76

  columns: [id, function, args, expected, description]
  rows:
    - [cache_co_name_eq_cache,
       cache.__code__.co_name.__eq__,
       ["cache"],
       true,
       "functools.cache.__code__.co_name.__eq__('cache') == True — cache is a pure-Python function in Lib/functools.py added in Python 3.9 as an unbounded memoization decorator; it is defined as 'def cache(user_function):' so the code object's co_name is 'cache' (5 chars); str.__eq__('cache') returns True; no prior functools spec checks cache.__code__.co_name via functoolsmore76; new to extra76"]
    - [cache_co_argcount_eq_1,
       cache.__code__.co_argcount.__eq__,
       [1],
       true,
       "functools.cache.__code__.co_argcount.__eq__(1) == True — cache is defined as 'def cache(user_function):' with exactly one positional parameter user_function and no keyword-only, *args, or **kwargs parameters; co_argcount counts positional parameters only and equals 1; int.__eq__(1) returns True; no prior functools spec checks cache.__code__.co_argcount via functoolsmore76; new to extra76"]

# ---------------------------------------------------------------------------
# singledispatch __code__ attributes — extra76
#
# Wave 237 theme: singledispatch is a pure-Python function with __code__.
#
# functools.singledispatch is defined in Lib/functools.py as:
#   def singledispatch(func):
#
# Its __code__ object has:
#   co_name      == 'singledispatch'
#   co_argcount  == 1   (only func is positional)
#
# No prior functools spec checks singledispatch.__code__ attributes via functoolsmore76. New to extra76.
# ---------------------------------------------------------------------------

table functools_extra76.singledispatch_code:
  description: "singledispatch.__code__.co_name=='singledispatch', co_argcount==1; wave 237 singledispatch __code__ attributes; new to extra76"
  kind: python_call_eq
  category: code_attributes
  id_prefix: functoolsmore76

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_co_name_eq_singledispatch,
       singledispatch.__code__.co_name.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__code__.co_name.__eq__('singledispatch') == True — singledispatch is a pure-Python function in Lib/functools.py that transforms a function into a single-dispatch generic function; it is defined as 'def singledispatch(func):' so the code object's co_name is 'singledispatch' (15 chars); str.__eq__('singledispatch') returns True; no prior functools spec checks singledispatch.__code__.co_name via functoolsmore76; new to extra76"]
    - [singledispatch_co_argcount_eq_1,
       singledispatch.__code__.co_argcount.__eq__,
       [1],
       true,
       "functools.singledispatch.__code__.co_argcount.__eq__(1) == True — singledispatch is defined as 'def singledispatch(func):' with exactly one positional parameter func and no keyword-only, *args, or **kwargs parameters; co_argcount counts positional parameters only and equals 1; int.__eq__(1) returns True; no prior functools spec checks singledispatch.__code__.co_argcount via functoolsmore76; new to extra76"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra76
# ---------------------------------------------------------------------------

invariant functools_extra76.partial_class_type:
  description: "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C extension type whose metaclass is the built-in type; wave 237 partial class identity; new to extra76"
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra76.lru_cache_co_name:
  description: "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — co_name records the name from the def statement; wave 237 lru_cache __code__; new to extra76"
  kind: python_call_eq
  function: lru_cache.__code__.co_name.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra76.lru_cache_co_argcount:
  description: "functools.lru_cache.__code__.co_argcount.__eq__(2) == True — lru_cache(maxsize=128, typed=False) has 2 positional parameters; wave 237 lru_cache __code__; new to extra76"
  kind: python_call_eq
  function: lru_cache.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant functools_extra76.cache_co_argcount:
  description: "functools.cache.__code__.co_argcount.__eq__(1) == True — cache(user_function) has 1 positional parameter; wave 237 cache __code__; new to extra76"
  kind: python_call_eq
  function: cache.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant functools_extra76.singledispatch_co_argcount:
  description: "functools.singledispatch.__code__.co_argcount.__eq__(1) == True — singledispatch(func) has 1 positional parameter; wave 237 singledispatch __code__; new to extra76"
  kind: python_call_eq
  function: singledispatch.__code__.co_argcount.__eq__
  args: [1]
  expected: true
