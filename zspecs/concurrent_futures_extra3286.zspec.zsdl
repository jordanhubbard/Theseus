spec: cf3286
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 666 (cf3286): __iadd__, __isub__, __imul__ dict-presence (in-place augmented assignment) for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__iadd__): all 3 concurrent.futures classes return false for __iadd__. In-place addition (__iadd__, +=) is the augmented assignment variant of __add__. concurrent.futures types define no __add__ (confirmed false in wave 658), so __iadd__ is equally absent. concurrent.futures.Future is a result handle with a PENDING/RUNNING/CANCELLED/FINISHED state machine — not a numeric or collection type; future += n is not a defined Python expression. ThreadPoolExecutor and ProcessPoolExecutor manage worker pools via submit()/map()/shutdown(); in-place addition is not defined for executor objects."
    - "Key finding (__isub__): all 3 concurrent.futures classes return false for __isub__. In-place subtraction (__isub__, -=) is the augmented assignment variant of __sub__. concurrent.futures types define no __sub__ (confirmed false in wave 658), so __isub__ is equally absent. concurrent.futures.Future: a state-machine result handle; future -= n is not a valid Python expression. ThreadPoolExecutor/ProcessPoolExecutor: worker-pool managers with an entirely method-based API; -= is not defined for executor objects."
    - "Key finding (__imul__): all 3 concurrent.futures classes return false for __imul__. In-place multiplication (__imul__, *=) is the augmented assignment variant of __mul__. concurrent.futures types define no __mul__ (confirmed false in wave 658), so __imul__ is equally absent. Note: list defines __imul__ (list *= n repeats in-place), but concurrent.futures types are not list-like and implement no sequence-repetition protocol. concurrent.futures.Future is a state-machine result handle, not a sequence type; future *= n is not a valid Python expression. ThreadPoolExecutor/ProcessPoolExecutor: executor types with no in-place multiplication semantics."
    - "All 9 values in this wave are false. concurrent.futures is a high-level parallel execution API operating entirely through method calls — submit(), map(), result(), cancel(), add_done_callback(), shutdown() — with no arithmetic, in-place augmented assignment, or operator overloading of any kind."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iadd__ dict-presence — operator.contains(Cls.__dict__, '__iadd__')
#
# All 3 concurrent.futures classes return false for __iadd__.
# In-place addition (__iadd__, +=) is the augmented assignment variant of __add__.
# concurrent.futures types define no __add__ (wave 658), so __iadd__ is
#   equally absent.
# concurrent.futures.Future: a result-handle with PENDING/RUNNING/CANCELLED/
#   FINISHED states; future += n is not a valid Python expression.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool managers with an
#   entirely method-based API; in-place addition is not defined for pools.
# ---------------------------------------------------------------------------

table cf3286.iadd:
  description: "concurrent.futures types __iadd__ dict-presence checks; wave 666"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3286

  columns: [id, function, args, expected]
  rows:
    - ["cf3286001", operator.contains, [concurrent.futures.Future.__dict__,              "__iadd__"], false]
    - ["cf3286002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__iadd__"], false]
    - ["cf3286003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__iadd__"], false]

# ---------------------------------------------------------------------------
# __isub__ dict-presence — operator.contains(Cls.__dict__, '__isub__')
#
# All 3 concurrent.futures classes return false for __isub__.
# In-place subtraction (__isub__, -=) is the augmented assignment variant of __sub__.
# concurrent.futures types define no __sub__ (wave 658), so __isub__ is
#   equally absent.
# concurrent.futures.Future: a state-machine result handle; future -= n is
#   not a valid Python expression. Future manages asynchronous results through
#   callbacks and state transitions, not arithmetic operators.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers;
#   in-place subtraction is entirely absent from their API.
# ---------------------------------------------------------------------------

table cf3286.isub:
  description: "concurrent.futures types __isub__ dict-presence checks; wave 666"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3286

  columns: [id, function, args, expected]
  rows:
    - ["cf3286004", operator.contains, [concurrent.futures.Future.__dict__,              "__isub__"], false]
    - ["cf3286005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__isub__"], false]
    - ["cf3286006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__isub__"], false]

# ---------------------------------------------------------------------------
# __imul__ dict-presence — operator.contains(Cls.__dict__, '__imul__')
#
# All 3 concurrent.futures classes return false for __imul__.
# In-place multiplication (__imul__, *=) is the augmented assignment variant of __mul__.
# concurrent.futures types define no __mul__ (wave 658), so __imul__ is
#   equally absent.
# Note: list defines __imul__ (list *= n repeats the list in-place), but
#   concurrent.futures types are not list-like and implement no sequence-
#   repetition protocol.
# concurrent.futures.Future: a state-machine result handle, not a sequence
#   type; future *= n is not a valid Python expression.
# ThreadPoolExecutor/ProcessPoolExecutor: pool managers; executor *= n is
#   not a defined Python operation.
# ---------------------------------------------------------------------------

table cf3286.imul:
  description: "concurrent.futures types __imul__ dict-presence checks; wave 666"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3286

  columns: [id, function, args, expected]
  rows:
    - ["cf3286007", operator.contains, [concurrent.futures.Future.__dict__,              "__imul__"], false]
    - ["cf3286008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__imul__"], false]
    - ["cf3286009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__imul__"], false]

# ---------------------------------------------------------------------------
# combined — __iadd__, __isub__, __imul__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __iadd__: false for all 3 — no in-place addition defined.
# __isub__: false for all 3 — no in-place subtraction defined.
# __imul__: false for all 3 — no in-place multiplication defined.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire
#   public surface is method-based: submit(), map(), result(), cancel(),
#   done(), running(), cancelled(), add_done_callback(), shutdown().
#   Neither forward arithmetic operators (wave 658) nor their in-place
#   augmented assignment variants appear anywhere in the concurrent.futures
#   type hierarchy.
# concurrent.futures.Future note: despite the name, Future is a state-machine
#   result handle — not a numeric or collection type. __iadd__, __isub__,
#   and __imul__ are all absent from its __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate
#   a pool of worker threads or processes; they expose only lifecycle and
#   dispatch methods. No in-place augmented assignment operator overloads
#   are defined.
# list.__imul__ distinction: Python's built-in list defines __imul__ to
#   implement list *= n (repeat in-place). concurrent.futures types are not
#   list subclasses and do not inherit or implement this protocol.
# ---------------------------------------------------------------------------

table cf3286.combined:
  description: "concurrent.futures types combined __iadd__/__isub__/__imul__; wave 666"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3286

  columns: [id, function, args, expected]
  rows:
    - ["cf3286010", operator.contains, [concurrent.futures.Future.__dict__,              "__iadd__"], false]
    - ["cf3286011", operator.contains, [concurrent.futures.Future.__dict__,              "__isub__"], false]
    - ["cf3286012", operator.contains, [concurrent.futures.Future.__dict__,              "__imul__"], false]
    - ["cf3286013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__iadd__"], false]
    - ["cf3286014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__isub__"], false]
    - ["cf3286015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__imul__"], false]
    - ["cf3286016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__iadd__"], false]
    - ["cf3286017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__isub__"], false]
    - ["cf3286018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__imul__"], false]
