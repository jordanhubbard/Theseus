spec: bisect_extra19
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl through bisect_extra18.zspec.zsdl."
    - "bisect_extra12 covers __name__.__len__ for bisect_left/bisect_right/insort_left/insort_right; __module__.__len__ for the same four."
    - "bisect_extra14 covers __name__.__len__ for all 6 callables including aliases."
    - "bisect_extra16 covers __text_signature__.__eq__ for all 6 callables (value check)."
    - "bisect_extra17 covers __qualname__.__len__ for all 6 callables."
    - "bisect_extra18 covers __qualname__.__eq__ for all 6 callables in a unified table."
    - "No prior spec covers __text_signature__.__len__() for any bisect callable."
    - "All 6 bisect callables share the same __text_signature__: '($module, /, a, x, lo=0, hi=None, *, key=None)' — length 46."
    - "bisect and insort are aliases for bisect_right and insort_right; they share the same C implementation and thus the same text signature."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# bisect function __text_signature__.__len__() table — all 6 callables
#
# bisect_extra16 covers __text_signature__.__eq__ (string value) for all 6
# bisect callables. No prior spec checks __text_signature__.__len__() for any
# bisect function. All 6 callables — bisect_left, bisect_right, insort_left,
# insort_right, and their aliases bisect/insort — share the same signature
# string '($module, /, a, x, lo=0, hi=None, *, key=None)', which has length 46.
# id_prefix btslen19 does not conflict with any prior bisect spec.
# ---------------------------------------------------------------------------

table bisect_extra19.text_signature_lengths:
  description: "__text_signature__.__len__() == 46 for all 6 bisect callables"
  kind: python_call_eq
  category: function_metadata
  id_prefix: btslen19

  columns: [id, function, args, expected]
  rows:
    - [bisect_left,  bisect_left.__text_signature__.__len__,  [], 46]
    - [bisect_right, bisect_right.__text_signature__.__len__, [], 46]
    - [insort_left,  insort_left.__text_signature__.__len__,  [], 46]
    - [insort_right, insort_right.__text_signature__.__len__, [], 46]
    - [bisect,       bisect.__text_signature__.__len__,       [], 46]
    - [insort,       insort.__text_signature__.__len__,       [], 46]
