spec: struct_extra571
version: ">=3.9"
backend: python_module(struct)
docs: "https://docs.python.org/3/library/struct.html"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers struct module function and class identity"
  created_at: "2026-04-12T00:00:00Z"

table struct_extra571.class_identity:
  description: "struct function and class __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: ste571ci
  columns: [id, function, args, expected]
  rows:
    - [ste571ci001, struct.pack.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ste571ci002, struct.unpack.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ste571ci003, struct.pack_into.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ste571ci004, struct.unpack_from.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ste571ci005, struct.calcsize.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ste571ci006, struct.iter_unpack.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ste571ci007, struct.Struct.__class__.__name__.__eq__, ["type"], true]
    - [ste571ci008, struct.error.__class__.__name__.__eq__, ["type"], true]
table struct_extra571.name_identity:
  description: "struct function __name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: ste571ni
  columns: [id, function, args, expected]
  rows:
    - [ste571ni001, struct.pack.__name__.__eq__, ["pack"], true]
    - [ste571ni002, struct.unpack.__name__.__eq__, ["unpack"], true]
table struct_extra571.qualname_identity:
  description: "struct type __qualname__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: ste571qi
  columns: [id, function, args, expected]
  rows:
    - [ste571qi001, struct.Struct.__qualname__.__eq__, ["Struct"], true]
    - [ste571qi002, struct.error.__qualname__.__eq__, ["error"], true]