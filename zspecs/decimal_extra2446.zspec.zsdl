    - ["dc2446006", "decimal.Decimal.__dict__.__contains__", ["__mul__"],      true]
    - ["dc2446007", "decimal.Decimal.__dict__.__contains__", ["__sub__"],      true]
    - ["dc2446008", "decimal.Decimal.__dict__.__contains__", ["__truediv__"],  true]
    - ["dc2446009", "decimal.Decimal.__dict__.__contains__", ["__floordiv__"], true]
    - ["dc2446010", "decimal.Decimal.__dict__.__contains__", ["__mod__"],      true]
    - ["dc2446011", "decimal.Decimal.__dict__.__contains__", ["__abs__"],      true]
    - ["dc2446012", "decimal.Decimal.__dict__.__contains__", ["__neg__"],      true]
    - ["dc2446013", "decimal.Decimal.__dict__.__contains__", ["__pos__"],      true]

