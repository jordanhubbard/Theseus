spec: decimal_extra2446
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "Python decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra.zspec.zsdl"
    - "decimal_extra1876.zspec.zsdl"
    - "_decimal_extra.zspec.zsdl"
  notes:
    - "Wave 2446, theme: __enter__/__exit__ context manager protocol dict-presence."
    - "decimal.Decimal is NOT a context manager — __enter__ and __exit__ are absent from its __dict__."
    - "decimal.Context is NOT a context manager itself — __enter__ and __exit__ are absent from its __dict__."
    - "decimal.localcontext() returns a decimal.ContextManager object, which IS a context manager (__enter__ and __exit__ in its __dict__ are True)."
    - "The ContextManager wrapper (type of decimal.localcontext()) is distinct from decimal.Context itself."
    - "decimal.Decimal.__dict__ DOES contain arithmetic operators: __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __abs__, __neg__, __pos__."
    - "decimal.Decimal.__dict__ DOES contain: quantize, sqrt, normalize, to_eng_string, to_integral_value, as_tuple, is_nan, is_infinite, is_zero."
    - "decimal.Context.__dict__ DOES contain: add, multiply, subtract, divide, sqrt, power, abs, plus, minus, compare, create_decimal, copy, rounding, Emin, Emax."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# decimal.Decimal — context manager protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table decimal_extra2446.decimal_cm_protocol:
  description: "decimal.Decimal and decimal.Context do not define __enter__ or __exit__ in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2446

  columns: [id, function, args, expected]
  rows:
    - ["dc2446001", "decimal.Decimal.__dict__.__contains__", ["__enter__"], false]
    - ["dc2446002", "decimal.Decimal.__dict__.__contains__", ["__exit__"],  false]
    - ["dc2446003", "decimal.Context.__dict__.__contains__", ["__enter__"], false]
    - ["dc2446004", "decimal.Context.__dict__.__contains__", ["__exit__"],  false]

