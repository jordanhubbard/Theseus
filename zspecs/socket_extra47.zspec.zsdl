spec: socket_extra47
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra46.zspec.zsdl — covers socket.socket/__class__.__name__.__eq__('type'), herror/gaierror/timeout/__class__.__name__.__eq__('type'), gethostname/gethostbyname/__class__.__name__.__eq__('builtin_function_or_method'), getaddrinfo/getfqdn/__class__.__name__.__eq__('function')."
    - "socket_extra45.zspec.zsdl — covers gethostbyname/__module__.__eq__('_socket'); getnameinfo __qualname__/__module__.__eq__; gethostbyaddr __qualname__/__module__.__eq__."
    - "socket_extra44.zspec.zsdl — covers socket.socket recvfrom/sendto/connect_ex/recv_into/recvfrom_into __name__.__eq__."
    - "socket_extra9.zspec.zsdl — covers socket.gethostname/__module__.__eq__('_socket') and socket.getaddrinfo/__module__.__eq__('socket')."
    - "socket_extra8.zspec.zsdl — covers __qualname__.__eq__ for gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection."
    - "socket_extra4.zspec.zsdl — covers gethostbyname/__name__.__eq__, gethostbyaddr/__name__.__eq__, getnameinfo/__name__.__eq__."
    - "socket_extra3.zspec.zsdl — covers getaddrinfo/__name__, gethostbyname/__name__, getnameinfo/__name__, getfqdn/__name__."
  notes:
    - "This spec extends socket through socket_extra46; it does NOT duplicate invariants present in those files."
    - "Coverage gap: No prior socket spec checks __class__.__qualname__.__eq__ for socket.socket, herror, gaierror, timeout, gethostname, gethostbyname, getaddrinfo, or getfqdn. The __class__.__qualname__ axis mirrors __class__.__name__ for non-nested types and provides additional regression coverage. socket_extra46 covers __class__.__name__.__eq__ for the same objects. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.__class__.__qualname__ == 'type'. socket.socket is a Python class (wrapping C socket objects); its metaclass is the built-in type whose __qualname__ is 'type'. No prior spec checks socket.socket.__class__.__qualname__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.herror.__class__.__qualname__ == 'type'. herror is an exception class; its metaclass is the built-in type. No prior spec checks herror.__class__.__qualname__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gaierror.__class__.__qualname__ == 'type'. gaierror is an exception class; its metaclass is the built-in type. No prior spec checks gaierror.__class__.__qualname__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.timeout.__class__.__qualname__ == 'type'. timeout is an exception class; its metaclass is the built-in type. No prior spec checks timeout.__class__.__qualname__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostname.__class__.__qualname__ == 'builtin_function_or_method'. gethostname is a C builtin in the _socket extension; its class's __qualname__ matches its __name__. No prior spec checks gethostname.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__class__.__qualname__ == 'builtin_function_or_method'. Same C builtin calling convention as gethostname. No prior spec checks gethostbyname.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__class__.__qualname__ == 'function'. getaddrinfo is a Python wrapper function defined in Lib/socket.py; its class is the built-in function type whose __qualname__ is 'function'. No prior spec checks getaddrinfo.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__class__.__qualname__ == 'function'. getfqdn is a pure Python function defined in Lib/socket.py. No prior spec checks getfqdn.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.__class__.__module__ == 'builtins'. The metaclass of socket.socket is the built-in type, whose __module__ is 'builtins'. No prior spec checks socket.socket.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostname.__class__.__module__ == 'builtins'. The builtin_function_or_method type lives in the builtins module. No prior spec checks gethostname.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__class__.__module__ == 'builtins'. The built-in function type (to which Python functions belong) has __module__ == 'builtins'. No prior spec checks getaddrinfo.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module-level type and callable __class__.__qualname__.__eq__ string values
#
# socket_extra46 covers __class__.__name__.__eq__ for the same objects.
# No prior socket spec checks __class__.__qualname__.__eq__ for socket.socket,
# herror, gaierror, timeout (all 'type'), gethostname/gethostbyname
# (both 'builtin_function_or_method'), or getaddrinfo/getfqdn (both 'function').
# ---------------------------------------------------------------------------

table socket_extra47.callable_class_qualnames:
  description: "socket socket/herror/gaierror/timeout __class__.__qualname__.__eq__('type'), gethostname/gethostbyname __class__.__qualname__.__eq__('builtin_function_or_method'), getaddrinfo/getfqdn __class__.__qualname__.__eq__('function') — novel __class__.__qualname__ axis; no prior socket spec checks __class__.__qualname__.__eq__ for any of these objects"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketclsqual47

  columns: [id, function, args, expected]
  rows:
    - [socket_class_qualname_eq,      socket.__class__.__qualname__.__eq__,      ["type"],                       true]
    - [herror_class_qualname_eq,      herror.__class__.__qualname__.__eq__,      ["type"],                       true]
    - [gaierror_class_qualname_eq,    gaierror.__class__.__qualname__.__eq__,    ["type"],                       true]
    - [timeout_class_qualname_eq,     timeout.__class__.__qualname__.__eq__,     ["type"],                       true]
    - [gethostname_class_qualname_eq, gethostname.__class__.__qualname__.__eq__, ["builtin_function_or_method"], true]
    - [gethostbyname_class_qualname_eq, gethostbyname.__class__.__qualname__.__eq__, ["builtin_function_or_method"], true]
    - [getaddrinfo_class_qualname_eq, getaddrinfo.__class__.__qualname__.__eq__, ["function"],                   true]
    - [getfqdn_class_qualname_eq,     getfqdn.__class__.__qualname__.__eq__,     ["function"],                   true]

# ---------------------------------------------------------------------------
# socket module-level object __class__.__module__.__eq__ string values
#
# No prior socket spec checks __class__.__module__.__eq__ for socket.socket,
# gethostname, or getaddrinfo at the metaclass/type level.
# socket.socket.__class__.__module__ == 'builtins'     (type metaclass → builtins)
# socket.gethostname.__class__.__module__ == 'builtins' (builtin_function_or_method → builtins)
# socket.getaddrinfo.__class__.__module__ == 'builtins' (function type → builtins)
# Three rows cover the three distinct __class__ kinds present in this module.
# ---------------------------------------------------------------------------

table socket_extra47.callable_class_modules:
  description: "socket socket/gethostname/getaddrinfo __class__.__module__.__eq__('builtins') — all socket module-level object metaclasses/types are defined in builtins; novel __class__.__module__ axis; no prior socket spec checks __class__.__module__.__eq__('builtins') for any of these objects"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketclsmod47

  columns: [id, function, args, expected]
  rows:
    - [socket_class_module_eq,      socket.__class__.__module__.__eq__,      ["builtins"], true]
    - [gethostname_class_module_eq, gethostname.__class__.__module__.__eq__, ["builtins"], true]
    - [getaddrinfo_class_module_eq, getaddrinfo.__class__.__module__.__eq__, ["builtins"], true]
