spec: remove_markdown
version: ">=0.5.0"
backend: node(remove-markdown)

docs: https://github.com/stiang/remove-markdown#readme

provenance:
  derived_from:
    - "remove-markdown README — https://github.com/stiang/remove-markdown#readme"
    - "Test vectors verified with remove-markdown via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "remove-markdown source"
  notes:
    - "Strips Markdown formatting from text — used by feeds, summaries, search-index pipelines."
    - "Install: npm install remove-markdown"
    - "Module export IS the function (CJS)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table remove_markdown.strip:
  kind: node_module_call_eq
  category: strip
  function: ~
  id_prefix: strip

  columns: [id, args, expected]
  rows:
    - [heading_and_bold,
       ["# Hello **world**"],
       "Hello world"]

    - [plain_text_passthrough,
       ["Plain text"],
       "Plain text"]

    - [link,
       ["[link](url)"],
       "link"]

    - [italic,
       ["*italic*"],
       "italic"]

    - [code_block,
       ["```js\nlet x = 1\n```"],
       "let x = 1"]

    - [inline_code,
       ["use `fn()` here"],
       "use fn() here"]

    - [unordered_list,
       ["- one\n- two"],
       "one\ntwo"]

    - [empty_string,
       [""],
       ""]

    - [hr_stripped,
       ["before\n---\nafter"],
       "before\nafter"]
