spec: asyncio_extra150
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "This spec covers: wave 255 theme — asyncio.__dict__.__contains__ membership checks. NEW in extra150: asyncio.__dict__.__contains__('Task')==True; asyncio.__dict__.__contains__('run')==True; asyncio.__dict__.__contains__('sleep')==True; asyncio.__dict__.__contains__('Queue')==True; asyncio.__dict__.__contains__('Lock')==True; asyncio.__dict__.__contains__('Future')==True; asyncio.__dict__.__contains__('gather')==True; asyncio.__dict__.__contains__('Event')==True; asyncio.__dict__.__contains__('Semaphore')==True; asyncio.__dict__.__contains__('wait')==True; asyncio.__dict__.__contains__('create_task')==True; asyncio.__dict__.__contains__('foobar')==False; asyncio.__dict__.__contains__('_task_factory')==False. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.__dict__.__contains__('Task') == True. Task is re-exported from _asyncio (C extension) through asyncio/__init__.py; it appears in asyncio.__dict__ as a public name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.__dict__.__contains__('run') == True. asyncio.run() is defined in Lib/asyncio/runners.py and re-exported; it appears in asyncio.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.__dict__.__contains__('foobar') == False. 'foobar' is not a name in the asyncio package namespace. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.__dict__.__contains__('_task_factory') == False. '_task_factory' is not a module-level name in asyncio.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.__dict__.__contains__ membership — True cases — extra150
#
# Wave 255 theme: asyncio.__dict__.__contains__ membership checks.
#
# asyncio.__dict__.__contains__('Task')        == True
# asyncio.__dict__.__contains__('run')         == True
# asyncio.__dict__.__contains__('sleep')       == True
# asyncio.__dict__.__contains__('Queue')       == True
# asyncio.__dict__.__contains__('Lock')        == True
# asyncio.__dict__.__contains__('Future')      == True
# asyncio.__dict__.__contains__('gather')      == True
# asyncio.__dict__.__contains__('Event')       == True
# asyncio.__dict__.__contains__('Semaphore')   == True
# asyncio.__dict__.__contains__('wait')        == True
# asyncio.__dict__.__contains__('create_task') == True
# ---------------------------------------------------------------------------

table asyncio_extra150.asyncio_dict_contains_true:
  description: "asyncio.__dict__.__contains__ membership checks (True cases) in asynciodictcontains150 namespace — wave 255 theme: asyncio.__dict__.__contains__ returns True for all public names re-exported through asyncio/__init__.py; the asyncio package has 136 entries in __dict__; Task and Future are re-exported from the _asyncio C extension; sleep, gather, and wait are re-exported from asyncio.tasks; Queue, Lock, Event, and Semaphore are re-exported from asyncio.queues and asyncio.locks respectively; asyncio.__dict__.__contains__('Task')==True; asyncio.__dict__.__contains__('run')==True (asyncio.run is from Lib/asyncio/runners.py); asyncio.__dict__.__contains__('sleep')==True; asyncio.__dict__.__contains__('Queue')==True; asyncio.__dict__.__contains__('Lock')==True; asyncio.__dict__.__contains__('Future')==True; asyncio.__dict__.__contains__('gather')==True; asyncio.__dict__.__contains__('Event')==True; asyncio.__dict__.__contains__('Semaphore')==True; asyncio.__dict__.__contains__('wait')==True; asyncio.__dict__.__contains__('create_task')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: asynciodictcontains150

  columns: [id, function, args, expected, description]
  rows:
    - [task_in,        "asyncio.__dict__.__contains__",  ["Task"],        true, "asyncio.__dict__.__contains__('Task') == True — Task re-exported from _asyncio C extension; verified with Python 3.14.3"]
    - [run_in,         "asyncio.__dict__.__contains__",  ["run"],         true, "asyncio.__dict__.__contains__('run') == True — asyncio.run from runners.py; verified with Python 3.14.3"]
    - [sleep_in,       "asyncio.__dict__.__contains__",  ["sleep"],       true, "asyncio.__dict__.__contains__('sleep') == True — asyncio.sleep from tasks.py; verified with Python 3.14.3"]
    - [queue_in,       "asyncio.__dict__.__contains__",  ["Queue"],       true, "asyncio.__dict__.__contains__('Queue') == True — asyncio.Queue from queues.py; verified with Python 3.14.3"]
    - [lock_in,        "asyncio.__dict__.__contains__",  ["Lock"],        true, "asyncio.__dict__.__contains__('Lock') == True — asyncio.Lock from locks.py; verified with Python 3.14.3"]
    - [future_in,      "asyncio.__dict__.__contains__",  ["Future"],      true, "asyncio.__dict__.__contains__('Future') == True — Future re-exported from _asyncio C extension; verified with Python 3.14.3"]
    - [gather_in,      "asyncio.__dict__.__contains__",  ["gather"],      true, "asyncio.__dict__.__contains__('gather') == True — asyncio.gather from tasks.py; verified with Python 3.14.3"]
    - [event_in,       "asyncio.__dict__.__contains__",  ["Event"],       true, "asyncio.__dict__.__contains__('Event') == True — asyncio.Event from locks.py; verified with Python 3.14.3"]
    - [semaphore_in,   "asyncio.__dict__.__contains__",  ["Semaphore"],   true, "asyncio.__dict__.__contains__('Semaphore') == True — asyncio.Semaphore from locks.py; verified with Python 3.14.3"]
    - [wait_in,        "asyncio.__dict__.__contains__",  ["wait"],        true, "asyncio.__dict__.__contains__('wait') == True — asyncio.wait from tasks.py; verified with Python 3.14.3"]
    - [create_task_in, "asyncio.__dict__.__contains__",  ["create_task"], true, "asyncio.__dict__.__contains__('create_task') == True — asyncio.create_task from tasks.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.__dict__.__contains__ membership — False cases — extra150
#
# asyncio.__dict__.__contains__('foobar')       == False
# asyncio.__dict__.__contains__('_task_factory') == False
# ---------------------------------------------------------------------------

table asyncio_extra150.asyncio_dict_contains_false:
  description: "asyncio.__dict__.__contains__ membership checks (False cases) in asynciodictcontains150 namespace — wave 255 theme: asyncio.__dict__.__contains__ returns False for names not in the asyncio public namespace; 'foobar' is not any real Python identifier in asyncio; '_task_factory' is not a module-level attribute (it is a concept related to loop.set_task_factory, but not in asyncio.__dict__); asyncio.__dict__.__contains__('foobar')==False; asyncio.__dict__.__contains__('_task_factory')==False; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: asynciodictcontains150a

  columns: [id, function, args, expected, description]
  rows:
    - [foobar_out,       "asyncio.__dict__.__contains__",  ["foobar"],        false, "asyncio.__dict__.__contains__('foobar') == False — not in asyncio namespace; verified with Python 3.14.3"]
    - [taskfact_out,     "asyncio.__dict__.__contains__",  ["_task_factory"], false, "asyncio.__dict__.__contains__('_task_factory') == False — not a module-level attribute; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra150
# ---------------------------------------------------------------------------

invariant asyncio_extra150.asyncio_dict_contains_Task:
  description: "asyncio.__dict__.__contains__('Task') returns True — asyncio.Task is re-exported through asyncio/__init__.py from the C extension module _asyncio (Modules/_asynciomodule.c); as a public API class it appears in asyncio.__dict__ under the key 'Task'; asyncio.__dict__.__contains__ is a builtin_function_or_method (dict.__contains__); asyncio.__dict__ has 136 entries; Task.__module__ is '_asyncio' (the C extension, not 'asyncio') yet 'Task' is present in asyncio.__dict__ because __init__.py imports and re-exports it; this verifies that the asyncio package's public namespace includes Task regardless of where it is implemented; NEW in extra150: first standalone asyncio.__dict__.__contains__('Task') invariant in asynciodictcontains150 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: "asyncio.__dict__.__contains__"
  args: ["Task"]
  expected: true

invariant asyncio_extra150.asyncio_dict_contains_run:
  description: "asyncio.__dict__.__contains__('run') returns True — asyncio.run is defined in Lib/asyncio/runners.py and re-exported through asyncio/__init__.py; it appears in asyncio.__dict__ under the key 'run'; asyncio.run is the primary entry point for running asyncio programs from synchronous code, creating a new event loop, running a coroutine, then closing the loop; asyncio.__dict__.__contains__('run')==True confirms 'run' is a top-level public name in the asyncio package namespace; compare with asyncio.__dict__.__contains__('sleep')==True (sleep is in tasks.py), asyncio.__dict__.__contains__('gather')==True, and asyncio.__dict__.__contains__('wait')==True; NEW in extra150: first standalone asyncio.__dict__.__contains__('run') invariant in asynciodictcontains150 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: "asyncio.__dict__.__contains__"
  args: ["run"]
  expected: true

invariant asyncio_extra150.asyncio_dict_contains_Future:
  description: "asyncio.__dict__.__contains__('Future') returns True — asyncio.Future is re-exported through asyncio/__init__.py from the _asyncio C extension; like asyncio.Task, Future is defined in Modules/_asynciomodule.c (module='_asyncio') yet 'Future' appears in asyncio.__dict__; asyncio.Future.__mro__.__len__() is 2 (MRO=[Future, object]); asyncio.Task inherits from asyncio.Future (Task.__bases__[0].__name__=='Future'); both Task and Future are in asyncio.__dict__: asyncio.__dict__.__contains__('Task')==True and asyncio.__dict__.__contains__('Future')==True; this verifies the asyncio package exposes both C extension classes through its public namespace; NEW in extra150: first standalone asyncio.__dict__.__contains__('Future') invariant in asynciodictcontains150 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: "asyncio.__dict__.__contains__"
  args: ["Future"]
  expected: true

invariant asyncio_extra150.asyncio_dict_contains_gather:
  description: "asyncio.__dict__.__contains__('gather') returns True — asyncio.gather is defined in Lib/asyncio/tasks.py alongside asyncio.sleep and asyncio.wait; all three are re-exported through asyncio/__init__.py and appear in asyncio.__dict__; asyncio.__dict__.__contains__('gather')==True; asyncio.__dict__.__contains__('sleep')==True; asyncio.__dict__.__contains__('wait')==True; these three coroutine scheduling functions share the same source module (asyncio.tasks) and are all in asyncio.__dict__; gather.__module__ is 'asyncio.tasks' but 'gather' is still in asyncio.__dict__ via re-export; NEW in extra150: first standalone asyncio.__dict__.__contains__('gather') invariant in asynciodictcontains150 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: "asyncio.__dict__.__contains__"
  args: ["gather"]
  expected: true

invariant asyncio_extra150.asyncio_dict_not_contains_foobar:
  description: "asyncio.__dict__.__contains__('foobar') returns False — 'foobar' is not any real Python identifier in the asyncio public namespace; asyncio.__dict__ has 136 entries, none of which is 'foobar'; this confirms that asyncio.__dict__.__contains__ correctly returns False for arbitrary strings that are not in the module's namespace; contrasts with the True cases: asyncio.__dict__.__contains__('Task')==True, asyncio.__dict__.__contains__('run')==True, asyncio.__dict__.__contains__('gather')==True; NEW in extra150: first standalone asyncio.__dict__.__contains__('foobar') False invariant in asynciodictcontains150 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: "asyncio.__dict__.__contains__"
  args: ["foobar"]
  expected: false

