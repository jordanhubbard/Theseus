spec: multiprocessing_extra237
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool class"
    - "https://docs.python.org/3/library/multiprocessing.html#managers — Managers section"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py (internal implementation)"
    - "CPython source: Lib/multiprocessing/managers.py (internal implementation)"
  notes:
    - "multiprocessing.Queue and multiprocessing.Pipe are methods (bound to the context), not classes directly."
    - "type(multiprocessing.Queue).__name__ == 'method'; type(multiprocessing.Pipe).__name__ == 'method'."
    - "This spec focuses on classes that have stable, verifiable identity: Pool, ApplyResult, SyncManager, BaseManager."
    - "multiprocessing.pool.Pool.__name__ == 'Pool' (len=4); __module__ == 'multiprocessing.pool' (len=20)."
    - "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object' — Pool inherits directly from object."
    - "multiprocessing.pool.ApplyResult.__name__ == 'ApplyResult' (len=11); AsyncResult is an alias for ApplyResult."
    - "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'."
    - "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool and ApplyResult class identity
#
# Pool.__name__ == 'Pool' (len=4)
# Pool.__module__ == 'multiprocessing.pool' (len=20)
# Pool.__bases__[0].__name__ == 'object'
# ApplyResult.__name__ == 'ApplyResult' (len=11)
# ApplyResult.__module__ == 'multiprocessing.pool' (len=20)
# ApplyResult.__bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

table multiprocessing_extra237.pool_class_identity:
  description: "multiprocessing.pool.Pool and ApplyResult class identity — Pool.__name__.__eq__('Pool')==True (len=4); Pool.__module__.__eq__('multiprocessing.pool')==True (len=20); Pool.__bases__[0].__name__.__eq__('object')==True (Pool inherits directly from object); ApplyResult.__name__.__eq__('ApplyResult')==True (len=11; AsyncResult is an alias for the same class); ApplyResult.__module__.__eq__('multiprocessing.pool')==True (len=20, same module as Pool); ApplyResult.__bases__[0].__name__.__eq__('object')==True; Pool.__name__.__len__()==4; ApplyResult.__name__.__len__()==11; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp237pool

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name_eq,   pool.Pool.__name__.__eq__,                        ["Pool"],                  true, "multiprocessing.pool.Pool.__name__ == 'Pool'; verified with Python 3.14.3"]
    - [pool_name_len,  pool.Pool.__name__.__len__,                       [],                        4,    "multiprocessing.pool.Pool.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [pool_mod_eq,    pool.Pool.__module__.__eq__,                      ["multiprocessing.pool"],  true, "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool'; verified with Python 3.14.3"]
    - [pool_mod_len,   pool.Pool.__module__.__len__,                     [],                        20,   "multiprocessing.pool.Pool.__module__.__len__() == 20; verified with Python 3.14.3"]
    - [pool_base_eq,   "pool.Pool.__bases__[0].__name__.__eq__",         ["object"],                true, "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]
    - [ar_name_eq,     pool.ApplyResult.__name__.__eq__,                 ["ApplyResult"],           true, "multiprocessing.pool.ApplyResult.__name__ == 'ApplyResult'; verified with Python 3.14.3"]
    - [ar_name_len,    pool.ApplyResult.__name__.__len__,                [],                        11,   "multiprocessing.pool.ApplyResult.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [ar_mod_eq,      pool.ApplyResult.__module__.__eq__,               ["multiprocessing.pool"],  true, "multiprocessing.pool.ApplyResult.__module__ == 'multiprocessing.pool'; verified with Python 3.14.3"]
    - [ar_mod_len,     pool.ApplyResult.__module__.__len__,              [],                        20,   "multiprocessing.pool.ApplyResult.__module__.__len__() == 20; verified with Python 3.14.3"]
    - [ar_base_eq,     "pool.ApplyResult.__bases__[0].__name__.__eq__",  ["object"],                true, "multiprocessing.pool.ApplyResult.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.managers.SyncManager and BaseManager class identity
#
# SyncManager.__name__ == 'SyncManager' (len=11)
# SyncManager.__module__ == 'multiprocessing.managers' (len=24)
# SyncManager.__bases__[0].__name__ == 'BaseManager'
# BaseManager.__name__ == 'BaseManager' (len=11)
# BaseManager.__module__ == 'multiprocessing.managers' (len=24)
# BaseManager.__bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

table multiprocessing_extra237.manager_class_identity:
  description: "multiprocessing.managers.SyncManager and BaseManager class identity — SyncManager.__name__.__eq__('SyncManager')==True (len=11); SyncManager.__module__.__eq__('multiprocessing.managers')==True (len=24); SyncManager.__bases__[0].__name__.__eq__('BaseManager')==True (SyncManager inherits from BaseManager, not object); BaseManager.__name__.__eq__('BaseManager')==True (len=11, same length as SyncManager); BaseManager.__module__.__eq__('multiprocessing.managers')==True (len=24, same module as SyncManager); BaseManager.__bases__[0].__name__.__eq__('object')==True (BaseManager is the root of the manager hierarchy); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp237mgr

  columns: [id, function, args, expected, description]
  rows:
    - [sync_name_eq,   managers.SyncManager.__name__.__eq__,                      ["SyncManager"],                true, "multiprocessing.managers.SyncManager.__name__ == 'SyncManager'; verified with Python 3.14.3"]
    - [sync_name_len,  managers.SyncManager.__name__.__len__,                     [],                             11,   "multiprocessing.managers.SyncManager.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [sync_mod_eq,    managers.SyncManager.__module__.__eq__,                    ["multiprocessing.managers"],   true, "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [sync_mod_len,   managers.SyncManager.__module__.__len__,                   [],                             24,   "multiprocessing.managers.SyncManager.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [sync_base_eq,   "managers.SyncManager.__bases__[0].__name__.__eq__",       ["BaseManager"],                true, "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'; verified with Python 3.14.3"]
    - [base_name_eq,   managers.BaseManager.__name__.__eq__,                      ["BaseManager"],                true, "multiprocessing.managers.BaseManager.__name__ == 'BaseManager'; verified with Python 3.14.3"]
    - [base_name_len,  managers.BaseManager.__name__.__len__,                     [],                             11,   "multiprocessing.managers.BaseManager.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [base_mod_eq,    managers.BaseManager.__module__.__eq__,                    ["multiprocessing.managers"],   true, "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [base_mod_len,   managers.BaseManager.__module__.__len__,                   [],                             24,   "multiprocessing.managers.BaseManager.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [base_base_eq,   "managers.BaseManager.__bases__[0].__name__.__eq__",       ["object"],                     true, "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra237
# ---------------------------------------------------------------------------

invariant multiprocessing_extra237.pool_name_eq:
  description: "multiprocessing.pool.Pool.__name__.__eq__('Pool') returns True — the class is named 'Pool' (len=4, shortest name in this spec); it lives in multiprocessing.pool (len=20); Pool.__bases__[0].__name__ == 'object' (inherits directly from object); ApplyResult.__name__ == 'ApplyResult' (len=11, longer); SyncManager.__name__ == 'SyncManager' (len=11); BaseManager.__name__ == 'BaseManager' (len=11); Pool has the shortest name among classes in this spec; NEW in extra237: first standalone Pool name equality invariant in mp237pool namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pool.Pool.__name__.__eq__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra237.syncmanager_base_is_basemanager:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') returns True — SyncManager inherits from BaseManager (not object directly); this makes SyncManager a two-level hierarchy: SyncManager -> BaseManager -> object; BaseManager.__bases__[0].__name__ == 'object'; SyncManager.__module__ == 'multiprocessing.managers' (len=24); SyncManager.__name__ == 'SyncManager' (len=11); BaseManager.__name__ == 'BaseManager' (len=11, same length); NEW in extra237: first standalone SyncManager base class invariant in mp237mgr namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "managers.SyncManager.__bases__[0].__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra237.pool_module_eq:
  description: "multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool') returns True — Pool is defined in Lib/multiprocessing/pool.py; __module__ == 'multiprocessing.pool' (len=20); ApplyResult shares this same module (also 'multiprocessing.pool', len=20); contrast with managers.SyncManager.__module__ == 'multiprocessing.managers' (len=24); Pool.__name__ == 'Pool' (len=4); Pool.__bases__[0].__name__ == 'object'; NEW in extra237: first standalone Pool module invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pool.Pool.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra237.basemanager_base_is_object:
  description: "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__('object') returns True — BaseManager is the root of the manager class hierarchy, inheriting directly from object; SyncManager.__bases__[0].__name__ == 'BaseManager' (SyncManager inherits from BaseManager); Pool.__bases__[0].__name__ == 'object' (Pool also inherits directly from object); BaseManager.__module__ == 'multiprocessing.managers' (len=24); BaseManager.__name__ == 'BaseManager' (len=11); NEW in extra237: first standalone BaseManager base class invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "managers.BaseManager.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
