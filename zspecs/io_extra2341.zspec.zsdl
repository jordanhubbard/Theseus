spec: io_extra2341
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "_io_extra.zspec.zsdl — covers class names, modules, is_type checks"
    - "io_extra.zspec.zsdl — covers read/write/tell/seek operations"
  notes:
    - "Theme: __slots__ contents. All io classes are C extension types implemented in _io."
    - "C extension types do not expose Python-level __slots__ in their __dict__."
    - "For every class checked, '__slots__' in cls.__dict__ is False."
    - "This is consistent across: IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO, BytesIO, StringIO, BufferedReader, BufferedWriter, TextIOWrapper, IncrementalNewlineDecoder."
    - "All expected values verified by running Python 3.14 io module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# io C types — no Python __slots__ in __dict__
# C extension types use C-level slots, never Python __slots__ tuples.
# ---------------------------------------------------------------------------

table io_extra2341.iobase_slots:
  kind: python_call_eq
  category: slots
  id_prefix: io2341

  columns: [id, function, args, expected]
  rows:
    - ["io2341001", IOBase.__dict__.__contains__,           ["__slots__"], false]
    - ["io2341002", RawIOBase.__dict__.__contains__,        ["__slots__"], false]
    - ["io2341003", BufferedIOBase.__dict__.__contains__,   ["__slots__"], false]
    - ["io2341004", TextIOBase.__dict__.__contains__,       ["__slots__"], false]
    - ["io2341005", FileIO.__dict__.__contains__,           ["__slots__"], false]
    - ["io2341006", BytesIO.__dict__.__contains__,          ["__slots__"], false]
    - ["io2341007", StringIO.__dict__.__contains__,         ["__slots__"], false]
    - ["io2341008", BufferedReader.__dict__.__contains__,   ["__slots__"], false]
    - ["io2341009", BufferedWriter.__dict__.__contains__,   ["__slots__"], false]
    - ["io2341010", TextIOWrapper.__dict__.__contains__,    ["__slots__"], false]
    - ["io2341011", IncrementalNewlineDecoder.__dict__.__contains__, ["__slots__"], false]

# ---------------------------------------------------------------------------
# Spot-check: a known instance attribute name is also not in __slots__
# (since __slots__ is absent, no slot name can be present)
# ---------------------------------------------------------------------------

table io_extra2341.no_slot_names:
  kind: python_call_eq
  category: slots
  id_prefix: io2341

  columns: [id, function, args, expected]
  rows:
    - ["io2341012", IOBase.__dict__.__contains__,         ["_raw"], false]
    - ["io2341013", BytesIO.__dict__.__contains__,        ["_buffer"], false]
    - ["io2341014", StringIO.__dict__.__contains__,       ["_buffer"], false]
    - ["io2341015", FileIO.__dict__.__contains__,         ["name"], false]
    - ["io2341016", BufferedReader.__dict__.__contains__, ["raw"], false]
    - ["io2341017", BufferedWriter.__dict__.__contains__, ["raw"], false]
    - ["io2341018", TextIOWrapper.__dict__.__contains__,  ["buffer"], false]
    - ["io2341019", TextIOWrapper.__dict__.__contains__,  ["encoding"], false]
    - ["io2341020", IncrementalNewlineDecoder.__dict__.__contains__, ["_decoder"], false]
    - ["io2341021", IncrementalNewlineDecoder.__dict__.__contains__, ["translate"], false]
