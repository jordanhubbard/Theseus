spec: logging_extra9
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra8.zspec.zsdl."
    - "logging_extra4 covers: class hierarchy __bases__[0].__name__ for Logger/Handler/StreamHandler/FileHandler/Formatter/Filter/LogRecord; Filterer/__name__+__module__; Manager/PlaceHolder __name__; style class __name__; BASIC_FORMAT type check."
    - "logging_extra8 covers: Manager/PlaceHolder __module__; makeLogRecord/disable/captureWarnings/addLevelName __module__; LoggerAdapter __qualname__/__module__; Logger.setLevel/addHandler/removeHandler __qualname__; Filterer.addFilter/removeFilter __qualname__; BASIC_FORMAT content membership."
    - "No prior spec checks __qualname__ for Handler methods (emit/format/handle/setLevel)."
    - "No prior spec checks __qualname__ for Formatter methods (format/formatTime/formatException)."
    - "No prior spec checks __qualname__ for Filter.filter method."
    - "No prior spec checks MRO depth beyond __bases__[0] for Handler/StreamHandler/FileHandler."
    - "No prior spec checks __qualname__ for makeLogRecord/disable/captureWarnings/addLevelName functions."
    - "logging.Handler.emit.__qualname__ == 'Handler.emit'."
    - "logging.Handler.format.__qualname__ == 'Handler.format'."
    - "logging.Handler.handle.__qualname__ == 'Handler.handle'."
    - "logging.Handler.setLevel.__qualname__ == 'Handler.setLevel'."
    - "logging.Formatter.format.__qualname__ == 'Formatter.format'."
    - "logging.Formatter.formatTime.__qualname__ == 'Formatter.formatTime'."
    - "logging.Formatter.formatException.__qualname__ == 'Formatter.formatException'."
    - "logging.Filter.filter.__qualname__ == 'Filter.filter'."
    - "logging.Handler.__mro__[1].__name__ == 'Filterer' — Handler inherits from Filterer."
    - "logging.Handler.__mro__[2].__name__ == 'object' — MRO terminates at object."
    - "logging.StreamHandler.__mro__[2].__name__ == 'Filterer' — StreamHandler→Handler→Filterer."
    - "logging.FileHandler.__mro__[3].__name__ == 'Filterer' — FileHandler→StreamHandler→Handler→Filterer."
    - "logging.makeLogRecord.__qualname__ == 'makeLogRecord' — plain function."
    - "logging.disable.__qualname__ == 'disable' — plain function."
    - "logging.captureWarnings.__qualname__ == 'captureWarnings' — plain function."
    - "logging.addLevelName.__qualname__ == 'addLevelName' — plain function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Handler method __qualname__ checks
#
# logging_extra8 checks Logger.setLevel/addHandler/removeHandler __qualname__
# and Filterer.addFilter/removeFilter __qualname__. No prior spec has checked
# Handler method __qualname__ for emit/format/handle/setLevel.
# ---------------------------------------------------------------------------

table logging_extra9.Handler_method_qualnames:
  description: "Handler methods have __qualname__ == 'Handler.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: hmqname

  columns: [id, function, args, expected]
  rows:
    - [emit,     Handler.emit.__qualname__.__eq__,     ["Handler.emit"],     true]
    - [format,   Handler.format.__qualname__.__eq__,   ["Handler.format"],   true]
    - [handle,   Handler.handle.__qualname__.__eq__,   ["Handler.handle"],   true]
    - [setLevel, Handler.setLevel.__qualname__.__eq__, ["Handler.setLevel"], true]

# ---------------------------------------------------------------------------
# Formatter method __qualname__ checks
#
# No prior logging spec has checked __qualname__ for Formatter methods.
# The three primary methods are format, formatTime, and formatException.
# ---------------------------------------------------------------------------

invariant logging_extra9.Formatter_format.qualname:
  description: "logging.Formatter.format.__qualname__ == 'Formatter.format'"
  category: method_qualnames
  kind: python_call_eq
  function: Formatter.format.__qualname__.__eq__
  args: ["Formatter.format"]
  expected: true

invariant logging_extra9.Formatter_formatTime.qualname:
  description: "logging.Formatter.formatTime.__qualname__ == 'Formatter.formatTime'"
  category: method_qualnames
  kind: python_call_eq
  function: Formatter.formatTime.__qualname__.__eq__
  args: ["Formatter.formatTime"]
  expected: true

invariant logging_extra9.Formatter_formatException.qualname:
  description: "logging.Formatter.formatException.__qualname__ == 'Formatter.formatException'"
  category: method_qualnames
  kind: python_call_eq
  function: Formatter.formatException.__qualname__.__eq__
  args: ["Formatter.formatException"]
  expected: true

# ---------------------------------------------------------------------------
# Filter.filter method __qualname__
#
# logging_extra3 covers Logger method __name__ (debug/info/warning etc.).
# No prior spec has checked Filter.filter __qualname__.
# ---------------------------------------------------------------------------

invariant logging_extra9.Filter_filter.qualname:
  description: "logging.Filter.filter.__qualname__ == 'Filter.filter'"
  category: method_qualnames
  kind: python_call_eq
  function: Filter.filter.__qualname__.__eq__
  args: ["Filter.filter"]
  expected: true

# ---------------------------------------------------------------------------
# Handler/StreamHandler/FileHandler MRO — deeper entries
#
# logging_extra4 covers __bases__[0].__name__ for all major classes.
# No prior spec checks MRO at index > 0 for Handler, StreamHandler, FileHandler.
# The full MROs are:
#   Handler       → Filterer → object
#   StreamHandler → Handler  → Filterer → object
#   FileHandler   → StreamHandler → Handler → Filterer → object
# ---------------------------------------------------------------------------

invariant logging_extra9.Handler.mro_index1:
  description: "logging.Handler.__mro__[1].__name__ == 'Filterer' — Handler inherits from Filterer"
  category: class_hierarchy
  kind: python_call_eq
  function: Handler.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Filterer"

invariant logging_extra9.Handler.mro_index2:
  description: "logging.Handler.__mro__[2].__name__ == 'object' — MRO terminates at object"
  category: class_hierarchy
  kind: python_call_eq
  function: Handler.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"

invariant logging_extra9.StreamHandler.mro_index2:
  description: "logging.StreamHandler.__mro__[2].__name__ == 'Filterer' — StreamHandler→Handler→Filterer"
  category: class_hierarchy
  kind: python_call_eq
  function: StreamHandler.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Filterer"

invariant logging_extra9.FileHandler.mro_index3:
  description: "logging.FileHandler.__mro__[3].__name__ == 'Filterer' — FileHandler→StreamHandler→Handler→Filterer"
  category: class_hierarchy
  kind: python_call_eq
  function: FileHandler.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "Filterer"

# ---------------------------------------------------------------------------
# Top-level function __qualname__ checks
#
# logging_extra8 checks __module__ for makeLogRecord/disable/captureWarnings/
# addLevelName. No prior spec checks __qualname__ for these functions.
# Each is a module-scope function so __qualname__ equals its plain name.
# ---------------------------------------------------------------------------

table logging_extra9.function_qualnames:
  description: "Top-level logging functions have __qualname__ equal to their name"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [makeLogRecord,    makeLogRecord.__qualname__.__eq__,    ["makeLogRecord"],    true]
    - [disable,         disable.__qualname__.__eq__,          ["disable"],          true]
    - [captureWarnings, captureWarnings.__qualname__.__eq__,  ["captureWarnings"],  true]
    - [addLevelName,    addLevelName.__qualname__.__eq__,     ["addLevelName"],     true]
