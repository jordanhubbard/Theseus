spec: socket_extra13
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "This spec extends socket.zspec.zsdl and prior extras through socket_extra12.zspec.zsdl."
    - "socket_extra12 covers: SocketType.__name__/__module__; herror.__mro__[0/1/2/3]; gaierror.__mro__[0/2]; AddressFamily/__qualname__; SocketKind/__qualname__; AF_INET6/__class__.__name__; SOCK_RAW/__class__.__name__."
    - "socket_extra11 covers: socket.socket.__name__/__module__/__bases__[0].__name__; SOCK_SEQPACKET.value/name; AF_APPLETALK.value/name; setdefaulttimeout/__module__; getdefaulttimeout/__module__; create_server/__module__; create_connection/__module__; timeout.__bases__[0].__name__; gaierror.__bases__[0].__name__."
    - "socket_extra9 covers: AF_INET.name; SOCK_STREAM.name."
    - "socket_extra6 covers: AF_INET.value; SOCK_STREAM.value."
    - "socket_extra2 covers: timeout.__name__ == 'TimeoutError' (the alias); SOCK_STREAM/__class__.__name__."
    - "socket.zspec.zsdl covers: SOL_SOCKET == 65535; SHUT_RD == 0; SHUT_WR == 1; SHUT_RDWR == 2."
    - "socket_extra4 covers: SHUT_RD/WR/RDWR __class__.__name__ == 'int'; SOL_SOCKET __class__.__name__ == 'int'."
    - "No prior spec covers: socket.timeout.__mro__[0].__name__ == 'TimeoutError' (MRO self-check at index 0)."
    - "No prior spec covers: socket.timeout.__mro__[1].__name__ == 'OSError' (via MRO, not __bases__)."
    - "No prior spec covers: socket.timeout.__mro__[2].__name__ == 'Exception' (MRO depth 2)."
    - "No prior spec covers: socket.has_ipv6 == True as a value assertion (it is a bool)."
    - "No prior spec covers: socket.has_ipv6.__class__.__name__ == 'bool'."
    - "No prior spec covers: socket.SO_REUSEADDR == 4 on macOS/Darwin (plain int constant)."
    - "socket.timeout is an alias for TimeoutError; timeout.__mro__: [TimeoutError, OSError, Exception, BaseException, object]."
    - "socket.has_ipv6 is True on all modern platforms with IPv6 compiled into the interpreter."
    - "socket.SO_REUSEADDR == 4 on macOS/Darwin; the value differs on Linux (where it is 2)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.timeout MRO — self-check (index 0) and depths 1 and 2
#
# socket.timeout is an alias for builtins.TimeoutError.
# socket_extra11 checks timeout.__bases__[0].__name__ == 'OSError' via __bases__.
# socket_extra2 checks timeout.__name__ == 'TimeoutError' (the __name__ attribute).
# No prior spec checks timeout.__mro__ at any index.
# timeout.__mro__: [TimeoutError, OSError, Exception, BaseException, object]
# Index 0 is TimeoutError itself; index 1 is OSError; index 2 is Exception.
# ---------------------------------------------------------------------------

invariant socket_extra13.timeout.mro_index0:
  description: "socket.timeout.__mro__[0].__name__ == 'TimeoutError' — MRO index 0 is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: timeout.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "TimeoutError"

invariant socket_extra13.timeout.mro_index1:
  description: "socket.timeout.__mro__[1].__name__ == 'OSError' — timeout inherits from OSError"
  category: class_hierarchy
  kind: python_call_eq
  function: timeout.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "OSError"

invariant socket_extra13.timeout.mro_index2:
  description: "socket.timeout.__mro__[2].__name__ == 'Exception' — timeout MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: timeout.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# socket.has_ipv6 — boolean feature flag
#
# socket.zspec.zsdl and all prior extras do not check socket.has_ipv6 at all.
# has_ipv6 is a plain bool exposed by the socket C extension.
# On CPython 3.9+ with IPv6 support compiled in (all modern distributions),
# has_ipv6 is True.
# ---------------------------------------------------------------------------

invariant socket_extra13.has_ipv6.value:
  description: "socket.has_ipv6 == True — IPv6 is available in this build"
  category: constants
  kind: python_call_eq
  function: has_ipv6.__eq__
  args: [true]
  expected: true

invariant socket_extra13.has_ipv6.class_name:
  description: "socket.has_ipv6.__class__.__name__ == 'bool' — has_ipv6 is a plain bool"
  category: constants
  kind: python_call_eq
  function: has_ipv6.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SO_REUSEADDR — plain int constant value on macOS/Darwin
#
# socket.zspec.zsdl covers SOL_SOCKET == 65535; socket_extra4 checks class name.
# socket_extra4 covers SHUT_RD/WR/RDWR and SOL_SOCKET __class__.__name__ == 'int'.
# No prior spec checks SO_REUSEADDR's integer value (4 on macOS) or its type.
# SO_REUSEADDR is a plain int (not an enum member) on all platforms.
# ---------------------------------------------------------------------------

invariant socket_extra13.SO_REUSEADDR.value:
  description: "socket.SO_REUSEADDR == 4 on macOS/Darwin — socket-level reuse-address option"
  category: constants
  kind: python_call_eq
  function: SO_REUSEADDR.__eq__
  args: [4]
  expected: true

invariant socket_extra13.SO_REUSEADDR.class_name:
  description: "socket.SO_REUSEADDR.__class__.__name__ == 'int' — SO_REUSEADDR is a plain int constant"
  category: constants
  kind: python_call_eq
  function: SO_REUSEADDR.__class__.__name__.__eq__
  args: ["int"]
  expected: true
