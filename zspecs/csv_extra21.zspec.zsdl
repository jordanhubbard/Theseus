spec: csv_extra21
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra20.zspec.zsdl."
    - "csv_extra20 covers: DictReader/__next__/__qualname__; DictReader/__iter__/__qualname__; DictWriter/writerow/__qualname__; DictWriter/writeheader/__qualname__; Sniffer/sniff/__qualname__; Sniffer/has_header/__qualname__."
    - "csv_extra19 covers: __qualname__.__class__.__name__ type axis for reader/writer/DictReader/DictWriter/Dialect/Sniffer/Error; QUOTE_ALL/__class__.__qualname__; QUOTE_MINIMAL/__class__.__qualname__."
    - "csv_extra18 covers: DictReader/DictWriter/Sniffer/excel/excel_tab/Dialect __qualname__ table; get_dialect/__module__; list_dialects/__module__."
    - "csv_extra16 covers: QUOTE_ALL/__class__.__name__; QUOTE_MINIMAL/__class__.__name__; QUOTE_NONNUMERIC/__class__.__name__; QUOTE_NONE/__class__.__name__."
    - "csv_extra6 covers: excel/__module__; unix_dialect/__qualname__; excel_tab/__qualname__."
    - "csv_extra covers: unix_dialect/__name__; unix_dialect/lineterminator; unix_dialect/quoting; unix_dialect/delimiter; excel/__bases__[0]/__name__."
    - "Focus: unix_dialect/__module__ and unix_dialect/__bases__[0]/__name__; QUOTE_NONNUMERIC/__class__/__qualname__; QUOTE_NONE/__class__/__qualname__; Dialect/delimiter type (NoneType at class level)."
    - "No prior csv spec checks unix_dialect.__module__."
    - "No prior csv spec checks unix_dialect.__bases__[0].__name__."
    - "No prior csv spec checks QUOTE_NONNUMERIC.__class__.__qualname__."
    - "No prior csv spec checks QUOTE_NONE.__class__.__qualname__."
    - "No prior csv spec checks Dialect.delimiter.__class__.__name__ (NoneType — delimiter is None at the Dialect base class level)."
    - "csv.unix_dialect.__module__ == 'csv' — pure-Python subclass defined in csv.py."
    - "csv.unix_dialect.__bases__[0].__name__ == 'Dialect' — unix_dialect inherits directly from Dialect."
    - "csv.QUOTE_NONNUMERIC.__class__.__qualname__ == 'int' — int type's qualname equals its name."
    - "csv.QUOTE_NONE.__class__.__qualname__ == 'int' — int type's qualname equals its name."
    - "csv.Dialect.delimiter is None at the class level; type(csv.Dialect.delimiter).__name__ == 'NoneType'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# unix_dialect — __module__ and __bases__[0].__name__
#
# csv_extra covers unix_dialect.__name__, lineterminator, quoting, and
# delimiter attribute values.
# csv_extra6 checks unix_dialect.__qualname__ == 'unix_dialect'.
# No prior csv spec checks unix_dialect.__module__ or __bases__[0].__name__.
# unix_dialect is a pure-Python subclass defined in csv.py, so its __module__
# is 'csv'.  It inherits directly from Dialect, the abstract base for all
# dialect classes.
# ---------------------------------------------------------------------------

invariant csv_extra21.unix_dialect.module:
  description: "csv.unix_dialect.__module__ == 'csv' — pure-Python dialect class defined in csv.py"
  category: class_attrs
  kind: python_call_eq
  function: unix_dialect.__module__.__eq__
  args: ["csv"]
  expected: true

invariant csv_extra21.unix_dialect.base_name:
  description: "csv.unix_dialect.__bases__[0].__name__ == 'Dialect' — unix_dialect inherits from Dialect"
  category: class_attrs
  kind: python_call_eq
  function: "unix_dialect.__bases__[0].__name__.__eq__"
  args: ["Dialect"]
  expected: true

# ---------------------------------------------------------------------------
# QUOTE_NONNUMERIC and QUOTE_NONE — __class__.__qualname__
#
# csv_extra16 checks QUOTE_NONNUMERIC/__class__/__name__ == 'int' and
# QUOTE_NONE/__class__/__name__ == 'int'.
# csv_extra19 checks QUOTE_ALL and QUOTE_MINIMAL __class__/__qualname__.
# No prior csv spec checks QUOTE_NONNUMERIC or QUOTE_NONE __class__/__qualname__.
# For a plain int the __qualname__ of its type is also 'int'.
# ---------------------------------------------------------------------------

invariant csv_extra21.QUOTE_NONNUMERIC.class_qualname:
  description: "csv.QUOTE_NONNUMERIC.__class__.__qualname__ == 'int' — int type's qualname"
  category: constant_types
  kind: python_call_eq
  function: QUOTE_NONNUMERIC.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true

invariant csv_extra21.QUOTE_NONE.class_qualname:
  description: "csv.QUOTE_NONE.__class__.__qualname__ == 'int' — int type's qualname"
  category: constant_types
  kind: python_call_eq
  function: QUOTE_NONE.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Dialect.delimiter — type name at class level
#
# The abstract Dialect base class has delimiter set to None at the class level
# (concrete dialect subclasses override it).  No prior csv spec checks the
# type of Dialect.delimiter.  At class level type(csv.Dialect.delimiter)
# is NoneType.
# ---------------------------------------------------------------------------

invariant csv_extra21.Dialect.delimiter.class_name:
  description: "csv.Dialect.delimiter.__class__.__name__ == 'NoneType' — delimiter is None on the abstract base class"
  category: class_attrs
  kind: python_call_eq
  function: Dialect.delimiter.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all five new invariants
#
# All five are first covered in this spec (csv_extra21).
# ---------------------------------------------------------------------------

table csv_extra21.new_attrs:
  description: "csv unix_dialect module/base, QUOTE_NONNUMERIC/NONE qualname type, Dialect.delimiter type"
  kind: python_call_eq
  category: class_attrs
  id_prefix: cna21

  columns: [id, function, args, expected]
  rows:
    - [unix_dialect_module,          unix_dialect.__module__.__eq__,                    ["csv"],         true]
    - [unix_dialect_base_name,       "unix_dialect.__bases__[0].__name__.__eq__",       ["Dialect"],     true]
    - [QUOTE_NONNUMERIC_class_qn,    QUOTE_NONNUMERIC.__class__.__qualname__.__eq__,    ["int"],         true]
    - [QUOTE_NONE_class_qn,          QUOTE_NONE.__class__.__qualname__.__eq__,          ["int"],         true]
    - [Dialect_delimiter_class_name, Dialect.delimiter.__class__.__name__.__eq__,       ["NoneType"],    true]
