# inspect.iscoroutine — __name__ and __module__
# ---------------------------------------------------------------------------

invariant inspect_extra346.iscoroutine.name:
  description: "inspect.iscoroutine.__name__ == 'iscoroutine'"
  category: async_inspection
  kind: python_call_eq
  function: iscoroutine.__name__.__eq__
  args: ["iscoroutine"]
  expected: true

invariant inspect_extra346.iscoroutine.module:
  description: "inspect.iscoroutine.__module__ == 'inspect'"
  category: async_inspection
  kind: python_call_eq
  function: iscoroutine.__module__.__eq__
  args: ["inspect"]
  expected: true

