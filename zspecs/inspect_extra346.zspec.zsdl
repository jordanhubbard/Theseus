# ---------------------------------------------------------------------------

invariant inspect_extra346.isawaitable.name:
  description: "inspect.isawaitable.__name__ == 'isawaitable'"
  category: async_inspection
  kind: python_call_eq
  function: isawaitable.__name__.__eq__
  args: ["isawaitable"]
  expected: true

invariant inspect_extra346.isawaitable.module:
  description: "inspect.isawaitable.__module__ == 'inspect'"
