spec: inspect_extra346
version: ">=3.5"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.isasyncgen.__name__ == 'isasyncgen' — plain Python function, name attribute is its identifier."
    - "inspect.isasyncgen.__module__ == 'inspect' — defined in the inspect module."
    - "inspect.isasyncgenfunction.__name__ == 'isasyncgenfunction' — note: NOT 'isasyncgeneratorfunction'; that name does not exist on Python 3.14."
    - "inspect.isasyncgenfunction.__module__ == 'inspect' — defined in the inspect module."
    - "inspect.iscoroutine.__name__ == 'iscoroutine' — plain Python function."
    - "inspect.iscoroutine.__module__ == 'inspect' — defined in the inspect module."
    - "inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction' — plain Python function."
    - "inspect.iscoroutinefunction.__module__ == 'inspect' — defined in the inspect module."
    - "inspect.isawaitable.__name__ == 'isawaitable' — plain Python function."
    - "inspect.isawaitable.__module__ == 'inspect' — defined in the inspect module."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.isasyncgen — __name__ and __module__
# ---------------------------------------------------------------------------

invariant inspect_extra346.isasyncgen.name:
  description: "inspect.isasyncgen.__name__ == 'isasyncgen'"
  category: async_inspection
  kind: python_call_eq
  function: isasyncgen.__name__.__eq__
  args: ["isasyncgen"]
  expected: true

invariant inspect_extra346.isasyncgen.module:
  description: "inspect.isasyncgen.__module__ == 'inspect'"
  category: async_inspection
  kind: python_call_eq
  function: isasyncgen.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# inspect.isasyncgenfunction — __name__ and __module__
#
# The correct name on Python 3.14 is 'isasyncgenfunction' (not
# 'isasyncgeneratorfunction', which does not exist).
# ---------------------------------------------------------------------------

invariant inspect_extra346.isasyncgenfunction.name:
  description: "inspect.isasyncgenfunction.__name__ == 'isasyncgenfunction'"
  category: async_inspection
  kind: python_call_eq
  function: isasyncgenfunction.__name__.__eq__
  args: ["isasyncgenfunction"]
  expected: true

invariant inspect_extra346.isasyncgenfunction.module:
  description: "inspect.isasyncgenfunction.__module__ == 'inspect'"
  category: async_inspection
  kind: python_call_eq
  function: isasyncgenfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

