# ---------------------------------------------------------------------------

invariant inspect_extra346.iscoroutinefunction.name:
  description: "inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction'"
  category: async_inspection
  kind: python_call_eq
  function: iscoroutinefunction.__name__.__eq__
  args: ["iscoroutinefunction"]
  expected: true

invariant inspect_extra346.iscoroutinefunction.module:
  description: "inspect.iscoroutinefunction.__module__ == 'inspect'"
  category: async_inspection
  kind: python_call_eq
  function: iscoroutinefunction.__module__.__eq__
  args: ["inspect"]
  expected: true

