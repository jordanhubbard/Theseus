spec: pdb_extra9
version: ">=3.9"
backend: python_module(pdb)

docs: https://docs.python.org/3/library/pdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pdb.html — Python pdb module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pdb.py"
  notes:
    - "This spec extends pdb.zspec.zsdl through pdb_extra8.zspec.zsdl."
    - "pdb covers: Pdb/__name__, Restart/__name__, Pdb/__module__, run/runeval/runcall/set_trace/post_mortem/pm __name__ (table), Pdb().prompt, Pdb().use_rawinput."
    - "pdb_extra covers: Pdb/__name__/__module__/__bases__[0].__name__, run/runeval/runcall/set_trace/post_mortem/pm/help __name__."
    - "pdb_extra2 covers: Pdb/__name__/__module__/__qualname__ (via __eq__ predicate), run/runcall/post_mortem/set_trace/pm __name__ and __module__."
    - "pdb_extra3 covers: runeval/__module__, help/__module__, Restart/__module__, Restart.__bases__[0]/__name__, Pdb.__bases__.__len__()==2, Pdb.__bases__[0]/__module__=='bdb', Pdb.__bases__[1]/__name__=='Cmd', Pdb.__bases__[1]/__module__=='cmd', function __qualname__ table (run/runeval/runcall/set_trace/post_mortem/pm, all via __eq__ predicate)."
    - "pdb_extra4 covers: Restart/__qualname__, Restart.__bases__.__len__()==1, Pdb.__bases__[0]/__qualname__=='Bdb', Pdb.__bases__[1]/__qualname__=='Cmd', Pdb.__bases__.__class__.__name__=='tuple', Pdb/__name__/__class__.__name__=='str', Restart/__name__/__class__.__name__=='str'."
    - "pdb_extra5 covers: Pdb command-method names (do_break/do_continue/do_step/do_next/do_quit/do_list), do_break.__module__, Pdb().__class__.__name__, Pdb().skip/nosigint defaults, run.__class__.__name__, Pdb.MAX_CHAINED_EXCEPTION_DEPTH."
    - "pdb_extra6 covers: Pdb/__name__/__module__ via __eq__, Pdb.__bases__[0]/__name__=='Bdb' via __eq__, run/pm/runcall/runeval/set_trace/post_mortem __name__ via __eq__, Restart/__name__/__bases__[0]/__name__ via __eq__, line_prefix.__class__.__name__=='str'."
    - "pdb_extra7 covers: Pdb.__mro__ (length 4, entries at indices 0..3 __name__ and __module__), do_where/do_up/do_down/do_args/do_return/do_jump __qualname__ table, line_prefix exact value."
    - "pdb_extra8 covers: Pdb.__name__/__module__/__bases__[0].__name__/__mro__.__len__ in direct expected-value form; run/set_trace/post_mortem/pm __qualname__ table (via __eq__); set_trace/post_mortem/pm __class__.__name__=='function'; Pdb.__class__.__name__=='type'."
    - "NEW in this spec: pdb.Pdb.__qualname__ and pdb.Pdb.__module__ in direct expected-value form (not __eq__ predicate); pdb.runcall.__qualname__ and pdb.runeval.__qualname__ as standalone invariants in direct expected-value form — pdb_extra3 covers these only in a table via __eq__ predicate; pdb.runcall.__qualname__ and pdb.runeval.__qualname__ not covered individually in any prior spec."
    - "pdb.Pdb.__qualname__ == 'Pdb' — top-level class; qualname equals name (verified runtime)."
    - "pdb.Pdb.__module__ == 'pdb' — Pdb is defined in the pdb module (verified runtime)."
    - "pdb.runcall.__qualname__ == 'runcall' — top-level function; qualname equals name (verified runtime)."
    - "pdb.runeval.__qualname__ == 'runeval' — top-level function; qualname equals name (verified runtime)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pdb.Pdb class __qualname__ and __module__ — direct expected-value form
#
# pdb_extra2 checks Pdb.__qualname__ via __eq__ predicate (function: Pdb.__qualname__.__eq__,
# expected: true).  This spec provides the direct expected-value form where
# the function returns the string and expected holds the value directly.
# ---------------------------------------------------------------------------

invariant pdb_extra9.Pdb.qualname:
  description: "pdb.Pdb.__qualname__ == 'Pdb' — top-level class qualname equals name, direct value form"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pdb_extra9.Pdb.module:
  description: "pdb.Pdb.__module__ == 'pdb' — Pdb is defined in the pdb module, direct value form"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# pdb.runcall and pdb.runeval __qualname__ — standalone invariants
#
# pdb_extra3 covers runcall/__qualname__ and runeval/__qualname__ only as
# rows in the function_qualnames table (via __eq__ predicate).  These standalone
# invariants provide an independent confirmation as individual invariant blocks.
# pdb_extra8 covers run/set_trace/post_mortem/pm __qualname__ as table rows
# but does NOT cover runcall or runeval in that table.
# ---------------------------------------------------------------------------

table pdb_extra9.runcall_runeval_qualnames:
  description: "pdb.runcall and pdb.runeval __qualname__ — standalone invariants not covered by any prior individual-invariant form"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: rrqn

  columns: [id, function, args, expected]
  rows:
    - [runcall, runcall.__qualname__.__eq__, ["runcall"], true]
    - [runeval, runeval.__qualname__.__eq__, ["runeval"], true]

# ---------------------------------------------------------------------------
# pdb.set_trace, pdb.post_mortem, pdb.pm, pdb.run __qualname__ — class name axis
#
# pdb_extra8 covers the __qualname__ values for run/set_trace/post_mortem/pm
# via a table (eq-predicate form).  This spec provides the __class__.__name__
# of each __qualname__ string (== 'str') — a new axis not covered by any spec.
# ---------------------------------------------------------------------------

table pdb_extra9.function_qualname_types:
  description: "pdb module-level function __qualname__ is always a str — __class__.__name__ == 'str'"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqnt

  columns: [id, function, args, expected]
  rows:
    - [runcall,     runcall.__qualname__.__class__.__name__.__eq__,     ["str"], true]
    - [runeval,     runeval.__qualname__.__class__.__name__.__eq__,     ["str"], true]
    - [set_trace,   set_trace.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [post_mortem, post_mortem.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [pm,          pm.__qualname__.__class__.__name__.__eq__,          ["str"], true]
