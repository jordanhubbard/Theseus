spec: logging_extra12
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra11.zspec.zsdl."
    - "logging_extra11 covers StreamHandler.__module__, FileHandler.__module__, Filterer.__qualname__, and MRO lengths for Logger/Handler/Formatter/StreamHandler."
    - "logging_extra10 covers class __name__ standalone invariants and getLevelName int->str."
    - "logging_extra9 covers Handler/Formatter/Filter method __qualname__ and MRO deeper entries."
    - "NOT yet covered: NullHandler.mro() length == 4 as a standalone invariant."
    - "NOT yet covered: Filter.mro() length == 2 as a standalone invariant."
    - "NOT yet covered: LogRecord.mro() length == 2 as a standalone invariant."
    - "NOT yet covered: Filterer.mro() length == 2 as a standalone invariant."
    - "NOT yet covered: FileHandler.mro() length == 5 as a standalone invariant."
    - "NOT yet covered: NullHandler.__bases__[0].__name__ == 'Handler' as a standalone invariant."
    - "NOT yet covered: getLevelName string->int for INFO/WARNING/ERROR/CRITICAL as standalone invariants."
    - "NOT yet covered: getLevelName('NOTSET') == 0 as a standalone invariant."
    - "NullHandler.mro() has 4 entries: [NullHandler, Handler, Filterer, object]."
    - "Filter.mro() has 2 entries: [Filter, object]."
    - "LogRecord.mro() has 2 entries: [LogRecord, object]."
    - "Filterer.mro() has 2 entries: [Filterer, object]."
    - "FileHandler.mro() has 5 entries: [FileHandler, StreamHandler, Handler, Filterer, object]."
    - "NullHandler.__bases__[0].__name__ == 'Handler' — NullHandler is a direct subclass of Handler."
    - "getLevelName('INFO') == 20, getLevelName('WARNING') == 30, getLevelName('ERROR') == 40, getLevelName('CRITICAL') == 50, getLevelName('NOTSET') == 0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO lengths — NullHandler, Filter, LogRecord, Filterer, FileHandler
#
# logging_extra11 covers MRO lengths for Logger/Handler/Formatter/StreamHandler.
# These five are the remaining major classes without standalone MRO length checks.
# NullHandler: [NullHandler, Handler, Filterer, object] — length 4
# Filter: [Filter, object] — length 2
# LogRecord: [LogRecord, object] — length 2
# Filterer: [Filterer, object] — length 2
# FileHandler: [FileHandler, StreamHandler, Handler, Filterer, object] — length 5
# ---------------------------------------------------------------------------

invariant logging_extra12.NullHandler.mro_len:
  description: "logging.NullHandler.mro() has 4 entries: [NullHandler, Handler, Filterer, object]"
  category: mro
  kind: python_call_eq
  function: NullHandler.mro
  args: []
  method: __len__
  expected: 4

invariant logging_extra12.Filter.mro_len:
  description: "logging.Filter.mro() has 2 entries: [Filter, object]"
  category: mro
  kind: python_call_eq
  function: Filter.mro
  args: []
  method: __len__
  expected: 2

invariant logging_extra12.LogRecord.mro_len:
  description: "logging.LogRecord.mro() has 2 entries: [LogRecord, object]"
  category: mro
  kind: python_call_eq
  function: LogRecord.mro
  args: []
  method: __len__
  expected: 2

invariant logging_extra12.Filterer.mro_len:
  description: "logging.Filterer.mro() has 2 entries: [Filterer, object]"
  category: mro
  kind: python_call_eq
  function: Filterer.mro
  args: []
  method: __len__
  expected: 2

invariant logging_extra12.FileHandler.mro_len:
  description: "logging.FileHandler.mro() has 5 entries: [FileHandler, StreamHandler, Handler, Filterer, object]"
  category: mro
  kind: python_call_eq
  function: FileHandler.mro
  args: []
  method: __len__
  expected: 5

# ---------------------------------------------------------------------------
# NullHandler.__bases__[0].__name__ — direct base class check
#
# logging_extra4 covers __bases__[0].__name__ for Logger/Handler/StreamHandler/
# FileHandler/Formatter/Filter/LogRecord. NullHandler was not included.
# NullHandler extends Handler directly, not StreamHandler.
# ---------------------------------------------------------------------------

invariant logging_extra12.NullHandler.base_is_handler:
  description: "logging.NullHandler.__bases__[0].__name__ == 'Handler' — NullHandler is a direct subclass of Handler"
  category: class_hierarchy
  kind: python_call_eq
  function: NullHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Handler"

# ---------------------------------------------------------------------------
# getLevelName — string → integer direction for remaining levels
#
# logging_extra10 covers getLevelName('DEBUG') == 10 as a standalone invariant.
# The remaining four standard levels (INFO/WARNING/ERROR/CRITICAL) and NOTSET
# have not been covered as standalone string→int invariants.
# ---------------------------------------------------------------------------

invariant logging_extra12.getLevelName.info_str_to_int:
  description: "logging.getLevelName('INFO') == 20"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: ["INFO"]
  expected: 20

invariant logging_extra12.getLevelName.warning_str_to_int:
  description: "logging.getLevelName('WARNING') == 30"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: ["WARNING"]
  expected: 30

invariant logging_extra12.getLevelName.error_str_to_int:
  description: "logging.getLevelName('ERROR') == 40"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: ["ERROR"]
  expected: 40

invariant logging_extra12.getLevelName.critical_str_to_int:
  description: "logging.getLevelName('CRITICAL') == 50"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: ["CRITICAL"]
  expected: 50

invariant logging_extra12.getLevelName.notset_str_to_int:
  description: "logging.getLevelName('NOTSET') == 0"
  category: level_names
  kind: python_call_eq
  function: getLevelName
  args: ["NOTSET"]
  expected: 0
