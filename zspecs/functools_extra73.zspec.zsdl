spec: functools_extra73
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra72.zspec.zsdl."
    - "Wave 234 theme: __kwdefaults__ for functools functions + total_ordering/singledispatch identity."
    - "wraps.__kwdefaults__ is None — wraps has no keyword-only parameters; __kwdefaults__.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3."
    - "update_wrapper.__kwdefaults__ is None — update_wrapper has no keyword-only parameters; __kwdefaults__.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3."
    - "lru_cache.__kwdefaults__ is None — lru_cache(maxsize=128, typed=False) has all positional defaults, no keyword-only params; __kwdefaults__.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3."
    - "total_ordering.__class__.__name__ == 'function' — total_ordering is a decorator function (not a class). Verified with Python 3.14.3."
    - "total_ordering.__module__ == 'functools' — defined in Lib/functools.py. Verified with Python 3.14.3."
    - "total_ordering.__qualname__ == 'total_ordering' — top-level function so qualname equals simple name. Verified with Python 3.14.3."
    - "total_ordering.__code__.co_name == 'total_ordering' — code object name matches function name. Verified with Python 3.14.3."
    - "total_ordering.__code__.co_argcount == 1 — takes a single positional argument 'cls'. Verified with Python 3.14.3."
    - "singledispatch.__class__.__name__ == 'function' — singledispatch is a Python function (decorator factory). Verified with Python 3.14.3."
    - "singledispatch.__module__ == 'functools' — defined in Lib/functools.py. Verified with Python 3.14.3."
    - "singledispatch.__qualname__ == 'singledispatch' — top-level function so qualname equals simple name. Verified with Python 3.14.3."
    - "singledispatch.__code__.co_name == 'singledispatch' — code object name matches function name. Verified with Python 3.14.3."
    - "singledispatch.__code__.co_argcount == 1 — takes a single positional argument 'func'. Verified with Python 3.14.3."
    - "singledispatch.__defaults__ is None — singledispatch(func) has no positional defaults; __defaults__.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3."
    - "No prior functools spec checks __kwdefaults__ for wraps/update_wrapper/lru_cache, or checks total_ordering/__code__/singledispatch/__code__ identity. All checks in this spec are new to extra73."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools functions __kwdefaults__ class name — extra73
#
# Wave 234 theme: __kwdefaults__ for wraps/update_wrapper/lru_cache.
#
# Python functions that have no keyword-only parameters have __kwdefaults__
# equal to None (not a dict). For these three functools functions:
#
#   wraps(wrapped, assigned=..., updated=...)
#     — 'assigned' and 'updated' are positional-with-defaults, NOT keyword-only
#     — therefore __kwdefaults__ is None → 'NoneType'
#
#   update_wrapper(wrapper, wrapped, assigned=..., updated=...)
#     — same: positional defaults only → __kwdefaults__ is None → 'NoneType'
#
#   lru_cache(maxsize=128, typed=False)
#     — positional defaults only → __kwdefaults__ is None → 'NoneType'
#
# No prior functools spec checks __kwdefaults__ for any of these functions.
# New to extra73.
# ---------------------------------------------------------------------------

table functools_extra73.kwdefaults_class_name:
  description: "wraps/update_wrapper/lru_cache __kwdefaults__.__class__.__name__=='NoneType' — no keyword-only parameters so __kwdefaults__ is None; wave 234 __kwdefaults__ checks; new to extra73"
  kind: python_call_eq
  category: kwdefaults_type
  id_prefix: functoolskw73

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_kwdefaults_class_name_eq_NoneType,
       wraps.__kwdefaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "functools.wraps.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — wraps is a pure-Python decorator factory (Lib/functools.py) with signature wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES); 'assigned' and 'updated' are regular positional parameters with defaults, not keyword-only parameters (there is no bare * before them); Python functions with no keyword-only parameters have __kwdefaults__ == None; None.__class__ is NoneType and NoneType.__name__ == 'NoneType' (8 chars); __eq__ returns True; no prior functools spec checks wraps.__kwdefaults__.__class__.__name__; new to extra73"]
    - [update_wrapper_kwdefaults_class_name_eq_NoneType,
       update_wrapper.__kwdefaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "functools.update_wrapper.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — update_wrapper is a pure-Python function (Lib/functools.py) with signature update_wrapper(wrapper, wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES); 'assigned' and 'updated' are positional parameters with defaults, not keyword-only; __kwdefaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior functools spec checks update_wrapper.__kwdefaults__.__class__.__name__; new to extra73"]
    - [lru_cache_kwdefaults_class_name_eq_NoneType,
       lru_cache.__kwdefaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "functools.lru_cache.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — lru_cache is a pure-Python function (Lib/functools.py) with signature lru_cache(maxsize=128, typed=False); both 'maxsize' and 'typed' are regular positional parameters with defaults, not keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior functools spec checks lru_cache.__kwdefaults__.__class__.__name__; new to extra73"]

# ---------------------------------------------------------------------------
# total_ordering identity — extra73
#
# Wave 234 theme: total_ordering code object and identity attributes.
#
# functools.total_ordering is a pure-Python decorator function defined in
# Lib/functools.py. It fills in missing comparison methods from a class that
# defines __eq__ and one of __lt__/__le__/__gt__/__ge__.
#
# total_ordering.__class__.__name__ == 'function'   (Python function)
# total_ordering.__module__         == 'functools'   (defined in functools)
# total_ordering.__qualname__       == 'total_ordering'  (top-level, no enclosing scope)
# total_ordering.__code__.co_name   == 'total_ordering'  (code object's name)
# total_ordering.__code__.co_argcount == 1  (single positional arg 'cls')
#
# No prior functools spec checks total_ordering.__code__ attributes. New to extra73.
# ---------------------------------------------------------------------------

table functools_extra73.total_ordering_identity:
  description: "total_ordering identity: __class__.__name__=='function', __module__=='functools', __qualname__=='total_ordering', __code__.co_name=='total_ordering'; wave 234 total_ordering identity; new to extra73"
  kind: python_call_eq
  category: decorator_identity
  id_prefix: functoolskw73

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_class_name_eq_function,
       total_ordering.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a pure-Python function defined at module level in Lib/functools.py; it is a decorator (a function that takes a class and returns a modified class); its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior functools spec checks total_ordering.__class__.__name__ in extra73; new to extra73"]
    - [total_ordering_module_eq_functools,
       total_ordering.__module__.__eq__,
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in Lib/functools.py and belongs to the functools module; its __module__ attribute is set to 'functools' at import time; __eq__ on the str 'functools' returns True; no prior functools spec checks total_ordering.__module__ in extra73; new to extra73"]
    - [total_ordering_qualname_eq_total_ordering,
       total_ordering.__qualname__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — total_ordering is a top-level function in the functools module (no enclosing class or function scope); its __qualname__ is therefore equal to its simple name 'total_ordering' (15 chars); __eq__ returns True; no prior functools spec checks total_ordering.__qualname__ in extra73; new to extra73"]
    - [total_ordering_code_co_name_eq_total_ordering,
       total_ordering.__code__.co_name.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True — total_ordering is a pure-Python function; its code object (a types.CodeType instance) has a co_name attribute equal to the function name as it appears in the def statement; the function is defined as 'def total_ordering(cls):' so co_name == 'total_ordering' (15 chars); __eq__ returns True; no prior functools spec checks total_ordering.__code__.co_name; new to extra73"]

# ---------------------------------------------------------------------------
# singledispatch identity — extra73
#
# Wave 234 theme: singledispatch code object and identity attributes.
#
# functools.singledispatch is a pure-Python decorator factory defined in
# Lib/functools.py. It transforms a function into a single-dispatch generic
# function that dispatches based on the type of its first argument.
#
# singledispatch.__class__.__name__ == 'function'   (Python function)
# singledispatch.__module__         == 'functools'   (defined in functools)
# singledispatch.__qualname__       == 'singledispatch'  (top-level)
# singledispatch.__code__.co_name   == 'singledispatch'  (code object's name)
# singledispatch.__code__.co_argcount == 1  (single positional arg 'func')
#
# No prior functools spec checks singledispatch.__code__ attributes. New to extra73.
# ---------------------------------------------------------------------------

table functools_extra73.singledispatch_identity:
  description: "singledispatch identity: __class__.__name__=='function', __module__=='functools', __qualname__=='singledispatch', __code__.co_name=='singledispatch'; wave 234 singledispatch identity; new to extra73"
  kind: python_call_eq
  category: decorator_identity
  id_prefix: functoolskw73

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_class_name_eq_function,
       singledispatch.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a pure-Python function defined at module level in Lib/functools.py; it is a decorator factory that transforms a function into a single-dispatch generic function; its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior functools spec checks singledispatch.__class__.__name__ in extra73; new to extra73"]
    - [singledispatch_module_eq_functools,
       singledispatch.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in Lib/functools.py and belongs to the functools module; its __module__ attribute is set to 'functools' at import time; __eq__ on the str 'functools' returns True; no prior functools spec checks singledispatch.__module__ in extra73; new to extra73"]
    - [singledispatch_qualname_eq_singledispatch,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — singledispatch is a top-level function in the functools module (no enclosing class or function scope); its __qualname__ is therefore equal to its simple name 'singledispatch' (14 chars); __eq__ returns True; no prior functools spec checks singledispatch.__qualname__ in extra73; new to extra73"]
    - [singledispatch_code_co_name_eq_singledispatch,
       singledispatch.__code__.co_name.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__code__.co_name.__eq__('singledispatch') == True — singledispatch is a pure-Python function; its code object has a co_name attribute equal to the function name as it appears in the def statement; the function is defined as 'def singledispatch(func):' so co_name == 'singledispatch' (14 chars); __eq__ returns True; no prior functools spec checks singledispatch.__code__.co_name; new to extra73"]

# ---------------------------------------------------------------------------
# total_ordering and singledispatch __code__.co_argcount — extra73
#
# Wave 234 theme: both decorators take exactly one positional argument.
#
# total_ordering.__code__.co_argcount == 1
#   — def total_ordering(cls): takes one arg 'cls'
#
# singledispatch.__code__.co_argcount == 1
#   — def singledispatch(func): takes one arg 'func'
#
# No prior functools spec checks __code__.co_argcount for either. New to extra73.
# ---------------------------------------------------------------------------

table functools_extra73.decorator_code_argcount:
  description: "total_ordering and singledispatch __code__.co_argcount==1 — each takes exactly one positional argument; wave 234 code argcount; new to extra73"
  kind: python_call_eq
  category: code_argcount
  id_prefix: functoolskw73

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_code_co_argcount_eq_1,
       total_ordering.__code__.co_argcount.__eq__,
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering is defined as 'def total_ordering(cls):' with a single positional parameter 'cls' representing the class to be decorated; the code object attribute co_argcount counts the number of positional parameters (excluding *args and **kwargs); for total_ordering co_argcount == 1; int.__eq__(1) returns True; no prior functools spec checks total_ordering.__code__.co_argcount; new to extra73"]
    - [singledispatch_code_co_argcount_eq_1,
       singledispatch.__code__.co_argcount.__eq__,
       [1],
       true,
       "functools.singledispatch.__code__.co_argcount.__eq__(1) == True — singledispatch is defined as 'def singledispatch(func):' with a single positional parameter 'func' representing the function to be wrapped into a generic function; co_argcount counts positional parameters excluding *args and **kwargs; for singledispatch co_argcount == 1; int.__eq__(1) returns True; no prior functools spec checks singledispatch.__code__.co_argcount; new to extra73"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra73
# ---------------------------------------------------------------------------

invariant functools_extra73.wraps_kwdefaults_NoneType:
  description: "functools.wraps.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — wraps has no keyword-only parameters; __kwdefaults__ is None; wave 234 __kwdefaults__ checks; new to extra73"
  kind: python_call_eq
  function: wraps.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant functools_extra73.total_ordering_class_function:
  description: "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a Python decorator function; wave 234 total_ordering identity; new to extra73"
  kind: python_call_eq
  function: total_ordering.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra73.total_ordering_module_functools:
  description: "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in Lib/functools.py; wave 234 total_ordering identity; new to extra73"
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra73.singledispatch_class_function:
  description: "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a Python decorator factory function; wave 234 singledispatch identity; new to extra73"
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra73.singledispatch_module_functools:
  description: "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in Lib/functools.py; wave 234 singledispatch identity; new to extra73"
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true
