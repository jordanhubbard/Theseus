spec: theseus_html_escape
version: ">=3.9"
backend: python_cleanroom(theseus_html_escape)
blocks: html

docs: https://html.spec.whatwg.org/

provenance:
  derived_from:
    - "https://html.spec.whatwg.org/ — HTML standard"
  notes:
    - "Clean-room HTML escaping. Do NOT import html, html.parser, or any HTML library."
    - "Implement HTML entity escaping/unescaping using only string replacement."
    - "escape('<script>') returns '&lt;script&gt;'."
    - "escape('a & b') returns 'a &amp; b'."
    - "unescape('&lt;b&gt;') returns '<b>'."
    - "Export: escape(s: str) -> str, unescape(s: str) -> str."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_html_escape.escape_lt_gt:
  description: "escape('<script>') == '&lt;script&gt;'"
  category: escape
  kind: python_call_eq
  function: html_escape_lt_gt
  args: []
  expected: "&lt;script&gt;"

invariant theseus_html_escape.escape_amp:
  description: "escape('a & b') == 'a &amp; b'"
  category: escape
  kind: python_call_eq
  function: html_escape_amp
  args: []
  expected: "a &amp; b"

invariant theseus_html_escape.unescape:
  description: "unescape('&lt;b&gt;') == '<b>'"
  category: unescape
  kind: python_call_eq
  function: html_unescape_lt
  args: []
  expected: "<b>"
