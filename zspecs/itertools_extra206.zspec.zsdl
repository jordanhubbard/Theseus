spec: itertools_extra206
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "Python itertools documentation — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra.zspec.zsdl — covers filterfalse classname, chain length_hint, repeat, islice"
    - "itertools_product.zspec.zsdl — covers product iterator behavior"
  notes:
    - "itertools functions are C-level types implemented in itertoolsmodule.c and therefore lack a __code__ attribute."
    - "itertools.__doc__.__class__.__name__ == 'str' — the module-level docstring is a plain Python string. Verified with Python 3.14.3."
    - "itertools.__doc__.__len__() == 1386 — the module docstring is 1386 characters long on Python 3.14.3. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__class__.__name__ == 'str' — chain's C-level type has a docstring exposed as a Python str. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__len__() == 190 — chain docstring is 190 characters. Verified with Python 3.14.3."
    - "itertools.count.__doc__.__class__.__name__ == 'str' — count docstring is a Python str. Verified with Python 3.14.3."
    - "itertools.count.__doc__.__len__() == 205 — count docstring is 205 characters. Verified with Python 3.14.3."
    - "itertools.cycle.__doc__.__len__() == 95 — cycle docstring is 95 characters. Verified with Python 3.14.3."
    - "itertools.islice.__doc__.__len__() == 453 — islice docstring is 453 characters. Verified with Python 3.14.3."
    - "itertools.zip_longest.__doc__.__len__() == 427 — zip_longest docstring is 427 characters. Verified with Python 3.14.3."
    - "itertools.combinations.__doc__.__len__() == 134 — combinations docstring is 134 characters. Verified with Python 3.14.3."
    - "itertools.product.__doc__.__len__() == 681 — product docstring is 681 characters. Verified with Python 3.14.3."
    - "itertools.starmap.__doc__.__len__() == 126 — starmap docstring is 126 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__.__class__.__name__ for itertools module and its C-level types
#
# itertools functions are C-level types; their docstrings are exposed as Python
# str objects. This table confirms the type of each docstring attribute.
# ---------------------------------------------------------------------------

table itertools_extra206.doc_class_name:
  description: "__doc__.__class__.__name__ for itertools module and type objects; new to extra206"
  kind: python_call_eq
  category: doc_attributes
  id_prefix: itercocode206

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_class,
       "__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__doc__.__class__.__name__ == 'str' — the itertools module has a top-level docstring exposed as a Python str; C extension modules expose their docstrings this way; str.__eq__('str') returns True; new to extra206"]
    - [chain_doc_class,
       "chain.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__ == 'str' — itertools.chain is a C-level type whose tp_doc slot is exposed as a Python str; chain docstrings describe lazy concatenation of iterables; str.__eq__('str') returns True; new to extra206"]
    - [count_doc_class,
       "count.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__name__ == 'str' — itertools.count is a C-level type whose docstring is exposed as a Python str; count produces an infinite arithmetic sequence; str.__eq__('str') returns True; new to extra206"]
    - [cycle_doc_class,
       "cycle.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.cycle.__doc__.__class__.__name__ == 'str' — itertools.cycle is a C-level type whose docstring is exposed as a Python str; cycle repeatedly cycles through the elements of an iterable; str.__eq__('str') returns True; new to extra206"]
    - [islice_doc_class,
       "islice.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.islice.__doc__.__class__.__name__ == 'str' — itertools.islice is a C-level type whose docstring is exposed as a Python str; islice returns a lazy iterator that slices an iterable; str.__eq__('str') returns True; new to extra206"]

# ---------------------------------------------------------------------------
# Table 2: __doc__.__len__() for itertools module and selected C-level types
#
# Each docstring has a known fixed length on Python 3.14.3. These lengths
# are stable within a minor Python version for a given platform. The checks
# confirm exact character counts.
# ---------------------------------------------------------------------------

table itertools_extra206.doc_len:
  description: "__doc__.__len__() for itertools module and C-level iterator types; new to extra206"
  kind: python_call_eq
  category: doc_attributes
  id_prefix: itercocode206

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_len,
       "__doc__.__len__",
       [],
       1386,
       "itertools.__doc__.__len__() == 1386 — the itertools module docstring is 1386 characters long on Python 3.14.3; it summarises the module's purpose and references; str.__len__() returns 1386; new to extra206"]
    - [chain_doc_len,
       "chain.__doc__.__len__",
       [],
       190,
       "itertools.chain.__doc__.__len__() == 190 — the chain type docstring is 190 characters long on Python 3.14.3; it describes lazy concatenation of iterables into a single sequence; str.__len__() returns 190; new to extra206"]
    - [count_doc_len,
       "count.__doc__.__len__",
       [],
       205,
       "itertools.count.__doc__.__len__() == 205 — the count type docstring is 205 characters long on Python 3.14.3; it describes the infinite arithmetic counting iterator; str.__len__() returns 205; new to extra206"]
    - [cycle_doc_len,
       "cycle.__doc__.__len__",
       [],
       95,
       "itertools.cycle.__doc__.__len__() == 95 — the cycle type docstring is 95 characters long on Python 3.14.3; it describes infinite cycling over an iterable's elements; str.__len__() returns 95; new to extra206"]

# ---------------------------------------------------------------------------
# Table 3: __doc__.__len__() for additional itertools types
#
# zip_longest, combinations, product, and starmap each have docstrings of
# known lengths on Python 3.14.3. These extend the coverage beyond chain,
# count, and cycle.
# ---------------------------------------------------------------------------

table itertools_extra206.doc_len_extended:
  description: "__doc__.__len__() for zip_longest, combinations, product, starmap; new to extra206"
  kind: python_call_eq
  category: doc_attributes
  id_prefix: itercocode206

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_doc_len,
       "zip_longest.__doc__.__len__",
       [],
       427,
       "itertools.zip_longest.__doc__.__len__() == 427 — the zip_longest type docstring is 427 characters long on Python 3.14.3; it describes padding-based aggregation of iterables of unequal length; str.__len__() returns 427; new to extra206"]
    - [islice_doc_len,
       "islice.__doc__.__len__",
       [],
       453,
       "itertools.islice.__doc__.__len__() == 453 — the islice type docstring is 453 characters long on Python 3.14.3; it describes lazy slicing of an iterable with start/stop/step; str.__len__() returns 453; new to extra206"]
    - [combinations_doc_len,
       "combinations.__doc__.__len__",
       [],
       134,
       "itertools.combinations.__doc__.__len__() == 134 — the combinations type docstring is 134 characters long on Python 3.14.3; it describes r-length subsequences without repetition; str.__len__() returns 134; new to extra206"]
    - [starmap_doc_len,
       "starmap.__doc__.__len__",
       [],
       126,
       "itertools.starmap.__doc__.__len__() == 126 — the starmap type docstring is 126 characters long on Python 3.14.3; it describes mapping a function over pre-zipped argument tuples; str.__len__() returns 126; new to extra206"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra206
# ---------------------------------------------------------------------------

invariant itertools_extra206.module_doc_class_name:
  description: "itertools.__doc__.__class__.__name__ == 'str' — module docstring is a Python str; new to extra206"
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra206.module_doc_len_1386:
  description: "itertools.__doc__.__len__() == 1386 — module docstring length on Python 3.14.3; new to extra206"
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 1386

invariant itertools_extra206.chain_doc_class_name:
  description: "itertools.chain.__doc__.__class__.__name__ == 'str' — chain C-level type has a str docstring; new to extra206"
  kind: python_call_eq
  function: chain.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra206.chain_doc_len_190:
  description: "itertools.chain.__doc__.__len__() == 190 — chain docstring length on Python 3.14.3; new to extra206"
  kind: python_call_eq
  function: chain.__doc__.__len__
  args: []
  expected: 190

invariant itertools_extra206.count_doc_class_name:
  description: "itertools.count.__doc__.__class__.__name__ == 'str' — count C-level type has a str docstring; new to extra206"
  kind: python_call_eq
  function: count.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra206.count_doc_len_205:
  description: "itertools.count.__doc__.__len__() == 205 — count docstring length on Python 3.14.3; new to extra206"
  kind: python_call_eq
  function: count.__doc__.__len__
  args: []
  expected: 205

invariant itertools_extra206.product_doc_len_681:
  description: "itertools.product.__doc__.__len__() == 681 — product docstring length on Python 3.14.3; new to extra206"
  kind: python_call_eq
  function: product.__doc__.__len__
  args: []
  expected: 681

invariant itertools_extra206.zip_longest_doc_len_427:
  description: "itertools.zip_longest.__doc__.__len__() == 427 — zip_longest docstring length on Python 3.14.3; new to extra206"
  kind: python_call_eq
  function: zip_longest.__doc__.__len__
  args: []
  expected: 427
