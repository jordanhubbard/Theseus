spec: abc_extra341
version: ">=3.3"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Container — name, module, base class, and abstractmethods
#
# collections.abc.Container is a single-method ABC requiring __contains__.
# Its only base is object.
# ---------------------------------------------------------------------------

invariant abc_extra341.Container.name:
  description: "collections.abc.Container.__name__ == 'Container'"
  category: container
  kind: python_call_eq
  function: Container.__name__.__eq__
  args: ["Container"]
  expected: true

invariant abc_extra341.Container.module:
  description: "collections.abc.Container.__module__ == 'collections.abc'"
  category: container
  kind: python_call_eq
  function: Container.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra341.Container.base:
  description: "collections.abc.Container.__bases__[0].__name__ == 'object'"
  category: container
  kind: python_call_eq
  function: Container.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant abc_extra341.Container.abstractmethods_contains:
  description: "collections.abc.Container.__abstractmethods__.__contains__('__contains__') == True"
  category: container
  kind: python_call_eq
  function: Container.__abstractmethods__.__contains__
  args: ["__contains__"]
  expected: true

# ---------------------------------------------------------------------------
# Sized — name, module, base class, and abstractmethods
#
# collections.abc.Sized is a single-method ABC requiring __len__.
# Its only base is object.
# ---------------------------------------------------------------------------

invariant abc_extra341.Sized.name:
  description: "collections.abc.Sized.__name__ == 'Sized'"
  category: sized
  kind: python_call_eq
  function: Sized.__name__.__eq__
  args: ["Sized"]
  expected: true

invariant abc_extra341.Sized.module:
  description: "collections.abc.Sized.__module__ == 'collections.abc'"
  category: sized
  kind: python_call_eq
  function: Sized.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra341.Sized.base:
  description: "collections.abc.Sized.__bases__[0].__name__ == 'object'"
  category: sized
  kind: python_call_eq
  function: Sized.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant abc_extra341.Sized.abstractmethods_len:
  description: "collections.abc.Sized.__abstractmethods__.__contains__('__len__') == True"
  category: sized
  kind: python_call_eq
  function: Sized.__abstractmethods__.__contains__
  args: ["__len__"]
  expected: true

# ---------------------------------------------------------------------------
# Collection — name, module, and first base class
#
# collections.abc.Collection combines Sized, Iterable, and Container.
# Its first base (index 0) is Sized.
# ---------------------------------------------------------------------------

invariant abc_extra341.Collection.name:
  description: "collections.abc.Collection.__name__ == 'Collection'"
  category: collection
  kind: python_call_eq
  function: Collection.__name__.__eq__
  args: ["Collection"]
  expected: true

invariant abc_extra341.Collection.module:
  description: "collections.abc.Collection.__module__ == 'collections.abc'"
  category: collection
  kind: python_call_eq
  function: Collection.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra341.Collection.first_base:
  description: "collections.abc.Collection.__bases__[0].__name__ == 'Sized'"
  category: collection
  kind: python_call_eq
  function: Collection.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Sized"

# ---------------------------------------------------------------------------
# Reversible — name, module, base class, and abstractmethods
#
# collections.abc.Reversible inherits from Iterable. It requires
# __reversed__ (and inherits the __iter__ requirement from Iterable).
# ---------------------------------------------------------------------------

invariant abc_extra341.Reversible.name:
  description: "collections.abc.Reversible.__name__ == 'Reversible'"
  category: reversible
  kind: python_call_eq
  function: Reversible.__name__.__eq__
  args: ["Reversible"]
  expected: true

invariant abc_extra341.Reversible.module:
  description: "collections.abc.Reversible.__module__ == 'collections.abc'"
  category: reversible
  kind: python_call_eq
  function: Reversible.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra341.Reversible.base:
  description: "collections.abc.Reversible.__bases__[0].__name__ == 'Iterable'"
  category: reversible
  kind: python_call_eq
  function: Reversible.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Iterable"

invariant abc_extra341.Reversible.abstractmethods_reversed:
  description: "collections.abc.Reversible.__abstractmethods__.__contains__('__reversed__') == True"
  category: reversible
  kind: python_call_eq
  function: Reversible.__abstractmethods__.__contains__
  args: ["__reversed__"]
  expected: true
