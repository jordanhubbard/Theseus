spec: functools_extra211
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "Python functools documentation — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra.zspec.zsdl — covers __name__ and __module__ checks for public functools symbols"
    - "functools_lru.zspec.zsdl — covers lru_cache and cache identity, qualname, module, and decorator behavior"
  notes:
    - "functools.lru_cache.__defaults__.__class__.__name__ == 'tuple' — lru_cache is a Python-level function; its positional defaults are (128, False) corresponding to maxsize=128 and typed=False. Verified with Python 3.14.3."
    - "functools.lru_cache.__defaults__.__len__() == 2 — lru_cache has exactly two positional default values. Verified with Python 3.14.3."
    - "functools.wraps.__defaults__.__class__.__name__ == 'tuple' — wraps is a Python-level function wrapping update_wrapper; its defaults are the WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES tuples. Verified with Python 3.14.3."
    - "functools.wraps.__defaults__.__len__() == 2 — wraps has exactly two positional default values (WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES). Verified with Python 3.14.3."
    - "functools.update_wrapper.__defaults__.__class__.__name__ == 'tuple' — update_wrapper is a Python-level function; same two defaults as wraps. Verified with Python 3.14.3."
    - "functools.recursive_repr.__defaults__.__class__.__name__ == 'tuple' — recursive_repr has one default value: '...'. Verified with Python 3.14.3."
    - "functools.recursive_repr.__defaults__.__len__() == 1 — recursive_repr has exactly one default: the fill_value string '...'. Verified with Python 3.14.3."
    - "functools.total_ordering.__defaults__.__class__.__name__ == 'NoneType' — total_ordering is a class decorator with no defaults. Verified with Python 3.14.3."
    - "functools.cache.__defaults__.__class__.__name__ == 'NoneType' — cache is a zero-argument lru_cache wrapper with no positional defaults. Verified with Python 3.14.3."
    - "functools.singledispatch.__defaults__.__class__.__name__ == 'NoneType' — singledispatch takes exactly one positional arg (func) with no default. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __defaults__.__class__.__name__ for Python-level functools functions
#
# lru_cache, wraps, update_wrapper, and recursive_repr are Python-level
# functions that have positional defaults. Their __defaults__ attribute is a
# tuple. total_ordering, cache, and singledispatch are Python-level but have
# no positional defaults — __defaults__ is None, so __class__.__name__ is
# 'NoneType'.
# ---------------------------------------------------------------------------

table functools_extra211.defaults_class_name:
  description: "__defaults__.__class__.__name__ for Python-level functools functions; new to extra211"
  kind: python_call_eq
  category: defaults
  id_prefix: functdefaults211

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_defaults_class,
       "lru_cache.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.lru_cache.__defaults__.__class__.__name__ == 'tuple' — lru_cache is a Python function whose positional defaults are (128, False) for maxsize and typed; __defaults__ is a tuple; str.__eq__('tuple') returns True; new to extra211"]
    - [wraps_defaults_class,
       "wraps.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.wraps.__defaults__.__class__.__name__ == 'tuple' — wraps is a Python function wrapping update_wrapper; its __defaults__ holds WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES; __defaults__ is a tuple; str.__eq__('tuple') returns True; new to extra211"]
    - [update_wrapper_defaults_class,
       "update_wrapper.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.update_wrapper.__defaults__.__class__.__name__ == 'tuple' — update_wrapper is a Python function that copies attributes from the wrapped to the wrapper; its __defaults__ holds the same two default tuples as wraps; str.__eq__('tuple') returns True; new to extra211"]
    - [recursive_repr_defaults_class,
       "recursive_repr.__defaults__.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.recursive_repr.__defaults__.__class__.__name__ == 'tuple' — recursive_repr is a Python decorator factory with one default (the fill_value string '...'); __defaults__ is a tuple; str.__eq__('tuple') returns True; new to extra211"]
    - [total_ordering_defaults_class,
       "total_ordering.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "functools.total_ordering.__defaults__.__class__.__name__ == 'NoneType' — total_ordering is a Python class decorator with no positional defaults; __defaults__ is None; None.__class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra211"]

# ---------------------------------------------------------------------------
# Table 2: __defaults__.__len__() for Python-level functools functions that
# have non-None defaults (lru_cache, wraps, update_wrapper, recursive_repr)
#
# lru_cache has 2 defaults: maxsize=128, typed=False.
# wraps has 2 defaults: WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES.
# update_wrapper has 2 defaults: same as wraps.
# recursive_repr has 1 default: fill_value='...'.
# ---------------------------------------------------------------------------

table functools_extra211.defaults_len:
  description: "__defaults__.__len__() for functools functions with non-None defaults; new to extra211"
  kind: python_call_eq
  category: defaults
  id_prefix: functdefaults211

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_defaults_len,
       "lru_cache.__defaults__.__len__",
       [],
       2,
       "functools.lru_cache.__defaults__.__len__() == 2 — lru_cache has exactly two positional default values: maxsize=128 and typed=False; tuple.__len__() returns 2; new to extra211"]
    - [wraps_defaults_len,
       "wraps.__defaults__.__len__",
       [],
       2,
       "functools.wraps.__defaults__.__len__() == 2 — wraps has exactly two positional default values corresponding to WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES; tuple.__len__() returns 2; new to extra211"]
    - [update_wrapper_defaults_len,
       "update_wrapper.__defaults__.__len__",
       [],
       2,
       "functools.update_wrapper.__defaults__.__len__() == 2 — update_wrapper has exactly two positional default values (the same as wraps since wraps is a partial application of update_wrapper); tuple.__len__() returns 2; new to extra211"]
    - [recursive_repr_defaults_len,
       "recursive_repr.__defaults__.__len__",
       [],
       1,
       "functools.recursive_repr.__defaults__.__len__() == 1 — recursive_repr has exactly one positional default value (fill_value='...'); tuple.__len__() returns 1; new to extra211"]

# ---------------------------------------------------------------------------
# Table 3: NoneType __defaults__ — cache, singledispatch confirm None defaults
#
# cache and singledispatch have no positional defaults. We confirm this by
# checking that their __defaults__.__class__.__name__ equals 'NoneType' and
# not 'tuple'. Negative checks confirm that lru_cache (which has defaults)
# does NOT have 'NoneType'.
# ---------------------------------------------------------------------------

table functools_extra211.none_defaults_check:
  description: "cache and singledispatch have NoneType __defaults__; lru_cache does not; new to extra211"
  kind: python_call_eq
  category: defaults
  id_prefix: functdefaults211

  columns: [id, function, args, expected, description]
  rows:
    - [cache_defaults_nonetype,
       "cache.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "functools.cache.__defaults__.__class__.__name__ == 'NoneType' — cache is a zero-argument wrapper around lru_cache(maxsize=None); it takes no positional defaults itself; __defaults__ is None; None.__class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra211"]
    - [singledispatch_defaults_nonetype,
       "singledispatch.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "functools.singledispatch.__defaults__.__class__.__name__ == 'NoneType' — singledispatch takes exactly one positional arg (func) with no default value; __defaults__ is None; None.__class__.__name__ is 'NoneType'; str.__eq__('NoneType') returns True; new to extra211"]
    - [lru_cache_defaults_not_nonetype,
       "lru_cache.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       false,
       "functools.lru_cache.__defaults__.__class__.__name__ != 'NoneType' — lru_cache has two positional defaults; __defaults__ is a tuple, NOT None; None.__class__.__name__ would be 'NoneType' but this is 'tuple'; str.__eq__('NoneType') returns False; new to extra211"]
    - [recursive_repr_defaults_not_nonetype,
       "recursive_repr.__defaults__.__class__.__name__.__eq__",
       ["NoneType"],
       false,
       "functools.recursive_repr.__defaults__.__class__.__name__ != 'NoneType' — recursive_repr has one positional default (fill_value='...'); __defaults__ is a tuple, NOT None; str.__eq__('NoneType') returns False; new to extra211"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra211
# ---------------------------------------------------------------------------

invariant functools_extra211.lru_cache_defaults_class_name:
  description: "functools.lru_cache.__defaults__.__class__.__name__ == 'tuple' — lru_cache positional defaults are (128, False); __defaults__ is a tuple; new to extra211"
  kind: python_call_eq
  function: lru_cache.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra211.lru_cache_defaults_len_2:
  description: "functools.lru_cache.__defaults__.__len__() == 2 — lru_cache has exactly two defaults: maxsize=128 and typed=False; new to extra211"
  kind: python_call_eq
  function: lru_cache.__defaults__.__len__
  args: []
  expected: 2

invariant functools_extra211.wraps_defaults_class_name:
  description: "functools.wraps.__defaults__.__class__.__name__ == 'tuple' — wraps defaults are WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES; new to extra211"
  kind: python_call_eq
  function: wraps.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra211.wraps_defaults_len_2:
  description: "functools.wraps.__defaults__.__len__() == 2 — wraps has exactly two positional defaults; new to extra211"
  kind: python_call_eq
  function: wraps.__defaults__.__len__
  args: []
  expected: 2

invariant functools_extra211.recursive_repr_defaults_len_1:
  description: "functools.recursive_repr.__defaults__.__len__() == 1 — recursive_repr has exactly one default: fill_value='...'; new to extra211"
  kind: python_call_eq
  function: recursive_repr.__defaults__.__len__
  args: []
  expected: 1

invariant functools_extra211.total_ordering_defaults_nonetype:
  description: "functools.total_ordering.__defaults__.__class__.__name__ == 'NoneType' — total_ordering has no positional defaults; new to extra211"
  kind: python_call_eq
  function: total_ordering.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant functools_extra211.cache_defaults_nonetype:
  description: "functools.cache.__defaults__.__class__.__name__ == 'NoneType' — cache has no positional defaults; new to extra211"
  kind: python_call_eq
  function: cache.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant functools_extra211.singledispatch_defaults_nonetype:
  description: "functools.singledispatch.__defaults__.__class__.__name__ == 'NoneType' — singledispatch has no positional defaults; new to extra211"
  kind: python_call_eq
  function: singledispatch.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

