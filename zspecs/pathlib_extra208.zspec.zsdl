spec: pathlib_extra208
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra207.zspec.zsdl — covers pathlib class attribute identity"
  notes:
    - "This spec covers pathlib module-level dunder attributes: __name__, __package__, __spec__.name, __loader__.__class__.__name__, __doc__.__class__.__name__."
    - "pathlib.__name__ == 'pathlib'; the module name is the string 'pathlib'; confirmed Python 3.14.3 macOS."
    - "pathlib.__package__ == 'pathlib'; pathlib is a package (directory with __init__.py); __package__ equals the package name; confirmed Python 3.14.3 macOS."
    - "pathlib.__spec__.name == 'pathlib'; the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS."
    - "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader'; pathlib is a pure-Python source module loaded by SourceFileLoader; confirmed Python 3.14.3 macOS."
    - "pathlib.__doc__.__class__.__name__ == 'str'; the module docstring is a str object; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib module __name__ identity
# __name__ == 'pathlib', length == 7
# ---------------------------------------------------------------------------

table pathlib_extra208.module_name:
  description: "pathlib module __name__ attribute identity: value, equality, and length"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibmod208

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        pathlib.__name__.__eq__,   ["pathlib"], true,  "pathlib.__name__ == 'pathlib'; the module name is the string 'pathlib'; confirmed Python 3.14.3 macOS"]
    - [name_len,       pathlib.__name__.__len__,  [],          7,     "pathlib.__name__.__len__() == 7; 'pathlib' has p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"]
    - [name_not_path,  pathlib.__name__.__eq__,   ["path"],    false, "pathlib.__name__ != 'path'; the full module name includes 'lib' suffix; confirmed Python 3.14.3 macOS"]
    - [name_not_empty, pathlib.__name__.__eq__,   [""],        false, "pathlib.__name__ is not empty string; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib module __package__ and __spec__.name identity
# __package__ == 'pathlib', __spec__.name == 'pathlib'
# ---------------------------------------------------------------------------

table pathlib_extra208.module_package_and_spec:
  description: "pathlib module __package__ and __spec__.name attribute identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibmod208

  columns: [id, function, args, expected, description]
  rows:
    - [package_eq,      pathlib.__package__.__eq__,      ["pathlib"], true,  "pathlib.__package__ == 'pathlib'; pathlib is a package and __package__ equals the package name; confirmed Python 3.14.3 macOS"]
    - [package_len,     pathlib.__package__.__len__,     [],          7,     "pathlib.__package__.__len__() == 7; 'pathlib' has p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"]
    - [spec_name_eq,    pathlib.__spec__.name.__eq__,    ["pathlib"], true,  "pathlib.__spec__.name == 'pathlib'; the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS"]
    - [spec_name_len,   pathlib.__spec__.name.__len__,   [],          7,     "pathlib.__spec__.name.__len__() == 7; 'pathlib' has p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib module __loader__ and __doc__ class names
# __loader__.__class__.__name__ == 'SourceFileLoader', __doc__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table pathlib_extra208.module_loader_and_doc:
  description: "pathlib module __loader__.__class__.__name__ and __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibmod208

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_eq,   pathlib.__loader__.__class__.__name__.__eq__,    ["SourceFileLoader"], true,  "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader'; pathlib is a pure-Python source module loaded by SourceFileLoader; confirmed Python 3.14.3 macOS"]
    - [loader_class_len,  pathlib.__loader__.__class__.__name__.__len__,   [],                  16,    "pathlib.__loader__.__class__.__name__.__len__() == 16; 'SourceFileLoader' has 16 characters; confirmed Python 3.14.3 macOS"]
    - [doc_class_eq,      pathlib.__doc__.__class__.__name__.__eq__,       ["str"],             true,  "pathlib.__doc__.__class__.__name__ == 'str'; the module docstring is a str object; confirmed Python 3.14.3 macOS"]
    - [doc_class_len,     pathlib.__doc__.__class__.__name__.__len__,      [],                  3,     "pathlib.__doc__.__class__.__name__.__len__() == 3; 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra208.name_eq:
  description: "pathlib.__name__ == 'pathlib' — the module name is the string 'pathlib'; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: pathlib.__name__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra208.name_len:
  description: "pathlib.__name__.__len__() == 7 — 'pathlib' has seven characters; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: pathlib.__name__.__len__
  args: []
  expected: 7

invariant pathlib_extra208.package_eq:
  description: "pathlib.__package__ == 'pathlib' — pathlib is a package and __package__ equals the package name; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: pathlib.__package__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra208.package_len:
  description: "pathlib.__package__.__len__() == 7 — 'pathlib' has seven characters; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: pathlib.__package__.__len__
  args: []
  expected: 7

invariant pathlib_extra208.spec_name_eq:
  description: "pathlib.__spec__.name == 'pathlib' — the ModuleSpec name matches the module __name__; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: pathlib.__spec__.name.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra208.spec_name_len:
  description: "pathlib.__spec__.name.__len__() == 7 — 'pathlib' has p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: pathlib.__spec__.name.__len__
  args: []
  expected: 7

invariant pathlib_extra208.loader_class_name_eq:
  description: "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader' — pathlib is a pure-Python source module loaded by SourceFileLoader; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: pathlib.__loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant pathlib_extra208.doc_class_name_eq:
  description: "pathlib.__doc__.__class__.__name__ == 'str' — the module docstring is a str object; confirmed Python 3.14.3 macOS"
  category: module_identity
  kind: python_call_eq
  function: pathlib.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

