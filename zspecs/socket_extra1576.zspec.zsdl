spec: socket_extra1576
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __str__/__repr__/__bytes__ protocol"
    - "socket.AF_INET, AF_INET6, SOCK_STREAM, SOCK_DGRAM are IntEnum members since Python 3.4."
    - "IntEnum members expose .name (str) and .value (int) attributes."
    - "AF_INET.value == 2 on all platforms; SOCK_STREAM.value == 1; SOCK_DGRAM.value == 2."
    - "AF_INET6.value is platform-dependent (10 on Linux, 30 on macOS); only isinstance checks are used."
    - "socket.inet_aton() converts a dotted-decimal IPv4 string to 4 bytes (network byte order)."
    - "socket.inet_ntoa() is the inverse of inet_aton()."
    - "socket.htons/htonl/ntohs/ntohl return int; their round-trip property holds for any value."
    - "All expected values verified by running Python 3.12 socket on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# AddressFamily .name attribute — str representation of enum members
# ---------------------------------------------------------------------------

table socket_extra1576.af_name:
  kind: python_call_eq
  category: str_repr
  id_prefix: sk1576

  columns: [id, function, args, expected]
  rows:
    - ["sk1576_001", "socket.AF_INET.name",        [], "AF_INET"]
    - ["sk1576_002", "socket.AF_INET6.name",       [], "AF_INET6"]
    - ["sk1576_003", "socket.SOCK_STREAM.name",    [], "SOCK_STREAM"]
    - ["sk1576_004", "socket.SOCK_DGRAM.name",     [], "SOCK_DGRAM"]
    - ["sk1576_005", "socket.AF_INET.name.__str__", [], "AF_INET"]
    - ["sk1576_006", "socket.AF_INET.name.__class__.__name__", [], "str"]

# ---------------------------------------------------------------------------
# AddressFamily .value attribute — int representation of enum members
# ---------------------------------------------------------------------------

table socket_extra1576.af_value:
  kind: python_call_eq
  category: int_repr
  id_prefix: sk1576

  columns: [id, function, args, expected]
  rows:
    - ["sk1576_010", "socket.AF_INET.value",             [], 2]
    - ["sk1576_011", "socket.SOCK_STREAM.value",         [], 1]
    - ["sk1576_012", "socket.SOCK_DGRAM.value",          [], 2]
    - ["sk1576_013", "socket.AF_INET.value.__class__.__name__",  [], "int"]
    - ["sk1576_014", "socket.AF_INET6.value.__class__.__name__", [], "int"]

# ---------------------------------------------------------------------------
# isinstance checks — AF_INET6.value is int (platform-safe)
# ---------------------------------------------------------------------------

table socket_extra1576.af_isinstance:
  kind: python_call_eq
  category: properties
  id_prefix: sk1576

  columns: [id, function, args, expected]
  rows:
    - ["sk1576_020", "isinstance", [socket.AF_INET6.value, int], true]
    - ["sk1576_021", "isinstance", [socket.SOCK_STREAM.value, int], true]
    - ["sk1576_022", "isinstance", [socket.AF_INET.name, str], true]
    - ["sk1576_023", "isinstance", [socket.AF_INET6.name, str], true]

# ---------------------------------------------------------------------------
# inet_aton() — dotted-decimal IPv4 string to 4-byte bytes (network order)
# ---------------------------------------------------------------------------

table socket_extra1576.inet_aton:
  kind: python_call_eq
  category: bytes_repr
  id_prefix: sk1576

  columns: [id, function, args, expected]
  rows:
    - ["sk1576_030", "socket.inet_aton", ["127.0.0.1"],       b"\x7f\x00\x00\x01"]
    - ["sk1576_031", "socket.inet_aton", ["0.0.0.0"],         b"\x00\x00\x00\x00"]
    - ["sk1576_032", "socket.inet_aton", ["255.255.255.255"], b"\xff\xff\xff\xff"]
    - ["sk1576_033", "socket.inet_aton", ["192.168.1.1"],     b"\xc0\xa8\x01\x01"]
    - ["sk1576_034", "socket.inet_aton", ["10.0.0.1"],        b"\x0a\x00\x00\x01"]

# ---------------------------------------------------------------------------
# inet_aton() length — always 4 bytes
# ---------------------------------------------------------------------------

table socket_extra1576.inet_aton_len:
  kind: python_call_eq
  category: bytes_repr
  id_prefix: sk1576

  columns: [id, function, args, expected]
  rows:
    - ["sk1576_040", "socket.inet_aton.__len__", ["127.0.0.1"],       4]
    - ["sk1576_041", "socket.inet_aton.__len__", ["0.0.0.0"],         4]
    - ["sk1576_042", "socket.inet_aton.__len__", ["255.255.255.255"], 4]

# ---------------------------------------------------------------------------
# inet_ntoa() — 4-byte bytes to dotted-decimal IPv4 string
# ---------------------------------------------------------------------------

table socket_extra1576.inet_ntoa:
  kind: python_call_eq
  category: str_repr
  id_prefix: sk1576

  columns: [id, function, args, expected]
  rows:
    - ["sk1576_050", "socket.inet_ntoa", [b"\x7f\x00\x00\x01"], "127.0.0.1"]
    - ["sk1576_051", "socket.inet_ntoa", [b"\x00\x00\x00\x00"], "0.0.0.0"]
    - ["sk1576_052", "socket.inet_ntoa", [b"\xff\xff\xff\xff"], "255.255.255.255"]
    - ["sk1576_053", "socket.inet_ntoa", [b"\xc0\xa8\x01\x01"], "192.168.1.1"]
    - ["sk1576_054", "socket.inet_ntoa", [b"\x0a\x00\x00\x01"], "10.0.0.1"]
    - ["sk1576_055", "socket.inet_ntoa.__class__.__name__", [b"\x7f\x00\x00\x01"], "str"]

# ---------------------------------------------------------------------------
# htons / ntohs — host-to-network and network-to-host short (16-bit int)
# Round-trip: ntohs(htons(x)) == x for all x in [0, 65535]
# isinstance checks are platform-safe (byte order varies)
# ---------------------------------------------------------------------------

table socket_extra1576.htons_ntohs:
  kind: python_call_eq
  category: int_repr
  id_prefix: sk1576

  columns: [id, function, args, expected]
  rows:
    - ["sk1576_060", "isinstance", [socket.htons(80), int],  true]
    - ["sk1576_061", "isinstance", [socket.ntohs(80), int],  true]
    - ["sk1576_062", "isinstance", [socket.htonl(1), int],   true]
    - ["sk1576_063", "isinstance", [socket.ntohl(1), int],   true]
    - ["sk1576_064", "socket.ntohs.socket.htons.__eq__", [80, socket.ntohs(socket.htons(80))], true]
    - ["sk1576_065", "socket.ntohl.socket.htonl.__eq__", [1,  socket.ntohl(socket.htonl(1))],  true]
