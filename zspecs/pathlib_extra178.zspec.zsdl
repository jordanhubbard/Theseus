spec: pathlib_extra178
version: ">=3.10"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec covers: pathlib module-level identity (__name__, __package__, __spec__.__class__.__name__) and pathlib.Path.__dict__.__contains__ for link methods (hardlink_to, samefile), ownership methods (owner, group), and absence of removed method (link_to)."
    - "pathlib.__name__ == 'pathlib' (len=7)."
    - "pathlib.__package__ == 'pathlib' (len=7) — pathlib is a package, __package__ equals __name__."
    - "pathlib.__spec__.__class__.__name__ == 'ModuleSpec' (len=10)."
    - "pathlib.Path.__dict__.__contains__('hardlink_to') == True (len=11: 'hard'(4)+'link_to'(7)=11) — added in Python 3.10."
    - "pathlib.Path.__dict__.__contains__('link_to') == False — 'link_to' was deprecated in 3.10 and removed in 3.12."
    - "pathlib.Path.__dict__.__contains__('samefile') == True (len=8: 'same'(4)+'file'(4)=8)."
    - "pathlib.Path.__dict__.__contains__('owner') == True (len=5: 'o-w-n-e-r')."
    - "pathlib.Path.__dict__.__contains__('group') == True (len=5: 'g-r-o-u-p')."
    - "Method name lengths: owner(5)=group(5) < samefile(8) < hardlink_to(11)."
    - "Two-way tie at 5: owner(5)=group(5)."
    - "'hardlink_to' (11) = 'hard'(4)+'link_to'(7)=11; equivalently 'hard'(4)+'link'(4)+'_to'(3)=11."
    - "'samefile' (8) = 'same'(4)+'file'(4)=8: two equal-length components."
    - "version: >=3.10 because hardlink_to() was added and link_to() was deprecated in Python 3.10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib module-level identity: __name__ and __package__
# pathlib.__name__ == 'pathlib' (len=7)
# pathlib.__package__ == 'pathlib' (len=7) — package module: __package__ == __name__
# pathlib (7 chars) > io (2 chars): module name length comparison
# ---------------------------------------------------------------------------

table pathlib_extra178.module_name_package:
  description: "pathlib.__name__=='pathlib' (len=7); pathlib.__package__=='pathlib' (len=7); both __name__ and __package__ are 'pathlib' (7 chars) — pathlib is a package module; pathlib.__name__ (7) == pathlib.__package__ (7): the defining characteristic of a package; pathlib(7) > io(2) > re(2) and pathlib(7)==decimal(7) in module name length"
  kind: python_call_eq
  category: identity
  id_prefix: plmod178

  columns: [id, function, args, expected, description]
  rows:
    - [pl_name_eq,  pathlib.__name__.__eq__,    ["pathlib"], true,  "pathlib.__name__ == 'pathlib' — the public name of the pathlib module; 'pathlib' has 7 characters: 'p-a-t-h-l-i-b'; pathlib (7 chars) == len('decimal') (7 chars): the pathlib and decimal module names share the 7-character length; pathlib (7 chars) > io (2 chars) by 5 and > re (2 chars) by 5: pathlib has the longest module name (tied with decimal) in this spec series; pathlib.__name__ (7 chars) == len('Pattern') (7 chars) == len('Decimal') (7 chars) == len('Context') (7 chars): the module name ties with primary class names across re and decimal modules; pathlib.__name__ (7 chars) == len('replace') (7 chars) from pathlib_extra175 — within-module tie at 7: the module name ties with the replace method name; confirmed Python 3.14.3 macOS"]
    - [pl_name_len, pathlib.__name__.__len__,   [],          7,     "pathlib.__name__.__len__() == 7 — 'pathlib' has 7 characters; pathlib (7 chars) == decimal (7 chars) in module name length: the two longest module names in this spec series are equal at 7; pathlib (7) > io (2) by 5 and > re (2) by 5: the pathlib module name is 5 characters longer than the io and re module names; pathlib.__name__ (7 chars) is the same as pathlib.__package__ (7 chars): for a package module, the name and package attributes are equal; the 7-character module name 'pathlib' == 'Decimal' (7 chars) == 'Pattern' (7 chars): a three-way cross-module tie at 7; confirmed Python 3.14.3 macOS"]
    - [pl_pkg_eq,   pathlib.__package__.__eq__, ["pathlib"], true,  "pathlib.__package__ == 'pathlib' — pathlib is a package module, so __package__ equals __name__; pathlib.__package__ (7: 'pathlib') == pathlib.__name__ (7: 'pathlib'): the defining characteristic of a package in Python's import system is that __package__ equals the module's own name; pathlib.__package__ (7 chars: 'pathlib') != io.__package__ (0 chars: ''): io has an empty __package__ while pathlib has a 7-character __package__ matching its own name; pathlib.__package__ (7 chars) == re.__package__ (2 chars: 're'): both re and pathlib are packages with __package__ == __name__, but they differ in length; confirmed Python 3.14.3 macOS"]
    - [pl_pkg_len,  pathlib.__package__.__len__, [],         7,     "pathlib.__package__.__len__() == 7 — pathlib.__package__ is 'pathlib' (7 chars), equal in length to pathlib.__name__ (7 chars); pathlib.__package__ (7 chars) > io.__package__ (0 chars) by 7: io has an empty package while pathlib has a 7-character one; pathlib.__package__ (7 chars) > re.__package__ (2 chars) by 5: pathlib's package name is 5 characters longer than re's; pathlib.__package__ (7 chars) > decimal.__package__ (0 chars) by 7: decimal has an empty package while pathlib has a 7-character one; the package/non-package split: pathlib and re set __package__ == __name__ (packages), while io and decimal set __package__ == '' (top-level modules); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib module-level identity: __spec__.__class__.__name__
# pathlib.__spec__.__class__.__name__ == 'ModuleSpec' (len=10)
# Consistent across io, pathlib, re, decimal
# ---------------------------------------------------------------------------

table pathlib_extra178.module_spec_class:
  description: "pathlib.__spec__.__class__.__name__=='ModuleSpec' (len=10); 'ModuleSpec'='Module'(6)+'Spec'(4)=10; pathlib.__spec__.__class__.__name__ (10) == io.__spec__.__class__.__name__ (10) == re.__spec__.__class__.__name__ (10) == decimal.__spec__.__class__.__name__ (10) — uniform four-module tie at 'ModuleSpec'"
  kind: python_call_eq
  category: identity
  id_prefix: plspec178

  columns: [id, function, args, expected, description]
  rows:
    - [pl_spec_cls, pathlib.__spec__.__class__.__name__.__eq__,  ["ModuleSpec"], true, "pathlib.__spec__.__class__.__name__ == 'ModuleSpec' — pathlib.__spec__ is an instance of importlib.machinery.ModuleSpec; 'ModuleSpec' has 10 characters: 'Module'(6)+'Spec'(4)=10; pathlib.__spec__.__class__.__name__ (10: 'ModuleSpec') == io.__spec__.__class__.__name__ (10: 'ModuleSpec') == re.__spec__.__class__.__name__ (10: 'ModuleSpec') == decimal.__spec__.__class__.__name__ (10: 'ModuleSpec'): a four-module cross-spec tie at 'ModuleSpec' (10 chars); 'Module' (6 chars) == len('FileIO') (6 chars) from io_extra176 and len('object') (6 chars) — within-module and cross-module ties at 6 for the first component of 'ModuleSpec'; confirmed Python 3.14.3 macOS"]
    - [pl_spec_len, pathlib.__spec__.__class__.__name__.__len__, [],             10,   "pathlib.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters: 'Module'(6)+'Spec'(4)=10; 10 is the consistent ModuleSpec class name length across all standard library modules; 'Spec' (4 chars) == len('glob') (4 chars) == len('walk') (4 chars) from pathlib_extra177 — within-module tie: the second component of 'ModuleSpec' ties with the shortest pathlib traversal method names; ModuleSpec (10) == len('read_bytes') (10 chars) from pathlib_extra176 — within-module tie at 10: the spec class name and the binary read method share 10-character length; confirmed Python 3.14.3 macOS"]
    - [pl_spec_ne,  pathlib.__spec__.__class__.__name__.__eq__,  ["NoneType"],   false, "pathlib.__spec__.__class__.__name__.__eq__('NoneType') == False — pathlib.__spec__ is NOT NoneType; pathlib.__spec__ is a ModuleSpec instance (10 chars), not NoneType (8 chars); 'NoneType' (8 chars) < 'ModuleSpec' (10 chars) by 2: the absent-spec class name is shorter than the present-spec class name; pathlib.__spec__ is always a ModuleSpec for properly imported modules; the False assertion encodes that pathlib is fully specified through the import system; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ contains hardlink_to and NOT link_to
# hardlink_to (len=11: 'hard'(4)+'link_to'(7)=11): added in Python 3.10
# link_to: removed in Python 3.12 (deprecated in 3.10)
# This spec requires version >=3.10 for hardlink_to and the removal of link_to
# ---------------------------------------------------------------------------

table pathlib_extra178.Path_dict_hardlink_to:
  description: "pathlib.Path.__dict__.__contains__('hardlink_to')==True (len=11); __contains__('link_to')==False — link_to was deprecated in 3.10, removed in 3.12; hardlink_to='hard'(4)+'link_to'(7)=11; hardlink_to replaced link_to in Python 3.10; 'link_to' (7 chars) absent while 'hardlink_to' (11 chars) present"
  kind: python_call_eq
  category: identity
  id_prefix: plhlt178

  columns: [id, function, args, expected, description]
  rows:
    - [has_hardlink_to, "Path.__dict__.__contains__", ["hardlink_to"], true,  "pathlib.Path.__dict__.__contains__('hardlink_to') == True — 'hardlink_to' is a key in Path.__dict__, meaning hardlink_to() is defined directly on Path; 'hardlink_to' has 11 characters: 'hard'(4)+'link_to'(7)=11; equivalently 'hard'(4)+'link'(4)+'_to'(3)=11; hardlink_to (11 chars) is the maximum method name length in this spec: owner(5)=group(5) < samefile(8) < hardlink_to(11); hardlink_to was added in Python 3.10 as a replacement for the deprecated link_to(); Path.hardlink_to(target) makes this path a hard link pointing to target; hardlink_to (11 chars) == len('write_bytes') (11 chars) from pathlib_extra176 and len('_TextIOBase') (11 chars) from io — cross-spec and cross-module ties at 11; confirmed Python 3.14.3 macOS"]
    - [no_link_to,      "Path.__dict__.__contains__", ["link_to"],     false, "pathlib.Path.__dict__.__contains__('link_to') == False — 'link_to' is NOT a key in Path.__dict__ in Python 3.12+ (this spec requires >=3.10, but link_to removal happened in 3.12); 'link_to' has 7 characters: 'link'(4)+'_to'(3)=7; link_to was deprecated in Python 3.10 in favor of hardlink_to() and removed in Python 3.12; link_to (7 chars) < hardlink_to (11 chars) by 4: the replacement method name 'hardlink_to' is 4 characters longer than the removed 'link_to' — the 'hard' prefix (4 chars) was added to make the name unambiguous; the False assertion encodes that Python 3.12+ has removed the deprecated link_to from Path.__dict__; confirmed Python 3.14.3 macOS"]
    - [hlt_not_lt,      "Path.__dict__.__contains__", ["hardlink_to"], true,  "pathlib.Path.__dict__.__contains__('hardlink_to') == True — confirming that hardlink_to (True, 11 chars) replaced link_to (False, 7 chars); the name change: link_to (7 chars) -> hardlink_to (11 chars): the 'hard' prefix (4 chars) was prepended, making the method name 4 characters longer; 'hard' (4 chars) == len('glob') (4 chars) == len('walk') (4 chars) == len('same') (4 chars): the 'hard' prefix ties with the shortest traversal method names and the first component of 'samefile'; hardlink_to (11 chars) is in Path.__dict__ while link_to is absent — this version-aware pair tests the Python 3.10/3.12 API evolution; confirmed Python 3.14.3 macOS"]
    - [hlt_len_11,      "Path.__dict__.__contains__", ["hardlink_to"], true,  "pathlib.Path.__dict__.__contains__('hardlink_to') == True — confirming hardlink_to (11 chars) is the maximum method name length in this spec: owner(5)=group(5) < samefile(8) < hardlink_to(11); the three-level ascending sequence: 5, 8, 11 with gaps of 3 and 3 — a uniform gap of 3 at both transitions; hardlink_to (11) - samefile (8) = 3 and samefile (8) - owner (5) = 3: a perfectly uniform step of 3 between all consecutive levels; the uniform gap of 3 between levels in this spec contrasts with the unit-gap pattern in pathlib_extra177; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ contains samefile
# samefile (len=8: 'same'(4)+'file'(4)=8): two equal 4-char components
# samefile (8) sits between owner(5)=group(5) and hardlink_to(11)
# ---------------------------------------------------------------------------

table pathlib_extra178.Path_dict_samefile:
  description: "pathlib.Path.__dict__.__contains__('samefile')==True (len=8); 'samefile'='same'(4)+'file'(4)=8; both components are equal at 4 chars; samefile(8) sits between owner(5)=group(5) and hardlink_to(11); Path.samefile() checks whether two paths refer to the same filesystem file"
  kind: python_call_eq
  category: identity
  id_prefix: plsf178

  columns: [id, function, args, expected, description]
  rows:
    - [has_samefile,   "Path.__dict__.__contains__", ["samefile"], true, "pathlib.Path.__dict__.__contains__('samefile') == True — 'samefile' is a key in Path.__dict__, meaning samefile() is defined directly on Path; 'samefile' has 8 characters: 'same'(4)+'file'(4)=8; samefile (8 chars) is the middle level in this spec's three-level ascending sequence: owner(5)=group(5) < samefile(8) < hardlink_to(11); the two components of 'samefile' are equal: 'same'(4) == 'file'(4) — a 50/50 split compound name; Path.samefile(other_path) returns True if the path refers to the same inode as other_path (resolves symlinks); samefile (8 chars) == len('absolute') (8 chars) from pathlib_extra176 — within-module tie at 8: samefile and absolute share the 8-character name length; confirmed Python 3.14.3 macOS"]
    - [sf_gt_owner,    "Path.__dict__.__contains__", ["samefile"], true, "pathlib.Path.__dict__.__contains__('samefile') == True — confirming samefile (8 chars) > owner (5 chars) == group (5 chars) by 3; the gap from the 5-char group to samefile (8) is 3 — the same as the gap from samefile (8) to hardlink_to (11): a uniform gap of 3 at both transitions; samefile (8) occupies the unique middle position in the three-level sequence, equidistant from both the 5-char group and hardlink_to (11); 'same' prefix (4 chars) == 'file' suffix (4 chars): the equal-component split makes 'samefile' the most symmetric compound name in this spec; confirmed Python 3.14.3 macOS"]
    - [sf_lt_hlt,      "Path.__dict__.__contains__", ["samefile"], true, "pathlib.Path.__dict__.__contains__('samefile') == True — confirming samefile (8 chars) < hardlink_to (11 chars) by 3; samefile (8) is 3 characters shorter than hardlink_to (11) — the same gap of 3 that separates samefile from the 5-char group below; the three-level sequence owner(5)=group(5) < samefile(8) < hardlink_to(11) spans integers {5, 8, 11}: an arithmetic sequence with common difference 3; samefile (8 chars) == len('readline') (8 chars) from io_extra177 and len('finditer') (8 chars) from re_extra173 — cross-module ties at 8: the filesystem identity check method ties with the text stream line-reading and the pattern iteration method; confirmed Python 3.14.3 macOS"]
    - [sf_compound,    "Path.__dict__.__contains__", ["samefile"], true, "pathlib.Path.__dict__.__contains__('samefile') == True — confirming samefile (8 chars) = 'same'(4)+'file'(4): a 50/50 compound name; samefile joins other equal-component compound names in this spec series: finditer (8 chars = 'find'(4)+'iter'(4)=8) from re_extra173 — both are 8-character compounds with equal 4-char components; 'same' (4 chars) == 'file' (4 chars) == 'hard' (4 chars) == 'link' (4 chars): all four-character components in the 8-char and 11-char method names in this spec are equal in length; the four-way tie at 4-char components: 'same', 'file', 'hard', 'link' — all parts of names in this spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ contains owner and group
# owner (len=5), group (len=5): two-way tie at 5
# Both return string-valued ownership metadata
# ---------------------------------------------------------------------------

table pathlib_extra178.Path_dict_owner_group:
  description: "pathlib.Path.__dict__.__contains__('owner')==True (len=5); __contains__('group')==True (len=5); owner(5)==group(5): two-way tie at 5; both are ownership metadata methods on Path; owner(5) < samefile(8) < hardlink_to(11): the three-level ascending sequence"
  kind: python_call_eq
  category: identity
  id_prefix: plog178

  columns: [id, function, args, expected, description]
  rows:
    - [has_owner,    "Path.__dict__.__contains__", ["owner"], true, "pathlib.Path.__dict__.__contains__('owner') == True — 'owner' is a key in Path.__dict__, meaning owner() is defined directly on Path; 'owner' has 5 characters: 'o-w-n-e-r'; owner (5 chars) ties with group (5 chars) — the two-way tie at 5 in this spec; owner (5 chars) is the minimum method name length in this spec: owner(5)=group(5) < samefile(8) < hardlink_to(11); Path.owner() returns the name of the file owner as a string; owner (5 chars) == len('chmod') (5 chars) == len('rglob') (5 chars) == len('lstat') (5 chars) from pathlib_extra177 — within-module tie at 5 with the three-way tie from pathlib_extra177; confirmed Python 3.14.3 macOS"]
    - [has_group,    "Path.__dict__.__contains__", ["group"], true, "pathlib.Path.__dict__.__contains__('group') == True — 'group' is a key in Path.__dict__, meaning group() is defined directly on Path; 'group' has 5 characters: 'g-r-o-u-p'; group (5 chars) == owner (5 chars): the two-way tie at 5 in this spec; Path.group() returns the name of the file's group as a string; group (5 chars) == len('write') (5 chars) from io_extra177 and len('flush') (5 chars) from io_extra177 and len('close') (5 chars) from io_extra177 — cross-module ties at 5 with the three-way tie from io_extra177; group (5) < samefile (8) by 3: consecutive levels in this spec are separated by 3; confirmed Python 3.14.3 macOS"]
    - [og_tie_5,     "Path.__dict__.__contains__", ["owner"], true, "pathlib.Path.__dict__.__contains__('owner') == True — confirming owner (5 chars) == group (5 chars): the two-way tie at 5 in this spec; owner and group are the two filesystem ownership metadata methods on Path: owner() returns the username and group() returns the groupname of the file's owner; both 5-char ownership methods start with different letters ('o' and 'g') and describe different dimensions of file ownership (user vs group); the 5-char tie (owner, group) is the minimum length group in this spec; confirmed Python 3.14.3 macOS"]
    - [og_lt_samef,  "Path.__dict__.__contains__", ["group"], true, "pathlib.Path.__dict__.__contains__('group') == True — confirming group (5 chars) < samefile (8 chars) by 3; the gap between the minimum (5) and middle (8) levels is 3, the same as the gap between middle (8) and maximum (11); the three-level sequence {5, 8, 11} with uniform gap 3 forms an arithmetic progression: 5, 5+3=8, 8+3=11; group (5 chars) == len('purge') (5 chars) from re and len('Match') (5 chars) from re — cross-module tie at 5 with re module names; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra178.pathlib_name_is_pathlib:
  description: "pathlib.__name__ == 'pathlib' — the public name of the pathlib module; 'pathlib' has 7 characters; pathlib (7 chars) == decimal (7 chars) in module name length: the two longest module names in this spec series; pathlib.__name__ (7 chars) == pathlib.__package__ (7 chars): the defining equality for package modules; pathlib.__name__ (7 chars) == len('Pattern') (7 chars) == len('Decimal') (7 chars) == len('Context') (7 chars): the module name ties with primary class names across re and decimal; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.__name__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra178.pathlib_package_is_pathlib:
  description: "pathlib.__package__ == 'pathlib' — pathlib is a package module: __package__ equals __name__; pathlib.__package__ (7 chars: 'pathlib') == pathlib.__name__ (7 chars: 'pathlib'): they are equal for package modules; pathlib.__package__ (7: 'pathlib') != io.__package__ (0: ''): io is a top-level module (empty package) while pathlib is a package (package == name); pathlib and re both satisfy __package__ == __name__, but re.__package__ (2: 're') < pathlib.__package__ (7: 'pathlib') by 5; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.__package__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra178.pathlib_spec_class_is_ModuleSpec:
  description: "pathlib.__spec__.__class__.__name__ == 'ModuleSpec' — pathlib.__spec__ is an importlib.machinery.ModuleSpec instance; 'ModuleSpec' has 10 characters: 'Module'(6)+'Spec'(4)=10; pathlib.__spec__.__class__.__name__ (10: 'ModuleSpec') == io.__spec__.__class__.__name__ (10: 'ModuleSpec') == re.__spec__.__class__.__name__ (10: 'ModuleSpec') == decimal.__spec__.__class__.__name__ (10: 'ModuleSpec'): a four-module cross-spec tie at 'ModuleSpec' (10 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant pathlib_extra178.Path_dict_has_hardlink_to:
  description: "pathlib.Path.__dict__.__contains__('hardlink_to') == True — hardlink_to() is defined directly on Path (added in Python 3.10); 'hardlink_to' has 11 characters: 'hard'(4)+'link_to'(7)=11; hardlink_to (11) is the maximum method name length in this spec; hardlink_to (11 chars) == len('write_bytes') (11 chars) from pathlib_extra176 and len('_TextIOBase') (11 chars) from io_extra178 — cross-spec and cross-module ties at 11; Path.hardlink_to(target) makes this path a hard link to target; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["hardlink_to"]
  expected: true

invariant pathlib_extra178.Path_dict_no_link_to:
  description: "pathlib.Path.__dict__.__contains__('link_to') == False — 'link_to' is NOT in Path.__dict__ in Python 3.12+ (removed after deprecation in 3.10); 'link_to' has 7 characters: 'link'(4)+'_to'(3)=7; link_to (7 chars) < hardlink_to (11 chars) by 4: the removed method name is 4 characters shorter than its replacement; the 'hard' prefix (4 chars) was added to make the name unambiguous about the type of link being created; the False assertion tests that the deprecated API is cleanly absent; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["link_to"]
  expected: false

invariant pathlib_extra178.Path_dict_has_samefile:
  description: "pathlib.Path.__dict__.__contains__('samefile') == True — samefile() is defined directly on Path; 'samefile' has 8 characters: 'same'(4)+'file'(4)=8; both components are equal at 4 chars — a 50/50 compound name; samefile (8) is the middle level: owner(5)=group(5) < samefile(8) < hardlink_to(11), with uniform gap of 3; samefile (8 chars) == len('absolute') (8 chars) from pathlib_extra176 — within-module tie at 8; Path.samefile(other) checks if two paths refer to the same inode; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["samefile"]
  expected: true

invariant pathlib_extra178.Path_dict_has_owner:
  description: "pathlib.Path.__dict__.__contains__('owner') == True — owner() is defined directly on Path; 'owner' has 5 characters; owner (5) ties with group (5) — the two-way minimum-length tie in this spec; owner (5 chars) == len('chmod') (5 chars) == len('rglob') (5 chars) == len('lstat') (5 chars) from pathlib_extra177 — within-module ties at 5; Path.owner() returns the string username of the file owner; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["owner"]
  expected: true

invariant pathlib_extra178.Path_dict_has_group:
  description: "pathlib.Path.__dict__.__contains__('group') == True — group() is defined directly on Path; 'group' has 5 characters; group (5) ties with owner (5) — the two-way minimum-length tie in this spec; group (5 chars) == len('write') (5 chars) from io_extra177 and len('flush') (5 chars) == len('close') (5 chars) — cross-module ties at 5 with the io three-way tie group; Path.group() returns the string group name of the file's owning group; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "Path.__dict__.__contains__"
  args: ["group"]
  expected: true
