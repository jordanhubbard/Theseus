spec: textwrap_extra3
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
    - "textwrap.zspec.zsdl — covers function names (wrap, fill, shorten, dedent, indent, TextWrapper class name)"
    - "textwrap_extra.zspec.zsdl — covers wrap/fill/dedent/indent/shorten __name__, TextWrapper __name__/__module__, wrap('hello world', width=5), fill('hello world', width=5), dedent('  hello\\n  world'), indent('hello', '  '), shorten with placeholder"
    - "textwrap_extra2.zspec.zsdl — covers wrap.__name__, fill.__name__, shorten.__name__, dedent.__name__, indent.__name__, TextWrapper.__name__, TextWrapper.__bases__[0].__name__, TextWrapper(width=10).__class__.__name__, wrap('a b c', width=3), fill('a b c', width=3), function __qualname__ and __module__ table"
  notes:
    - "textwrap.wrap.__module__ == 'textwrap' — wrap belongs to textwrap."
    - "textwrap.fill.__module__ == 'textwrap' — fill belongs to textwrap."
    - "textwrap.dedent.__module__ == 'textwrap' — dedent belongs to textwrap."
    - "textwrap.indent.__module__ == 'textwrap' — indent belongs to textwrap."
    - "textwrap.shorten.__module__ == 'textwrap' — shorten belongs to textwrap."
    - "textwrap.TextWrapper.__module__ == 'textwrap' — TextWrapper belongs to textwrap."
    - "textwrap.wrap('hello', width=3) == ['hel', 'lo'] — break_long_words=True by default so 'hello' is split."
    - "textwrap.fill('hello world', width=20) == 'hello world' — fits on one line, no wrapping."
    - "textwrap.indent('hello\\nworld', '> ') == '> hello\\n> world' — prefix applied to each line."
    - "textwrap.dedent('\\n  hello\\n  world\\n') == '\\nhello\\nworld\\n' — common indent stripped, blank first line preserved."
    - "textwrap.shorten('hello world foo', width=11, placeholder='...') == 'hello...' — 'world foo' must be dropped."
    - "textwrap.shorten('hello world', width=20) == 'hello world' — fits within width, returned unchanged."
    - "textwrap.wrap('', width=10) == [] — empty string produces empty list."
    - "textwrap.fill('', width=10) == '' — empty string produces empty string."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module affiliation — wrap
# ---------------------------------------------------------------------------

invariant textwrap_extra3.wrap.module:
  description: "textwrap.wrap.__module__ == 'textwrap'"
  category: module
  kind: python_call_eq
  function: wrap.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — fill
# ---------------------------------------------------------------------------

invariant textwrap_extra3.fill.module:
  description: "textwrap.fill.__module__ == 'textwrap'"
  category: module
  kind: python_call_eq
  function: fill.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — dedent
# ---------------------------------------------------------------------------

invariant textwrap_extra3.dedent.module:
  description: "textwrap.dedent.__module__ == 'textwrap'"
  category: module
  kind: python_call_eq
  function: dedent.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — indent
# ---------------------------------------------------------------------------

invariant textwrap_extra3.indent.module:
  description: "textwrap.indent.__module__ == 'textwrap'"
  category: module
  kind: python_call_eq
  function: indent.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — shorten
# ---------------------------------------------------------------------------

invariant textwrap_extra3.shorten.module:
  description: "textwrap.shorten.__module__ == 'textwrap'"
  category: module
  kind: python_call_eq
  function: shorten.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — TextWrapper class
# ---------------------------------------------------------------------------

invariant textwrap_extra3.TextWrapper.module:
  description: "textwrap.TextWrapper.__module__ == 'textwrap'"
  category: module
  kind: python_call_eq
  function: TextWrapper.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# wrap() — breaking long words and empty input
# ---------------------------------------------------------------------------

invariant textwrap_extra3.wrap.break_long_word:
  description: "textwrap.wrap('hello', width=3) == ['hel', 'lo'] — break_long_words=True splits mid-word"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["hello", 3]
  expected: ["hel", "lo"]

invariant textwrap_extra3.wrap.empty_string:
  description: "textwrap.wrap('', width=10) == [] — empty string produces empty list"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["", 10]
  expected: []

# ---------------------------------------------------------------------------
# fill() — wide width and empty input
# ---------------------------------------------------------------------------

invariant textwrap_extra3.fill.wide_width:
  description: "textwrap.fill('hello world', width=20) == 'hello world' — fits on one line"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["hello world", 20]
  expected: "hello world"

invariant textwrap_extra3.fill.empty_string:
  description: "textwrap.fill('', width=10) == '' — empty string fills to empty string"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["", 10]
  expected: ""

# ---------------------------------------------------------------------------
# indent() — angle-bracket prefix on multi-line input
# ---------------------------------------------------------------------------

invariant textwrap_extra3.indent.angle_bracket_prefix:
  description: "textwrap.indent('hello\\nworld', '> ') == '> hello\\n> world'"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["hello\nworld", "> "]
  expected: "> hello\n> world"

# ---------------------------------------------------------------------------
# dedent() — leading blank line preserved; common indent stripped
# ---------------------------------------------------------------------------

invariant textwrap_extra3.dedent.blank_first_line:
  description: "textwrap.dedent('\\n  hello\\n  world\\n') == '\\nhello\\nworld\\n'"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["\n  hello\n  world\n"]
  expected: "\nhello\nworld\n"

# ---------------------------------------------------------------------------
# shorten() — placeholder truncation and fits-within-width
# ---------------------------------------------------------------------------

invariant textwrap_extra3.shorten.truncated_with_placeholder:
  description: "textwrap.shorten('hello world foo', width=11, placeholder='...') == 'hello...'"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["hello world foo", 11]
  kwargs: {placeholder: "..."}
  expected: "hello..."

invariant textwrap_extra3.shorten.fits_within_width:
  description: "textwrap.shorten('hello world', width=20) == 'hello world' — no truncation needed"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["hello world", 20]
  expected: "hello world"
