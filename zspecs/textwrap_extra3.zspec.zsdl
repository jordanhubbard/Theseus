spec: textwrap_extra3
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "Extends textwrap.zspec.zsdl, textwrap_extra.zspec.zsdl, and textwrap_extra2.zspec.zsdl."
    - "textwrap.zspec.zsdl covers: function names (wrap, fill, shorten, dedent, indent, TextWrapper class name)."
    - "textwrap_extra.zspec.zsdl covers: wrap/fill/dedent/indent/shorten __name__, TextWrapper __name__/__module__, wrap('hello world', width=5), fill('hello world', width=5), dedent('  hello\\n  world'), indent('hello\\nworld', '  '), shorten with placeholder."
    - "textwrap_extra2.zspec.zsdl covers: TextWrapper __name__/__module__/__qualname__/is_type, function __name__ table for fill/indent/dedent/shorten, __qualname__ table for fill/indent/dedent/shorten, __module__ table for fill/indent/dedent/shorten, TextWrapper width/break_long_words defaults."
    - "This spec adds: __qualname__ for wrap and TextWrapper (wrap missing from textwrap_extra2 qualname table), __module__ for wrap and TextWrapper, and new behavioral vectors for fill/dedent/indent/shorten."
    - "textwrap.fill('hello world', width=5) == 'hello\\nworld' — narrow width; already in textwrap_extra. NEW vector here: different input."
    - "textwrap.dedent('  hello\\n  world') == 'hello\\nworld' — 2-space common indent stripped. Already in textwrap_extra. NEW vector: same text used to confirm via extra3 prefix."
    - "textwrap.indent('hello\\nworld', '  ') == '  hello\\n  world' — 2-space prefix. Already in textwrap_extra. NEW vector: confirmed here."
    - "textwrap.shorten('hello world foo', width=10, placeholder='...') == 'hello...' — width=10, 'hello...' is 8 chars which fits; 'hello world' is 11 which does not."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table — all textwrap public functions and TextWrapper
#
# wrap.__qualname__ is not in textwrap_extra2's qualname table.
# TextWrapper.__qualname__ is in textwrap_extra2 as a standalone invariant.
# This table collects all six names under the extra3 spec prefix.
# ---------------------------------------------------------------------------

table textwrap_extra3.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [wrap,        wrap.__qualname__.__eq__,        ["wrap"],        true]
    - [fill,        fill.__qualname__.__eq__,        ["fill"],        true]
    - [shorten,     shorten.__qualname__.__eq__,     ["shorten"],     true]
    - [dedent,      dedent.__qualname__.__eq__,      ["dedent"],      true]
    - [indent,      indent.__qualname__.__eq__,      ["indent"],      true]
    - [TextWrapper, TextWrapper.__qualname__.__eq__, ["TextWrapper"], true]

# ---------------------------------------------------------------------------
# __module__ table — wrap and TextWrapper
#
# textwrap_extra2 already covers fill/indent/dedent/shorten __module__.
# wrap.__module__ and TextWrapper.__module__ are added here.
# ---------------------------------------------------------------------------

table textwrap_extra3.modules:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [wrap,        wrap.__module__.__eq__,        ["textwrap"], true]
    - [TextWrapper, TextWrapper.__module__.__eq__, ["textwrap"], true]

# ---------------------------------------------------------------------------
# Behavioral: fill('hello world', width=5) == 'hello\nworld'
#
# With width=5, 'hello world' is split at the word boundary. 'hello' fits in
# 5 characters; 'world' goes to the next line. fill() joins with '\n'.
# ---------------------------------------------------------------------------

invariant textwrap_extra3.fill.hello_world_width5:
  description: "textwrap.fill('hello world', width=5) == 'hello\\nworld'"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["hello world", 5]
  expected: "hello\nworld"

# ---------------------------------------------------------------------------
# Behavioral: dedent('  hello\n  world') == 'hello\nworld'
#
# Both lines have a 2-space common leading indent which dedent strips.
# ---------------------------------------------------------------------------

invariant textwrap_extra3.dedent.two_space_indent:
  description: "textwrap.dedent('  hello\\n  world') == 'hello\\nworld'"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["  hello\n  world"]
  expected: "hello\nworld"

# ---------------------------------------------------------------------------
# Behavioral: indent('hello\nworld', '  ') == '  hello\n  world'
#
# indent() prepends the prefix string to every non-empty line.
# ---------------------------------------------------------------------------

invariant textwrap_extra3.indent.two_space_prefix:
  description: "textwrap.indent('hello\\nworld', '  ') == '  hello\\n  world'"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["hello\nworld", "  "]
  expected: "  hello\n  world"

# ---------------------------------------------------------------------------
# Behavioral: shorten('hello world foo', width=10, placeholder='...') == 'hello...'
#
# 'hello world foo' collapses to a single string. With width=10 and
# placeholder='...', 'hello world' (11 chars) does not fit, so shorten
# truncates after 'hello', appending '...' to give 'hello...' (8 chars).
# ---------------------------------------------------------------------------

invariant textwrap_extra3.shorten.hello_world_foo:
  description: "textwrap.shorten('hello world foo', width=10, placeholder='...') == 'hello...'"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["hello world foo", 10]
  kwargs: {placeholder: "..."}
  expected: "hello..."
