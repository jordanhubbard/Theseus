spec: threading_extra280
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Barrier is a pure-Python class: __module__ == 'threading', __class__.__name__ == 'type'."
    - "Barrier.__name__ == 'Barrier' (7 chars); __module__ == 'threading' (9 chars)."
    - "Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object."
    - "Barrier.wait.__qualname__ == 'Barrier.wait' (12 chars); __module__ == 'threading'."
    - "Barrier.reset.__qualname__ == 'Barrier.reset' (13 chars); __module__ == 'threading'."
    - "Barrier.abort.__qualname__ == 'Barrier.abort' (13 chars); __module__ == 'threading'."
    - "Barrier.parties, Barrier.n_waiting, and Barrier.broken are properties: __class__.__name__ == 'property'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Barrier class identity
#
# Barrier.__name__ == 'Barrier' (7 chars); __module__ == 'threading' (9 chars).
# __class__.__name__ == 'type'; __bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

table threading_extra280.barrier_class_identity:
  description: "threading.Barrier class identity — __name__, __module__, __class__.__name__, base class; name and module lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex280bci

  columns: [id, function, args, expected, description]
  rows:
    - [bc_name_eq,  Barrier.__name__.__eq__,                  ["Barrier"],   true, "threading.Barrier.__name__ == 'Barrier'; verified with Python 3.14.3"]
    - [bc_name_len, Barrier.__name__.__len__,                   [],           7,    "threading.Barrier.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [bc_mod_eq,   Barrier.__module__.__eq__,                  ["threading"], true, "threading.Barrier.__module__ == 'threading'; verified with Python 3.14.3"]
    - [bc_mod_len,  Barrier.__module__.__len__,                  [],           9,    "threading.Barrier.__module__.__len__() == 9; verified with Python 3.14.3"]
    - [bc_cls_eq,   Barrier.__class__.__name__.__eq__,          ["type"],      true, "threading.Barrier.__class__.__name__ == 'type' (pure-Python class); verified with Python 3.14.3"]
    - [bc_base_eq,  "Barrier.__bases__[0].__name__.__eq__",     ["object"],    true, "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.Barrier method qualnames — wait, reset, abort
#
# All three are pure-Python instance methods defined in threading.Barrier.
# Barrier.wait.__qualname__ == 'Barrier.wait' (12 chars).
# Barrier.reset.__qualname__ == 'Barrier.reset' (13 chars).
# Barrier.abort.__qualname__ == 'Barrier.abort' (13 chars).
#
# threading.Barrier.parties, n_waiting, broken are properties.
# ---------------------------------------------------------------------------

table threading_extra280.barrier_method_qualnames:
  description: "threading.Barrier method qualnames — wait, reset, abort; qualname lengths; parties/n_waiting/broken are properties; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex280bmq

  columns: [id, function, args, expected, description]
  rows:
    - [wa_qn_eq,   Barrier.wait.__qualname__.__eq__,          ["Barrier.wait"],  true, "threading.Barrier.wait.__qualname__ == 'Barrier.wait'; verified with Python 3.14.3"]
    - [wa_qn_len,  Barrier.wait.__qualname__.__len__,           [],              12,   "threading.Barrier.wait.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [wa_mod_eq,  Barrier.wait.__module__.__eq__,              ["threading"],    true, "threading.Barrier.wait.__module__ == 'threading'; verified with Python 3.14.3"]
    - [re_qn_eq,   Barrier.reset.__qualname__.__eq__,          ["Barrier.reset"], true, "threading.Barrier.reset.__qualname__ == 'Barrier.reset'; verified with Python 3.14.3"]
    - [re_qn_len,  Barrier.reset.__qualname__.__len__,           [],              13,   "threading.Barrier.reset.__qualname__.__len__() == 13; verified with Python 3.14.3"]
    - [re_mod_eq,  Barrier.reset.__module__.__eq__,              ["threading"],    true, "threading.Barrier.reset.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ab_qn_eq,   Barrier.abort.__qualname__.__eq__,          ["Barrier.abort"], true, "threading.Barrier.abort.__qualname__ == 'Barrier.abort'; verified with Python 3.14.3"]
    - [ab_qn_len,  Barrier.abort.__qualname__.__len__,           [],              13,   "threading.Barrier.abort.__qualname__.__len__() == 13; verified with Python 3.14.3"]
    - [pa_cls_eq,  Barrier.parties.__class__.__name__.__eq__,  ["property"],      true, "threading.Barrier.parties.__class__.__name__ == 'property'; verified with Python 3.14.3"]
    - [nw_cls_eq,  Barrier.n_waiting.__class__.__name__.__eq__, ["property"],     true, "threading.Barrier.n_waiting.__class__.__name__ == 'property'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra280
# ---------------------------------------------------------------------------

invariant threading_extra280.barrier_is_type:
  description: "threading.Barrier.__class__.__name__ == 'type' — Barrier is a pure-Python class object"
  category: identity
  kind: python_call_eq
  function: Barrier.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra280.barrier_base_is_object:
  description: "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object with no intermediate base class"
  category: identity
  kind: python_call_eq
  function: "Barrier.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra280.barrier_name_length_is_7:
  description: "threading.Barrier.__name__.__len__() == 7 — 'Barrier' has 7 characters"
  category: identity
  kind: python_call_eq
  function: Barrier.__name__.__len__
  args: []
  expected: 7

invariant threading_extra280.barrier_module_is_threading:
  description: "threading.Barrier.__module__ == 'threading' — Barrier is defined in the threading module"
  category: identity
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra280.barrier_wait_qualname:
  description: "threading.Barrier.wait.__qualname__ == 'Barrier.wait' — the method's qualified name encodes the owning class"
  category: identity
  kind: python_call_eq
  function: Barrier.wait.__qualname__.__eq__
  args: ["Barrier.wait"]
  expected: true

invariant threading_extra280.barrier_reset_qualname:
  description: "threading.Barrier.reset.__qualname__ == 'Barrier.reset' — the method's qualified name encodes the owning class"
  category: identity
  kind: python_call_eq
  function: Barrier.reset.__qualname__.__eq__
  args: ["Barrier.reset"]
  expected: true

invariant threading_extra280.barrier_abort_qualname:
  description: "threading.Barrier.abort.__qualname__ == 'Barrier.abort' — the method's qualified name encodes the owning class"
  category: identity
  kind: python_call_eq
  function: Barrier.abort.__qualname__.__eq__
  args: ["Barrier.abort"]
  expected: true

invariant threading_extra280.barrier_parties_is_property:
  description: "threading.Barrier.parties.__class__.__name__ == 'property' — parties is a property descriptor, not a plain attribute"
  category: identity
  kind: python_call_eq
  function: Barrier.parties.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra280.barrier_n_waiting_is_property:
  description: "threading.Barrier.n_waiting.__class__.__name__ == 'property' — n_waiting is a property descriptor, not a plain attribute"
  category: identity
  kind: python_call_eq
  function: Barrier.n_waiting.__class__.__name__.__eq__
  args: ["property"]
  expected: true
