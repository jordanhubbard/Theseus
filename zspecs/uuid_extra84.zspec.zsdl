spec: uuid_extra84
version: ">=3.9"
extends: uuid_extra83
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra83.zspec.zsdl — covers UUID dunder method __qualname__ lengths / UUID string and numeric property fget __qualname__ lengths / module-level uuid function qualname equality (table + invariants)."
    - "uuid_extra82.zspec.zsdl — covers uuid.SafeUUID enum member class identity / uuid module identity (__name__/__package__/__spec__/__loader__) (table + invariants)."
    - "uuid_extra80.zspec.zsdl — covers UUID property __class__.__name__ identity / SafeUUID class identity (__name__/__module__/__qualname__/__bases__[0].__name__) / SafeUUID.__mro__.__len__()==3 (table + invariants)."
    - "uuid_extra79.zspec.zsdl — covers UUID dunder method __qualname__.__eq__ / uuid1/uuid3/uuid4/uuid5 __qualname__.__eq__ / UUID.__name__/__module__.__eq__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra83; it does NOT duplicate invariants present in those files."
    - "Wave 256 theme: uuid.UUID and uuid.SafeUUID class identity — __name__, __module__, __qualname__, __bases__, __mro__, __class__.__name__."
    - "uuid.UUID.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__qualname__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__qualname__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__mro__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_NCS.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RFC_4122.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_MICROSOFT.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.RESERVED_FUTURE.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID')
# uuid.UUID.__module__.__eq__('uuid')
# uuid.UUID.__qualname__.__eq__('UUID')
#
# Wave 256 theme: UUID class string identity attributes.
#
# uuid.UUID.__name__, __module__, and __qualname__ are all basic string identity
# attributes of the UUID class. uuid_extra79 anchors __name__/__module__ via __eq__;
# this table groups all three string identity attrs together under uuidclsid84.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra84.uuid_class_string_identity:
  description: "uuid.UUID.__name__.__eq__('UUID')==True / UUID.__module__.__eq__('uuid')==True / UUID.__qualname__.__eq__('UUID')==True — UUID class string identity: __name__, __module__, and __qualname__ are all 'UUID' or 'uuid'; uuid_extra79 anchors __name__/__module__; this table groups all three under uuidclsid84; first uuidclsid84 anchor for UUID class string identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidclsid84

  columns: [id, function, args, expected]
  rows:
    - [uuid_name_eq,      UUID.__name__.__eq__,      ["UUID"], true]
    - [uuid_module_eq,    UUID.__module__.__eq__,    ["uuid"], true]
    - [uuid_qualname_eq,  UUID.__qualname__.__eq__,  ["UUID"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__bases__[0]/__name__.__eq__('object')
# uuid.UUID.__mro__/__len__()==2
# uuid.UUID.__class__/__name__.__eq__('type')
#
# Wave 256 theme: UUID class hierarchy attributes.
#
# uuid.UUID inherits directly from object, giving a two-entry MRO. As a class,
# UUID.__class__.__name__ is 'type'. uuid_extra80 anchors __bases__[0].__name__
# for UUID; this table groups bases, mro length, and class name together under
# uuidclsid84. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra84.uuid_class_hierarchy:
  description: "uuid.UUID/__bases__[0]/__name__.__eq__('object')==True / UUID/__mro__/__len__()==2 / UUID/__class__/__name__.__eq__('type')==True — UUID inherits directly from object (MRO length 2); UUID itself is a type (metaclass is type); uuid_extra80 anchors __bases__[0].__name__; this table groups bases/mro/class under uuidclsid84; first uuidclsid84 anchor for UUID class hierarchy"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidclsid84

  columns: [id, function, args, expected]
  rows:
    - ["uuid_bases0_name_eq",  "UUID.__bases__[0].__name__.__eq__",  ["object"], true]
    - [uuid_mro_len,           UUID.__mro__.__len__,                 [],         2]
    - [uuid_class_name_eq,     UUID.__class__.__name__.__eq__,       ["type"],   true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__name__.__eq__('SafeUUID')
# uuid.SafeUUID.__module__.__eq__('uuid')
# uuid.SafeUUID.__qualname__.__eq__('SafeUUID')
# uuid.SafeUUID.__bases__[0]/__name__.__eq__('Enum')
# uuid.SafeUUID.__mro__/__len__()==3
#
# Wave 256 theme: SafeUUID class identity and hierarchy.
#
# uuid.SafeUUID is an enum.Enum subclass. Its __name__ and __qualname__ are
# 'SafeUUID', __module__ is 'uuid', __bases__[0].__name__ is 'Enum', and
# __mro__.__len__() is 3. uuid_extra80 anchors SafeUUID class identity including
# __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); this
# table groups all five under uuidclsid84. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra84.safeuuid_class_identity:
  description: "uuid.SafeUUID.__name__.__eq__('SafeUUID')==True / SafeUUID.__module__.__eq__('uuid')==True / SafeUUID.__qualname__.__eq__('SafeUUID')==True / SafeUUID/__bases__[0]/__name__.__eq__('Enum')==True / SafeUUID/__mro__/__len__()==3 — SafeUUID is an Enum subclass with __name__/__qualname__=='SafeUUID', __module__=='uuid', and MRO length 3; uuid_extra80 first anchors these; this table cross-checks all five under uuidclsid84; first uuidclsid84 anchor for SafeUUID class identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidclsid84

  columns: [id, function, args, expected]
  rows:
    - [safeuuid_name_eq,          SafeUUID.__name__.__eq__,          ["SafeUUID"], true]
    - [safeuuid_module_eq,        SafeUUID.__module__.__eq__,        ["uuid"],     true]
    - [safeuuid_qualname_eq,      SafeUUID.__qualname__.__eq__,      ["SafeUUID"], true]
    - ["safeuuid_bases0_name_eq", "SafeUUID.__bases__[0].__name__.__eq__", ["Enum"], true]
    - [safeuuid_mro_len,          SafeUUID.__mro__.__len__,          [],           3]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_URL/__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_OID/__class__.__name__.__eq__('UUID')
# uuid.NAMESPACE_X500/__class__.__name__.__eq__('UUID')
# uuid.RESERVED_NCS/__class__.__name__.__eq__('str')
# uuid.RFC_4122/__class__.__name__.__eq__('str')
# uuid.RESERVED_MICROSOFT/__class__.__name__.__eq__('str')
# uuid.RESERVED_FUTURE/__class__.__name__.__eq__('str')
#
# Wave 256 theme: uuid namespace constants and reserved string constants class names.
#
# The four namespace constants (NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID,
# NAMESPACE_X500) are UUID instances. The four reserved variant constants
# (RESERVED_NCS, RFC_4122, RESERVED_MICROSOFT, RESERVED_FUTURE) are plain str.
# No prior uuid spec anchors these __class__.__name__.__eq__ calls under uuidclsid84.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra84.uuid_namespace_and_reserved_class_names:
  description: "uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID')==True / NAMESPACE_URL/__class__.__name__.__eq__('UUID')==True / NAMESPACE_OID/__class__.__name__.__eq__('UUID')==True / NAMESPACE_X500/__class__.__name__.__eq__('UUID')==True / RESERVED_NCS/__class__.__name__.__eq__('str')==True / RFC_4122/__class__.__name__.__eq__('str')==True / RESERVED_MICROSOFT/__class__.__name__.__eq__('str')==True / RESERVED_FUTURE/__class__.__name__.__eq__('str')==True — namespace constants are UUID instances; reserved variant string constants are str; no prior uuid spec anchors these under uuidclsid84; first uuidclsid84 anchor for namespace/reserved class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidclsid84

  columns: [id, function, args, expected]
  rows:
    - [namespace_dns_class_eq,        NAMESPACE_DNS.__class__.__name__.__eq__,        ["UUID"], true]
    - [namespace_url_class_eq,        NAMESPACE_URL.__class__.__name__.__eq__,        ["UUID"], true]
    - [namespace_oid_class_eq,        NAMESPACE_OID.__class__.__name__.__eq__,        ["UUID"], true]
    - [namespace_x500_class_eq,       NAMESPACE_X500.__class__.__name__.__eq__,       ["UUID"], true]
    - [reserved_ncs_class_eq,         RESERVED_NCS.__class__.__name__.__eq__,         ["str"],  true]
    - [rfc_4122_class_eq,             RFC_4122.__class__.__name__.__eq__,             ["str"],  true]
    - [reserved_microsoft_class_eq,   RESERVED_MICROSOFT.__class__.__name__.__eq__,   ["str"],  true]
    - [reserved_future_class_eq,      RESERVED_FUTURE.__class__.__name__.__eq__,      ["str"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID') — standalone
#
# uuid.UUID.__name__ is 'UUID'. uuid_extra79 first anchors this via __eq__; this
# standalone re-anchors it under uuidclsid84. UUID is the central class of the
# uuid module providing immutable UUID objects. First standalone for UUID.__name__
# under uuidclsid84. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra84.uuid_name_eq:
  description: "uuid.UUID.__name__.__eq__('UUID') == True — UUID is the central class of the uuid module; its __name__ is 'UUID'; uuid_extra79 first anchors this; this standalone re-anchors under uuidclsid84; first standalone for UUID.__name__ under uuidclsid84"
  category: type_identity
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__mro__.__len__() == 2 — standalone
#
# uuid.UUID.__mro__.__len__() is 2 ([UUID, object]). UUID inherits directly from
# object with no intermediate classes. No prior uuid spec anchors UUID.__mro__.__len__
# as a standalone under uuidclsid84. First standalone for UUID MRO length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra84.uuid_mro_len:
  description: "uuid.UUID.__mro__.__len__() == 2 — UUID inherits directly from object; its MRO is [UUID, object] with length 2; no prior uuid spec anchors UUID.__mro__.__len__ as a standalone under uuidclsid84; first standalone for UUID MRO length under uuidclsid84"
  category: type_identity
  kind: python_call_eq
  function: UUID.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') — standalone
#
# uuid.SafeUUID.__bases__[0].__name__ is 'Enum'. SafeUUID is a direct subclass of
# enum.Enum. uuid_extra80 first anchors this; this standalone re-anchors it under
# uuidclsid84. First standalone for SafeUUID.__bases__[0].__name__ under uuidclsid84.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra84.safeuuid_bases0_name_eq:
  description: "uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') == True — SafeUUID is a direct subclass of enum.Enum; its __bases__[0].__name__ is 'Enum'; uuid_extra80 first anchors this; first standalone for SafeUUID base class name under uuidclsid84"
  category: type_identity
  kind: python_call_eq
  function: "SafeUUID.__bases__[0].__name__.__eq__"
  args: ["Enum"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_DNS is a UUID instance representing the DNS namespace UUID.
# Its __class__.__name__ is 'UUID'. No prior uuid spec anchors
# NAMESPACE_DNS.__class__.__name__.__eq__ as a standalone under uuidclsid84.
# First standalone for NAMESPACE_DNS class name. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra84.namespace_dns_class_eq:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is a UUID instance for the DNS namespace (6ba7b810-9dad-11d1-80b4-00c04fd430c8); its __class__.__name__ is 'UUID'; no prior uuid spec anchors this __eq__ call; first standalone for NAMESPACE_DNS class name under uuidclsid84"
  category: type_identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.RESERVED_NCS/__class__.__name__.__eq__('str') — standalone
#
# uuid.RESERVED_NCS is a plain str constant with value 'reserved for NCS
# compatibility'. Its __class__.__name__ is 'str'. No prior uuid spec anchors
# RESERVED_NCS.__class__.__name__.__eq__ as a standalone under uuidclsid84.
# First standalone for RESERVED_NCS class name. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra84.reserved_ncs_class_eq:
  description: "uuid.RESERVED_NCS.__class__.__name__.__eq__('str') == True — RESERVED_NCS is a plain str constant ('reserved for NCS compatibility') describing the NCS variant; its __class__.__name__ is 'str'; no prior uuid spec anchors this __eq__ call; first standalone for RESERVED_NCS class name under uuidclsid84"
  category: type_identity
  kind: python_call_eq
  function: RESERVED_NCS.__class__.__name__.__eq__
  args: ["str"]
  expected: true
