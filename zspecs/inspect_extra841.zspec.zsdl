spec: inspect_extra841
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - inspect module standard library documentation
    - Python 3.9+ inspect API
  not_derived_from:
    - executing or stack_data third-party introspection packages
    - dis module or bytecode analysis tools
  notes:
    - Covers __qualname__ and __module__ identity for inspect utility functions
    - All functions are pure Python defined in the inspect module itself
    - getfile and getsource may raise OSError at runtime but qualname/module are static attributes
  created_at: "2026-04-12"

table inspect_extra841.qualname_and_module:
  description: Verify __qualname__ and __module__ identity for inspect module utility functions
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: ins841xx
  columns: [id, function, args, expected]
  rows:
    - [ins841xx001, inspect.getfile.__qualname__.__eq__, ["getfile"], true]
    - [ins841xx002, inspect.getfile.__module__.__eq__, ["inspect"], true]
    - [ins841xx003, inspect.getsource.__qualname__.__eq__, ["getsource"], true]
    - [ins841xx004, inspect.getsource.__module__.__eq__, ["inspect"], true]
    - [ins841xx005, inspect.getdoc.__qualname__.__eq__, ["getdoc"], true]
    - [ins841xx006, inspect.getdoc.__module__.__eq__, ["inspect"], true]
    - [ins841xx007, inspect.getcomments.__qualname__.__eq__, ["getcomments"], true]
    - [ins841xx008, inspect.getcomments.__module__.__eq__, ["inspect"], true]
    - [ins841xx009, inspect.getmodule.__qualname__.__eq__, ["getmodule"], true]
    - [ins841xx010, inspect.getmodule.__module__.__eq__, ["inspect"], true]
    - [ins841xx011, inspect.stack.__qualname__.__eq__, ["stack"], true]
    - [ins841xx012, inspect.stack.__module__.__eq__, ["inspect"], true]
