spec: sendgrid_rust
version: ">=3.9"
backend: rust_module(sendgrid_rust)

docs: https://github.com/sendgrid/sendgrid-python

provenance:
  derived_from:
    - "https://github.com/sendgrid/sendgrid-python — sendgrid"
  notes:
    - "sendgrid provides SendGrid email API integration."
    - "sendgrid.SendGridAPIClient is a class."
    - "sendgrid.helpers.mail.Mail is a class."
    - "sendgrid.version.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant sendgrid_rust.has_api_client:
  description: "sendgrid.SendGridAPIClient is a class"
  category: presence
  kind: python_call_eq
  function: sendgrid_has_api_client
  args: []
  expected: true

invariant sendgrid_rust.has_mail:
  description: "sendgrid.helpers.mail.Mail is a class"
  category: presence
  kind: python_call_eq
  function: sendgrid_has_mail
  args: []
  expected: true

invariant sendgrid_rust.version_nonempty:
  description: "sendgrid.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: sendgrid_version_nonempty
  args: []
  expected: true

