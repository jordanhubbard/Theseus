  args: ["getaddrinfo"]
  expected: true

invariant socket_extra181.getnameinfo_name_is_getnameinfo:
  description: "socket.getnameinfo.__name__ == 'getnameinfo' — len=11; translates socket address to host/service names; new to extra181"
  category: identity
  kind: python_call_eq
  function: getnameinfo.__name__.__eq__
  args: ["getnameinfo"]
  expected: true

invariant socket_extra181.setdefaulttimeout_name_is_setdefaulttimeout:
  description: "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout' — len=17; sets the default blocking timeout; new to extra181"
  category: identity
  kind: python_call_eq
  function: setdefaulttimeout.__name__.__eq__
  args: ["setdefaulttimeout"]
  expected: true

invariant socket_extra181.getdefaulttimeout_name_is_getdefaulttimeout:
  description: "socket.getdefaulttimeout.__name__ == 'getdefaulttimeout' — len=17; returns the default blocking timeout; new to extra181"
  category: identity
  kind: python_call_eq
