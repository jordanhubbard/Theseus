  args: ["getdefaulttimeout"]
  expected: true

invariant socket_extra181.htons_name_is_htons:
  description: "socket.htons.__name__ == 'htons' — len=5; host-to-network short byte-order conversion; new to extra181"
  category: identity
  kind: python_call_eq
  function: htons.__name__.__eq__
  args: ["htons"]
  expected: true

invariant socket_extra181.ntohs_name_is_ntohs:
  description: "socket.ntohs.__name__ == 'ntohs' — len=5; network-to-host short byte-order conversion; new to extra181"
  category: identity
  kind: python_call_eq
  function: ntohs.__name__.__eq__
  args: ["ntohs"]
  expected: true
