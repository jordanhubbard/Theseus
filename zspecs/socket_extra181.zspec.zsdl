spec: socket_extra181
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket.zspec.zsdl — core socket vectors."
    - "socket_extra.zspec.zsdl through socket_extra180.zspec.zsdl — prior extras."
  notes:
    - "socket.gethostname.__name__ == 'gethostname' — len=11; C-level builtin in the socket module."
    - "socket.gethostbyname.__name__ == 'gethostbyname' — len=13; C-level builtin."
    - "socket.getaddrinfo.__name__ == 'getaddrinfo' — len=11; C-level builtin."
    - "socket.getnameinfo.__name__ == 'getnameinfo' — len=11; C-level builtin."
    - "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout' — len=17; C-level builtin."
    - "socket.getdefaulttimeout.__name__ == 'getdefaulttimeout' — len=17; C-level builtin."
    - "socket.htons.__name__ == 'htons' — len=5; host-to-network-short byte-order conversion."
    - "socket.ntohs.__name__ == 'ntohs' — len=5; network-to-host-short byte-order conversion."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: gethostname and gethostbyname — function name identity
#
# socket.gethostname.__name__  == 'gethostname'   (len=11)
# socket.gethostbyname.__name__ == 'gethostbyname' (len=13)
#
# gethostname returns the machine's hostname as a string.
# gethostbyname resolves a hostname to its IPv4 address string.
# Both are C-level builtins in the socket module. New to extra181.
# ---------------------------------------------------------------------------

table socket_extra181.gethostname_gethostbyname_identity:
  description: "gethostname.__name__=='gethostname' and gethostbyname.__name__=='gethostbyname'; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: socketfuncs181

  columns: [id, function, args, expected, description]
  rows:
    - [gethostname_name_eq,
       "gethostname.__name__.__eq__",
       ["gethostname"],
       true,
       "socket.gethostname.__name__.__eq__('gethostname') == True — gethostname's __name__ is 'gethostname'; len=11; new to extra181"]
    - [gethostbyname_name_eq,
       "gethostbyname.__name__.__eq__",
       ["gethostbyname"],
       true,
       "socket.gethostbyname.__name__.__eq__('gethostbyname') == True — gethostbyname's __name__ is 'gethostbyname'; len=13; new to extra181"]
    - [gethostname_name_len,
       "gethostname.__name__.__len__",
       [],
       11,
       "socket.gethostname.__name__.__len__() == 11 — 'gethostname' has 11 characters; new to extra181"]
    - [gethostbyname_name_len,
       "gethostbyname.__name__.__len__",
       [],
       13,
       "socket.gethostbyname.__name__.__len__() == 13 — 'gethostbyname' has 13 characters; new to extra181"]

# ---------------------------------------------------------------------------
# Table 2: getaddrinfo and getnameinfo — function name identity
#
# socket.getaddrinfo.__name__ == 'getaddrinfo' (len=11)
# socket.getnameinfo.__name__ == 'getnameinfo' (len=11)
#
# getaddrinfo translates a host/service to socket address structures.
# getnameinfo translates a socket address to host/service names.
# Both are C-level builtins in the socket module. New to extra181.
# ---------------------------------------------------------------------------

table socket_extra181.getaddrinfo_getnameinfo_identity:
  description: "getaddrinfo.__name__=='getaddrinfo' and getnameinfo.__name__=='getnameinfo'; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: socketfuncs181

  columns: [id, function, args, expected, description]
  rows:
    - [getaddrinfo_name_eq,
       "getaddrinfo.__name__.__eq__",
       ["getaddrinfo"],
       true,
       "socket.getaddrinfo.__name__.__eq__('getaddrinfo') == True — getaddrinfo's __name__ is 'getaddrinfo'; len=11; new to extra181"]
    - [getnameinfo_name_eq,
       "getnameinfo.__name__.__eq__",
       ["getnameinfo"],
       true,
       "socket.getnameinfo.__name__.__eq__('getnameinfo') == True — getnameinfo's __name__ is 'getnameinfo'; len=11; new to extra181"]
    - [getaddrinfo_name_len,
       "getaddrinfo.__name__.__len__",
       [],
       11,
       "socket.getaddrinfo.__name__.__len__() == 11 — 'getaddrinfo' has 11 characters; new to extra181"]
    - [getnameinfo_name_len,
       "getnameinfo.__name__.__len__",
       [],
       11,
       "socket.getnameinfo.__name__.__len__() == 11 — 'getnameinfo' has 11 characters; new to extra181"]

# ---------------------------------------------------------------------------
# Table 3: timeout functions and byte-order functions — name identity
#
# socket.setdefaulttimeout.__name__ == 'setdefaulttimeout' (len=17)
# socket.getdefaulttimeout.__name__ == 'getdefaulttimeout' (len=17)
# socket.htons.__name__             == 'htons'             (len=5)
# socket.ntohs.__name__             == 'ntohs'             (len=5)
#
# setdefaulttimeout/getdefaulttimeout control the default blocking timeout
# for all new socket objects. htons/ntohs convert 16-bit integers between
# host and network byte order. New to extra181.
# ---------------------------------------------------------------------------

table socket_extra181.timeout_byteorder_identity:
  description: "setdefaulttimeout, getdefaulttimeout, htons, ntohs name identity; new to extra181"
  kind: python_call_eq
  category: identity
  id_prefix: socketfuncs181

  columns: [id, function, args, expected, description]
  rows:
    - [setdefaulttimeout_name_eq,
       "setdefaulttimeout.__name__.__eq__",
       ["setdefaulttimeout"],
       true,
       "socket.setdefaulttimeout.__name__.__eq__('setdefaulttimeout') == True — len=17; sets the default socket timeout; new to extra181"]
    - [getdefaulttimeout_name_eq,
       "getdefaulttimeout.__name__.__eq__",
       ["getdefaulttimeout"],
       true,
       "socket.getdefaulttimeout.__name__.__eq__('getdefaulttimeout') == True — len=17; returns the default socket timeout; new to extra181"]
    - [htons_name_eq,
       "htons.__name__.__eq__",
       ["htons"],
       true,
       "socket.htons.__name__.__eq__('htons') == True — htons converts a 16-bit int from host to network byte order; len=5; new to extra181"]
    - [ntohs_name_eq,
       "ntohs.__name__.__eq__",
       ["ntohs"],
       true,
       "socket.ntohs.__name__.__eq__('ntohs') == True — ntohs converts a 16-bit int from network to host byte order; len=5; new to extra181"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra181
# ---------------------------------------------------------------------------

invariant socket_extra181.gethostname_name_is_gethostname:
  description: "socket.gethostname.__name__ == 'gethostname' — len=11; C-level builtin; new to extra181"
  category: identity
  kind: python_call_eq
  function: gethostname.__name__.__eq__
  args: ["gethostname"]
  expected: true

invariant socket_extra181.gethostbyname_name_is_gethostbyname:
  description: "socket.gethostbyname.__name__ == 'gethostbyname' — len=13; resolves hostname to IPv4 string; new to extra181"
  category: identity
  kind: python_call_eq
  function: gethostbyname.__name__.__eq__
  args: ["gethostbyname"]
  expected: true

invariant socket_extra181.getaddrinfo_name_is_getaddrinfo:
  description: "socket.getaddrinfo.__name__ == 'getaddrinfo' — len=11; translates host/service to address structures; new to extra181"
  category: identity
  kind: python_call_eq
