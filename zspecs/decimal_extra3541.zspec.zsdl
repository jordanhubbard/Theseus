spec: dc3541
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 683 (dc3541): __format__, __sizeof__, __dir__ dict-presence checks for decimal types."
    - "decimal.Decimal defines __format__ (true): Decimal implements a custom format specification mini-language supporting e, E, f, F, g, G, n, % format codes and full decimal format spec."
    - "decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow: do NOT define __format__, __sizeof__, or __dir__ in their own __dict__ (false)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __format__ dict-presence — operator.contains(Cls.__dict__, '__format__')
#
# decimal.Decimal defines __format__ to support the decimal format spec.
# ---------------------------------------------------------------------------

table dc3541.format:
  description: "decimal types __format__ dict-presence checks; wave 683"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3541
  columns: [id, function, args, expected]
  rows:
    - ["dc3541001", operator.contains, [decimal.Decimal.__dict__,          "__format__"], true]
    - ["dc3541002", operator.contains, [decimal.Context.__dict__,          "__format__"], false]
    - ["dc3541003", operator.contains, [decimal.DecimalException.__dict__,  "__format__"], false]
    - ["dc3541004", operator.contains, [decimal.InvalidOperation.__dict__,  "__format__"], false]
    - ["dc3541005", operator.contains, [decimal.Overflow.__dict__,          "__format__"], false]

