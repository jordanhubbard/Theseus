spec: decimal_extra161
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal.__repr__ and __str__ method qualnames, and decimal.Decimal.__hash__ and __bool__ qualnames."
    - "decimal.Decimal.__repr__.__qualname__ == 'Decimal.__repr__' (len=16; 'Decimal.' (8) + '__repr__' (8) = 16)."
    - "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' (len=15; 'Decimal.' (8) + '__str__' (7) = 15)."
    - "decimal.Decimal.__hash__.__qualname__ == 'Decimal.__hash__' (len=16; 'Decimal.' (8) + '__hash__' (8) = 16)."
    - "decimal.Decimal.__bool__.__qualname__ == 'Decimal.__bool__' (len=16; 'Decimal.' (8) + '__bool__' (8) = 16)."
    - "All four dunders are directly defined in Decimal.__dict__ — none are inherited from object."
    - "__repr__, __hash__, and __bool__ all have qualname length 16 — forming a three-way tie at 16."
    - "__str__ stands alone at length 15 — the sole occupant of length 15 in this spec."
    - "__str__ (15) is 1 shorter than __repr__=__hash__=__bool__ (16) because '__str__' (7 chars) < '__repr__'='__hash__'='__bool__' (all 8 chars) by 1."
    - "The 'Decimal.' prefix is 8 characters: 'Decimal' (7) + '.' (1) = 8."
    - "Key qualname length ranking: __str__=15 (sole), __repr__=__hash__=__bool__=16 (three-way tie)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__repr__ and __str__ qualnames
# __repr__ = 'Decimal.__repr__' (len=16)
# __str__ = 'Decimal.__str__' (len=15, sole occupant — 1 shorter than the others)
# ---------------------------------------------------------------------------

table decimal_extra161.Decimal_repr_str_qualnames:
  description: "decimal.Decimal.__repr__ and __str__ qualnames: __repr__='Decimal.__repr__' (len=16), __str__='Decimal.__str__' (len=15); __str__ is 1 shorter than __repr__ because '__str__' (7 chars) < '__repr__' (8 chars) by 1; 'Decimal.' prefix is 8 chars"
  kind: python_call_eq
  category: qualname
  id_prefix: dqn161

  columns: [id, function, args, expected, description]
  rows:
    - [dec_repr_qeq,  decimal.Decimal.__repr__.__qualname__.__eq__,  ["Decimal.__repr__"],  true, "decimal.Decimal.__repr__.__qualname__ == 'Decimal.__repr__' (Decimal.__repr__() returns a string of the form Decimal('value') suitable for eval(); the repr is unambiguous and round-trips through eval(repr(d)) == d for finite values; '__repr__' has 8 characters: '__' (2) + 'repr' (4) + '__' (2) = 8; 'Decimal.__repr__' has 16 characters: 'Decimal.' (8) + '__repr__' (8) = 16; __repr__ (16) is part of the three-way tie at 16 with __hash__ and __bool__; __repr__ (16) > __str__ (15) by 1 character — 'repr' (4 chars) > 'str' (3 chars) by 1, which propagates through the prefix to give a 1-character qualname difference; Decimal.__repr__() is directly defined on Decimal — confirmed by '__repr__' in decimal.Decimal.__dict__)"]
    - [dec_str_qeq,   decimal.Decimal.__str__.__qualname__.__eq__,   ["Decimal.__str__"],   true, "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' (Decimal.__str__() returns the human-readable string representation of the value — the decimal numeral without the 'Decimal(...)' wrapper; Decimal('3.14').__str__() == '3.14'; '__str__' has 7 characters: '__' (2) + 'str' (3) + '__' (2) = 7; 'Decimal.__str__' has 15 characters: 'Decimal.' (8) + '__str__' (7) = 15; __str__ (15) is the sole occupant of qualname length 15 in this spec — the only one of the four dunders with an odd-character core name ('str' = 3 chars vs 'repr'/'hash'/'bool' all at 4 chars); __str__ (15) < __repr__=__hash__=__bool__ (16) by 1; Decimal.__str__() is directly defined on Decimal, not inherited from object)"]
    - [dec_repr_len,  decimal.Decimal.__repr__.__qualname__.__len__,  [],                   16,   "decimal.Decimal.__repr__.__qualname__.__len__() == 16 — 'Decimal.__repr__' has 16 characters: 'Decimal.' (8) + '__repr__' (8) = 16; the prefix 'Decimal.' (8 chars) equals '__repr__' (8 chars) in length — a symmetric qualname; 16 is the three-way tie length shared by __repr__, __hash__, and __bool__; the length 16 arises because the 'Decimal.' prefix (8 chars) plus each 8-character dunder method name produces exactly 16; '__repr__' (8) = '__' (2) + 'repr' (4) + '__' (2) = 8; compared to __str__ (15), the difference is exactly 1 character — 'repr' (4) > 'str' (3) by 1")"]
    - [dec_str_len,   decimal.Decimal.__str__.__qualname__.__len__,   [],                   15,   "decimal.Decimal.__str__.__qualname__.__len__() == 15 — 'Decimal.__str__' has 15 characters: 'Decimal.' (8) + '__str__' (7) = 15; __str__ stands alone at 15 — the sole occupant of qualname length 15 in this spec; __str__ (15) is the minimum qualname length in this spec; the three-way tie at 16 (repr, hash, bool) is 1 longer than __str__ (15); '__str__' (7 chars) = '__' (2) + 'str' (3) + '__' (2) = 7; 'str' (3 chars) < 'repr' (4) < 'hash' (4) < 'bool' (4) — only 'str' has a 3-character core name; the 3-character core of '__str__' is what makes its qualname 15 rather than 16")"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__hash__ and __bool__ qualnames
# Both = 'Decimal.__hash__' / 'Decimal.__bool__' (len=16)
# Three-way tie at 16: __repr__, __hash__, __bool__
# ---------------------------------------------------------------------------

table decimal_extra161.Decimal_hash_bool_qualnames:
  description: "decimal.Decimal.__hash__ and __bool__ qualnames: __hash__='Decimal.__hash__' (len=16), __bool__='Decimal.__bool__' (len=16); both join __repr__ in a three-way tie at 16; all four dunders are directly defined in Decimal.__dict__"
  kind: python_call_eq
  category: qualname
  id_prefix: dqn161

  columns: [id, function, args, expected, description]
  rows:
    - [dec_hash_qeq,  decimal.Decimal.__hash__.__qualname__.__eq__,  ["Decimal.__hash__"],  true, "decimal.Decimal.__hash__.__qualname__ == 'Decimal.__hash__' (Decimal.__hash__() is directly defined on Decimal to ensure that equal Decimal values always hash equal; Decimal implements its own __hash__ because Decimal('1.0') == Decimal('1.00') even though their internal representations differ in precision — the hash must be consistent with equality; '__hash__' has 8 characters: '__' (2) + 'hash' (4) + '__' (2) = 8; 'Decimal.__hash__' has 16 characters: 'Decimal.' (8) + '__hash__' (8) = 16; __hash__ (16) is part of the three-way tie at 16 with __repr__ and __bool__; a custom __hash__ on Decimal also ensures compatibility with Python's requirement that hashable objects obey hash(a) == hash(b) whenever a == b)"]
    - [dec_bool_qeq,  decimal.Decimal.__bool__.__qualname__.__eq__,  ["Decimal.__bool__"],  true, "decimal.Decimal.__bool__.__qualname__ == 'Decimal.__bool__' (Decimal.__bool__() is directly defined on Decimal; bool(Decimal('0')) is False and bool(Decimal('1')) is True; Decimal('0.00') is also False since any zero value — regardless of precision — is falsy; Decimal('NaN') is True (NaN is truthy); '__bool__' has 8 characters: '__' (2) + 'bool' (4) + '__' (2) = 8; 'Decimal.__bool__' has 16 characters: 'Decimal.' (8) + '__bool__' (8) = 16; __bool__ (16) joins the three-way tie at 16 with __repr__ and __hash__; a custom __bool__ is needed because Decimal('0.00') must be falsy even though its string form is non-empty)"]
    - [dec_hash_len,  decimal.Decimal.__hash__.__qualname__.__len__,  [],                   16,   "decimal.Decimal.__hash__.__qualname__.__len__() == 16 — 'Decimal.__hash__' has 16 characters: 'Decimal.' (8) + '__hash__' (8) = 16; the prefix 'Decimal.' (8 chars) equals '__hash__' (8 chars) in length — symmetric structure shared by __repr__ and __bool__ as well; all three of __repr__, __hash__, and __bool__ have 8-character dunder names and therefore all produce 16-character qualnames under the 8-character 'Decimal.' prefix; the three-way tie at 16 (__repr__, __hash__, __bool__) contrasts with __str__ (15) which uses the 7-character '__str__' instead")"]
    - [dec_bool_len,  decimal.Decimal.__bool__.__qualname__.__len__,  [],                   16,   "decimal.Decimal.__bool__.__qualname__.__len__() == 16 — 'Decimal.__bool__' has 16 characters: 'Decimal.' (8) + '__bool__' (8) = 16; __bool__ (16) confirms the three-way tie at 16 with __repr__ (16) and __hash__ (16); complete qualname length ranking in this spec: __str__=15 (sole), __repr__=__hash__=__bool__=16 (three-way tie); the minimum qualname length is __str__ (15) and the maximum is 16 (three members); the gap between minimum and maximum is just 1 character — the smallest possible non-trivial gap; all four dunders are confirmed in decimal.Decimal.__dict__ on Python 3.14.3 macOS")"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra161.Decimal_repr_hash_bool_three_way_tie_at_16:
  description: "decimal.Decimal.__repr__.__qualname__.__len__() == 16 — 'Decimal.__repr__' (16 chars) participates in a three-way tie at 16 with 'Decimal.__hash__' (16) and 'Decimal.__bool__' (16); all three have 8-character dunder names ('__repr__', '__hash__', '__bool__') and the same 8-character prefix 'Decimal.', yielding 8+8=16; __str__ (15) is the sole exception with a 7-character dunder ('__str__'); the three-way tie at 16 is the maximum qualname length in this spec; all four dunders are directly defined in decimal.Decimal.__dict__ — none are inherited from object; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: decimal.Decimal.__repr__.__qualname__.__len__
  args: []
  expected: 16

invariant decimal_extra161.Decimal_str_is_sole_at_15:
  description: "decimal.Decimal.__str__.__qualname__.__len__() == 15 — 'Decimal.__str__' (15 chars) is the sole occupant of length 15 in this spec; __str__ (15) is the minimum qualname length and the only one shorter than the three-way tie at 16; '__str__' (7 chars) = '__' (2) + 'str' (3) + '__' (2) = 7; 'str' is the only 3-character core name among the four dunders: repr/hash/bool are all 4 characters; the 1-character difference in core name length ('str'=3 vs 'repr'/'hash'/'bool'=4) produces the 1-character qualname difference (15 vs 16); Decimal.__str__() returns the plain decimal numeral string, while Decimal.__repr__() returns Decimal('...') form; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: decimal.Decimal.__str__.__qualname__.__len__
  args: []
  expected: 15

invariant decimal_extra161.Decimal_hash_qualname_eq:
  description: "decimal.Decimal.__hash__.__qualname__ == 'Decimal.__hash__' — Decimal defines its own __hash__ to ensure hash consistency with equality; Decimal('1.0') == Decimal('1.00') so their hashes must be equal — the custom __hash__ normalizes before hashing; 'Decimal.__hash__' has 16 characters: 'Decimal.' (8) + '__hash__' (8) = 16; the symmetric structure where both halves of the qualname (prefix and dunder) are exactly 8 characters is shared by __repr__ and __bool__ as well; the three-way tie at 16 (__repr__, __hash__, __bool__) is the maximum qualname length in this spec; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: decimal.Decimal.__hash__.__qualname__.__eq__
  args: ["Decimal.__hash__"]
  expected: true

invariant decimal_extra161.Decimal_bool_qualname_eq:
  description: "decimal.Decimal.__bool__.__qualname__ == 'Decimal.__bool__' — Decimal defines __bool__ so that Decimal('0'), Decimal('0.00'), and Decimal('-0') are all falsy while any non-zero finite Decimal and Decimal('NaN') are truthy; 'Decimal.__bool__' has 16 characters: 'Decimal.' (8) + '__bool__' (8) = 16; __bool__ participates in the three-way tie at 16 with __repr__ and __hash__; all four dunders (__repr__, __str__, __hash__, __bool__) are directly in decimal.Decimal.__dict__ — none inherited from object; complete qualname length ranking: __str__=15, __repr__=__hash__=__bool__=16; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: decimal.Decimal.__bool__.__qualname__.__eq__
  args: ["Decimal.__bool__"]
  expected: true
