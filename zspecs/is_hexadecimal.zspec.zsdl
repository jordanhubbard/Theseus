spec: is_hexadecimal
version: ">=2.0.1"
backend: node(is-hexadecimal)

docs: https://www.npmjs.com/package/is-hexadecimal

provenance:
  derived_from:
    - "is-hexadecimal README — https://www.npmjs.com/package/is-hexadecimal"
    - "Test vectors verified with is-hexadecimal via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-hexadecimal source"
  notes:
    - "is-hexadecimal is an npm package. Install: npm install is-hexadecimal"
    - "Checks a single character: returns true if it is a valid hexadecimal digit (0-9, a-f, A-F)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_hexadecimal.isHexadecimal:
  kind: node_module_call_eq
  function: isHexadecimal
  category: predicate
  id_prefix: ishex

  columns: [id, args, expected]
  rows:
    - [hex_f,   ["f"],  true]
    - [hex_a,   ["a"],  true]
    - [hex_0,   ["0"],  true]
    - [non_hex, ["g"],  false]
    - [non_hex2,["z"],  false]
