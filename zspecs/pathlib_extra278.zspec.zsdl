spec: pathlib_extra278
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "pathlib.__package__ == 'pathlib' — pathlib is a package (has a directory with __init__.py)."
    - "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader' — loaded from Lib/pathlib/__init__.py."
    - "pathlib._local is an internal submodule; pathlib._local.__package__ == 'pathlib'."
    - "pathlib.Path.__module__ == 'pathlib' and pathlib.PurePath.__module__ == 'pathlib'."
    - "pathlib.__all__ is a list containing 'Path' and 'PurePath' among other entries."
    - "pathlib.__all__.__class__.__name__ == 'list'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: pathlib module __spec__ and loader identity
# ---------------------------------------------------------------------------

table pathlib_extra278.pathlib_module_spec_identity:
  description: "pathlib module __name__, __package__, __spec__.name, __spec__.__class__.__name__, and __loader__.__class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: msi

  columns: [id, function, args, expected, description]
  rows:
    - [pathlib_name,    __name__.__eq__,                    ["pathlib"],        true, "pathlib.__name__ == 'pathlib'"]
    - [pathlib_pkg,     __package__.__eq__,                 ["pathlib"],        true, "pathlib.__package__ == 'pathlib' — pathlib is a package"]
    - [spec_name,       __spec__.name.__eq__,               ["pathlib"],        true, "pathlib.__spec__.name == 'pathlib'"]
    - [spec_class,      __spec__.__class__.__name__.__eq__, ["ModuleSpec"],     true, "pathlib.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [loader_class,    __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader'"]
    - [all_class,       __all__.__class__.__name__.__eq__,  ["list"],           true, "pathlib.__all__.__class__.__name__ == 'list'"]

# ---------------------------------------------------------------------------
# Table: pathlib._local submodule and class module identity
# ---------------------------------------------------------------------------

table pathlib_extra278.pathlib_submodule_and_class_identity:
  description: "pathlib._local submodule __name__ and __package__; pathlib.Path and pathlib.PurePath __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: sci

  columns: [id, function, args, expected, description]
  rows:
    - [local_name,      _local.__name__.__eq__,              ["pathlib._local"], true, "pathlib._local.__name__ == 'pathlib._local'"]
    - [local_package,   _local.__package__.__eq__,           ["pathlib"],        true, "pathlib._local.__package__ == 'pathlib'"]
    - [path_module,     Path.__module__.__eq__,              ["pathlib"],        true, "pathlib.Path.__module__ == 'pathlib'"]
    - [purepath_module, PurePath.__module__.__eq__,          ["pathlib"],        true, "pathlib.PurePath.__module__ == 'pathlib'"]

# ---------------------------------------------------------------------------
# Standalone invariants: pathlib module spec and __all__ membership
# ---------------------------------------------------------------------------

invariant pathlib_extra278.pathlib.__spec__.name:
  description: "pathlib.__spec__.name == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra278.pathlib.__package__:
  description: "pathlib.__package__ == 'pathlib' — pathlib is a package"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra278.pathlib.__loader__.class_name:
  description: "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant pathlib_extra278.pathlib.__all__.is_list:
  description: "pathlib.__all__.__class__.__name__ == 'list'"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant pathlib_extra278.pathlib.Path.__module__:
  description: "pathlib.Path.__module__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra278.pathlib.PurePath.__module__:
  description: "pathlib.PurePath.__module__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra278.pathlib._local.__name__:
  description: "pathlib._local.__name__ == 'pathlib._local'"
  category: identity
  kind: python_call_eq
  function: _local.__name__.__eq__
  args: ["pathlib._local"]
  expected: true

invariant pathlib_extra278.pathlib._local.__package__:
  description: "pathlib._local.__package__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: _local.__package__.__eq__
  args: ["pathlib"]
  expected: true
