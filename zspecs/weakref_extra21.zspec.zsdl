spec: weakref_extra21
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
    - "weakref_extra20.zspec.zsdl — covers ref/WeakValueDictionary/WeakKeyDictionary/WeakSet/finalize __qualname__ standalones; WeakValueDictionary.get/__qualname__; WeakSet.add/__qualname__; finalize.__call__/__qualname__; combined table."
    - "weakref_extra19.zspec.zsdl — covers ReferenceType/CallableProxyType/ProxyType/WeakMethod __qualname__ and WeakValueDictionary/WeakKeyDictionary __module__."
    - "weakref_extra18.zspec.zsdl — covers ref.__qualname__ as standalone."
    - "weakref_extra15.zspec.zsdl — covers ref/__qualname__/WeakValueDictionary/__qualname__/WeakKeyDictionary/__qualname__ in combined table."
  notes:
    - "This spec extends weakref_extra20.zspec.zsdl."
    - "Focus: additional method-level __qualname__ values not yet recorded in any prior weakref spec — ref.__call__, WeakValueDictionary.setdefault/update/pop, WeakKeyDictionary.get/keys, WeakSet.discard/remove."
    - "weakref.ref.__call__.__qualname__ == 'ReferenceType.__call__' — ref's C-level type is ReferenceType; __call__ qualname reflects the C-level type name."
    - "weakref.WeakValueDictionary.setdefault.__qualname__ == 'WeakValueDictionary.setdefault' — method qualname includes class name."
    - "weakref.WeakValueDictionary.update.__qualname__ == 'WeakValueDictionary.update' — method qualname includes class name."
    - "weakref.WeakValueDictionary.pop.__qualname__ == 'WeakValueDictionary.pop' — method qualname includes class name."
    - "weakref.WeakKeyDictionary.get.__qualname__ == 'WeakKeyDictionary.get' — method qualname includes class name."
    - "weakref.WeakKeyDictionary.keys.__qualname__ == 'WeakKeyDictionary.keys' — method qualname includes class name."
    - "weakref.WeakSet.discard.__qualname__ == 'WeakSet.discard' — method qualname includes class name."
    - "weakref.WeakSet.remove.__qualname__ == 'WeakSet.remove' — method qualname includes class name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Method-level __qualname__ values — combined table in extra21 namespace
#
# weakref_extra20 covers WeakValueDictionary.get, WeakSet.add, finalize.__call__
# as novel method-level qualnames. This extra21 table adds ref.__call__,
# WeakValueDictionary.setdefault/update/pop, WeakKeyDictionary.get/keys, and
# WeakSet.discard/remove — none of which appear in any prior weakref spec.
# ---------------------------------------------------------------------------

table weakref_extra21.method_qualnames:
  description: "method-level __qualname__ values for weakref types in the extra21 namespace"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ref_call,                     "ref.__call__.__qualname__.__eq__",                     ["ReferenceType.__call__"],            true]
    - [WeakValueDictionary_setdefault, "WeakValueDictionary.setdefault.__qualname__.__eq__", ["WeakValueDictionary.setdefault"],    true]
    - [WeakValueDictionary_update,   "WeakValueDictionary.update.__qualname__.__eq__",       ["WeakValueDictionary.update"],        true]
    - [WeakValueDictionary_pop,      "WeakValueDictionary.pop.__qualname__.__eq__",          ["WeakValueDictionary.pop"],           true]
    - [WeakKeyDictionary_get,        "WeakKeyDictionary.get.__qualname__.__eq__",            ["WeakKeyDictionary.get"],             true]
    - [WeakKeyDictionary_keys,       "WeakKeyDictionary.keys.__qualname__.__eq__",           ["WeakKeyDictionary.keys"],            true]
    - [WeakSet_discard,              "WeakSet.discard.__qualname__.__eq__",                  ["WeakSet.discard"],                   true]
    - [WeakSet_remove,               "WeakSet.remove.__qualname__.__eq__",                   ["WeakSet.remove"],                    true]

# ---------------------------------------------------------------------------
# weakref.ref.__call__.__qualname__ — standalone invariant
#
# The C-level type underlying weakref.ref is named ReferenceType. Its __call__
# method's qualname is therefore 'ReferenceType.__call__'. No prior weakref spec
# records this value.
# ---------------------------------------------------------------------------

invariant weakref_extra21.ref.call.qualname:
  description: "weakref.ref.__call__.__qualname__ == 'ReferenceType.__call__' — C-level type underlying ref is ReferenceType"
  category: method_qualnames
  kind: python_call_eq
  function: "ref.__call__.__qualname__.__eq__"
  args: ["ReferenceType.__call__"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.WeakValueDictionary.setdefault.__qualname__ — standalone invariant
#
# No prior weakref spec records WeakValueDictionary.setdefault.__qualname__.
# ---------------------------------------------------------------------------

invariant weakref_extra21.WeakValueDictionary.setdefault.qualname:
  description: "weakref.WeakValueDictionary.setdefault.__qualname__ == 'WeakValueDictionary.setdefault'"
  category: method_qualnames
  kind: python_call_eq
  function: "WeakValueDictionary.setdefault.__qualname__.__eq__"
  args: ["WeakValueDictionary.setdefault"]
  expected: true

