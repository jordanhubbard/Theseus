spec: glob_extra13
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/glob.py"
    - "glob_extra12.zspec.zsdl — covers glob.__spec__.name, __spec__.submodule_search_locations, __loader__.__class__.__name__."
    - "glob_extra11.zspec.zsdl — covers __module__ table for glob/iglob/escape; __qualname__ and __name__ standalone invariants for all three functions."
  notes:
    - "This spec extends glob_extra12.zspec.zsdl."
    - "Focus: __qualname__ string lengths for glob public functions (glob, iglob, escape)."
    - "No prior glob spec covers __qualname__.__len__() for any of these functions."
    - "glob.glob.__qualname__.__len__() == 4 — 'glob' has 4 characters."
    - "glob.iglob.__qualname__.__len__() == 5 — 'iglob' has 5 characters."
    - "glob.escape.__qualname__.__len__() == 6 — 'escape' has 6 characters."
    - "glob.glob.__module__.__len__() == 4 — 'glob' has 4 characters."
    - "glob.iglob.__module__.__len__() == 4 — 'glob' has 4 characters."
    - "glob.escape.__module__.__len__() == 4 — 'glob' has 4 characters."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ string lengths for glob public functions
#
# glob_extra11 covers __qualname__ equality for glob/iglob/escape. No prior
# glob spec covers __qualname__.__len__() for any function. The length of each
# qualname is the same as the function name length since qualname == name for
# top-level module functions.
# Verified: glob=4, iglob=5, escape=6.
# ---------------------------------------------------------------------------

table glob_extra13.function_qualname_lengths:
  description: "__qualname__.__len__() for glob public functions glob/iglob/escape"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqlen13

  columns: [id, function, args, expected]
  rows:
    - [glob,   glob.__qualname__.__len__,   [], 4]
    - [iglob,  iglob.__qualname__.__len__,  [], 5]
    - [escape, escape.__qualname__.__len__, [], 6]

# ---------------------------------------------------------------------------
# Table: __module__ string lengths for glob public functions
#
# All three glob public functions have __module__ == 'glob' (4 characters).
# No prior glob spec covers __module__.__len__() for any function.
# Verified: glob=4, iglob=4, escape=4.
# ---------------------------------------------------------------------------

table glob_extra13.function_module_lengths:
  description: "__module__.__len__() for glob public functions — all equal 4 (length of 'glob')"
  kind: python_call_eq
  category: function_identity
  id_prefix: fmlen13

  columns: [id, function, args, expected]
  rows:
    - [glob,   glob.__module__.__len__,   [], 4]
    - [iglob,  iglob.__module__.__len__,  [], 4]
    - [escape, escape.__module__.__len__, [], 4]

# ---------------------------------------------------------------------------
# Standalone: glob.__qualname__.__len__() == 4
#
# 'glob' is the shortest qualname in the table (4 chars). Standalone invariant
# anchors it independently for direct lookup in the extra13 namespace.
# ---------------------------------------------------------------------------

invariant glob_extra13.glob.qualname_length:
  description: "glob.glob.__qualname__.__len__() == 4 — 'glob' has 4 characters"
  category: function_identity
  kind: python_call_eq
  function: glob.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: glob.escape.__qualname__.__len__() == 6
#
# 'escape' is the longest qualname in the table (6 chars). Standalone invariant
# anchors it independently for direct lookup in the extra13 namespace.
# ---------------------------------------------------------------------------

invariant glob_extra13.escape.qualname_length:
  description: "glob.escape.__qualname__.__len__() == 6 — 'escape' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: escape.__qualname__.__len__
  args: []
  expected: 6
