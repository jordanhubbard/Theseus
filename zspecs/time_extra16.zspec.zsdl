spec: time_extra16
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time_extra4.zspec.zsdl — covers __qualname__ table for time/sleep/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime/strptime/struct_time"
    - "time_extra7.zspec.zsdl — covers monotonic_ns/__name__ in a table row and as a standalone invariant; monotonic_ns/__qualname__ as standalone invariant"
    - "time_extra10.zspec.zsdl — covers __qualname__ standalone invariants for sleep/monotonic/perf_counter; __module__ table"
    - "time_extra11.zspec.zsdl — covers __qualname__ for time_ns/monotonic_ns/perf_counter_ns in table"
    - "time_extra12.zspec.zsdl — covers __qualname__ standalone invariants for time/sleep/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime/strptime"
    - "time_extra13.zspec.zsdl — covers __qualname__ standalone invariants for clock_gettime_ns/monotonic_ns/perf_counter_ns/process_time_ns/time_ns"
    - "time_extra15.zspec.zsdl — covers __module__ standalone invariants for sleep/time/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime"
  notes:
    - "This spec extends time.zspec.zsdl and prior extras through time_extra15.zspec.zsdl."
    - "NEW in extra16 — Axis 1: __qualname__ for the core timing and conversion functions as extra16-namespace standalone invariants: time, sleep, monotonic, perf_counter, process_time."
    - "NEW in extra16 — Axis 2: __qualname__ for the time-conversion functions as extra16-namespace standalone invariants: localtime, gmtime, mktime, strftime, strptime, ctime."
    - "NEW in extra16 — Axis 3: time.monotonic_ns.__name__ as an extra16-namespace standalone invariant (prior coverage was in a table row in time_extra7 and a standalone invariant in that spec's own namespace)."
    - "time.time.__qualname__ == 'time' — verified Python 3.12."
    - "time.sleep.__qualname__ == 'sleep' — verified Python 3.12."
    - "time.monotonic.__qualname__ == 'monotonic' — verified Python 3.12."
    - "time.perf_counter.__qualname__ == 'perf_counter' — verified Python 3.12."
    - "time.process_time.__qualname__ == 'process_time' — verified Python 3.12."
    - "time.localtime.__qualname__ == 'localtime' — verified Python 3.12."
    - "time.gmtime.__qualname__ == 'gmtime' — verified Python 3.12."
    - "time.mktime.__qualname__ == 'mktime' — verified Python 3.12."
    - "time.strftime.__qualname__ == 'strftime' — verified Python 3.12."
    - "time.strptime.__qualname__ == 'strptime' — verified Python 3.12."
    - "time.ctime.__qualname__ == 'ctime' — verified Python 3.12."
    - "time.monotonic_ns.__name__ == 'monotonic_ns' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for core timing functions — standalone extra16-namespace invariants
#
# time, sleep, monotonic, perf_counter, and process_time are all C-level
# builtin functions registered directly in the 'time' module. Their __qualname__
# values are flat (not dotted), matching their simple function names. Prior
# __qualname__ coverage for these functions exists in time_extra4 (table rows),
# time_extra10, and time_extra12 (different namespace invariants). These
# invariants establish the same facts in the extra16 namespace.
# ---------------------------------------------------------------------------

table time_extra16.timing_function_qualnames:
  description: "__qualname__ for core timing functions: time, sleep, monotonic, perf_counter, process_time"
  kind: python_call_eq
  category: function_identity
  id_prefix: tfq16

  columns: [id, function, args, expected]
  rows:
    - [time,         time.__qualname__.__eq__,         ["time"],         true]
    - [sleep,        sleep.__qualname__.__eq__,        ["sleep"],        true]
    - [monotonic,    monotonic.__qualname__.__eq__,    ["monotonic"],    true]
    - [perf_counter, perf_counter.__qualname__.__eq__, ["perf_counter"], true]
    - [process_time, process_time.__qualname__.__eq__, ["process_time"], true]

# ---------------------------------------------------------------------------
# __qualname__ for time conversion functions — standalone extra16-namespace invariants
#
# localtime, gmtime, mktime, strftime, strptime, and ctime are C-level
# builtins that convert between time representations. Their __qualname__ values
# are all flat (equal to __name__). Prior __qualname__ coverage for most of
# these exists in time_extra4 (table) and time_extra12 (standalone); these
# invariants establish the same facts under the extra16 namespace.
# ctime is included here as it was not covered as a standalone qualname
# invariant in extra12.
# ---------------------------------------------------------------------------

table time_extra16.conversion_function_qualnames:
  description: "__qualname__ for time conversion functions: localtime, gmtime, mktime, strftime, strptime, ctime"
  kind: python_call_eq
  category: function_identity
  id_prefix: cfq16

  columns: [id, function, args, expected]
  rows:
    - [localtime, localtime.__qualname__.__eq__, ["localtime"], true]
    - [gmtime,    gmtime.__qualname__.__eq__,    ["gmtime"],    true]
    - [mktime,    mktime.__qualname__.__eq__,    ["mktime"],    true]
    - [strftime,  strftime.__qualname__.__eq__,  ["strftime"],  true]
    - [strptime,  strptime.__qualname__.__eq__,  ["strptime"],  true]
    - [ctime,     ctime.__qualname__.__eq__,     ["ctime"],     true]

# ---------------------------------------------------------------------------
# time.monotonic_ns.__name__ — standalone extra16-namespace invariant
#
# time.monotonic_ns is the nanosecond-resolution variant of time.monotonic,
# returning an integer count of nanoseconds. Its __name__ is the flat string
# 'monotonic_ns'. Prior coverage of this attribute exists in time_extra7 as
# both a table row and a standalone invariant. This invariant establishes the
# same fact under the extra16 namespace for completeness with the __qualname__
# table above and alignment with the monotonic_ns __qualname__ coverage in
# time_extra13.
# ---------------------------------------------------------------------------

invariant time_extra16.monotonic_ns.name:
  description: "time.monotonic_ns.__name__ == 'monotonic_ns' — flat __name__ for the nanosecond monotonic clock builtin"
  category: function_identity
  kind: python_call_eq
  function: monotonic_ns.__name__.__eq__
  args: ["monotonic_ns"]
  expected: true
