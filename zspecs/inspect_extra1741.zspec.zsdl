spec: inspect_extra1741
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol dict-presence checks."
    - "inspect.Parameter: data container class, not a descriptor — __get__ False, __set__ False, __delete__ False, __set_name__ False."
    - "inspect.Signature: introspection class, not a descriptor — all False."
    - "inspect.BoundArguments: data container, not a descriptor — all False."
    - "None of the inspect types implement the descriptor protocol in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: descriptor protocol dict-presence checks for inspect types
#
# Wave 563 theme: which inspect types define __get__, __set__, __delete__,
# __set_name__ in their own __dict__.
#
# inspect.Parameter: data container class (name, kind, default, annotation);
#   not a descriptor — all four descriptor dunders absent from __dict__.
# inspect.Signature: represents a function's calling signature;
#   not a descriptor — all four descriptor dunders absent.
# inspect.BoundArguments: result of Signature.bind(); data container;
#   not a descriptor — all four descriptor dunders absent.
# ---------------------------------------------------------------------------

table inspect_extra1741.descriptor_protocol:
  description: "inspect types descriptor protocol dict-presence checks — all False — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1741

  columns: [id, function, args, expected]
  rows:
    - ["in1741001", "inspect.Parameter.__dict__.__contains__", ["__get__"], false]
    - ["in1741002", "inspect.Parameter.__dict__.__contains__", ["__set__"], false]
    - ["in1741003", "inspect.Parameter.__dict__.__contains__", ["__delete__"], false]
    - ["in1741004", "inspect.Parameter.__dict__.__contains__", ["__set_name__"], false]
    - ["in1741005", "inspect.Signature.__dict__.__contains__", ["__get__"], false]
    - ["in1741006", "inspect.Signature.__dict__.__contains__", ["__set__"], false]
    - ["in1741007", "inspect.Signature.__dict__.__contains__", ["__delete__"], false]
    - ["in1741008", "inspect.Signature.__dict__.__contains__", ["__set_name__"], false]
    - ["in1741009", "inspect.BoundArguments.__dict__.__contains__", ["__get__"], false]
    - ["in1741010", "inspect.BoundArguments.__dict__.__contains__", ["__set__"], false]
    - ["in1741011", "inspect.BoundArguments.__dict__.__contains__", ["__delete__"], false]
    - ["in1741012", "inspect.BoundArguments.__dict__.__contains__", ["__set_name__"], false]

# ---------------------------------------------------------------------------
# Table 2: non-descriptor contrast — inspect types DO define other dunders
#
# Contrast: inspect.Parameter.__dict__ contains __init__, __repr__, __eq__,
# __hash__ (regular class methods), confirming the __dict__ is accessible
# and populated — the absence of descriptor dunders is meaningful, not
# merely an inaccessible __dict__.
# inspect.Signature and BoundArguments also define __init__, __repr__, etc.
# ---------------------------------------------------------------------------

table inspect_extra1741.non_descriptor_contrast:
  description: "inspect types __dict__ has __init__/__repr__ but NOT descriptor dunders — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1741

  columns: [id, function, args, expected]
  rows:
    - ["in1741013", "inspect.Parameter.__dict__.__contains__", ["__init__"], true]
    - ["in1741014", "inspect.Parameter.__dict__.__contains__", ["__repr__"], true]
    - ["in1741015", "inspect.Parameter.__dict__.__contains__", ["__eq__"], true]
    - ["in1741016", "inspect.Parameter.__dict__.__contains__", ["__hash__"], true]
    - ["in1741017", "inspect.Signature.__dict__.__contains__", ["__init__"], true]
    - ["in1741018", "inspect.Signature.__dict__.__contains__", ["__repr__"], true]
    - ["in1741019", "inspect.Signature.__dict__.__contains__", ["__eq__"], true]
    - ["in1741020", "inspect.BoundArguments.__dict__.__contains__", ["__init__"], true]
    - ["in1741021", "inspect.BoundArguments.__dict__.__contains__", ["__repr__"], true]
    - ["in1741022", "inspect.Parameter.__dict__.__contains__", ["__get__"], false]
    - ["in1741023", "inspect.Signature.__dict__.__contains__", ["__get__"], false]
    - ["in1741024", "inspect.BoundArguments.__dict__.__contains__", ["__get__"], false]
    - ["in1741025", "inspect.Parameter.__dict__.__contains__", ["__set_name__"], false]
