spec: espree
version: ">=10.0.0"
backend: node(espree)

docs: https://github.com/eslint/espree#readme

provenance:
  derived_from:
    - "Espree README — https://github.com/eslint/espree#readme"
    - "ESTree specification — https://github.com/estree/estree"
    - "Test vectors verified with espree via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "espree source"
  notes:
    - "Espree is the ECMAScript parser used by ESLint (a fork of Acorn)."
    - "Install: npm install espree"
    - "parse(code, options) returns ESTree AST. Specs pin ecmaVersion to ensure stability."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure parser; throws SyntaxError on malformed input."
  stderr: "null"
  stickiness: "N/A — each parse independent."
  codes: {}

invariant espree.parse_program_type:
  description: "parse() returns Program node"
  category: program
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["1 + 2", {ecmaVersion: 2022}]
  chain:
    - {get: type}
  expected: "Program"

invariant espree.binary_expression_type:
  description: "Inner expression for '1+2' is BinaryExpression"
  category: expressions
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["1 + 2", {ecmaVersion: 2022}]
  chain:
    - {get: body}
    - {method: at, args: [0]}
    - {get: expression}
    - {get: type}
  expected: "BinaryExpression"

invariant espree.assignment_operator:
  description: "Assignment '=' preserved"
  category: expressions
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["x = 1", {ecmaVersion: 2022}]
  chain:
    - {get: body}
    - {method: at, args: [0]}
    - {get: expression}
    - {get: operator}
  expected: "="

# Latest supported version
invariant espree.latest_ecma_version_is_seventeen:
  description: "latestEcmaVersion property is 17 (ECMAScript 2026 = version 17)"
  category: registry
  kind: node_property_eq
  entry: bare
  property: latestEcmaVersion
  expected: 17

# Token mode
invariant espree.tokenize_returns_array:
  description: "tokenize('1 + 2') returns array of tokens"
  category: tokenize
  kind: node_chain_eq
  entry: named
  function: tokenize
  entry_args: ["1 + 2", {ecmaVersion: 2022}]
  chain:
    - {get: length}
  expected: 3

invariant espree.tokenize_first_token_type:
  description: "First token of '1 + 2' is Numeric"
  category: tokenize
  kind: node_chain_eq
  entry: named
  function: tokenize
  entry_args: ["1 + 2", {ecmaVersion: 2022}]
  chain:
    - {method: at, args: [0]}
    - {get: type}
  expected: "Numeric"

invariant espree.tokenize_first_token_value:
  description: "First token value preserved as string"
  category: tokenize
  kind: node_chain_eq
  entry: named
  function: tokenize
  entry_args: ["1 + 2", {ecmaVersion: 2022}]
  chain:
    - {method: at, args: [0]}
    - {get: value}
  expected: "1"
