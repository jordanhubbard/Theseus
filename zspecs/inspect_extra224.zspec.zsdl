spec: inspect_extra224
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect function __code__.co_argcount and co_name attribute contracts."
    - "inspect.isfunction.__code__.co_argcount == 1 (object). Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_argcount == 1 (object). Verified with Python 3.14.3."
    - "inspect.ismodule.__code__.co_argcount == 1 (object). Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_argcount == 1 (object). Verified with Python 3.14.3."
    - "inspect.isroutine.__code__.co_argcount == 1 (object). Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_argcount == 2 (object, predicate). Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_argcount == 1 (object). Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_argcount == 1 (object). Verified with Python 3.14.3."
    - "inspect.getdoc.__code__.co_argcount == 1 (object). Verified with Python 3.14.3."
    - "inspect.isfunction.__code__.co_name == 'isfunction'. Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_name == 'isclass'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect predicate function __code__.co_argcount checks
#
# Verified with Python 3.14.3:
#   inspect.isfunction.__code__.co_argcount == 1  (object)
#   inspect.isclass.__code__.co_argcount == 1     (object)
#   inspect.ismodule.__code__.co_argcount == 1    (object)
#   inspect.isbuiltin.__code__.co_argcount == 1   (object)
#   inspect.isroutine.__code__.co_argcount == 1   (object)
# ---------------------------------------------------------------------------

table inspect_extra224.is_predicate_co_argcount:
  description: "inspect is* predicate function __code__.co_argcount == 1 checks; new to extra224"
  kind: python_call_eq
  category: code_inspection
  id_prefix: inspectextra224ispredcoa

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_co_argcount_eq,
       isfunction.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — isfunction(object) takes only the object param; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]
    - [isclass_co_argcount_eq,
       isclass.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isclass.__code__.co_argcount.__eq__(1) == True — isclass(object) takes only the object param; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]
    - [ismodule_co_argcount_eq,
       ismodule.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.ismodule.__code__.co_argcount.__eq__(1) == True — ismodule(object) takes only the object param; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]
    - [isbuiltin_co_argcount_eq,
       isbuiltin.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isbuiltin.__code__.co_argcount.__eq__(1) == True — isbuiltin(object) takes only the object param; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]
    - [isroutine_co_argcount_eq,
       isroutine.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.isroutine.__code__.co_argcount.__eq__(1) == True — isroutine(object) takes only the object param; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]

# ---------------------------------------------------------------------------
# Table 2: inspect utility function __code__.co_argcount checks
#
# Verified with Python 3.14.3:
#   inspect.getmembers.__code__.co_argcount == 2  (object, predicate)
#   inspect.getsource.__code__.co_argcount == 1   (object)
#   inspect.getfile.__code__.co_argcount == 1     (object)
#   inspect.getdoc.__code__.co_argcount == 1      (object)
# ---------------------------------------------------------------------------

table inspect_extra224.util_func_co_argcount:
  description: "inspect utility function __code__.co_argcount checks; new to extra224"
  kind: python_call_eq
  category: code_inspection
  id_prefix: inspectextra224utilcoa

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_co_argcount_eq,
       getmembers.__code__.co_argcount.__eq__,
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers(object, predicate=None) takes object and predicate; co_argcount is 2; int.__eq__(2) returns True; new to extra224"]
    - [getsource_co_argcount_eq,
       getsource.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getsource.__code__.co_argcount.__eq__(1) == True — getsource(object) takes only the object param; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]
    - [getfile_co_argcount_eq,
       getfile.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getfile.__code__.co_argcount.__eq__(1) == True — getfile(object) takes only the object param; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]
    - [getdoc_co_argcount_eq,
       getdoc.__code__.co_argcount.__eq__,
       [1],
       true,
       "inspect.getdoc.__code__.co_argcount.__eq__(1) == True — getdoc(object) takes only the object param; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]
    - [isfunction_co_name_eq,
       isfunction.__code__.co_name.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__code__.co_name.__eq__('isfunction') == True — co_name is the code object's function name; str.__eq__('isfunction') returns True; new to extra224"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra224
# ---------------------------------------------------------------------------

invariant inspect_extra224.isfunction_co_argcount:
  description: "inspect.isfunction.__code__.co_argcount == 1 — isfunction takes only object; new to extra224"
  kind: python_call_eq
  function: isfunction.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra224.isclass_co_argcount:
  description: "inspect.isclass.__code__.co_argcount == 1 — isclass takes only object; new to extra224"
  kind: python_call_eq
  function: isclass.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra224.ismodule_co_argcount:
  description: "inspect.ismodule.__code__.co_argcount == 1 — ismodule takes only object; new to extra224"
  kind: python_call_eq
  function: ismodule.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra224.isbuiltin_co_argcount:
  description: "inspect.isbuiltin.__code__.co_argcount == 1 — isbuiltin takes only object; new to extra224"
  kind: python_call_eq
  function: isbuiltin.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra224.isroutine_co_argcount:
  description: "inspect.isroutine.__code__.co_argcount == 1 — isroutine takes only object; new to extra224"
  kind: python_call_eq
  function: isroutine.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra224.getmembers_co_argcount:
  description: "inspect.getmembers.__code__.co_argcount == 2 — getmembers takes object and predicate; new to extra224"
  kind: python_call_eq
  function: getmembers.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra224.getsource_co_argcount:
  description: "inspect.getsource.__code__.co_argcount == 1 — getsource takes only object; new to extra224"
  kind: python_call_eq
  function: getsource.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra224.getfile_co_argcount:
  description: "inspect.getfile.__code__.co_argcount == 1 — getfile takes only object; new to extra224"
  kind: python_call_eq
  function: getfile.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra224.getdoc_co_argcount:
  description: "inspect.getdoc.__code__.co_argcount == 1 — getdoc takes only object; new to extra224"
  kind: python_call_eq
  function: getdoc.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra224.isfunction_co_name:
  description: "inspect.isfunction.__code__.co_name == 'isfunction' — co_name matches function name; new to extra224"
  kind: python_call_eq
  function: isfunction.__code__.co_name.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra224.isclass_co_name:
  description: "inspect.isclass.__code__.co_name == 'isclass' — co_name matches function name; new to extra224"
  kind: python_call_eq
  function: isclass.__code__.co_name.__eq__
  args: ["isclass"]
  expected: true
