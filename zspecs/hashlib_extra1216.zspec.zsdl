spec: hashlib_extra1216
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib.md5.__dict__.__contains__ for block_size/digest_size/name/digest/hexdigest/update/copy keys; hashlib.sha256.__dict__.__contains__ for the same set; and hashlib.md5/__mro__/__len__ and hashlib.sha256/__mro__/__len__ counts"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1216.md5_dict_contains:
  description: "hashlib.md5 type __dict__.__contains__ checks for key method and attribute names"
  kind: python_call_eq
  category: md5_dict_contains
  id_prefix: hl1216md
  columns: [id, function, args, expected]
  rows:
    - [hl1216md001, hashlib.md5.__dict__.__contains__,                   ["block_size"],   true]
    - [hl1216md002, hashlib.md5.__dict__.__contains__,                   ["digest_size"],  true]
    - [hl1216md003, hashlib.md5.__dict__.__contains__,                   ["name"],         true]
    - [hl1216md004, hashlib.md5.__dict__.__contains__,                   ["digest"],       true]
    - [hl1216md005, hashlib.md5.__dict__.__contains__,                   ["hexdigest"],    true]
    - [hl1216md006, hashlib.md5.__dict__.__contains__,                   ["update"],       true]
    - [hl1216md007, hashlib.md5.__dict__.__contains__,                   ["copy"],         true]
    - [hl1216md008, hashlib.md5.__dict__.__class__.__name__.__eq__,      ["mappingproxy"], true]
    - [hl1216md009, hashlib.md5.__dict__.__class__.__qualname__.__eq__,  ["mappingproxy"], true]

table hashlib_extra1216.sha256_dict_contains:
  description: "hashlib.sha256 type __dict__.__contains__ checks for key method and attribute names"
  kind: python_call_eq
  category: sha256_dict_contains
  id_prefix: hl1216sd
  columns: [id, function, args, expected]
  rows:
    - [hl1216sd001, hashlib.sha256.__dict__.__contains__,                ["block_size"],   true]
    - [hl1216sd002, hashlib.sha256.__dict__.__contains__,                ["digest_size"],  true]
    - [hl1216sd003, hashlib.sha256.__dict__.__contains__,                ["name"],         true]
    - [hl1216sd004, hashlib.sha256.__dict__.__contains__,                ["digest"],       true]
    - [hl1216sd005, hashlib.sha256.__dict__.__contains__,                ["hexdigest"],    true]
    - [hl1216sd006, hashlib.sha256.__dict__.__contains__,                ["update"],       true]
    - [hl1216sd007, hashlib.sha256.__dict__.__contains__,                ["copy"],         true]
    - [hl1216sd008, hashlib.sha256.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]
    - [hl1216sd009, hashlib.sha256.__dict__.__class__.__module__.__eq__,  ["builtins"],    true]

table hashlib_extra1216.mro_len:
  description: "hashlib.md5 and hashlib.sha256 type __mro__.__len__ counts"
  kind: python_call_eq
  category: mro_len
  id_prefix: hl1216ml
  columns: [id, function, args, expected]
  rows:
    - [hl1216ml001, hashlib.md5.__mro__.__len__,                         [],              2]
    - [hl1216ml002, hashlib.sha256.__mro__.__len__,                      [],              2]
    - [hl1216ml003, hashlib.md5.__mro__.__class__.__name__.__eq__,       ["tuple"],       true]
    - [hl1216ml004, hashlib.sha256.__mro__.__class__.__name__.__eq__,    ["tuple"],       true]
    - [hl1216ml005, hashlib.md5.__mro__.__class__.__module__.__eq__,     ["builtins"],    true]
    - [hl1216ml006, hashlib.sha256.__mro__.__class__.__module__.__eq__,  ["builtins"],    true]
