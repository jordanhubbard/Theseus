spec: decimal_extra1306
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for invalid Decimal construction, bad type arguments, and invalid operation."
    - "decimal.Decimal([]) raises ValueError: argument must be a sequence of length 3."
    - "decimal.Decimal('not_a_number_string') raises decimal.InvalidOperation."
    - "decimal.Decimal(b'1.5') raises TypeError: conversion from bytes to Decimal is not supported."
    - "decimal.setcontext(42) raises TypeError: argument must be a Context."
    - "decimal.Decimal.from_float(None) raises TypeError: argument must be int or float."
    - "decimal.Decimal with 4-element list raises ValueError: argument must be a sequence of length 3."
    - "decimal.Decimal with invalid sign in tuple raises ValueError: sign must be 0 or 1."
    - "decimal.Decimal with invalid digit in tuple raises ValueError: coefficient must be a tuple of digits."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table decimal_extra1306.decimal_string_errors:
  description: "decimal.Decimal raises InvalidOperation when given an invalid numeric string"
  kind: python_call_raises
  category: invalid_operation
  id_prefix: dc1306ds
  columns: [id, function, args, exception]
  rows:
    - [dc1306ds001, decimal.Decimal, ["not_a_number_string"],   "InvalidOperation"]
    - [dc1306ds002, decimal.Decimal, ["--1"],                   "InvalidOperation"]
    - [dc1306ds003, decimal.Decimal, ["1.2.3"],                 "InvalidOperation"]
    - [dc1306ds004, decimal.Decimal, ["1e"],                    "InvalidOperation"]
    - [dc1306ds005, decimal.Decimal, ["abc"],                   "InvalidOperation"]
    - [dc1306ds006, decimal.Decimal, ["1+2"],                   "InvalidOperation"]

table decimal_extra1306.decimal_type_errors:
  description: "decimal.Decimal and related functions raise TypeError or ValueError on wrong argument types"
  kind: python_call_raises
  category: type_errors
  id_prefix: dc1306dt
  columns: [id, function, args, exception]
  rows:
    - [dc1306dt001, decimal.Decimal,           [[]],            "ValueError"]
    - [dc1306dt002, decimal.Decimal,           [[0, 1, 2, 3]],  "ValueError"]
    - [dc1306dt003, decimal.setcontext,        [42],            "TypeError"]
    - [dc1306dt004, decimal.setcontext,        ["bad"],         "TypeError"]
    - [dc1306dt005, decimal.setcontext,        [null],          "TypeError"]
    - [dc1306dt006, decimal.Decimal.from_float, [null],         "TypeError"]

table decimal_extra1306.tuple_constructor_errors:
  description: "decimal.Decimal raises ValueError when given malformed tuple arguments with wrong length, sign, or digit values"
  kind: python_call_raises
  category: constructor_errors
  id_prefix: dc1306tc
  columns: [id, function, args, exception]
  rows:
    - [dc1306tc001, decimal.Decimal, [[2, [1], 0]],             "ValueError"]
    - [dc1306tc002, decimal.Decimal, [[0, [1, 10], 0]],         "ValueError"]
    - [dc1306tc003, decimal.Decimal, [[0]],                     "ValueError"]
    - [dc1306tc004, decimal.Decimal, [[0, 1, 2, 3]],            "ValueError"]
    - [dc1306tc005, decimal.Decimal, [[0, [1, -1], 0]],         "ValueError"]
    - [dc1306tc006, decimal.Decimal.from_float, ["not_float"],  "TypeError"]
