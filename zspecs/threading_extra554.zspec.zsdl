spec: threading_extra554
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__, __class__.__name__, and doc-class identity invariants for threading module public API"
    - "threading.Lock and threading.RLock are factory functions; their __qualname__ is platform-specific and not tested here"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra554.class_qualnames:
  description: "Verify __qualname__ strings for threading synchronization primitive classes"
  kind: python_call_eq
  category: identity
  id_prefix: thx554qn
  columns: [id, function, args, expected]
  rows:
    - [thx554qn001, threading.local.__qualname__.__eq__, ["local"], true]
    - [thx554qn002, threading.Thread.__qualname__.__eq__, ["Thread"], true]
    - [thx554qn003, threading.Condition.__qualname__.__eq__, ["Condition"], true]
    - [thx554qn004, threading.Semaphore.__qualname__.__eq__, ["Semaphore"], true]
    - [thx554qn005, threading.BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"], true]
    - [thx554qn006, threading.Event.__qualname__.__eq__, ["Event"], true]
    - [thx554qn007, threading.Timer.__qualname__.__eq__, ["Timer"], true]
    - [thx554qn008, threading.Barrier.__qualname__.__eq__, ["Barrier"], true]
    - [thx554qn009, threading.BrokenBarrierError.__qualname__.__eq__, ["BrokenBarrierError"], true]

table threading_extra554.constant_and_doc_class:
  description: "Verify TIMEOUT_MAX is a float and Thread carries a str docstring"
  kind: python_call_eq
  category: identity
  id_prefix: thx554cd
  columns: [id, function, args, expected]
  rows:
    - [thx554cd001, threading.TIMEOUT_MAX.__class__.__name__.__eq__, ["float"], true]
    - [thx554cd002, threading.Thread.__doc__.__class__.__name__.__eq__, ["str"], true]

invariant threading_extra554.timeout_max_is_float:
  description: "threading.TIMEOUT_MAX is a float constant"
  category: identity
  kind: python_call_eq
  function: threading.TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra554.thread_qualname:
  description: "threading.Thread has qualname 'Thread'"
  category: identity
  kind: python_call_eq
  function: threading.Thread.__qualname__.__eq__
  args: ["Thread"]
  expected: true
