       "threading.Barrier.n_waiting.__class__.__name__.__eq__('property') == True — Barrier.n_waiting is a property descriptor; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra141"]
    - [n_waiting_fget_qualname_eq,
       "Barrier.n_waiting.fget.__qualname__.__eq__",
       ["Barrier.n_waiting"],
       true,
       "threading.Barrier.n_waiting.fget.__qualname__.__eq__('Barrier.n_waiting') == True — the property getter's __qualname__ is 'Barrier.n_waiting'; str.__eq__ returns True; new to extra141"]
    - [n_waiting_fget_qualname_len_eq_17,
       "Barrier.n_waiting.fget.__qualname__.__len__",
       [],
       17,
       "threading.Barrier.n_waiting.fget.__qualname__.__len__() == 17 — __qualname__ is 'Barrier.n_waiting' which has 17 characters; len() == 17; new to extra141"]
    - [parties_class_eq_property,
       "Barrier.parties.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Barrier.parties.__class__.__name__.__eq__('property') == True — Barrier.parties is a property descriptor; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra141"]
