    - [parties_fget_qualname_len_eq_15,
       "Barrier.parties.fget.__qualname__.__len__",
       [],
       15,
       "threading.Barrier.parties.fget.__qualname__.__len__() == 15 — __qualname__ is 'Barrier.parties' which has 15 characters; len() == 15; new to extra141"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier — class identity and doc string
#
# Wave 268 theme: threading.Barrier — Python class identity and __doc__.
#
# threading.Barrier.__class__.__name__ == 'type'
# threading.Barrier.__name__ == 'Barrier' (len 7)
# threading.Barrier.__module__ == 'threading' (len 9)
# threading.Barrier.__bases__[0].__name__ == 'object'
# len(threading.Barrier.__mro__) == 2
# threading.Barrier.__doc__.__class__.__name__ == 'str'
# len(threading.Barrier.__doc__) == 200
#
# This completes the Barrier profile alongside extra140. New to extra141.
# ---------------------------------------------------------------------------

table threading_extra141.barrier_class_doc:
  description: "threading.Barrier: Python class (type), __name__ len 7, __module__ len 9, MRO len 2, __doc__ str len 200; wave 268; new to extra141"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingbarrierdoc141

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_class_eq_type,
       "Barrier.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Barrier.__class__.__name__.__eq__('type') == True — Barrier is a Python class defined in Lib/threading.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra141"]
    - [barrier_name_eq,
       "Barrier.__name__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — the class __name__ is 'Barrier'; str.__eq__('Barrier') returns True; new to extra141"]
    - [barrier_name_len_eq_7,
       "Barrier.__name__.__len__",
       [],
       7,
       "threading.Barrier.__name__.__len__() == 7 — __name__ is 'Barrier' which has 7 characters; len('Barrier') == 7; new to extra141"]
    - [barrier_module_eq_threading,
       "Barrier.__module__.__eq__",
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra141"]
    - [barrier_module_len_eq_9,
       "Barrier.__module__.__len__",
       [],
       9,
       "threading.Barrier.__module__.__len__() == 9 — __module__ is 'threading' which has 9 characters; len('threading') == 9; new to extra141"]
    - [barrier_bases_0_eq_object,
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier directly inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra141"]
    - [barrier_mro_len_eq_2,
       "Barrier.__mro__.__len__",
       [],
       2,
       "threading.Barrier.__mro__.__len__() == 2 — Barrier's MRO is [Barrier, object]; len(__mro__) is 2; new to extra141"]
    - [barrier_doc_class_eq_str,
       "Barrier.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.Barrier.__doc__.__class__.__name__.__eq__('str') == True — the Barrier docstring is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra141"]
    - [barrier_doc_len_eq_200,
       "Barrier.__doc__.__len__",
       [],
       200,
       "threading.Barrier.__doc__.__len__() == 200 — the Barrier docstring has 200 characters; len(__doc__) == 200; verified with Python 3.14.3; new to extra141"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra141
# ---------------------------------------------------------------------------

invariant threading_extra141.barrier_init_qualname_len:
  description: "len(threading.Barrier.__init__.__qualname__) == 16 — __qualname__ is 'Barrier.__init__'; wave 268; new to extra141"
  kind: python_call_eq
  function: Barrier.__init__.__qualname__.__len__
  args: []
  expected: 16

invariant threading_extra141.barrier_init_co_argcount:
  description: "threading.Barrier.__init__.__code__.co_argcount == 4 — takes self, parties, action, timeout; wave 268; new to extra141"
  kind: python_call_eq
  function: Barrier.__init__.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant threading_extra141.barrier_wait_co_argcount:
  description: "threading.Barrier.wait.__code__.co_argcount == 2 — takes self, timeout; wave 268; new to extra141"
  kind: python_call_eq
  function: Barrier.wait.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra141.barrier_reset_qualname_len:
  description: "len(threading.Barrier.reset.__qualname__) == 13 — __qualname__ is 'Barrier.reset'; wave 268; new to extra141"
  kind: python_call_eq
  function: Barrier.reset.__qualname__.__len__
  args: []
  expected: 13

invariant threading_extra141.barrier_abort_qualname_len:
  description: "len(threading.Barrier.abort.__qualname__) == 13 — __qualname__ is 'Barrier.abort'; wave 268; new to extra141"
  kind: python_call_eq
  function: Barrier.abort.__qualname__.__len__
  args: []
  expected: 13

invariant threading_extra141.barrier_broken_is_property:
  description: "threading.Barrier.broken.__class__.__name__ == 'property' — broken is a property descriptor; wave 268; new to extra141"
  kind: python_call_eq
  function: Barrier.broken.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra141.barrier_n_waiting_fget_qualname_len:
  description: "len(threading.Barrier.n_waiting.fget.__qualname__) == 17 — fget qualname is 'Barrier.n_waiting'; wave 268; new to extra141"
  kind: python_call_eq
  function: Barrier.n_waiting.fget.__qualname__.__len__
  args: []
  expected: 17

invariant threading_extra141.barrier_doc_len:
  description: "len(threading.Barrier.__doc__) == 200 — the Barrier docstring has 200 characters; wave 268; new to extra141"
  kind: python_call_eq
  function: Barrier.__doc__.__len__
