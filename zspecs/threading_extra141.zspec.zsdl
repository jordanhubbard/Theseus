spec: threading_extra141
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Barrier — method qualnames (.__init__, .wait, .reset, .abort), property fget qualnames (.broken, .n_waiting, .parties), __doc__, and co_argcount values (Wave 268)."
    - "threading.Barrier.__init__.__qualname__ == 'Barrier.__init__' (len 16). Verified with Python 3.14.3."
    - "threading.Barrier.__init__.__code__.co_argcount == 4 (self, parties, action, timeout). Verified with Python 3.14.3."
    - "threading.Barrier.wait.__qualname__ == 'Barrier.wait' (len 12). Verified with Python 3.14.3."
    - "threading.Barrier.wait.__code__.co_argcount == 2 (self, timeout). Verified with Python 3.14.3."
    - "threading.Barrier.reset.__qualname__ == 'Barrier.reset' (len 13). Verified with Python 3.14.3."
    - "threading.Barrier.reset.__code__.co_argcount == 1 (self). Verified with Python 3.14.3."
    - "threading.Barrier.abort.__qualname__ == 'Barrier.abort' (len 13). Verified with Python 3.14.3."
    - "threading.Barrier.abort.__code__.co_argcount == 1 (self). Verified with Python 3.14.3."
    - "threading.Barrier.broken is a property; .broken.fget.__qualname__ == 'Barrier.broken' (len 14). Verified with Python 3.14.3."
    - "threading.Barrier.n_waiting is a property; .n_waiting.fget.__qualname__ == 'Barrier.n_waiting' (len 17). Verified with Python 3.14.3."
    - "threading.Barrier.parties is a property; .parties.fget.__qualname__ == 'Barrier.parties' (len 15). Verified with Python 3.14.3."
    - "threading.Barrier.__doc__.__class__.__name__ == 'str' (len 200). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Barrier — method qualnames and co_argcount
#
# Wave 268 theme: threading.Barrier method qualnames (__init__, wait, reset, abort).
#
# threading.Barrier.__init__.__qualname__ == 'Barrier.__init__' (len 16)
# threading.Barrier.__init__.__code__.co_argcount == 4
# threading.Barrier.wait.__qualname__ == 'Barrier.wait' (len 12)
# threading.Barrier.wait.__code__.co_argcount == 2
# threading.Barrier.reset.__qualname__ == 'Barrier.reset' (len 13)
# threading.Barrier.reset.__code__.co_argcount == 1
# threading.Barrier.abort.__qualname__ == 'Barrier.abort' (len 13)
# threading.Barrier.abort.__code__.co_argcount == 1
#
# All are pure Python functions defined in Lib/threading.py. New to extra141.
# ---------------------------------------------------------------------------

table threading_extra141.barrier_method_qualnames:
  description: "threading.Barrier: __init__ qualname len 16 co_argcount 4, wait len 12 co_argcount 2, reset/abort len 13 co_argcount 1; wave 268; new to extra141"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingbarriermeth141

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_init_qualname_eq,
       "Barrier.__init__.__qualname__.__eq__",
       ["Barrier.__init__"],
       true,
       "threading.Barrier.__init__.__qualname__.__eq__('Barrier.__init__') == True — __init__ is a Python function defined on Barrier; its qualname is 'Barrier.__init__'; str.__eq__ returns True; new to extra141"]
    - [barrier_init_qualname_len_eq_16,
       "Barrier.__init__.__qualname__.__len__",
       [],
       16,
       "threading.Barrier.__init__.__qualname__.__len__() == 16 — __qualname__ is 'Barrier.__init__' which has 16 characters; len() == 16; new to extra141"]
    - [barrier_init_co_argcount_eq_4,
       "Barrier.__init__.__code__.co_argcount.__eq__",
       [4],
       true,
       "threading.Barrier.__init__.__code__.co_argcount.__eq__(4) == True — __init__ takes 4 positional-or-keyword arguments: self, parties, action, timeout; co_argcount is 4; int.__eq__(4) returns True; new to extra141"]
    - [barrier_wait_qualname_eq,
       "Barrier.wait.__qualname__.__eq__",
       ["Barrier.wait"],
       true,
       "threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True — wait is a Python function defined on Barrier; its qualname is 'Barrier.wait'; str.__eq__ returns True; new to extra141"]
    - [barrier_wait_qualname_len_eq_12,
       "Barrier.wait.__qualname__.__len__",
       [],
       12,
       "threading.Barrier.wait.__qualname__.__len__() == 12 — __qualname__ is 'Barrier.wait' which has 12 characters; len() == 12; new to extra141"]
    - [barrier_wait_co_argcount_eq_2,
       "Barrier.wait.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Barrier.wait.__code__.co_argcount.__eq__(2) == True — wait takes 2 positional-or-keyword arguments: self, timeout; co_argcount is 2; int.__eq__(2) returns True; new to extra141"]
    - [barrier_reset_qualname_eq,
       "Barrier.reset.__qualname__.__eq__",
       ["Barrier.reset"],
       true,
       "threading.Barrier.reset.__qualname__.__eq__('Barrier.reset') == True — reset is a Python function defined on Barrier; its qualname is 'Barrier.reset'; str.__eq__ returns True; new to extra141"]
    - [barrier_reset_qualname_len_eq_13,
       "Barrier.reset.__qualname__.__len__",
       [],
       13,
       "threading.Barrier.reset.__qualname__.__len__() == 13 — __qualname__ is 'Barrier.reset' which has 13 characters; len() == 13; new to extra141"]
    - [barrier_reset_co_argcount_eq_1,
       "Barrier.reset.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Barrier.reset.__code__.co_argcount.__eq__(1) == True — reset takes 1 positional-or-keyword argument: self; co_argcount is 1; int.__eq__(1) returns True; new to extra141"]
    - [barrier_abort_qualname_eq,
       "Barrier.abort.__qualname__.__eq__",
       ["Barrier.abort"],
       true,
       "threading.Barrier.abort.__qualname__.__eq__('Barrier.abort') == True — abort is a Python function defined on Barrier; its qualname is 'Barrier.abort'; str.__eq__ returns True; new to extra141"]
    - [barrier_abort_qualname_len_eq_13,
       "Barrier.abort.__qualname__.__len__",
       [],
       13,
       "threading.Barrier.abort.__qualname__.__len__() == 13 — __qualname__ is 'Barrier.abort' which has 13 characters; len() == 13; new to extra141"]
    - [barrier_abort_co_argcount_eq_1,
       "Barrier.abort.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Barrier.abort.__code__.co_argcount.__eq__(1) == True — abort takes 1 positional-or-keyword argument: self; co_argcount is 1; int.__eq__(1) returns True; new to extra141"]

# ---------------------------------------------------------------------------
# Table 2: threading.Barrier — property fget qualnames
#
# Wave 268 theme: threading.Barrier property descriptors.
#
# threading.Barrier.broken is a property
# threading.Barrier.broken.fget.__qualname__ == 'Barrier.broken' (len 14)
# threading.Barrier.n_waiting is a property
# threading.Barrier.n_waiting.fget.__qualname__ == 'Barrier.n_waiting' (len 17)
# threading.Barrier.parties is a property
# threading.Barrier.parties.fget.__qualname__ == 'Barrier.parties' (len 15)
#
# The Barrier class exposes three read-only properties. New to extra141.
# ---------------------------------------------------------------------------

table threading_extra141.barrier_property_fget_qualnames:
  description: "threading.Barrier properties: broken.fget qualname len 14, n_waiting.fget len 17, parties.fget len 15; wave 268; new to extra141"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingbarrierprop141

  columns: [id, function, args, expected, description]
  rows:
    - [broken_class_eq_property,
       "Barrier.broken.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Barrier.broken.__class__.__name__.__eq__('property') == True — Barrier.broken is a property descriptor; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra141"]
    - [broken_fget_qualname_eq,
       "Barrier.broken.fget.__qualname__.__eq__",
