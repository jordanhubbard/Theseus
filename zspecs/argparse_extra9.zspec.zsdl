spec: argparse_extra9
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html — Python argparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/argparse.py"
    - "argparse.zspec.zsdl — covers __name__ table for all public classes, nargs constants, SUPPRESS/REMAINDER, parse_args, Namespace attrs, MRO checks"
    - "argparse_formatters.zspec.zsdl — covers formatter __name__/__module__/__bases__ tables, FileType, BooleanOptionalAction __bases__, exception __bases__"
    - "argparse_extra.zspec.zsdl — covers ArgumentParser/Namespace/HelpFormatter/ArgumentError/Action __name__/__module__, Action.__bases__[0], ArgumentDefaultsHelpFormatter/__name__, FileType/__name__/__module__, parse_args/__name__, add_argument/__name__"
    - "argparse_extra2.zspec.zsdl — covers __module__ table for formatters/exceptions, __bases__[0].__name__ invariants for ArgumentParser/Namespace/ArgumentError/ArgumentTypeError/HelpFormatter/RawText*/RawDescription*/ArgumentDefaults*"
    - "argparse_extra3.zspec.zsdl — covers class_names table, nargs_constants table, ArgumentParser/__module__, Namespace instance class, ArgumentError/ArgumentTypeError __bases__[0], ArgumentParser().prog type"
    - "argparse_extra4.zspec.zsdl — covers __qualname__ table for ArgumentParser/Namespace/Action/FileType/HelpFormatter/RawDescription*/RawText*/ArgumentDefaults*/MetavarType*/ArgumentError/ArgumentTypeError"
    - "argparse_extra5.zspec.zsdl — covers argparse module __name__, FileType/__bases__[0], BooleanOptionalAction/__bases__[0], SUPPRESS/REMAINDER/ONE_OR_MORE/ZERO_OR_MORE/OPTIONAL __class__.__name__"
    - "argparse_extra6.zspec.zsdl — covers BooleanOptionalAction/__qualname__, PARSER value/class, Namespace/__bases__[0].__name__, HelpFormatter/__bases__[0].__name__, ArgumentParser method names (set_defaults/format_help/format_usage/parse_known_args), ArgumentParser().description"
    - "argparse_extra7.zspec.zsdl — covers Action/__module__, FileType/__module__, formatter_bases table, ONE_OR_MORE __ne__/__len__, ArgumentParser().prefix_chars, ArgumentParser().add_help, formatter __name__ standalone invariants"
    - "argparse_extra8.zspec.zsdl — covers __bases__.__len__()==1 for ArgumentParser/Namespace/Action/HelpFormatter; ArgumentParser method names print_usage/print_help/convert_arg_line_to_args/exit/error"
  notes:
    - "This spec extends the argparse chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: __class__.__name__ metaclass checks for FileType/ArgumentError/ArgumentTypeError (extra8 only covers ArgumentParser/Namespace/Action/HelpFormatter for __bases__.__len__); ArgumentParser method names parse_intermixed_args/parse_known_intermixed_args/add_argument_group/add_mutually_exclusive_group/get_default not covered in any prior spec; RawDescriptionHelpFormatter/__bases__.__len__()==1."
    - "argparse.FileType.__class__.__name__ == 'type' — FileType is a plain class; extra8 covers ArgumentParser/Namespace/Action/HelpFormatter metaclasses but not FileType."
    - "argparse.ArgumentError.__class__.__name__ == 'type' — ArgumentError is an exception class; its metaclass is 'type'."
    - "argparse.ArgumentTypeError.__class__.__name__ == 'type' — ArgumentTypeError is an exception class; its metaclass is 'type'."
    - "argparse.ArgumentParser.parse_intermixed_args.__name__ == 'parse_intermixed_args' — added in Python 3.7; no prior spec covers this method name."
    - "argparse.ArgumentParser.parse_known_intermixed_args.__name__ == 'parse_known_intermixed_args' — added in Python 3.7; no prior spec covers this method name."
    - "argparse.ArgumentParser.add_argument_group.__name__ == 'add_argument_group' — no prior spec covers this method name."
    - "argparse.ArgumentParser.add_mutually_exclusive_group.__name__ == 'add_mutually_exclusive_group' — no prior spec covers this method name."
    - "argparse.ArgumentParser.get_default.__name__ == 'get_default' — no prior spec covers this method name."
    - "argparse.RawDescriptionHelpFormatter.__bases__.__len__() == 1 — extra7/formatters verify __bases__[0].__name__ but not the tuple length."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Metaclass checks for FileType, ArgumentError, ArgumentTypeError.
#
# argparse_extra8 covers __class__.__name__ == 'type' for ArgumentParser,
# Namespace, Action, and HelpFormatter. No prior spec checks these for
# FileType, ArgumentError, or ArgumentTypeError.
# ---------------------------------------------------------------------------

table argparse_extra9.class_metaclasses:
  kind: python_call_eq
  category: class_metadata
  id_prefix: metacls9

  columns: [id, function, args, expected]
  rows:
    - [FileType,          FileType.__class__.__name__.__eq__,          ["type"], true]
    - [ArgumentError,     ArgumentError.__class__.__name__.__eq__,     ["type"], true]
    - [ArgumentTypeError, ArgumentTypeError.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# ArgumentParser method names not covered in any prior argparse spec.
#
# extra covers: parse_args.__name__, add_argument.__name__
# extra6 covers: set_defaults, format_help, format_usage, parse_known_args
# extra8 covers: print_usage, print_help, convert_arg_line_to_args, exit, error
# This table adds: parse_intermixed_args, parse_known_intermixed_args,
#   add_argument_group, add_mutually_exclusive_group, get_default.
# ---------------------------------------------------------------------------

table argparse_extra9.ArgumentParser.additional_method_names:
  kind: python_call_eq
  category: methods
  id_prefix: mname9

  columns: [id, function, args, expected]
  rows:
    - [parse_intermixed_args,        ArgumentParser.parse_intermixed_args.__name__.__eq__,        ["parse_intermixed_args"],        true]
    - [parse_known_intermixed_args,  ArgumentParser.parse_known_intermixed_args.__name__.__eq__,  ["parse_known_intermixed_args"],  true]
    - [add_argument_group,           ArgumentParser.add_argument_group.__name__.__eq__,           ["add_argument_group"],           true]
    - [add_mutually_exclusive_group, ArgumentParser.add_mutually_exclusive_group.__name__.__eq__, ["add_mutually_exclusive_group"], true]
    - [get_default,                  ArgumentParser.get_default.__name__.__eq__,                  ["get_default"],                  true]

# ---------------------------------------------------------------------------
# RawDescriptionHelpFormatter.__bases__.__len__() == 1
#
# argparse_extra7 and argparse_formatters verify __bases__[0].__name__ for
# RawDescriptionHelpFormatter but no prior spec checks the length of the
# __bases__ tuple (single-inheritance confirmation).
# ---------------------------------------------------------------------------

invariant argparse_extra9.RawDescriptionHelpFormatter.bases_len:
  description: "argparse.RawDescriptionHelpFormatter.__bases__.__len__() == 1 — inherits from exactly one base (HelpFormatter)"
  category: hierarchy
  kind: python_call_eq
  function: RawDescriptionHelpFormatter.__bases__.__len__
  args: []
  expected: 1
