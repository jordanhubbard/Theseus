spec: re_extra98
version: ">=3.9"
backend: python_module(re)
extends: re_extra97

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra97.zspec.zsdl."
    - "This spec covers: re.RegexFlag enum member values and names + re module __all__."
    - "re.IGNORECASE.value = 2, re.MULTILINE.value = 8, re.DOTALL.value = 16, re.VERBOSE.value = 64."
    - "re.ASCII.value = 256, re.UNICODE.value = 32, re.LOCALE.value = 4, re.NOFLAG.value = 0."
    - "re.DEBUG.value = 128."
    - "Single-letter aliases (I, M, S, X, A, U, L) are the same enum member as their long-form counterparts; their .name returns the long-form name (e.g. re.I.name == 'IGNORECASE')."
    - "re.FULLMATCH does not exist as an attribute in Python 3.14.3 (re.fullmatch is a function, not a flag)."
    - "re.__all__ is a list of length 31."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag main flag values: IGNORECASE=2, MULTILINE=8, DOTALL=16, VERBOSE=64
# ---------------------------------------------------------------------------

table re_extra98.RegexFlag_main_values:
  description: "re.RegexFlag main flag integer values: IGNORECASE=2, MULTILINE=8, DOTALL=16, VERBOSE=64"
  kind: python_call_eq
  category: enum_values
  id_prefix: reregexflagvalues98

  columns: [id, function, args, expected]
  rows:
    - [ic_value,       IGNORECASE.value.__eq__, [2],  true]
    - [ml_value,       MULTILINE.value.__eq__,  [8],  true]
    - [da_value,       DOTALL.value.__eq__,     [16], true]
    - [vb_value,       VERBOSE.value.__eq__,    [64], true]
    - [ic_value_int,   IGNORECASE.value.__eq__, [2],  true]
    - [ic_not_8,       IGNORECASE.value.__eq__, [8],  false]

# ---------------------------------------------------------------------------
# re.RegexFlag secondary flag values: ASCII=256, UNICODE=32, LOCALE=4, NOFLAG=0
# ---------------------------------------------------------------------------

table re_extra98.RegexFlag_secondary_values:
  description: "re.RegexFlag secondary flag integer values: ASCII=256, UNICODE=32, LOCALE=4, NOFLAG=0, DEBUG=128"
  kind: python_call_eq
  category: enum_values
  id_prefix: reregexflagvalues98

  columns: [id, function, args, expected]
  rows:
    - [asc_value,    ASCII.value.__eq__,   [256], true]
    - [uni_value,    UNICODE.value.__eq__, [32],  true]
    - [loc_value,    LOCALE.value.__eq__,  [4],   true]
    - [nof_value,    NOFLAG.value.__eq__,  [0],   true]
    - [dbg_value,    DEBUG.value.__eq__,   [128], true]
    - [asc_not_32,   ASCII.value.__eq__,   [32],  false]

# ---------------------------------------------------------------------------
# re.RegexFlag enum member .name string values
# IGNORECASE.name == 'IGNORECASE', alias I.name == 'IGNORECASE', etc.
# ---------------------------------------------------------------------------

table re_extra98.RegexFlag_member_names:
  description: "re.RegexFlag enum member .name string values: long-form flags return their canonical name; single-letter aliases return the long-form name"
  kind: python_call_eq
  category: enum_values
  id_prefix: reregexflagvalues98

  columns: [id, function, args, expected]
  rows:
    - [ic_name,   IGNORECASE.name.__eq__, ["IGNORECASE"], true]
    - [ml_name,   MULTILINE.name.__eq__,  ["MULTILINE"],  true]
    - [da_name,   DOTALL.name.__eq__,     ["DOTALL"],     true]
    - [vb_name,   VERBOSE.name.__eq__,    ["VERBOSE"],    true]
    - [asc_name,  ASCII.name.__eq__,      ["ASCII"],      true]
    - [uni_name,  UNICODE.name.__eq__,    ["UNICODE"],    true]
    - [loc_name,  LOCALE.name.__eq__,     ["LOCALE"],     true]
    - [nof_name,  NOFLAG.name.__eq__,     ["NOFLAG"],     true]
    - [dbg_name,  DEBUG.name.__eq__,      ["DEBUG"],      true]
    - [i_alias,   I.name.__eq__,          ["IGNORECASE"], true]
    - [m_alias,   M.name.__eq__,          ["MULTILINE"],  true]
    - [s_alias,   S.name.__eq__,          ["DOTALL"],     true]

# ---------------------------------------------------------------------------
# re.__all__ class name, length, and selected membership
# re.__all__ is a list of length 31.
# Contains: 'compile', 'match', 'search', 'sub', 'IGNORECASE', 'error'
# ---------------------------------------------------------------------------

table re_extra98.module_all_class_and_membership:
  description: "re.__all__ class name ('list'), length (31), and selected membership checks"
  kind: python_call_eq
  category: module_all
  id_prefix: reregexflagvalues98

  columns: [id, function, args, expected]
  rows:
    - [all_cls,        __all__.__class__.__name__.__eq__,     ["list"], true]
    - [all_len,        __all__.__len__,                       [],       31]
    - [all_has_compile,"__all__.__contains__",                ["compile"],    true]
    - [all_has_match,  "__all__.__contains__",                ["match"],      true]
    - [all_has_search, "__all__.__contains__",                ["search"],     true]
    - [all_has_sub,    "__all__.__contains__",                ["sub"],        true]
    - [all_has_ic,     "__all__.__contains__",                ["IGNORECASE"], true]
    - [all_has_error,  "__all__.__contains__",                ["error"],      true]
    - [all_not_sys,    "__all__.__contains__",                ["sys"],        false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra98.IGNORECASE.value_is_2:
  description: "re.IGNORECASE.value == 2 (IGNORECASE is the bit-1 flag in the RegexFlag enum; its integer value is 2)"
  category: enum_values
  kind: python_call_eq
  function: IGNORECASE.value.__eq__
  args: [2]
  expected: true

invariant re_extra98.DOTALL.value_is_16:
  description: "re.DOTALL.value == 16 (DOTALL makes . match any character including newline; its integer value is 16)"
  category: enum_values
  kind: python_call_eq
  function: DOTALL.value.__eq__
  args: [16]
  expected: true

invariant re_extra98.I_alias_name_is_IGNORECASE:
  description: "re.I.name == 'IGNORECASE' (single-letter aliases in RegexFlag are the same enum member as the long form; .name always returns the canonical long-form name)"
  category: enum_values
  kind: python_call_eq
  function: I.name.__eq__
  args: ["IGNORECASE"]
  expected: true

invariant re_extra98.NOFLAG.value_is_0:
  description: "re.NOFLAG.value == 0 (NOFLAG is the zero-value sentinel member of RegexFlag; it represents no flags applied)"
  category: enum_values
  kind: python_call_eq
  function: NOFLAG.value.__eq__
  args: [0]
  expected: true

invariant re_extra98.all_len_is_31:
  description: "re.__all__.__len__() == 31 (the re module exports exactly 31 public names in Python 3.14.3)"
  category: module_all
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 31
