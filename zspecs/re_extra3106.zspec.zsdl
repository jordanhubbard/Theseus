spec: re3106
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (re3106): __lt__, __le__, __gt__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "re.Pattern defines __lt__, __le__, and __gt__ in its own __dict__: compiled patterns support lexicographic ordering (by pattern string and flags)."
    - "re.Match does NOT define __lt__, __le__, or __gt__ in its own __dict__; identity-based ordering is inherited from object."
    - "re.RegexFlag is an IntFlag enum and does NOT define __lt__, __le__, or __gt__ in its own __dict__; ordering is inherited via IntFlag/int."
    - "re.Pattern.__dict__ is accessed directly (not via type(re.compile(...)).__dict__) per wave 654 convention."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __lt__ dict-presence — operator.contains(Cls.__dict__, '__lt__')
#
# re.Pattern defines __lt__ (true): compiled patterns support ordering comparisons.
# re.Match and re.RegexFlag do not define __lt__ in their own __dict__ (false).
# re.Pattern.__dict__ is used directly, not type(re.compile(...)).__dict__.
# ---------------------------------------------------------------------------

table re3106.lt:
  description: "re types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3106

  columns: [id, function, args, expected]
  rows:
    - ["re3106001", operator.contains, [re.Pattern.__dict__,    "__lt__"], true]
    - ["re3106002", operator.contains, [re.Match.__dict__,      "__lt__"], false]
    - ["re3106003", operator.contains, [re.RegexFlag.__dict__,  "__lt__"], false]

# ---------------------------------------------------------------------------
# __le__ dict-presence — operator.contains(Cls.__dict__, '__le__')
#
# re.Pattern defines __le__ (true); re.Match and re.RegexFlag do not (false).
# ---------------------------------------------------------------------------

