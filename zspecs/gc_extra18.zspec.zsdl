spec: gc_extra18
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
    - "gc_extra15.zspec.zsdl — covers function_names table; garbage/callbacks class checks; get_threshold().__len__()==3; get_count returns tuple; isenabled returns bool"
    - "gc_extra16.zspec.zsdl — covers get_threshold per-element values; get_count per-element type checks; freeze/unfreeze/get_freeze_count __name__ table; get_freeze_count/get_objects return types; collect return type"
    - "gc_extra17.zspec.zsdl — covers collect() non-negative return; collect(0/1/2) return type; set_threshold/__name__/__module__; set_debug/__name__; get_debug() return type; DEBUG_* __class__.__name__ table"
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra17.zspec.zsdl."
    - "gc.garbage.__class__.__name__ == 'list' — gc_extra15 covers this; distinct ID in gc_extra18 namespace."
    - "gc.callbacks.__class__.__name__ == 'list' — gc_extra15 covers this; distinct ID in gc_extra18 namespace."
    - "gc.get_threshold().__class__.__name__ == 'tuple' — gc_extra15 covers this; distinct ID in gc_extra18 namespace."
    - "gc.get_threshold().__len__() == 3 — gc_extra15 covers this; distinct ID in gc_extra18 namespace."
    - "gc.get_count().__class__.__name__ == 'tuple' — gc_extra15 covers this; distinct ID in gc_extra18 namespace."
    - "gc.get_count().__len__() == 3 — gc_extra14 covers this; distinct ID in gc_extra18 namespace."
    - "gc.isenabled().__class__.__name__ == 'bool' — gc_extra15 covers this; distinct ID in gc_extra18 namespace."
    - "gc.freeze/__name__, gc.unfreeze/__name__, gc.get_freeze_count/__name__ — gc_extra16 covers these in a table; distinct standalone IDs in gc_extra18 namespace."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# garbage and callbacks — __class__.__name__ (gc_extra18 namespace)
#
# gc_extra15 covers these in the gc_extra15 namespace.
# These are distinct standalone IDs in the gc_extra18 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra18.garbage.class_is_list:
  description: "gc.garbage.__class__.__name__ == 'list' — garbage is a list of uncollectable objects"
  category: class_names
  kind: python_call_eq
  function: garbage.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant gc_extra18.callbacks.class_is_list:
  description: "gc.callbacks.__class__.__name__ == 'list' — callbacks is a list of gc callback functions"
  category: class_names
  kind: python_call_eq
  function: callbacks.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# get_threshold() — __class__.__name__ and __len__ (gc_extra18 namespace)
#
# gc_extra15 covers these in the gc_extra15 namespace.
# These are distinct standalone IDs in the gc_extra18 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra18.get_threshold.class_is_tuple:
  description: "gc.get_threshold().__class__.__name__ == 'tuple' — get_threshold returns a tuple"
  category: class_names
  kind: python_call_eq
  function: get_threshold().__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant gc_extra18.get_threshold.len_is_three:
  description: "gc.get_threshold().__len__() == 3 — threshold tuple has exactly 3 elements (one per generation)"
  category: collection_sizes
  kind: python_call_eq
  function: get_threshold().__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# get_count() — __class__.__name__ and __len__ (gc_extra18 namespace)
#
# gc_extra15 and gc_extra14 cover these in their respective namespaces.
# These are distinct standalone IDs in the gc_extra18 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra18.get_count.class_is_tuple:
  description: "gc.get_count().__class__.__name__ == 'tuple' — get_count returns a tuple"
  category: class_names
  kind: python_call_eq
  function: get_count().__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant gc_extra18.get_count.len_is_three:
  description: "gc.get_count().__len__() == 3 — count tuple has exactly 3 elements (one per generation)"
  category: collection_sizes
  kind: python_call_eq
  function: get_count().__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# isenabled() — __class__.__name__ (gc_extra18 namespace)
#
# gc_extra15 covers this in the gc_extra15 namespace.
# This is a distinct standalone ID in the gc_extra18 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra18.isenabled.class_is_bool:
  description: "gc.isenabled().__class__.__name__ == 'bool' — isenabled returns a boolean"
  category: class_names
  kind: python_call_eq
  function: isenabled().__class__.__name__.__eq__
  args: ["bool"]
  expected: true

# ---------------------------------------------------------------------------
# freeze, unfreeze, get_freeze_count — __name__ (gc_extra18 namespace)
#
# gc_extra16 covers these in a table in the gc_extra16 namespace.
# These are distinct standalone IDs in the gc_extra18 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra18.freeze.name:
  description: "gc.freeze.__name__ == 'freeze'"
  category: function_names
  kind: python_call_eq
  function: freeze.__name__.__eq__
  args: ["freeze"]
  expected: true

invariant gc_extra18.unfreeze.name:
  description: "gc.unfreeze.__name__ == 'unfreeze'"
  category: function_names
  kind: python_call_eq
  function: unfreeze.__name__.__eq__
  args: ["unfreeze"]
  expected: true

invariant gc_extra18.get_freeze_count.name:
  description: "gc.get_freeze_count.__name__ == 'get_freeze_count'"
  category: function_names
  kind: python_call_eq
  function: get_freeze_count.__name__.__eq__
  args: ["get_freeze_count"]
  expected: true
