spec: dis_extra
version: ">=3.0"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/dis.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: internal bytecode implementation (compile.c, ceval.c)"
  notes:
    - "This spec covers dis behaviors not already captured in dis.zspec.zsdl."
    - "dis.__name__ == 'dis' — the module's own __name__ attribute reflects its import name."
    - "distb.__name__ == 'distb' — disassembles a traceback's last frame."
    - "code_info, show_code, get_instructions, findlinestarts, findlabels are all top-level public functions."
    - "Instruction is a named tuple (NamedTuple) class; its __module__ is 'dis'."
    - "opname is a plain list; opmap is a plain dict; HAVE_ARGUMENT is a plain int."
    - "stack_effect.__name__ == 'stack_effect' — covered in dis.zspec.zsdl for return values; name check added here."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity — dis.__name__
# ---------------------------------------------------------------------------

invariant dis_extra.module.name:
  description: "dis.__name__ == 'dis' — the module's own name attribute"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["dis"]
  expected: true

# ---------------------------------------------------------------------------
# Function names not covered in dis.zspec.zsdl
# ---------------------------------------------------------------------------

invariant dis_extra.functions.distb:
  description: "dis.distb.__name__ == 'distb'"
  category: functions
  kind: python_call_eq
  function: distb.__name__.__eq__
  args: ["distb"]
  expected: true

invariant dis_extra.functions.findlinestarts:
  description: "dis.findlinestarts.__name__ == 'findlinestarts'"
  category: functions
  kind: python_call_eq
  function: findlinestarts.__name__.__eq__
  args: ["findlinestarts"]
  expected: true

invariant dis_extra.functions.findlabels:
  description: "dis.findlabels.__name__ == 'findlabels'"
  category: functions
  kind: python_call_eq
  function: findlabels.__name__.__eq__
  args: ["findlabels"]
  expected: true

# These were in dis.zspec.zsdl table rows; add as standalone invariants here
# for completeness of this extra spec per the task spec.

invariant dis_extra.functions.disassemble:
  description: "dis.disassemble.__name__ == 'disassemble'"
  category: functions
  kind: python_call_eq
  function: disassemble.__name__.__eq__
  args: ["disassemble"]
  expected: true

invariant dis_extra.functions.code_info:
  description: "dis.code_info.__name__ == 'code_info'"
  category: functions
  kind: python_call_eq
  function: code_info.__name__.__eq__
  args: ["code_info"]
  expected: true

invariant dis_extra.functions.show_code:
  description: "dis.show_code.__name__ == 'show_code'"
  category: functions
  kind: python_call_eq
  function: show_code.__name__.__eq__
  args: ["show_code"]
  expected: true

invariant dis_extra.functions.get_instructions:
  description: "dis.get_instructions.__name__ == 'get_instructions'"
  category: functions
  kind: python_call_eq
  function: get_instructions.__name__.__eq__
  args: ["get_instructions"]
  expected: true

invariant dis_extra.functions.stack_effect:
  description: "dis.stack_effect.__name__ == 'stack_effect'"
  category: functions
  kind: python_call_eq
  function: stack_effect.__name__.__eq__
  args: ["stack_effect"]
  expected: true

# ---------------------------------------------------------------------------
# Instruction class — name and module
# ---------------------------------------------------------------------------

invariant dis_extra.Instruction.name:
  description: "dis.Instruction.__name__ == 'Instruction'"
  category: instruction
  kind: python_call_eq
  function: Instruction.__name__.__eq__
  args: ["Instruction"]
  expected: true

invariant dis_extra.Instruction.module:
  description: "dis.Instruction.__module__ == 'dis'"
  category: instruction
  kind: python_call_eq
  function: Instruction.__module__.__eq__
  args: ["dis"]
  expected: true

# ---------------------------------------------------------------------------
# opname — class check (value checks are in dis.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant dis_extra.opname.class_name:
  description: "dis.opname.__class__.__name__ == 'list'"
  category: opname
  kind: python_call_eq
  function: opname.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# opmap — class check (value checks are in dis.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant dis_extra.opmap.class_name:
  description: "dis.opmap.__class__.__name__ == 'dict'"
  category: opmap
  kind: python_call_eq
  function: opmap.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# HAVE_ARGUMENT — integer constant separating simple and compound opcodes
#
# dis.HAVE_ARGUMENT is the threshold opcode value: opcodes >= HAVE_ARGUMENT
# take an argument. It is a plain int constant exported from the dis module.
# ---------------------------------------------------------------------------

invariant dis_extra.HAVE_ARGUMENT.class_name:
  description: "dis.HAVE_ARGUMENT.__class__.__name__ == 'int'"
  category: have_argument
  kind: python_call_eq
  function: HAVE_ARGUMENT.__class__.__name__.__eq__
  args: ["int"]
  expected: true
