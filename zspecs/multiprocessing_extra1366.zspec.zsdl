    - [mp1366pr002, multiprocessing.Process.__basicsize__.__class__.__name__.__eq__,   ["int"], true]
    - [mp1366pr003, multiprocessing.Process.__itemsize__.__class__.__name__.__eq__,    ["int"], true]
    - [mp1366pr004, multiprocessing.Process.__flags__.__class__.__name__.__eq__,       ["int"], true]
