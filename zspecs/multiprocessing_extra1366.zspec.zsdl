spec: multiprocessing_extra1366
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Process-based parallelism"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks."
    - "multiprocessing.Process, multiprocessing.process.BaseProcess, and multiprocessing.pool.Pool are all pure-Python classes."
    - "__flags__, __basicsize__, and __itemsize__ are type object attributes present on every Python class."
    - "Only the types (int) of these attributes are checked — exact integer values are platform-specific."
    - "multiprocessing.Process is a concrete subclass of multiprocessing.process.BaseProcess."
    - "multiprocessing.pool.Pool must be accessed via the submodule (multiprocessing.pool.Pool)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra1366.Process_flags_basicsize_itemsize:
  description: "multiprocessing.Process __flags__, __basicsize__, __itemsize__ are all of type int"
  kind: python_call_eq
