spec: multiprocessing_extra147
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "This spec covers multiprocessing class __dict__ sizes and module loader identity. multiprocessing.Process.__dict__.__len__()==7 (mappingproxy; Process is a proxy class in context.py that wraps BaseProcess). multiprocessing.pool.Pool.__dict__.__len__()==42 (mappingproxy; Pool is the most method-rich class in this spec with map, apply, starmap, imap, async variants, etc.). multiprocessing.queues.Queue.__dict__.__len__()==28 (mappingproxy). multiprocessing.queues.JoinableQueue.__dict__.__len__()==10. multiprocessing.queues.SimpleQueue.__dict__.__len__()==14. multiprocessing.__loader__.__class__.__name__=='SourceFileLoader' (len=16). multiprocessing.__package__.__eq__('multiprocessing')==True (len=15). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Process.__dict__.__len__()==7 because Process in multiprocessing is a context-bound proxy (multiprocessing.Process.__module__=='multiprocessing.context'); the actual implementation is in BaseProcess. Pool has the most __dict__ entries at 42. Queue from multiprocessing.queues has 28 entries (more than JoinableQueue at 10 because Queue is the base class). SimpleQueue has 14 entries. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing module loader and package — extra147
#
# multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16)
# multiprocessing.__package__.__eq__('multiprocessing') == True (len=15)
# multiprocessing.__loader__.__class__.__name__.__len__() == 16
# ---------------------------------------------------------------------------

table multiprocessing_extra147.mp_loader_and_package:
  description: "multiprocessing module loader and package attribute checks in mp_dict147 namespace — multiprocessing.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True (len=16: 'SourceFileLoader'=16 chars; multiprocessing is loaded from Lib/multiprocessing/__init__.py, using the standard file-based SourceFileLoader); multiprocessing.__loader__.__class__.__name__.__len__()==16; multiprocessing.__package__.__eq__('multiprocessing')==True (len=15: 'multiprocessing'=15 chars; __package__ equals the package name since multiprocessing is a package); multiprocessing.__package__.__len__()==15; the loader class name 'SourceFileLoader' is the same length (16) as for concurrent.futures, both being .py-file loaded packages; contrast with abc which uses a FrozenImporter (loader class is 'type'); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: mp_dict147

  columns: [id, function, args, expected, description]
  rows:
    - [ldr_cls_eq,   multiprocessing.__loader__.__class__.__name__.__eq__,  ["SourceFileLoader"],   true,  "multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16); verified with Python 3.14.3"]
    - [ldr_cls_len,  multiprocessing.__loader__.__class__.__name__.__len__,  [],                     16,    "multiprocessing.__loader__.__class__.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [pkg_eq,       multiprocessing.__package__.__eq__,                    ["multiprocessing"],    true,  "multiprocessing.__package__ == 'multiprocessing' (len=15); verified with Python 3.14.3"]
    - [pkg_len,      multiprocessing.__package__.__len__,                    [],                     15,    "multiprocessing.__package__.__len__() == 15; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Process.__dict__ — extra147
#
# multiprocessing.Process.__dict__.__len__()          == 7
# multiprocessing.Process.__dict__.__class__.__name__ == 'mappingproxy'
# multiprocessing.Process.__name__.__len__()          == 7
# multiprocessing.Process.__module__                  == 'multiprocessing.context'
# ---------------------------------------------------------------------------

table multiprocessing_extra147.mp_process_dict:
  description: "multiprocessing.Process __dict__ size and identity checks in mp_dict147 namespace — multiprocessing.Process.__dict__.__len__()==7 (7 entries in the Process class namespace mappingproxy; multiprocessing.Process is a context-bound proxy class defined in multiprocessing.context, not the full BaseProcess implementation; it only overrides __module__ and delegates everything else to BaseProcess via inheritance, hence only 7 entries); multiprocessing.Process.__dict__.__class__.__name__.__eq__('mappingproxy')==True; multiprocessing.Process.__name__.__eq__('Process')==True (len=7: 'Process'='P'+'r'+'o'+'c'+'e'+'s'+'s'=7); multiprocessing.Process.__name__.__len__()==7; multiprocessing.Process.__module__.__eq__('multiprocessing.context')==True (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23; the proxy class is defined in the context module); multiprocessing.Process.__module__.__len__()==23; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp_proc147

  columns: [id, function, args, expected, description]
  rows:
    - [proc_dict_len,  multiprocessing.Process.__dict__.__len__,                      [],                       7,     "multiprocessing.Process.__dict__.__len__() == 7; verified with Python 3.14.3"]
    - [proc_dict_cls,  multiprocessing.Process.__dict__.__class__.__name__.__eq__,    ["mappingproxy"],         true,  "multiprocessing.Process.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [proc_name_eq,   multiprocessing.Process.__name__.__eq__,                       ["Process"],              true,  "multiprocessing.Process.__name__ == 'Process' (len=7); verified with Python 3.14.3"]
    - [proc_name_len,  multiprocessing.Process.__name__.__len__,                       [],                       7,     "multiprocessing.Process.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [proc_mod_eq,    multiprocessing.Process.__module__.__eq__,                     ["multiprocessing.context"], true, "multiprocessing.Process.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [proc_mod_len,   multiprocessing.Process.__module__.__len__,                     [],                       23,    "multiprocessing.Process.__module__.__len__() == 23; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool and multiprocessing.queues.Queue __dict__ — extra147
#
# multiprocessing.pool.Pool.__dict__.__len__()          == 42
# multiprocessing.pool.Pool.__dict__.__class__.__name__ == 'mappingproxy'
# multiprocessing.queues.Queue.__dict__.__len__()       == 28
# multiprocessing.queues.JoinableQueue.__dict__.__len__() == 10
# multiprocessing.queues.SimpleQueue.__dict__.__len__() == 14
# ---------------------------------------------------------------------------

table multiprocessing_extra147.mp_pool_and_queue_dicts:
  description: "multiprocessing.pool.Pool and multiprocessing.queues.Queue family __dict__ size checks in mp_dict147 namespace — multiprocessing.pool.Pool.__dict__.__len__()==42 (42 entries: the most method-rich class in this spec; Pool defines map, apply, starmap, imap, async variants, terminate, close, join, and many helper methods plus worker management; Pool.__module__=='multiprocessing.pool'); multiprocessing.pool.Pool.__dict__.__class__.__name__.__eq__('mappingproxy')==True; multiprocessing.queues.Queue.__dict__.__len__()==28 (28 entries in the Queue class mappingproxy; Queue is the base queue class with put, get, qsize, empty, full, put_nowait, get_nowait, close, join_thread, cancel_join_thread, and internal state management; Queue.__module__=='multiprocessing.queues'); multiprocessing.queues.Queue.__dict__.__class__.__name__.__eq__('mappingproxy')==True; multiprocessing.queues.JoinableQueue.__dict__.__len__()==10 (10 entries: JoinableQueue subclasses Queue and adds task_done and join methods plus join-specific state); multiprocessing.queues.SimpleQueue.__dict__.__len__()==14 (14 entries: SimpleQueue is a simpler queue implementation without the pipe-and-lock architecture of Queue); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp_pq147

  columns: [id, function, args, expected, description]
  rows:
    - [pool_dict_len,  multiprocessing.pool.Pool.__dict__.__len__,                     [],               42,    "multiprocessing.pool.Pool.__dict__.__len__() == 42 (largest in this spec); verified with Python 3.14.3"]
    - [pool_dict_cls,  multiprocessing.pool.Pool.__dict__.__class__.__name__.__eq__,   ["mappingproxy"],  true,  "multiprocessing.pool.Pool.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [que_dict_len,   multiprocessing.queues.Queue.__dict__.__len__,                  [],               28,    "multiprocessing.queues.Queue.__dict__.__len__() == 28; verified with Python 3.14.3"]
    - [que_dict_cls,   multiprocessing.queues.Queue.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true,  "multiprocessing.queues.Queue.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [jq_dict_len,    multiprocessing.queues.JoinableQueue.__dict__.__len__,           [],               10,    "multiprocessing.queues.JoinableQueue.__dict__.__len__() == 10; verified with Python 3.14.3"]
    - [sq_dict_len,    multiprocessing.queues.SimpleQueue.__dict__.__len__,             [],               14,    "multiprocessing.queues.SimpleQueue.__dict__.__len__() == 14; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra147
# ---------------------------------------------------------------------------

invariant multiprocessing_extra147.mp_loader_is_sourcefileloader:
  description: "multiprocessing.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — multiprocessing.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars); multiprocessing is loaded from Lib/multiprocessing/__init__.py using the standard SourceFileLoader; this is the same loader as concurrent.futures (both are .py file loaded packages); multiprocessing.__loader__.__class__.__name__.__len__()==16; multiprocessing.__package__=='multiprocessing' (len=15); multiprocessing.__spec__.name=='multiprocessing' (len=15); NEW in extra147: first standalone multiprocessing loader class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.__loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant multiprocessing_extra147.mp_process_dict_len_7:
  description: "multiprocessing.Process.__dict__.__len__() == 7 — multiprocessing.Process.__dict__ has 7 entries (a mappingproxy of the Process class namespace); multiprocessing.Process is a context-bound proxy class created in multiprocessing.context (not the full implementation); the actual base class is multiprocessing.process.BaseProcess which contains the full implementation; Process in the context module overrides only __module__ and a few other attributes, delegating implementation to BaseProcess; multiprocessing.Process.__module__=='multiprocessing.context' (len=23); multiprocessing.Process.__name__=='Process' (len=7); contrast with Pool.__dict__.__len__()==42 (far more method-rich); NEW in extra147: first standalone multiprocessing.Process __dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__len__
  args: []
  expected: 7

invariant multiprocessing_extra147.mp_pool_dict_len_42:
  description: "multiprocessing.pool.Pool.__dict__.__len__() == 42 — multiprocessing.pool.Pool.__dict__ has 42 entries (a mappingproxy of the Pool class namespace); Pool is the most method-rich class in this spec with 42 entries; Pool provides a rich API for parallel execution: synchronous methods (map, apply, starmap), asynchronous variants (map_async, apply_async, starmap_async), iteration (imap, imap_unordered), lifecycle management (close, terminate, join), and context manager support (__enter__, __exit__); multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20); contrast with Process at 7, JoinableQueue at 10, SimpleQueue at 14, Queue at 28; NEW in extra147: first standalone multiprocessing.pool.Pool __dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__dict__.__len__
  args: []
  expected: 42

invariant multiprocessing_extra147.mp_queue_dict_len_28:
  description: "multiprocessing.queues.Queue.__dict__.__len__() == 28 — multiprocessing.queues.Queue.__dict__ has 28 entries (a mappingproxy of the Queue class namespace); Queue provides inter-process communication with a full API: put(), get(), qsize(), empty(), full(), put_nowait(), get_nowait(), close(), join_thread(), cancel_join_thread(), __getstate__, __setstate__, and internal implementation helpers; multiprocessing.queues.Queue.__module__=='multiprocessing.queues' (len=22); contrast with JoinableQueue (subclass) at 10 entries (10 additional entries on top of Queue's inheritance) and SimpleQueue at 14 entries (a simpler implementation); NEW in extra147: first standalone multiprocessing.queues.Queue __dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.Queue.__dict__.__len__
  args: []
  expected: 28

invariant multiprocessing_extra147.mp_process_module_len_23:
  description: "multiprocessing.Process.__module__.__len__() == 23 — multiprocessing.Process.__module__ is 'multiprocessing.context' (23 chars: 'multiprocessing'=15+'.'=1+'context'=7=23); the context module is where Process proxy classes are defined for each start method (spawn, fork, forkserver); multiprocessing.Process is the Process class bound to the platform's default start method; the actual implementation lives in multiprocessing.process.BaseProcess; multiprocessing.Process.__name__=='Process' (len=7); multiprocessing.Process.__dict__.__len__()==7; NEW in extra147: first standalone multiprocessing.Process __module__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__module__.__len__
  args: []
  expected: 23

invariant multiprocessing_extra147.mp_joinablequeue_dict_len_10:
  description: "multiprocessing.queues.JoinableQueue.__dict__.__len__() == 10 — multiprocessing.queues.JoinableQueue.__dict__ has 10 entries (a mappingproxy of the JoinableQueue class namespace); JoinableQueue subclasses Queue and adds task_done() and join() methods (plus associated state for counting unfinished tasks); the 10 entries are JoinableQueue-specific additions on top of Queue's 28-entry __dict__ (inherited entries are not in JoinableQueue.__dict__); multiprocessing.queues.SimpleQueue.__dict__.__len__()==14 (SimpleQueue has a completely separate implementation, not subclassing Queue); NEW in extra147: first standalone multiprocessing.queues.JoinableQueue __dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.JoinableQueue.__dict__.__len__
  args: []
  expected: 10
