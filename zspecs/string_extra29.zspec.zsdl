spec: string_extra29
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/string.py"
    - "string_extra28.zspec.zsdl — covers __mro__.__len__() for Formatter (2) and Template (2); __bases__[0].__name__.__len__() for both ('object', 6); string constant __len__() for printable/digits/hexdigits/ascii_letters/ascii_lowercase/ascii_uppercase/octdigits/punctuation/whitespace; printable.__class__.__name__.__len__()==3; Template.__init__.__qualname__.__len__()==17."
    - "string_extra27.zspec.zsdl — covers Formatter method __qualname__.__len__() for all major methods; Template.substitute/__qualname__.__len__()==19; Template.safe_substitute/__qualname__.__len__()==24; capwords/__qualname__.__len__()==8."
    - "string_extra26.zspec.zsdl — covers Template/Formatter __module__.__len__()/__name__.__len__()/__qualname__.__len__(), __bases__[0].__name__, Template method __qualname__ equality checks."
  notes:
    - "This spec extends string_extra28.zspec.zsdl."
    - "Prior specs covered: Template/Formatter __name__/__module__/__qualname__/__mro__/__bases__[0].__name__ lengths, all string constant __len__() values, all major Template/Formatter method __qualname__.__len__() values, capwords/__qualname__/__name__/__module__ lengths."
    - "This spec covers NEW angles: string.__all__.__len__()==12; string.__all__.__class__.__name__=='list' (len 4); string.Formatter.__dict__.__class__.__name__=='mappingproxy' (len 12) and same for Template; Template.pattern.__class__.__name__=='Pattern' (len 7); Template.delimiter.__class__.__name__=='str' (len 3) and __len__()==1; Template.idpattern.__class__.__name__=='str' (len 3) and __len__()==21; capwords.__name__.__len__()==8; string constant __class__.__name__.__len__()==3 for ascii_letters/digits."
    - "string.__all__.__len__() == 12 — 12 public names exported. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.__all__.__class__.__name__ == 'list' (len 4). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.Formatter.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Same for Template. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.Template.pattern.__class__.__name__ == 'Pattern' (len 7) — compiled regex pattern object. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.Template.delimiter == '$' (__len__()==1). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.Template.delimiter.__class__.__name__ == 'str' (len 3). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.Template.idpattern.__len__() == 21 — '(?a:[_a-z][_a-z0-9]*)' has 21 characters. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.Template.idpattern.__class__.__name__ == 'str' (len 3). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.capwords.__name__.__len__() == 8 — 'capwords' has 8 characters. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.ascii_letters.__class__.__name__.__len__() == 3 — 'str'. Same for digits. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# string.__all__.__len__() and __all__.__class__.__name__.__len__()
#
# No prior spec checks __all__.__len__() or __all__.__class__.__name__ for
# the string module. string.__all__ exports 12 public names and is a list.
# ---------------------------------------------------------------------------

invariant string_extra29.all.len:
  description: "string.__all__.__len__() == 12 — 12 public names exported"
  category: module_membership
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 12

invariant string_extra29.all.class.name.len:
  description: "string.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list'"
  category: module_membership
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Template class attribute types: pattern, delimiter, idpattern
#
# No prior spec checks the class names or lengths of Template class-level
# attribute values. Template.pattern is a compiled re.Pattern (class name
# 'Pattern', len 7). Template.delimiter is '$' (str, len 1).
# Template.idpattern is the raw regex string (str, len 21).
# ---------------------------------------------------------------------------

invariant string_extra29.Template.pattern.class.name.len:
  description: "string.Template.pattern.__class__.__name__.__len__() == 7 — Template.pattern is a 'Pattern'"
  category: module_constants
  kind: python_call_eq
  function: Template.pattern.__class__.__name__.__len__
  args: []
  expected: 7

invariant string_extra29.Template.delimiter.len:
  description: "string.Template.delimiter.__len__() == 1 — delimiter is '$' (one character)"
  category: module_constants
  kind: python_call_eq
  function: Template.delimiter.__len__
  args: []
  expected: 1

invariant string_extra29.Template.delimiter.class.name.len:
  description: "string.Template.delimiter.__class__.__name__.__len__() == 3 — delimiter is a 'str'"
  category: module_constants
  kind: python_call_eq
  function: Template.delimiter.__class__.__name__.__len__
  args: []
  expected: 3

invariant string_extra29.Template.idpattern.len:
  description: "string.Template.idpattern.__len__() == 21 — idpattern '(?a:[_a-z][_a-z0-9]*)' has 21 characters"
  category: module_constants
  kind: python_call_eq
  function: Template.idpattern.__len__
  args: []
  expected: 21

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__() for Formatter and Template
#
# No prior spec checks __dict__.__class__.__name__.__len__() for any string
# class. Both Formatter and Template expose their namespace via a mappingproxy
# (len 12).
# ---------------------------------------------------------------------------

invariant string_extra29.Formatter.dict.class.name.len:
  description: "string.Formatter.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy'"
  category: module_constants
  kind: python_call_eq
  function: Formatter.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant string_extra29.Template.dict.class.name.len:
  description: "string.Template.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy'"
  category: module_constants
  kind: python_call_eq
  function: Template.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Table: string.__all__ membership and Template attribute type checks
#
# Groups __all__ membership checks and Template class-attribute type/length
# measurements. No prior spec groups these together.
# ---------------------------------------------------------------------------

table string_extra29.all_and_template_attrs:
  description: "string.__all__.__len__() (12), __all__.__class__.__name__.__len__() (4), Template.pattern class name len (7), Template.delimiter len (1) and class name len (3), Template.idpattern len (21)"
  kind: python_call_eq
  category: module_membership

  columns: [id, function, args, expected, description]
  rows:
    - [all_len,
       __all__.__len__,
       [],
       12,
       "len(string.__all__) == 12"]
    - [all_class_name_len,
       __all__.__class__.__name__.__len__,
       [],
       4,
       "len('list') == 4 — __all__.__class__.__name__"]
    - [Template_pattern_class_name_len,
       Template.pattern.__class__.__name__.__len__,
       [],
       7,
       "len('Pattern') == 7 — Template.pattern.__class__.__name__"]
    - [Template_delimiter_len,
       Template.delimiter.__len__,
       [],
       1,
       "len('$') == 1 — Template.delimiter"]
    - [Template_delimiter_class_name_len,
       Template.delimiter.__class__.__name__.__len__,
       [],
       3,
       "len('str') == 3 — Template.delimiter.__class__.__name__"]
    - [Template_idpattern_len,
       Template.idpattern.__len__,
       [],
       21,
       "len('(?a:[_a-z][_a-z0-9]*)') == 21 — Template.idpattern"]

# ---------------------------------------------------------------------------
# Table: class __dict__ type name lengths and string constant class names
#
# Groups Formatter/Template __dict__.__class__.__name__.__len__() and the
# __class__.__name__.__len__() for string constant types. No prior spec covers
# __dict__.__class__.__name__.__len__() for either string class, or
# __class__.__name__.__len__() for ascii_letters/digits.
# capwords.__name__.__len__()==8 also included for function name coverage.
# ---------------------------------------------------------------------------

table string_extra29.dict_class_and_constant_types:
  description: "string Formatter/Template __dict__.__class__.__name__.__len__() (both 12), ascii_letters/__class__.__name__.__len__() (3), digits/__class__.__name__.__len__() (3), capwords/__name__.__len__() (8)"
  kind: python_call_eq
  category: module_constants

  columns: [id, function, args, expected, description]
  rows:
    - [Formatter_dict_class_name_len,
       Formatter.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — Formatter.__dict__.__class__.__name__"]
    - [Template_dict_class_name_len,
       Template.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — Template.__dict__.__class__.__name__"]
    - [ascii_letters_class_name_len,
       ascii_letters.__class__.__name__.__len__,
       [],
       3,
       "len('str') == 3 — ascii_letters.__class__.__name__"]
    - [digits_class_name_len,
       digits.__class__.__name__.__len__,
       [],
       3,
       "len('str') == 3 — digits.__class__.__name__"]
    - [Template_idpattern_class_name_len,
       Template.idpattern.__class__.__name__.__len__,
       [],
       3,
       "len('str') == 3 — Template.idpattern.__class__.__name__"]
    - [capwords_name_len,
       capwords.__name__.__len__,
       [],
       8,
       "len('capwords') == 8 — capwords.__name__"]
