spec: threading_extra194
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Timer.__name__ == 'Timer' (len=5); Timer is a pure-Python class in threading.py for delayed execution; verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' (len=9); defined in the threading standard library module; verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' (len=6); Timer inherits directly from Thread; verified with Python 3.14.3."
    - "threading.Timer.__init__.__qualname__ == 'Timer.__init__' (len=14); __init__ method qualified name carries the class prefix; verified with Python 3.14.3."
    - "threading.Timer.run.__qualname__ == 'Timer.run' (len=9); run is the method that executes the timer function; verified with Python 3.14.3."
    - "threading.Timer.cancel.__qualname__ == 'Timer.cancel' (len=12); cancel stops the timer if it has not yet fired; verified with Python 3.14.3."
    - "threading.Thread.__name__ == 'Thread' (len=6); Thread is the primary threading class in threading.py; verified with Python 3.14.3."
    - "threading.Thread.__bases__[0].__name__ == 'object' (len=6); Thread inherits directly from object; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

