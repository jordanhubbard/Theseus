spec: ntpath_extra
version: ">=3.0"
backend: python_module(ntpath)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path / ntpath documentation"
    - "Test vectors verified by running Python 3.14.3 ntpath module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ntpath.py"
  notes:
    - "This spec covers ntpath behaviors not present in ntpath.zspec.zsdl."
    - "ntpath.join.__module__ == 'ntpath' confirms the function is defined directly in ntpath."
    - "exists.__name__ and abspath.__name__ are omitted from ntpath.zspec.zsdl and added here."
    - "The join('C:\\\\Users', 'test.txt') vector uses a realistic Windows-style path."
    - "basename and dirname on 'C:\\\\Users\\\\test.txt' confirm single-level extraction."
    - "isabs('C:\\\\Users') returns True because the path has both a drive letter and a root backslash."
    - "isabs('Users\\\\test') returns False because the path has no leading drive or backslash root."
    - "All expected values verified by running Python 3.14.3 ntpath module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity
# ---------------------------------------------------------------------------

invariant ntpath_extra.module.join_module:
  description: "ntpath.join.__module__ == 'ntpath'"
  category: module
  kind: python_call_eq
  function: join.__module__.__eq__
  args: ["ntpath"]
  expected: true

# ---------------------------------------------------------------------------
# Additional function name checks not in ntpath.zspec.zsdl
# ---------------------------------------------------------------------------

invariant ntpath_extra.function_names.exists:
  description: "ntpath.exists.__name__ == 'exists'"
  category: function_names
  kind: python_call_eq
  function: exists.__name__.__eq__
  args: ["exists"]
  expected: true

invariant ntpath_extra.function_names.abspath:
  description: "ntpath.abspath.__name__ == 'abspath'"
  category: function_names
  kind: python_call_eq
  function: abspath.__name__.__eq__
  args: ["abspath"]
  expected: true

# ---------------------------------------------------------------------------
# join — realistic Windows path joining
# ---------------------------------------------------------------------------

invariant ntpath_extra.join.users_dir:
  description: "ntpath.join('C:\\\\Users', 'test.txt') == 'C:\\\\Users\\\\test.txt'"
  category: join
  kind: python_call_eq
  function: join
  args: ["C:\\Users", "test.txt"]
  expected: "C:\\Users\\test.txt"

# ---------------------------------------------------------------------------
# basename — last component of Windows path
# ---------------------------------------------------------------------------

invariant ntpath_extra.basename.simple_file:
  description: "ntpath.basename('C:\\\\Users\\\\test.txt') == 'test.txt'"
  category: basename
  kind: python_call_eq
  function: basename
  args: ["C:\\Users\\test.txt"]
  expected: "test.txt"

# ---------------------------------------------------------------------------
# dirname — parent directory of Windows path
# ---------------------------------------------------------------------------

invariant ntpath_extra.dirname.users_dir:
  description: "ntpath.dirname('C:\\\\Users\\\\test.txt') == 'C:\\\\Users'"
  category: dirname
  kind: python_call_eq
  function: dirname
  args: ["C:\\Users\\test.txt"]
  expected: "C:\\Users"

# ---------------------------------------------------------------------------
# isabs — absolute path detection
# ---------------------------------------------------------------------------

invariant ntpath_extra.isabs.drive_rooted:
  description: "ntpath.isabs('C:\\\\Users') == True — drive-rooted path is absolute"
  category: isabs
  kind: python_call_eq
  function: isabs
  args: ["C:\\Users"]
  expected: true

invariant ntpath_extra.isabs.relative_subdir:
  description: "ntpath.isabs('Users\\\\test') == False — path without drive/root is relative"
  category: isabs
  kind: python_call_eq
  function: isabs
  args: ["Users\\test"]
  expected: false
