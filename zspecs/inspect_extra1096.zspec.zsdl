spec: inspect_extra1096
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks isbuiltin/isfunction class and module identity, signature/getsourcefile/getfile/findsource/indentsize qualname and module not already in _extra976/_extra991"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1096.isbuiltin_isfunction_identity:
  description: "inspect.isbuiltin and inspect.isfunction class and module identity"
  kind: python_call_eq
  category: isbuiltin_isfunction_identity
  id_prefix: ip1096if
  columns: [id, function, args, expected]
  rows:
    - [ip1096if001, inspect.isbuiltin.__class__.__name__.__eq__,                ["function"],                         true]
    - [ip1096if002, inspect.isbuiltin.__module__.__eq__,                        ["inspect"],                          true]
    - [ip1096if003, inspect.isbuiltin.__doc__.__class__.__name__.__eq__,        ["str"],                              true]
    - [ip1096if004, inspect.isfunction.__class__.__name__.__eq__,               ["function"],                         true]
    - [ip1096if005, inspect.isfunction.__module__.__eq__,                       ["inspect"],                          true]
    - [ip1096if006, inspect.isfunction.__doc__.__class__.__name__.__eq__,       ["str"],                              true]
    - [ip1096if007, inspect.isclass.__class__.__name__.__eq__,                  ["function"],                         true]
    - [ip1096if008, inspect.isclass.__module__.__eq__,                          ["inspect"],                          true]

table inspect_extra1096.signature_getsourcefile_module:
  description: "inspect.signature and inspect.getsourcefile module and class identity"
  kind: python_call_eq
  category: signature_getsourcefile_module
  id_prefix: ip1096sg
  columns: [id, function, args, expected]
  rows:
    - [ip1096sg001, inspect.signature.__module__.__eq__,                        ["inspect"],                          true]
    - [ip1096sg002, inspect.signature.__class__.__name__.__eq__,                ["function"],                         true]
    - [ip1096sg003, inspect.signature.__doc__.__class__.__name__.__eq__,        ["str"],                              true]
    - [ip1096sg004, inspect.getsourcefile.__qualname__.__eq__,                  ["getsourcefile"],                    true]
    - [ip1096sg005, inspect.getsourcefile.__module__.__eq__,                    ["inspect"],                          true]
    - [ip1096sg006, inspect.getsourcefile.__class__.__name__.__eq__,            ["function"],                         true]
    - [ip1096sg007, inspect.getfile.__qualname__.__eq__,                        ["getfile"],                          true]
    - [ip1096sg008, inspect.getfile.__module__.__eq__,                          ["inspect"],                          true]

table inspect_extra1096.findsource_indentsize_module:
  description: "inspect.findsource and inspect.indentsize module and class identity not covered in _extra976"
  kind: python_call_eq
  category: findsource_indentsize_module
  id_prefix: ip1096fi
  columns: [id, function, args, expected]
  rows:
    - [ip1096fi001, inspect.findsource.__qualname__.__eq__,                     ["findsource"],                       true]
    - [ip1096fi002, inspect.findsource.__module__.__eq__,                       ["inspect"],                          true]
    - [ip1096fi003, inspect.findsource.__class__.__name__.__eq__,               ["function"],                         true]
    - [ip1096fi004, inspect.findsource.__doc__.__class__.__name__.__eq__,       ["NoneType"],                         true]
    - [ip1096fi005, inspect.indentsize.__module__.__eq__,                       ["inspect"],                          true]
    - [ip1096fi006, inspect.indentsize.__class__.__name__.__eq__,               ["function"],                         true]
    - [ip1096fi007, inspect.getfile.__class__.__name__.__eq__,                  ["function"],                         true]
    - [ip1096fi008, inspect.getfile.__doc__.__class__.__name__.__eq__,          ["str"],                              true]
