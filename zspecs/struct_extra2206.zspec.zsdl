spec: struct_extra2206
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/struct.html"
    - "CPython source: Modules/_struct.c"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2206: rich comparison operator protocol dict-presence — __lt__, __le__, __gt__, __ge__, __eq__, __ne__."
    - "struct.Struct is a C extension type for compiled binary format strings. It defines none of the rich comparison operators in its own __dict__. Struct instances are not orderable or equality-comparable as objects."
    - "struct.error is a plain Exception subclass. It defines none of the rich comparison operators in its own __dict__."
    - "struct.Struct.__dict__ contains: format, size, pack, unpack, pack_into, unpack_from, iter_unpack."
    - "struct.error.__dict__ is nearly empty; it inherits all behavior from Exception."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2206.Struct_rich_comparison_protocol:
  description: "struct.Struct rich comparison operator protocol dict-presence — Struct defines none of __lt__, __le__, __gt__, __ge__, __eq__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2206

  columns: [id, function, args, expected]
  rows:
    - ["st2206001", "struct.Struct.__dict__.__contains__", ["__lt__"], false]
    - ["st2206002", "struct.Struct.__dict__.__contains__", ["__le__"], false]
    - ["st2206003", "struct.Struct.__dict__.__contains__", ["__gt__"], false]
    - ["st2206004", "struct.Struct.__dict__.__contains__", ["__ge__"], false]
    - ["st2206005", "struct.Struct.__dict__.__contains__", ["__eq__"], false]
    - ["st2206006", "struct.Struct.__dict__.__contains__", ["__ne__"], false]

table struct_extra2206.error_rich_comparison_protocol:
  description: "struct.error rich comparison operator protocol dict-presence — error is a plain Exception subclass and defines none of __lt__, __le__, __gt__, __ge__, __eq__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2206

  columns: [id, function, args, expected]
  rows:
    - ["st2206007", "struct.error.__dict__.__contains__", ["__lt__"], false]
    - ["st2206008", "struct.error.__dict__.__contains__", ["__le__"], false]
    - ["st2206009", "struct.error.__dict__.__contains__", ["__gt__"], false]
    - ["st2206010", "struct.error.__dict__.__contains__", ["__ge__"], false]
    - ["st2206011", "struct.error.__dict__.__contains__", ["__eq__"], false]
    - ["st2206012", "struct.error.__dict__.__contains__", ["__ne__"], false]

