    - ["cf3406004", operator.contains, [concurrent.futures.Future.__dict__,              "__str__"], false]
    - ["cf3406005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__str__"], false]
    - ["cf3406006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__str__"], false]

# ---------------------------------------------------------------------------
# __repr__ dict-presence — operator.contains(Cls.__dict__, '__repr__')
#
# All 3 concurrent.futures classes return false for __repr__.
# repr() delegates to __repr__ when defined in the class's own __dict__.
# concurrent.futures types do not define a Python-level __repr__ in their
#   own __dict__; repr output falls back to inherited or C-level mechanisms.
# concurrent.futures.Future: repr(future) is not defined in Future.__dict__;
#   the result handle exposes state through done()/result()/exception()
#   methods, not through a custom __repr__ entry in its class __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor: pool lifecycle managers with no
#   __repr__ defined in their own __dict__.
# ---------------------------------------------------------------------------

table cf3406.repr:
  description: "concurrent.futures types __repr__ dict-presence checks; wave 674"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3406

  columns: [id, function, args, expected]
  rows:
    - ["cf3406007", operator.contains, [concurrent.futures.Future.__dict__,              "__repr__"], false]
    - ["cf3406008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__repr__"], false]
    - ["cf3406009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__repr__"], false]

# ---------------------------------------------------------------------------
# combined — __bool__, __str__, __repr__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __bool__: false for all 3 — truth-value protocol not in own __dict__.
# __str__: false for all 3 — string conversion not in own __dict__.
# __repr__: false for all 3 — repr not in own __dict__.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire
#   public surface is method-based: submit(), map(), result(), cancel(),
#   done(), running(), cancelled(), add_done_callback(), shutdown(). Waves
#   658–673 established that no arithmetic, bitwise, reflected, in-place
#   augmented assignment, unary numeric, rounding, or numeric conversion
#   operator appears anywhere in the concurrent.futures type hierarchy.
#   The display protocol dunders tested here follow the same pattern.
# concurrent.futures.Future note: despite the name, Future is a state-machine
#   result handle — not a numeric or display-customized type. __bool__, __str__,
#   and __repr__ are all absent from its __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate a
#   pool of worker threads or processes; they expose only lifecycle and dispatch
#   methods. No display protocol overloads are defined in their __dict__.
# ---------------------------------------------------------------------------

table cf3406.combined:
  description: "concurrent.futures types combined __bool__/__str__/__repr__; wave 674"
