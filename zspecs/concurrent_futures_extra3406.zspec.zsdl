    - ["cf3406011", operator.contains, [concurrent.futures.Future.__dict__,              "__str__"],   false]
    - ["cf3406012", operator.contains, [concurrent.futures.Future.__dict__,              "__repr__"],  false]
    - ["cf3406013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__bool__"],  false]
    - ["cf3406014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__str__"],   false]
    - ["cf3406015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__repr__"],  false]
    - ["cf3406016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__bool__"],  false]
    - ["cf3406017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__str__"],   false]
    - ["cf3406018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__repr__"],  false]
