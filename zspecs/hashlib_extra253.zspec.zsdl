spec: hashlib_extra253
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra252.zspec.zsdl — covers SHA-3 digest_size values / BLAKE2 identity and digest_size / SHAKE variable-length output (table + invariants)."
    - "hashlib_extra251.zspec.zsdl — covers algorithms_guaranteed.__contains__ for md5/sha1/sha256/sha3_256/blake2b / algorithms_guaranteed type identity / len==14 (table + invariants)."
  notes:
    - "Wave 295 theme: hashlib module-level function identity — new, pbkdf2_hmac, scrypt — and _hashlib.HASH method identity."
    - "hashlib.new.__name__ == '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__name__ == 'scrypt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.scrypt.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5(b'')).__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5(b'')).__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5(b'')).update.__name__ == 'update'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5(b'')).digest.__name__ == 'digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5(b'')).hexdigest.__name__ == 'hexdigest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.md5(b'')).copy.__name__ == 'copy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.new is a pure Python function defined in Lib/hashlib.py as __hash_new (the internal wrapper that dispatches to OpenSSL or pure-Python backends). Its __name__ is '__hash_new' (not 'new') because the module re-exports it as 'new'. Its __module__ is 'hashlib' (pure Python). This contrasts with pbkdf2_hmac and scrypt which are C builtins from Modules/_hashlib.c with __module__=='_hashlib'."
    - "Note: The _hashlib.HASH type is the C extension type for hash objects produced by OpenSSL-backed constructors (md5, sha1, sha256, etc. on macOS). Its methods (update, digest, hexdigest, copy) are method_descriptors. The HASH type is accessible as type(hashlib.md5(b'')) or directly as _hashlib.HASH."
    - "Note: hashlib.scrypt is a password-based key derivation function using the scrypt algorithm (RFC 7914). It is only available when the underlying OpenSSL supports it (True on macOS/Python 3.14.3). Its __class__.__name__ is 'builtin_function_or_method' (C builtin from _hashlib)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module-level function identity: new, pbkdf2_hmac, scrypt
#
# Wave 295 theme: hashlib.new / pbkdf2_hmac / scrypt function __name__ and
# __class__.__name__ identity.
#
# hashlib.new is a pure Python function re-exported from Lib/hashlib.py; its
# internal name is '__hash_new' (not 'new'). pbkdf2_hmac and scrypt are C
# builtins from Modules/_hashlib.c with __module__=='_hashlib' and
# __class__.__name__=='builtin_function_or_method'. No prior spec anchors
# these three functions together in a grouped identity table under hashlibid295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra253.module_function_identity:
  description: "new.__name__.__eq__('__hash_new')==True / new.__module__.__eq__('hashlib')==True / new.__class__.__name__.__eq__('function')==True / pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac')==True / pbkdf2_hmac.__module__.__eq__('_hashlib')==True / pbkdf2_hmac.__class__.__name__.__eq__('builtin_function_or_method')==True / scrypt.__name__.__eq__('scrypt')==True / scrypt.__module__.__eq__('_hashlib')==True / scrypt.__class__.__name__.__eq__('builtin_function_or_method')==True — hashlib.new is a pure Python wrapper (name=='__hash_new'); pbkdf2_hmac and scrypt are C builtins from _hashlib; first hashlibid295 anchor for these three function identities"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibid295

  columns: [id, function, args, expected, description]
  rows:
    - [new_name_eq,              "new.__name__.__eq__",                         ["__hash_new"],               true, "hashlib.new.__name__ is '__hash_new' (internal name of the Python wrapper in Lib/hashlib.py)"]
    - [new_module_eq,            "new.__module__.__eq__",                       ["hashlib"],                  true, "hashlib.new.__module__ is 'hashlib' (pure Python function defined in Lib/hashlib.py)"]
    - [new_class_eq,             "new.__class__.__name__.__eq__",               ["function"],                 true, "hashlib.new.__class__.__name__ is 'function' (pure Python, not C builtin)"]
    - [pbkdf2_name_eq,           "pbkdf2_hmac.__name__.__eq__",                 ["pbkdf2_hmac"],              true, "hashlib.pbkdf2_hmac.__name__ is 'pbkdf2_hmac' (C builtin in _hashlib)"]
    - [pbkdf2_module_eq,         "pbkdf2_hmac.__module__.__eq__",               ["_hashlib"],                 true, "hashlib.pbkdf2_hmac.__module__ is '_hashlib' (C extension, not 'hashlib' Python wrapper)"]
    - [pbkdf2_class_eq,          "pbkdf2_hmac.__class__.__name__.__eq__",       ["builtin_function_or_method"], true, "hashlib.pbkdf2_hmac.__class__.__name__ is 'builtin_function_or_method' (C builtin)"]
    - [scrypt_name_eq,           "scrypt.__name__.__eq__",                      ["scrypt"],                   true, "hashlib.scrypt.__name__ is 'scrypt' (C builtin in _hashlib; RFC 7914 KDF)"]
    - [scrypt_module_eq,         "scrypt.__module__.__eq__",                    ["_hashlib"],                 true, "hashlib.scrypt.__module__ is '_hashlib' (C extension; requires OpenSSL support)"]
    - [scrypt_class_eq,          "scrypt.__class__.__name__.__eq__",            ["builtin_function_or_method"], true, "hashlib.scrypt.__class__.__name__ is 'builtin_function_or_method' (C builtin)"]

# ---------------------------------------------------------------------------
# _hashlib.HASH method identity: update, digest, hexdigest, copy
#
# Wave 295 theme: _hashlib.HASH method __name__ and __class__.__name__.
#
# The _hashlib.HASH type (accessible as type(hashlib.md5(b''))) is the C
# extension type for OpenSSL-backed hash objects. Its methods are
# method_descriptors. update() appends data to the hash; digest() and
# hexdigest() return the hash value as bytes or hex string; copy() returns a
# clone of the hash object. The HASH type name is 'HASH' and module is
# '_hashlib'. No prior spec anchors these four method names together in a
# grouped table under hashlibid295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra253.HASH_method_identity:
  description: "md5(b'').update.__name__.__eq__('update')==True / md5(b'').digest.__name__.__eq__('digest')==True / md5(b'').hexdigest.__name__.__eq__('hexdigest')==True / md5(b'').copy.__name__.__eq__('copy')==True / md5(b'').update.__class__.__name__.__eq__('method_descriptor')==True / md5(b'').digest.__class__.__name__.__eq__('method_descriptor')==True — _hashlib.HASH methods are method_descriptors; update() appends data; digest() returns bytes; hexdigest() returns hex str; copy() clones the hash state; first hashlibid295 anchor for HASH method identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: hashlibid295

  columns: [id, function, args, expected, description]
  rows:
    - [hash_update_name_eq,        "md5(b'').update.__name__.__eq__",            ["update"],            true, "HASH.update.__name__ is 'update' (appends data to the running hash)"]
    - [hash_digest_name_eq,        "md5(b'').digest.__name__.__eq__",            ["digest"],            true, "HASH.digest.__name__ is 'digest' (returns hash value as bytes object)"]
    - [hash_hexdigest_name_eq,     "md5(b'').hexdigest.__name__.__eq__",         ["hexdigest"],         true, "HASH.hexdigest.__name__ is 'hexdigest' (returns hash value as hex string)"]
    - [hash_copy_name_eq,          "md5(b'').copy.__name__.__eq__",              ["copy"],              true, "HASH.copy.__name__ is 'copy' (returns a clone of the hash object with current state)"]
    - [hash_update_class_eq,       "md5(b'').update.__class__.__name__.__eq__",  ["method_descriptor"], true, "HASH.update.__class__.__name__ is 'method_descriptor' (C method on the HASH type)"]
    - [hash_hexdigest_class_eq,    "md5(b'').hexdigest.__class__.__name__.__eq__", ["method_descriptor"], true, "HASH.hexdigest.__class__.__name__ is 'method_descriptor' (C method on the HASH type)"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') — standalone
#
# hashlib.pbkdf2_hmac.__name__ is 'pbkdf2_hmac'. pbkdf2_hmac is a
# Password-Based Key Derivation Function 2 (PKCS#5 v2.0) using HMAC as the
# pseudorandom function. It is a C builtin from Modules/_hashlib.c with
# __module__=='_hashlib'. pbkdf2_hmac(hash_name, password, salt, iterations,
# dklen=None) — a common choice is sha256 with 600000+ iterations per OWASP
# recommendations. No prior spec anchors pbkdf2_hmac.__name__ as a standalone
# under hashlibid295. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra253.pbkdf2_hmac_name_eq:
  description: "hashlib.pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac') == True — pbkdf2_hmac is PKCS#5 v2.0 PBKDF2 using HMAC; C builtin from _hashlib.c; __module__=='_hashlib'; takes hash_name/password/salt/iterations/dklen; OWASP recommends sha256 with 600000+ iterations; __class__.__name__=='builtin_function_or_method'; no prior spec anchors pbkdf2_hmac.__name__ as standalone; first standalone under hashlibid295"
  category: function_identity
  kind: python_call_eq
  function: "pbkdf2_hmac.__name__.__eq__"
  args: ["pbkdf2_hmac"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.scrypt.__module__.__eq__('_hashlib') — standalone
#
# hashlib.scrypt.__module__ is '_hashlib'. scrypt is a memory-hard password-
# based key derivation function defined in RFC 7914. It is a C builtin from
# Modules/_hashlib.c. scrypt(password, salt, n, r, p, maxmem=0, dklen=64)
# requires n (CPU/memory cost), r (block size), p (parallelization). It is
# more memory-hard than PBKDF2 and bcrypt, making it more resistant to
# GPU-based attacks. Only available when OpenSSL supports it. No prior spec
# anchors scrypt.__module__ as a standalone under hashlibid295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra253.scrypt_module_eq:
  description: "hashlib.scrypt.__module__.__eq__('_hashlib') == True — scrypt is a memory-hard KDF (RFC 7914); C builtin from _hashlib.c; __module__=='_hashlib' (not 'hashlib'); requires OpenSSL support; more memory-hard than PBKDF2/bcrypt; parameters: password, salt, n (cost), r (block), p (parallelism); __class__.__name__=='builtin_function_or_method'; no prior spec anchors scrypt.__module__ as standalone; first standalone under hashlibid295"
  category: function_identity
  kind: python_call_eq
  function: "scrypt.__module__.__eq__"
  args: ["_hashlib"]
  expected: true
