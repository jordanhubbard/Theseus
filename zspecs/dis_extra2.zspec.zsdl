spec: dis_extra2
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/dis.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: internal bytecode implementation (compile.c, ceval.c)"
    - "dis.zspec.zsdl — covers class __name__ checks for Instruction/Bytecode, function __name__ checks for dis/disassemble/code_info/show_code/get_instructions/stack_effect, opname class/length, opmap contains/value checks for LOAD_FAST/POP_TOP, stack_effect values, haslocal/hasname class and non-empty checks"
    - "dis_extra.zspec.zsdl — covers dis.__name__ (module name), distb/__name__, findlinestarts/__name__, findlabels/__name__, disassemble/__name__, code_info/__name__, show_code/__name__, get_instructions/__name__, stack_effect/__name__, Instruction.__name__, Instruction.__module__, opname.__class__.__name__, opmap.__class__.__name__, HAVE_ARGUMENT.__class__.__name__"
  notes:
    - "This spec covers __module__ attributes for dis functions and classes — not previously covered."
    - "dis.dis.__module__ == 'dis' — the dis() function is defined in the dis module."
    - "dis.disassemble.__module__ == 'dis' — disassemble() is defined in the dis module."
    - "dis.get_instructions.__module__ == 'dis' — get_instructions() is defined in the dis module."
    - "dis.findlinestarts.__module__ == 'dis' — findlinestarts() is defined in the dis module."
    - "dis.findlabels.__module__ == 'dis' — findlabels() is defined in the dis module."
    - "dis.code_info.__module__ == 'dis' — code_info() is defined in the dis module."
    - "dis.Instruction.__module__ == 'dis' — also confirmed in dis_extra; included here per task spec."
    - "dis.Instruction.__name__ == 'Instruction' — also confirmed in dis.zspec.zsdl; included here per task spec."
    - "dis.Bytecode.__name__ == 'Bytecode' — also confirmed in dis.zspec.zsdl; included here per task spec."
    - "dis.Bytecode.__module__ == 'dis' — Bytecode class is defined in the dis module."
    - "dis.Bytecode.__bases__[0].__name__ == 'object' — Bytecode inherits directly from object."
    - "dis.Instruction.__bases__[0].__name__ == 'tuple' — Instruction is a named tuple backed by tuple."
    - "dis.opname.__class__.__name__ == 'list' — also in dis_extra; included here per task spec."
    - "dis.opmap.__class__.__name__ == 'dict' — also in dis_extra; included here per task spec."
    - "dis.HAVE_ARGUMENT.__class__.__name__ == 'int' — also in dis_extra; included here per task spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks for dis functions
# ---------------------------------------------------------------------------

table dis_extra2.function_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [dis_fn,          dis.__module__.__eq__,            ["dis"], true]
    - [disassemble,     disassemble.__module__.__eq__,    ["dis"], true]
    - [get_instructions, get_instructions.__module__.__eq__, ["dis"], true]
    - [findlinestarts,  findlinestarts.__module__.__eq__, ["dis"], true]
    - [findlabels,      findlabels.__module__.__eq__,     ["dis"], true]
    - [code_info,       code_info.__module__.__eq__,      ["dis"], true]

# ---------------------------------------------------------------------------
# Instruction class — __name__ and __module__
# ---------------------------------------------------------------------------

invariant dis_extra2.Instruction.name:
  description: "dis.Instruction.__name__ == 'Instruction'"
  category: instruction
  kind: python_call_eq
  function: Instruction.__name__.__eq__
  args: ["Instruction"]
  expected: true

invariant dis_extra2.Instruction.module:
  description: "dis.Instruction.__module__ == 'dis'"
  category: instruction
  kind: python_call_eq
  function: Instruction.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra2.Instruction.base_is_tuple:
  description: "dis.Instruction.__bases__[0].__name__ == 'tuple' — Instruction is a named tuple backed by tuple"
  category: hierarchy
  kind: python_call_eq
  function: Instruction.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# Bytecode class — __name__, __module__, and base class
# ---------------------------------------------------------------------------

invariant dis_extra2.Bytecode.name:
  description: "dis.Bytecode.__name__ == 'Bytecode'"
  category: bytecode
  kind: python_call_eq
  function: Bytecode.__name__.__eq__
  args: ["Bytecode"]
  expected: true

invariant dis_extra2.Bytecode.module:
  description: "dis.Bytecode.__module__ == 'dis'"
  category: bytecode
  kind: python_call_eq
  function: Bytecode.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra2.Bytecode.base_is_object:
  description: "dis.Bytecode.__bases__[0].__name__ == 'object' — Bytecode inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: Bytecode.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# opname — class check
# ---------------------------------------------------------------------------

invariant dis_extra2.opname.class_name:
  description: "dis.opname.__class__.__name__ == 'list'"
  category: opname
  kind: python_call_eq
  function: opname.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# opmap — class check
# ---------------------------------------------------------------------------

invariant dis_extra2.opmap.class_name:
  description: "dis.opmap.__class__.__name__ == 'dict'"
  category: opmap
  kind: python_call_eq
  function: opmap.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# HAVE_ARGUMENT — integer constant class check
# ---------------------------------------------------------------------------

invariant dis_extra2.HAVE_ARGUMENT.class_name:
  description: "dis.HAVE_ARGUMENT.__class__.__name__ == 'int'"
  category: have_argument
  kind: python_call_eq
  function: HAVE_ARGUMENT.__class__.__name__.__eq__
  args: ["int"]
  expected: true
