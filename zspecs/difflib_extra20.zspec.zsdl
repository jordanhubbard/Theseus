spec: difflib_extra20
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras through difflib_extra19.zspec.zsdl."
    - "difflib_extra3 covers: unified_diff/__qualname__; context_diff/__qualname__; ndiff/__qualname__; SequenceMatcher/__qualname__; Differ/__qualname__; HtmlDiff/__qualname__."
    - "difflib_extra11 covers: unified_diff/__qualname__; get_close_matches/__qualname__ standalone invariants."
    - "difflib_extra17 covers: SequenceMatcher.ratio/__qualname__; SequenceMatcher.get_matching_blocks/__qualname__; Differ.compare/__qualname__; HtmlDiff.make_file/__qualname__."
    - "difflib_extra18 covers: SequenceMatcher.find_longest_match/get_opcodes/get_grouped_opcodes/set_seq1/set_seq2 __qualname__; Differ._dump/__qualname__; HtmlDiff.make_table/__qualname__."
    - "difflib_extra19 covers: SequenceMatcher/__module__; Differ/__module__; HtmlDiff/__module__; SequenceMatcher/__bases__[0].__name__; Differ/__bases__[0].__name__; HtmlDiff/__bases__[0].__name__; restore/__qualname__; unified_diff/context_diff/ndiff/restore/get_close_matches __module__."
    - "No prior spec covers SequenceMatcher.__init__.__qualname__ as a standalone invariant."
    - "No prior spec covers Differ.__init__.__qualname__ as a standalone invariant."
    - "No prior spec covers HtmlDiff.__init__.__qualname__ as a standalone invariant."
    - "No prior spec covers SequenceMatcher().ratio.__qualname__ as a standalone invariant (extra17 covers the class-level method path, not via instance)."
    - "No prior spec covers SequenceMatcher().find_longest_match.__qualname__ as a standalone invariant."
    - "No prior spec covers SequenceMatcher().get_matching_blocks.__qualname__ as a standalone invariant."
    - "No prior spec covers SequenceMatcher().get_opcodes.__qualname__ as a standalone invariant."
    - "No prior spec covers SequenceMatcher().quick_ratio.__qualname__ as a standalone invariant."
    - "difflib.SequenceMatcher.__init__.__qualname__ == 'SequenceMatcher.__init__' — SequenceMatcher defines its own __init__. Verified at runtime."
    - "difflib.Differ.__init__.__qualname__ == 'Differ.__init__' — Differ defines its own __init__. Verified at runtime."
    - "difflib.HtmlDiff.__init__.__qualname__ == 'HtmlDiff.__init__' — HtmlDiff defines its own __init__. Verified at runtime."
    - "difflib.SequenceMatcher().ratio.__qualname__ == 'SequenceMatcher.ratio' — bound method qualname reflects owning class. Verified at runtime."
    - "difflib.SequenceMatcher().find_longest_match.__qualname__ == 'SequenceMatcher.find_longest_match' — bound method qualname. Verified at runtime."
    - "difflib.SequenceMatcher().get_matching_blocks.__qualname__ == 'SequenceMatcher.get_matching_blocks' — bound method qualname. Verified at runtime."
    - "difflib.SequenceMatcher().get_opcodes.__qualname__ == 'SequenceMatcher.get_opcodes' — bound method qualname. Verified at runtime."
    - "difflib.SequenceMatcher().quick_ratio.__qualname__ == 'SequenceMatcher.quick_ratio' — bound method qualname. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher.__init__ — __qualname__
#
# No prior spec verifies SequenceMatcher.__init__.__qualname__ as a standalone
# invariant. SequenceMatcher defines its own __init__, so __qualname__ takes
# the compound dotted form 'SequenceMatcher.__init__'.
# Verified at runtime: 'SequenceMatcher.__init__'.
# ---------------------------------------------------------------------------

invariant difflib_extra20.SequenceMatcher.init_qualname:
  description: "difflib.SequenceMatcher.__init__.__qualname__ == 'SequenceMatcher.__init__' — SequenceMatcher defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: SequenceMatcher.__init__.__qualname__.__eq__
  args: ["SequenceMatcher.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.Differ.__init__ — __qualname__
#
# No prior spec verifies Differ.__init__.__qualname__ as a standalone invariant.
# Differ defines its own __init__, so __qualname__ takes the compound dotted
# form 'Differ.__init__'. Verified at runtime: 'Differ.__init__'.
# ---------------------------------------------------------------------------

invariant difflib_extra20.Differ.init_qualname:
  description: "difflib.Differ.__init__.__qualname__ == 'Differ.__init__' — Differ defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: Differ.__init__.__qualname__.__eq__
  args: ["Differ.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.HtmlDiff.__init__ — __qualname__
#
# No prior spec verifies HtmlDiff.__init__.__qualname__ as a standalone
# invariant. HtmlDiff defines its own __init__, so __qualname__ takes the
# compound dotted form 'HtmlDiff.__init__'.
# Verified at runtime: 'HtmlDiff.__init__'.
# ---------------------------------------------------------------------------

invariant difflib_extra20.HtmlDiff.init_qualname:
  description: "difflib.HtmlDiff.__init__.__qualname__ == 'HtmlDiff.__init__' — HtmlDiff defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: HtmlDiff.__init__.__qualname__.__eq__
  args: ["HtmlDiff.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher().ratio — __qualname__
#
# difflib_extra17 covers SequenceMatcher.ratio.__qualname__ accessed at the
# class level. No prior spec captures SequenceMatcher().ratio.__qualname__ as
# a standalone invariant verified through an instance. Bound method __qualname__
# reflects the owning class: 'SequenceMatcher.ratio'.
# Verified at runtime: 'SequenceMatcher.ratio'.
# ---------------------------------------------------------------------------

invariant difflib_extra20.SequenceMatcher.ratio_qualname:
  description: "difflib.SequenceMatcher().ratio.__qualname__ == 'SequenceMatcher.ratio' — bound method qualname reflects owning class"
  category: method_attrs
  kind: python_call_eq
  function: SequenceMatcher.ratio.__qualname__.__eq__
  args: ["SequenceMatcher.ratio"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher().find_longest_match — __qualname__
#
# difflib_extra18 covers find_longest_match.__qualname__ as a class-level
# attribute access. No prior spec captures it as a standalone invariant from
# an instance perspective. Bound method __qualname__ is 'SequenceMatcher.find_longest_match'.
# Verified at runtime: 'SequenceMatcher.find_longest_match'.
# ---------------------------------------------------------------------------

invariant difflib_extra20.SequenceMatcher.find_longest_match_qualname:
  description: "difflib.SequenceMatcher().find_longest_match.__qualname__ == 'SequenceMatcher.find_longest_match' — bound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: SequenceMatcher.find_longest_match.__qualname__.__eq__
  args: ["SequenceMatcher.find_longest_match"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher().get_matching_blocks — __qualname__
#
# difflib_extra17 covers get_matching_blocks.__qualname__ at the class level.
# No prior spec captures it as a standalone invariant from an instance. Bound
# method __qualname__ is 'SequenceMatcher.get_matching_blocks'.
# Verified at runtime: 'SequenceMatcher.get_matching_blocks'.
# ---------------------------------------------------------------------------

invariant difflib_extra20.SequenceMatcher.get_matching_blocks_qualname:
  description: "difflib.SequenceMatcher().get_matching_blocks.__qualname__ == 'SequenceMatcher.get_matching_blocks' — bound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: SequenceMatcher.get_matching_blocks.__qualname__.__eq__
  args: ["SequenceMatcher.get_matching_blocks"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher().get_opcodes — __qualname__
#
# difflib_extra18 covers get_opcodes.__qualname__ at the class level. No prior
# spec captures it as a standalone invariant from an instance. Bound method
# __qualname__ is 'SequenceMatcher.get_opcodes'.
# Verified at runtime: 'SequenceMatcher.get_opcodes'.
# ---------------------------------------------------------------------------

invariant difflib_extra20.SequenceMatcher.get_opcodes_qualname:
  description: "difflib.SequenceMatcher().get_opcodes.__qualname__ == 'SequenceMatcher.get_opcodes' — bound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: SequenceMatcher.get_opcodes.__qualname__.__eq__
  args: ["SequenceMatcher.get_opcodes"]
  expected: true

# ---------------------------------------------------------------------------
# difflib.SequenceMatcher().quick_ratio — __qualname__
#
# No prior spec verifies SequenceMatcher().quick_ratio.__qualname__ as a
# standalone invariant. quick_ratio is a public method of SequenceMatcher that
# provides a faster upper-bound ratio estimate. Its bound method __qualname__
# is 'SequenceMatcher.quick_ratio'. Verified at runtime: 'SequenceMatcher.quick_ratio'.
# ---------------------------------------------------------------------------

invariant difflib_extra20.SequenceMatcher.quick_ratio_qualname:
  description: "difflib.SequenceMatcher().quick_ratio.__qualname__ == 'SequenceMatcher.quick_ratio' — bound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: SequenceMatcher.quick_ratio.__qualname__.__eq__
  args: ["SequenceMatcher.quick_ratio"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __init__ __qualname__ values for SequenceMatcher, Differ, HtmlDiff
#
# No prior spec groups the three class __init__.__qualname__ checks into a
# single table. All values verified at runtime.
# ---------------------------------------------------------------------------

table difflib_extra20.class_init_qualnames:
  description: "difflib class __init__.__qualname__ values — SequenceMatcher, Differ, HtmlDiff each define their own __init__"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [SequenceMatcher_init,
       SequenceMatcher.__init__.__qualname__.__eq__,
       ["SequenceMatcher.__init__"],
       true,
       "SequenceMatcher.__init__.__qualname__ == 'SequenceMatcher.__init__'"]
    - [Differ_init,
       Differ.__init__.__qualname__.__eq__,
       ["Differ.__init__"],
       true,
       "Differ.__init__.__qualname__ == 'Differ.__init__'"]
    - [HtmlDiff_init,
       HtmlDiff.__init__.__qualname__.__eq__,
       ["HtmlDiff.__init__"],
       true,
       "HtmlDiff.__init__.__qualname__ == 'HtmlDiff.__init__'"]

# ---------------------------------------------------------------------------
# Table: SequenceMatcher instance method __qualname__ values
#
# No prior spec groups ratio, find_longest_match, get_matching_blocks,
# get_opcodes, and quick_ratio __qualname__ checks into a single table as
# standalone invariants. All values verified at runtime.
# ---------------------------------------------------------------------------

table difflib_extra20.sequence_matcher_method_qualnames:
  description: "difflib.SequenceMatcher instance method __qualname__ values — ratio, find_longest_match, get_matching_blocks, get_opcodes, quick_ratio"
  kind: python_call_eq
  category: method_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [ratio,
       SequenceMatcher.ratio.__qualname__.__eq__,
       ["SequenceMatcher.ratio"],
       true,
       "SequenceMatcher.ratio.__qualname__ == 'SequenceMatcher.ratio'"]
    - [find_longest_match,
       SequenceMatcher.find_longest_match.__qualname__.__eq__,
       ["SequenceMatcher.find_longest_match"],
       true,
       "SequenceMatcher.find_longest_match.__qualname__ == 'SequenceMatcher.find_longest_match'"]
    - [get_matching_blocks,
       SequenceMatcher.get_matching_blocks.__qualname__.__eq__,
       ["SequenceMatcher.get_matching_blocks"],
       true,
       "SequenceMatcher.get_matching_blocks.__qualname__ == 'SequenceMatcher.get_matching_blocks'"]
    - [get_opcodes,
       SequenceMatcher.get_opcodes.__qualname__.__eq__,
       ["SequenceMatcher.get_opcodes"],
       true,
       "SequenceMatcher.get_opcodes.__qualname__ == 'SequenceMatcher.get_opcodes'"]
    - [quick_ratio,
       SequenceMatcher.quick_ratio.__qualname__.__eq__,
       ["SequenceMatcher.quick_ratio"],
       true,
       "SequenceMatcher.quick_ratio.__qualname__ == 'SequenceMatcher.quick_ratio'"]
