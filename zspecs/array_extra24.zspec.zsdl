spec: array_extra24
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array.zspec.zsdl — baseline typecode, itemsize, and instance vectors."
    - "array_extra4.zspec.zsdl — covers array.array.__qualname__ == 'array'."
    - "array_extra5.zspec.zsdl — covers array.ArrayType.__qualname__ == 'array'."
    - "array_extra19.zspec.zsdl — covers array.ArrayType.__qualname__.__len__() == 5."
    - "array_extra21.zspec.zsdl — covers __qualname__ for append/extend/pop/insert/remove/reverse/tolist/tobytes/frombytes."
    - "array_extra22.zspec.zsdl — covers __qualname__ for buffer_info/byteswap/index; array.array.__qualname__; array.ArrayType.__qualname__; typecodes type check."
    - "array_extra23.zspec.zsdl — covers __qualname__ for count/fromlist/fromfile/tofile/__len__/__iter__."
  notes:
    - "This spec extends array_extra23.zspec.zsdl."
    - "Focus: __qualname__ for operator-protocol dunder methods __add__/__contains__/__repr__/__eq__/__mul__/__setitem__/__getitem__/__delitem__ — none covered in prior specs."
    - "Also: module-level __name__ and __package__ attributes; __qualname__.__len__() for several of the new methods."
    - "array.array.__add__.__qualname__ == 'array.__add__' — arithmetic operator method. Verified."
    - "array.array.__contains__.__qualname__ == 'array.__contains__' — membership test. Verified."
    - "array.array.__repr__.__qualname__ == 'array.__repr__' — string representation method. Verified."
    - "array.array.__eq__.__qualname__ == 'array.__eq__' — equality comparison method. Verified."
    - "array.array.__mul__.__qualname__ == 'array.__mul__' — multiplication operator method. Verified."
    - "array.array.__getitem__.__qualname__ == 'array.__getitem__' — item access method. Verified."
    - "array.array.__setitem__.__qualname__ == 'array.__setitem__' — item assignment method. Verified."
    - "array.array.__delitem__.__qualname__ == 'array.__delitem__' — item deletion method. Verified."
    - "array.__name__ == 'array' — module-level __name__ attribute. Verified."
    - "array.__package__ == '' — top-level module has empty package string. Verified."
    - "len('array.__add__') == 13, len('array.__contains__') == 18, len('array.__repr__') == 14, len('array.__eq__') == 12. All verified."
    - "len('array.__getitem__') == 17, len('array.__setitem__') == 17, len('array.__delitem__') == 17. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ for array.array operator-protocol dunder methods
#
# Prior specs (extra21/22/23) cover: append, extend, pop, insert, remove,
# reverse, tolist, tobytes, frombytes, buffer_info, byteswap, index,
# count, fromlist, fromfile, tofile, __len__, __iter__.
# No prior spec covers __qualname__ for __add__, __contains__, __repr__,
# __eq__, __mul__, __getitem__, __setitem__, __delitem__.
# These are operator-protocol methods implementing Python's data model.
# Under python_module(array), 'array.__add__.__qualname__.__eq__' resolves as
# array_module.array.__add__.__qualname__.__eq__.
# Verified: all have qualname of the form 'array.<method_name>'.
# ---------------------------------------------------------------------------

table array_extra24.operator_method_qualnames:
  description: "array.array operator-protocol dunder __qualname__ values — not covered in prior specs"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aqn24

  columns: [id, function, args, expected]
  rows:
    - [add,      "array.__add__.__qualname__.__eq__",      ["array.__add__"],      true]
    - [contains, "array.__contains__.__qualname__.__eq__", ["array.__contains__"], true]
    - [repr,     "array.__repr__.__qualname__.__eq__",     ["array.__repr__"],     true]
    - [eq,       "array.__eq__.__qualname__.__eq__",       ["array.__eq__"],       true]
    - [mul,      "array.__mul__.__qualname__.__eq__",      ["array.__mul__"],      true]
    - [getitem,  "array.__getitem__.__qualname__.__eq__",  ["array.__getitem__"],  true]
    - [setitem,  "array.__setitem__.__qualname__.__eq__",  ["array.__setitem__"],  true]
    - [delitem,  "array.__delitem__.__qualname__.__eq__",  ["array.__delitem__"],  true]

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for operator dunder methods
#
# No prior spec covers qualname string lengths for any of these dunder methods.
# Length checks provide an independent cross-validation axis.
# Verified: __add__=13, __contains__=18, __repr__=14, __eq__=12,
#   __mul__=13, __getitem__=17, __setitem__=17, __delitem__=17.
# ---------------------------------------------------------------------------

table array_extra24.operator_method_qualname_lengths:
  description: "array.array operator dunder __qualname__.__len__() — length cross-checks"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aqlen24

  columns: [id, function, args, expected]
  rows:
    - [add,      "array.__add__.__qualname__.__len__",      [], 13]
    - [contains, "array.__contains__.__qualname__.__len__", [], 18]
    - [repr,     "array.__repr__.__qualname__.__len__",     [], 14]
    - [eq,       "array.__eq__.__qualname__.__len__",       [], 12]
    - [mul,      "array.__mul__.__qualname__.__len__",      [], 13]
    - [getitem,  "array.__getitem__.__qualname__.__len__",  [], 17]
    - [setitem,  "array.__setitem__.__qualname__.__len__",  [], 17]
    - [delitem,  "array.__delitem__.__qualname__.__len__",  [], 17]

# ---------------------------------------------------------------------------
# Table: array module-level __name__ and __package__ attributes
#
# No prior array spec checks array.__name__ or array.__package__ as
# module-level attributes (value and class). These parallel the pattern
# used in glob_extra15 for the glob module and struct_extra19 for struct.
# array.__name__ == 'array', array.__package__ == '' (top-level module).
# Verified: __name__='array' (class='str', len=5), __package__='' (class='str', len=0).
# ---------------------------------------------------------------------------

table array_extra24.module_dunder_attrs:
  description: "array module __name__ and __package__ value and class checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: mda24

  columns: [id, function, args, expected]
  rows:
    - [name_value,    "__name__.__eq__",                     ["array"], true]
    - [name_class,    "__name__.__class__.__name__.__eq__",  ["str"],   true]
    - [name_len,      "__name__.__len__",                    [],        5]
    - [pkg_value,     "__package__.__eq__",                  [""],      true]
    - [pkg_class,     "__package__.__class__.__name__.__eq__", ["str"], true]
    - [pkg_len,       "__package__.__len__",                 [],        0]

# ---------------------------------------------------------------------------
# Standalone: array.array.__add__.__qualname__ == 'array.__add__'
#
# __add__ implements the + operator for array objects. No prior array spec
# covers any arithmetic operator dunder's __qualname__. This standalone
# invariant anchors the first arithmetic operator method for direct lookup
# in the extra24 namespace.
# Verified: array.array.__add__.__qualname__ == 'array.__add__'
# ---------------------------------------------------------------------------

invariant array_extra24.array.add_qualname:
  description: "array.array.__add__.__qualname__ == 'array.__add__' — arithmetic operator method qualname includes class prefix"
  category: method_qualnames
  kind: python_call_eq
  function: "array.__add__.__qualname__.__eq__"
  args: ["array.__add__"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: array.array.__contains__.__qualname__ == 'array.__contains__'
#
# __contains__ implements the `in` membership test for array objects.
# No prior spec covers __contains__.__qualname__. With length 18 it is the
# longest qualname in the operator methods table.
# Verified: array.array.__contains__.__qualname__ == 'array.__contains__'
# ---------------------------------------------------------------------------

invariant array_extra24.array.contains_qualname:
  description: "array.array.__contains__.__qualname__ == 'array.__contains__' — membership test method; longest operator dunder qualname (len=18)"
  category: method_qualnames
  kind: python_call_eq
  function: "array.__contains__.__qualname__.__eq__"
  args: ["array.__contains__"]
  expected: true
