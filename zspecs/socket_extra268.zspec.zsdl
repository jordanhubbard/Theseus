spec: socket_extra268
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra267.zspec.zsdl — covers socket.getfqdn/gethostname/getnameinfo/getservbyname/getservbyport/htons/htonl/ntohs/ntohl function identity."
    - "socket_extra266.zspec.zsdl — covers socket.socket bind/listen/accept/connect/send/recv/close/shutdown/setsockopt/getsockopt method identity."
    - "socket_extra265.zspec.zsdl — covers socket module-level function identity."
  notes:
    - "socket.create_connection.__name__ == 'create_connection' — pure-Python function in Lib/socket.py (Python 3.0+). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.create_connection.__module__ == 'socket' — defined in Lib/socket.py (not _socket C extension). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.create_connection.__class__.__name__ == 'function' — pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.create_connection.__qualname__ == 'create_connection' — top-level function in module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.create_server.__name__ == 'create_server' — pure-Python function in Lib/socket.py (Python 3.8+). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.create_server.__module__ == 'socket' — defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.create_server.__class__.__name__ == 'function' — pure-Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.create_server.__qualname__ == 'create_server' — top-level function in module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socketpair.__name__ == 'socketpair' — pure-Python wrapper in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.fromfd.__name__ == 'fromfd' — pure-Python wrapper in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getaddrinfo.__name__ == 'getaddrinfo' — pure-Python wrapper in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.gethostbyaddr.__name__ == 'gethostbyaddr' — C builtin from _socket extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.gethostbyaddr.__class__.__name__ == 'builtin_function_or_method' — C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.create_connection and create_server function identity
# Both are pure-Python functions defined in Lib/socket.py.
# create_connection is available since Python 3.0; create_server since 3.8.
# ---------------------------------------------------------------------------

table socket_extra268.create_connection_create_server_names:
  description: "socket.create_connection/create_server __name__ identity — both pure-Python functions in Lib/socket.py; __name__ matches function name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockcreat268

  columns: [id, function, args, expected, description]
  rows:
    - [create_conn_name,   create_connection.__name__.__eq__,   ["create_connection"], true, "socket.create_connection.__name__ == 'create_connection' — pure-Python function in Lib/socket.py"]
    - [create_conn_mod,    create_connection.__module__.__eq__, ["socket"],             true, "socket.create_connection.__module__ == 'socket' — defined in Lib/socket.py not _socket C extension"]
    - [create_serv_name,   create_server.__name__.__eq__,       ["create_server"],      true, "socket.create_server.__name__ == 'create_server' — pure-Python function in Lib/socket.py (Python 3.8+)"]
    - [create_serv_mod,    create_server.__module__.__eq__,     ["socket"],             true, "socket.create_server.__module__ == 'socket' — defined in Lib/socket.py not _socket C extension"]
    - [create_conn_qual,   create_connection.__qualname__.__eq__, ["create_connection"], true, "socket.create_connection.__qualname__ == 'create_connection' — top-level function in module"]

# ---------------------------------------------------------------------------
# socket function __class__.__name__ identity
# create_connection, create_server, socketpair, fromfd, getaddrinfo are
# pure-Python 'function'; gethostbyaddr is a C 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

table socket_extra268.module_function_class_names:
  description: "socket function __class__.__name__ identity — create_connection/create_server/socketpair/fromfd/getaddrinfo are 'function'; gethostbyaddr is 'builtin_function_or_method'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockfcls268

  columns: [id, function, args, expected, description]
  rows:
    - [create_conn_class,  create_connection.__class__.__name__.__eq__,  ["function"], true, "socket.create_connection.__class__.__name__ == 'function' — pure-Python function in Lib/socket.py"]
    - [create_serv_class,  create_server.__class__.__name__.__eq__,      ["function"], true, "socket.create_server.__class__.__name__ == 'function' — pure-Python function in Lib/socket.py"]
    - [socketpair_class,   socketpair.__class__.__name__.__eq__,         ["function"], true, "socket.socketpair.__class__.__name__ == 'function' — pure-Python wrapper in Lib/socket.py"]
    - [fromfd_class,       fromfd.__class__.__name__.__eq__,             ["function"], true, "socket.fromfd.__class__.__name__ == 'function' — pure-Python wrapper in Lib/socket.py"]
    - [gethostbyaddr_class, gethostbyaddr.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "socket.gethostbyaddr.__class__.__name__ == 'builtin_function_or_method' — C builtin from _socket"]

# ---------------------------------------------------------------------------
# Standalone invariants — socket function identity properties
# ---------------------------------------------------------------------------

invariant socket_extra268.create_connection_qualname_eq:
  description: "socket.create_connection.__qualname__ == 'create_connection' — top-level function in socket module; qualname equals simple name; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: create_connection.__qualname__.__eq__
  args: ["create_connection"]
  expected: true

invariant socket_extra268.create_server_qualname_eq:
  description: "socket.create_server.__qualname__ == 'create_server' — top-level function in socket module; qualname equals simple name; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: create_server.__qualname__.__eq__
  args: ["create_server"]
  expected: true

invariant socket_extra268.create_server_module_eq:
  description: "socket.create_server.__module__ == 'socket' — create_server is a pure-Python function in Lib/socket.py; available since Python 3.8; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: create_server.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra268.socketpair_name_eq:
  description: "socket.socketpair.__name__ == 'socketpair' — pure-Python wrapper in Lib/socket.py; creates a pair of connected sockets; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: socketpair.__name__.__eq__
  args: ["socketpair"]
  expected: true

invariant socket_extra268.fromfd_name_eq:
  description: "socket.fromfd.__name__ == 'fromfd' — pure-Python wrapper in Lib/socket.py; creates a socket from an existing file descriptor; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: fromfd.__name__.__eq__
  args: ["fromfd"]
  expected: true

invariant socket_extra268.getaddrinfo_name_eq:
  description: "socket.getaddrinfo.__name__ == 'getaddrinfo' — pure-Python wrapper in Lib/socket.py; translates hostname/service to socket address structures; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: getaddrinfo.__name__.__eq__
  args: ["getaddrinfo"]
  expected: true

invariant socket_extra268.gethostbyaddr_name_eq:
  description: "socket.gethostbyaddr.__name__ == 'gethostbyaddr' — C builtin from _socket extension; returns hostname and address info for given address; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: gethostbyaddr.__name__.__eq__
  args: ["gethostbyaddr"]
  expected: true
