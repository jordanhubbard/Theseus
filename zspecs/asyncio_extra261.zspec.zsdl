# ---------------------------------------------------------------------------

invariant asyncio_extra261.all_tasks.__name__:
  description: "asyncio.all_tasks.__name__ == 'all_tasks'"
  category: identity
  kind: python_call_eq
  function: all_tasks.__name__.__eq__
  args: ["all_tasks"]
  expected: true

invariant asyncio_extra261.all_tasks.__qualname__:
  description: "asyncio.all_tasks.__qualname__ == 'all_tasks'"
  category: identity
  kind: python_call_eq
  function: all_tasks.__qualname__.__eq__
  args: ["all_tasks"]
  expected: true

invariant asyncio_extra261.all_tasks.__module__:
  description: "asyncio.all_tasks.__module__ == '_asyncio' — provided by the C accelerator"
  category: identity
  kind: python_call_eq
  function: all_tasks.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra261.all_tasks.__class__.__name__:
  description: "asyncio.all_tasks.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: all_tasks.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# Cross-function table: __name__ comparisons for all five functions
# ---------------------------------------------------------------------------

table asyncio_extra261.function_names:
  description: "All five asyncio concurrency functions report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: fname

  columns: [id, function, args, expected, description]
  rows:
    - [shield,       shield.__name__.__eq__,       ["shield"],       true, "asyncio.shield.__name__ == 'shield'"]
    - [timeout,      timeout.__name__.__eq__,      ["timeout"],      true, "asyncio.timeout.__name__ == 'timeout'"]
    - [timeout_at,   timeout_at.__name__.__eq__,   ["timeout_at"],   true, "asyncio.timeout_at.__name__ == 'timeout_at'"]
    - [current_task, current_task.__name__.__eq__,  ["current_task"], true, "asyncio.current_task.__name__ == 'current_task'"]
    - [all_tasks,    all_tasks.__name__.__eq__,     ["all_tasks"],    true, "asyncio.all_tasks.__name__ == 'all_tasks'"]

# ---------------------------------------------------------------------------
# Cross-function table: __class__.__name__ for all five functions
# ---------------------------------------------------------------------------

table asyncio_extra261.function_classes:
  description: "shield/timeout/timeout_at are Python functions; current_task/all_tasks are C builtins"
  kind: python_call_eq
  category: identity
  id_prefix: fcls

  columns: [id, function, args, expected, description]
  rows:
    - [shield,       shield.__class__.__name__.__eq__,       ["function"],                    true, "asyncio.shield is a Python function"]
    - [timeout,      timeout.__class__.__name__.__eq__,      ["function"],                    true, "asyncio.timeout is a Python function"]
    - [timeout_at,   timeout_at.__class__.__name__.__eq__,   ["function"],                    true, "asyncio.timeout_at is a Python function"]
    - [current_task, current_task.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "asyncio.current_task is a C builtin"]
    - [all_tasks,    all_tasks.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "asyncio.all_tasks is a C builtin"]
