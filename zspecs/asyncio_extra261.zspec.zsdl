  function: timeout.__module__.__eq__
  args: ["asyncio.timeouts"]
  expected: true

invariant asyncio_extra261.timeout.__class__.__name__:
  description: "asyncio.timeout.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
