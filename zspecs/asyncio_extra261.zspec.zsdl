spec: asyncio_extra261
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py, Lib/asyncio/timeouts.py"
  notes:
    - "asyncio.shield, asyncio.timeout, and asyncio.timeout_at are plain Python functions (class: function)."
    - "asyncio.current_task and asyncio.all_tasks are C builtins from the _asyncio accelerator module."
    - "asyncio.shield.__module__ == 'asyncio.tasks'; asyncio.timeout.__module__ == 'asyncio.timeouts'."
    - "asyncio.current_task.__module__ == '_asyncio'; asyncio.all_tasks.__module__ == '_asyncio'."
    - "asyncio.timeout_at is a distinct function from asyncio.timeout with its own __name__ 'timeout_at'."
    - "asyncio.all_tasks.__qualname__ == 'all_tasks' (top-level in C module, no class prefix)."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.shield — identity
# ---------------------------------------------------------------------------

invariant asyncio_extra261.shield.__name__:
  description: "asyncio.shield.__name__ == 'shield'"
  category: identity
  kind: python_call_eq
  function: shield.__name__.__eq__
  args: ["shield"]
  expected: true

invariant asyncio_extra261.shield.__qualname__:
  description: "asyncio.shield.__qualname__ == 'shield'"
  category: identity
  kind: python_call_eq
  function: shield.__qualname__.__eq__
  args: ["shield"]
  expected: true

invariant asyncio_extra261.shield.__module__:
  description: "asyncio.shield.__module__ == 'asyncio.tasks'"
  category: identity
  kind: python_call_eq
  function: shield.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra261.shield.__class__.__name__:
  description: "asyncio.shield.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: shield.__class__.__name__.__eq__
  args: ["function"]
  expected: true

