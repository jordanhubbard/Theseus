  description: "asyncio.timeout_at.__name__ == 'timeout_at'"
  category: identity
  kind: python_call_eq
  function: timeout_at.__name__.__eq__
  args: ["timeout_at"]
  expected: true

invariant asyncio_extra261.timeout_at.__qualname__:
  description: "asyncio.timeout_at.__qualname__ == 'timeout_at'"
  category: identity
  kind: python_call_eq
  function: timeout_at.__qualname__.__eq__
  args: ["timeout_at"]
  expected: true

invariant asyncio_extra261.timeout_at.__module__:
  description: "asyncio.timeout_at.__module__ == 'asyncio.timeouts'"
  category: identity
  kind: python_call_eq
  function: timeout_at.__module__.__eq__
  args: ["asyncio.timeouts"]
  expected: true

invariant asyncio_extra261.timeout_at.__class__.__name__:
  description: "asyncio.timeout_at.__class__.__name__ == 'function'"
  category: identity
