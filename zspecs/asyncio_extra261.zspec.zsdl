# ---------------------------------------------------------------------------
# asyncio.current_task — identity (C builtin)
# ---------------------------------------------------------------------------

invariant asyncio_extra261.current_task.__name__:
  description: "asyncio.current_task.__name__ == 'current_task'"
  category: identity
  kind: python_call_eq
  function: current_task.__name__.__eq__
  args: ["current_task"]
  expected: true

invariant asyncio_extra261.current_task.__qualname__:
  description: "asyncio.current_task.__qualname__ == 'current_task'"
  category: identity
  kind: python_call_eq
  function: current_task.__qualname__.__eq__
  args: ["current_task"]
  expected: true

invariant asyncio_extra261.current_task.__module__:
  description: "asyncio.current_task.__module__ == '_asyncio' — provided by the C accelerator"
  category: identity
  kind: python_call_eq
  function: current_task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra261.current_task.__class__.__name__:
  description: "asyncio.current_task.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: current_task.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

