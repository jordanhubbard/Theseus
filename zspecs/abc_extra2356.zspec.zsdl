spec: abc_extra2356
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes:
    - "Checks .__init__.__class__.__name__ and .__new__.__class__.__name__ for abc module classes"
    - "abc.ABC has no custom __init__ — inherits from object, class name is 'wrapper_descriptor'"
    - "abc.ABCMeta has no custom __init__ (inherits from type) — class name is 'wrapper_descriptor'"
    - "abc.ABCMeta defines custom __new__ — class name is 'function'"
    - "abc.abstractmethod.__init__ is a 'method-wrapper' (bound wrapper on a C instance)"
    - "All __new__ except ABCMeta.__new__ are 'builtin_function_or_method' (inherited from object/type)"
  created_at: "2026-04-12"
error_model: python_exceptions

table abc_extra2356.abc_class_init_type:
  description: "__init__ and __new__ implementation type for abc.ABC (no custom __init__)"
  kind: python_call_eq
  category: init_type
  id_prefix: ab2356
  columns: [id, function, args, expected]
  rows:
    - ["ab2356001", abc.ABC.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"],       true]
    - ["ab2356002", abc.ABC.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

table abc_extra2356.abcmeta_init_type:
  description: "__init__ and __new__ implementation type for abc.ABCMeta (metaclass)"
  kind: python_call_eq
  category: init_type
  id_prefix: ab2356
  columns: [id, function, args, expected]
  rows:
    - ["ab2356003", abc.ABCMeta.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - ["ab2356004", abc.ABCMeta.__new__.__class__.__name__.__eq__,  ["function"],           true]

table abc_extra2356.abstractmethod_init_type:
  description: "__init__ and __new__ implementation type for abc.abstractmethod (decorator class)"
  kind: python_call_eq
  category: init_type
  id_prefix: ab2356
  columns: [id, function, args, expected]
  rows:
    - ["ab2356005", abc.abstractmethod.__init__.__class__.__name__.__eq__, ["method-wrapper"],        true]
    - ["ab2356006", abc.abstractmethod.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

table abc_extra2356.init_type_contrast:
  description: "Cross-class contrast: each abc class has a distinct __init__ implementation type"
  kind: python_call_eq
  category: init_type
  id_prefix: ab2356
  columns: [id, function, args, expected]
  rows:
    - ["ab2356007",  abc.ABC.__init__.__class__.__name__.__eq__,            ["function"],          false]
    - ["ab2356008",  abc.ABC.__init__.__class__.__name__.__eq__,            ["method-wrapper"],    false]
    - ["ab2356009",  abc.ABCMeta.__init__.__class__.__name__.__eq__,        ["function"],          false]
    - ["ab2356010",  abc.ABCMeta.__init__.__class__.__name__.__eq__,        ["method-wrapper"],    false]
    - ["ab2356011",  abc.abstractmethod.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], false]
    - ["ab2356012",  abc.abstractmethod.__init__.__class__.__name__.__eq__, ["function"],          false]
    - ["ab2356013",  abc.ABCMeta.__new__.__class__.__name__.__eq__,         ["wrapper_descriptor"], false]
    - ["ab2356014",  abc.ABCMeta.__new__.__class__.__name__.__eq__,         ["builtin_function_or_method"], false]
    - ["ab2356015",  abc.ABC.__new__.__class__.__name__.__eq__,             ["function"],          false]
    - ["ab2356016",  abc.abstractmethod.__new__.__class__.__name__.__eq__,  ["function"],          false]

table abc_extra2356.new_type_affirmative:
  description: "Affirm correct __new__ class names for each abc class"
  kind: python_call_eq
  category: init_type
  id_prefix: ab2356
  columns: [id, function, args, expected]
  rows:
    - ["ab2356017",  abc.ABC.__new__.__class__.__name__.__eq__,             ["builtin_function_or_method"], true]
    - ["ab2356018",  abc.ABCMeta.__new__.__class__.__name__.__eq__,         ["function"],           true]
    - ["ab2356019",  abc.abstractmethod.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - ["ab2356020",  abc.ABC.__init__.__class__.__name__.__eq__,            ["wrapper_descriptor"], true]
    - ["ab2356021",  abc.ABCMeta.__init__.__class__.__name__.__eq__,        ["wrapper_descriptor"], true]
    - ["ab2356022",  abc.abstractmethod.__init__.__class__.__name__.__eq__, ["method-wrapper"],     true]
