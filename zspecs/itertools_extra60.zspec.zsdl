spec: itertools_extra60
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra59.zspec.zsdl."
    - "Wave 226 theme: __loader__ attribute chains (depth 2+): __loader__.__name__.__len__(), __loader__.__name__.__class__.__name__; __spec__.origin values; __spec__.submodule_search_locations checks; __version__ attribute presence/absence."
    - "itertools is a C builtin module (Modules/itertoolsmodule.c). Its __loader__ is the BuiltinImporter class itself (not an instance). Because __loader__ IS a class, it has a __name__ attribute directly: itertools.__loader__.__name__ == 'BuiltinImporter' (15 chars). extra59 checked __loader__.__name__.__eq__('BuiltinImporter') == True. Wave 226 adds the depth-2 chain: __loader__.__name__.__len__() == 15 and __loader__.__name__.__class__.__name__.__eq__('str') == True."
    - "itertools.__spec__.origin == 'built-in' (a str sentinel value, not a filesystem path). For C builtin modules compiled into the interpreter binary, the import system sets origin to the string 'built-in'. This differs from pure-Python modules (functools, inspect, threading) where origin is an absolute file path. extra59 checked __spec__.__class__.__name__.__eq__('ModuleSpec'). Wave 226 checks __spec__.origin.__eq__('built-in') directly."
    - "itertools.__spec__.submodule_search_locations is None — itertools is not a package, so there are no subpackage search paths. The NoneType check uses __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType'). This is new to extra60."
    - "itertools.__spec__.has_location is False — for built-in modules, has_location is False because there is no filesystem location associated with the module. This is new to extra60."
    - "itertools.__dict__.__contains__('__version__') is False — itertools does not expose a __version__ attribute. CPython stdlib C builtin modules are versioned with Python itself and do not define __version__ in their module namespace. This is new to extra60."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.__loader__.__name__ depth-2 chains — extra60
#
# Wave 226 theme: __loader__ attribute chains (depth 2+).
#
# itertools.__loader__ IS the BuiltinImporter class (not an instance).
# As a class, it has a __name__ attribute: itertools.__loader__.__name__ == 'BuiltinImporter'.
# extra59 checked __loader__.__name__.__eq__('BuiltinImporter') == True.
#
# Wave 226 adds two depth-2 chains:
# 1. __loader__.__name__.__len__() == 15
#    'BuiltinImporter' has 15 characters: B-u-i-l-t-i-n-I-m-p-o-r-t-e-r.
#    __len__() on a str returns the character count as a Python int.
#
# 2. __loader__.__name__.__class__.__name__.__eq__('str') == True
#    The class name string itself is a str object (not some other type).
#    This confirms the type of the __name__ attribute value.
#
# No prior itertools spec has table rows checking __loader__.__name__.__len__()
# or __loader__.__name__.__class__.__name__.__eq__('str'). Both are new to extra60.
# ---------------------------------------------------------------------------

table itertools_extra60.loader_name_depth2:
  description: "itertools.__loader__.__name__.__len__()==15 and __loader__.__name__.__class__.__name__.__eq__('str')==true — 'BuiltinImporter' is 15 chars and is a str; depth-2 chains beyond extra59's __eq__ check; wave 226 __loader__ depth-2 chains; new to extra60"
  kind: python_call_eq
  category: string_length
  id_prefix: itertspec60

  columns: [id, function, args, expected, description]
  rows:
    - [loader_name_len_eq_15,
       __loader__.__name__.__len__,
       [],
       15,
       "itertools.__loader__.__name__.__len__() == 15 — itertools.__loader__ is the _frozen_importlib.BuiltinImporter class itself (not an instance); as a class it has a __name__ attribute equal to 'BuiltinImporter'; the string 'BuiltinImporter' has exactly 15 characters (B-u-i-l-t-i-n-I-m-p-o-r-t-e-r); __len__() on a str returns the character count as a Python int; this is a depth-2 chain beyond extra59's __loader__.__name__.__eq__('BuiltinImporter') check; contrast with pure-Python modules where __loader__ is a SourceFileLoader instance with no __name__ (accessing loader class name requires __loader__.__class__.__name__ == 'SourceFileLoader', 16 chars); no prior itertools spec has a table row checking __loader__.__name__.__len__()==15; new to extra60"]
    - [loader_name_class_name_eq_str,
       __loader__.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.__loader__.__name__.__class__.__name__.__eq__('str') == True — itertools.__loader__.__name__ is the string 'BuiltinImporter'; as a Python str object, its __class__ is str and str.__name__ == 'str' (3 chars); this depth-3 chain confirms that the class name attribute of the BuiltinImporter class is indeed a str object (as expected — all Python class __name__ attributes are str objects); for pure-Python modules, the equivalent chain would be __loader__.__class__.__name__.__class__.__name__.__eq__('str') since the loader class name requires an extra indirection through __class__; no prior itertools spec has a table row checking __loader__.__name__.__class__.__name__.__eq__('str'); new to extra60"]

# ---------------------------------------------------------------------------
# itertools.__spec__.origin value check — extra60
#
# Wave 226 theme: __spec__.origin values.
#
# itertools.__spec__.origin == 'built-in' — a str sentinel value.
# For C builtin modules compiled into the CPython interpreter binary, the import
# system (BuiltinImporter) sets ModuleSpec.origin to the string 'built-in'.
# This is NOT a filesystem path — it is a conventional sentinel indicating that
# the module has no disk location.
#
# extra59 checked __spec__.__class__.__name__.__eq__('ModuleSpec') (the spec
# object class). Wave 226 checks __spec__.origin.__eq__('built-in') directly.
#
# Contrast with pure-Python modules (functools, inspect, threading) where
# __spec__.origin is an absolute filesystem path to the .py source file.
#
# No prior itertools spec has a table row checking __spec__.origin.__eq__('built-in').
# New to extra60.
# ---------------------------------------------------------------------------

table itertools_extra60.spec_origin_value:
  description: "itertools.__spec__.origin.__eq__('built-in')==true — C builtin modules have origin 'built-in' (not a file path); wave 226 __spec__.origin value check; new to extra60"
  kind: python_call_eq
  category: equality
  id_prefix: itertspec60

  columns: [id, function, args, expected, description]
  rows:
    - [spec_origin_eq_built_in,
       __spec__.origin.__eq__,
       ["built-in"],
       true,
       "itertools.__spec__.origin.__eq__('built-in') == True — itertools is a C builtin module compiled into the CPython interpreter binary (from Modules/itertoolsmodule.c); for such modules, the BuiltinImporter sets ModuleSpec.origin to the sentinel string 'built-in' rather than a filesystem path; this sentinel indicates that the module has no disk location and was compiled directly into the interpreter; contrast with pure-Python modules (functools, inspect, threading) where __spec__.origin is an absolute filesystem path (e.g., '/opt/homebrew/.../lib/python3.14/functools.py'); the 'built-in' sentinel is defined by CPython's importlib and is used consistently for all built-in modules; no prior itertools spec has a table row checking __spec__.origin.__eq__('built-in'); new to extra60"]

# ---------------------------------------------------------------------------
# itertools.__spec__.submodule_search_locations — NoneType check — extra60
#
# Wave 226 theme: __spec__.submodule_search_locations checks.
#
# itertools is a regular module, not a package. Its __spec__.submodule_search_locations
# is None. Packages have a non-None submodule_search_locations (a list-like object
# of search paths). Regular modules — whether pure-Python or C builtin — have
# submodule_search_locations == None.
#
# The check: __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType')
# — None.__class__ is NoneType, NoneType.__name__ == 'NoneType' (8 chars).
#
# No prior itertools spec has a table row checking __spec__.submodule_search_locations.
# New to extra60.
# ---------------------------------------------------------------------------

table itertools_extra60.spec_submodule_search_locations:
  description: "itertools.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType')==true — itertools is not a package, submodule_search_locations is None; wave 226 submodule_search_locations check; new to extra60"
  kind: python_call_eq
  category: class_identity
  id_prefix: itertspec60

  columns: [id, function, args, expected, description]
  rows:
    - [spec_submodule_search_locations_is_none,
       __spec__.submodule_search_locations.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "itertools.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — itertools is a regular C builtin module (not a package); Python packages (directories with __init__.py or namespace packages) set ModuleSpec.submodule_search_locations to a list-like object of filesystem paths enabling the import system to search for submodules; regular modules like itertools have submodule_search_locations == None; None.__class__ is the built-in NoneType and NoneType.__name__ == 'NoneType' (8 chars); this is consistent across both pure-Python non-package modules (functools, inspect, threading) and C builtin modules (itertools) — all have submodule_search_locations == None; no prior itertools spec has a table row checking __spec__.submodule_search_locations; new to extra60"]

# ---------------------------------------------------------------------------
# itertools.__spec__.has_location — False check — extra60
#
# Wave 226 theme: __spec__ attribute chains.
#
# itertools.__spec__.has_location is False — built-in modules have no disk
# location. The ModuleSpec.has_location property returns True only when the
# module's loader sets a location (i.e., has_location == True for modules
# loaded from the filesystem). For C builtin modules, has_location is False
# because the BuiltinImporter does not associate any filesystem location.
#
# Contrast with pure-Python modules (functools, inspect, threading) where
# __spec__.has_location is True (the source file is on disk).
#
# No prior itertools spec has a table row checking __spec__.has_location.
# New to extra60.
# ---------------------------------------------------------------------------

table itertools_extra60.spec_has_location:
  description: "itertools.__spec__.has_location.__eq__(False)==true — built-in modules have no filesystem location; wave 226 __spec__ attribute chain; new to extra60"
  kind: python_call_eq
  category: boolean
  id_prefix: itertspec60

  columns: [id, function, args, expected, description]
  rows:
    - [spec_has_location_eq_false,
       __spec__.has_location.__eq__,
       [false],
       true,
       "itertools.__spec__.has_location.__eq__(False) == True — itertools.__spec__.has_location is False; the ModuleSpec.has_location property is True for modules loaded from a filesystem location (pure-Python modules loaded by SourceFileLoader) and False for built-in modules loaded by BuiltinImporter (which have no disk location); itertools is a C builtin module compiled into the interpreter binary and has no filesystem origin; therefore has_location is False; contrast with functools, inspect, threading where __spec__.has_location is True because they are loaded from .py source files on disk; no prior itertools spec has a table row checking __spec__.has_location; new to extra60"]

# ---------------------------------------------------------------------------
# itertools.__dict__.__contains__('__version__') — extra60
#
# Wave 226 theme: __version__ attribute presence/absence.
#
# itertools does NOT define a __version__ attribute. CPython stdlib C builtin
# modules are versioned with Python itself and do not expose __version__ in
# their module namespace. itertools.__dict__.__contains__('__version__') is False.
#
# No prior itertools spec has a table row checking __dict__.__contains__('__version__').
# New to extra60.
# ---------------------------------------------------------------------------

table itertools_extra60.version_absence:
  description: "itertools.__dict__.__contains__('__version__')==false — itertools has no __version__ attribute; CPython stdlib C builtin modules do not define __version__; wave 226 __version__ presence/absence check; new to extra60"
  kind: python_call_eq
  category: membership
  id_prefix: itertspec60

  columns: [id, function, args, expected, description]
  rows:
    - [dict_not_contains_version,
       __dict__.__contains__,
       ["__version__"],
       false,
       "itertools.__dict__.__contains__('__version__') == False — itertools does not define a __version__ attribute in its module namespace; CPython stdlib C builtin modules (like itertools, sys, builtins) are versioned with Python itself and do not expose a standalone __version__ string; third-party packages typically define __version__ for use with importlib.metadata or direct attribute access, but stdlib modules rely on sys.version for version information; '__version__' is not a key in itertools.__dict__; no prior itertools spec has a table row checking __dict__.__contains__('__version__'); new to extra60"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra60
# ---------------------------------------------------------------------------

invariant itertools_extra60.loader_name_len_is_15:
  description: "itertools.__loader__.__name__.__len__() == 15 — 'BuiltinImporter' has 15 chars; depth-2 chain beyond extra59's __eq__ check; wave 226; new to extra60"
  kind: python_call_eq
  function: __loader__.__name__.__len__
  args: []
  expected: 15

invariant itertools_extra60.loader_name_class_name_is_str:
  description: "itertools.__loader__.__name__.__class__.__name__.__eq__('str') == True — the __name__ attribute of the BuiltinImporter class is a str object; wave 226 depth-2 chain; new to extra60"
  kind: python_call_eq
  function: __loader__.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra60.spec_origin_is_built_in:
  description: "itertools.__spec__.origin.__eq__('built-in') == True — C builtin modules have sentinel origin 'built-in' not a file path; wave 226 __spec__.origin check; new to extra60"
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["built-in"]
  expected: true

invariant itertools_extra60.spec_submodule_search_locations_is_NoneType:
  description: "itertools.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — itertools is not a package; submodule_search_locations is None; wave 226; new to extra60"
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant itertools_extra60.spec_has_location_is_false:
  description: "itertools.__spec__.has_location.__eq__(False) == True — built-in modules have no filesystem location; wave 226 has_location check; new to extra60"
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [false]
  expected: true

invariant itertools_extra60.no_version_in_dict:
  description: "itertools.__dict__.__contains__('__version__') == False — itertools has no __version__; CPython C builtin modules are versioned with Python itself; wave 226; new to extra60"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["__version__"]
  expected: false
