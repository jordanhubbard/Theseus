    - [abcmeta_ic_qn_len,  abc.ABCMeta.__instancecheck__.__qualname__.__len__,  [],                             25,   "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 ('ABCMeta.__instancecheck__'=25); verified Python 3.14.3"]
