table abc_extra193.abc_ABC_dunder_qualnames:
  description: "abc.ABC dunder method qualname checks in abcdunders193 namespace — ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21: 'ABC'=3+'.'=1+'__init_subclass__'=17=21; __init_subclass__ is a class method hook called when a class is subclassed; ABC defines it to coordinate with ABCMeta); ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20: 'ABC'=3+'.'=1+'__subclasshook__'=16=20; __subclasshook__ is a classmethod used to customize issubclass() checks; by default it returns NotImplemented); ABC.__init_subclass__.__qualname__ (21) > ABC.__subclasshook__.__qualname__ (20) by 1 — __init_subclass__ is one character longer than __subclasshook__; verified with Python 3.14.3"
  kind: python_call_eq
  category: abc_methods
  id_prefix: abcdunders193

  columns: [id, function, args, expected, description]
  rows:
    - [abc_init_sub_qn_eq,   abc.ABC.__init_subclass__.__qualname__.__eq__,   ["ABC.__init_subclass__"],  true, "abc.ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (len=21); verified Python 3.14.3"]
    - [abc_init_sub_qn_len,  abc.ABC.__init_subclass__.__qualname__.__len__,  [],                         21,   "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 ('ABC.__init_subclass__'=21); verified Python 3.14.3"]
    - [abc_hook_qn_eq,       abc.ABC.__subclasshook__.__qualname__.__eq__,    ["ABC.__subclasshook__"],   true, "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20); verified Python 3.14.3"]
    - [abc_hook_qn_len,      abc.ABC.__subclasshook__.__qualname__.__len__,   [],                         20,   "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 ('ABC.__subclasshook__'=20); verified Python 3.14.3"]
    - [abcmeta_reg_qn_eq,    abc.ABCMeta.register.__qualname__.__eq__,        ["ABCMeta.register"],       true, "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' (len=16); verified Python 3.14.3"]

