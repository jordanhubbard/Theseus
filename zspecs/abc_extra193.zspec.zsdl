# Length ordering: type.__init__ (13) < ABCMeta.__new__ (15) < ABCMeta.register (16)
#   < ABC.__subclasshook__ (20) < ABC.__init_subclass__ (21)
#   < ABCMeta.__instancecheck__ (25) == ABCMeta.__subclasscheck__ (25)
# ---------------------------------------------------------------------------

table abc_extra193.abc_ABCMeta_init_new_ordering:
  description: "abc.ABCMeta.__init__ and __new__ qualname checks and length ordering in abcdunders193 namespace — ABCMeta.__init__.__qualname__=='type.__init__' (len=13: 'type'=4+'.'=1+'__init__'=8=13; ABCMeta does NOT define __init__ — it inherits from type, so the qualname reflects type.__init__); ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15; ABCMeta defines its own __new__ to set up the abstract method infrastructure); length ordering confirmed: type.__init__ (13) < ABCMeta.__new__ (15) < ABCMeta.register (16) < ABC.__subclasshook__ (20) < ABC.__init_subclass__ (21) < ABCMeta.__instancecheck__ (25) == ABCMeta.__subclasscheck__ (25); verified with Python 3.14.3"
  kind: python_call_eq
  category: abcmeta_methods
  id_prefix: abcdunders193

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_init_qn_eq,  abc.ABCMeta.__init__.__qualname__.__eq__,  ["type.__init__"],    true, "abc.ABCMeta.__init__.__qualname__ == 'type.__init__' (len=13; inherited from type, not defined by ABCMeta); verified Python 3.14.3"]
    - [abcmeta_init_qn_len, abc.ABCMeta.__init__.__qualname__.__len__, [],                   13,   "abc.ABCMeta.__init__.__qualname__.__len__() == 13 ('type.__init__'=13; shortest qualname in spec); verified Python 3.14.3"]
    - [abcmeta_new_qn_eq,   abc.ABCMeta.__new__.__qualname__.__eq__,   ["ABCMeta.__new__"],  true, "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15; ABCMeta defines __new__ for abstract method setup); verified Python 3.14.3"]
    - [abcmeta_new_qn_len,  abc.ABCMeta.__new__.__qualname__.__len__,  [],                   15,   "abc.ABCMeta.__new__.__qualname__.__len__() == 15 ('ABCMeta.__new__'=15); verified Python 3.14.3"]
    - [abc_hook_qn_len2,    abc.ABC.__subclasshook__.__qualname__.__len__, [],                20,   "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 ('ABC.__subclasshook__'=20); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra193
# ---------------------------------------------------------------------------

invariant abc_extra193.abc_ABC_init_subclass_qualname_eq:
  description: "abc.ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__') returns True — __qualname__=='ABC.__init_subclass__' (len=21: 'ABC'=3+'.'=1+'__init_subclass__'=17=21); __init_subclass__ is called on the base class whenever a class is subclassed; ABC defines it to work with ABCMeta's abstract method tracking; ABC.__init_subclass__.__qualname__ (21) > ABC.__subclasshook__.__qualname__ (20) by 1; ABC.__init_subclass__.__qualname__ (21) < ABCMeta.__instancecheck__.__qualname__ (25) by 4; NEW in abcdunders193: first standalone ABC.__init_subclass__ qualname invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abc_methods
  kind: python_call_eq
  function: abc.ABC.__init_subclass__.__qualname__.__eq__
  args: ["ABC.__init_subclass__"]
  expected: true

invariant abc_extra193.abc_ABC_subclasshook_qualname_eq:
  description: "abc.ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__') returns True — __qualname__=='ABC.__subclasshook__' (len=20: 'ABC'=3+'.'=1+'__subclasshook__'=16=20); __subclasshook__ is a classmethod that customizes issubclass() checks; by default it returns NotImplemented, which falls through to the normal subclass check; ABC.__subclasshook__.__qualname__ (20) < ABC.__init_subclass__.__qualname__ (21) by 1; ABC.__subclasshook__.__qualname__ (20) < ABCMeta.__instancecheck__.__qualname__ (25) by 5; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abc_methods
  kind: python_call_eq
  function: abc.ABC.__subclasshook__.__qualname__.__eq__
  args: ["ABC.__subclasshook__"]
  expected: true

invariant abc_extra193.abc_ABCMeta_register_qualname_eq:
  description: "abc.ABCMeta.register.__qualname__.__eq__('ABCMeta.register') returns True — ABCMeta.register.__qualname__=='ABCMeta.register' (len=16: 'ABCMeta'=7+'.'=1+'register'=8=16); register(subclass) registers a class as a virtual subclass of the ABC, allowing isinstance() and issubclass() checks to return True for classes that do not actually inherit from the ABC; ABCMeta.register.__qualname__ (16) > ABCMeta.__new__.__qualname__ (15) by 1; ABCMeta.register.__qualname__ (16) < ABC.__subclasshook__.__qualname__ (20) by 4; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abcmeta_methods
  kind: python_call_eq
  function: abc.ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

invariant abc_extra193.abc_ABCMeta_instancecheck_qualname_eq:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') returns True — ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25: 'ABCMeta'=7+'.'=1+'__instancecheck__'=17=25); __instancecheck__ is called by isinstance() to support virtual subclasses; it checks both the MRO and the set of registered virtual subclasses; ABCMeta.__instancecheck__.__qualname__ (25) == ABCMeta.__subclasscheck__.__qualname__ (25) — tied as the longest in this spec; ABCMeta.__instancecheck__.__qualname__ (25) > ABC.__init_subclass__.__qualname__ (21) by 4; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abcmeta_methods
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

invariant abc_extra193.abc_ABCMeta_subclasscheck_qualname_eq:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__') returns True — ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25: 'ABCMeta'=7+'.'=1+'__subclasscheck__'=17=25); __subclasscheck__ is called by issubclass() to support virtual subclasses; it first calls __subclasshook__ and falls back to the standard subclass check; ABCMeta.__subclasscheck__.__qualname__ (25) == ABCMeta.__instancecheck__.__qualname__ (25) — both __instancecheck__ and __subclasscheck__ are 17-character method names; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abcmeta_methods
  kind: python_call_eq
  function: abc.ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true

invariant abc_extra193.abc_ABCMeta_init_qualname_eq:
  description: "abc.ABCMeta.__init__.__qualname__.__eq__('type.__init__') returns True — ABCMeta.__init__.__qualname__=='type.__init__' (len=13: 'type'=4+'.'=1+'__init__'=8=13); ABCMeta does NOT define its own __init__ — it inherits __init__ from type, its metaclass parent; the qualname 'type.__init__' reflects the defining class (type), not the accessing class (ABCMeta); ABCMeta.__init__.__qualname__ (13: 'type.__init__') is the shortest qualname in this spec; ABCMeta.__init__.__qualname__ (13) < ABCMeta.__new__.__qualname__ (15: 'ABCMeta.__new__') by 2; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abcmeta_methods
  kind: python_call_eq
  function: abc.ABCMeta.__init__.__qualname__.__eq__
  args: ["type.__init__"]
  expected: true

invariant abc_extra193.abc_ABCMeta_new_qualname_eq:
  description: "abc.ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__') returns True — ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15); ABCMeta defines its own __new__ to initialize the set of abstract methods (__abstractmethods__) when a new class is created using ABCMeta as its metaclass; ABCMeta.__new__.__qualname__ (15) > ABCMeta.__init__.__qualname__ (13: 'type.__init__') by 2; ABCMeta.__new__.__qualname__ (15) < ABCMeta.register.__qualname__ (16) by 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abcmeta_methods
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__qualname__.__eq__
  args: ["ABCMeta.__new__"]
  expected: true

invariant abc_extra193.abc_ABCMeta_check_qualnames_tied_len:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — 'ABCMeta.__instancecheck__' has 25 characters; ABCMeta.__instancecheck__.__qualname__ (25) == ABCMeta.__subclasscheck__.__qualname__ (25) — both are tied as the longest qualnames in this spec; the tie arises because __instancecheck__ and __subclasscheck__ both have 17-character method names; length ordering: type.__init__ (13) < ABCMeta.__new__ (15) < ABCMeta.register (16) < ABC.__subclasshook__ (20) < ABC.__init_subclass__ (21) < ABCMeta.__instancecheck__ (25) == ABCMeta.__subclasscheck__ (25); NEW in abcdunders193: completing 8-invariant coverage for abc ABC and ABCMeta dunder method qualnames; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: abcmeta_methods
  kind: python_call_eq
  function: abc.ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25

