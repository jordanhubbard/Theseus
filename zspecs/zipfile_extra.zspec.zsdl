spec: zipfile_extra
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/zipfile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "zipfile source: Lib/zipfile/__init__.py (internal implementation)"
  notes:
    - "Covers __module__ checks, constant type checks, and is_zipfile __name__ not in zipfile.zspec.zsdl."
    - "ZipFile.__module__ == 'zipfile' — the public module name."
    - "ZIP_STORED=0, ZIP_DEFLATED=8, ZIP_BZIP2=12, ZIP_LZMA=14 are int constants."
    - "BadZipFile.__bases__[0].__name__ == 'Exception' — BadZipFile is a direct Exception subclass."
    - "is_zipfile.__name__ == 'is_zipfile' — function name attribute confirms identity."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — verifying __name__ for all public classes
# ---------------------------------------------------------------------------

invariant zipfile_extra.classes.ZipFile_name:
  description: "zipfile.ZipFile.__name__ == 'ZipFile'"
  category: classes
  kind: python_call_eq
  function: ZipFile.__name__.__eq__
  args: ["ZipFile"]
  expected: true

invariant zipfile_extra.classes.ZipInfo_name:
  description: "zipfile.ZipInfo.__name__ == 'ZipInfo'"
  category: classes
  kind: python_call_eq
  function: ZipInfo.__name__.__eq__
  args: ["ZipInfo"]
  expected: true

invariant zipfile_extra.classes.BadZipFile_name:
  description: "zipfile.BadZipFile.__name__ == 'BadZipFile'"
  category: classes
  kind: python_call_eq
  function: BadZipFile.__name__.__eq__
  args: ["BadZipFile"]
  expected: true

invariant zipfile_extra.classes.LargeZipFile_name:
  description: "zipfile.LargeZipFile.__name__ == 'LargeZipFile'"
  category: classes
  kind: python_call_eq
  function: LargeZipFile.__name__.__eq__
  args: ["LargeZipFile"]
  expected: true

invariant zipfile_extra.classes.Path_name:
  description: "zipfile.Path.__name__ == 'Path'"
  category: classes
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

# ---------------------------------------------------------------------------
# Module check — ZipFile lives in the zipfile module
# ---------------------------------------------------------------------------

invariant zipfile_extra.modules.ZipFile_module:
  description: "zipfile.ZipFile.__module__ == 'zipfile'"
  category: modules
  kind: python_call_eq
  function: ZipFile.__module__.__eq__
  args: ["zipfile"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — BadZipFile inherits from Exception
# ---------------------------------------------------------------------------

invariant zipfile_extra.bases.BadZipFile_base:
  description: "zipfile.BadZipFile.__bases__[0].__name__ == 'Exception'"
  category: bases
  kind: python_call_eq
  function: BadZipFile.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Function name check — is_zipfile
# ---------------------------------------------------------------------------

invariant zipfile_extra.functions.is_zipfile_name:
  description: "zipfile.is_zipfile.__name__ == 'is_zipfile'"
  category: functions
  kind: python_call_eq
  function: is_zipfile.__name__.__eq__
  args: ["is_zipfile"]
  expected: true

# ---------------------------------------------------------------------------
# Constant type checks — compression method constants are int
# ---------------------------------------------------------------------------

invariant zipfile_extra.constants.ZIP_STORED_class:
  description: "zipfile.ZIP_STORED.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: ZIP_STORED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant zipfile_extra.constants.ZIP_DEFLATED_class:
  description: "zipfile.ZIP_DEFLATED.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: ZIP_DEFLATED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant zipfile_extra.constants.ZIP_BZIP2_class:
  description: "zipfile.ZIP_BZIP2.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: ZIP_BZIP2.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant zipfile_extra.constants.ZIP_LZMA_class:
  description: "zipfile.ZIP_LZMA.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: ZIP_LZMA.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Constant value checks — compression method integer values
# ---------------------------------------------------------------------------

invariant zipfile_extra.constants.ZIP_STORED_value:
  description: "zipfile.ZIP_STORED == 0 — no compression"
  category: constants
  kind: python_call_eq
  function: ZIP_STORED.__eq__
  args: [0]
  expected: true

invariant zipfile_extra.constants.ZIP_DEFLATED_value:
  description: "zipfile.ZIP_DEFLATED == 8 — zlib deflate compression"
  category: constants
  kind: python_call_eq
  function: ZIP_DEFLATED.__eq__
  args: [8]
  expected: true

invariant zipfile_extra.constants.ZIP_BZIP2_value:
  description: "zipfile.ZIP_BZIP2 == 12 — bzip2 compression"
  category: constants
  kind: python_call_eq
  function: ZIP_BZIP2.__eq__
  args: [12]
  expected: true

invariant zipfile_extra.constants.ZIP_LZMA_value:
  description: "zipfile.ZIP_LZMA == 14 — LZMA compression"
  category: constants
  kind: python_call_eq
  function: ZIP_LZMA.__eq__
  args: [14]
  expected: true
