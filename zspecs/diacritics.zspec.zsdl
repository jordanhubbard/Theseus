spec: diacritics
version: ">=1.0.0"
backend: node(diacritics)

docs: https://www.npmjs.com/package/diacritics

provenance:
  derived_from:
    - "diacritics README — https://www.npmjs.com/package/diacritics"
    - "Test vectors verified with diacritics@1.3.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "diacritics source"
  notes:
    - "diacritics exports {remove} named function."
    - "remove(string) strips diacritical marks (accents) from characters."
    - "Replaces accented characters with their ASCII equivalents."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns ASCII string with diacritics removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table diacritics.remove:
  kind: node_module_call_eq
  function: remove
  category: remove
  id_prefix: diacr

  columns: [id, args, expected]
  rows:
    - [french,   ["héllo wörld"],  "hello world"]
    - [spanish,  ["café"],         "cafe"]
    - [german,   ["über"],         "uber"]
    - [clean,    ["hello"],        "hello"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:19:21Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
