spec: lodash_kebabcase
version: ">=4.0.0"
backend: node(lodash.kebabcase)

docs: https://lodash.com/docs/#kebabCase

provenance:
  derived_from:
    - "lodash.kebabcase README — https://www.npmjs.com/package/lodash.kebabcase"
    - "Test vectors verified with lodash.kebabcase@4.1.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.kebabcase exports the _.kebabCase function directly as module.exports."
    - "kebabCase(string) converts string to kebab-case (lower case, hyphen-separated)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns kebab-case string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_kebabcase.kebabcase:
  kind: node_module_call_eq
  function: ~
  category: kebabcase
  id_prefix: lkc

  columns: [id, args, expected]
  rows:
    - [spaces,   ["hello world"],  "hello-world"]
    - [camel,    ["fooBar"],       "foo-bar"]
    - [snake,    ["foo_bar"],      "foo-bar"]
    - [upper,    ["FOO BAR"],      "foo-bar"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:32:01Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
