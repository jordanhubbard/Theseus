spec: multiprocessing_extra35
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra34.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() for Pool/Queue/Lock/Event/Semaphore/Barrier, Process method __qualname__.__len__() for start/run/join/terminate/is_alive/kill, Pool method __qualname__.__len__() tables (extra34), AuthenticationError/ProcessError/BufferTooShort __bases__[0].__name__, Process/Pool/__mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__.__len__() tables, DefaultContext method qualname lengths, BaseProcess class metadata, Process/__init__.__qualname__.__len__()==20, cpu_count/__name__.__len__()==9, current_process/__name__.__len__()==15, active_children/__qualname__.__len__()==15."
    - "This spec covers: pool.Pool.map.__name__.__len__()==3; pool.Pool.apply.__name__.__len__()==5; pool.Pool.close.__name__.__len__()==5; pool.Pool.terminate.__name__.__len__()==9; pool.Pool.map_async.__name__.__len__()==9; pool.Pool.apply_async.__name__.__len__()==11; pool.Pool.starmap.__name__.__len__()==7; pool.Pool.starmap_async.__name__.__len__()==13; active_children.__name__.__len__()==15; parent_process.__name__.__len__()==14; get_start_method.__name__.__len__()==16; set_start_method.__name__.__len__()==16."
    - "Prior spec extra34 covered Pool method __qualname__.__len__() for all these methods. This spec measures __name__.__len__() — the short unqualified method name without the 'Pool.' prefix."
    - "pool.Pool.apply and pool.Pool.close share __name__.__len__() == 5 ('apply' and 'close' both have 5 characters). pool.Pool.terminate and pool.Pool.map_async also share __name__.__len__() == 9 ('terminate' is 9, 'map_async' is 9)."
    - "pool.Pool.starmap_async.__name__ == 'starmap_async' (13 chars) — the longest Pool method short name in this spec, reflecting both 'starmap' (7) and '_async' (6) components."
    - "active_children.__name__.__len__() == 15 ('active_children'); parent_process.__name__.__len__() == 14 ('parent_process'). get_start_method and set_start_method both have __name__.__len__() == 16. Prior specs measured __qualname__.__len__() for these functions (extra32 covers DefaultContext method qualname lengths) but not __name__.__len__() as integers."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool method __name__.__len__() — extra35 namespace
#
# Prior spec extra34 covered Pool method __qualname__.__len__() for all key
# methods. This spec covers __name__.__len__() — the short name without the
# 'Pool.' prefix. Key pairings by length:
#   Pool.map.__name__          == 'map'           (3 chars)
#   Pool.apply.__name__        == 'apply'         (5 chars)
#   Pool.close.__name__        == 'close'         (5 chars)  ← ties apply
#   Pool.starmap.__name__      == 'starmap'       (7 chars)
#   Pool.terminate.__name__    == 'terminate'     (9 chars)
#   Pool.map_async.__name__    == 'map_async'     (9 chars)  ← ties terminate
#   Pool.apply_async.__name__  == 'apply_async'   (11 chars)
#   Pool.starmap_async.__name__ == 'starmap_async' (13 chars)
# apply/close share length 5; terminate/map_async share length 9.
# No prior multiprocessing spec has captured these __name__.__len__() values.
# ---------------------------------------------------------------------------

table multiprocessing_extra35.pool_method_name_lengths:
  description: "multiprocessing.pool.Pool method __name__.__len__() in extra35 namespace — short names without 'Pool.' prefix"
  kind: python_call_eq
  category: method_names
  id_prefix: poolmnamelen35

  columns: [id, function, args, expected, description]
  rows:
    - [map,           "pool.Pool.map.__name__.__len__",           [], 3,  "'map' is 3 characters — shortest Pool method name"]
    - [apply,         "pool.Pool.apply.__name__.__len__",         [], 5,  "'apply' is 5 characters — ties with 'close'"]
    - [close,         "pool.Pool.close.__name__.__len__",         [], 5,  "'close' is 5 characters — ties with 'apply'"]
    - [starmap,       "pool.Pool.starmap.__name__.__len__",       [], 7,  "'starmap' is 7 characters"]
    - [terminate,     "pool.Pool.terminate.__name__.__len__",     [], 9,  "'terminate' is 9 characters — ties with 'map_async'"]
    - [map_async,     "pool.Pool.map_async.__name__.__len__",     [], 9,  "'map_async' is 9 characters — ties with 'terminate'"]
    - [apply_async,   "pool.Pool.apply_async.__name__.__len__",   [], 11, "'apply_async' is 11 characters"]
    - [starmap_async, "pool.Pool.starmap_async.__name__.__len__", [], 13, "'starmap_async' is 13 characters — longest Pool method short name"]

# ---------------------------------------------------------------------------
# multiprocessing module-level function __name__.__len__() — extra35 namespace
#
# The DefaultContext-bound functions exposed at the multiprocessing module
# level have these short __name__ lengths:
#   active_children.__name__  == 'active_children'  (15 chars)
#   parent_process.__name__   == 'parent_process'   (14 chars)
#   get_start_method.__name__ == 'get_start_method' (16 chars)
#   set_start_method.__name__ == 'set_start_method' (16 chars)
# get_start_method and set_start_method share __name__.__len__() == 16 because
# both names have the same structure: 3-letter verb + '_start_method' (13).
# Prior specs measured __qualname__.__len__() for these functions (DefaultContext
# prefix, extra32) but not their __name__.__len__() as integer invariants.
# ---------------------------------------------------------------------------

table multiprocessing_extra35.module_function_name_lengths:
  description: "multiprocessing module-level function __name__.__len__() in extra35 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: mpfuncnamelen35

  columns: [id, function, args, expected, description]
  rows:
    - [parent_process,   parent_process.__name__.__len__,   [], 14, "'parent_process' is 14 characters"]
    - [active_children,  active_children.__name__.__len__,  [], 15, "'active_children' is 15 characters — one longer than parent_process"]
    - [get_start_method, get_start_method.__name__.__len__,  [], 16, "'get_start_method' is 16 characters — ties with set_start_method"]
    - [set_start_method, set_start_method.__name__.__len__,  [], 16, "'set_start_method' is 16 characters — ties with get_start_method"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra35
# ---------------------------------------------------------------------------

invariant multiprocessing_extra35.pool_Pool_starmap_async_name_len:
  description: "multiprocessing.pool.Pool.starmap_async.__name__.__len__() == 13 — 'starmap_async' has 13 characters; the longest Pool method short name in this spec"
  category: method_names
  kind: python_call_eq
  function: "pool.Pool.starmap_async.__name__.__len__"
  args: []
  expected: 13

invariant multiprocessing_extra35.pool_Pool_map_name_len:
  description: "multiprocessing.pool.Pool.map.__name__.__len__() == 3 — 'map' has 3 characters; the shortest Pool method name and one of the shortest Python method names possible"
  category: method_names
  kind: python_call_eq
  function: "pool.Pool.map.__name__.__len__"
  args: []
  expected: 3

invariant multiprocessing_extra35.get_start_method_name_len:
  description: "multiprocessing.get_start_method.__name__.__len__() == 16 — 'get_start_method' has 16 characters; same length as set_start_method (both have the same structure)"
  category: function_names
  kind: python_call_eq
  function: get_start_method.__name__.__len__
  args: []
  expected: 16
