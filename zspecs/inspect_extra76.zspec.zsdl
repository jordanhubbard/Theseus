spec: inspect_extra76
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra75.zspec.zsdl."
    - "This spec covers: inspect Signature and Parameter __dict__ content (Wave 242)."
    - "Signature.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of Signature is a mappingproxy. Verified with Python 3.14.3."
    - "Signature.__dict__.__contains__('bind') == True — Signature.bind is defined. Verified with Python 3.14.3."
    - "Signature.__dict__.__contains__('bind_partial') == True — Signature.bind_partial is defined. Verified with Python 3.14.3."
    - "Signature.__dict__.__contains__('replace') == True — Signature.replace is defined. Verified with Python 3.14.3."
    - "Signature.__dict__.__contains__('from_callable') == True — Signature.from_callable is a classmethod. Verified with Python 3.14.3."
    - "Parameter.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of Parameter is a mappingproxy. Verified with Python 3.14.3."
    - "Parameter.__dict__.__contains__('replace') == True — Parameter.replace is defined. Verified with Python 3.14.3."
    - "Parameter.__dict__.__contains__('name') == True — name is a property on Parameter. Verified with Python 3.14.3."
    - "Parameter.__dict__.__contains__('kind') == True — kind is a property on Parameter. Verified with Python 3.14.3."
    - "Parameter.__dict__.__contains__('default') == True — default is a property on Parameter. Verified with Python 3.14.3."
    - "Parameter.__dict__.__contains__('annotation') == True — annotation is a property on Parameter. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Signature __dict__ class name — extra76
#
# Wave 242 theme: Signature.__dict__ is a mappingproxy.
#
# inspect.Signature.__dict__.__class__.__name__ == 'mappingproxy'
#
# No prior inspect spec checks Signature.__dict__.__class__.__name__ via inspmore76. New to extra76.
# ---------------------------------------------------------------------------

table inspect_extra76.Signature_dict_class_name:
  description: "Signature.__dict__.__class__.__name__=='mappingproxy'; wave 242 Signature __dict__ content; new to extra76"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore76

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_dict_class_name_eq_mappingproxy,
       Signature.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "inspect.Signature.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Signature is a pure-Python class defined in Lib/inspect.py that represents the signature of a callable; its class namespace is exposed as a read-only mappingproxy; __dict__.__class__.__name__ == 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior inspect spec checks Signature.__dict__.__class__.__name__ via inspmore76; new to extra76"]

# ---------------------------------------------------------------------------
# Signature __dict__ method presence — extra76
#
# Wave 242 theme: Signature.__dict__ contains bind/bind_partial/replace/from_callable.
#
# inspect.Signature.__dict__.__contains__('bind')          == True
# inspect.Signature.__dict__.__contains__('bind_partial')  == True
# inspect.Signature.__dict__.__contains__('replace')       == True
# inspect.Signature.__dict__.__contains__('from_callable') == True
#
# No prior inspect spec checks Signature.__dict__ method keys via inspmore76. New to extra76.
# ---------------------------------------------------------------------------

table inspect_extra76.Signature_dict_methods:
  description: "Signature.__dict__.__contains__('bind')==True, 'bind_partial'==True, 'replace'==True, 'from_callable'==True; wave 242 Signature __dict__ content; new to extra76"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore76

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_dict_contains_bind,
       Signature.__dict__.__contains__,
       ["bind"],
       true,
       "inspect.Signature.__dict__.__contains__('bind') == True — Signature.bind(self, *args, **kwargs) is defined in the Signature class body in Lib/inspect.py; it binds the provided arguments to the signature's parameters; mappingproxy.__contains__('bind') returns True; no prior inspect spec checks Signature.__dict__.__contains__('bind') via inspmore76; new to extra76"]
    - [Signature_dict_contains_bind_partial,
       Signature.__dict__.__contains__,
       ["bind_partial"],
       true,
       "inspect.Signature.__dict__.__contains__('bind_partial') == True — Signature.bind_partial(self, *args, **kwargs) is defined in the Signature class body in Lib/inspect.py; it works like bind but allows omitting required arguments; mappingproxy.__contains__('bind_partial') returns True; no prior inspect spec checks Signature.__dict__.__contains__('bind_partial') via inspmore76; new to extra76"]
    - [Signature_dict_contains_replace,
       Signature.__dict__.__contains__,
       ["replace"],
       true,
       "inspect.Signature.__dict__.__contains__('replace') == True — Signature.replace(self, *, parameters=..., return_annotation=...) is defined in the Signature class body in Lib/inspect.py; it creates a modified copy of the signature; mappingproxy.__contains__('replace') returns True; no prior inspect spec checks Signature.__dict__.__contains__('replace') via inspmore76; new to extra76"]
    - [Signature_dict_contains_from_callable,
       Signature.__dict__.__contains__,
       ["from_callable"],
       true,
       "inspect.Signature.__dict__.__contains__('from_callable') == True — Signature.from_callable(obj, ...) is a classmethod defined in the Signature class body in Lib/inspect.py that creates a Signature for the given callable; mappingproxy.__contains__('from_callable') returns True; no prior inspect spec checks Signature.__dict__.__contains__('from_callable') via inspmore76; new to extra76"]

# ---------------------------------------------------------------------------
# Parameter __dict__ class name — extra76
#
# Wave 242 theme: Parameter.__dict__ is a mappingproxy.
#
# inspect.Parameter.__dict__.__class__.__name__ == 'mappingproxy'
#
# No prior inspect spec checks Parameter.__dict__.__class__.__name__ via inspmore76. New to extra76.
# ---------------------------------------------------------------------------

table inspect_extra76.Parameter_dict_class_name:
  description: "Parameter.__dict__.__class__.__name__=='mappingproxy'; wave 242 Parameter __dict__ content; new to extra76"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore76

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_dict_class_name_eq_mappingproxy,
       Parameter.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "inspect.Parameter.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Parameter is a pure-Python class defined in Lib/inspect.py that represents a parameter in a function signature; its class namespace is exposed as a read-only mappingproxy; __dict__.__class__.__name__ == 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior inspect spec checks Parameter.__dict__.__class__.__name__ via inspmore76; new to extra76"]

# ---------------------------------------------------------------------------
# Parameter __dict__ property and method presence — extra76
#
# Wave 242 theme: Parameter.__dict__ contains replace/name/kind/default/annotation.
#
# inspect.Parameter.__dict__.__contains__('replace')    == True
# inspect.Parameter.__dict__.__contains__('name')       == True
# inspect.Parameter.__dict__.__contains__('kind')       == True
# inspect.Parameter.__dict__.__contains__('default')    == True
# inspect.Parameter.__dict__.__contains__('annotation') == True
#
# No prior inspect spec checks Parameter.__dict__ property/method keys via inspmore76. New to extra76.
# ---------------------------------------------------------------------------

table inspect_extra76.Parameter_dict_properties:
  description: "Parameter.__dict__.__contains__('replace')==True, 'name'==True, 'kind'==True, 'default'==True, 'annotation'==True; wave 242 Parameter __dict__ content; new to extra76"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore76

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_dict_contains_replace,
       Parameter.__dict__.__contains__,
       ["replace"],
       true,
       "inspect.Parameter.__dict__.__contains__('replace') == True — Parameter.replace(self, *, name=..., kind=..., default=..., annotation=...) is defined in the Parameter class body in Lib/inspect.py; it creates a modified copy of the parameter; mappingproxy.__contains__('replace') returns True; no prior inspect spec checks Parameter.__dict__.__contains__('replace') via inspmore76; new to extra76"]
    - [Parameter_dict_contains_name,
       Parameter.__dict__.__contains__,
       ["name"],
       true,
       "inspect.Parameter.__dict__.__contains__('name') == True — Parameter.name is a read-only property defined in the Parameter class body in Lib/inspect.py that returns the parameter's name string; mappingproxy.__contains__('name') returns True; no prior inspect spec checks Parameter.__dict__.__contains__('name') via inspmore76; new to extra76"]
    - [Parameter_dict_contains_kind,
       Parameter.__dict__.__contains__,
       ["kind"],
       true,
       "inspect.Parameter.__dict__.__contains__('kind') == True — Parameter.kind is a read-only property defined in the Parameter class body in Lib/inspect.py that returns the parameter kind (POSITIONAL_ONLY, etc.); mappingproxy.__contains__('kind') returns True; no prior inspect spec checks Parameter.__dict__.__contains__('kind') via inspmore76; new to extra76"]
    - [Parameter_dict_contains_default,
       Parameter.__dict__.__contains__,
       ["default"],
       true,
       "inspect.Parameter.__dict__.__contains__('default') == True — Parameter.default is a read-only property defined in the Parameter class body in Lib/inspect.py that returns the parameter's default value or Parameter.empty; mappingproxy.__contains__('default') returns True; no prior inspect spec checks Parameter.__dict__.__contains__('default') via inspmore76; new to extra76"]
    - [Parameter_dict_contains_annotation,
       Parameter.__dict__.__contains__,
       ["annotation"],
       true,
       "inspect.Parameter.__dict__.__contains__('annotation') == True — Parameter.annotation is a read-only property defined in the Parameter class body in Lib/inspect.py that returns the parameter's annotation or Parameter.empty; mappingproxy.__contains__('annotation') returns True; no prior inspect spec checks Parameter.__dict__.__contains__('annotation') via inspmore76; new to extra76"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra76
# ---------------------------------------------------------------------------

invariant inspect_extra76.Signature_dict_class_name:
  description: "inspect.Signature.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Signature class namespace is a mappingproxy; wave 242 Signature __dict__ content; new to extra76"
  kind: python_call_eq
  function: Signature.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant inspect_extra76.Signature_dict_contains_bind:
  description: "inspect.Signature.__dict__.__contains__('bind') == True — Signature class namespace contains 'bind'; wave 242 Signature __dict__ content; new to extra76"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["bind"]
  expected: true

invariant inspect_extra76.Signature_dict_contains_from_callable:
  description: "inspect.Signature.__dict__.__contains__('from_callable') == True — Signature class namespace contains 'from_callable'; wave 242 Signature __dict__ content; new to extra76"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["from_callable"]
  expected: true

invariant inspect_extra76.Parameter_dict_contains_name:
  description: "inspect.Parameter.__dict__.__contains__('name') == True — Parameter class namespace contains 'name' property; wave 242 Parameter __dict__ content; new to extra76"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["name"]
  expected: true

invariant inspect_extra76.Parameter_dict_contains_annotation:
  description: "inspect.Parameter.__dict__.__contains__('annotation') == True — Parameter class namespace contains 'annotation' property; wave 242 Parameter __dict__ content; new to extra76"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["annotation"]
  expected: true
