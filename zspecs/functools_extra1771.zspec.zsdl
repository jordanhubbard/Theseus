spec: functools_extra1771
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 565 (_extra1771): async protocol dict-presence checks."
    - "Theme: which functools stdlib types define __aenter__, __aexit__, __aiter__, __anext__, __await__ in their own __dict__."
    - "functools.partial: a C-level type wrapping a callable with pre-filled args — not an async context manager or async iterator; no async protocol dunders -> all False."
    - "functools.cached_property: a Python descriptor class caching the result of a property call — synchronous descriptor, no async protocol -> all False."
    - "functools.partialmethod: a Python descriptor class for partial method application — not async -> all False."
    - "Rationale: functools types implement the higher-order-function / descriptor protocol (partial application, caching, method wrapping), not the async protocol."
    - "Complementary checks confirm class-type identity of key functools callables."
    - "functools.wraps.__class__.__name__ -> 'function' — wraps is a Python-level decorator factory."
    - "functools.total_ordering.__class__.__name__ -> 'function' — total_ordering is a Python-level class decorator."
    - "functools.singledispatch.__class__.__name__ -> 'function' — singledispatch is a Python-level decorator factory."
    - "functools.cmp_to_key.__class__.__name__ -> 'builtin_function_or_method' — cmp_to_key is implemented in C."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: async protocol dict-presence checks for functools types
#
# Wave 565 theme: which functools types define __aenter__, __aexit__,
# __aiter__, __anext__, __await__ in their own __dict__.
#
# functools.partial: C-level type wrapping a callable + partial args.
#   It is a synchronous higher-order-function tool; no async protocol.
# functools.cached_property: Python descriptor that computes and caches a
#   property value the first time it is accessed. Synchronous.
# functools.partialmethod: Python descriptor enabling partial method
#   application on class instances. Synchronous.
# ---------------------------------------------------------------------------

table functools_extra1771.async_protocol:
  description: "functools types async protocol dict-presence checks — all False — wave 565 _extra1771"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1771

  columns: [id, function, args, expected]
  rows:
    - ["fu1771001", "functools.partial.__dict__.__contains__",          ["__aenter__"], false]
    - ["fu1771002", "functools.partial.__dict__.__contains__",          ["__aexit__"],  false]
    - ["fu1771003", "functools.partial.__dict__.__contains__",          ["__aiter__"],  false]
    - ["fu1771004", "functools.partial.__dict__.__contains__",          ["__anext__"],  false]
    - ["fu1771005", "functools.partial.__dict__.__contains__",          ["__await__"],  false]
    - ["fu1771006", "functools.cached_property.__dict__.__contains__",  ["__aenter__"], false]
    - ["fu1771007", "functools.cached_property.__dict__.__contains__",  ["__aexit__"],  false]
    - ["fu1771008", "functools.cached_property.__dict__.__contains__",  ["__aiter__"],  false]
    - ["fu1771009", "functools.cached_property.__dict__.__contains__",  ["__anext__"],  false]
    - ["fu1771010", "functools.cached_property.__dict__.__contains__",  ["__await__"],  false]
    - ["fu1771011", "functools.partialmethod.__dict__.__contains__",    ["__aenter__"], false]
    - ["fu1771012", "functools.partialmethod.__dict__.__contains__",    ["__aexit__"],  false]
    - ["fu1771013", "functools.partialmethod.__dict__.__contains__",    ["__aiter__"],  false]
    - ["fu1771014", "functools.partialmethod.__dict__.__contains__",    ["__anext__"],  false]
    - ["fu1771015", "functools.partialmethod.__dict__.__contains__",    ["__await__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for functools module-level callables
#
# The async theme is all-False for all functools types. Complementary checks
# confirm genuine functools-specific structural properties:
# - functools.wraps.__class__.__name__ -> 'function' (Python-level function)
# - functools.total_ordering.__class__.__name__ -> 'function'
# - functools.singledispatch.__class__.__name__ -> 'function'
# - functools.cmp_to_key.__class__.__name__ -> 'builtin_function_or_method'
# - functools.partial.__dict__.__contains__('__call__') -> True (partial is callable)
# - functools.cached_property.__dict__.__contains__('__get__') -> True (it's a descriptor)
# - functools.partialmethod.__dict__.__contains__('__get__') -> True (it's a descriptor)
# ---------------------------------------------------------------------------

table functools_extra1771.complementary_checks:
  description: "functools module-level callable type names and key dict-presence complementary checks — wave 565 _extra1771"
  kind: python_call_eq
  category: complementary
  id_prefix: fu1771

  columns: [id, function, args, expected]
  rows:
    - ["fu1771016", "functools.wraps.__class__.__name__.__eq__",              ["function"],                   true]
    - ["fu1771017", "functools.total_ordering.__class__.__name__.__eq__",     ["function"],                   true]
    - ["fu1771018", "functools.singledispatch.__class__.__name__.__eq__",     ["function"],                   true]
    - ["fu1771019", "functools.cmp_to_key.__class__.__name__.__eq__",        ["builtin_function_or_method"], true]
    - ["fu1771020", "functools.partial.__dict__.__contains__",               ["__call__"],                   true]
    - ["fu1771021", "functools.cached_property.__dict__.__contains__",       ["__get__"],                    true]
    - ["fu1771022", "functools.partialmethod.__dict__.__contains__",         ["__get__"],                    true]
