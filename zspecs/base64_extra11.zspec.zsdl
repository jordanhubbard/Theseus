spec: base64_extra11
version: ">=3.9"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html
rfcs:
  - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings"

provenance:
  derived_from:
    - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings, October 2006"
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/base64.py"
    - "CPython source: Modules/binascii.c"
    - "base64_extra10.zspec.zsdl — covers b64decode.__name__/__module__; b64encode(abc)/b64decode(Man); urlsafe_b64encode fbff; b32encode/decode foo/foobar; b16encode/decode DEADBEEF."
    - "base64_extra9.zspec.zsdl — covers a85encode/decode hello/Man vectors; a85 __name__; b85encode abc/empty; b16encode abc_len/hello_len; b32encode/decode hello world."
    - "base64_extra7.zspec.zsdl — covers b16/b32/b85 __name__ and __module__; b16encode null/ff; b64encode Man; urlsafe return class."
    - "base64_extra5.zspec.zsdl — covers b64encode/__name__, __module__; return type checks; b64encode length 1/3/6; zero-byte encode/decode."
  notes:
    - "This spec extends base64 through base64_extra10; it does NOT duplicate invariants present in those files."
    - "Focus: urlsafe_b64encode/decode __name__ attributes; b16encode/decode __name__ and __module__ attributes; b32encode/decode __name__ and __module__; new encoding vectors."
    - "base64_extra7 covers b16encode.__name__=='b16encode' and b16encode.__module__=='base64'. Re-anchored from extra11 namespace with distinct id prefix."
    - "base64_extra7 covers b32encode.__name__=='b32encode'. b32encode.__module__=='base64' not yet covered. Re-anchored from extra11."
    - "urlsafe_b64encode.__name__ not covered in any prior spec as a standalone python_call_eq invariant."
    - "urlsafe_b64decode.__name__ not covered in any prior spec as a standalone python_call_eq invariant."
    - "urlsafe_b64encode.__module__ not covered in any prior spec."
    - "urlsafe_b64decode.__module__ not covered in any prior spec."
    - "b32decode.__name__ not covered in any prior spec as a standalone python_call_eq invariant."
    - "b32decode.__module__ not covered in any prior spec."
    - "base64.urlsafe_b64encode(b'f') == b'Zg==' — single byte URL-safe base64 with padding."
    - "base64.urlsafe_b64decode(b'Zg==') == b'f' — decode single byte URL-safe padded input."
    - "base64.b16encode(b'\\x00\\xff') == b'00FF' — two-byte input with min and max byte values."
    - "base64.b16decode(b'00FF') == b'\\x00\\xff' — decode two-byte hex string."
    - "base64.b32encode(b'f') == b'MY======' — single byte encodes to 8 base32 chars with 6 padding."
    - "base64.b32decode(b'MY======') == b'f' — decode single-byte padded base32."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# urlsafe_b64encode / urlsafe_b64decode — __name__ attributes
#
# base64_extra7 covers b16/b32/b85 __name__. No prior spec covers
# urlsafe_b64encode.__name__ or urlsafe_b64decode.__name__ as standalone
# python_call_eq invariants.
# ---------------------------------------------------------------------------

invariant base64_extra11.urlsafe_b64encode.function_name:
  description: "base64.urlsafe_b64encode.__name__ == 'urlsafe_b64encode'"
  category: function_names
  kind: python_call_eq
  function: urlsafe_b64encode.__name__.__eq__
  args: ["urlsafe_b64encode"]
  expected: true

invariant base64_extra11.urlsafe_b64decode.function_name:
  description: "base64.urlsafe_b64decode.__name__ == 'urlsafe_b64decode'"
  category: function_names
  kind: python_call_eq
  function: urlsafe_b64decode.__name__.__eq__
  args: ["urlsafe_b64decode"]
  expected: true

# ---------------------------------------------------------------------------
# urlsafe_b64encode / urlsafe_b64decode — __module__ attributes
#
# base64_extra5 covers b64encode.__module__. base64_extra10 covers
# b64decode.__module__. No prior spec covers __module__ for the
# urlsafe variants.
# ---------------------------------------------------------------------------

invariant base64_extra11.urlsafe_b64encode.module:
  description: "base64.urlsafe_b64encode.__module__ == 'base64'"
  category: function_modules
  kind: python_call_eq
  function: urlsafe_b64encode.__module__.__eq__
  args: ["base64"]
  expected: true

invariant base64_extra11.urlsafe_b64decode.module:
  description: "base64.urlsafe_b64decode.__module__ == 'base64'"
  category: function_modules
  kind: python_call_eq
  function: urlsafe_b64decode.__module__.__eq__
  args: ["base64"]
  expected: true

# ---------------------------------------------------------------------------
# b32decode.__name__ and __module__
#
# base64_extra7 covers b32encode.__name__. No prior spec covers
# b32decode.__name__ or b32decode.__module__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant base64_extra11.b32decode.function_name:
  description: "base64.b32decode.__name__ == 'b32decode'"
  category: function_names
  kind: python_call_eq
  function: b32decode.__name__.__eq__
  args: ["b32decode"]
  expected: true

invariant base64_extra11.b32decode.module:
  description: "base64.b32decode.__module__ == 'base64'"
  category: function_modules
  kind: python_call_eq
  function: b32decode.__module__.__eq__
  args: ["base64"]
  expected: true

# ---------------------------------------------------------------------------
# urlsafe_b64encode / urlsafe_b64decode — single-byte vectors
#
# base64_extra8 covers urlsafe for abc and foobar; base64_extra10 covers
# urlsafe for b'\xfb\xff'. No prior spec covers the single-byte b'f' vector
# for urlsafe variants. b'f' encodes to b'Zg==' (two padding chars).
# ---------------------------------------------------------------------------

invariant base64_extra11.urlsafe_b64encode.f:
  description: "base64.urlsafe_b64encode(b'f') == b'Zg==' — single byte with padding"
  category: urlsafe
  rfc: "RFC 4648 §5"
  kind: python_call_eq
  function: urlsafe_b64encode
  args: [!ascii "f"]
  expected: !ascii "Zg=="

invariant base64_extra11.urlsafe_b64decode.f:
  description: "base64.urlsafe_b64decode(b'Zg==') == b'f' — decode single byte URL-safe padded input"
  category: urlsafe
  rfc: "RFC 4648 §5"
  kind: python_call_eq
  function: urlsafe_b64decode
  args: [!ascii "Zg=="]
  expected: !ascii "f"

# ---------------------------------------------------------------------------
# b16encode / b16decode — min/max byte vector
#
# base64_extra6 covers b16encode for b'abc' (== b'616263'), b'\xff' (== b'FF'),
# and b'\x00' (== b'00'). base64_extra10 covers b'\xde\xad\xbe\xef'.
# No prior spec covers the two-byte b'\x00\xff' vector as a combined input,
# which exercises both the minimum (0) and maximum (255) byte values.
# ---------------------------------------------------------------------------

invariant base64_extra11.b16encode.null_ff:
  description: "base64.b16encode(b'\\x00\\xff') == b'00FF' — min and max byte values"
  category: b16
  rfc: "RFC 4648 §8"
  kind: python_call_eq
  function: b16encode
  args: [!hex 00ff]
  expected: !ascii "00FF"

invariant base64_extra11.b16decode.null_ff:
  description: "base64.b16decode(b'00FF') == b'\\x00\\xff' — decode min/max hex string"
  category: b16
  rfc: "RFC 4648 §8"
  kind: python_call_eq
  function: b16decode
  args: [!ascii "00FF"]
  expected: !hex 00ff

# ---------------------------------------------------------------------------
# b32encode / b32decode — single-byte vector
#
# No prior base64 spec covers the single-byte b'f' vector for b32encode/b32decode.
# A single byte (8 bits) requires 2 base32 characters (10 bits with 2 padding
# bits) plus 6 '=' padding characters to reach the 8-char block boundary.
# ---------------------------------------------------------------------------

invariant base64_extra11.b32encode.f:
  description: "base64.b32encode(b'f') == b'MY======' — single byte with six padding chars"
  category: b32
  rfc: "RFC 4648 §6"
  kind: python_call_eq
  function: b32encode
  args: [!ascii "f"]
  expected: !ascii "MY======"

invariant base64_extra11.b32decode.f:
  description: "base64.b32decode(b'MY======') == b'f' — decode single-byte padded base32"
  category: b32
  rfc: "RFC 4648 §6"
  kind: python_call_eq
  function: b32decode
  args: [!ascii "MY======"]
  expected: !ascii "f"
