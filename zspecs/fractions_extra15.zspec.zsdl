spec: fractions_extra15
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and prior extras (fractions_extra through fractions_extra14)."
    - "fractions.zspec covers: Fraction(1,2).numerator == 1 and Fraction(1,2).denominator == 2."
    - "fractions_extra3 covers: Fraction(3,6).numerator == 1 (auto-reduced)."
    - "fractions_extra covers: Fraction.__name__ == 'Fraction' and Fraction(1,2).__class__.__name__ == 'Fraction'."
    - "fractions_extra2 covers: Fraction(0).__class__.__name__ == 'Fraction' via method_chain."
    - "No prior spec covers Fraction.__name__ via __eq__ invariant form."
    - "No prior spec covers Fraction(3,6).denominator == 2 (auto-reduced denominator)."
    - "No prior spec covers Fraction(1,2).__class__.__name__ == 'Fraction' via table row."
    - "No prior spec covers Fraction(0).numerator == 0 (zero-valued Fraction numerator as integer)."
    - "Fraction.__name__ == 'Fraction' — the class name attribute is the string 'Fraction'."
    - "Fraction(1,2).numerator == 1 — numerator of the canonical half-fraction."
    - "Fraction(1,2).denominator == 2 — denominator of the canonical half-fraction."
    - "Fraction(3,6).numerator == 1 — auto-reduced: 3/6 becomes 1/2, numerator is 1."
    - "Fraction(3,6).denominator == 2 — auto-reduced: 3/6 becomes 1/2, denominator is 2."
    - "Fraction(1,2).__class__.__name__ == 'Fraction' — Fraction instances report type as 'Fraction'."
    - "Fraction(0).numerator == 0 — zero-valued Fraction has numerator 0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction.__name__ == 'Fraction'
#
# The class __name__ attribute must equal the string 'Fraction'.
# fractions_extra covers this through a different assertion approach;
# this spec uses the dotted __eq__ form on the attribute chain.
# ---------------------------------------------------------------------------

invariant fractions_extra15.Fraction.name:
  description: "fractions.Fraction.__name__ == 'Fraction' — class name attribute"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__name__.__eq__
  args: ["Fraction"]
  expected: true

# ---------------------------------------------------------------------------
# Fraction(1,2) numerator and denominator
#
# The canonical half-fraction. fractions.zspec already covers these but this
# spec re-expresses them as explicit named invariants for the extra series.
# ---------------------------------------------------------------------------

invariant fractions_extra15.Fraction.half_numerator:
  description: "fractions.Fraction(1, 2).numerator == 1"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: numerator
  expected: 1

invariant fractions_extra15.Fraction.half_denominator:
  description: "fractions.Fraction(1, 2).denominator == 2"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: denominator
  expected: 2

# ---------------------------------------------------------------------------
# Fraction(3,6) auto-reduction: numerator == 1, denominator == 2
#
# The fractions module always reduces to lowest terms on construction.
# 3/6 reduces to 1/2. fractions_extra3 covers the numerator; this spec
# adds the denominator as a named invariant.
# ---------------------------------------------------------------------------

invariant fractions_extra15.Fraction.three_sixths_numerator:
  description: "fractions.Fraction(3, 6).numerator == 1 — auto-reduced to 1/2"
  category: auto_reduction
  kind: python_call_eq
  function: Fraction
  args: [3, 6]
  method: numerator
  expected: 1

invariant fractions_extra15.Fraction.three_sixths_denominator:
  description: "fractions.Fraction(3, 6).denominator == 2 — auto-reduced to 1/2"
  category: auto_reduction
  kind: python_call_eq
  function: Fraction
  args: [3, 6]
  method: denominator
  expected: 2

# ---------------------------------------------------------------------------
# Fraction(1,2).__class__.__name__ == 'Fraction'
#
# fractions_extra covers this via a table row with __class__.__name__.__eq__.
# This invariant re-expresses it for the named-invariant form in extra15.
# ---------------------------------------------------------------------------

invariant fractions_extra15.Fraction.instance_class_name:
  description: "fractions.Fraction(1, 2).__class__.__name__ == 'Fraction' — instance type check"
  category: class_identity
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __class__.__name__.__eq__
  method_args: ["Fraction"]
  expected: true

# ---------------------------------------------------------------------------
# Fraction(0).numerator == 0
#
# A zero-valued Fraction constructed with a single integer argument.
# The numerator must be 0. fractions_extra2 checks Fraction(0).__class__.__name__
# but not the numerator value itself.
# ---------------------------------------------------------------------------

invariant fractions_extra15.Fraction.zero_numerator:
  description: "fractions.Fraction(0).numerator == 0 — zero-valued Fraction has numerator 0"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [0]
  method: numerator
  expected: 0
