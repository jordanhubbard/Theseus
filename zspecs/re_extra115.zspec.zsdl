spec: re_extra115
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra114.zspec.zsdl."
    - "This spec covers: re.Pattern descriptor attribute __qualname__ string equality for pattern, flags, groups, and groupindex."
    - "re.Pattern.pattern.__qualname__ == 'Pattern.pattern' (len 15); type 'member_descriptor'."
    - "re.Pattern.flags.__qualname__ == 'Pattern.flags' (len 13); type 'member_descriptor'."
    - "re.Pattern.groups.__qualname__ == 'Pattern.groups' (len 14); type 'member_descriptor'."
    - "re.Pattern.groupindex.__qualname__ == 'Pattern.groupindex' (len 18); type 'getset_descriptor'."
    - "pattern/flags/groups are 'member_descriptor'; groupindex is 'getset_descriptor'."
    - "re_extra37 covered these qualname LENGTHS via Pattern.__dict__[name].__qualname__.__len__() notation."
    - "This spec covers the qualname STRING EQUALITY via direct attribute access: Pattern.pattern.__qualname__.__eq__()."
    - "Both approaches resolve to the same descriptor object but use distinct ZSDL function paths."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern.pattern and re.Pattern.flags descriptor qualname string equality
# Both are 'member_descriptor' (C extension member slots).
# pattern: 'Pattern.pattern' (15 chars); stores the compiled pattern string.
# flags: 'Pattern.flags' (13 chars); stores the integer flags used to compile.
# Direct attribute access (Pattern.pattern) vs __dict__ bracket access
# (Pattern.__dict__['pattern']) both resolve to the same descriptor object.
# This spec uses direct attribute access to test the qualname equality string.
# ---------------------------------------------------------------------------

table re_extra115.Pattern_pattern_flags_qualname_equality:
  description: "re.Pattern.pattern qualname='Pattern.pattern'(15) type='member_descriptor'; re.Pattern.flags qualname='Pattern.flags'(13) type='member_descriptor'; string equality via direct attribute access"
  kind: python_call_eq
  category: qualnames
  id_prefix: repatdesc115a

  columns: [id, function, args, expected, description]
  rows:
    - [pat_type,         "Pattern.pattern.__class__.__name__.__eq__",     ["member_descriptor"],  true,  "type(re.Pattern.pattern).__name__ == 'member_descriptor' (C extension member slot for the compiled pattern string)"]
    - [pat_qn_eq,        "Pattern.pattern.__qualname__.__eq__",           ["Pattern.pattern"],    true,  "re.Pattern.pattern.__qualname__ == 'Pattern.pattern' (15 chars; stores the regex pattern string used at compile time)"]
    - [pat_qn_len,       "Pattern.pattern.__qualname__.__len__",          [],                     15,    "re.Pattern.pattern.__qualname__.__len__() == 15 ('Pattern.pattern' has 15 chars; 'Pattern.'(8)+'pattern'(7)==15)"]
    - [flags_type,       "Pattern.flags.__class__.__name__.__eq__",       ["member_descriptor"],  true,  "type(re.Pattern.flags).__name__ == 'member_descriptor' (C extension member slot for the integer flags value)"]
    - [flags_qn_eq,      "Pattern.flags.__qualname__.__eq__",             ["Pattern.flags"],      true,  "re.Pattern.flags.__qualname__ == 'Pattern.flags' (13 chars; stores the integer regex flags e.g. re.IGNORECASE|re.MULTILINE)"]
    - [flags_qn_len,     "Pattern.flags.__qualname__.__len__",            [],                     13,    "re.Pattern.flags.__qualname__.__len__() == 13 ('Pattern.flags' has 13 chars; shortest among the four Pattern descriptor qualnames)"]
    - [pat_gt_flags,     "Pattern.pattern.__qualname__.__len__.__gt__",   [13],                   true,  "len('Pattern.pattern') > len('Pattern.flags') (15 > 13; pattern is 2 chars longer than flags)"]
    - [flags_ne_pat,     "Pattern.flags.__qualname__.__eq__",             ["Pattern.pattern"],    false, "re.Pattern.flags.__qualname__ != 'Pattern.pattern' (distinct qualname strings; flags(13) is shorter than pattern(15))"]

# ---------------------------------------------------------------------------
# re.Pattern.groups and re.Pattern.groupindex descriptor qualname string equality
# groups is 'member_descriptor' (14 chars); groupindex is 'getset_descriptor' (18 chars).
# groups: integer count of capturing groups in the pattern.
# groupindex: mapping of named groups to group numbers.
# groupindex is a 'getset_descriptor' (tp_getset entry) because it requires
# computed access, unlike pattern/flags/groups which are direct C struct member slots.
# ---------------------------------------------------------------------------

table re_extra115.Pattern_groups_groupindex_qualname_equality:
  description: "re.Pattern.groups qualname='Pattern.groups'(14) type='member_descriptor'; re.Pattern.groupindex qualname='Pattern.groupindex'(18) type='getset_descriptor'; groupindex is longer and uses distinct descriptor type"
  kind: python_call_eq
  category: qualnames
  id_prefix: repatdesc115b

  columns: [id, function, args, expected, description]
  rows:
    - [groups_type,      "Pattern.groups.__class__.__name__.__eq__",      ["member_descriptor"],   true,  "type(re.Pattern.groups).__name__ == 'member_descriptor' (C extension member slot for the count of capturing groups)"]
    - [groups_qn_eq,     "Pattern.groups.__qualname__.__eq__",            ["Pattern.groups"],      true,  "re.Pattern.groups.__qualname__ == 'Pattern.groups' (14 chars; stores the integer count of capturing groups in the pattern)"]
    - [groups_qn_len,    "Pattern.groups.__qualname__.__len__",           [],                      14,    "re.Pattern.groups.__qualname__.__len__() == 14 ('Pattern.groups' has 14 chars; 'Pattern.'(8)+'groups'(6)==14)"]
    - [gidx_type,        "Pattern.groupindex.__class__.__name__.__eq__",  ["getset_descriptor"],   true,  "type(re.Pattern.groupindex).__name__ == 'getset_descriptor' (tp_getset entry; distinct from the three member_descriptor attributes)"]
    - [gidx_qn_eq,       "Pattern.groupindex.__qualname__.__eq__",        ["Pattern.groupindex"],  true,  "re.Pattern.groupindex.__qualname__ == 'Pattern.groupindex' (18 chars; maps named group names to their group numbers)"]
    - [gidx_qn_len,      "Pattern.groupindex.__qualname__.__len__",       [],                      18,    "re.Pattern.groupindex.__qualname__.__len__() == 18 ('Pattern.groupindex' has 18 chars; longest Pattern descriptor qualname)"]
    - [gidx_gt_groups,   "Pattern.groupindex.__qualname__.__len__.__gt__", [14],                   true,  "len('Pattern.groupindex') > len('Pattern.groups') (18 > 14; groupindex is 4 chars longer than groups)"]
    - [gidx_type_ne_md,  "Pattern.groupindex.__class__.__name__.__eq__",  ["member_descriptor"],   false, "type(re.Pattern.groupindex).__name__ != 'member_descriptor' (it is 'getset_descriptor', not 'member_descriptor' like pattern/flags/groups)"]
    - [groups_ne_gidx,   "Pattern.groups.__qualname__.__eq__",            ["Pattern.groupindex"],  false, "re.Pattern.groups.__qualname__ != 'Pattern.groupindex' (distinct qualnames; groups(14) stores a count, groupindex(18) stores a name mapping)"]

# ---------------------------------------------------------------------------
# Pattern descriptor type comparison: member_descriptor vs getset_descriptor
# pattern/flags/groups are all 'member_descriptor' (direct C struct member slots).
# groupindex is a 'getset_descriptor' (tp_getset entry with custom getter/setter).
# The descriptor type hierarchy: flags(13) < groups(14) < pattern(15) < groupindex(18).
# All four qualnames use the 'Pattern.' prefix (8 chars).
# ---------------------------------------------------------------------------

table re_extra115.Pattern_descriptor_type_summary:
  description: "re.Pattern descriptor type summary: pattern/flags/groups are 'member_descriptor' (direct C members); groupindex is 'getset_descriptor'; length ordering: flags(13) < groups(14) < pattern(15) < groupindex(18)"
  kind: python_call_eq
  category: qualnames
  id_prefix: repatdesc115c

  columns: [id, function, args, expected, description]
  rows:
    - [pat_md_type,      "Pattern.pattern.__class__.__name__.__eq__",     ["member_descriptor"],   true,  "re.Pattern.pattern type is 'member_descriptor' (direct C struct member; same type as flags and groups)"]
    - [flags_md_type,    "Pattern.flags.__class__.__name__.__eq__",       ["member_descriptor"],   true,  "re.Pattern.flags type is 'member_descriptor' (same 'member_descriptor' type as pattern)"]
    - [groups_md_type,   "Pattern.groups.__class__.__name__.__eq__",      ["member_descriptor"],   true,  "re.Pattern.groups type is 'member_descriptor' (same 'member_descriptor' type as pattern and flags)"]
    - [gidx_gs_type,     "Pattern.groupindex.__class__.__name__.__eq__",  ["getset_descriptor"],   true,  "re.Pattern.groupindex type is 'getset_descriptor' (distinct from the three member_descriptor attributes; uses a custom getter function)"]
    - [flags_shortest,   "Pattern.flags.__qualname__.__len__.__lt__",     [14],                    true,  "len('Pattern.flags') < len('Pattern.groups') (13 < 14; flags is the shortest Pattern descriptor qualname)"]
    - [gidx_longest,     "Pattern.groupindex.__qualname__.__len__.__gt__", [15],                   true,  "len('Pattern.groupindex') > len('Pattern.pattern') (18 > 15; groupindex is the longest Pattern descriptor qualname)"]
    - [pat_between,      "Pattern.pattern.__qualname__.__len__.__gt__",   [14],                    true,  "len('Pattern.pattern') > len('Pattern.groups') (15 > 14; pattern is between groups and groupindex in qualname length)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra115.Pattern.pattern_qualname_eq:
  description: "re.Pattern.pattern.__qualname__ == 'Pattern.pattern' (length 15; type is 'member_descriptor' — a direct C struct member slot exposed via tp_members in _sre.c; 'Pattern.'(8) + 'pattern'(7) == 15; the .pattern attribute stores the original pattern string passed to re.compile(); re_extra37 covered this length via Pattern.__dict__['pattern'].__qualname__.__len__(); this spec verifies the string equality via direct attribute access Pattern.pattern.__qualname__.__eq__())"
  category: qualnames
  kind: python_call_eq
  function: "Pattern.pattern.__qualname__.__eq__"
  args: ["Pattern.pattern"]
  expected: true

invariant re_extra115.Pattern.flags_qualname_len:
  description: "re.Pattern.flags.__qualname__.__len__() == 13 ('Pattern.flags' has 13 characters; 'Pattern.'(8) + 'flags'(5) == 13; type is 'member_descriptor'; flags is the shortest qualname among the four Pattern descriptor attributes — flags(13) < groups(14) < pattern(15) < groupindex(18); the .flags attribute stores the compiled integer flags value combining re.IGNORECASE, re.MULTILINE, re.DOTALL, etc.)"
  category: qualnames
  kind: python_call_eq
  function: "Pattern.flags.__qualname__.__len__"
  args: []
  expected: 13

invariant re_extra115.Pattern.groups_qualname_eq:
  description: "re.Pattern.groups.__qualname__ == 'Pattern.groups' (length 14; type is 'member_descriptor'; 'Pattern.'(8) + 'groups'(6) == 14; the .groups attribute stores the integer count of capturing groups in the compiled pattern; for example re.compile(r'(a)(b)').groups == 2; this is a direct C struct member, not a computed property like groupindex)"
  category: qualnames
  kind: python_call_eq
  function: "Pattern.groups.__qualname__.__eq__"
  args: ["Pattern.groups"]
  expected: true

invariant re_extra115.Pattern.groupindex_qualname_len:
  description: "re.Pattern.groupindex.__qualname__.__len__() == 18 ('Pattern.groupindex' has 18 characters; 'Pattern.'(8) + 'groupindex'(10) == 18; type is 'getset_descriptor' — distinct from the 'member_descriptor' type used by pattern/flags/groups; groupindex stores a dict mapping named group names to their group numbers; it is the longest Pattern descriptor qualname at 18 chars)"
  category: qualnames
  kind: python_call_eq
  function: "Pattern.groupindex.__qualname__.__len__"
  args: []
  expected: 18

invariant re_extra115.Pattern.groupindex_is_getset_descriptor:
  description: "type(re.Pattern.groupindex).__name__ == 'getset_descriptor' (unlike the other three Pattern descriptor attributes pattern/flags/groups which are 'member_descriptor', groupindex uses a tp_getset entry in _sre.c because it requires constructing a Python dict from internal C data rather than simply reading a C struct member field; this makes groupindex.__class__.__name__ == 'getset_descriptor' not 'member_descriptor')"
  category: qualnames
  kind: python_call_eq
  function: "Pattern.groupindex.__class__.__name__.__eq__"
  args: ["getset_descriptor"]
  expected: true

