spec: concurrent_futures_extra1426
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures: Launching parallel tasks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "Wave 542 (_extra1426): focuses on __format__ and __dir__ method type and dict-presence checks for concurrent.futures classes."
    - "All concurrent.futures classes (Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor) have __format__ with type 'method_descriptor'."
    - "All concurrent.futures classes have __dir__ with type 'method_descriptor'."
    - "None of these classes define __format__ or __dir__ in their own __dict__ — both are inherited from object."
    - "concurrent.futures.Future.__format__.__class__.__name__ == 'method_descriptor'; '__format__' not in concurrent.futures.Future.__dict__."
    - "concurrent.futures.Executor.__format__.__class__.__name__ == 'method_descriptor'; '__format__' not in concurrent.futures.Executor.__dict__."
    - "concurrent.futures.ThreadPoolExecutor.__dir__.__class__.__name__ == 'method_descriptor'; '__dir__' not in ThreadPoolExecutor.__dict__."
    - "concurrent.futures.ProcessPoolExecutor.__dir__.__class__.__name__ == 'method_descriptor'; '__dir__' not in ProcessPoolExecutor.__dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra1426.format_class_name:
  description: "concurrent.futures class __format__.__class__.__name__ identity checks — Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor all inherit __format__ from object; type is 'method_descriptor' for all; verified with Python 3.14.3"
  kind: python_call_eq
  category: format_class_name
  id_prefix: cf1426fm
  columns: [id, function, args, expected]
  rows:
    - [cf1426fm001, concurrent.futures.Future.__format__.__class__.__name__.__eq__,              ["method_descriptor"], true]
    - [cf1426fm002, concurrent.futures.Executor.__format__.__class__.__name__.__eq__,            ["method_descriptor"], true]
    - [cf1426fm003, concurrent.futures.ThreadPoolExecutor.__format__.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [cf1426fm004, concurrent.futures.ProcessPoolExecutor.__format__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [cf1426fm005, concurrent.futures.Future.__format__.__class__.__name__.__eq__,              ["method_descriptor"], true]
    - [cf1426fm006, concurrent.futures.Executor.__format__.__class__.__name__.__eq__,            ["method_descriptor"], true]

table concurrent_futures_extra1426.format_not_in_dict:
  description: "concurrent.futures class __format__ absence from own __dict__ — none of Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor define __format__ directly; all inherit from object; __dict__.__contains__('__format__') is False for each; verified with Python 3.14.3"
  kind: python_call_eq
  category: format_dict_membership
  id_prefix: cf1426fd
  columns: [id, function, args, expected]
  rows:
    - [cf1426fd001, concurrent.futures.Future.__dict__.__contains__,              ["__format__"], false]
    - [cf1426fd002, concurrent.futures.Executor.__dict__.__contains__,            ["__format__"], false]
    - [cf1426fd003, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__format__"], false]
    - [cf1426fd004, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__format__"], false]
    - [cf1426fd005, concurrent.futures.Future.__dict__.__contains__,              ["__dir__"], false]
    - [cf1426fd006, concurrent.futures.Executor.__dict__.__contains__,            ["__dir__"], false]

table concurrent_futures_extra1426.dir_class_name:
  description: "concurrent.futures class __dir__.__class__.__name__ identity checks — all classes inherit __dir__ from object; type is 'method_descriptor'; none define __dir__ in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: dir_class_name
  id_prefix: cf1426dr
  columns: [id, function, args, expected]
  rows:
    - [cf1426dr001, concurrent.futures.Future.__dir__.__class__.__name__.__eq__,              ["method_descriptor"], true]
    - [cf1426dr002, concurrent.futures.Executor.__dir__.__class__.__name__.__eq__,            ["method_descriptor"], true]
    - [cf1426dr003, concurrent.futures.ThreadPoolExecutor.__dir__.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [cf1426dr004, concurrent.futures.ProcessPoolExecutor.__dir__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [cf1426dr005, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,              ["__dir__"], false]
    - [cf1426dr006, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,             ["__dir__"], false]
