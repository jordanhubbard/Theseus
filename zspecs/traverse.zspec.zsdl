spec: traverse
version: ">=0.6.0"
backend: node(traverse)

docs: https://www.npmjs.com/package/traverse

provenance:
  derived_from:
    - "traverse README — https://www.npmjs.com/package/traverse"
    - "Test vectors verified with traverse via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "traverse source"
  notes:
    - "traverse is an npm package. Install: npm install traverse"
    - "traverse(obj).paths() returns all paths in the object as arrays (DFS order)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of path arrays."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table traverse.paths:
  kind: node_factory_call_eq
  factory: ~
  method: paths
  category: traverse
  id_prefix: travpaths

  columns: [id, factory_args, expected]
  rows:
    - [flat,   [{"a": 1, "b": 2}],
       [[], ["a"], ["b"]]]
    - [nested, [{"a": 1, "b": {"c": 2}}],
       [[], ["a"], ["b"], ["b", "c"]]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:50:58Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
