spec: inspect_extra226
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect module __dict__ membership checks for predicate functions, utilities, and public classes."
    - "inspect.__dict__.__contains__('isfunction') == True — isfunction is a predicate function in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('isclass') == True — isclass is a predicate function in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('ismodule') == True — ismodule is a predicate function in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('isbuiltin') == True — isbuiltin is a predicate function in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('signature') == True — signature is a utility function in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('getmembers') == True — getmembers is a utility function in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('getsource') == True — getsource is a source retrieval function in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('getfile') == True — getfile is a source retrieval function in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('getdoc') == True — getdoc is a docstring retrieval function in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('Parameter') == True — Parameter is a public class in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('Signature') == True — Signature is a public class in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('BoundArguments') == True — BoundArguments is a public class in inspect. Verified with Python 3.14.3."
    - "inspect.__dict__.__contains__('FrameInfo') == True — FrameInfo is a named tuple class in inspect. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.__dict__.__contains__ — predicate functions
#
# inspect.__dict__.__contains__('isfunction') == True
# inspect.__dict__.__contains__('isclass') == True
# inspect.__dict__.__contains__('ismodule') == True
# inspect.__dict__.__contains__('isbuiltin') == True
#
# These are predicate functions defined in Lib/inspect.py. New to extra226.
# ---------------------------------------------------------------------------

table inspect_extra226.module_dict_contains_predicates:
  description: "inspect.__dict__.__contains__: isfunction True, isclass True, ismodule True, isbuiltin True; predicate functions; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra226dictpred

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_isfunction,
       __dict__.__contains__,
       ["isfunction"],
       true,
       "inspect.__dict__.__contains__('isfunction') == True — isfunction is a predicate function registered in the inspect module dict; it returns True if the object is a Python function created by a def statement; dict.__contains__('isfunction') returns True; new to extra226"]
    - [dict_contains_isclass,
       __dict__.__contains__,
       ["isclass"],
       true,
       "inspect.__dict__.__contains__('isclass') == True — isclass is a predicate function registered in the inspect module dict; it returns True if the object is a class; dict.__contains__('isclass') returns True; new to extra226"]
    - [dict_contains_ismodule,
       __dict__.__contains__,
       ["ismodule"],
       true,
       "inspect.__dict__.__contains__('ismodule') == True — ismodule is a predicate function registered in the inspect module dict; it returns True if the object is a module; dict.__contains__('ismodule') returns True; new to extra226"]
    - [dict_contains_isbuiltin,
       __dict__.__contains__,
       ["isbuiltin"],
       true,
       "inspect.__dict__.__contains__('isbuiltin') == True — isbuiltin is a predicate function registered in the inspect module dict; it returns True if the object is a built-in function or method; dict.__contains__('isbuiltin') returns True; new to extra226"]

# ---------------------------------------------------------------------------
# Table 2: inspect.__dict__.__contains__ — utility and retrieval functions
#
# inspect.__dict__.__contains__('signature') == True
# inspect.__dict__.__contains__('getmembers') == True
# inspect.__dict__.__contains__('getsource') == True
# inspect.__dict__.__contains__('getfile') == True
# inspect.__dict__.__contains__('getdoc') == True
#
# These are utility and retrieval functions defined in Lib/inspect.py. New to extra226.
# ---------------------------------------------------------------------------

table inspect_extra226.module_dict_contains_utilities:
  description: "inspect.__dict__.__contains__: signature True, getmembers True, getsource True, getfile True, getdoc True; utility functions; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra226dictutil

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_signature,
       __dict__.__contains__,
       ["signature"],
       true,
       "inspect.__dict__.__contains__('signature') == True — signature is a utility function registered in the inspect module dict; it returns a Signature object for the given callable; dict.__contains__('signature') returns True; new to extra226"]
    - [dict_contains_getmembers,
       __dict__.__contains__,
       ["getmembers"],
       true,
       "inspect.__dict__.__contains__('getmembers') == True — getmembers is a utility function registered in the inspect module dict; it returns all attributes of an object as (name, value) pairs; dict.__contains__('getmembers') returns True; new to extra226"]
    - [dict_contains_getsource,
       __dict__.__contains__,
       ["getsource"],
       true,
       "inspect.__dict__.__contains__('getsource') == True — getsource is a source retrieval function registered in the inspect module dict; it returns the source code text of a Python object; dict.__contains__('getsource') returns True; new to extra226"]
    - [dict_contains_getfile,
       __dict__.__contains__,
       ["getfile"],
       true,
       "inspect.__dict__.__contains__('getfile') == True — getfile is a source retrieval function registered in the inspect module dict; it returns the Python source file in which an object was defined; dict.__contains__('getfile') returns True; new to extra226"]
    - [dict_contains_getdoc,
       __dict__.__contains__,
       ["getdoc"],
       true,
       "inspect.__dict__.__contains__('getdoc') == True — getdoc is a docstring retrieval function registered in the inspect module dict; it returns the docstring for an object with leading whitespace stripped; dict.__contains__('getdoc') returns True; new to extra226"]

# ---------------------------------------------------------------------------
# Table 3: inspect.__dict__.__contains__ — public classes
#
# inspect.__dict__.__contains__('Parameter') == True
# inspect.__dict__.__contains__('Signature') == True
# inspect.__dict__.__contains__('BoundArguments') == True
# inspect.__dict__.__contains__('FrameInfo') == True
#
# These are public classes defined in Lib/inspect.py. New to extra226.
# ---------------------------------------------------------------------------

table inspect_extra226.module_dict_contains_classes:
  description: "inspect.__dict__.__contains__: Parameter True, Signature True, BoundArguments True, FrameInfo True; public classes; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra226dictcls

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_parameter,
       __dict__.__contains__,
       ["Parameter"],
       true,
       "inspect.__dict__.__contains__('Parameter') == True — Parameter is a public class registered in the inspect module dict; it represents a parameter in a function signature; dict.__contains__('Parameter') returns True; new to extra226"]
    - [dict_contains_signature_cls,
       __dict__.__contains__,
       ["Signature"],
       true,
       "inspect.__dict__.__contains__('Signature') == True — Signature is a public class registered in the inspect module dict; it represents the call signature of a callable object; dict.__contains__('Signature') returns True; new to extra226"]
    - [dict_contains_bound_arguments,
       __dict__.__contains__,
       ["BoundArguments"],
       true,
       "inspect.__dict__.__contains__('BoundArguments') == True — BoundArguments is a public class registered in the inspect module dict; it holds the result of Signature.bind(); dict.__contains__('BoundArguments') returns True; new to extra226"]
    - [dict_contains_frame_info,
       __dict__.__contains__,
       ["FrameInfo"],
       true,
       "inspect.__dict__.__contains__('FrameInfo') == True — FrameInfo is a named tuple class registered in the inspect module dict; it holds information about a frame in the call stack; dict.__contains__('FrameInfo') returns True; new to extra226"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra226
# ---------------------------------------------------------------------------

invariant inspect_extra226.dict_contains_isfunction:
  description: "inspect.__dict__.__contains__('isfunction') == True — isfunction is in module dict; new to extra226"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["isfunction"]
  expected: true

invariant inspect_extra226.dict_contains_isclass:
  description: "inspect.__dict__.__contains__('isclass') == True — isclass is in module dict; new to extra226"
