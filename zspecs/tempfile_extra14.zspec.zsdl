spec: tempfile_extra14
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
    - "tempfile_extra13.zspec.zsdl — covers __qualname__ equality for mkstemp/mkdtemp/gettempdir/gettempprefix; __module__ table; NamedTemporaryFile.__class__.__name__"
  notes:
    - "This spec extends tempfile.zspec.zsdl and all prior tempfile_extra specs through tempfile_extra13.zspec.zsdl."
    - "Focus: __qualname__ for NamedTemporaryFile/TemporaryDirectory/SpooledTemporaryFile/TemporaryFile, and tempdir default value."
    - "tempfile.NamedTemporaryFile.__qualname__ == 'NamedTemporaryFile' — NamedTemporaryFile is a factory function; its __qualname__ equals the function name; no prior tempfile spec covers NamedTemporaryFile.__qualname__ in equality form."
    - "tempfile.TemporaryDirectory.__qualname__ == 'TemporaryDirectory' — TemporaryDirectory is a class; its __qualname__ equals the class name; not covered in prior specs."
    - "tempfile.SpooledTemporaryFile.__qualname__ == 'SpooledTemporaryFile' — no prior tempfile spec covers SpooledTemporaryFile.__qualname__."
    - "tempfile.TemporaryFile.__qualname__ == 'TemporaryFile' — TemporaryFile is a factory function on POSIX; no prior tempfile spec covers TemporaryFile.__qualname__."
    - "tempfile.tempdir is None by default — the module-level tempdir variable is None unless explicitly set by the user; no prior tempfile spec covers tempdir == None as a standalone invariant."
    - "Qualname length facts: NamedTemporaryFile=18, TemporaryDirectory=18, SpooledTemporaryFile=20, TemporaryFile=13."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ equality table — class/factory qualnames
#
# tempfile_extra13 covers __qualname__ for mkstemp/mkdtemp/gettempdir/
# gettempprefix but not for the class/factory names. This table fills that
# gap. NamedTemporaryFile and TemporaryFile are factory functions; their
# __qualname__ equals the function name. TemporaryDirectory and
# SpooledTemporaryFile are classes; their __qualname__ equals the class name.
# ---------------------------------------------------------------------------

table tempfile_extra14.class_qualnames:
  description: "__qualname__ equals the plain name for tempfile classes and factory functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: tqname14

  columns: [id, function, args, expected]
  rows:
    - [NamedTemporaryFile,   NamedTemporaryFile.__qualname__.__eq__,   ["NamedTemporaryFile"],   true]
    - [TemporaryDirectory,   TemporaryDirectory.__qualname__.__eq__,   ["TemporaryDirectory"],   true]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__qualname__.__eq__, ["SpooledTemporaryFile"], true]
    - [TemporaryFile,        TemporaryFile.__qualname__.__eq__,        ["TemporaryFile"],        true]

# ---------------------------------------------------------------------------
# tempfile.tempdir default value — None
#
# tempfile.tempdir is a module-level variable that controls the default
# directory used by tempfile functions. It is None by default, meaning
# the OS-level temporary directory is used. No prior tempfile spec covers
# tempdir == None as a standalone invariant.
# ---------------------------------------------------------------------------

invariant tempfile_extra14.tempdir.is_none:
  description: "tempfile.tempdir is None by default — module-level override is unset"
  category: module_state
  kind: python_call_eq
  function: tempdir.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ length invariants — NamedTemporaryFile, TemporaryDirectory,
#                                  SpooledTemporaryFile, TemporaryFile
#
# Length of __qualname__ is a distinct axis from equality. These standalone
# invariants anchor the qualname lengths for each tempfile class/factory
# in the extra14 namespace.
# ---------------------------------------------------------------------------

invariant tempfile_extra14.NamedTemporaryFile.qualname_length:
  description: "tempfile.NamedTemporaryFile.__qualname__.__len__() == 18 — 'NamedTemporaryFile' has 18 characters"
  category: function_identity
  kind: python_call_eq
  function: NamedTemporaryFile.__qualname__.__len__
  args: []
  expected: 18

invariant tempfile_extra14.TemporaryDirectory.qualname_length:
  description: "tempfile.TemporaryDirectory.__qualname__.__len__() == 18 — 'TemporaryDirectory' has 18 characters"
  category: function_identity
  kind: python_call_eq
  function: TemporaryDirectory.__qualname__.__len__
  args: []
  expected: 18

invariant tempfile_extra14.SpooledTemporaryFile.qualname_length:
  description: "tempfile.SpooledTemporaryFile.__qualname__.__len__() == 20 — 'SpooledTemporaryFile' has 20 characters"
  category: function_identity
  kind: python_call_eq
  function: SpooledTemporaryFile.__qualname__.__len__
  args: []
  expected: 20

invariant tempfile_extra14.TemporaryFile.qualname_length:
  description: "tempfile.TemporaryFile.__qualname__.__len__() == 13 — 'TemporaryFile' has 13 characters"
  category: function_identity
  kind: python_call_eq
  function: TemporaryFile.__qualname__.__len__
  args: []
  expected: 13
