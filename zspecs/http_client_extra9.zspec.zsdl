spec: http_client_extra9
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client_extra covers: HTTPException/__bases__[0].__name__=='Exception'; NotConnected/InvalidURL __bases__[0].__name__=='HTTPException'."
    - "http_client_extra3 covers: BadStatusLine/__bases__[0].__name__=='HTTPException'; RemoteDisconnected/__bases__[0].__name__=='BadStatusLine'."
    - "http_client_extra4 covers: ImproperConnectionState/__bases__[0].__name__=='HTTPException'; IncompleteRead/__bases__[0].__name__=='HTTPException'."
    - "http_client_extra5 covers: CannotSendRequest/CannotSendHeader __bases__[0].__name__=='ImproperConnectionState'."
    - "http_client_extra8 covers: HTTPException/NotConnected/InvalidURL __name__.__eq__(); HTTPException.__bases__[0].__name__ via __getitem__; responses[200/404/500]."
  notes:
    - "This spec extends http_client through http_client_extra8; it does NOT duplicate invariants in any prior spec."
    - "Focus: __bases__[0].__name__ checks for HTTPSConnection, HTTPResponse, and LineTooLong (not yet covered); __name__.__len__() checks for key http.client classes (no prior spec uses __len__ in this module)."
    - "http.client.HTTPSConnection.__bases__[0].__name__ == 'HTTPConnection': HTTPSConnection inherits from HTTPConnection. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.__bases__[0].__name__ == 'BufferedIOBase': HTTPResponse inherits from io.BufferedIOBase. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.LineTooLong.__bases__[0].__name__ == 'HTTPException': LineTooLong is a direct HTTPException subclass. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "len('HTTPSConnection') == 15; len('HTTPResponse') == 12; len('HTTPConnection') == 14; len('BadStatusLine') == 13; len('LineTooLong') == 11. No prior http.client spec checks any __name__.__len__()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTTPSConnection, HTTPResponse, LineTooLong — base class hierarchy
#
# http_client_extra covers HTTPException/NotConnected/InvalidURL bases.
# http_client_extra3 covers BadStatusLine/RemoteDisconnected bases.
# http_client_extra4 covers ImproperConnectionState/IncompleteRead bases.
# http_client_extra5 covers CannotSendRequest/CannotSendHeader bases.
# HTTPSConnection, HTTPResponse, and LineTooLong bases are not yet covered.
# ---------------------------------------------------------------------------

invariant http_client_extra9.HTTPSConnection.base_name:
  description: "http.client.HTTPSConnection.__bases__[0].__name__ == 'HTTPConnection' — HTTPS inherits from HTTP"
  category: class_hierarchy
  kind: python_call_eq
  function: "HTTPSConnection.__bases__[0].__name__.__eq__"
  args: ["HTTPConnection"]
  expected: true

invariant http_client_extra9.HTTPResponse.base_name:
  description: "http.client.HTTPResponse.__bases__[0].__name__ == 'BufferedIOBase' — HTTPResponse inherits from io.BufferedIOBase"
  category: class_hierarchy
  kind: python_call_eq
  function: "HTTPResponse.__bases__[0].__name__.__eq__"
  args: ["BufferedIOBase"]
  expected: true

invariant http_client_extra9.LineTooLong.base_name:
  description: "http.client.LineTooLong.__bases__[0].__name__ == 'HTTPException' — LineTooLong is a direct HTTPException subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: "LineTooLong.__bases__[0].__name__.__eq__"
  args: ["HTTPException"]
  expected: true

# ---------------------------------------------------------------------------
# __name__.__len__() checks for http.client classes
#
# No prior http.client spec uses __len__() at all. These are the first
# name-length invariants for this module.
# len('HTTPSConnection') == 15; len('HTTPResponse') == 12;
# len('HTTPConnection') == 14; len('BadStatusLine') == 13;
# len('LineTooLong') == 11.
# ---------------------------------------------------------------------------

table http_client_extra9.class_name_lengths:
  description: "Length of __name__ strings for key http.client classes"
  kind: python_call_eq
  category: class_metadata
  id_prefix: hcnamelen9

  columns: [id, function, args, expected]
  rows:
    - [HTTPSConnection, HTTPSConnection.__name__.__len__, [], 15]
    - [HTTPResponse,    HTTPResponse.__name__.__len__,    [], 12]
    - [HTTPConnection,  HTTPConnection.__name__.__len__,  [], 14]
    - [BadStatusLine,   BadStatusLine.__name__.__len__,   [], 13]
    - [LineTooLong,     LineTooLong.__name__.__len__,     [], 11]

# ---------------------------------------------------------------------------
# HTTPSConnection.__bases__[0].__name__.__len__() == 14
#
# HTTPSConnection's base is HTTPConnection; len('HTTPConnection') == 14.
# No prior spec checks the length of any base class name string in http.client.
# This is a new execution path combining __bases__ subscript and __len__.
# ---------------------------------------------------------------------------

invariant http_client_extra9.HTTPSConnection.base_name_len:
  description: "len(http.client.HTTPSConnection.__bases__[0].__name__) == 14 — len('HTTPConnection') == 14"
  category: class_hierarchy
  kind: python_call_eq
  function: "HTTPSConnection.__bases__[0].__name__.__len__"
  args: []
  expected: 14
