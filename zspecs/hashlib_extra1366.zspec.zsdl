spec: hashlib_extra1366
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks."
    - "hashlib.new('md5').__class__ is _hashlib.HASH — a C extension type; __flags__, __basicsize__, and __itemsize__ are C-level integer attributes present on every type object."
    - "hashlib.new('md5').__class__.__flags__.__class__.__name__ == 'int' — __flags__ is always an int on all CPython type objects."
    - "hashlib.new('md5').__class__.__basicsize__.__class__.__name__ == 'int' — __basicsize__ reports the C struct size in bytes; always an int."
    - "hashlib.new('md5').__class__.__itemsize__.__class__.__name__ == 'int' — __itemsize__ reports the per-element size for variable-length types; always an int (0 for fixed-size types)."
    - "hashlib.md5.__class__ is builtin_function_or_method; type(hashlib.md5).__flags__.__class__.__name__ == 'int'."
    - "set.__flags__, set.__basicsize__, set.__itemsize__ are all int — set is the type of hashlib.algorithms_guaranteed."
    - "Exact integer values are not checked; they are platform-specific and may vary across CPython builds."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra1366.hash_class_flags_basicsize_itemsize:
  description: "hashlib HASH C extension class __flags__, __basicsize__, __itemsize__ type-name checks; all three C-type attributes must be int"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: hl1366hf
  columns: [id, function, args, expected]
  rows:
    - [hl1366hf001, hashlib.new("md5").__class__.__flags__.__class__.__name__.__eq__,      ["int"], true]
    - [hl1366hf002, hashlib.new("md5").__class__.__basicsize__.__class__.__name__.__eq__,  ["int"], true]
    - [hl1366hf003, hashlib.new("md5").__class__.__itemsize__.__class__.__name__.__eq__,   ["int"], true]
    - [hl1366hf004, hashlib.new("sha256").__class__.__flags__.__class__.__name__.__eq__,   ["int"], true]
    - [hl1366hf005, hashlib.new("sha256").__class__.__basicsize__.__class__.__name__.__eq__,["int"], true]
    - [hl1366hf006, hashlib.new("sha256").__class__.__itemsize__.__class__.__name__.__eq__,["int"], true]

table hashlib_extra1366.builtin_function_class_flags_basicsize:
  description: "type(hashlib.md5) is builtin_function_or_method; its __flags__ and __basicsize__ are int on all CPython builds"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: hl1366bf
  columns: [id, function, args, expected]
  rows:
    - [hl1366bf001, hashlib.md5.__class__.__flags__.__class__.__name__.__eq__,     ["int"], true]
    - [hl1366bf002, hashlib.md5.__class__.__basicsize__.__class__.__name__.__eq__, ["int"], true]
    - [hl1366bf003, hashlib.md5.__class__.__itemsize__.__class__.__name__.__eq__,  ["int"], true]
    - [hl1366bf004, hashlib.sha256.__class__.__flags__.__class__.__name__.__eq__,  ["int"], true]
    - [hl1366bf005, hashlib.sha256.__class__.__basicsize__.__class__.__name__.__eq__,["int"], true]
    - [hl1366bf006, hashlib.sha256.__class__.__itemsize__.__class__.__name__.__eq__,["int"], true]

table hashlib_extra1366.set_class_flags_basicsize_itemsize:
  description: "set (the type of hashlib.algorithms_guaranteed) __flags__, __basicsize__, __itemsize__ type-name checks; set is a C builtin type and all three attributes are int"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: hl1366sf
  columns: [id, function, args, expected]
  rows:
    - [hl1366sf001, set.__flags__.__class__.__name__.__eq__,          ["int"], true]
    - [hl1366sf002, set.__basicsize__.__class__.__name__.__eq__,      ["int"], true]
    - [hl1366sf003, set.__itemsize__.__class__.__name__.__eq__,       ["int"], true]
    - [hl1366sf004, frozenset.__flags__.__class__.__name__.__eq__,    ["int"], true]
    - [hl1366sf005, frozenset.__basicsize__.__class__.__name__.__eq__, ["int"], true]
    - [hl1366sf006, frozenset.__itemsize__.__class__.__name__.__eq__,  ["int"], true]
