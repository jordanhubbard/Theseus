spec: dis_extra16
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis_extra14.zspec.zsdl — covers opmap __contains__ table; opmap.__len__() >= 50; Instruction/Bytecode __name__ and __module__; stack_effect/get_instructions __module__"
    - "dis_extra15.zspec.zsdl — covers Bytecode/__qualname__; Instruction/__qualname__; function_modules table (findlinestarts/findlabels/get_instructions/stack_effect/dis); opname item0 type; opmap class/len; cmp_op class; HAVE_ARGUMENT.__ge__(1)"
  notes:
    - "This spec extends dis_extra15.zspec.zsdl."
    - "dis.Bytecode.__module__ — dis_extra14 covers this in the dis_extra14 namespace; distinct standalone ID in dis_extra16 namespace."
    - "dis.Instruction.__module__ — dis_extra14 covers this in the dis_extra14 namespace; distinct standalone ID in dis_extra16 namespace."
    - "dis.Bytecode/__qualname__ and dis.Instruction/__qualname__ — dis_extra15 covers these; distinct standalone IDs in dis_extra16 namespace."
    - "dis.COMPILER_FLAG_NAMES.__class__.__name__ == 'dict' — the attribute is COMPILER_FLAG_NAMES (not COMPILER_FLAGS); verified with Python 3.14.3."
    - "dis.hasarg/__class__.__name__ == 'list' — hasarg/hasjrel/hasjabs/hasjump are all lists of opcode integers."
    - "dis.hasjump exists in Python 3.12+; verified present in Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Bytecode and Instruction — __module__ (dis_extra16 namespace)
#
# dis_extra14 covers __module__ for Bytecode and Instruction in the dis_extra14
# namespace. These are distinct standalone IDs in the dis_extra16 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra16.Bytecode.module:
  description: "dis.Bytecode.__module__ == 'dis' — Bytecode class is defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: Bytecode.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra16.Instruction.module:
  description: "dis.Instruction.__module__ == 'dis' — Instruction class is defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: Instruction.__module__.__eq__
  args: ["dis"]
  expected: true

# ---------------------------------------------------------------------------
# Bytecode and Instruction — __qualname__ (dis_extra16 namespace)
#
# dis_extra15 covers __qualname__ for Bytecode and Instruction in the dis_extra15
# namespace. These are distinct standalone IDs in the dis_extra16 namespace.
# ---------------------------------------------------------------------------

table dis_extra16.class_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Bytecode,     Bytecode.__qualname__.__eq__,     ["Bytecode"],     true]
    - [Instruction,  Instruction.__qualname__.__eq__,  ["Instruction"],  true]

# ---------------------------------------------------------------------------
# COMPILER_FLAG_NAMES — __class__.__name__ (dis_extra16 namespace)
#
# dis.COMPILER_FLAG_NAMES is a dict mapping compiler flag bit positions to names.
# (Note: the attribute is COMPILER_FLAG_NAMES, not COMPILER_FLAGS.)
# No prior dis spec verifies COMPILER_FLAG_NAMES.__class__.__name__ in the
# dis_extra16 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra16.COMPILER_FLAG_NAMES.class_is_dict:
  description: "dis.COMPILER_FLAG_NAMES.__class__.__name__ == 'dict' — COMPILER_FLAG_NAMES is a dict mapping flag bits to names"
  category: class_names
  kind: python_call_eq
  function: COMPILER_FLAG_NAMES.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# has* opcode lists — __class__.__name__ (dis_extra16 namespace)
#
# dis_extra12 covers hasjump.__class__.__name__ in the dis_extra12 namespace.
# No prior dis spec verifies hasarg/hasjrel/hasjabs/hasjump __class__.__name__
# together as a table in the dis_extra16 namespace.
# ---------------------------------------------------------------------------

table dis_extra16.has_lists_class:
  kind: python_call_eq
  category: class_names
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [hasarg,   hasarg.__class__.__name__.__eq__,   ["list"],  true]
    - [hasjrel,  hasjrel.__class__.__name__.__eq__,  ["list"],  true]
    - [hasjabs,  hasjabs.__class__.__name__.__eq__,  ["list"],  true]
    - [hasjump,  hasjump.__class__.__name__.__eq__,  ["list"],  true]
