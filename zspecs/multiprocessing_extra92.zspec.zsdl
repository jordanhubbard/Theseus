spec: multiprocessing_extra92
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra91

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra91.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing exception classes and Process class identity. NEW in extra92: ProcessError.__name__=='ProcessError'; ProcessError.__module__=='multiprocessing.context'; ProcessError.__bases__[0].__name__=='Exception'; ProcessError.__mro__.__len__()==4; BufferTooShort.__module__=='multiprocessing.context'; BufferTooShort.__bases__[0].__name__=='ProcessError'; BufferTooShort.__mro__.__len__()==5; TimeoutError.__module__=='multiprocessing.context'; TimeoutError.__bases__[0].__name__=='ProcessError'; TimeoutError.__mro__.__len__()==5; AuthenticationError.__module__=='multiprocessing.context'; AuthenticationError.__bases__[0].__name__=='ProcessError'; AuthenticationError.__mro__.__len__()==5; Process.__name__=='Process'; Process.__module__=='multiprocessing.context'; Process.__qualname__=='Process'; Process.__bases__[0].__name__=='BaseProcess'; Process.__mro__.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__module__ == 'multiprocessing.context'. ProcessError is defined in Lib/multiprocessing/context.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'. ProcessError is the root of the multiprocessing exception hierarchy; it inherits from Exception. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__mro__.__len__() == 4. MRO is [ProcessError, Exception, BaseException, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'. BufferTooShort inherits from ProcessError. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'. The multiprocessing TimeoutError inherits from ProcessError (not from the builtin OSError-derived TimeoutError). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'. AuthenticationError inherits from ProcessError. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__name__ == 'Process'. Process is a class (not a bound method like Queue). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context'. Process is defined in Lib/multiprocessing/context.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__qualname__ == 'Process'. Process has a simple (non-nested) qualified name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess'. Process inherits from BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__mro__.__len__() == 3. MRO is [Process, BaseProcess, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing exception __name__ and __module__ equality — extra92
#
# Wave 254 theme: multiprocessing exception classes and Process class identity.
#
# ProcessError.__name__ == 'ProcessError', __module__ == 'multiprocessing.context'
# BufferTooShort.__name__ == 'BufferTooShort', __module__ == 'multiprocessing.context'
# TimeoutError.__name__ == 'TimeoutError', __module__ == 'multiprocessing.context'
# AuthenticationError.__name__ == 'AuthenticationError', __module__ == 'multiprocessing.context'
# ---------------------------------------------------------------------------

table multiprocessing_extra92.exception_name_and_module:
  description: "multiprocessing exception __name__ and __module__ equality checks in mpexceptions92 namespace — wave 254 theme: multiprocessing exception classes and Process identity; ProcessError.__name__.__eq__('ProcessError')==True; ProcessError.__module__.__eq__('multiprocessing.context')==True; BufferTooShort.__module__.__eq__('multiprocessing.context')==True; TimeoutError.__module__.__eq__('multiprocessing.context')==True (mp TimeoutError, not builtin); AuthenticationError.__module__.__eq__('multiprocessing.context')==True; all exceptions defined in Lib/multiprocessing/context.py; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpexceptions92

  columns: [id, function, args, expected, description]
  rows:
    - [procerr_name,    ProcessError.__name__.__eq__,         ["ProcessError"],                true, "ProcessError.__name__ == 'ProcessError' — root mp exception class name; verified with Python 3.14.3"]
    - [procerr_module,  ProcessError.__module__.__eq__,       ["multiprocessing.context"],     true, "ProcessError.__module__ == 'multiprocessing.context' — defined in Lib/multiprocessing/context.py; verified with Python 3.14.3"]
    - [buf_name,        BufferTooShort.__name__.__eq__,       ["BufferTooShort"],              true, "BufferTooShort.__name__ == 'BufferTooShort' — exception class name; verified with Python 3.14.3"]
    - [buf_module,      BufferTooShort.__module__.__eq__,     ["multiprocessing.context"],     true, "BufferTooShort.__module__ == 'multiprocessing.context' — defined in Lib/multiprocessing/context.py; verified with Python 3.14.3"]
    - [timeout_name,    TimeoutError.__name__.__eq__,         ["TimeoutError"],                true, "TimeoutError.__name__ == 'TimeoutError' — mp TimeoutError name; verified with Python 3.14.3"]
    - [timeout_module,  TimeoutError.__module__.__eq__,       ["multiprocessing.context"],     true, "TimeoutError.__module__ == 'multiprocessing.context' — mp TimeoutError defined in context.py (not builtins); verified with Python 3.14.3"]
    - [auth_name,       AuthenticationError.__name__.__eq__,  ["AuthenticationError"],         true, "AuthenticationError.__name__ == 'AuthenticationError' — exception class name; verified with Python 3.14.3"]
    - [auth_module,     AuthenticationError.__module__.__eq__, ["multiprocessing.context"],    true, "AuthenticationError.__module__ == 'multiprocessing.context' — defined in Lib/multiprocessing/context.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing exception __bases__[0].__name__ and __mro__.__len__() — extra92
#
# ProcessError.__bases__[0].__name__ == 'Exception', __mro__.__len__() == 4
# BufferTooShort.__bases__[0].__name__ == 'ProcessError', __mro__.__len__() == 5
# TimeoutError.__bases__[0].__name__ == 'ProcessError', __mro__.__len__() == 5
# AuthenticationError.__bases__[0].__name__ == 'ProcessError', __mro__.__len__() == 5
# ---------------------------------------------------------------------------

table multiprocessing_extra92.exception_bases_and_mro:
  description: "multiprocessing exception __bases__[0].__name__ and __mro__.__len__() checks in mpexceptions92 namespace — wave 254 theme: multiprocessing exception classes; ProcessError.__bases__[0].__name__.__eq__('Exception')==True (root exception, inherits from Exception); ProcessError.__mro__.__len__()==4; BufferTooShort.__bases__[0].__name__.__eq__('ProcessError')==True; BufferTooShort.__mro__.__len__()==5; TimeoutError.__bases__[0].__name__.__eq__('ProcessError')==True (mp TimeoutError inherits from ProcessError, not OSError); TimeoutError.__mro__.__len__()==5; AuthenticationError.__bases__[0].__name__.__eq__('ProcessError')==True; AuthenticationError.__mro__.__len__()==5; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpexceptions92a

  columns: [id, function, args, expected, description]
  rows:
    - [procerr_bases0,   "ProcessError.__bases__[0].__name__.__eq__",        ["Exception"],      true, "ProcessError.__bases__[0].__name__ == 'Exception' — root mp exception inherits from Exception; verified with Python 3.14.3"]
    - [procerr_mro_len,  ProcessError.__mro__.__len__,                        [],                 4,    "ProcessError.__mro__.__len__() == 4 — MRO is [ProcessError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [buf_bases0,       "BufferTooShort.__bases__[0].__name__.__eq__",       ["ProcessError"],   true, "BufferTooShort.__bases__[0].__name__ == 'ProcessError' — inherits from ProcessError; verified with Python 3.14.3"]
    - [buf_mro_len,      BufferTooShort.__mro__.__len__,                       [],                 5,    "BufferTooShort.__mro__.__len__() == 5 — MRO is [BufferTooShort, ProcessError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [timeout_bases0,   "TimeoutError.__bases__[0].__name__.__eq__",         ["ProcessError"],   true, "TimeoutError.__bases__[0].__name__ == 'ProcessError' — mp TimeoutError inherits from ProcessError (not OSError); verified with Python 3.14.3"]
    - [timeout_mro_len,  TimeoutError.__mro__.__len__,                         [],                 5,    "TimeoutError.__mro__.__len__() == 5 — MRO is [TimeoutError, ProcessError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [auth_bases0,      "AuthenticationError.__bases__[0].__name__.__eq__",  ["ProcessError"],   true, "AuthenticationError.__bases__[0].__name__ == 'ProcessError' — inherits from ProcessError; verified with Python 3.14.3"]
    - [auth_mro_len,     AuthenticationError.__mro__.__len__,                  [],                 5,    "AuthenticationError.__mro__.__len__() == 5 — MRO is [AuthenticationError, ProcessError, Exception, BaseException, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Process class identity — extra92
#
# Process.__name__ == 'Process'
# Process.__module__ == 'multiprocessing.context'
# Process.__qualname__ == 'Process'
# Process.__bases__[0].__name__ == 'BaseProcess'
# Process.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table multiprocessing_extra92.Process_class_identity:
  description: "multiprocessing Process class identity checks in mpexceptions92 namespace — wave 254 theme: multiprocessing Process class identity; Process.__name__.__eq__('Process')==True (Process is a class, not a bound method like Queue); Process.__module__.__eq__('multiprocessing.context')==True (defined in Lib/multiprocessing/context.py); Process.__qualname__.__eq__('Process')==True; Process.__bases__[0].__name__.__eq__('BaseProcess')==True (inherits from BaseProcess); Process.__mro__.__len__()==3 (MRO is [Process, BaseProcess, object]); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpexceptions92b

  columns: [id, function, args, expected, description]
  rows:
    - [proc_name,       Process.__name__.__eq__,                  ["Process"],                  true, "Process.__name__ == 'Process' — class name; Process is a class not a bound method; verified with Python 3.14.3"]
    - [proc_module,     Process.__module__.__eq__,                ["multiprocessing.context"],  true, "Process.__module__ == 'multiprocessing.context' — defined in Lib/multiprocessing/context.py; verified with Python 3.14.3"]
    - [proc_qualname,   Process.__qualname__.__eq__,              ["Process"],                  true, "Process.__qualname__ == 'Process' — simple (non-nested) qualified name; verified with Python 3.14.3"]
    - [proc_bases0,     "Process.__bases__[0].__name__.__eq__",   ["BaseProcess"],              true, "Process.__bases__[0].__name__ == 'BaseProcess' — Process inherits from BaseProcess; verified with Python 3.14.3"]
    - [proc_mro_len,    Process.__mro__.__len__,                  [],                           3,    "Process.__mro__.__len__() == 3 — MRO is [Process, BaseProcess, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing ProcessError vs exception bases cross-check — extra92
#
# ProcessError is the root of all mp exceptions.
# BufferTooShort, TimeoutError, AuthenticationError all inherit from ProcessError.
# ---------------------------------------------------------------------------

table multiprocessing_extra92.exception_hierarchy_cross_check:
  description: "multiprocessing exception hierarchy cross-check in mpexceptions92 namespace — wave 254 theme: multiprocessing exception hierarchy; all of BufferTooShort, TimeoutError, AuthenticationError inherit from ProcessError; ProcessError.__mro__.__len__()==4 (shorter than its subclasses); BufferTooShort and TimeoutError and AuthenticationError all have mro length 5; Process.__mro__.__len__()==3 (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpexceptions92c

  columns: [id, function, args, expected, description]
  rows:
    - [procerr_mro_cross,  ProcessError.__mro__.__len__,          [], 4, "ProcessError.__mro__.__len__() == 4 — root exception with mro length 4; verified with Python 3.14.3"]
    - [buf_mro_cross,      BufferTooShort.__mro__.__len__,         [], 5, "BufferTooShort.__mro__.__len__() == 5 — subclass of ProcessError, mro length 5; verified with Python 3.14.3"]
    - [timeout_mro_cross,  TimeoutError.__mro__.__len__,           [], 5, "TimeoutError.__mro__.__len__() == 5 — mp TimeoutError, subclass of ProcessError, mro length 5; verified with Python 3.14.3"]
    - [auth_mro_cross,     AuthenticationError.__mro__.__len__,    [], 5, "AuthenticationError.__mro__.__len__() == 5 — subclass of ProcessError, mro length 5; verified with Python 3.14.3"]
    - [proc_mro_cross,     Process.__mro__.__len__,                [], 3, "Process.__mro__.__len__() == 3 — cross-check: Process MRO length is 3; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra92
# ---------------------------------------------------------------------------

invariant multiprocessing_extra92.ProcessError_base_is_Exception:
  description: "multiprocessing.ProcessError.__bases__[0].__name__.__eq__('Exception') returns True — ProcessError is the root of the multiprocessing exception hierarchy; it inherits directly from Exception (not from a more specific base); all other mp exceptions (BufferTooShort, TimeoutError, AuthenticationError) inherit from ProcessError; NEW in extra92: first standalone __bases__ invariant for ProcessError in mpexceptions92 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ProcessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant multiprocessing_extra92.mp_TimeoutError_base_is_ProcessError:
  description: "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__('ProcessError') returns True — the multiprocessing TimeoutError inherits from ProcessError (not from the builtin OSError-derived TimeoutError); this distinguishes it from asyncio.TimeoutError (which is the builtin) and from concurrent.futures.TimeoutError (also builtin); the mp-specific TimeoutError represents process operation timeouts in the multiprocessing context; NEW in extra92: first standalone __bases__ invariant for mp TimeoutError in mpexceptions92 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "TimeoutError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra92.Process_base_is_BaseProcess:
  description: "multiprocessing.Process.__bases__[0].__name__.__eq__('BaseProcess') returns True — Process inherits from BaseProcess (defined in Lib/multiprocessing/process.py); BaseProcess provides the core process management infrastructure; Process is a class (unlike Queue and Pipe which are bound methods of BaseContext); NEW in extra92: first standalone __bases__ invariant for Process in mpexceptions92 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Process.__bases__[0].__name__.__eq__"
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra92.Process_module_is_context:
  description: "multiprocessing.Process.__module__.__eq__('multiprocessing.context') returns True — Process is defined in Lib/multiprocessing/context.py; this is the same module where all the exception classes are defined; Process.__qualname__ is simply 'Process' (not a nested class); NEW in extra92: first standalone __module__ invariant for Process in mpexceptions92 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra92.AuthenticationError_mro_len_five:
  description: "multiprocessing.AuthenticationError.__mro__.__len__() == 5 — AuthenticationError's MRO is [AuthenticationError, ProcessError, Exception, BaseException, object]; the length of 5 is shared by BufferTooShort, TimeoutError, and AuthenticationError — all direct subclasses of ProcessError; AuthenticationError is raised when there is an authentication failure in multiprocessing connections; NEW in extra92: first standalone __mro__.__len__ invariant for AuthenticationError in mpexceptions92 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AuthenticationError.__mro__.__len__
  args: []
  expected: 5
