spec: io_extra83
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra82."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__ membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO lengths; BufferedReader/BufferedWriter/TextIOWrapper __dict__.__class__.__name__ and key method membership; BytesIO/StringIO/FileIO __dict__.__class__.__name__ and membership."
    - "io_extra82 covers BytesIO/StringIO/FileIO __dict__.__class__.__name__ == 'mappingproxy' and key method membership."
    - "This spec covers: UnsupportedOperation __name__/__module__/__qualname__; UnsupportedOperation.__bases__ len and names; UnsupportedOperation.__mro__.__len__(); DEFAULT_BUFFER_SIZE.__class__.__name__ and value; SEEK_SET/SEEK_CUR/SEEK_END __class__.__name__."
    - "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' — the C type's __name__ matches the Python-visible name."
    - "io.UnsupportedOperation.__module__ == 'io' — exported through the io module even though implemented in _io C extension."
    - "io.UnsupportedOperation.__qualname__ == 'UnsupportedOperation' — top-level class, no nesting."
    - "io.UnsupportedOperation.__bases__.__len__() == 2 — UnsupportedOperation inherits from both OSError and ValueError."
    - "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — OSError is the first base class."
    - "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError' — ValueError is the second base class."
    - "io.UnsupportedOperation.__mro__.__len__() == 6 — MRO is [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object]."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — it is a plain Python int."
    - "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True — verified on macOS/Darwin 25.4.0 with Python 3.14.3; value is 131072, not 8192."
    - "io.SEEK_SET.__class__.__name__ == 'int', SEEK_CUR.__class__.__name__ == 'int', SEEK_END.__class__.__name__ == 'int'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UnsupportedOperation class name, module, and qualname
# UnsupportedOperation is a C type exported via the io module.
# __module__ == 'io' (not '_io') because it is re-exported at the io level.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra83.UnsupportedOperation_identity:
  description: "UnsupportedOperation __name__, __module__, __qualname__"
  kind: python_call_eq
  category: class_identity
  id_prefix: iomore83

  columns: [id, function, args, expected]
  rows:
    - [unsupop_name,    UnsupportedOperation.__name__.__eq__,    ["UnsupportedOperation"], true]
    - [unsupop_module,  UnsupportedOperation.__module__.__eq__,  ["io"],                   true]
    - [unsupop_qualname,UnsupportedOperation.__qualname__.__eq__, ["UnsupportedOperation"], true]

# ---------------------------------------------------------------------------
# UnsupportedOperation __bases__ length and names
# UnsupportedOperation uses multiple inheritance: bases are (OSError, ValueError).
# __bases__.__len__() == 2; __bases__[0].__name__ == 'OSError'; __bases__[1].__name__ == 'ValueError'.
# Function values with [ must be double-quoted.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra83.UnsupportedOperation_bases:
  description: "UnsupportedOperation __bases__ length and base class names"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iomore83

  columns: [id, function, args, expected]
  rows:
    - [unsupop_bases_len,  UnsupportedOperation.__bases__.__len__,               [], 2]
    - [unsupop_base0_name, "UnsupportedOperation.__bases__[0].__name__.__eq__",  ["OSError"],    true]
    - [unsupop_base1_name, "UnsupportedOperation.__bases__[1].__name__.__eq__",  ["ValueError"], true]

# ---------------------------------------------------------------------------
# UnsupportedOperation MRO length
# MRO: [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object]
# __mro__.__len__() == 6.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra83.UnsupportedOperation_mro:
  description: "UnsupportedOperation.__mro__.__len__() == 6"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iomore83

  columns: [id, function, args, expected]
  rows:
    - [unsupop_mro_len, UnsupportedOperation.__mro__.__len__, [], 6]

# ---------------------------------------------------------------------------
# DEFAULT_BUFFER_SIZE and SEEK_* constants class name and value
# DEFAULT_BUFFER_SIZE is 131072 on Python 3.14.3 (macOS/Darwin 25.4.0).
# SEEK_SET == 0, SEEK_CUR == 1, SEEK_END == 2; all are plain Python ints.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra83.constants_class_and_value:
  description: "DEFAULT_BUFFER_SIZE and SEEK_* constants __class__.__name__ and value"
  kind: python_call_eq
  category: constants
  id_prefix: iomore83

  columns: [id, function, args, expected]
  rows:
    - [dbs_class,    DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"],   true]
    - [dbs_value,    DEFAULT_BUFFER_SIZE.__eq__,                    [131072],  true]
    - [seek_set_cls, SEEK_SET.__class__.__name__.__eq__,            ["int"],   true]
    - [seek_cur_cls, SEEK_CUR.__class__.__name__.__eq__,            ["int"],   true]
    - [seek_end_cls, SEEK_END.__class__.__name__.__eq__,            ["int"],   true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra83.UnsupportedOperation.name:
  description: "io.UnsupportedOperation.__name__ == 'UnsupportedOperation'"
  category: class_identity
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra83.UnsupportedOperation.module:
  description: "io.UnsupportedOperation.__module__ == 'io'"
  category: class_identity
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra83.UnsupportedOperation.bases_len:
  description: "io.UnsupportedOperation.__bases__.__len__() == 2 (OSError, ValueError)"
  category: class_hierarchy
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__len__
  args: []
  expected: 2

invariant io_extra83.UnsupportedOperation.mro_len:
  description: "io.UnsupportedOperation.__mro__.__len__() == 6 (UnsupportedOperation, OSError, ValueError, Exception, BaseException, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: UnsupportedOperation.__mro__.__len__
  args: []
  expected: 6

invariant io_extra83.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE.__eq__(131072) == True (verified Python 3.14.3 on macOS/Darwin 25.4.0)"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true
