spec: lodash_sortby
version: ">=4.0.0"
backend: node(lodash.sortby)

docs: https://lodash.com/docs/#sortBy

provenance:
  derived_from:
    - "lodash.sortby README — https://www.npmjs.com/package/lodash.sortby"
    - "Test vectors verified with lodash.sortby@4.7.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.sortby exports the _.sortBy function directly as module.exports."
    - "sortBy(collection, iteratees) sorts a collection by the given property or function."
    - "Sort is stable and ascending by default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new sorted array. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_sortby.sortby:
  kind: node_module_call_eq
  function: ~
  category: sortby
  id_prefix: lsb

  columns: [id, args, expected]
  rows:
    - [by_name,  [[{"n": "b"}, {"n": "a"}, {"n": "c"}], "n"],   [{"n": "a"}, {"n": "b"}, {"n": "c"}]]
    - [by_age,   [[{"age": 30}, {"age": 20}, {"age": 25}], "age"],  [{"age": 20}, {"age": 25}, {"age": 30}]]
    - [numbers,  [[3, 1, 2]],                                    [1, 2, 3]]

