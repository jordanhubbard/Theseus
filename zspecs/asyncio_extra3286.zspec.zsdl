    - ["as3286007", operator.contains, [asyncio.Condition.__dict__,        "__iadd__"], false]
    - ["as3286008", operator.contains, [asyncio.Queue.__dict__,            "__iadd__"], false]
    - ["as3286009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__iadd__"], false]
    - ["as3286010", operator.contains, [asyncio.LifoQueue.__dict__,        "__iadd__"], false]

# ---------------------------------------------------------------------------
# __isub__ dict-presence — operator.contains(Cls.__dict__, '__isub__')
#
# All 10 asyncio classes return false for __isub__.
# In-place subtraction (__isub__, -=) is the augmented assignment variant of __sub__.
# asyncio types define no __sub__ (wave 658), so __isub__ is equally absent.
# asyncio synchronization primitives (Event, Lock, Condition, Semaphore,
#   BoundedSemaphore) have no numeric data model that -= could operate on.
# asyncio.Task/Future: coroutine result handles; -= is not defined for
#   pending result objects.
# asyncio.Queue/PriorityQueue/LifoQueue: item stores; in-place subtraction
#   is entirely absent — items are managed through put()/get() coroutines only.
# ---------------------------------------------------------------------------

