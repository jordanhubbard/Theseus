spec: threading_extra394
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.stack_size.__name__ == 'stack_size' — stack_size is a Python function in Lib/threading.py that wraps _thread.stack_size; its __name__ is 'stack_size'. Verified with Python 3.14.4."
    - "threading.stack_size.__module__ == '_thread' — stack_size is assigned from _thread.stack_size in Lib/threading.py; the underlying C function carries __module__ == '_thread'. Verified with Python 3.14.4."
    - "threading.Thread.start.__name__ == 'start' — start is a Python method on threading.Thread; __name__ is 'start'. Verified with Python 3.14.4."
    - "threading.Thread.run.__name__ == 'run' — run is a Python method on threading.Thread; __name__ is 'run'. Verified with Python 3.14.4."
    - "threading.Thread.join.__name__ == 'join' — join is a Python method on threading.Thread; __name__ is 'join'. Verified with Python 3.14.4."
    - "threading.Thread.is_alive.__name__ == 'is_alive' — is_alive is a Python method on threading.Thread; __name__ is 'is_alive'. Verified with Python 3.14.4."
    - "threading.Thread.daemon.__class__.__name__ == 'property' — daemon is a Python property descriptor on the Thread class; __class__.__name__ is 'property'. Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.stack_size __name__ and __module__
#
# threading.stack_size is the C function _thread.stack_size re-exported
# from Lib/threading.py. Its __name__ is 'stack_size' and its __module__
# is '_thread' (the underlying C extension), not 'threading'.
# ---------------------------------------------------------------------------

table threading_extra394.stack_size_identity:
  description: "threading.stack_size __name__ and __module__ — C function from _thread module; new to extra394"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingss394

  columns: [id, function, args, expected, description]
  rows:
    - [stack_size_name_eq,
       "stack_size.__name__.__eq__",
       ["stack_size"],
       true,
       "threading.stack_size.__name__.__eq__('stack_size') == True — stack_size is the C function _thread.stack_size re-exported by Lib/threading.py; __name__ is 'stack_size'; str.__eq__('stack_size') returns True; new to extra394"]
    - [stack_size_module_eq,
       "stack_size.__module__.__eq__",
       ["_thread"],
       true,
       "threading.stack_size.__module__.__eq__('_thread') == True — stack_size is the C function _thread.stack_size; its __module__ is '_thread' (the underlying C extension), not 'threading'; str.__eq__('_thread') returns True; new to extra394"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread method __name__ values
#
# start, run, join, and is_alive are Python methods defined on the Thread
# class in Lib/threading.py. Their __name__ equals the bare method name.
# ---------------------------------------------------------------------------

table threading_extra394.thread_method_name:
  description: "threading.Thread method __name__ values — Python methods on Thread; new to extra394"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtm394

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_name_eq,
       "Thread.start.__name__.__eq__",
       ["start"],
       true,
       "threading.Thread.start.__name__.__eq__('start') == True — start is a Python method on threading.Thread defined in Lib/threading.py; __name__ is 'start'; str.__eq__('start') returns True; new to extra394"]
    - [thread_run_name_eq,
       "Thread.run.__name__.__eq__",
       ["run"],
       true,
       "threading.Thread.run.__name__.__eq__('run') == True — run is a Python method on threading.Thread defined in Lib/threading.py; __name__ is 'run'; str.__eq__('run') returns True; new to extra394"]
    - [thread_join_name_eq,
       "Thread.join.__name__.__eq__",
       ["join"],
       true,
       "threading.Thread.join.__name__.__eq__('join') == True — join is a Python method on threading.Thread defined in Lib/threading.py; __name__ is 'join'; str.__eq__('join') returns True; new to extra394"]
    - [thread_is_alive_name_eq,
       "Thread.is_alive.__name__.__eq__",
       ["is_alive"],
       true,
       "threading.Thread.is_alive.__name__.__eq__('is_alive') == True — is_alive is a Python method on threading.Thread defined in Lib/threading.py; __name__ is 'is_alive'; str.__eq__('is_alive') returns True; new to extra394"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread.daemon property descriptor identity
#
# threading.Thread.daemon is a Python property descriptor. When accessed
# on the class (not an instance), __class__.__name__ is 'property'.
# ---------------------------------------------------------------------------

table threading_extra394.thread_daemon_descriptor:
  description: "threading.Thread.daemon __class__.__name__ — Python property descriptor; new to extra394"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtd394

  columns: [id, function, args, expected, description]
  rows:
    - [thread_daemon_class_name_eq,
       "Thread.daemon.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.daemon.__class__.__name__.__eq__('property') == True — daemon is a Python property descriptor on threading.Thread; accessed on the class it is a property object; __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra394"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra394
# ---------------------------------------------------------------------------

invariant threading_extra394.stack_size_name:
  description: "threading.stack_size.__name__ == 'stack_size' — C function from _thread re-exported by threading; new to extra394"
  kind: python_call_eq
  function: stack_size.__name__.__eq__
  args: ["stack_size"]
  expected: true

invariant threading_extra394.stack_size_module:
  description: "threading.stack_size.__module__ == '_thread' — underlying C extension module, not 'threading'; new to extra394"
  kind: python_call_eq
  function: stack_size.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra394.thread_start_name:
  description: "threading.Thread.start.__name__ == 'start' — Python method on Thread; new to extra394"
  kind: python_call_eq
  function: Thread.start.__name__.__eq__
  args: ["start"]
  expected: true

invariant threading_extra394.thread_run_name:
  description: "threading.Thread.run.__name__ == 'run' — Python method on Thread; new to extra394"
  kind: python_call_eq
  function: Thread.run.__name__.__eq__
  args: ["run"]
  expected: true

invariant threading_extra394.thread_join_name:
  description: "threading.Thread.join.__name__ == 'join' — Python method on Thread; new to extra394"
  kind: python_call_eq
  function: Thread.join.__name__.__eq__
  args: ["join"]
  expected: true

invariant threading_extra394.thread_is_alive_name:
  description: "threading.Thread.is_alive.__name__ == 'is_alive' — Python method on Thread; new to extra394"
  kind: python_call_eq
  function: Thread.is_alive.__name__.__eq__
  args: ["is_alive"]
  expected: true

invariant threading_extra394.thread_daemon_class_name:
  description: "threading.Thread.daemon.__class__.__name__ == 'property' — Python property descriptor on Thread class; new to extra394"
  kind: python_call_eq
  function: Thread.daemon.__class__.__name__.__eq__
  args: ["property"]
  expected: true
