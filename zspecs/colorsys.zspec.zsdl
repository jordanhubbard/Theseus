spec: colorsys
version: ">=3.x"
backend: python_module(colorsys)

docs: https://docs.python.org/3/library/colorsys.html

provenance:
  derived_from:
    - "Python colorsys documentation — https://docs.python.org/3/library/colorsys.html"
    - "Test vectors verified by running Python 3.12 colorsys module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/colorsys.py"
  notes:
    - "colorsys converts between RGB and three alternative color systems: YIQ, HLS, and HSV."
    - "All color components are floats in the range [0.0, 1.0], except YIQ I and Q which may be negative."
    - "rgb_to_yiq(1.0, 0.0, 0.0)[0] == 0.299 is the ITU-R BT.601 luma coefficient for red."
    - "rgb_to_hsv(1.0, 0.0, 0.0) returns (0.0, 1.0, 1.0): hue=0 (red), saturation=1, value=1."
    - "hsv_to_rgb(0.0, 1.0, 1.0) is the exact inverse: returns red (1.0, 0.0, 0.0)."
    - "rgb_to_hls(1.0, 0.0, 0.0)[0] == 0.0: hue of pure red in HLS is 0.0."
    - "rgb_to_hls(1.0, 1.0, 1.0)[1] == 1.0: white has lightness 1.0 in HLS."
    - "All tuple index access uses __getitem__ with kind: python_call_eq."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table colorsys.func_names:
  kind: python_call_eq
  category: functions
  id_prefix: func_name

  columns: [id, function, args, expected]
  rows:
    - [rgb_to_yiq, "rgb_to_yiq.__name__.__eq__", ["rgb_to_yiq"], true]
    - [yiq_to_rgb, "yiq_to_rgb.__name__.__eq__", ["yiq_to_rgb"], true]
    - [rgb_to_hls, "rgb_to_hls.__name__.__eq__", ["rgb_to_hls"], true]
    - [hls_to_rgb, "hls_to_rgb.__name__.__eq__", ["hls_to_rgb"], true]
    - [rgb_to_hsv, "rgb_to_hsv.__name__.__eq__", ["rgb_to_hsv"], true]
    - [hsv_to_rgb, "hsv_to_rgb.__name__.__eq__", ["hsv_to_rgb"], true]

# ---------------------------------------------------------------------------
# Module attribute
# ---------------------------------------------------------------------------

invariant colorsys.module.rgb_to_yiq:
  description: "colorsys.rgb_to_yiq.__module__ == 'colorsys'"
  category: module
  kind: python_call_eq
  function: rgb_to_yiq.__module__.__eq__
  args: ["colorsys"]
  expected: true

# ---------------------------------------------------------------------------
# rgb_to_yiq — YIQ luma (Y) of primary colors
# ---------------------------------------------------------------------------

invariant colorsys.rgb_to_yiq.red_y_component:
  description: "colorsys.rgb_to_yiq(1.0, 0.0, 0.0)[0] == 0.299 — Y (luma) of red per ITU-R BT.601"
  category: yiq
  kind: python_call_eq
  function: rgb_to_yiq
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.299

# ---------------------------------------------------------------------------
# rgb_to_hsv — HSV components of pure red
# ---------------------------------------------------------------------------

invariant colorsys.rgb_to_hsv.red_hue:
  description: "colorsys.rgb_to_hsv(1.0, 0.0, 0.0)[0] == 0.0 — hue of red is 0.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

invariant colorsys.rgb_to_hsv.red_saturation:
  description: "colorsys.rgb_to_hsv(1.0, 0.0, 0.0)[1] == 1.0 — saturation of red is 1.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [1]
  expected: 1.0

invariant colorsys.rgb_to_hsv.red_value:
  description: "colorsys.rgb_to_hsv(1.0, 0.0, 0.0)[2] == 1.0 — value of red is 1.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [2]
  expected: 1.0

# ---------------------------------------------------------------------------
# hsv_to_rgb — inverse of rgb_to_hsv for pure red
# ---------------------------------------------------------------------------

invariant colorsys.hsv_to_rgb.back_to_red:
  description: "colorsys.hsv_to_rgb(0.0, 1.0, 1.0)[0] == 1.0 — red channel is 1.0"
  category: hsv
  kind: python_call_eq
  function: hsv_to_rgb
  args: [0.0, 1.0, 1.0]
  method: __getitem__
  method_args: [0]
  expected: 1.0

# ---------------------------------------------------------------------------
# rgb_to_hls — HLS hue of red and lightness of white
# ---------------------------------------------------------------------------

invariant colorsys.rgb_to_hls.red_hue:
  description: "colorsys.rgb_to_hls(1.0, 0.0, 0.0)[0] == 0.0 — hue of red in HLS is 0.0"
  category: hls
  kind: python_call_eq
  function: rgb_to_hls
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

invariant colorsys.rgb_to_hls.white_lightness:
  description: "colorsys.rgb_to_hls(1.0, 1.0, 1.0)[1] == 1.0 — white has lightness 1.0 in HLS"
  category: hls
  kind: python_call_eq
  function: rgb_to_hls
  args: [1.0, 1.0, 1.0]
  method: __getitem__
  method_args: [1]
  expected: 1.0

