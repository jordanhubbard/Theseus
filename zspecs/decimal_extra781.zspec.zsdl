spec: decimal_extra781
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "Python standard library documentation: decimal module"
    - "CPython source: Lib/_pydecimal.py"
  not_derived_from:
    - "Any third-party decimal arithmetic library"
  notes:
    - "Covers __qualname__ identity checks for decimal.Context arithmetic methods"
    - "Continues coverage of Context methods beyond those in earlier decimal specs"
    - "All qualnames reflect the Context class-level naming convention"
  created_at: "2026-04-12"

table decimal_extra781.name:
  description: "Verifies __qualname__ strings for decimal.Context arithmetic methods"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: dc781xx
  columns: [id, function, args, expected]
  rows:
    - [dc781xx001, decimal.Context.compare.__qualname__.__eq__, ["Context.compare"], true]
    - [dc781xx002, decimal.Context.compare_signal.__qualname__.__eq__, ["Context.compare_signal"], true]
    - [dc781xx003, decimal.Context.compare_total.__qualname__.__eq__, ["Context.compare_total"], true]
    - [dc781xx004, decimal.Context.max.__qualname__.__eq__, ["Context.max"], true]
    - [dc781xx005, decimal.Context.min.__qualname__.__eq__, ["Context.min"], true]
    - [dc781xx006, decimal.Context.max_mag.__qualname__.__eq__, ["Context.max_mag"], true]
    - [dc781xx007, decimal.Context.min_mag.__qualname__.__eq__, ["Context.min_mag"], true]
    - [dc781xx008, decimal.Context.plus.__qualname__.__eq__, ["Context.plus"], true]
    - [dc781xx009, decimal.Context.minus.__qualname__.__eq__, ["Context.minus"], true]
    - [dc781xx010, decimal.Context.remainder.__qualname__.__eq__, ["Context.remainder"], true]
    - [dc781xx011, decimal.Context.divide_int.__qualname__.__eq__, ["Context.divide_int"], true]
    - [dc781xx012, decimal.Context.fma.__qualname__.__eq__, ["Context.fma"], true]
