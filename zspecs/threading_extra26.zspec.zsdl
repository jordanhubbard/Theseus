spec: threading_extra26
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends prior threading specs through threading_extra25.zspec.zsdl."
    - "threading_extra19 covers: Lock/RLock/Condition/Semaphore/Timer/Barrier/BoundedSemaphore __qualname__ eq table."
    - "threading_extra24 covers: Thread.start/run/join/is_alive method qualnames; Event.set/clear/wait/is_set; Thread.daemon.fget qualname."
    - "threading_extra25 covers: Lock.acquire/release method qualnames/lengths; Condition.wait/notify/notify_all; Semaphore.acquire/release; Timer qualname_len."
    - "NOT yet covered in any prior spec: Thread property fget qualnames (name, ident, native_id) in extra26 namespace."
    - "NOT yet covered: Thread.daemon.fset.__qualname__ (extra24 covers fget only) in extra26 namespace."
    - "NOT yet covered: Barrier method __qualname__ table (wait/abort/reset) in extra26 namespace."
    - "NOT yet covered: BoundedSemaphore method __qualname__ table in extra26 namespace."
    - "NOT yet covered: threading.main_thread().__class__.__qualname__ == '_MainThread' in extra26 namespace."
    - "NOT yet covered: threading.TIMEOUT_MAX.__class__.__name__ == 'float' in extra26 namespace."
    - "Thread.name.fget.__qualname__ == 'Thread.name' — length 11."
    - "Thread.ident.fget.__qualname__ == 'Thread.ident' — length 12."
    - "Thread.native_id.fget.__qualname__ == 'Thread.native_id' — length 16."
    - "Thread.daemon.fset.__qualname__ == 'Thread.daemon' — length 13 (extra24 checks fget; fset has same value)."
    - "Barrier.wait.__qualname__ == 'Barrier.wait' — length 12."
    - "Barrier.abort.__qualname__ == 'Barrier.abort' — length 13."
    - "Barrier.reset.__qualname__ == 'Barrier.reset' — length 13."
    - "BoundedSemaphore.acquire.__qualname__ == 'Semaphore.acquire' — INHERITED from Semaphore (length 17)."
    - "BoundedSemaphore.release.__qualname__ == 'BoundedSemaphore.release' — overridden (length 24)."
    - "threading.main_thread().__class__.__qualname__ == '_MainThread' — length 11."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread property fget __qualname__ table — extra26 namespace
#
# threading_extra24 checks Thread.daemon.fget.__qualname__ == 'Thread.daemon'
# as a standalone invariant. No prior spec covers the name/ident/native_id
# property getter qualnames.
# Lengths: Thread.name(11), Thread.ident(12), Thread.native_id(16).
# ---------------------------------------------------------------------------

table threading_extra26.thread_property_fget_qualnames:
  description: "threading.Thread property fget __qualname__ values in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: thpfqn26

  columns: [id, function, args, expected]
  rows:
    - [name,      Thread.name.fget.__qualname__.__eq__,      ["Thread.name"],      true]
    - [ident,     Thread.ident.fget.__qualname__.__eq__,     ["Thread.ident"],     true]
    - [native_id, Thread.native_id.fget.__qualname__.__eq__, ["Thread.native_id"], true]

# ---------------------------------------------------------------------------
# Thread property fget __qualname__ length table — extra26 namespace
#
# Lengths: Thread.name(11), Thread.ident(12), Thread.native_id(16).
# ---------------------------------------------------------------------------

table threading_extra26.thread_property_fget_qualname_lengths:
  description: "threading.Thread property fget __qualname__ lengths in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: thpfqnlen26

  columns: [id, function, args, expected]
  rows:
    - [name,      Thread.name.fget.__qualname__.__len__,      [], 11]
    - [ident,     Thread.ident.fget.__qualname__.__len__,     [], 12]
    - [native_id, Thread.native_id.fget.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# Barrier method __qualname__ table — extra26 namespace
#
# threading_extra19 checks Barrier.__qualname__ == 'Barrier' (the class).
# No prior spec provides a table of Barrier *method* __qualname__ values.
# Lengths: Barrier.wait(12), Barrier.abort(13), Barrier.reset(13).
# ---------------------------------------------------------------------------

table threading_extra26.barrier_method_qualnames:
  description: "threading.Barrier method __qualname__ values in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: barmqn26

  columns: [id, function, args, expected]
  rows:
    - [wait,  Barrier.wait.__qualname__.__eq__,  ["Barrier.wait"],  true]
    - [abort, Barrier.abort.__qualname__.__eq__, ["Barrier.abort"], true]
    - [reset, Barrier.reset.__qualname__.__eq__, ["Barrier.reset"], true]

# ---------------------------------------------------------------------------
# Barrier method __qualname__ length table — extra26 namespace
#
# Lengths: Barrier.wait(12), Barrier.abort(13), Barrier.reset(13).
# ---------------------------------------------------------------------------

table threading_extra26.barrier_method_qualname_lengths:
  description: "threading.Barrier method __qualname__ lengths in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: barmqnlen26

  columns: [id, function, args, expected]
  rows:
    - [wait,  Barrier.wait.__qualname__.__len__,  [], 12]
    - [abort, Barrier.abort.__qualname__.__len__, [], 13]
    - [reset, Barrier.reset.__qualname__.__len__, [], 13]

# ---------------------------------------------------------------------------
# BoundedSemaphore method __qualname__ table — extra26 namespace
#
# threading_extra19 checks BoundedSemaphore.__qualname__ == 'BoundedSemaphore'.
# BoundedSemaphore.acquire is INHERITED from Semaphore, so its __qualname__
# is 'Semaphore.acquire' (length 17), NOT 'BoundedSemaphore.acquire'.
# BoundedSemaphore.release is overridden, so its __qualname__ is
# 'BoundedSemaphore.release' (length 24).
# ---------------------------------------------------------------------------

table threading_extra26.boundedsemaphore_method_qualnames:
  description: "threading.BoundedSemaphore method __qualname__ values in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: bsmqn26

  columns: [id, function, args, expected]
  rows:
    - [acquire, BoundedSemaphore.acquire.__qualname__.__eq__, ["Semaphore.acquire"],         true]
    - [release, BoundedSemaphore.release.__qualname__.__eq__, ["BoundedSemaphore.release"],  true]

# ---------------------------------------------------------------------------
# BoundedSemaphore method __qualname__ length table — extra26 namespace
#
# acquire inherits from Semaphore -> length 17; release overridden -> length 24.
# ---------------------------------------------------------------------------

table threading_extra26.boundedsemaphore_method_qualname_lengths:
  description: "threading.BoundedSemaphore method __qualname__ lengths in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: bsmqnlen26

  columns: [id, function, args, expected]
  rows:
    - [acquire, BoundedSemaphore.acquire.__qualname__.__len__, [], 17]
    - [release, BoundedSemaphore.release.__qualname__.__len__, [], 24]

# ---------------------------------------------------------------------------
# Thread.daemon.fset.__qualname__ — standalone extra26 invariant
#
# threading_extra24 checks Thread.daemon.fget.__qualname__ == 'Thread.daemon'.
# No prior spec checks the daemon property *setter* qualname. The fset also
# has __qualname__ == 'Thread.daemon' (length 13).
# ---------------------------------------------------------------------------

invariant threading_extra26.Thread.daemon.fset_qualname_eq:
  description: "threading.Thread.daemon.fset.__qualname__ == 'Thread.daemon' — property setter qualname"
  category: method_names
  kind: python_call_eq
  function: Thread.daemon.fset.__qualname__.__eq__
  args: ["Thread.daemon"]
  expected: true

# ---------------------------------------------------------------------------
# threading.main_thread().__class__.__qualname__ — standalone extra26 invariant
#
# The main thread is an instance of _MainThread (a private subclass of Thread).
# threading.main_thread().__class__.__qualname__ == '_MainThread'. Length 11.
# No prior spec checks this value.
# ---------------------------------------------------------------------------

invariant threading_extra26.main_thread_class_qualname:
  description: "threading.main_thread().__class__.__qualname__ == '_MainThread'"
  category: method_names
  kind: python_call_eq
  function: main_thread().__class__.__qualname__.__eq__
  args: ["_MainThread"]
  expected: true

# ---------------------------------------------------------------------------
# threading.TIMEOUT_MAX class name — standalone extra26 invariant
#
# threading.TIMEOUT_MAX is a float constant. Its __class__.__name__ == 'float'.
# No prior spec checks this. Length of 'float' is 5.
# ---------------------------------------------------------------------------

invariant threading_extra26.TIMEOUT_MAX_class_name:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float'"
  category: method_names
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true
