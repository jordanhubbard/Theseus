spec: itertools_extra170
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.combinations_with_replacement.__name__ 'combinations_with_replacement'; itertools.combinations_with_replacement.__module__ 'itertools'; itertools.combinations_with_replacement.__name__.__len__() 29; itertools.combinations.__name__.__len__() 12; itertools.permutations.__name__.__len__() 12; itertools.product.__name__.__len__() 7; name length ordering: product(7) < combinations(12)==permutations(12) < combinations_with_replacement(29) (Wave 299)."
    - "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' — itertools.combinations_with_replacement is a C extension type in itertoolsmodule.c that returns r-length sub-sequences of elements from the input iterable allowing individual elements to be repeated more than once; its type __name__ is 'combinations_with_replacement'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__module__ == 'itertools' — combinations_with_replacement is declared in the itertools C extension module; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__name__.__len__() == 29 — the string 'combinations_with_replacement' has 29 characters. Verified with Python 3.14.3."
    - "itertools.combinations.__name__.__len__() == 12 — the string 'combinations' has 12 characters. Verified with Python 3.14.3."
    - "itertools.permutations.__name__.__len__() == 12 — the string 'permutations' has 12 characters. Verified with Python 3.14.3."
    - "itertools.product.__name__.__len__() == 7 — the string 'product' has 7 characters. Verified with Python 3.14.3."
    - "Name length ordering: len('product')==7 < len('combinations')==len('permutations')==12 < len('combinations_with_replacement')==29."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.combinations_with_replacement C extension type identity —
# __name__, __module__, __class__.__name__
#
# Wave 299 theme: itertools.combinations_with_replacement C extension type
# identity — __name__, __module__, and __class__.__name__.
#
# itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement'
# itertools.combinations_with_replacement.__module__ == 'itertools'
# itertools.combinations_with_replacement.__class__.__name__ == 'type'
# itertools.combinations_with_replacement.__name__ != 'combinations'
#
# itertools.combinations_with_replacement(iterable, r) returns r-length
# sub-sequences of elements from the input iterable, allowing individual elements
# to be repeated more than once. Unlike combinations(), which yields strictly
# sorted sub-sequences with no repetition, combinations_with_replacement() allows
# repeated selections. It is a C extension type in itertoolsmodule.c. New to
# extra170.
# ---------------------------------------------------------------------------

table itertools_extra170.combinations_with_replacement_identity:
  description: "itertools.combinations_with_replacement: __name__ 'combinations_with_replacement', __module__ 'itertools', __class__.__name__ 'type'; wave 299; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscwri170

  columns: [id, function, args, expected, description]
  rows:
    - [cwr_name_eq,
       "combinations_with_replacement.__name__.__eq__",
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__name__.__eq__('combinations_with_replacement') == True — combinations_with_replacement is a C extension type in itertoolsmodule.c that returns r-length sub-sequences allowing individual element repetition; its type __name__ attribute is 'combinations_with_replacement'; str.__eq__('combinations_with_replacement') returns True; new to extra170"]
    - [cwr_module_itertools,
       "combinations_with_replacement.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations_with_replacement.__module__.__eq__('itertools') == True — combinations_with_replacement is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra170"]
    - [cwr_class_name_type,
       "combinations_with_replacement.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.combinations_with_replacement.__class__.__name__.__eq__('type') == True — combinations_with_replacement is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra170"]
    - [cwr_name_ne_combinations,
       "combinations_with_replacement.__name__.__eq__",
       ["combinations"],
       false,
       "itertools.combinations_with_replacement.__name__.__eq__('combinations') == False — 'combinations_with_replacement' and 'combinations' are distinct names; combinations_with_replacement allows element repetition while combinations does not; str.__eq__('combinations') returns False; new to extra170"]

# ---------------------------------------------------------------------------
# Table 2: itertools.combinations and itertools.permutations __name__ length
# checks
#
# Wave 299 theme: itertools.combinations and itertools.permutations name length
# checks — both have __name__.__len__() == 12.
#
# itertools.combinations.__name__.__len__() == 12
# itertools.permutations.__name__.__len__() == 12
# itertools.combinations.__name__ != 'permutations'
# itertools.permutations.__name__ != 'combinations'
#
# 'combinations' and 'permutations' each have exactly 12 characters. Despite
# sharing the same name length, they are entirely distinct algorithms: combinations
# yields sorted sub-sequences without repetition (order doesn't matter) while
# permutations yields all orderings of elements (order matters). New to extra170.
# ---------------------------------------------------------------------------

table itertools_extra170.combinations_permutations_name_lengths:
  description: "itertools: combinations.__name__.__len__() 12, permutations.__name__.__len__() 12; both length 12 but distinct; wave 299; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscpnl170

  columns: [id, function, args, expected, description]
  rows:
    - [comb_name_len_12,
       "combinations.__name__.__len__",
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — the string 'combinations' has exactly 12 characters: c-o-m-b-i-n-a-t-i-o-n-s; str.__len__() returns 12; new to extra170"]
    - [perm_name_len_12,
       "permutations.__name__.__len__",
       [],
       12,
       "itertools.permutations.__name__.__len__() == 12 — the string 'permutations' has exactly 12 characters: p-e-r-m-u-t-a-t-i-o-n-s; str.__len__() returns 12; coincidentally the same length as 'combinations'; new to extra170"]
    - [comb_name_ne_permutations,
       "combinations.__name__.__eq__",
       ["permutations"],
       false,
       "itertools.combinations.__name__.__eq__('permutations') == False — combinations.__name__ is 'combinations', not 'permutations'; they are distinct C extension types despite sharing the same name length (12); combinations yields sorted sub-sequences without repetition while permutations yields all orderings; str.__eq__('permutations') returns False; new to extra170"]
    - [perm_name_ne_combinations,
       "permutations.__name__.__eq__",
       ["combinations"],
       false,
       "itertools.permutations.__name__.__eq__('combinations') == False — permutations.__name__ is 'permutations', not 'combinations'; they are distinct C extension types; str.__eq__('combinations') returns False; new to extra170"]

# ---------------------------------------------------------------------------
# Table 3: itertools.product __name__ length check and identity
#
# Wave 299 theme: itertools.product — __name__, __module__, and
# __name__.__len__() == 7.
#
# itertools.product.__name__ == 'product'
# itertools.product.__name__.__len__() == 7
# itertools.product.__module__ == 'itertools'
# itertools.product.__name__.__len__() != 12
#
# itertools.product(*iterables, repeat=1) computes the Cartesian product of
# input iterables. It is a C extension type in itertoolsmodule.c. The name
# 'product' is 7 characters long, which is fewer than both 'combinations' and
# 'permutations' (each 12 characters). New to extra170.
# ---------------------------------------------------------------------------

table itertools_extra170.product_name_length:
  description: "itertools.product: __name__ 'product', __module__ 'itertools', __name__.__len__() 7; wave 299; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolspnl170

  columns: [id, function, args, expected, description]
  rows:
    - [product_name_product,
       "product.__name__.__eq__",
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — itertools.product is a C extension type in itertoolsmodule.c that computes the Cartesian product of input iterables (equivalent to nested for-loops); its type __name__ attribute is 'product'; str.__eq__('product') returns True; new to extra170"]
    - [product_name_len_7,
       "product.__name__.__len__",
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — the string 'product' has exactly 7 characters: p-r-o-d-u-c-t; str.__len__() returns 7; new to extra170"]
    - [product_module_itertools,
       "product.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — itertools.product is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra170"]
    - [product_name_len_ne_12,
       "product.__name__.__len__",
       [],
       7,
       "itertools.product.__name__.__len__() == 7 (not 12) — 'product' has 7 characters, fewer than 'combinations' or 'permutations' (each 12 characters); cross-check confirming the length ordering product(7) < combinations(12); str.__len__() returns 7; new to extra170"]

# ---------------------------------------------------------------------------
# Table 4: combinations_with_replacement __name__ length check — 29 characters
#
# Wave 299 theme: itertools.combinations_with_replacement name length — the
# longest name among the four combinatoric types.
#
# itertools.combinations_with_replacement.__name__.__len__() == 29
# itertools.combinations_with_replacement.__name__.__len__() > 12
# itertools.combinations_with_replacement.__name__.__len__() > 7
# itertools.combinations.__module__ == 'itertools'
#
# 'combinations_with_replacement' is 29 characters long — significantly longer
# than 'combinations' (12), 'permutations' (12), or 'product' (7). This is the
# longest __name__ among the itertools combinatoric iterator types. New to extra170.
# ---------------------------------------------------------------------------

table itertools_extra170.cwr_name_length_and_module:
  description: "itertools: combinations_with_replacement.__name__.__len__() 29; combinations.__module__ 'itertools'; length ordering confirmed; wave 299; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscwrnl170

  columns: [id, function, args, expected, description]
  rows:
    - [cwr_name_len_29,
       "combinations_with_replacement.__name__.__len__",
       [],
       29,
       "itertools.combinations_with_replacement.__name__.__len__() == 29 — the string 'combinations_with_replacement' has exactly 29 characters; this is the longest __name__ among the four itertools combinatoric types (product: 7, combinations: 12, permutations: 12, combinations_with_replacement: 29); str.__len__() returns 29; new to extra170"]
    - [comb_module_itertools,
       "combinations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — itertools.combinations is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra170"]
    - [perm_module_itertools,
       "permutations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — itertools.permutations is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra170"]
    - [cwr_name_len_ne_12,
       "combinations_with_replacement.__name__.__len__",
       [],
       29,
       "itertools.combinations_with_replacement.__name__.__len__() == 29 (not 12) — 'combinations_with_replacement' has 29 characters, far more than 'combinations' or 'permutations' (each 12 characters); cross-check confirming the ordering; str.__len__() returns 29; new to extra170"]

# ---------------------------------------------------------------------------
# Table 5: all four combinatoric types share __module__ 'itertools' and
# __class__.__name__ 'type'
#
# Wave 299 theme: cross-checks confirming all four combinatoric C extension types
# (product, combinations, permutations, combinations_with_replacement) have
# __module__ 'itertools' and __class__.__name__ 'type'.
#
# itertools.combinations.__class__.__name__ == 'type'
# itertools.permutations.__class__.__name__ == 'type'
# itertools.product.__class__.__name__ == 'type'
# itertools.permutations.__module__ == 'itertools'
#
# All four are C extension types in itertoolsmodule.c. They all share the same
# metaclass ('type') and the same __module__ ('itertools'). New to extra170.
# ---------------------------------------------------------------------------

table itertools_extra170.combinatoric_types_cross_checks:
  description: "itertools: combinations, permutations, product __class__.__name__ 'type'; permutations.__module__ 'itertools'; wave 299; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsctcc170

  columns: [id, function, args, expected, description]
  rows:
    - [comb_class_type,
       "combinations.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.combinations.__class__.__name__.__eq__('type') == True — itertools.combinations is a C extension type in itertoolsmodule.c; as a class object its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra170"]
    - [perm_class_type,
       "permutations.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.permutations.__class__.__name__.__eq__('type') == True — itertools.permutations is a C extension type in itertoolsmodule.c; as a class object its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra170"]
    - [product_class_type,
       "product.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.product.__class__.__name__.__eq__('type') == True — itertools.product is a C extension type in itertoolsmodule.c; as a class object its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra170"]
    - [perm_module_itertools_xcheck,
       "permutations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — all four combinatoric types (product, combinations, permutations, combinations_with_replacement) share __module__ 'itertools'; cross-check via permutations; str.__eq__('itertools') returns True; new to extra170"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra170
# ---------------------------------------------------------------------------

invariant itertools_extra170.cwr_name_eq:
  description: "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' — C extension type returning r-length sub-sequences with element repetition allowed; wave 299; new to extra170"
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__eq__
  args: ["combinations_with_replacement"]
  expected: true

invariant itertools_extra170.cwr_module_itertools:
  description: "itertools.combinations_with_replacement.__module__ == 'itertools' — combinations_with_replacement is declared in itertoolsmodule.c; wave 299; new to extra170"
  kind: python_call_eq
  function: combinations_with_replacement.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra170.cwr_name_len_29:
  description: "itertools.combinations_with_replacement.__name__.__len__() == 29 — 'combinations_with_replacement' is 29 characters long; the longest combinatoric type name; wave 299; new to extra170"
  kind: python_call_eq
  function: combinations_with_replacement.__name__.__len__
  args: []
  expected: 29

invariant itertools_extra170.comb_name_len_12:
  description: "itertools.combinations.__name__.__len__() == 12 — 'combinations' is 12 characters long; wave 299; new to extra170"
  kind: python_call_eq
  function: combinations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra170.perm_name_len_12:
  description: "itertools.permutations.__name__.__len__() == 12 — 'permutations' is 12 characters long; same length as 'combinations'; wave 299; new to extra170"
  kind: python_call_eq
  function: permutations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra170.product_name_len_7:
  description: "itertools.product.__name__.__len__() == 7 — 'product' is 7 characters long; shortest among the four combinatoric types; wave 299; new to extra170"
  kind: python_call_eq
  function: product.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra170.comb_module_itertools:
  description: "itertools.combinations.__module__ == 'itertools' — combinations is declared in itertoolsmodule.c; wave 299; new to extra170"
  kind: python_call_eq
  function: combinations.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra170.product_module_itertools:
  description: "itertools.product.__module__ == 'itertools' — product is declared in itertoolsmodule.c; wave 299; new to extra170"
  kind: python_call_eq
  function: product.__module__.__eq__
  args: ["itertools"]
  expected: true
