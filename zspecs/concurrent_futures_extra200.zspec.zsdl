spec: concurrent_futures_extra200
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "This spec covers concurrent.futures.__spec__ deeper attributes: name, has_location, parent, __class__.__name__, submodule_search_locations.__class__.__name__."
    - "concurrent.futures.__spec__.name == 'concurrent.futures' — the ModuleSpec's name attribute matches the module name. Verified with Python 3.14.3."
    - "concurrent.futures.__spec__.has_location == True — concurrent.futures is loaded from disk; has_location is True for file-backed packages. Verified with Python 3.14.3."
    - "concurrent.futures.__spec__.parent == 'concurrent.futures' — concurrent.futures is a sub-package of concurrent; __spec__.parent equals __spec__.name for packages. Verified with Python 3.14.3."
    - "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "concurrent.futures.__spec__.submodule_search_locations.__class__.__name__ == 'list' — concurrent.futures is a package; submodule_search_locations is a list of directory paths. Verified with Python 3.14.3."
    - "concurrent.futures.__spec__.has_location.__class__.__name__ == 'bool' — has_location is a plain Python bool. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.__spec__.name identity
#
# concurrent.futures.__spec__.name == 'concurrent.futures' (len 18)
# concurrent.futures is a package; its ModuleSpec.name is 'concurrent.futures'.
# New to concurrent_futures_extra200.
# ---------------------------------------------------------------------------

table concurrent_futures_extra200.spec_name:
  description: "concurrent.futures.__spec__.name == 'concurrent.futures' and its length is 18; new to concurrent_futures_extra200"
  kind: python_call_eq
  category: spec_attrs
  id_prefix: cfspec200

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       "__spec__.name.__eq__",
       ["concurrent.futures"],
       true,
       "concurrent.futures.__spec__.name.__eq__('concurrent.futures') == True — ModuleSpec.name equals 'concurrent.futures'; new to concurrent_futures_extra200"]
    - [spec_name_len_eq_18,
       "__spec__.name.__len__",
       [],
       18,
       "concurrent.futures.__spec__.name.__len__() == 18 — 'concurrent.futures' has 18 characters; new to concurrent_futures_extra200"]
    - [spec_name_class_eq,
       "__spec__.name.__class__.__name__.__eq__",
       ["str"],
       true,
       "concurrent.futures.__spec__.name.__class__.__name__.__eq__('str') == True — ModuleSpec.name is a str; new to concurrent_futures_extra200"]
    - [spec_name_contains_dot,
       "__spec__.name.__contains__",
       ["."],
       true,
       "concurrent.futures.__spec__.name.__contains__('.') == True — the dotted module name contains a dot; new to concurrent_futures_extra200"]

