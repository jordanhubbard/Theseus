spec: decimal_extra1156
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module __package__.__class__.__name__, __loader__.__class__.__name__, __all__.__class__.__name__, and Decimal/Context/DecimalException/Overflow/Underflow __module__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.__package__.__class__.__name__, decimal.__loader__.__class__.__name__, decimal.__all__.__class__.__name__, decimal.Decimal.__module__, decimal.Context.__module__, decimal.DecimalException.__module__, decimal.Overflow.__module__, decimal.Underflow.__module__; __package__/__loader__/__all__ class name checks not covered in _extra1126 or _extra1141; class __module__ checks not covered in either prior file"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1156.module_dunder_class_names:
  description: "decimal module __package__, __loader__, and __all__ __class__.__name__ checks"
  kind: python_call_eq
  category: module_dunder_class_names
  id_prefix: dc1156mc
  columns: [id, function, args, expected]
  rows:
    - [dc1156mc001, decimal.__package__.__class__.__name__.__eq__,  ["str"],   true]
    - [dc1156mc002, decimal.__loader__.__class__.__name__.__eq__,   ["BuiltinImporter"], true]
    - [dc1156mc003, decimal.__all__.__class__.__name__.__eq__,      ["list"],  true]
    - [dc1156mc004, decimal.__package__.__class__.__name__.__eq__,  ["bytes"], false]
    - [dc1156mc005, decimal.__package__.__class__.__name__.__eq__,  ["NoneType"], false]
    - [dc1156mc006, decimal.__all__.__class__.__name__.__eq__,      ["tuple"], false]
    - [dc1156mc007, decimal.__package__.__eq__,                     ["decimal"], true]
    - [dc1156mc008, decimal.__package__.__class__.__name__.__eq__,  ["str"],   true]

table decimal_extra1156.core_class_modules:
  description: "decimal.Decimal, decimal.Context, decimal.DecimalException __module__ checks — all must equal 'decimal'"
  kind: python_call_eq
  category: core_class_modules
  id_prefix: dc1156cm
  columns: [id, function, args, expected]
  rows:
    - [dc1156cm001, decimal.Decimal.__module__.__eq__,          ["decimal"],  true]
    - [dc1156cm002, decimal.Context.__module__.__eq__,          ["decimal"],  true]
    - [dc1156cm003, decimal.DecimalException.__module__.__eq__, ["decimal"],  true]
    - [dc1156cm004, decimal.Decimal.__module__.__eq__,          ["_decimal"], false]
    - [dc1156cm005, decimal.Context.__module__.__eq__,          ["_decimal"], false]
    - [dc1156cm006, decimal.DecimalException.__module__.__eq__, ["builtins"], false]
    - [dc1156cm007, decimal.Decimal.__module__.__class__.__name__.__eq__,          ["str"], true]
    - [dc1156cm008, decimal.Context.__module__.__class__.__name__.__eq__,          ["str"], true]
    - [dc1156cm009, decimal.DecimalException.__module__.__class__.__name__.__eq__, ["str"], true]

table decimal_extra1156.exception_subclass_modules:
  description: "decimal exception subclass Overflow, Underflow, Inexact, InvalidOperation, DivisionByZero __module__ checks"
  kind: python_call_eq
  category: exception_subclass_modules
  id_prefix: dc1156es
  columns: [id, function, args, expected]
  rows:
    - [dc1156es001, decimal.Overflow.__module__.__eq__,        ["decimal"],  true]
    - [dc1156es002, decimal.Underflow.__module__.__eq__,       ["decimal"],  true]
    - [dc1156es003, decimal.Inexact.__module__.__eq__,         ["decimal"],  true]
    - [dc1156es004, decimal.InvalidOperation.__module__.__eq__, ["decimal"], true]
    - [dc1156es005, decimal.DivisionByZero.__module__.__eq__,  ["decimal"],  true]
    - [dc1156es006, decimal.Overflow.__module__.__eq__,        ["_decimal"], false]
    - [dc1156es007, decimal.Underflow.__module__.__eq__,       ["builtins"], false]
    - [dc1156es008, decimal.Overflow.__module__.__class__.__name__.__eq__,  ["str"], true]
    - [dc1156es009, decimal.Underflow.__module__.__class__.__name__.__eq__, ["str"], true]
    - [dc1156es010, decimal.DivisionByZero.__module__.__class__.__name__.__eq__, ["str"], true]
