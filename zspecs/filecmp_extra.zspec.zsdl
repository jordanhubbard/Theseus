spec: filecmp_extra
version: ">=3.2"
backend: python_module(filecmp)

docs: https://docs.python.org/3/library/filecmp.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/filecmp.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "filecmp source: Lib/filecmp.py (PSF; source inspection permitted)"
  not_derived_from:
    - "filecmp source: internal implementation details"
  notes:
    - "This spec extends filecmp.zspec.zsdl with invariants not covered there: dircmp class hierarchy, module membership, DEFAULT_IGNORES membership for standard VCS ignore entries, and dircmp attribute names present on the class."
    - "filecmp.dircmp.__bases__[0].__name__ == 'object' — dircmp inherits from object."
    - "filecmp.dircmp.__module__ == 'filecmp' — dircmp is defined in the filecmp module."
    - "DEFAULT_IGNORES contains 'RCS', 'CVS', 'tags', '.git', '.hg', '.bzr', '_darcs' on Python 3.4+."
    - "dircmp has attribute 'left', 'right', 'hide', 'ignore' as constructor parameters; these are set as instance attributes."
    - "filecmp.cmpfiles returns a tuple of length 3: (match, mismatch, errors)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "filecmp.cmp() raises OSError when a file cannot be accessed. dircmp raises OSError when a directory cannot be listed."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# dircmp class hierarchy and module
# ---------------------------------------------------------------------------

invariant filecmp_extra.dircmp.base_object:
  description: "filecmp.dircmp.__bases__[0].__name__ == 'object' — dircmp inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: dircmp.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant filecmp_extra.dircmp.module:
  description: "filecmp.dircmp.__module__ == 'filecmp'"
  category: modules
  kind: python_call_eq
  function: dircmp.__module__.__eq__
  args: ["filecmp"]
  expected: true

invariant filecmp_extra.dircmp.is_type:
  description: "filecmp.dircmp.__class__.__name__ == 'type' — dircmp is a class object"
  category: class_names
  kind: python_call_eq
  function: dircmp.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_IGNORES — membership of VCS and legacy SCM directories
# ---------------------------------------------------------------------------

table filecmp_extra.DEFAULT_IGNORES.vcs_entries:
  kind: python_call_eq
  category: constants
  id_prefix: ignore_entry
  function: DEFAULT_IGNORES.__contains__

  columns: [id, description, args, expected]
  rows:
    - [RCS,     "DEFAULT_IGNORES contains 'RCS' — legacy RCS version control",    ["RCS"],    true]
    - [CVS,     "DEFAULT_IGNORES contains 'CVS' — legacy CVS version control",    ["CVS"],    true]
    - [tags,    "DEFAULT_IGNORES contains 'tags' — ctags index file",             ["tags"],   true]
    - [git,     "DEFAULT_IGNORES contains '.git' — Git version control",          [".git"],   true]
    - [hg,      "DEFAULT_IGNORES contains '.hg' — Mercurial version control",     [".hg"],    true]
    - [bzr,     "DEFAULT_IGNORES contains '.bzr' — Bazaar version control",       [".bzr"],   true]
    - [darcs,   "DEFAULT_IGNORES contains '_darcs' — Darcs version control",      ["_darcs"], true]

# ---------------------------------------------------------------------------
# DEFAULT_IGNORES — structural invariants
# ---------------------------------------------------------------------------

invariant filecmp_extra.DEFAULT_IGNORES_length:
  description: "len(filecmp.DEFAULT_IGNORES) >= 7 — at least the major VCS entries are present"
  category: constants
  kind: python_call_eq
  function: DEFAULT_IGNORES.__len__
  args: []
  method: __ge__
  method_args: [7]
  expected: true

# ---------------------------------------------------------------------------
# Function module membership
# ---------------------------------------------------------------------------

table filecmp_extra.function_module_checks:
  kind: python_call_eq
  category: modules
  id_prefix: fmodule

  columns: [id, function, args, expected]
  rows:
    - [cmpfiles_module,    cmpfiles.__module__.__eq__,    ["filecmp"], true]
    - [clear_cache_module, clear_cache.__module__.__eq__, ["filecmp"], true]

# ---------------------------------------------------------------------------
# dircmp.hide attribute — default list of names hidden from listings
# ---------------------------------------------------------------------------

invariant filecmp_extra.dircmp_hide_attribute_type:
  description: "dircmp.hide.__class__.__name__ == 'list' — hide is a list attribute on the class"
  category: dircmp_attrs
  kind: python_call_eq
  function: dircmp.hide.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# cmpfiles — function is callable (class type check)
# ---------------------------------------------------------------------------

invariant filecmp_extra.cmpfiles_is_function:
  description: "cmpfiles.__class__.__name__ == 'function' — cmpfiles is a plain function"
  category: functions
  kind: python_call_eq
  function: cmpfiles.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant filecmp_extra.cmp_is_function:
  description: "cmp.__class__.__name__ == 'function' — cmp is a plain function"
  category: functions
  kind: python_call_eq
  function: cmp.__class__.__name__.__eq__
  args: ["function"]
  expected: true
