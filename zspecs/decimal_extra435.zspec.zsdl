spec: decimal_extra435
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module class hierarchy and exceptions"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers Decimal, Context, and the DecimalException hierarchy"
    - "__bases__[0] function fields are double-quoted per ZSDL rules for bracket expressions"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra435.class_names:
  description: "Class __name__ identity for decimal module classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: dcn

  columns: [id, function, args, expected]
  rows:
    - [dcn001, decimal.Decimal.__name__.__eq__, ["Decimal"], true]
    - [dcn002, decimal.Context.__name__.__eq__, ["Context"], true]
    - [dcn003, decimal.DecimalException.__name__.__eq__, ["DecimalException"], true]
    - [dcn004, decimal.InvalidOperation.__name__.__eq__, ["InvalidOperation"], true]
    - [dcn005, decimal.DivisionByZero.__name__.__eq__, ["DivisionByZero"], true]
    - [dcn006, decimal.Overflow.__name__.__eq__, ["Overflow"], true]
    - [dcn007, decimal.Underflow.__name__.__eq__, ["Underflow"], true]

table decimal_extra435.class_modules:
  description: "Class __module__ identity for decimal module classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: dcm

  columns: [id, function, args, expected]
  rows:
    - [dcm001, decimal.Decimal.__module__.__eq__, ["decimal"], true]
    - [dcm002, decimal.Context.__module__.__eq__, ["decimal"], true]
    - [dcm003, decimal.DecimalException.__module__.__eq__, ["decimal"], true]

table decimal_extra435.class_bases:
  description: "Base class identity for decimal module classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: dcb

  columns: [id, function, args, expected]
  rows:
    - [dcb001, "decimal.Decimal.__bases__[0].__name__.__eq__", ["object"], true]
    - [dcb002, "decimal.DecimalException.__bases__[0].__name__.__eq__", ["ArithmeticError"], true]
