spec: normalize_range
version: ">=0.1.2"
backend: node(normalize-range)

docs: https://www.npmjs.com/package/normalize-range

provenance:
  derived_from:
    - "normalize-range README — https://www.npmjs.com/package/normalize-range"
    - "Test vectors verified with normalize-range via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "normalize-range source"
  notes:
    - "normalize-range is an npm package. Install: npm install normalize-range"
    - "Provides wrap (modular wrap-around) and limit (clamp) for numeric ranges."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table normalize_range.wrap:
  kind: node_module_call_eq
  function: wrap
  category: math
  id_prefix: nrwrap

  columns: [id, args, expected]
  rows:
    - [in_range,  [0, 10, 5],   5]
    - [over_max,  [0, 10, 12],  2]
    - [under_min, [0, 10, -2],  8]

table normalize_range.limit:
  kind: node_module_call_eq
  function: limit
  category: math
  id_prefix: nrlimit

  columns: [id, args, expected]
  rows:
    - [in_range,  [0, 10, 5],   5]
    - [above_max, [0, 10, 15],  10]
    - [below_min, [0, 10, -5],  0]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:03:47Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
