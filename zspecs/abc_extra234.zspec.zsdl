spec: abc_extra234
version: ">=3.4"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers abc.ABC __doc__ contains checks and abc.abstractmethod doc checks."
    - "abc.ABC.__doc__ contains 'ABC', 'inheritance', 'standard', and 'Helper' — describing the ABC helper class."
    - "abc.ABC.__doc__.__len__() == 78 — exactly 78 characters; verified Python 3.14.3."
    - "abc.abstractmethod.__doc__ contains 'abstract', 'decorator', 'ABCMeta' — describing the decorator."
    - "abc.ABC.__dict__.__contains__('__doc__') == True — __doc__ is stored directly on the class."
    - "abc.ABC.__dict__.__contains__('__slots__') == True — __slots__ is defined on ABC."
    - "abc.ABC.__dict__.__contains__('__abstractmethods__') == True — ABC carries this descriptor."
    - "abc.ABC.__dict__.__contains__('_abc_impl') == True — internal C-level ABC state is stored here."
    - "abc.ABCMeta.__dict__.__contains__('register') == True — register() is a method on the metaclass."
    - "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True."
    - "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABC.__doc__ contains checks
#
# Verifies that the ABC docstring mentions key concepts: 'ABC', 'inheritance',
# 'standard', and 'Helper'.  Docstring length is 78 characters.
# ---------------------------------------------------------------------------

table abc_extra234.abc_doc_contains:
  description: "abc.ABC.__doc__ contains keyword checks; new to extra234"
  kind: python_call_eq
  category: doc
  id_prefix: abc234doc

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_contains_ABC,
       ABC.__doc__.__contains__,
       ["ABC"],
       true,
       "abc.ABC.__doc__.__contains__('ABC') == True — docstring references 'ABC' by name; new to extra234"]
    - [abc_doc_contains_inheritance,
       ABC.__doc__.__contains__,
       ["inheritance"],
       true,
       "abc.ABC.__doc__.__contains__('inheritance') == True — docstring mentions creating an ABC via inheritance; new to extra234"]
    - [abc_doc_contains_standard,
       ABC.__doc__.__contains__,
       ["standard"],
       true,
       "abc.ABC.__doc__.__contains__('standard') == True — docstring says 'standard way'; new to extra234"]
    - [abc_doc_contains_Helper,
       ABC.__doc__.__contains__,
       ["Helper"],
       true,
       "abc.ABC.__doc__.__contains__('Helper') == True — docstring starts with 'Helper class'; new to extra234"]
    - [abc_doc_len_78,
       ABC.__doc__.__len__,
       [],
       78,
       "abc.ABC.__doc__.__len__() == 78 — ABC docstring has exactly 78 characters; verified Python 3.14.3; new to extra234"]

# ---------------------------------------------------------------------------
# Table 2: abc.abstractmethod.__doc__ contains checks
#
# Verifies that abstractmethod's docstring mentions 'abstract', 'decorator',
# and 'ABCMeta'.
# ---------------------------------------------------------------------------

table abc_extra234.abstractmethod_doc_contains:
  description: "abc.abstractmethod.__doc__ contains keyword checks; new to extra234"
  kind: python_call_eq
  category: doc
  id_prefix: abc234doc

  columns: [id, function, args, expected, description]
  rows:
    - [am_doc_contains_abstract,
       abstractmethod.__doc__.__contains__,
       ["abstract"],
       true,
       "abc.abstractmethod.__doc__.__contains__('abstract') == True — describes abstract methods; new to extra234"]
    - [am_doc_contains_decorator,
       abstractmethod.__doc__.__contains__,
       ["decorator"],
       true,
       "abc.abstractmethod.__doc__.__contains__('decorator') == True — abstractmethod is a decorator; new to extra234"]
    - [am_doc_contains_ABCMeta,
       abstractmethod.__doc__.__contains__,
       ["ABCMeta"],
       true,
       "abc.abstractmethod.__doc__.__contains__('ABCMeta') == True — docstring references ABCMeta; new to extra234"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABC.__dict__.__contains__ checks
#
# Verifies key entries present in ABC.__dict__: __doc__, __slots__,
# __abstractmethods__, and _abc_impl.
# ---------------------------------------------------------------------------

table abc_extra234.abc_dict_contains:
  description: "abc.ABC.__dict__.__contains__ checks for expected dict keys; new to extra234"
  kind: python_call_eq
  category: dict_contains
  id_prefix: abc234dict

  columns: [id, function, args, expected, description]
  rows:
    - [abc_dict_has_doc,
       ABC.__dict__.__contains__,
       ["__doc__"],
       true,
       "abc.ABC.__dict__.__contains__('__doc__') == True — __doc__ stored directly on ABC; new to extra234"]
    - [abc_dict_has_slots,
       ABC.__dict__.__contains__,
       ["__slots__"],
       true,
       "abc.ABC.__dict__.__contains__('__slots__') == True — __slots__ defined on ABC; new to extra234"]
    - [abc_dict_has_abstractmethods,
       ABC.__dict__.__contains__,
       ["__abstractmethods__"],
       true,
       "abc.ABC.__dict__.__contains__('__abstractmethods__') == True — ABC carries __abstractmethods__; new to extra234"]
    - [abc_dict_has_abc_impl,
       ABC.__dict__.__contains__,
       ["_abc_impl"],
       true,
       "abc.ABC.__dict__.__contains__('_abc_impl') == True — internal C-level ABC state stored here; new to extra234"]
    - [abc_dict_no_register,
       ABC.__dict__.__contains__,
       ["register"],
       false,
       "abc.ABC.__dict__.__contains__('register') == False — register() lives on ABCMeta, not ABC itself; new to extra234"]

# ---------------------------------------------------------------------------
# Table 4: abc.ABCMeta.__dict__.__contains__ checks
#
# Verifies key entries present in ABCMeta.__dict__: register,
# __instancecheck__, and __subclasscheck__.
# ---------------------------------------------------------------------------

table abc_extra234.abcmeta_dict_contains:
  description: "abc.ABCMeta.__dict__.__contains__ checks for expected dict keys; new to extra234"
  kind: python_call_eq
  category: dict_contains
  id_prefix: abc234dict

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_has_register,
       ABCMeta.__dict__.__contains__,
       ["register"],
       true,
       "abc.ABCMeta.__dict__.__contains__('register') == True — register() is a method on ABCMeta; new to extra234"]
    - [abcmeta_dict_has_instancecheck,
       ABCMeta.__dict__.__contains__,
       ["__instancecheck__"],
       true,
       "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True — ABCMeta overrides isinstance; new to extra234"]
    - [abcmeta_dict_has_subclasscheck,
       ABCMeta.__dict__.__contains__,
       ["__subclasscheck__"],
       true,
       "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True — ABCMeta overrides issubclass; new to extra234"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra234
# ---------------------------------------------------------------------------

invariant abc_extra234.ABC.doc_contains_ABC:
  description: "abc.ABC.__doc__.__contains__('ABC') == True; new to extra234"
  category: doc
  kind: python_call_eq
  function: ABC.__doc__.__contains__
  args: ["ABC"]
  expected: true

invariant abc_extra234.ABC.doc_contains_inheritance:
  description: "abc.ABC.__doc__.__contains__('inheritance') == True; new to extra234"
  category: doc
  kind: python_call_eq
  function: ABC.__doc__.__contains__
  args: ["inheritance"]
  expected: true

invariant abc_extra234.abstractmethod.doc_contains_abstract:
  description: "abc.abstractmethod.__doc__.__contains__('abstract') == True; new to extra234"
  category: doc
  kind: python_call_eq
  function: abstractmethod.__doc__.__contains__
  args: ["abstract"]
  expected: true

invariant abc_extra234.abstractmethod.doc_contains_ABCMeta:
  description: "abc.abstractmethod.__doc__.__contains__('ABCMeta') == True; new to extra234"
  category: doc
  kind: python_call_eq
  function: abstractmethod.__doc__.__contains__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra234.ABC.dict_has_slots:
  description: "abc.ABC.__dict__.__contains__('__slots__') == True; new to extra234"
  category: dict_contains
  kind: python_call_eq
  function: ABC.__dict__.__contains__
  args: ["__slots__"]
  expected: true

invariant abc_extra234.ABC.dict_has_abstractmethods:
  description: "abc.ABC.__dict__.__contains__('__abstractmethods__') == True; new to extra234"
  category: dict_contains
  kind: python_call_eq
  function: ABC.__dict__.__contains__
  args: ["__abstractmethods__"]
  expected: true

invariant abc_extra234.ABC.dict_has_abc_impl:
  description: "abc.ABC.__dict__.__contains__('_abc_impl') == True; new to extra234"
  category: dict_contains
  kind: python_call_eq
  function: ABC.__dict__.__contains__
  args: ["_abc_impl"]
  expected: true

invariant abc_extra234.ABCMeta.dict_has_register:
  description: "abc.ABCMeta.__dict__.__contains__('register') == True; new to extra234"
  category: dict_contains
  kind: python_call_eq
  function: ABCMeta.__dict__.__contains__
  args: ["register"]
  expected: true
