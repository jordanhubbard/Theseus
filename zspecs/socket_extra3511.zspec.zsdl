spec: sk3511
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (sk3511): __get__, __set__, __delete__ dict-presence checks for socket types."
    - "All values false — socket types do not implement the descriptor protocol."
    - "socket.socket, socket.AddressFamily, socket.SocketKind: none define __get__, __set__, or __delete__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table sk3511.get:
  description: "socket types __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: sk3511
  columns: [id, function, args, expected]
  rows:
    - ["sk3511001", operator.contains, [socket.socket.__dict__,        "__get__"], false]
    - ["sk3511002", operator.contains, [socket.AddressFamily.__dict__, "__get__"], false]
    - ["sk3511003", operator.contains, [socket.SocketKind.__dict__,    "__get__"], false]

