spec: pathlib_extra223
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "Path method __name__ and __qualname__ values verified with Python 3.14.3 on macOS/Darwin 25.4.0."
    - "PurePath method __name__ and __qualname__ values verified with Python 3.14.3 on macOS/Darwin 25.4.0."
    - "PurePosixPath property values (name, stem, suffix, parts) verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path method __name__ checks
# ---------------------------------------------------------------------------

table pathlib_extra223.path_method_names:
  description: "pathlib.Path method __name__ attribute checks — stat, exists, is_file, is_dir, is_symlink, mkdir, open all return their simple name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibextra223a

  columns: [id, function, args, expected, description]
  rows:
    - [path_stat_name,     pathlib.Path.stat.__name__.__eq__,     ["stat"],     true, "pathlib.Path.stat.__name__ == 'stat'; verified with Python 3.14.3"]
    - [path_exists_name,   pathlib.Path.exists.__name__.__eq__,   ["exists"],   true, "pathlib.Path.exists.__name__ == 'exists'; verified with Python 3.14.3"]
    - [path_is_file_name,  pathlib.Path.is_file.__name__.__eq__,  ["is_file"],  true, "pathlib.Path.is_file.__name__ == 'is_file'; verified with Python 3.14.3"]
    - [path_is_dir_name,   pathlib.Path.is_dir.__name__.__eq__,   ["is_dir"],   true, "pathlib.Path.is_dir.__name__ == 'is_dir'; verified with Python 3.14.3"]
    - [path_mkdir_name,    pathlib.Path.mkdir.__name__.__eq__,    ["mkdir"],    true, "pathlib.Path.mkdir.__name__ == 'mkdir'; verified with Python 3.14.3"]
    - [path_unlink_name,   pathlib.Path.unlink.__name__.__eq__,   ["unlink"],   true, "pathlib.Path.unlink.__name__ == 'unlink'; verified with Python 3.14.3"]
    - [path_rename_name,   pathlib.Path.rename.__name__.__eq__,   ["rename"],   true, "pathlib.Path.rename.__name__ == 'rename'; verified with Python 3.14.3"]
    - [path_glob_name,     pathlib.Path.glob.__name__.__eq__,     ["glob"],     true, "pathlib.Path.glob.__name__ == 'glob'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Path method __qualname__ checks
# ---------------------------------------------------------------------------

table pathlib_extra223.path_method_qualnames:
  description: "pathlib.Path method __qualname__ checks — each is 'Path.<method>'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibextra223b

  columns: [id, function, args, expected, description]
  rows:
    - [path_stat_qualname,      pathlib.Path.stat.__qualname__.__eq__,      ["Path.stat"],      true, "pathlib.Path.stat.__qualname__ == 'Path.stat'; verified with Python 3.14.3"]
    - [path_exists_qualname,    pathlib.Path.exists.__qualname__.__eq__,    ["Path.exists"],    true, "pathlib.Path.exists.__qualname__ == 'Path.exists'; verified with Python 3.14.3"]
    - [path_is_file_qualname,   pathlib.Path.is_file.__qualname__.__eq__,   ["Path.is_file"],   true, "pathlib.Path.is_file.__qualname__ == 'Path.is_file'; verified with Python 3.14.3"]
    - [path_read_text_qualname, pathlib.Path.read_text.__qualname__.__eq__, ["Path.read_text"], true, "pathlib.Path.read_text.__qualname__ == 'Path.read_text'; verified with Python 3.14.3"]
    - [path_write_text_qualname, pathlib.Path.write_text.__qualname__.__eq__, ["Path.write_text"], true, "pathlib.Path.write_text.__qualname__ == 'Path.write_text'; verified with Python 3.14.3"]
    - [path_iterdir_qualname,   pathlib.Path.iterdir.__qualname__.__eq__,   ["Path.iterdir"],   true, "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# PurePath method name/qualname checks
# ---------------------------------------------------------------------------

table pathlib_extra223.purepath_method_names:
  description: "pathlib.PurePath method __name__ and __qualname__ checks — joinpath, with_name, with_suffix, with_stem, relative_to, is_relative_to; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibextra223c

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_joinpath_name,        pathlib.PurePath.joinpath.__name__.__eq__,        ["joinpath"],               true, "pathlib.PurePath.joinpath.__name__ == 'joinpath'; verified with Python 3.14.3"]
    - [purepath_with_name_name,       pathlib.PurePath.with_name.__name__.__eq__,       ["with_name"],              true, "pathlib.PurePath.with_name.__name__ == 'with_name'; verified with Python 3.14.3"]
    - [purepath_with_suffix_name,     pathlib.PurePath.with_suffix.__name__.__eq__,     ["with_suffix"],            true, "pathlib.PurePath.with_suffix.__name__ == 'with_suffix'; verified with Python 3.14.3"]
    - [purepath_with_stem_name,       pathlib.PurePath.with_stem.__name__.__eq__,       ["with_stem"],              true, "pathlib.PurePath.with_stem.__name__ == 'with_stem'; verified with Python 3.14.3"]
    - [purepath_relative_to_name,     pathlib.PurePath.relative_to.__name__.__eq__,     ["relative_to"],            true, "pathlib.PurePath.relative_to.__name__ == 'relative_to'; verified with Python 3.14.3"]
    - [purepath_is_relative_to_name,  pathlib.PurePath.is_relative_to.__name__.__eq__,  ["is_relative_to"],         true, "pathlib.PurePath.is_relative_to.__name__ == 'is_relative_to'; verified with Python 3.14.3"]
    - [purepath_joinpath_qualname,    pathlib.PurePath.joinpath.__qualname__.__eq__,    ["PurePath.joinpath"],      true, "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath'; verified with Python 3.14.3"]
    - [purepath_with_suffix_qualname, pathlib.PurePath.with_suffix.__qualname__.__eq__, ["PurePath.with_suffix"],   true, "pathlib.PurePath.with_suffix.__qualname__ == 'PurePath.with_suffix'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra223.path_is_symlink_qualname:
  description: "pathlib.Path.is_symlink.__qualname__ == 'Path.is_symlink' — qualname encodes class context for is_symlink; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.is_symlink.__qualname__.__eq__
  args: ["Path.is_symlink"]
  expected: true

invariant pathlib_extra223.purepath_relative_to_qualname:
  description: "pathlib.PurePath.relative_to.__qualname__ == 'PurePath.relative_to' — verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.relative_to.__qualname__.__eq__
  args: ["PurePath.relative_to"]
  expected: true

invariant pathlib_extra223.path_open_qualname:
  description: "pathlib.Path.open.__qualname__ == 'Path.open' — Path.open opens the path and returns a file object; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.open.__qualname__.__eq__
  args: ["Path.open"]
  expected: true

invariant pathlib_extra223.purepath_is_relative_to_qualname:
  description: "pathlib.PurePath.is_relative_to.__qualname__ == 'PurePath.is_relative_to' — is_relative_to was added in Python 3.9; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.is_relative_to.__qualname__.__eq__
  args: ["PurePath.is_relative_to"]
  expected: true
