spec: pathlib_extra235
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec covers: pathlib.Path class hierarchy contracts — PurePath, PurePosixPath, PureWindowsPath, Path class names, module, base class names, and name lengths."
    - "pathlib.PurePath.__name__ == 'PurePath' — length 8; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' — length 13; verified Python 3.14.3 macOS."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' — length 15; verified Python 3.14.3 macOS."
    - "pathlib.Path.__name__ == 'Path' — length 4; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — inherits from PurePath; verified Python 3.14.3 macOS."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — inherits from PurePath; verified Python 3.14.3 macOS."
    - "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path inherits directly from PurePath; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is the root of the hierarchy; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__module__ == 'pathlib' and pathlib.Path.__module__ == 'pathlib'; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __name__ identity contracts
# PurePath, PurePosixPath, PureWindowsPath, Path class name strings.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra235.class_names:
  description: "pathlib class __name__ identity contracts — PurePath, PurePosixPath, PureWindowsPath, Path; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibclsname235

  columns: [id, function, args, expected]
  rows:
    - [purepath_name,       PurePath.__name__.__eq__,       ["PurePath"],       true]
    - [pureposixpath_name,  PurePosixPath.__name__.__eq__,  ["PurePosixPath"],  true]
    - [purewindowspath_name, PureWindowsPath.__name__.__eq__, ["PureWindowsPath"], true]
    - [path_name,           Path.__name__.__eq__,           ["Path"],           true]

# ---------------------------------------------------------------------------
# pathlib class __name__ length contracts
# PurePath len 8, PurePosixPath len 13, PureWindowsPath len 15, Path len 4.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra235.class_name_lengths:
  description: "pathlib class __name__ length contracts — character count of each class name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibclsnamelen235

  columns: [id, function, args, expected]
  rows:
    - [purepath_namelen,       PurePath.__name__.__len__,       [], 8]
    - [pureposixpath_namelen,  PurePosixPath.__name__.__len__,  [], 13]
    - [purewindowspath_namelen, PureWindowsPath.__name__.__len__, [], 15]
    - [path_namelen,           Path.__name__.__len__,           [], 4]

# ---------------------------------------------------------------------------
# pathlib class __module__ contracts
# PurePath, PurePosixPath, PureWindowsPath, Path all report module 'pathlib'.
# Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra235.PurePath.module_pathlib:
  description: "pathlib.PurePath.__module__ == 'pathlib' — PurePath reports module as 'pathlib'; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra235.Path.module_pathlib:
  description: "pathlib.Path.__module__ == 'pathlib' — Path reports module as 'pathlib'; verified Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib class hierarchy __bases__ contracts
# PurePosixPath, PureWindowsPath, and Path all inherit from PurePath.
# PurePath itself inherits from object (it is the root of the hierarchy).
# Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra235.PurePosixPath.base_is_PurePath:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath directly inherits from PurePath; verified Python 3.14.3 macOS"
  category: hierarchy
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra235.PureWindowsPath.base_is_PurePath:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath directly inherits from PurePath; verified Python 3.14.3 macOS"
  category: hierarchy
  kind: python_call_eq
  function: "PureWindowsPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra235.Path.base_is_PurePath:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' — Path directly inherits from PurePath; verified Python 3.14.3 macOS"
  category: hierarchy
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra235.PurePath.base_is_object:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath is the root of the pathlib hierarchy, inheriting from object; verified Python 3.14.3 macOS"
  category: hierarchy
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
