spec: sklearn_cluster_rust
version: ">=3.9"
backend: rust_module(sklearn_cluster_rust)

docs: https://scikit-learn.org/stable/modules/clustering.html

provenance:
  derived_from:
    - "https://scikit-learn.org/stable/modules/clustering.html — sklearn clustering"
  not_derived_from:
    - "sklearn source: sklearn/cluster/_kmeans.py"
  notes:
    - "scikit-learn clustering algorithms."
    - "KMeans(n_clusters=2).fit([[0],[1],[10],[11]]).labels_ produces 2 distinct labels."
    - "KMeans n_clusters == number of distinct labels."
    - "Expose kmeans_n_clusters(data, k) -> int: len(set(KMeans(n_clusters=k).fit(data).labels_.tolist()))."
    - "Expose kmeans_label_count(data, k) -> int: len(KMeans(n_clusters=k).fit(data).labels_.tolist())."
    - "kmeans_n_clusters([[0],[10],[20]], 3) == 3."
    - "kmeans_label_count([[0],[1],[2]], 2) == 3 — one label per sample."
    - "All test vectors verified against scikit-learn 1.6.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# kmeans_n_clusters — number of distinct clusters produced
table sklearn_cluster_rust.kmeans.n_clusters:
  kind: python_call_eq
  category: n_clusters
  id_prefix: skc_nc
  function: kmeans_n_clusters

  columns: [id, args, expected]
  rows:
    - [two,   [[[0], [1], [10], [11]], 2], 2]
    - [three,  [[[0], [10], [20]], 3],     3]
    - [one,   [[[5], [5], [5]], 1],        1]

# kmeans_label_count — number of labels == number of samples
table sklearn_cluster_rust.kmeans.label_count:
  kind: python_call_eq
  category: label_count
  id_prefix: skc_lc
  function: kmeans_label_count

  columns: [id, args, expected]
  rows:
    - [four,  [[[0], [1], [10], [11]], 2], 4]
    - [three, [[[0], [10], [20]], 3],      3]

