spec: ssl_extra15
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "OpenSSL source"
  notes:
    - "This spec extends ssl.zspec.zsdl and prior extras through ssl_extra14.zspec.zsdl."
    - "ssl_extra14 covers: SSLError.__mro__[0/2/3].__name__; SSLCertVerificationError.__bases__[0].__name__; SSLWantReadError/SSLWantWriteError/SSLZeroReturnError __name__; SSLObject.__name__/__module__; HAS_SNI/HAS_ALPN values."
    - "ssl_extra13 covers: SSLContext/__bases__[0]/__mro__[1/2].__name__; SSLSocket/__bases__[0]/__mro__[2].__name__; PROTOCOL_TLS_SERVER.__class__.__name__; Purpose member class names."
    - "_ssl.zspec.zsdl covers: MemoryBIO.__name__ in the _ssl C-extension backend."
    - "No prior spec covers: ssl.MemoryBIO.__module__ == '_ssl' (the ssl public API re-exports from _ssl)."
    - "No prior spec covers: ssl.MemoryBIO.__qualname__ == 'MemoryBIO'."
    - "No prior spec covers: ssl.MemoryBIO.__bases__[0].__name__ == 'object'."
    - "No prior spec covers: ssl.SSLSession.__name__ == 'SSLSession'."
    - "No prior spec covers: ssl.SSLSession.__module__ == '_ssl'."
    - "No prior spec covers: ssl.SSLSession.__qualname__ == 'SSLSession'."
    - "No prior spec covers: ssl.SSLSession.__bases__[0].__name__ == 'object'."
    - "No prior spec covers: ssl.VerifyFlags.__name__ == 'VerifyFlags'."
    - "No prior spec covers: ssl.VerifyFlags.__module__ == 'ssl'."
    - "No prior spec covers: ssl.VerifyFlags.__qualname__ == 'VerifyFlags'."
    - "ssl.MemoryBIO and ssl.SSLSession are C-extension classes defined in _ssl; ssl re-exports them."
    - "VerifyFlags is an IntFlag enum used to configure OpenSSL certificate verification flags."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ssl.MemoryBIO — class attributes via the ssl public re-export
#
# _ssl.zspec.zsdl covers MemoryBIO.__name__ == 'MemoryBIO' via the _ssl backend.
# The ssl module re-exports MemoryBIO from _ssl. No prior spec checks the ssl
# module's view of MemoryBIO.__module__, __qualname__, or __bases__[0].__name__.
# MemoryBIO is a pure C type; its __module__ is '_ssl' and its base is object.
# ---------------------------------------------------------------------------

invariant ssl_extra15.MemoryBIO.module:
  description: "ssl.MemoryBIO.__module__ == '_ssl' — C-extension class lives in _ssl"
  category: modules
  kind: python_call_eq
  function: MemoryBIO.__module__.__eq__
  args: ["_ssl"]
  expected: true

invariant ssl_extra15.MemoryBIO.qualname:
  description: "ssl.MemoryBIO.__qualname__ == 'MemoryBIO'"
  category: class_names
  kind: python_call_eq
  function: MemoryBIO.__qualname__.__eq__
  args: ["MemoryBIO"]
  expected: true

invariant ssl_extra15.MemoryBIO.base:
  description: "ssl.MemoryBIO.__bases__[0].__name__ == 'object' — direct base is object"
  category: class_hierarchy
  kind: python_call_eq
  function: MemoryBIO.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# ssl.SSLSession — class attributes
#
# SSLSession is the session object returned by SSLSocket.session.
# No prior spec (ssl.* or _ssl.*) checks SSLSession.__name__,
# __module__, __qualname__, or __bases__[0].__name__ via the ssl backend.
# ---------------------------------------------------------------------------

invariant ssl_extra15.SSLSession.name:
  description: "ssl.SSLSession.__name__ == 'SSLSession'"
  category: class_names
  kind: python_call_eq
  function: SSLSession.__name__.__eq__
  args: ["SSLSession"]
  expected: true

invariant ssl_extra15.SSLSession.module:
  description: "ssl.SSLSession.__module__ == '_ssl' — SSLSession is a C-extension type"
  category: modules
  kind: python_call_eq
  function: SSLSession.__module__.__eq__
  args: ["_ssl"]
  expected: true

invariant ssl_extra15.SSLSession.qualname:
  description: "ssl.SSLSession.__qualname__ == 'SSLSession'"
  category: class_names
  kind: python_call_eq
  function: SSLSession.__qualname__.__eq__
  args: ["SSLSession"]
  expected: true

invariant ssl_extra15.SSLSession.base:
  description: "ssl.SSLSession.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLSession.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# ssl.VerifyFlags — enum class identity
#
# ssl_extra5 covers Options/__name__/__bases__/__module__; ssl_extra6 covers Options/__qualname__.
# ssl_extra5 covers VerifyMode/__name__/__bases__/__module__; ssl_extra6 covers VerifyMode/__qualname__.
# No prior spec covers VerifyFlags (a distinct IntFlag enum) at all.
# VerifyFlags members include VERIFY_CRL_CHECK_LEAF, VERIFY_X509_STRICT, etc.
# ---------------------------------------------------------------------------

invariant ssl_extra15.VerifyFlags.name:
  description: "ssl.VerifyFlags.__name__ == 'VerifyFlags'"
  category: class_names
  kind: python_call_eq
  function: VerifyFlags.__name__.__eq__
  args: ["VerifyFlags"]
  expected: true

invariant ssl_extra15.VerifyFlags.module:
  description: "ssl.VerifyFlags.__module__ == 'ssl'"
  category: modules
  kind: python_call_eq
  function: VerifyFlags.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra15.VerifyFlags.qualname:
  description: "ssl.VerifyFlags.__qualname__ == 'VerifyFlags'"
  category: class_names
  kind: python_call_eq
  function: VerifyFlags.__qualname__.__eq__
  args: ["VerifyFlags"]
  expected: true

# ---------------------------------------------------------------------------
# ssl.PEM_HEADER and ssl.PEM_FOOTER — PEM certificate delimiters
#
# No prior ssl spec checks PEM_HEADER or PEM_FOOTER.
# These are string constants used when wrapping/unwrapping DER certificates.
# ---------------------------------------------------------------------------

invariant ssl_extra15.PEM_HEADER.value:
  description: "ssl.PEM_HEADER == '-----BEGIN CERTIFICATE-----'"
  category: constants
  kind: python_call_eq
  function: PEM_HEADER.__eq__
  args: ["-----BEGIN CERTIFICATE-----"]
  expected: true

invariant ssl_extra15.PEM_FOOTER.value:
  description: "ssl.PEM_FOOTER == '-----END CERTIFICATE-----'"
  category: constants
  kind: python_call_eq
  function: PEM_FOOTER.__eq__
  args: ["-----END CERTIFICATE-----"]
  expected: true
