spec: doctest_extra2
version: ">=3.9"
backend: python_module(doctest)

docs: https://docs.python.org/3/library/doctest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/doctest.html — Python doctest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/doctest.py"
  notes:
    - "Covers DocTestFinder, DocTestRunner, DocTestParser class names; testmod, testfile, run_docstring_examples __name__; and ELLIPSIS constant value."
    - "ELLIPSIS == 8 in Python 3.12 — it is the 4th power-of-two bitmask (bit index 3)."
    - "NORMALIZE_WHITESPACE == 2, SKIP == 16 in Python 3.12."
    - "DocTestFinder.__module__ == 'doctest', DocTestRunner.__module__ == 'doctest', DocTestParser.__module__ == 'doctest'."
    - "testmod.__module__ == 'doctest', testfile.__module__ == 'doctest'."
    - "run_docstring_examples.__module__ == 'doctest'."
    - "These invariants extend doctest.zspec.zsdl and doctest_extra.zspec.zsdl without duplicating existing checks."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — DocTestFinder, DocTestRunner, DocTestParser
# ---------------------------------------------------------------------------

invariant doctest_extra2.classes.DocTestFinder_name:
  description: "doctest.DocTestFinder.__name__ == 'DocTestFinder'"
  category: classes
  kind: python_call_eq
  function: DocTestFinder.__name__.__eq__
  args: ["DocTestFinder"]
  expected: true

invariant doctest_extra2.classes.DocTestRunner_name:
  description: "doctest.DocTestRunner.__name__ == 'DocTestRunner'"
  category: classes
  kind: python_call_eq
  function: DocTestRunner.__name__.__eq__
  args: ["DocTestRunner"]
  expected: true

invariant doctest_extra2.classes.DocTestParser_name:
  description: "doctest.DocTestParser.__name__ == 'DocTestParser'"
  category: classes
  kind: python_call_eq
  function: DocTestParser.__name__.__eq__
  args: ["DocTestParser"]
  expected: true

# ---------------------------------------------------------------------------
# Class module checks — all live in 'doctest'
# ---------------------------------------------------------------------------

invariant doctest_extra2.class_modules.DocTestFinder_module:
  description: "doctest.DocTestFinder.__module__ == 'doctest'"
  category: class_modules
  kind: python_call_eq
  function: DocTestFinder.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra2.class_modules.DocTestRunner_module:
  description: "doctest.DocTestRunner.__module__ == 'doctest'"
  category: class_modules
  kind: python_call_eq
  function: DocTestRunner.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra2.class_modules.DocTestParser_module:
  description: "doctest.DocTestParser.__module__ == 'doctest'"
  category: class_modules
  kind: python_call_eq
  function: DocTestParser.__module__.__eq__
  args: ["doctest"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks — testmod, testfile, run_docstring_examples
# ---------------------------------------------------------------------------

invariant doctest_extra2.functions.testmod_name:
  description: "doctest.testmod.__name__ == 'testmod'"
  category: functions
  kind: python_call_eq
  function: testmod.__name__.__eq__
  args: ["testmod"]
  expected: true

invariant doctest_extra2.functions.testfile_name:
  description: "doctest.testfile.__name__ == 'testfile'"
  category: functions
  kind: python_call_eq
  function: testfile.__name__.__eq__
  args: ["testfile"]
  expected: true

invariant doctest_extra2.functions.run_docstring_examples_name:
  description: "doctest.run_docstring_examples.__name__ == 'run_docstring_examples'"
  category: functions
  kind: python_call_eq
  function: run_docstring_examples.__name__.__eq__
  args: ["run_docstring_examples"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ checks — all defined in doctest
# ---------------------------------------------------------------------------

invariant doctest_extra2.function_modules.testmod:
  description: "doctest.testmod.__module__ == 'doctest'"
  category: function_modules
  kind: python_call_eq
  function: testmod.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra2.function_modules.testfile:
  description: "doctest.testfile.__module__ == 'doctest'"
  category: function_modules
  kind: python_call_eq
  function: testfile.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra2.function_modules.run_docstring_examples:
  description: "doctest.run_docstring_examples.__module__ == 'doctest'"
  category: function_modules
  kind: python_call_eq
  function: run_docstring_examples.__module__.__eq__
  args: ["doctest"]
  expected: true

# ---------------------------------------------------------------------------
# ELLIPSIS constant — integer value 8
# ---------------------------------------------------------------------------

invariant doctest_extra2.constants.ELLIPSIS_value:
  description: "doctest.ELLIPSIS == 8"
  category: constants
  kind: python_call_eq
  function: ELLIPSIS.__eq__
  args: [8]
  expected: true

invariant doctest_extra2.constants.NORMALIZE_WHITESPACE_value:
  description: "doctest.NORMALIZE_WHITESPACE == 2"
  category: constants
  kind: python_call_eq
  function: NORMALIZE_WHITESPACE.__eq__
  args: [2]
  expected: true

invariant doctest_extra2.constants.SKIP_value:
  description: "doctest.SKIP == 16"
  category: constants
  kind: python_call_eq
  function: SKIP.__eq__
  args: [16]
  expected: true
