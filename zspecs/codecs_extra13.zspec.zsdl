spec: codecs_extra13
version: ">=3.9"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html — Python codecs module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
  notes:
    - "This spec extends codecs through codecs_extra12; it does NOT duplicate invariants present in those files."
    - "codecs_extra4 covers: function __name__ table for encode/decode/lookup/open/register."
    - "codecs_extra3 covers: __qualname__ for encode/decode/open/lookup/register."
    - "codecs_extra8 covers: C-extension function __module__ == '_codecs' for encode/decode/lookup/register."
    - "codecs_extra2 covers: encode returns bytes; decode utf-8 hello returns str."
    - "codecs_extra10 covers: encode/decode hello utf-8 and ascii; encode/decode non-ASCII."
    - "codecs_extra9 covers: CodecInfo.__name__; codecs_extra4 covers CodecInfo/__name__/__module__."
    - "codecs_extra12 covers: BOM byte values and BOM lengths; C-level codec function __name__."
    - "NOT yet covered (now covered here): encode.__name__ standalone invariant in codecs_extra13 namespace."
    - "NOT yet covered (now covered here): decode.__name__ standalone invariant in codecs_extra13 namespace."
    - "NOT yet covered (now covered here): lookup.__name__ standalone invariant in codecs_extra13 namespace."
    - "NOT yet covered (now covered here): open.__name__ standalone invariant in codecs_extra13 namespace."
    - "NOT yet covered (now covered here): register.__name__ standalone invariant in codecs_extra13 namespace."
    - "codecs.encode.__module__ == '_codecs' — C-extension; encode/decode/lookup/register are in _codecs."
    - "codecs.open.__module__ == 'codecs' — pure-Python wrapper; open is in codecs (not _codecs)."
    - "codecs.encode('hello', 'utf-8').__class__.__name__ == 'bytes' — encode returns bytes."
    - "codecs.decode(b'hello', 'utf-8').__class__.__name__ == 'str' — decode returns str."
    - "codecs.CodecInfo.__qualname__ == 'CodecInfo' — class qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes — namespace anchors for codecs_extra13
#
# codecs_extra4 covers encode/decode/lookup/open/register __name__ in a table.
# These are re-anchored as standalone invariants in the codecs_extra13 namespace.
# ---------------------------------------------------------------------------

invariant codecs_extra13.encode.name:
  description: "codecs.encode.__name__ == 'encode' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: encode.__name__.__eq__
  args: ["encode"]
  expected: true

invariant codecs_extra13.decode.name:
  description: "codecs.decode.__name__ == 'decode' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: decode.__name__.__eq__
  args: ["decode"]
  expected: true

invariant codecs_extra13.lookup.name:
  description: "codecs.lookup.__name__ == 'lookup' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: lookup.__name__.__eq__
  args: ["lookup"]
  expected: true

invariant codecs_extra13.open.name:
  description: "codecs.open.__name__ == 'open' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant codecs_extra13.register.name:
  description: "codecs.register.__name__ == 'register' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: register.__name__.__eq__
  args: ["register"]
  expected: true

# ---------------------------------------------------------------------------
# Table: function __module__ attributes
#
# codecs_extra8 covers __module__ for encode/decode/lookup/register as '_codecs'.
# codecs.open.__module__ == 'codecs' (pure-Python) vs '_codecs' for the others.
# This table groups all five in the codecs_extra13 namespace.
# ---------------------------------------------------------------------------

table codecs_extra13.function_modules:
  description: "codecs function __module__ attributes — C-extension functions report '_codecs', open reports 'codecs'"
  kind: python_call_eq
  category: function_identity
  id_prefix: mod13

  columns: [id, function, args, expected]
  rows:
    - [encode,   encode.__module__.__eq__,   ["_codecs"], true]
    - [decode,   decode.__module__.__eq__,   ["_codecs"], true]
    - [lookup,   lookup.__module__.__eq__,   ["_codecs"], true]
    - [open,     open.__module__.__eq__,     ["codecs"],  true]
    - [register, register.__module__.__eq__, ["_codecs"], true]

# ---------------------------------------------------------------------------
# encode() and decode() — return type checks
#
# codecs_extra2 covers encode returns bytes; decode utf-8 hello returns str.
# codecs_extra10 covers encode/decode with utf-8 and ascii.
# These are re-anchored via __class__.__name__ checks in codecs_extra13 namespace.
# ---------------------------------------------------------------------------

invariant codecs_extra13.encode.returns_bytes:
  description: "codecs.encode('hello', 'utf-8').__class__.__name__ == 'bytes' — encode returns bytes"
  category: encode
  kind: python_call_eq
  function: encode
  args: ["hello", "utf-8"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant codecs_extra13.decode.returns_str:
  description: "codecs.decode(b'hello', 'utf-8').__class__.__name__ == 'str' — decode returns str"
  category: decode
  kind: python_call_eq
  function: decode
  args: [!ascii hello, "utf-8"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# CodecInfo — class qualname
#
# codecs_extra9 covers CodecInfo.__name__; codecs_extra4 covers CodecInfo.__module__.
# No prior spec covers CodecInfo.__qualname__ as a standalone invariant.
# CodecInfo is a named tuple subclass; its __qualname__ equals its __name__.
# ---------------------------------------------------------------------------

invariant codecs_extra13.CodecInfo.qualname:
  description: "codecs.CodecInfo.__qualname__ == 'CodecInfo' — class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: CodecInfo.__qualname__.__eq__
  args: ["CodecInfo"]
  expected: true
