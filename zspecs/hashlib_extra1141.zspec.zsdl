spec: hashlib_extra1141
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib.__package__/__loader__ class attrs, algorithms_guaranteed/__contains__ and algorithms_available/__iter__ qualname and class names, HASH instance __repr__ class name and qualname, HASH instance digest_size integer values for md5/sha256/sha512"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1141.package_and_loader_attrs:
  description: "hashlib.__package__ and hashlib.__loader__ class identity"
  kind: python_call_eq
  category: package_loader_attrs
  id_prefix: hl1141pl
  columns: [id, function, args, expected]
  rows:
    - [hl1141pl001, hashlib.__package__.__eq__,                                  [""],                            true]
    - [hl1141pl002, hashlib.__package__.__class__.__name__.__eq__,               ["str"],                         true]
    - [hl1141pl003, hashlib.__package__.__class__.__qualname__.__eq__,           ["str"],                         true]
    - [hl1141pl004, hashlib.__package__.__class__.__module__.__eq__,             ["builtins"],                    true]
    - [hl1141pl005, hashlib.__loader__.__class__.__name__.__eq__,                ["SourceFileLoader"],             true]
    - [hl1141pl006, hashlib.__loader__.__class__.__qualname__.__eq__,            ["SourceFileLoader"],             true]
    - [hl1141pl007, hashlib.__loader__.__class__.__module__.__eq__,              ["_frozen_importlib_external"],   true]
    - [hl1141pl008, hashlib.__package__.__class__.__name__.__class__.__name__.__eq__, ["str"],                    true]

table hashlib_extra1141.algorithms_iter_contains_qualnames:
  description: "algorithms_guaranteed __contains__/__iter__ and algorithms_available __iter__/__contains__ qualname and class names"
  kind: python_call_eq
  category: algorithms_iter_contains_qualnames
  id_prefix: hl1141ic
  columns: [id, function, args, expected]
  rows:
    - [hl1141ic001, hashlib.algorithms_guaranteed.__iter__.__qualname__.__eq__,            ["set.__iter__"],                   true]
    - [hl1141ic002, hashlib.algorithms_guaranteed.__iter__.__class__.__name__.__eq__,      ["method-wrapper"],                  true]
    - [hl1141ic003, hashlib.algorithms_guaranteed.__contains__.__qualname__.__eq__,        ["set.__contains__"],               true]
    - [hl1141ic004, hashlib.algorithms_guaranteed.__contains__.__class__.__name__.__eq__,  ["builtin_function_or_method"],      true]
    - [hl1141ic005, hashlib.algorithms_available.__iter__.__qualname__.__eq__,             ["set.__iter__"],                   true]
    - [hl1141ic006, hashlib.algorithms_available.__iter__.__class__.__name__.__eq__,       ["method-wrapper"],                  true]
    - [hl1141ic007, hashlib.algorithms_available.__contains__.__qualname__.__eq__,         ["set.__contains__"],               true]
    - [hl1141ic008, hashlib.algorithms_available.__contains__.__class__.__name__.__eq__,   ["builtin_function_or_method"],      true]
    - [hl1141ic009, hashlib.algorithms_guaranteed.__iter__.__qualname__.__class__.__name__.__eq__, ["str"],                    true]
    - [hl1141ic010, hashlib.algorithms_available.__contains__.__qualname__.__class__.__name__.__eq__, ["str"],                 true]

table hashlib_extra1141.hash_instance_repr_and_digest_size:
  description: "HASH instance __repr__ class name and qualname, and digest_size integer values for md5/sha256/sha512"
  kind: python_call_eq
  category: hash_instance_repr_digest_size
  id_prefix: hl1141hr
  columns: [id, function, args, expected]
  rows:
    - [hl1141hr001, hashlib.md5.__call__.__class__.__name__.__eq__,              ["method-wrapper"],   true]
    - [hl1141hr002, hashlib.md5().__repr__.__class__.__name__.__eq__,            ["method-wrapper"],   true]
    - [hl1141hr003, hashlib.md5().__repr__.__qualname__.__eq__,                  ["HASH.__repr__"],    true]
    - [hl1141hr004, hashlib.sha256().__repr__.__class__.__name__.__eq__,         ["method-wrapper"],   true]
    - [hl1141hr005, hashlib.sha256().__repr__.__qualname__.__eq__,               ["HASH.__repr__"],    true]
    - [hl1141hr006, hashlib.md5().digest_size.__eq__,                            [16],                 true]
    - [hl1141hr007, hashlib.sha256().digest_size.__eq__,                         [32],                 true]
    - [hl1141hr008, hashlib.sha512().digest_size.__eq__,                         [64],                 true]
    - [hl1141hr009, hashlib.md5().digest_size.__class__.__name__.__eq__,         ["int"],              true]
    - [hl1141hr010, hashlib.sha256().digest_size.__class__.__name__.__eq__,      ["int"],              true]
    - [hl1141hr011, hashlib.sha512().digest_size.__class__.__name__.__eq__,      ["int"],              true]
    - [hl1141hr012, hashlib.sha1().name.__eq__,                                  ["sha1"],             true]
    - [hl1141hr013, hashlib.sha512().name.__eq__,                                ["sha512"],           true]
