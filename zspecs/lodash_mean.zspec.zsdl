spec: lodash_mean
version: ">=4.0.0"
backend: node(lodash.mean)

docs: https://lodash.com/docs/#mean

provenance:
  derived_from:
    - "lodash.mean README — https://www.npmjs.com/package/lodash.mean"
    - "Test vectors verified with lodash.mean@4.1.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.mean exports the _.mean function directly as module.exports."
    - "mean(array) computes the arithmetic mean of the values in array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_mean.mean:
  kind: node_module_call_eq
  function: ~
  category: mean
  id_prefix: lmean

  columns: [id, args, expected]
  rows:
    - [one_to_five,  [[1, 2, 3, 4, 5]],  3]
    - [endpoints,    [[0, 100]],          50]
    - [single,       [[7]],               7]
    - [negatives,    [[-4, -2]],          -3]
