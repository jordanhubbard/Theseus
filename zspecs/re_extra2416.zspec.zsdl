spec: re_extra2416
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/re.html"
    - "CPython source — Modules/_sre.c, Lib/re/__init__.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "re.Pattern and re.Match are C-extension types; neither defines __iter__ or __next__ in its class __dict__."
    - "re.error is an exception subclass; it does not define __iter__ or __next__."
    - "re.RegexFlag is an enum.Flag subclass; it does not define __iter__ or __next__ in its own __dict__ (Flag provides __iter__ through its own class)."
    - "re.Scanner is a pure-Python class; it does not define __iter__ or __next__ in its __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
