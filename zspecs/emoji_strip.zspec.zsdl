spec: emoji_strip
version: ">=1.0.0"
backend: node(emoji-strip)

docs: https://www.npmjs.com/package/emoji-strip

provenance:
  derived_from:
    - "emoji-strip README — https://www.npmjs.com/package/emoji-strip"
    - "Test vectors verified with emoji-strip via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "emoji-strip source"
  notes:
    - "emoji-strip is an npm package. Install: npm install emoji-strip"
    - "emojiStrip(str) removes emoji characters from a string."
    - "Emoji are replaced with empty string; surrounding whitespace is preserved."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string with emoji removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table emoji_strip.strip:
  kind: node_module_call_eq
  function: ~
  category: strip
  id_prefix: emjs

  columns: [id, args, expected]
  rows:
    - [with_emoji,  ["Hello 😀 World"], "Hello  World"]
    - [no_emoji,    ["plain text"],     "plain text"]
    - [empty,       [""],               ""]
