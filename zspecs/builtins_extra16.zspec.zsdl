spec: builtins_extra16
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/exceptions.html — Python exceptions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Objects/exceptions.c"
  notes:
    - "This spec extends prior builtins specs."
    - "BaseException.__qualname__ == 'BaseException' — root of the exception hierarchy."
    - "Exception.__qualname__ == 'Exception' — base for all non-system-exiting exceptions."
    - "Exception.__bases__[0].__name__ == 'BaseException' — Exception derives from BaseException."
    - "ValueError.__bases__[0].__name__ == 'Exception' — raised for inappropriate argument values."
    - "TypeError.__bases__[0].__name__ == 'Exception' — raised for inappropriate argument types."
    - "AttributeError.__bases__[0].__name__ == 'Exception' — raised when attribute lookup fails."
    - "KeyError.__bases__[0].__name__ == 'LookupError' — raised when dict key is missing."
    - "IndexError.__bases__[0].__name__ == 'LookupError' — raised when sequence index is out of range."
    - "LookupError.__bases__[0].__name__ == 'Exception' — base for key/index lookup errors."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BaseException and Exception — __qualname__
#
# These are the two root classes of the Python exception hierarchy.
# BaseException is the ultimate base; Exception is the base for all
# non-system-exiting exceptions.
# ---------------------------------------------------------------------------

invariant builtins_extra16.BaseException.qualname:
  description: "BaseException.__qualname__ == 'BaseException' — root of the exception hierarchy"
  category: exception_classes
  kind: python_call_eq
  function: BaseException.__qualname__.__eq__
  args: ["BaseException"]
  expected: true

invariant builtins_extra16.Exception.qualname:
  description: "Exception.__qualname__ == 'Exception' — base for non-system-exiting exceptions"
  category: exception_classes
  kind: python_call_eq
  function: Exception.__qualname__.__eq__
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Exception base class chain
#
# Exception inherits from BaseException. This invariant verifies the first
# element of Exception.__bases__ is named 'BaseException'.
# ---------------------------------------------------------------------------

invariant builtins_extra16.Exception.base:
  description: "Exception.__bases__[0].__name__ == 'BaseException'"
  category: exception_hierarchy
  kind: python_call_eq
  function: Exception.__bases__.__getitem__(0).__name__.__eq__
  args: ["BaseException"]
  expected: true

# ---------------------------------------------------------------------------
# LookupError — base class
#
# LookupError inherits from Exception. It is the common base for
# KeyError and IndexError.
# ---------------------------------------------------------------------------

invariant builtins_extra16.LookupError.base:
  description: "LookupError.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: LookupError.__bases__.__getitem__(0).__name__.__eq__
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# ValueError, TypeError, AttributeError — base classes
#
# Each of these common exceptions derives directly from Exception.
# ---------------------------------------------------------------------------

invariant builtins_extra16.ValueError.base:
  description: "ValueError.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: ValueError.__bases__.__getitem__(0).__name__.__eq__
  args: ["Exception"]
  expected: true

invariant builtins_extra16.TypeError.base:
  description: "TypeError.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: TypeError.__bases__.__getitem__(0).__name__.__eq__
  args: ["Exception"]
  expected: true

invariant builtins_extra16.AttributeError.base:
  description: "AttributeError.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: AttributeError.__bases__.__getitem__(0).__name__.__eq__
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# KeyError, IndexError — derive from LookupError
#
# Both lookup-based exceptions share LookupError as their immediate parent.
# ---------------------------------------------------------------------------

invariant builtins_extra16.KeyError.base:
  description: "KeyError.__bases__[0].__name__ == 'LookupError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: KeyError.__bases__.__getitem__(0).__name__.__eq__
  args: ["LookupError"]
  expected: true

invariant builtins_extra16.IndexError.base:
  description: "IndexError.__bases__[0].__name__ == 'LookupError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: IndexError.__bases__.__getitem__(0).__name__.__eq__
  args: ["LookupError"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table for ValueError/TypeError/AttributeError/KeyError/IndexError/LookupError
#
# All of these are simple non-nested exception classes so their __qualname__
# equals their __name__.
# ---------------------------------------------------------------------------

table builtins_extra16.exception_qualnames:
  description: "__qualname__ attributes for ValueError/TypeError/AttributeError/KeyError/IndexError/LookupError"
  kind: python_call_eq
  category: exception_classes

  columns: [id, function, args, expected]
  rows:
    - [ValueError,      ValueError.__qualname__.__eq__,      ["ValueError"],      true]
    - [TypeError,       TypeError.__qualname__.__eq__,       ["TypeError"],       true]
    - [AttributeError,  AttributeError.__qualname__.__eq__,  ["AttributeError"],  true]
    - [KeyError,        KeyError.__qualname__.__eq__,        ["KeyError"],        true]
    - [IndexError,      IndexError.__qualname__.__eq__,      ["IndexError"],      true]
    - [LookupError,     LookupError.__qualname__.__eq__,     ["LookupError"],     true]
