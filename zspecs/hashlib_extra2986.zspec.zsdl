spec: hl2986
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib: Secure hashes and message digests"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (hl2986): __len__, __length_hint__, __contains__ dict-presence checks for hashlib types."
    - "hashlib hash classes are cryptographic digest objects, not containers or sequences — none define __len__, __length_hint__, or __contains__ in their own __dict__."
    - "Verified types: type(hashlib.md5()), type(hashlib.sha256()), hashlib.blake2b, hashlib.blake2s."
    - "type(hashlib.md5()) and type(hashlib.sha256()) both yield the C-level HASH type from _hashlib."
    - "hashlib.blake2b and hashlib.blake2s are C extension types exposed directly from _blake2."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl2986.len:
  description: "hashlib types __len__ dict-presence checks; wave 646"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2986
  columns: [id, function, args, expected]
  rows:
    - ["hl2986001", operator.contains, [type(hashlib.md5()).__dict__,     "__len__"], false]
    - ["hl2986002", operator.contains, [type(hashlib.sha256()).__dict__,  "__len__"], false]
    - ["hl2986003", operator.contains, [hashlib.blake2b.__dict__,         "__len__"], false]
    - ["hl2986004", operator.contains, [hashlib.blake2s.__dict__,         "__len__"], false]

