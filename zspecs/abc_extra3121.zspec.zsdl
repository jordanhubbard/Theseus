spec: ab3121
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (ab3121): __ge__, __repr__, __str__ dict-presence for abc module types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "Key finding (__ge__): all 3 abc subjects return false for __ge__. Consistent with wave 654 (ab3106) which showed all false for __lt__/__le__/__gt__ as well. No ordering operators are defined in the abc module's own class __dict__s."
    - "Key finding (__repr__): type(abc.abstractmethod(lambda: None)) — i.e. <class 'function'> — defines __repr__ in its own __dict__ (true). abc.ABC and abc.ABCMeta return false. The function type's __repr__ produces the '<function name at 0x...>' string familiar from Python REPLs."
    - "Key finding (__str__): all 3 abc subjects return false for __str__. None define a dedicated __str__; str() falls back to __repr__ via object.__str__ for all three."
    - "abc.ABC does not define __repr__ — as a plain base class with no instance data, it has no meaningful state to display. Instances display the default object repr (type + address)."
    - "abc.ABCMeta does not define __repr__ in its own __dict__. ABCMeta is a metaclass and inherits type.__repr__, which produces '<class MyClass>' output. Since type.__repr__ is defined on type (not on ABCMeta itself), operator.contains(ABCMeta.__dict__, '__repr__') returns false."
    - "type(abc.abstractmethod(lambda: None)) is <class 'function'>. Functions define __repr__ directly on the function type to produce '<function <lambda> at 0x...>' style output."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ge__ dict-presence — operator.contains(Cls.__dict__, '__ge__')
#
# All 3 abc subjects return false for __ge__.
# abc.ABC and abc.ABCMeta are abstract-class infrastructure with no ordering.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>; functions
# do not define __ge__ — comparing them raises TypeError at runtime.
# Consistent with wave 654 (ab3106): all false for __lt__/__le__/__gt__ too.
# ---------------------------------------------------------------------------

table ab3121.ge:
  description: "abc types __ge__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3121

  columns: [id, function, args, expected]
  rows:
    - ["ab3121001", operator.contains, [abc.ABC.__dict__,                                 "__ge__"], false]
    - ["ab3121002", operator.contains, [abc.ABCMeta.__dict__,                             "__ge__"], false]
    - ["ab3121003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__ge__"], false]

# ---------------------------------------------------------------------------
# __repr__ dict-presence — operator.contains(Cls.__dict__, '__repr__')
#
# type(abc.abstractmethod(lambda: None)) is <class 'function'>: TRUE — the
#   function type defines __repr__ in its own __dict__ to produce the familiar
#   '<function name at 0x...>' string representation.
# abc.ABC: false — no __repr__ defined; instances display the default
#   object representation (type name + memory address).
# abc.ABCMeta: false — ABCMeta inherits type.__repr__ but does not define its
#   own; operator.contains(ABCMeta.__dict__, '__repr__') therefore returns false.
# ---------------------------------------------------------------------------

table ab3121.repr:
  description: "abc types __repr__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3121

  columns: [id, function, args, expected]
  rows:
    - ["ab3121004", operator.contains, [abc.ABC.__dict__,                                 "__repr__"], false]
    - ["ab3121005", operator.contains, [abc.ABCMeta.__dict__,                             "__repr__"], false]
    - ["ab3121006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__repr__"], true]

# ---------------------------------------------------------------------------
# __str__ dict-presence — operator.contains(Cls.__dict__, '__str__')
#
# All 3 abc subjects return false for __str__.
# None define a dedicated __str__; str() falls back to __repr__ via
# object.__str__ for all three subjects.
# ---------------------------------------------------------------------------

table ab3121.str:
  description: "abc types __str__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3121

  columns: [id, function, args, expected]
  rows:
    - ["ab3121007", operator.contains, [abc.ABC.__dict__,                                 "__str__"], false]
    - ["ab3121008", operator.contains, [abc.ABCMeta.__dict__,                             "__str__"], false]
    - ["ab3121009", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__str__"], false]

# ---------------------------------------------------------------------------
# combined — __ge__, __repr__, __str__ across all 3 abc subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __ge__:   false for all 3 — no ordering defined for abc types.
# __repr__: true only for type(abstractmethod(lambda: None)) (<class 'function'>);
#           false for abc.ABC and abc.ABCMeta.
# __str__:  false for all 3 — no custom string conversion defined.
# The only non-false value is the function type's __repr__ (true).
# Note the asymmetry: abc.ABCMeta inherits type.__repr__ at runtime, so
# repr(ABCMeta) works, but __repr__ is not in ABCMeta.__dict__ itself.
# Similarly, function.__repr__ IS in function.__dict__, which is why
# the function type returns true here.
# Cross-wave summary for abc subjects:
#   Wave 652 (ab3076): __get__ true for function type; __set__/__delete__ false for all.
#   Wave 653 (ab3091): __hash__/__eq__/__bool__ all false for all 3.
#   Wave 654 (ab3106): __lt__/__le__/__gt__ all false for all 3.
#   Wave 655 (ab3121): __ge__ false for all 3; __repr__ true for function type only.
# ---------------------------------------------------------------------------

table ab3121.combined:
  description: "abc types combined __ge__/__repr__/__str__; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3121

  columns: [id, function, args, expected]
  rows:
    - ["ab3121010", operator.contains, [abc.ABC.__dict__,                                 "__ge__"],   false]
    - ["ab3121011", operator.contains, [abc.ABC.__dict__,                                 "__repr__"], false]
    - ["ab3121012", operator.contains, [abc.ABC.__dict__,                                 "__str__"],  false]
    - ["ab3121013", operator.contains, [abc.ABCMeta.__dict__,                             "__ge__"],   false]
    - ["ab3121014", operator.contains, [abc.ABCMeta.__dict__,                             "__repr__"], false]
    - ["ab3121015", operator.contains, [abc.ABCMeta.__dict__,                             "__str__"],  false]
    - ["ab3121016", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__ge__"],   false]
    - ["ab3121017", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__repr__"], true]
    - ["ab3121018", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__str__"],  false]
