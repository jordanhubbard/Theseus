spec: ssl_extra9
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "OpenSSL source"
  notes:
    - "This spec extends ssl.zspec.zsdl and prior extras through ssl_extra8.zspec.zsdl."
    - "Focus: ssl.Protocol class metadata (__name__, __module__, __qualname__, __bases__[0].__name__); qualnames for SSLWantReadError/SSLWantWriteError/SSLObject not yet in extra8 table; wrap_socket.__module__."
    - "ssl.Protocol is an IntEnum defined in ssl.py; its __name__ == 'Protocol', __module__ == 'ssl', __qualname__ == 'Protocol', __bases__[0].__name__ == 'IntEnum'."
    - "PROTOCOL_TLS_CLIENT.__class__.__name__ == 'Protocol' is covered by ssl_extra.zspec.zsdl; this spec targets the Protocol *class itself*."
    - "ssl_extra8.class_qualnames table covers SSLContext/SSLSocket/SSLError/create_default_context qualnames; SSLWantReadError/SSLWantWriteError/SSLObject qualnames are new."
    - "ssl.wrap_socket.__module__ == 'ssl' — extra8 checks wrap_socket.__qualname__, not __module__."
    - "ssl.AlertDescription.__qualname__ == 'AlertDescription' — extra5 checks name/base/module but not qualname."
    - "ssl.SSLErrorNumber.__qualname__ == 'SSLErrorNumber' — extra5 checks name/base/module but not qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Protocol enum — class metadata
# ssl_extra covers PROTOCOL_TLS_CLIENT.__class__.__name__ == 'Protocol' (instance type).
# No prior spec checks the Protocol *class itself*: __name__, __module__,
# __qualname__, or __bases__[0].__name__.
# ---------------------------------------------------------------------------

invariant ssl_extra9.Protocol.name:
  description: "ssl.Protocol.__name__ == 'Protocol'"
  category: class_names
  kind: python_call_eq
  function: Protocol.__name__.__eq__
  args: ["Protocol"]
  expected: true

invariant ssl_extra9.Protocol.module:
  description: "ssl.Protocol.__module__ == 'ssl'"
  category: modules
  kind: python_call_eq
  function: Protocol.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra9.Protocol.qualname:
  description: "ssl.Protocol.__qualname__ == 'Protocol'"
  category: qualnames
  kind: python_call_eq
  function: Protocol.__qualname__.__eq__
  args: ["Protocol"]
  expected: true

invariant ssl_extra9.Protocol.base:
  description: "ssl.Protocol.__bases__[0].__name__ == 'IntEnum' — Protocol is an IntEnum subclass"
  category: hierarchy
  kind: python_call_eq
  function: Protocol.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntEnum"

# ---------------------------------------------------------------------------
# SSLWantReadError / SSLWantWriteError / SSLObject — __qualname__
# ssl_extra8.class_qualnames table covers SSLContext/SSLSocket/SSLError/create_default_context.
# ssl_extra8 individual invariants add SSLCertVerificationError/SSLZeroReturnError.
# SSLWantReadError, SSLWantWriteError, and SSLObject qualnames are not yet covered.
# ---------------------------------------------------------------------------

table ssl_extra9.exception_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [SSLWantReadError,  SSLWantReadError.__qualname__.__eq__,  ["SSLWantReadError"],  true]
    - [SSLWantWriteError, SSLWantWriteError.__qualname__.__eq__, ["SSLWantWriteError"], true]
    - [SSLObject,         SSLObject.__qualname__.__eq__,         ["SSLObject"],         true]

# ---------------------------------------------------------------------------
# AlertDescription and SSLErrorNumber — __qualname__
# ssl_extra5 checks __name__, __bases__[0].__name__, and __module__ for both.
# ssl_extra6 adds VerifyMode.__qualname__ and Options.__qualname__.
# AlertDescription.__qualname__ and SSLErrorNumber.__qualname__ are new here.
# ---------------------------------------------------------------------------

invariant ssl_extra9.AlertDescription.qualname:
  description: "ssl.AlertDescription.__qualname__ == 'AlertDescription'"
  category: qualnames
  kind: python_call_eq
  function: AlertDescription.__qualname__.__eq__
  args: ["AlertDescription"]
  expected: true

invariant ssl_extra9.SSLErrorNumber.qualname:
  description: "ssl.SSLErrorNumber.__qualname__ == 'SSLErrorNumber'"
  category: qualnames
  kind: python_call_eq
  function: SSLErrorNumber.__qualname__.__eq__
  args: ["SSLErrorNumber"]
  expected: true

# ---------------------------------------------------------------------------
# wrap_socket.__module__
# ssl_extra8 checks wrap_socket.__qualname__ == 'wrap_socket'.
# No prior spec checks wrap_socket.__module__; wrap_socket is defined in ssl.py.
# ---------------------------------------------------------------------------

invariant ssl_extra9.wrap_socket.module:
  description: "ssl.wrap_socket.__module__ == 'ssl'"
  category: modules
  kind: python_call_eq
  function: wrap_socket.__module__.__eq__
  args: ["ssl"]
  expected: true
