spec: io_extra435
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module stream class hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers class identity for all four ABC stream classes and three concrete classes"
    - "__bases__[0] function fields are double-quoted per ZSDL rules for bracket expressions"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra435.class_names:
  description: "Class __name__ identity for io stream classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: ion

  columns: [id, function, args, expected]
  rows:
    - [ion001, io.IOBase.__name__.__eq__, ["IOBase"], true]
    - [ion002, io.RawIOBase.__name__.__eq__, ["RawIOBase"], true]
    - [ion003, io.BufferedIOBase.__name__.__eq__, ["BufferedIOBase"], true]
    - [ion004, io.TextIOBase.__name__.__eq__, ["TextIOBase"], true]
    - [ion005, io.StringIO.__name__.__eq__, ["StringIO"], true]
    - [ion006, io.BytesIO.__name__.__eq__, ["BytesIO"], true]
    - [ion007, io.FileIO.__name__.__eq__, ["FileIO"], true]

table io_extra435.class_modules:
  description: "Class __module__ identity for io stream classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: iom

  columns: [id, function, args, expected]
  rows:
    - [iom001, io.IOBase.__module__.__eq__, ["io"], true]
    - [iom002, io.RawIOBase.__module__.__eq__, ["io"], true]
    - [iom003, io.BufferedIOBase.__module__.__eq__, ["io"], true]
    - [iom004, io.TextIOBase.__module__.__eq__, ["io"], true]

table io_extra435.class_bases:
  description: "Base class identity for io stream ABC classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: iob

  columns: [id, function, args, expected]
  rows:
    - [iob001, "io.IOBase.__bases__[0].__name__.__eq__", ["object"], true]
    - [iob002, "io.RawIOBase.__bases__[0].__name__.__eq__", ["IOBase"], true]
    - [iob003, "io.BufferedIOBase.__bases__[0].__name__.__eq__", ["IOBase"], true]
    - [iob004, "io.TextIOBase.__bases__[0].__name__.__eq__", ["IOBase"], true]
