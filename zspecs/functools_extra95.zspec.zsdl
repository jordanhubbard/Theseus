spec: functools_extra95
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra94

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra94.zspec.zsdl."
    - "This spec covers: functools class hierarchy — __bases__[0].__name__ and __mro__.__len__() for partial, partialmethod, cached_property; and __module__ string equality for Python and C functions (Wave 250)."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial is a C type in _functoolsmodule.c; it directly inherits from object. Verified with Python 3.14.3."
    - "functools.partial.__mro__.__len__() == 2 — MRO is (partial, object); length 2. Verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod is a pure-Python class in Lib/functools.py that directly inherits from object. Verified with Python 3.14.3."
    - "functools.partialmethod.__mro__.__len__() == 2 — MRO is (partialmethod, object); length 2. Verified with Python 3.14.3."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property is a pure-Python class in Lib/functools.py that directly inherits from object. Verified with Python 3.14.3."
    - "functools.cached_property.__mro__.__len__() == 2 — MRO is (cached_property, object); length 2. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is a pure-Python decorator defined in Lib/functools.py; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is a pure-Python decorator in Lib/functools.py; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is a pure-Python decorator in Lib/functools.py; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is a pure-Python function in Lib/functools.py; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.wraps.__module__.__eq__('functools') == True — wraps is a pure-Python function in Lib/functools.py; __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.reduce.__module__.__eq__('_functools') == True — reduce is a C builtin in Modules/_functoolsmodule.c; __module__ is '_functools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partial and partialmethod class hierarchy
#
# Wave 250 theme: functools class hierarchy — __bases__[0].__name__ for partial and partialmethod.
#
# functools.partial.__bases__[0].__name__.__eq__('object')      == True
# functools.partialmethod.__bases__[0].__name__.__eq__('object') == True
# functools.partial.__mro__.__len__()                            == 2
# functools.partialmethod.__mro__.__len__()                      == 2
#
# Prior spec extra94 checked WRAPPER_ASSIGNMENTS membership. This spec (extra95) checks class hierarchy. New to extra95.
# ---------------------------------------------------------------------------

table functools_extra95.partial_partialmethod_hierarchy:
  description: "partial/partialmethod __bases__[0].__name__ and __mro__.__len__(); both directly inherit from object; wave 250; new to extra95"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: functoolshier95

  columns: [id, function, args, expected, description]
  rows:
    - [partial_bases0_name_eq_object,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial is a C extension type defined in Modules/_functoolsmodule.c; it directly inherits from object with no intermediate base class; __bases__ is (object,); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; prior spec extra94 checked WRAPPER_ASSIGNMENTS membership; this spec (extra95) checks class hierarchy; new to extra95"]
    - [partialmethod_bases0_name_eq_object,
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — partialmethod is a pure-Python class in Lib/functools.py; it directly inherits from object; __bases__ is (object,); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra95"]
    - [partial_mro_len_eq_2,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — partial is a C extension type that directly inherits from object; MRO is (partial, object); tuple.__len__() returns 2; new to extra95"]
    - [partialmethod_mro_len_eq_2,
       "partialmethod.__mro__.__len__",
       [],
       2,
       "functools.partialmethod.__mro__.__len__() == 2 — partialmethod is a pure-Python class that directly inherits from object; MRO is (partialmethod, object); tuple.__len__() returns 2; new to extra95"]

# ---------------------------------------------------------------------------
# cached_property hierarchy and MRO depths
#
# Wave 250 theme: functools class hierarchy — cached_property base and MRO depth.
#
# functools.cached_property.__bases__[0].__name__.__eq__('object') == True
# functools.cached_property.__mro__.__len__()                       == 2
# functools.partial.__bases__[0].__name__.__eq__('object')          == True  (re-confirm)
# functools.partial.__mro__.__len__()                                == 2  (re-confirm)
#
# No prior functools spec checks cached_property class hierarchy via functoolshier95. New to extra95.
# ---------------------------------------------------------------------------

table functools_extra95.cached_property_hierarchy_and_mro_depths:
  description: "cached_property __bases__[0].__name__ and __mro__.__len__(); plus partial hierarchy re-confirms; wave 250; new to extra95"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: functoolshier95

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_bases0_name_eq_object,
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property is a pure-Python descriptor class in Lib/functools.py; it directly inherits from object; __bases__ is (object,); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior functools spec checks cached_property class hierarchy via functoolshier95; new to extra95"]
    - [cached_property_mro_len_eq_2,
       "cached_property.__mro__.__len__",
       [],
       2,
       "functools.cached_property.__mro__.__len__() == 2 — cached_property is a pure-Python class that directly inherits from object; MRO is (cached_property, object); tuple.__len__() returns 2; new to extra95"]
    - [partial_bases0_name_eq_object_reconfirm,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — re-confirms partial inherits from object; partial is a C extension type in Modules/_functoolsmodule.c; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra95"]
    - [partial_mro_len_eq_2_reconfirm,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — re-confirms partial MRO length; MRO is (partial, object); tuple.__len__() returns 2; new to extra95"]

# ---------------------------------------------------------------------------
# Python function __module__ string equality
#
# Wave 250 theme: functools Python function __module__ values — pure-Python functions.
#
# functools.total_ordering.__module__.__eq__('functools')  == True
# functools.singledispatch.__module__.__eq__('functools')  == True
# functools.lru_cache.__module__.__eq__('functools')       == True
# functools.update_wrapper.__module__.__eq__('functools')  == True
#
# No prior functools spec checks function __module__ via functoolshier95. New to extra95.
# ---------------------------------------------------------------------------

table functools_extra95.python_function_modules:
  description: "total_ordering/singledispatch/lru_cache/update_wrapper __module__ == 'functools'; pure-Python functions; wave 250; new to extra95"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolshier95

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_module_eq_functools,
       total_ordering.__module__.__eq__,
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is a class decorator defined in Lib/functools.py that fills in missing comparison methods; as a pure-Python function its __module__ is 'functools'; str.__eq__('functools') returns True; no prior functools spec checks function __module__ via functoolshier95; new to extra95"]
    - [singledispatch_module_eq_functools,
       singledispatch.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is a decorator defined in Lib/functools.py that transforms a function into a single-dispatch generic function; as a pure-Python function its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra95"]
    - [lru_cache_module_eq_functools,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is a decorator defined in Lib/functools.py that wraps a function with memoization using a least-recently-used cache; as a pure-Python function its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra95"]
    - [update_wrapper_module_eq_functools,
       update_wrapper.__module__.__eq__,
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is a function defined in Lib/functools.py that updates a wrapper function to look like the wrapped function; as a pure-Python function its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra95"]

# ---------------------------------------------------------------------------
# C builtin and wraps __module__ checks
#
# Wave 250 theme: functools __module__ values — wraps (Python) and reduce (C builtin).
#
# functools.wraps.__module__.__eq__('functools')  == True  (Python function)
# functools.reduce.__module__.__eq__('_functools') == True  (C builtin — note underscore prefix)
# functools.wraps.__module__.__eq__('_functools') == False (cross-check)
# functools.reduce.__module__.__eq__('functools') == False (cross-check)
#
# reduce is defined in C in Modules/_functoolsmodule.c; its __module__ is '_functools'. New to extra95.
# ---------------------------------------------------------------------------

table functools_extra95.c_builtin_and_wraps_modules:
  description: "wraps.__module__=='functools'; reduce.__module__=='_functools' (C builtin); cross-checks; wave 250; new to extra95"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolshier95

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_module_eq_functools,
       wraps.__module__.__eq__,
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is a convenience decorator defined in Lib/functools.py that applies update_wrapper(); as a pure-Python function its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra95"]
    - [reduce_module_eq_functools_c,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is a C builtin defined in Modules/_functoolsmodule.c; C extension functions have __module__ set to the C module name '_functools' (with underscore prefix), not the Python wrapper module 'functools'; str.__eq__('_functools') returns True; new to extra95"]
    - [wraps_module_ne_functools_c,
       wraps.__module__.__eq__,
       ["_functools"],
       false,
       "functools.wraps.__module__.__eq__('_functools') == False — wraps is a pure-Python function so __module__ is 'functools', not '_functools'; str.__eq__('_functools') returns False; confirms distinction between Python and C implementations; new to extra95"]
    - [reduce_module_ne_functools,
       reduce.__module__.__eq__,
       ["functools"],
       false,
       "functools.reduce.__module__.__eq__('functools') == False — reduce is a C builtin in _functoolsmodule.c so __module__ is '_functools', not 'functools'; str.__eq__('functools') returns False; confirms C builtins use the C module name; new to extra95"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra95
# ---------------------------------------------------------------------------

invariant functools_extra95.partial_bases0_name_eq_object:
  description: "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial C type directly inherits from object; wave 250; new to extra95"
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra95.partial_mro_len_eq_2:
  description: "functools.partial.__mro__.__len__() == 2 — partial MRO is (partial, object); wave 250; new to extra95"
  kind: python_call_eq
  function: "partial.__mro__.__len__"
  args: []
  expected: 2

invariant functools_extra95.cached_property_bases0_name_eq_object:
  description: "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property directly inherits from object; wave 250; new to extra95"
  kind: python_call_eq
  function: "cached_property.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra95.total_ordering_module_eq_functools:
  description: "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is a pure-Python function; wave 250; new to extra95"
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra95.reduce_module_eq_functools_c:
  description: "functools.reduce.__module__.__eq__('_functools') == True — reduce is a C builtin in _functoolsmodule.c; wave 250; new to extra95"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true
