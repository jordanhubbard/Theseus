spec: multiprocessing_extra180
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec covers: multiprocessing.pool.Pool class identity and multiprocessing.pool.AsyncResult class identity. multiprocessing.Pool at the top-level is a bound method of the default context (type=method, __qualname__=='BaseContext.Pool'), so Pool class identity is tested via multiprocessing.pool.Pool. multiprocessing.pool.Pool.__name__=='Pool' (len=4); __module__=='multiprocessing.pool'; __qualname__=='Pool'; __bases__[0].__name__=='object'."
    - "multiprocessing.pool.AsyncResult.__name__ == 'ApplyResult' (len=11). AsyncResult is an alias for ApplyResult in multiprocessing.pool — the class's own __name__ is 'ApplyResult', not 'AsyncResult'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.AsyncResult.__module__ == 'multiprocessing.pool'. The class (also named ApplyResult) is defined in multiprocessing.pool. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.Pool.__bases__[0].__name__ == 'object'. Pool inherits directly from object in Python 3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

