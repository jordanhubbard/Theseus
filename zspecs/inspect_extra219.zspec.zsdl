spec: inspect_extra219
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.signature, inspect.getmembers, inspect.getsource, inspect.Parameter, and inspect.Signature (wave 385)."
    - "inspect.signature(len).__str__() == '(obj, /)'. Verified with Python 3.14.3."
    - "inspect.getmembers.__name__ == 'getmembers'; __module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.getsource.__name__ == 'getsource'; __module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.__name__ == 'Parameter'; __module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Signature.__name__ == 'Signature'; __module__ == 'inspect'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers and inspect.getsource __name__ / __module__
#
# Both are pure-Python functions defined in Lib/inspect.py.
# Their __name__ and __module__ attributes are stable string invariants.
#
# Verified with Python 3.14.3:
#   inspect.getmembers.__name__ == 'getmembers'
#   inspect.getmembers.__module__ == 'inspect'
#   inspect.getsource.__name__ == 'getsource'
#   inspect.getsource.__module__ == 'inspect'
# ---------------------------------------------------------------------------

table inspect_extra219.function_identity:
  description: "inspect.getmembers and inspect.getsource __name__ and __module__ checks; wave 385; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra219funcidentity

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name_eq,
       getmembers.__name__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__name__.__eq__('getmembers') == True — getmembers returns all attributes of an object as (name, value) pairs; its __name__ is 'getmembers'; str.__eq__('getmembers') returns True; new to extra219"]
    - [getmembers_module_eq,
       getmembers.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is a pure-Python function defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra219"]
    - [getsource_name_eq,
       getsource.__name__.__eq__,
       ["getsource"],
       true,
       "inspect.getsource.__name__.__eq__('getsource') == True — getsource returns the text of the source code for an object; its __name__ is 'getsource'; str.__eq__('getsource') returns True; new to extra219"]
    - [getsource_module_eq,
       getsource.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsource.__module__.__eq__('inspect') == True — getsource is a pure-Python function defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra219"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter class identity checks
#
# inspect.Parameter represents a parameter in a function signature.
# Its __name__ and __module__ are stable string invariants.
#
# Verified with Python 3.14.3:
#   inspect.Parameter.__name__ == 'Parameter'
#   inspect.Parameter.__module__ == 'inspect'
# ---------------------------------------------------------------------------

table inspect_extra219.parameter_class_identity:
  description: "inspect.Parameter class __name__ and __module__ identity checks; wave 385; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra219paramcls

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_name_eq,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter represents a callable's parameter in the inspect API; its __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra219"]
    - [parameter_module_eq,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra219"]
    - [parameter_name_len,
       Parameter.__name__.__len__,
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — 'Parameter' has 9 characters; str.__len__() returns 9; new to extra219"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter kind enum checks
#
# Parameter.POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, and KEYWORD_ONLY are enum
# members of the _ParameterKind enum class. Their __class__.__name__ is
# '_ParameterKind'.
#
# Verified with Python 3.14.3:
#   type(Parameter.POSITIONAL_OR_KEYWORD).__name__ == '_ParameterKind'
#   type(Parameter.VAR_POSITIONAL).__name__ == '_ParameterKind'
#   type(Parameter.KEYWORD_ONLY).__name__ == '_ParameterKind'
# ---------------------------------------------------------------------------

table inspect_extra219.parameter_kind_checks:
  description: "inspect.Parameter kind enum member __class__.__name__ checks; wave 385; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra219paramkind

  columns: [id, function, args, expected, description]
  rows:
    - [positional_or_keyword_class_name,
       Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD is a member of the _ParameterKind enum; its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra219"]
    - [var_positional_class_name,
       Parameter.VAR_POSITIONAL.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — VAR_POSITIONAL (for *args) is a _ParameterKind enum member; its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra219"]
    - [keyword_only_class_name,
       Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY (for params after *) is a _ParameterKind enum member; its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra219"]

# ---------------------------------------------------------------------------
# Table 4: inspect.Signature class identity checks
#
# inspect.Signature represents a function's call signature.
# Its __name__ and __module__ are stable string invariants.
#
# Verified with Python 3.14.3:
#   inspect.Signature.__name__ == 'Signature'
#   inspect.Signature.__module__ == 'inspect'
# ---------------------------------------------------------------------------

table inspect_extra219.signature_class_identity:
  description: "inspect.Signature class __name__ and __module__ identity checks; wave 385; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra219sigcls

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name_eq,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature represents a callable's call signature; its __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra219"]
    - [signature_module_eq,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra219"]
    - [signature_name_len,
       Signature.__name__.__len__,
       [],
       9,
       "inspect.Signature.__name__.__len__() == 9 — 'Signature' has 9 characters matching 'Parameter'; str.__len__() returns 9; new to extra219"]

# ---------------------------------------------------------------------------
# Table 5: inspect.signature(len) string representation check
#
# inspect.signature(len) returns a Signature object for the built-in len.
# Its string representation is '(obj, /)' indicating one positional-only param.
#
# Verified with Python 3.14.3:
#   str(inspect.signature(len)) == '(obj, /)'
# ---------------------------------------------------------------------------

table inspect_extra219.signature_func_identity:
  description: "inspect.signature function __name__, __module__, __qualname__ checks; wave 385; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra219sigfunc

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name_eq,
       signature.__name__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__name__.__eq__('signature') == True — signature is the public API function for retrieving call signatures; its __name__ is 'signature'; str.__eq__('signature') returns True; new to extra219"]
    - [signature_module_eq,
       signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — signature is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra219"]
    - [signature_qualname_eq,
       signature.__qualname__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__qualname__.__eq__('signature') == True — signature is a top-level function so its __qualname__ equals its __name__; str.__eq__('signature') returns True; new to extra219"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra219
# ---------------------------------------------------------------------------

invariant inspect_extra219.getmembers_name:
  description: "inspect.getmembers.__name__.__eq__('getmembers') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: getmembers.__name__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra219.getmembers_module:
  description: "inspect.getmembers.__module__.__eq__('inspect') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra219.getsource_name:
  description: "inspect.getsource.__name__.__eq__('getsource') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: getsource.__name__.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra219.getsource_module:
  description: "inspect.getsource.__module__.__eq__('inspect') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra219.parameter_name:
  description: "inspect.Parameter.__name__.__eq__('Parameter') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra219.parameter_module:
  description: "inspect.Parameter.__module__.__eq__('inspect') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra219.positional_or_keyword_kind:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra219.var_positional_kind:
  description: "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra219.keyword_only_kind:
  description: "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra219.signature_class_name:
  description: "inspect.Signature.__name__.__eq__('Signature') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra219.signature_module:
  description: "inspect.Signature.__module__.__eq__('inspect') == True; wave 385; new to extra219"
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra219.parameter_name_len:
  description: "inspect.Parameter.__name__.__len__() == 9 — 'Parameter' has 9 characters; wave 385; new to extra219"
  kind: python_call_eq
  function: Parameter.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra219.signature_name_len:
  description: "inspect.Signature.__name__.__len__() == 9 — 'Signature' has 9 characters; wave 385; new to extra219"
  kind: python_call_eq
  function: Signature.__name__.__len__
  args: []
  expected: 9
