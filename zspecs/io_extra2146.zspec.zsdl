spec: io_extra2146
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "Wave extra2146, theme: numeric conversion protocol dict-presence."
    - "Checks __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in io class __dict__."
    - "io.IOBase, RawIOBase, BufferedIOBase, TextIOBase, StringIO, BytesIO, FileIO are non-numeric I/O types."
    - "None of the io abstract base classes or concrete classes define numeric conversion dunders in their own __dict__."
    - "All seven numeric protocol methods are absent from every checked io class __dict__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Numeric conversion protocol — __trunc__, __floor__, __ceil__
# io I/O classes are not numeric; none define these rounding dunders.
# ---------------------------------------------------------------------------

table io_extra2146.trunc_floor_ceil_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["io2146001", "io.IOBase.__dict__.__contains__",       ["__trunc__"], false]
