# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra145.WindowsPath.name_len_11:
  description: "pathlib.WindowsPath.__name__.__len__() == 11 ('WindowsPath' has 11 characters; the concrete Windows path class, longer than PosixPath (9))"
  category: class_identity
  kind: python_call_eq
  function: WindowsPath.__name__.__len__
  args: []
  expected: 11

invariant pathlib_extra145.WindowsPath.bases_len_2:
  description: "pathlib.WindowsPath.__bases__.__len__() == 2 (WindowsPath inherits from both Path and PureWindowsPath, providing both concrete OS operations and Windows path semantics)"
  category: class_identity
  kind: python_call_eq
  function: "WindowsPath.__bases__.__len__"
  args: []
  expected: 2

invariant pathlib_extra145.WindowsPath.mro_len_5:
  description: "pathlib.WindowsPath.__mro__.__len__() == 5 (MRO is: WindowsPath, Path, PureWindowsPath, PurePath, object — five entries reflecting multiple inheritance from Path and PureWindowsPath)"
  category: class_identity
  kind: python_call_eq
  function: "WindowsPath.__mro__.__len__"
  args: []
  expected: 5

invariant pathlib_extra145.PosixPath.name_len_9:
  description: "pathlib.PosixPath.__name__.__len__() == 9 ('PosixPath' has 9 characters; the concrete POSIX path class, shorter than WindowsPath (11))"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__name__.__len__
  args: []
  expected: 9

invariant pathlib_extra145.PosixPath.base1_is_PurePosixPath:
  description: "pathlib.PosixPath.__bases__[1].__name__ == 'PurePosixPath' (length 13; the second base provides POSIX path semantics such as case-sensitive names and forward slash separator)"
  category: class_identity
  kind: python_call_eq
  function: "PosixPath.__bases__[1].__name__.__eq__"
  args: ["PurePosixPath"]
  expected: true

invariant pathlib_extra145.WindowsPath.base1_is_PureWindowsPath:
  description: "pathlib.WindowsPath.__bases__[1].__name__ == 'PureWindowsPath' (length 15; the second base provides Windows path semantics such as case-insensitive names and backslash separator)"
  category: class_identity
  kind: python_call_eq
  function: "WindowsPath.__bases__[1].__name__.__eq__"
  args: ["PureWindowsPath"]
  expected: true

