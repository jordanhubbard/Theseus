spec: pathlib_extra145
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.WindowsPath and pathlib.PosixPath class identity (__name__, __module__, __qualname__, __class__.__name__), multiple-inheritance base classes (__bases__.__len__()=2), and MRO structure (__mro__.__len__()=5)."
    - "Both WindowsPath and PosixPath inherit from two bases: Path (the concrete base class) and the corresponding pure path class."
    - "pathlib.WindowsPath.__name__ == 'WindowsPath' (length 11); __module__ == 'pathlib' (length 7)."
    - "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' (4); bases[1].__name__ == 'PureWindowsPath' (15)."
    - "pathlib.WindowsPath.__mro__.__len__() == 5: WindowsPath, Path, PureWindowsPath, PurePath, object."
    - "pathlib.PosixPath.__name__ == 'PosixPath' (length 9); __module__ == 'pathlib' (length 7)."
    - "pathlib.PosixPath.__bases__[0].__name__ == 'Path' (4); bases[1].__name__ == 'PurePosixPath' (13)."
    - "pathlib.PosixPath.__mro__.__len__() == 5: PosixPath, Path, PurePosixPath, PurePath, object."
    - "Both __bases__ and __mro__ are tuples: __class__.__name__ == 'tuple'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

