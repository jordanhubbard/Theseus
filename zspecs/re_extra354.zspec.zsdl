spec: re_extra354
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Pattern and re.Match are C-level types; their __module__ is 're' and __bases__[0] is object"
    - "re.RegexFlag is an IntFlag enum subclass; its __bases__[0].__name__ is 'IntFlag'"
    - "re.IGNORECASE == 2 (re.I), re.MULTILINE == 8 (re.M), re.DOTALL == 16 (re.S)"
    - "Flag integer values verified with int() in Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re pattern/match/flag class identity — class names
# ---------------------------------------------------------------------------

table re_extra354.class_names:
  description: "re module class __name__ identity checks — Pattern, Match, RegexFlag; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: reclsname354

  columns: [id, function, args, expected]
  rows:
    - [pattern_name,   re.Pattern.__name__.__eq__,   ["Pattern"],   true]
    - [match_name,     re.Match.__name__.__eq__,     ["Match"],     true]
    - [regexflag_name, re.RegexFlag.__name__.__eq__, ["RegexFlag"], true]

# ---------------------------------------------------------------------------
# re class identity — module attributes
# ---------------------------------------------------------------------------

table re_extra354.class_modules:
  description: "re module class __module__ identity checks — Pattern, Match, and RegexFlag all report __module__ as 're'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: reclsmod354

  columns: [id, function, args, expected]
  rows:
    - [pattern_module,   re.Pattern.__module__.__eq__,   ["re"], true]
    - [match_module,     re.Match.__module__.__eq__,     ["re"], true]
    - [regexflag_module, re.RegexFlag.__module__.__eq__, ["re"], true]

# ---------------------------------------------------------------------------
# re class identity — base class names
# ---------------------------------------------------------------------------

table re_extra354.class_bases:
  description: "re module class __bases__[0].__name__ identity checks — Pattern and Match extend object (C-level types); RegexFlag extends IntFlag (enum flag type); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: reclsbase354

  columns: [id, function, args, expected]
  rows:
    - [pattern_base,   "re.Pattern.__bases__[0].__name__.__eq__",   ["object"],  true]
    - [match_base,     "re.Match.__bases__[0].__name__.__eq__",     ["object"],  true]
    - [regexflag_base, "re.RegexFlag.__bases__[0].__name__.__eq__", ["IntFlag"], true]

# ---------------------------------------------------------------------------
# re flag integer values
# ---------------------------------------------------------------------------

table re_extra354.flag_values:
  description: "re module flag integer values — IGNORECASE==2, MULTILINE==8, DOTALL==16; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: reflagval354

  columns: [id, function, args, expected]
  rows:
    - [ignorecase_value, re.IGNORECASE.__eq__, [2],  true]
    - [multiline_value,  re.MULTILINE.__eq__,  [8],  true]
    - [dotall_value,     re.DOTALL.__eq__,     [16], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra354.pattern_base_is_object:
  description: "re.Pattern.__bases__[0].__name__ == 'object' — re.Pattern is a C-level type implemented in the _sre extension module; it has no Python-level parent class, so __bases__[0] is the root object type; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant re_extra354.regexflag_base_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — re.RegexFlag is a Python IntFlag enumeration combining integer bitflag semantics with enum membership; its base class is enum.IntFlag; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "re.RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true
