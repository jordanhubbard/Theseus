spec: functools_extra133
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.singledispatchmethod class identity and MRO; functools.reduce C builtin identity attributes (Wave 260)."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod' — pure-Python class defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — singledispatchmethod inherits directly from object. Verified with Python 3.14.3."
    - "len(functools.singledispatchmethod.__mro__) == 2 — MRO is [singledispatchmethod, object]. Verified with Python 3.14.3."
    - "len(functools.singledispatchmethod.__qualname__) == 20 — qualname is 'singledispatchmethod'. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin from _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — reduce belongs to the C extension _functools module. Verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce' (len 6). Verified with Python 3.14.3."
    - "functools.reduce.__name__ == 'reduce' (len 6). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.singledispatchmethod class identity and MRO
#
# Wave 260 theme: functools.singledispatchmethod class identity.
#
# functools.singledispatchmethod.__name__.__eq__('singledispatchmethod') == True
# functools.singledispatchmethod.__module__.__eq__('functools') == True
# functools.singledispatchmethod.__bases__[0].__name__.__eq__('object') == True
# functools.singledispatchmethod.__mro__.__len__() == 2
# functools.singledispatchmethod.__qualname__.__len__() == 20
#
# singledispatchmethod is a pure-Python class that extends the singledispatch
# pattern to methods on classes. It inherits directly from object;
# MRO is [singledispatchmethod, object] (length 2). New to extra133.
# ---------------------------------------------------------------------------

table functools_extra133.singledispatchmethod_identity:
  description: "functools.singledispatchmethod class identity: __name__, __module__, __bases__[0], MRO len==2, __qualname__ len==20; wave 260; new to extra133"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolssdm133

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatchmethod_name_eq,
       "singledispatchmethod.__name__.__eq__",
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__name__.__eq__('singledispatchmethod') == True — singledispatchmethod is a pure-Python class defined with 'class singledispatchmethod:' in Lib/functools.py; its __name__ is 'singledispatchmethod'; str.__eq__('singledispatchmethod') returns True; new to extra133"]
    - [singledispatchmethod_module_eq_functools,
       "singledispatchmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatchmethod.__module__.__eq__('functools') == True — singledispatchmethod is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra133"]
    - [singledispatchmethod_bases_first_eq_object,
       "singledispatchmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.singledispatchmethod.__bases__[0].__name__.__eq__('object') == True — singledispatchmethod is defined as 'class singledispatchmethod:' with no explicit base; it therefore inherits from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra133"]
    - [singledispatchmethod_mro_len_eq_2,
       "singledispatchmethod.__mro__.__len__",
       [],
       2,
       "functools.singledispatchmethod.__mro__.__len__() == 2 — the MRO of singledispatchmethod is [singledispatchmethod, object]; it inherits directly from object with no intermediate bases; len(__mro__) is 2; new to extra133"]
    - [singledispatchmethod_qualname_len_eq_20,
       "singledispatchmethod.__qualname__.__len__",
       [],
       20,
       "functools.singledispatchmethod.__qualname__.__len__() == 20 — __qualname__ is 'singledispatchmethod' which has 20 characters; len('singledispatchmethod') == 20; new to extra133"]
    - [singledispatchmethod_class_name_eq_type,
       "singledispatchmethod.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.singledispatchmethod.__class__.__name__.__eq__('type') == True — singledispatchmethod is a Python class; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra133"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce C builtin identity attributes
#
# Wave 260 theme: functools.reduce C builtin class name and module.
#
# functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True
# functools.reduce.__module__.__eq__('_functools') == True
# functools.reduce.__qualname__.__eq__('reduce') == True
# functools.reduce.__name__.__eq__('reduce') == True
# functools.reduce.__name__.__len__() == 6
#
# functools.reduce is a C builtin function defined in Modules/_functoolsmodule.c.
# Its __module__ is '_functools' (the underlying C extension module), not 'functools'.
# New to extra133.
# ---------------------------------------------------------------------------

table functools_extra133.reduce_builtin_identity:
  description: "functools.reduce C builtin: __class__.__name__=='builtin_function_or_method', __module__=='_functools', __qualname__=='reduce' (len 6); wave 260; new to extra133"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsreduce133

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_name_eq_builtin,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — functools.reduce is a C-implemented function defined in Modules/_functoolsmodule.c; it is exposed as a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra133"]
    - [reduce_module_eq_functools_c,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in Modules/_functoolsmodule.c and belongs to the C extension module '_functools'; functools re-exports it from '_functools'; __module__ is '_functools' not 'functools'; str.__eq__('_functools') returns True; new to extra133"]
    - [reduce_qualname_eq_reduce,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a module-level C builtin function; its __qualname__ is the simple name 'reduce'; str.__eq__('reduce') returns True; new to extra133"]
    - [reduce_name_eq_reduce,
       "reduce.__name__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — the __name__ of a C builtin function is set from the ml_name field in the PyMethodDef; for functools.reduce it is 'reduce'; str.__eq__('reduce') returns True; new to extra133"]
    - [reduce_name_len_eq_6,
       "reduce.__name__.__len__",
       [],
       6,
       "functools.reduce.__name__.__len__() == 6 — __name__ is 'reduce' which has 6 characters; len('reduce') == 6; new to extra133"]

# ---------------------------------------------------------------------------
# Table 3: functools.singledispatchmethod qualname and __init__ class name
#
# Wave 260 theme: singledispatchmethod qualname and __init__ identity.
#
# functools.singledispatchmethod.__qualname__.__eq__('singledispatchmethod') == True
# functools.singledispatchmethod.__name__.__len__() == 20
# functools.singledispatchmethod.__init__.__class__.__name__.__eq__('function') == True
# functools.reduce.__qualname__.__len__() == 6
#
# singledispatchmethod's __qualname__ equals the class name (module scope).
# Its __init__ is a plain Python function. New to extra133.
# ---------------------------------------------------------------------------

table functools_extra133.singledispatchmethod_qualname_init:
  description: "functools.singledispatchmethod __qualname__=='singledispatchmethod', __name__ len==20, __init__.__class__.__name__=='function'; reduce __qualname__ len==6; wave 260; new to extra133"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolssdm133

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatchmethod_qualname_eq,
       "singledispatchmethod.__qualname__.__eq__",
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__qualname__.__eq__('singledispatchmethod') == True — singledispatchmethod is defined at module scope in Lib/functools.py; __qualname__ equals the simple class name; str.__eq__('singledispatchmethod') returns True; new to extra133"]
    - [singledispatchmethod_name_len_eq_20,
       "singledispatchmethod.__name__.__len__",
       [],
       20,
       "functools.singledispatchmethod.__name__.__len__() == 20 — __name__ is 'singledispatchmethod' which has 20 characters; len('singledispatchmethod') == 20; new to extra133"]
    - [singledispatchmethod_init_class_name_eq_function,
       "singledispatchmethod.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.singledispatchmethod.__init__.__class__.__name__.__eq__('function') == True — singledispatchmethod.__init__ is a pure-Python method defined in Lib/functools.py; when accessed on the class, it is a plain Python function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra133"]
    - [reduce_qualname_len_eq_6,
       "reduce.__qualname__.__len__",
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — __qualname__ is 'reduce' which has 6 characters; len('reduce') == 6; new to extra133"]
    - [singledispatchmethod_doc_class_name_eq_str,
       "singledispatchmethod.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.singledispatchmethod.__doc__.__class__.__name__.__eq__('str') == True — singledispatchmethod has a docstring; __doc__ is a plain Python string; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra133"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra133
# ---------------------------------------------------------------------------

invariant functools_extra133.singledispatchmethod_name:
  description: "functools.singledispatchmethod.__name__ == 'singledispatchmethod' — pure-Python class in Lib/functools.py; wave 260; new to extra133"
  kind: python_call_eq
  function: singledispatchmethod.__name__.__eq__
  args: ["singledispatchmethod"]
  expected: true

invariant functools_extra133.singledispatchmethod_mro_len:
  description: "len(functools.singledispatchmethod.__mro__) == 2 — MRO is [singledispatchmethod, object]; wave 260; new to extra133"
  kind: python_call_eq
  function: singledispatchmethod.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra133.reduce_class_name:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin from _functoolsmodule.c; wave 260; new to extra133"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra133.reduce_module:
  description: "functools.reduce.__module__ == '_functools' — reduce belongs to the C extension _functools module; wave 260; new to extra133"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra133.singledispatchmethod_bases_object:
  description: "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — singledispatchmethod inherits directly from object; wave 260; new to extra133"
  kind: python_call_eq
  function: singledispatchmethod.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true
