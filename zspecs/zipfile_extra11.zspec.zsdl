spec: zipfile_extra11
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipfile.html — Python zipfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipfile/__init__.py"
  notes:
    - "This spec extends zipfile.zspec.zsdl through zipfile_extra10.zspec.zsdl."
    - "zipfile_extra10 covers: ZipInfo compress_type/file_size/compress_size defaults; LargeZipFile.__mro__[1]/[2]; BadZipFile.__mro__[3]; ZipExtFile.__mro__[1]; module __name__; ZipInfo filename_config_json."
    - "zipfile_extra9 covers: ZipInfo.date_time type/epoch year; ZipInfo.create_system==3; Path.__bases__[0].__name__=='object'; BadZipFile.__mro__[1]/__mro__[2]."
    - "zipfile_extra8 covers: compression constant bool class checks; ZipExtFile metadata; BadZipfile alias; ZipFile/ZipInfo/Path base names; ZipInfo('data.bin').filename."
    - "No prior spec covers: zipfile.ZipFile.__qualname__ contains no dots — ZipFile is a top-level class."
    - "No prior spec covers: zipfile.ZipInfo.__qualname__ contains no dots — ZipInfo is a top-level class."
    - "No prior spec covers: zipfile.BadZipFile.__qualname__ contains no dots — BadZipFile is a top-level class."
    - "No prior spec covers: zipfile.ZipFile.open.__name__ == 'open' — ZipFile method name check."
    - "No prior spec covers: zipfile.ZipFile.namelist.__name__ == 'namelist' — ZipFile method name check."
    - "No prior spec covers: zipfile.ZipFile.read.__name__ == 'read' — ZipFile method name check."
    - "No prior spec covers: zipfile.ZipFile.infolist.__name__ == 'infolist' — ZipFile method name check."
    - "No prior spec covers: zipfile.LargeZipFile.__mro__[3].__name__ == 'object' — MRO terminal entry."
    - "No prior spec covers: zipfile.is_zipfile.__module__ == 'zipfile' — is_zipfile is defined in the zipfile module."
    - "zipfile.ZipFile method names: open, namelist, read, infolist — confirmed as top-level ZipFile methods."
    - "zipfile.LargeZipFile.__mro__: [LargeZipFile, Exception, BaseException, object]; mro[3] == 'object'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ dot-free checks for top-level zipfile classes
# Prior specs cover __qualname__ == exact string for ZipFile, ZipInfo, BadZipFile.
# No prior spec checks that none of these contain a dot (confirming top-level scope).
# ---------------------------------------------------------------------------

table zipfile_extra11.class_qualname_no_dots:
  description: "ZipFile/ZipInfo/BadZipFile __qualname__ contains no dot — all are top-level classes"
  kind: python_call_eq
  category: class_names
  id_prefix: qdot11

  columns: [id, function, args, expected]
  rows:
    - [ZipFile,    ZipFile.__qualname__.__contains__,    ["."], false]
    - [ZipInfo,    ZipInfo.__qualname__.__contains__,    ["."], false]
    - [BadZipFile, BadZipFile.__qualname__.__contains__,  ["."], false]

# ---------------------------------------------------------------------------
# ZipFile method names — open, namelist, read, infolist
# No prior zipfile spec checks __name__ for any ZipFile instance method.
# These four are the primary public API methods for reading ZIP archives.
# ---------------------------------------------------------------------------

table zipfile_extra11.ZipFile_method_names:
  description: "ZipFile method names: open, namelist, read, infolist"
  kind: python_call_eq
  category: method_names
  id_prefix: mname11

  columns: [id, function, args, expected]
  rows:
    - [open,     ZipFile.open.__name__.__eq__,     ["open"],     true]
    - [namelist, ZipFile.namelist.__name__.__eq__, ["namelist"], true]
    - [read,     ZipFile.read.__name__.__eq__,     ["read"],     true]
    - [infolist, ZipFile.infolist.__name__.__eq__, ["infolist"], true]

# ---------------------------------------------------------------------------
# LargeZipFile MRO terminal entry — index 3 == 'object'
# zipfile_extra10 covers LargeZipFile.__mro__[1] == 'Exception' and
# LargeZipFile.__mro__[2] == 'BaseException'. Index 3 ('object') is new.
# LargeZipFile.__mro__: [LargeZipFile, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant zipfile_extra11.LargeZipFile.mro_index3:
  description: "zipfile.LargeZipFile.__mro__[3].__name__ == 'object' — LargeZipFile MRO terminal entry"
  category: class_hierarchy
  kind: python_call_eq
  function: LargeZipFile.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# is_zipfile.__module__ == 'zipfile'
# Prior specs check is_zipfile.__name__, is_zipfile.__qualname__, and
# is_zipfile.__class__.__name__. No prior spec checks is_zipfile.__module__.
# is_zipfile is defined in the zipfile module.
# ---------------------------------------------------------------------------

invariant zipfile_extra11.is_zipfile.module:
  description: "zipfile.is_zipfile.__module__ == 'zipfile' — is_zipfile is defined in the zipfile module"
  category: functions
  kind: python_call_eq
  function: is_zipfile.__module__.__eq__
  args: ["zipfile"]
  expected: true
