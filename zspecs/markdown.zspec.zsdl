spec: markdown
version: ">=3.0"
backend: python_module(markdown)

docs: https://python-markdown.github.io/

provenance:
  derived_from:
    - "Python-Markdown documentation — https://python-markdown.github.io/"
    - "CommonMark Spec — https://spec.commonmark.org/"
    - "Test vectors verified with Python-Markdown 3.10.2 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "Python-Markdown source: markdown/core.py"
    - "Python-Markdown source: markdown/preprocessors.py"
    - "Python-Markdown source: markdown/blockprocessors.py"
    - "Python-Markdown source: markdown/inlinepatterns.py"
  notes:
    - "The top-level function markdown.markdown() has the same name as the module; accessed as function: markdown."
    - "markdown.markdown() returns a plain str (no special subclass)."
    - "markdown.Markdown is a class; Markdown.__name__ is accessed as a dotted function path."
    - "Markdown().convert() produces a new HTML fragment; reset() clears state for reuse."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — __version__ is a string and contains a dot
# ---------------------------------------------------------------------------

invariant markdown.version.is_string:
  description: "__version__ is a str (type name check)"
  category: version
  kind: python_call_eq
  function: __version__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant markdown.version.contains_dot:
  description: "__version__ contains a dot (e.g. '3.10.2')"
  category: version
  kind: python_call_eq
  function: __version__.__contains__
  args: ["."]
  expected: true

# ---------------------------------------------------------------------------
# convert — markdown() converts common Markdown constructs to HTML
# ---------------------------------------------------------------------------

invariant markdown.convert.h1:
  description: "markdown('# Hello') == '<h1>Hello</h1>'"
  category: convert
  kind: python_call_eq
  function: markdown
  args: ["# Hello"]
  expected: "<h1>Hello</h1>"

invariant markdown.convert.bold_contains_strong:
  description: "markdown('**bold**') contains '<strong>'"
  category: convert
  kind: python_call_eq
  function: markdown
  args: ["**bold**"]
  method: __contains__
  method_args: ["<strong>"]
  expected: true

invariant markdown.convert.italic_contains_em:
  description: "markdown('*italic*') contains '<em>'"
  category: convert
  kind: python_call_eq
  function: markdown
  args: ["*italic*"]
  method: __contains__
  method_args: ["<em>"]
  expected: true

invariant markdown.convert.inline_code:
  description: "markdown('`code`') == '<p><code>code</code></p>'"
  category: convert
  kind: python_call_eq
  function: markdown
  args: ["`code`"]
  expected: "<p><code>code</code></p>"

invariant markdown.convert.paragraph:
  description: "markdown('plain text') wraps in <p>"
  category: convert
  kind: python_call_eq
  function: markdown
  args: ["plain text"]
  expected: "<p>plain text</p>"

# ---------------------------------------------------------------------------
# links — markdown link syntax produces <a href="...">
# ---------------------------------------------------------------------------

invariant markdown.links.basic_href:
  description: "markdown('[link](http://example.com)') contains '<a href='"
  category: links
  kind: python_call_eq
  function: markdown
  args: ["[link](http://example.com)"]
  method: __contains__
  method_args: ["<a href="]
  expected: true

invariant markdown.links.exact_output:
  description: "markdown('[link](http://example.com)') == '<p><a href=\"http://example.com\">link</a></p>'"
  category: links
  kind: python_call_eq
  function: markdown
  args: ["[link](http://example.com)"]
  expected: "<p><a href=\"http://example.com\">link</a></p>"

# ---------------------------------------------------------------------------
# lists — unordered list produces <ul><li> structure
# ---------------------------------------------------------------------------

invariant markdown.lists.unordered_contains_ul:
  description: "markdown('- item1\\n- item2') contains '<ul>'"
  category: lists
  kind: python_call_eq
  function: markdown
  args: ["- item1\n- item2"]
  method: __contains__
  method_args: ["<ul>"]
  expected: true

invariant markdown.lists.unordered_contains_li:
  description: "markdown('- item1\\n- item2') contains '<li>item1</li>'"
  category: lists
  kind: python_call_eq
  function: markdown
  args: ["- item1\n- item2"]
  method: __contains__
  method_args: ["<li>item1</li>"]
  expected: true

# ---------------------------------------------------------------------------
# class — Markdown class name and instance convert method
# ---------------------------------------------------------------------------

invariant markdown.class.name_is_Markdown:
  description: "Markdown.__name__ == 'Markdown'"
  category: class
  kind: python_call_eq
  function: Markdown.__name__.__eq__
  args: ["Markdown"]
  expected: true

invariant markdown.class.convert_produces_p:
  description: "Markdown().convert('text') == '<p>text</p>'"
  category: class
  kind: python_call_eq
  function: Markdown
  args: []
  method: convert
  method_args: ["text"]
  expected: "<p>text</p>"

invariant markdown.class.convert_h1:
  description: "Markdown().convert('# Title') == '<h1>Title</h1>'"
  category: class
  kind: python_call_eq
  function: Markdown
  args: []
  method: convert
  method_args: ["# Title"]
  expected: "<h1>Title</h1>"
