spec: th3331
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 669 (th3331): __iand__, __ior__, __ixor__ dict-presence checks for threading types."
    - "Theme: __iand__/__ior__/__ixor__ in-place bitwise logical dict-presence."
    - "In-place augmented assignment operators (&=, |=, ^=) fall back to __and__/__or__/__xor__ if not defined."
    - "All values False — callable/iterator/inspection/synchronization types have no in-place bitwise logical operators."
    - "None of the threading types define __iand__, __ior__, or __ixor__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3331.iand:
  description: "threading types __iand__ dict-presence checks; wave 669"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3331
  columns: [id, function, args, expected]
  rows:
    - ["th3331001", operator.contains, [threading.Thread.__dict__,           "__iand__"], false]
    - ["th3331002", operator.contains, [threading.Event.__dict__,            "__iand__"], false]
    - ["th3331003", operator.contains, [threading.Condition.__dict__,        "__iand__"], false]
    - ["th3331004", operator.contains, [threading.Semaphore.__dict__,        "__iand__"], false]
    - ["th3331005", operator.contains, [threading.BoundedSemaphore.__dict__, "__iand__"], false]
    - ["th3331006", operator.contains, [threading.Timer.__dict__,            "__iand__"], false]
    - ["th3331007", operator.contains, [threading.Barrier.__dict__,          "__iand__"], false]
    - ["th3331008", operator.contains, [threading.local.__dict__,            "__iand__"], false]
    - ["th3331009", operator.contains, [type(threading.Lock()).__dict__,     "__iand__"], false]
    - ["th3331010", operator.contains, [type(threading.RLock()).__dict__,    "__iand__"], false]

