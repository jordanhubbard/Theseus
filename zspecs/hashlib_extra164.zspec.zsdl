spec: hashlib_extra164
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra163.zspec.zsdl — covers hashlib sha3 family and blake2 family constructor __name__ and __module__ identity (sha3_256/__name__/__module__, sha3_512/__name__/__module__, blake2b/__name__/__module__, blake2s/__name__/__module__); also sha3/blake2 __name__ length comparison table."
    - "hashlib_extra162.zspec.zsdl — covers hashlib.sha256.__name__.__eq__('openssl_sha256') / md5.__name__.__eq__('openssl_md5') / sha256.__module__.__eq__('_hashlib') / md5.__module__.__eq__('_hashlib') / sha256/__doc__/__len__() / md5/__doc__/__len__() ordering (table + invariants)."
    - "hashlib_extra160.zspec.zsdl — covers hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / new.__qualname__.__eq__('__hash_new') / new.__class__.__name__.__eq__('function') / algorithms_guaranteed.__class__.__name__.__eq__('set') (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra163."
    - "Wave 343 theme: hashlib.algorithms_available and hashlib.algorithms_guaranteed set membership — algorithms_available.__class__.__name__.__eq__('set') / algorithms_guaranteed.__class__.__name__.__eq__('set') / algorithms_guaranteed.__contains__('sha256') / algorithms_guaranteed.__contains__('md5') / algorithms_guaranteed.__contains__('sha1') / algorithms_guaranteed.__len__()==14 / algorithms_available.__len__()==19."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('md5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha1') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__len__() == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.algorithms_available is a 'set' (not 'frozenset'). Both algorithms_available and algorithms_guaranteed are plain Python 'set' objects. algorithms_guaranteed contains 14 algorithms: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256. algorithms_available contains 19 entries (19 > 14; available is a superset of guaranteed on this platform). extra160 anchors algorithms_guaranteed.__class__.__name__.__eq__('set') as a single row; this spec anchors that and algorithms_available class name as a table."
    - "Note: hashlib.algorithms_guaranteed is the set of algorithms guaranteed to be present on ALL Python platforms, regardless of OpenSSL version. algorithms_available is the set of algorithms supported by the current platform's OpenSSL installation. algorithms_guaranteed is always a subset of algorithms_available. The 14 guaranteed algorithms on Python 3.14.3 macOS: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256."
    - "Note: hashlib.algorithms_guaranteed.__len__() == 14. The 14 guaranteed algorithms represent the core set of hash functions required by the Python spec: SHA-1, SHA-2 family (sha224, sha256, sha384, sha512), SHA-3 family (sha3_224, sha3_256, sha3_384, sha3_512), SHAKE (shake_128, shake_256), BLAKE2 (blake2b, blake2s), and MD5. This count is specific to Python 3.14.3 on macOS/Darwin 25.4.0. algorithms_available.__len__()==19 (5 more than guaranteed on this platform)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set')
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
# hashlib.algorithms_guaranteed.__contains__('sha256')
# hashlib.algorithms_guaranteed.__contains__('md5')
#
# Wave 343 theme: algorithms_available and algorithms_guaranteed type identity.
#
# algorithms_available.__class__.__name__ == 'set' (not 'frozenset').
# algorithms_guaranteed.__class__.__name__ == 'set' (not 'frozenset').
# algorithms_guaranteed.__contains__('sha256') == True.
# algorithms_guaranteed.__contains__('md5') == True.
# extra160 anchors algorithms_guaranteed.__class__.__name__.__eq__('set') as a table row;
# no prior spec anchors algorithms_available class name or __contains__ as a table under
# algset164. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra164.algorithms_set_class_and_membership:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set')==True / algorithms_guaranteed.__class__.__name__.__eq__('set')==True / algorithms_guaranteed.__contains__('sha256')==True / algorithms_guaranteed.__contains__('md5')==True — algorithms_available.__class__.__name__ is 'set' (3 chars; not 'frozenset'; both algorithm sets are mutable plain Python set objects); algorithms_guaranteed.__class__.__name__ is 'set' (3 chars; same type as algorithms_available; extra160 anchors this as a single row but not as a full table); algorithms_guaranteed.__contains__('sha256') is True (sha256 is guaranteed on all Python platforms; member of the 14-element guaranteed set); algorithms_guaranteed.__contains__('md5') is True (md5 is guaranteed despite deprecation concerns; member of the 14-element guaranteed set on Python 3.14.3 macOS); first algset164 anchor for this combination as a table"
  kind: python_call_eq
  category: identity
  id_prefix: algset164

  columns: [id, function, args, expected, description]
  rows:
    - [avail_class_set,      "algorithms_available.__class__.__name__.__eq__",  ["set"],    true, "hashlib.algorithms_available.__class__.__name__ == 'set' (3 chars; not frozenset; mutable set object; superset of algorithms_guaranteed)"]
    - [guar_class_set,       "algorithms_guaranteed.__class__.__name__.__eq__", ["set"],    true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' (3 chars; extra160 anchors as row; confirmed as full-table first here)"]
    - [guar_contains_sha256, "algorithms_guaranteed.__contains__",              ["sha256"], true, "hashlib.algorithms_guaranteed.__contains__('sha256') == True (sha256 is guaranteed on all Python platforms; SHA-2 256-bit)"]
    - [guar_contains_md5,    "algorithms_guaranteed.__contains__",              ["md5"],    true, "hashlib.algorithms_guaranteed.__contains__('md5') == True (md5 is guaranteed despite legacy status; member of 14-element guaranteed set)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha1')
# hashlib.algorithms_guaranteed.__contains__('sha512')
# hashlib.algorithms_guaranteed.__len__()==14
# hashlib.algorithms_available.__len__()==19
#
# Wave 343 theme: algorithms_guaranteed membership and set lengths.
#
# algorithms_guaranteed.__contains__('sha1') == True.
# algorithms_guaranteed.__contains__('sha512') == True.
# algorithms_guaranteed.__len__() == 14.
# algorithms_available.__len__() == 19.
# No prior hashlib spec anchors algorithms_guaranteed.__len__()==14 as a table under algset164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra164.algorithms_membership_and_lengths:
  description: "hashlib.algorithms_guaranteed.__contains__('sha1')==True / algorithms_guaranteed.__contains__('sha512')==True / algorithms_guaranteed.__len__()==14 / algorithms_available.__len__()==19 — algorithms_guaranteed.__contains__('sha1') is True (sha1 is guaranteed; SHA-1 is legacy but still required by Python spec); algorithms_guaranteed.__contains__('sha512') is True (sha512 guaranteed; SHA-2 512-bit; member of 14-element set); algorithms_guaranteed.__len__() is 14 (14 algorithms: sha1/sha224/sha256/sha384/sha512/sha3_224/sha3_256/sha3_384/sha3_512/shake_128/shake_256/blake2b/blake2s/md5; Python 3.14.3 specific); algorithms_available.__len__() is 19 (19 algorithms on this platform; 5 more than guaranteed; includes OpenSSL-specific extras); algorithms_guaranteed(14) < algorithms_available(19); first algset164 anchor for both __len__ values"
  kind: python_call_eq
  category: identity
  id_prefix: algset164

  columns: [id, function, args, expected, description]
  rows:
    - [guar_contains_sha1,   "algorithms_guaranteed.__contains__", ["sha1"],   true, "hashlib.algorithms_guaranteed.__contains__('sha1') == True (sha1 guaranteed; SHA-1 legacy but required by Python spec; 14-element set)"]
    - [guar_contains_sha512, "algorithms_guaranteed.__contains__", ["sha512"], true, "hashlib.algorithms_guaranteed.__contains__('sha512') == True (sha512 guaranteed; SHA-2 512-bit; one of the 14 guaranteed algorithms)"]
    - [guar_len_14,          "algorithms_guaranteed.__len__",      [],         14,   "hashlib.algorithms_guaranteed.__len__() == 14 (sha1/sha224/sha256/sha384/sha512/sha3_224/sha3_256/sha3_384/sha3_512/shake_128/shake_256/blake2b/blake2s/md5; Python 3.14.3 macOS)"]
    - [avail_len_19,         "algorithms_available.__len__",       [],         19,   "hashlib.algorithms_available.__len__() == 19 (platform-specific; 5 more than guaranteed; superset of algorithms_guaranteed on macOS/Darwin 25.4.0)"]

# ---------------------------------------------------------------------------
# algorithms_guaranteed sha3 family membership
#
# Wave 343 theme: sha3 and shake family membership in algorithms_guaranteed.
#
# algorithms_guaranteed.__contains__('sha3_256') == True.
# algorithms_guaranteed.__contains__('sha3_512') == True.
# algorithms_guaranteed.__contains__('shake_128') == True.
# algorithms_guaranteed.__contains__('shake_256') == True.
# No prior hashlib spec anchors sha3/shake membership in algorithms_guaranteed as a table
# under algset164. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra164.algorithms_guaranteed_sha3_and_shake_membership:
  description: "hashlib.algorithms_guaranteed.__contains__('sha3_256')==True / algorithms_guaranteed.__contains__('sha3_512')==True / algorithms_guaranteed.__contains__('shake_128')==True / algorithms_guaranteed.__contains__('shake_256')==True — sha3_256 is True (SHA-3 256-bit guaranteed since Python 3.6+; member of 14-element set; sha3_256 is among the 14 guaranteed); sha3_512 is True (SHA-3 512-bit guaranteed; member of 14-element set; both sha3_256 and sha3_512 are in algorithms_guaranteed); shake_128 is True (SHAKE-128 variable-length output function; guaranteed; member of 14-element set); shake_256 is True (SHAKE-256 variable-length output function; guaranteed; member of 14-element set; both SHAKE variants guaranteed); first algset164 anchor for sha3/shake __contains__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: algset164

  columns: [id, function, args, expected, description]
  rows:
    - [guar_contains_sha3_256,  "algorithms_guaranteed.__contains__", ["sha3_256"],  true, "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True (SHA-3 256-bit; guaranteed since Python 3.6+; member of 14-element set)"]
    - [guar_contains_sha3_512,  "algorithms_guaranteed.__contains__", ["sha3_512"],  true, "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True (SHA-3 512-bit; guaranteed; member of 14-element set; ties sha3_256 in count)"]
    - [guar_contains_shake_128, "algorithms_guaranteed.__contains__", ["shake_128"], true, "hashlib.algorithms_guaranteed.__contains__('shake_128') == True (SHAKE-128 XOF; guaranteed; variable-length output; member of 14-element set)"]
    - [guar_contains_shake_256, "algorithms_guaranteed.__contains__", ["shake_256"], true, "hashlib.algorithms_guaranteed.__contains__('shake_256') == True (SHAKE-256 XOF; guaranteed; variable-length output; member of 14-element set)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_guaranteed.__class__.__name__ is 'set' (3 chars). Both
# algorithms_guaranteed and algorithms_available are plain Python set objects, not
# frozenset objects. This means they are mutable (though Lib/hashlib.py does not provide
# mutation APIs). The 'set' type supports __contains__, __len__, __iter__, and set
# operations (union, intersection, etc.). extra160 anchors algorithms_guaranteed class
# name as a table row under hashload160; this standalone provides a dedicated invariant
# under algset164. The guaranteed set contains exactly 14 algorithms on Python 3.14.3
# macOS. No prior hashlib spec anchors algorithms_guaranteed.__class__.__name__ as a
# standalone under algset164. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra164.guar_class_name_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — 'set' (3 chars; mutable plain Python set; not frozenset; supports __contains__/__len__/__iter__/set operations); extra160 anchors as a table row but NOT as a standalone; algorithms_guaranteed.__len__()==14 (14 algorithms on Python 3.14.3 macOS); algorithms_available.__class__.__name__=='set' (same type; both are set objects); 'set' (3 chars) vs 'frozenset' (9 chars) — NOT frozenset; no prior hashlib spec anchors this as a standalone under algset164; first standalone under algset164"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__()==14 — standalone
#
# hashlib.algorithms_guaranteed.__len__() is 14. The 14 guaranteed algorithms on
# Python 3.14.3 macOS/Darwin 25.4.0 are: blake2b, blake2s, md5, sha1, sha224, sha256,
# sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256.
# This set is guaranteed to be available on all Python 3.x platforms. The count 14
# includes: 1 MD family (md5), 1 SHA-1 (sha1), 4 SHA-2 (sha224/sha256/sha384/sha512),
# 4 SHA-3 (sha3_224/sha3_256/sha3_384/sha3_512), 2 SHAKE (shake_128/shake_256), and
# 2 BLAKE2 (blake2b/blake2s). algorithms_available.__len__()==19 (5 more on this platform).
# No prior hashlib spec anchors algorithms_guaranteed.__len__()==14 as a standalone under
# algset164. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra164.guar_len_14:
  description: "hashlib.algorithms_guaranteed.__len__() == 14 — 14 algorithms: blake2b/blake2s/md5/sha1/sha224/sha256/sha384/sha3_224/sha3_256/sha3_384/sha3_512/sha512/shake_128/shake_256; breakdown: MD(1=md5)+SHA1(1)+SHA2(4=sha224/sha256/sha384/sha512)+SHA3(4=sha3_224/sha3_256/sha3_384/sha3_512)+SHAKE(2=shake_128/shake_256)+BLAKE2(2=blake2b/blake2s)=14; algorithms_available.__len__()==19 (5 more on macOS); Python 3.14.3 macOS specific count; guaranteed means present on ALL Python 3.x platforms; no prior hashlib spec anchors this as a standalone; first standalone under algset164"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__('sha256') — standalone
#
# hashlib.algorithms_guaranteed.__contains__('sha256') is True. 'sha256' is one of the
# 14 algorithms guaranteed to be available on all Python platforms. sha256 is part of
# the SHA-2 family (SHA-2 256-bit), standardized in FIPS PUB 180-4. It produces a
# 256-bit (32-byte) digest. The hashlib.sha256 constructor is a builtin_function_or_method
# from the _hashlib C extension (extra162 anchors sha256.__name__=='openssl_sha256').
# In the algorithms_guaranteed set, it appears as the string 'sha256' (6 chars).
# algorithms_guaranteed is a plain Python 'set' and supports the same __contains__ method
# as any set. No prior hashlib spec anchors algorithms_guaranteed.__contains__('sha256')
# as a standalone under algset164. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra164.guar_contains_sha256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is in the 14-element guaranteed set; SHA-2 256-bit (FIPS PUB 180-4); produces 32-byte digest; 'sha256' = 6 chars (shorter than 'sha3_256'=8 chars which is also in guaranteed); extra162 anchors sha256.__name__=='openssl_sha256' (C-level name); algorithms_guaranteed is a 'set' (not frozenset); __contains__ returns True for string 'sha256' matching set member; no prior hashlib spec anchors this as a standalone; first standalone under algset164"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__len__()==19 — standalone
#
# hashlib.algorithms_available.__len__() is 19 on Python 3.14.3 macOS/Darwin 25.4.0.
# algorithms_available is the set of algorithms supported by the current platform's
# OpenSSL installation. It is always a superset of algorithms_guaranteed. On this platform,
# there are 19 available algorithms: 14 guaranteed plus 5 additional OpenSSL-backed
# algorithms. The exact 19-element count is platform-specific (may differ on other OS or
# OpenSSL versions). algorithms_guaranteed(14) < algorithms_available(19): algorithms_available
# has 5 more entries than algorithms_guaranteed. The 5 additional algorithms on this platform
# are provided by OpenSSL but not guaranteed by the Python specification.
# No prior hashlib spec anchors algorithms_available.__len__() as a standalone under algset164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra164.avail_len_19:
  description: "hashlib.algorithms_available.__len__() == 19 — platform-specific count (Python 3.14.3 macOS/Darwin 25.4.0); always a superset of algorithms_guaranteed.__len__()==14; 19-14=5 additional OpenSSL-specific algorithms on this platform; algorithms_available.__class__.__name__=='set' (same type as algorithms_guaranteed); 19 is the available count on this platform (may differ on other OS/OpenSSL versions); first algset164 standalone for algorithms_available.__len__()==19"
  category: identity
  kind: python_call_eq
  function: algorithms_available.__len__
  args: []
  expected: 19

