spec: uuid_extra69
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra68.zspec.zsdl — covers UUID/__repr__/__eq__/__code__/co_varnames/__class__/__name__=='tuple' / uuid3/uuid5 co_varnames class / SafeUUID/__doc__/__class__/__name__=='str' / UUID/__init__/__str__/__code__/co_flags/__class__/__name__=='int' (table + invariants)."
    - "uuid_extra67.zspec.zsdl — covers NAMESPACE_DNS/URL/__class__/__name__=='UUID' / RESERVED_NCS/__contains__('NCS') / RFC_4122/__contains__('RFC') / UUID/__repr__/__code__/co_name=='__repr__' (table + invariants)."
    - "uuid_extra60.zspec.zsdl — covers UUID/__repr__/__str__/__hash__/__eq__/__code__/co_name and co_argcount / SafeUUID class identity / SafeUUID/__bases__[0]/__name__=='IntEnum' (table + invariants)."
    - "uuid_extra52.zspec.zsdl — covers UUID/__setattr__/__qualname__.__eq__('UUID.__setattr__') / UUID/__getstate__/__setstate__/__init_subclass__/__subclasshook__ __qualname__ (table + invariants)."
    - "uuid_extra29.zspec.zsdl — covers SafeUUID/__mro__/__len__()==3 / UUID/__mro__/__len__()==2 (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra68; it does NOT duplicate invariants present in those files."
    - "Wave 244 theme: UUID __dict__ remaining method membership + UUID.__setattr__ code object attributes + SafeUUID __dict__ class."
    - "uuid.UUID.__dict__.__contains__('__repr__') == True — UUID defines __repr__ in its class __dict__ as a Python method. No prior uuid spec checks UUID.__dict__.__contains__('__repr__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__int__') == True — UUID defines __int__ in its class __dict__ enabling integer conversion. No prior uuid spec checks UUID.__dict__.__contains__('__int__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__setattr__') == True — UUID overrides __setattr__ in its class __dict__ to enforce immutability. uuid_extra52 covers UUID.__setattr__.__qualname__ but NOT UUID.__dict__.__contains__('__setattr__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace dict is always a mappingproxy. No prior uuid spec checks SafeUUID.__dict__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__code__.co_name == '__setattr__' — the code object's co_name matches the function name. uuid_extra52 covers __setattr__.__qualname__ but NOT __setattr__.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__code__.co_argcount == 3 — __setattr__ takes self + name + value (3 args). No prior uuid spec checks UUID.__setattr__.__code__.co_argcount. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__ for __repr__, __int__, __setattr__
#
# Wave 244 theme: UUID class __dict__ method membership.
#
# uuid.UUID is a Python class defining __repr__, __int__, and __setattr__
# directly in its class __dict__. No prior uuid spec checks UUID.__dict__.__contains__
# for __repr__, __int__, or __setattr__ (uuid_extra52 covers __setattr__.__qualname__,
# not __dict__ membership; no spec covers __repr__ or __int__ dict membership).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra69.UUID_dict_contains_repr_int_setattr:
  description: "uuid.UUID/__dict__.__contains__('__repr__')==True / __contains__('__int__')==True / __contains__('__setattr__')==True — UUID defines __repr__/__int__/__setattr__ directly in its class __dict__; uuid_extra52 covers __setattr__.__qualname__ but NOT __dict__ membership; no prior uuid spec checks UUID.__dict__.__contains__ for __repr__/__int__/__setattr__; first __dict__ method membership anchor for UUID.__repr__/__int__/__setattr__"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidmore69

  columns: [id, function, args, expected]
  rows:
    - [UUID_dict_has_repr,     UUID.__dict__.__contains__, ["__repr__"],     true]
    - [UUID_dict_has_int,      UUID.__dict__.__contains__, ["__int__"],      true]
    - [UUID_dict_has_setattr,  UUID.__dict__.__contains__, ["__setattr__"],  true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__dict__.__class__.__name__ == 'mappingproxy'
#
# Wave 244 theme: SafeUUID class namespace dict type identity.
#
# uuid.SafeUUID is an Enum subclass; its __dict__ is a mappingproxy (the
# read-only view of the class namespace). No prior uuid spec checks
# SafeUUID.__dict__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra69.SafeUUID_dict_class_name:
  description: "uuid.SafeUUID/__dict__/__class__/__name__.__eq__('mappingproxy')==True — SafeUUID is an Enum subclass; its class __dict__ is a mappingproxy (read-only namespace view); no prior uuid spec checks SafeUUID.__dict__.__class__.__name__; first __dict__ class identity anchor for SafeUUID"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidmore69

  columns: [id, function, args, expected]
  rows:
    - [SafeUUID_dict_class_mappingproxy, SafeUUID.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__code__.co_name and co_argcount
#
# Wave 244 theme: UUID.__setattr__ code object attributes.
#
# uuid.UUID.__setattr__ is a Python function overriding attribute assignment
# to enforce immutability. Its code object has co_name == '__setattr__' and
# co_argcount == 3 (self, name, value). uuid_extra52 covers __setattr__.__qualname__
# and the __dict__ membership fact was not covered. No prior uuid spec checks
# UUID.__setattr__.__code__.co_name or co_argcount.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra69.UUID_setattr_code_attrs:
  description: "uuid.UUID/__setattr__/__code__/co_name.__eq__('__setattr__')==True / UUID/__setattr__/__code__/co_argcount.__eq__(3)==True — UUID.__setattr__ is a Python function with co_name=='__setattr__' and co_argcount==3 (self+name+value); uuid_extra52 covers __setattr__.__qualname__ but NOT code object attributes; no prior uuid spec checks UUID.__setattr__.__code__.co_name or co_argcount; first code object anchor for UUID.__setattr__"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidmore69

  columns: [id, function, args, expected]
  rows:
    - [UUID_setattr_co_name_eq,     UUID.__setattr__.__code__.co_name.__eq__,     ["__setattr__"], true]
    - [UUID_setattr_co_argcount_eq, UUID.__setattr__.__code__.co_argcount.__eq__,  [3],             true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__ for __repr__ and __int__ — cross-check table
#
# Wave 244 theme: UUID method membership in __dict__.
#
# UUID defines both __repr__ and __int__ as Python methods. This cross-check
# table confirms both are present as a complementary pair.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra69.UUID_dict_repr_int_crosscheck:
  description: "uuid.UUID/__dict__.__contains__('__repr__')==True / __contains__('__int__')==True — UUID defines __repr__ for string representation and __int__ for integer conversion; both present in class __dict__; paired cross-check for the repr/int method family; no prior uuid spec checks UUID.__dict__.__contains__ for __repr__ or __int__; first repr/int dict membership cross-check for UUID"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidmore69

  columns: [id, function, args, expected]
  rows:
    - [UUID_dict_has_repr_crosscheck, UUID.__dict__.__contains__, ["__repr__"], true]
    - [UUID_dict_has_int_crosscheck,  UUID.__dict__.__contains__, ["__int__"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__repr__') — standalone
#
# UUID defines __repr__ in its class __dict__. No prior uuid spec checks
# UUID.__dict__.__contains__('__repr__'). First __repr__ dict membership
# standalone for UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra69.UUID_dict_has_repr:
  description: "uuid.UUID.__dict__.__contains__('__repr__') == True — UUID defines __repr__ directly in its class __dict__; no prior uuid spec checks UUID.__dict__.__contains__('__repr__'); first __repr__ dict membership standalone for UUID"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__setattr__') — standalone
#
# UUID overrides __setattr__ in its class __dict__ to enforce immutability.
# uuid_extra52 covers UUID.__setattr__.__qualname__ but NOT __dict__ membership.
# First __setattr__ dict membership standalone for UUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra69.UUID_dict_has_setattr:
  description: "uuid.UUID.__dict__.__contains__('__setattr__') == True — UUID overrides __setattr__ in its class __dict__ to enforce immutability (raises TypeError on assignment); uuid_extra52 covers __setattr__.__qualname__ but NOT __dict__ membership; first __setattr__ dict membership standalone for UUID"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["__setattr__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# SafeUUID.__dict__ is a mappingproxy (read-only class namespace). No prior
# uuid spec checks SafeUUID.__dict__.__class__.__name__. First __dict__ class
# identity standalone for SafeUUID.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra69.SafeUUID_dict_class_mappingproxy:
  description: "uuid.SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') == True — SafeUUID.__dict__ is a mappingproxy (read-only class namespace view); no prior uuid spec checks SafeUUID.__dict__.__class__.__name__; first __dict__ class identity standalone for SafeUUID"
  category: class_identity
  kind: python_call_eq
  function: SafeUUID.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__code__.co_name.__eq__('__setattr__') — standalone
#
# UUID.__setattr__ is a Python function; its code object's co_name is
# '__setattr__'. No prior uuid spec checks UUID.__setattr__.__code__.co_name.
# First co_name standalone for UUID.__setattr__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra69.UUID_setattr_co_name:
  description: "uuid.UUID.__setattr__.__code__.co_name.__eq__('__setattr__') == True — UUID.__setattr__ is a Python function; co_name matches the function name '__setattr__'; no prior uuid spec checks UUID.__setattr__.__code__.co_name; first co_name standalone for UUID.__setattr__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__setattr__.__code__.co_name.__eq__
  args: ["__setattr__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__code__.co_argcount.__eq__(3) — standalone
#
# UUID.__setattr__ takes 3 arguments: self, name, value. No prior uuid spec
# checks UUID.__setattr__.__code__.co_argcount. First co_argcount standalone
# for UUID.__setattr__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra69.UUID_setattr_co_argcount:
  description: "uuid.UUID.__setattr__.__code__.co_argcount.__eq__(3) == True — UUID.__setattr__ takes 3 positional arguments (self, name, value); no prior uuid spec checks UUID.__setattr__.__code__.co_argcount; first co_argcount standalone for UUID.__setattr__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__setattr__.__code__.co_argcount.__eq__
  args: [3]
  expected: true
