spec: enum_extra15
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra14.zspec.zsdl and enum_flags.zspec.zsdl."
    - "enum_extra14 covers: standalone __name__ invariants for IntFlag, IntEnum, Flag, EnumMeta, auto, unique; StrEnum/ReprEnum/EnumType __name__ (>=3.11); IntEnum/__bases__[0].__name__ == 'int'; IntFlag/__bases__[0].__name__ == 'int'; auto().__class__.__name__ == 'auto'."
    - "NOT yet covered: enum.Enum.__name__ length == 4; enum.IntEnum.__name__ length == 7; enum.Flag.__name__ length == 4; enum.auto.__name__ length == 4."
    - "NOT yet covered: enum.Enum.__module__ == 'enum' as a standalone invariant."
    - "NOT yet covered: enum.IntEnum.__module__ == 'enum' as a standalone invariant."
    - "NOT yet covered: enum.Flag.__module__ == 'enum' as a standalone invariant."
    - "NOT yet covered: enum.auto.__module__ == 'enum' as a standalone invariant."
    - "NOT yet covered: enum.Enum.__qualname__ == 'Enum' as a standalone invariant."
    - "NOT yet covered: enum.Flag.__qualname__ == 'Flag' as a standalone invariant."
    - "NOT yet covered: enum.IntEnum.__qualname__ == 'IntEnum' as a standalone invariant."
    - "NOT yet covered: enum.auto.__qualname__ == 'auto' as a standalone invariant."
    - "NOT yet covered: enum.EnumMeta.__qualname__ == 'EnumMeta' as a standalone invariant."
    - "enum.Enum.__module__ == 'enum'."
    - "enum.IntEnum.__module__ == 'enum'."
    - "enum.Flag.__module__ == 'enum'."
    - "enum.auto.__module__ == 'enum'."
    - "enum.Enum.__qualname__ == 'Enum'."
    - "enum.Flag.__qualname__ == 'Flag'."
    - "enum.IntEnum.__qualname__ == 'IntEnum'."
    - "enum.auto.__qualname__ == 'auto'."
    - "enum.EnumMeta.__qualname__ == 'EnumMeta'."
    - "enum.Enum.__name__.__len__() == 4 — 'Enum' is 4 characters."
    - "enum.Flag.__name__.__len__() == 4 — 'Flag' is 4 characters."
    - "enum.IntEnum.__name__.__len__() == 7 — 'IntEnum' is 7 characters."
    - "enum.auto.__name__.__len__() == 4 — 'auto' is 4 characters."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __module__ — standalone invariants for core enum classes
#
# Prior specs verify __module__ for unique, nonmember, member, global_enum,
# show_flag_values (extras 12–13). Not yet verified as standalone invariants:
# Enum, IntEnum, Flag, and auto __module__ attributes.
# ---------------------------------------------------------------------------

table enum_extra15.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__module__.__eq__,    ["enum"], true]
    - [IntEnum, IntEnum.__module__.__eq__, ["enum"], true]
    - [Flag,    Flag.__module__.__eq__,    ["enum"], true]
    - [auto,    auto.__module__.__eq__,    ["enum"], true]

# ---------------------------------------------------------------------------
# Class __qualname__ — standalone invariants
#
# Prior specs verify __qualname__ for unique, nonmember, member,
# global_enum, show_flag_values, ReprEnum (extras 12–13).
# Not yet verified as standalone invariants: Enum, Flag, IntEnum, auto,
# and EnumMeta __qualname__.
# ---------------------------------------------------------------------------

table enum_extra15.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__qualname__.__eq__,    ["Enum"],    true]
    - [Flag,    Flag.__qualname__.__eq__,    ["Flag"],    true]
    - [IntEnum, IntEnum.__qualname__.__eq__, ["IntEnum"], true]
    - [auto,    auto.__qualname__.__eq__,    ["auto"],    true]
    - [EnumMeta, EnumMeta.__qualname__.__eq__, ["EnumMeta"], true]

# ---------------------------------------------------------------------------
# Class __name__ string lengths
#
# enum_extra14 covers __name__ via __eq__ for all major classes.
# No prior spec verifies the __len__ of any class __name__ in the enum module.
# These are structural checks distinct from equality.
# ---------------------------------------------------------------------------

table enum_extra15.class_name_lengths:
  kind: python_call_eq
  category: class_names
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__name__.__len__,    [], 4]
    - [Flag,    Flag.__name__.__len__,    [], 4]
    - [IntEnum, IntEnum.__name__.__len__, [], 7]
    - [auto,    auto.__name__.__len__,    [], 4]

# ---------------------------------------------------------------------------
# Enum.__name__ standalone invariant
#
# enum.zspec.zsdl covers __name__ for Enum in a table alongside other attrs.
# No prior spec has a standalone invariant for Enum.__name__ using the
# __eq__ pattern exclusively. This adds it for machine-readability parity
# with the other classes in enum_extra14.
# ---------------------------------------------------------------------------

invariant enum_extra15.Enum.name:
  description: "enum.Enum.__name__ == 'Enum'"
  category: class_names
  kind: python_call_eq
  function: Enum.__name__.__eq__
  args: ["Enum"]
  expected: true
