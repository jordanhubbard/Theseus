spec: inspect_extra24
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra23.zspec.zsdl."
    - "Focus: __qualname__ values for inspect module-level functions (getmembers, getmro, getmodule, getfile, getsource, getsourcelines, getsourcefile, isclass, isfunction, ismethod) in the extra24 namespace."
    - "inspect_extra22 covers __qualname__.__len__() for isfunction/ismethod/isclass/ismodule/getmembers/getsource in a combined table (lengths only, not equality checks in the extra22 namespace)."
    - "inspect_extra19 covers predicate __qualname__.__eq__ for ismodule/isclass/isfunction/ismethod/isbuiltin in a table, and getmembers/__qualname__.__eq__ as a standalone invariant."
    - "inspect_extra21 covers source-retrieval function __qualname__.__eq__ table (getfile/getmodule/getsourcefile/getsourcelines) in the extra21 namespace."
    - "inspect_extra15 covers __qualname__ table for isfunction/isbuiltin/isclass/ismodule/ismethod/ismethoddescriptor in the extra15 namespace."
    - "No prior inspect spec has all ten of getmembers/getmro/getmodule/getfile/getsource/getsourcelines/getsourcefile/isclass/isfunction/ismethod together in a single combined __qualname__ table in the extra24 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect module-level function __qualname__ values — combined table
#
# All ten functions are defined at module level in inspect; each has
# __qualname__ equal to its own function name.
# No prior inspect spec has all ten together in a combined table in the
# extra24 namespace.
# ---------------------------------------------------------------------------

table inspect_extra24.function_qualnames:
  description: "__qualname__.__eq__ for inspect module-level functions"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [getmembers,    getmembers.__qualname__.__eq__,    ["getmembers"],    true]
    - [getmro,        getmro.__qualname__.__eq__,        ["getmro"],        true]
    - [getmodule,     getmodule.__qualname__.__eq__,     ["getmodule"],     true]
    - [getfile,       getfile.__qualname__.__eq__,       ["getfile"],       true]
    - [getsource,     getsource.__qualname__.__eq__,     ["getsource"],     true]
    - [getsourcelines, getsourcelines.__qualname__.__eq__, ["getsourcelines"], true]
    - [getsourcefile, getsourcefile.__qualname__.__eq__, ["getsourcefile"], true]
    - [isclass,       isclass.__qualname__.__eq__,       ["isclass"],       true]
    - [isfunction,    isfunction.__qualname__.__eq__,    ["isfunction"],    true]
    - [ismethod,      ismethod.__qualname__.__eq__,      ["ismethod"],      true]

# ---------------------------------------------------------------------------
# inspect module-level function __qualname__.__len__() — combined table
#
# Verifies the string length of each function __qualname__:
#   getmembers -> 10, getmro -> 6, getmodule -> 9, getfile -> 7,
#   getsource -> 9, getsourcelines -> 14, getsourcefile -> 13,
#   isclass -> 7, isfunction -> 10, ismethod -> 8
# inspect_extra22 covers a subset of these lengths (isfunction/ismethod/
# isclass/getmembers/getsource) in a table in the extra22 namespace.
# No prior inspect spec has all ten together in the extra24 namespace.
# ---------------------------------------------------------------------------

table inspect_extra24.function_qualname_lens:
  description: "__qualname__.__len__() for inspect module-level functions"
  kind: python_call_eq
  category: function_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [getmembers,     getmembers.__qualname__.__len__,     [], 10]
    - [getmro,         getmro.__qualname__.__len__,         [],  6]
    - [getmodule,      getmodule.__qualname__.__len__,      [],  9]
    - [getfile,        getfile.__qualname__.__len__,        [],  7]
    - [getsource,      getsource.__qualname__.__len__,      [],  9]
    - [getsourcelines, getsourcelines.__qualname__.__len__, [], 14]
    - [getsourcefile,  getsourcefile.__qualname__.__len__,  [], 13]
    - [isclass,        isclass.__qualname__.__len__,        [],  7]
    - [isfunction,     isfunction.__qualname__.__len__,     [], 10]
    - [ismethod,       ismethod.__qualname__.__len__,       [],  8]
