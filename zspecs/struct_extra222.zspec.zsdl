spec: struct_extra222
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.pack('!B', 0) == b'\\x00' — network byte order unsigned byte 0 packs to a single zero byte."
    - "struct.pack('!B', 255) == b'\\xff' — network byte order unsigned byte 255 packs to 0xff; covered in extra15 as standalone; extra222 anchors via table."
    - "struct.pack('!H', 256) == b'\\x01\\x00' — network byte order unsigned short 256 = 0x0100; MSB first."
    - "struct.pack('!H', 0) == b'\\x00\\x00' — network byte order unsigned short 0 packs to two zero bytes."
    - "struct.pack('!I', 256) == b'\\x00\\x00\\x01\\x00' — network byte order unsigned int 256 = 0x00000100."
    - "struct.unpack('!B', b'\\x00')[0] == 0 — inverse of pack('!B', 0)."
    - "struct.unpack('!B', b'\\xff')[0] == 255 — inverse of pack('!B', 255)."
    - "struct.unpack('!H', b'\\x01\\x00')[0] == 256 — inverse of pack('!H', 256)."
    - "struct.pack('!b', -1) == b'\\xff' — network byte order signed byte -1 = 0xff in two's complement."
    - "struct.unpack('!b', b'\\xff')[0] == -1 — inverse of pack('!b', -1); two's complement signed byte."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack('!B', ...) — network byte order unsigned byte boundary values
#
# struct.pack('!B', 0)   == b'\x00'
# struct.pack('!B', 255) == b'\xff'
#
# '!' prefix selects network byte order (big-endian). 'B' is unsigned char
# (1 byte). Values 0 and 255 are the min and max for an unsigned byte.
# pack('!B', 255) is covered in extra15 as standalone; extra222 adds 0
# and groups both in a table. pack('!B', 0) is new to extra222.
# ---------------------------------------------------------------------------

table struct_extra222.pack_network_B_boundary:
  description: "pack('!B',0)==b'\\x00'; pack('!B',255)==b'\\xff'; network byte order unsigned byte min/max; new table anchor in extra222"
  kind: python_call_eq
  category: pack_values
  id_prefix: struct222

  columns: [id, function, args, expected, description]
  rows:
    - [pack_netB_0,   pack, ["!B", 0],   !hex 00, "struct.pack('!B', 0) == b'\\x00' — network byte order unsigned byte 0; minimum value; single zero byte; new to extra222"]
    - [pack_netB_255, pack, ["!B", 255], !hex ff, "struct.pack('!B', 255) == b'\\xff' — network byte order unsigned byte 255; maximum value; single 0xff byte; extra15 anchors as standalone; extra222 table anchor"]

# ---------------------------------------------------------------------------
# struct.pack('!H', ...) — network byte order unsigned short boundary values
#
# struct.pack('!H', 0)   == b'\x00\x00'
# struct.pack('!H', 256) == b'\x01\x00'
#
# 'H' is unsigned short (2 bytes). In network (big-endian) order, 256 = 0x0100
# encodes as MSB first: b'\x01\x00'. Value 0 encodes as two zero bytes.
# No prior struct spec covers pack('!H', 0). New to extra222.
# ---------------------------------------------------------------------------

table struct_extra222.pack_network_H_values:
  description: "pack('!H',0)==b'\\x00\\x00'; pack('!H',256)==b'\\x01\\x00'; network byte order unsigned short; new to extra222"
  kind: python_call_eq
  category: pack_values
  id_prefix: struct222a

  columns: [id, function, args, expected, description]
  rows:
    - [pack_netH_0,   pack, ["!H", 0],   "!hex 0000", "struct.pack('!H', 0) == b'\\x00\\x00' — network byte order unsigned short 0; two zero bytes; no prior spec covers pack('!H', 0); new to extra222"]
    - [pack_netH_256, pack, ["!H", 256], "!hex 0100", "struct.pack('!H', 256) == b'\\x01\\x00' — network byte order unsigned short 256 = 0x0100; MSB first in big-endian order; new to extra222"]

# ---------------------------------------------------------------------------
# struct.pack('!I', 256) — network byte order unsigned int
#
# struct.pack('!I', 256) == b'\x00\x00\x01\x00'
#
# 'I' is unsigned int (4 bytes). 256 = 0x00000100 in network (big-endian) order
# encodes as b'\x00\x00\x01\x00'. No prior struct spec covers pack('!I', 256).
# New to extra222.
# ---------------------------------------------------------------------------

table struct_extra222.pack_network_I_256:
  description: "pack('!I',256)==b'\\x00\\x00\\x01\\x00'; network byte order unsigned int 256=0x00000100; new to extra222"
  kind: python_call_eq
  category: pack_values
  id_prefix: struct222b

  columns: [id, function, args, expected, description]
  rows:
    - [pack_netI_256, pack, ["!I", 256], "!hex 00000100", "struct.pack('!I', 256) == b'\\x00\\x00\\x01\\x00' — network byte order unsigned int 256 = 0x00000100; 4-byte big-endian encoding; new to extra222"]

# ---------------------------------------------------------------------------
# struct.unpack('!B', ...) — network byte order unsigned byte round-trip
#
# struct.unpack('!B', b'\x00')[0] == 0
# struct.unpack('!B', b'\xff')[0] == 255
#
# Inverse of pack('!B', ...). unpack always returns a tuple; index [0] gives
# the first (only) element. New to extra222.
# ---------------------------------------------------------------------------

table struct_extra222.unpack_network_B_boundary:
  description: "unpack('!B',b'\\x00')==(0,); unpack('!B',b'\\xff')==(255,); round-trip for network byte order unsigned byte; new to extra222"
  kind: python_call_eq
  category: unpack_values
  id_prefix: struct222c

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_netB_0,   unpack, ["!B", !hex 00], [0],   "struct.unpack('!B', b'\\x00')[0] == 0 — inverse of pack('!B', 0); single byte 0x00 decodes to unsigned 0; result tuple element 0 is 0; new to extra222"]
    - [unpack_netB_255, unpack, ["!B", !hex ff], [255], "struct.unpack('!B', b'\\xff')[0] == 255 — inverse of pack('!B', 255); single byte 0xff decodes to unsigned 255; result tuple element 0 is 255; new to extra222"]

# ---------------------------------------------------------------------------
# struct.unpack('!H', ...) — network byte order unsigned short round-trip
#
# struct.unpack('!H', b'\x01\x00')[0] == 256
#
# Inverse of pack('!H', 256). Big-endian: 0x01 is MSB, 0x00 is LSB = 256.
# New to extra222.
# ---------------------------------------------------------------------------

table struct_extra222.unpack_network_H_256:
  description: "unpack('!H',b'\\x01\\x00')==(256,); round-trip for network byte order unsigned short; new to extra222"
  kind: python_call_eq
  category: unpack_values
  id_prefix: struct222d

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_netH_256, unpack, ["!H", "!hex 0100"], [256], "struct.unpack('!H', b'\\x01\\x00')[0] == 256 — inverse of pack('!H', 256); 0x01 MSB + 0x00 LSB = 256 in network (big-endian) order; new to extra222"]

# ---------------------------------------------------------------------------
# struct.pack('!b', -1) and struct.unpack('!b', b'\xff')
#
# struct.pack('!b', -1)         == b'\xff'
# struct.unpack('!b', b'\xff')[0] == -1
#
# 'b' is signed char (1 byte, range -128 to 127). Two's complement: -1 is
# all bits set = 0xff. This is different from 'B' (unsigned byte 255 = 0xff).
# New to extra222.
# ---------------------------------------------------------------------------

table struct_extra222.pack_unpack_signed_byte_neg1:
  description: "pack('!b',-1)==b'\\xff'; unpack('!b',b'\\xff')==(-1,); signed byte -1=0xff in two's complement; new to extra222"
  kind: python_call_eq
  category: pack_values
  id_prefix: struct222e

  columns: [id, function, args, expected, description]
  rows:
    - [pack_signed_b_neg1,   pack,   ["!b", -1],       !hex ff, "struct.pack('!b', -1) == b'\\xff' — signed byte -1 in two's complement is all 8 bits set = 0xff; same bytes as unsigned 255 but different type code; new to extra222"]
    - [unpack_signed_b_xff,  unpack, ["!b", !hex ff],  [-1],    "struct.unpack('!b', b'\\xff')[0] == -1 — inverse of pack('!b', -1); 0xff as signed byte is -1 in two's complement; contrasts with unpack('!B',xff)==255; new to extra222"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra222.pack_netB_0:
  description: "struct.pack('!B', 0) == b'\\x00' — network byte order ('!') unsigned char ('B') with value 0 produces a single zero byte; the '!' prefix means network byte order (big-endian, same as '>'); 'B' is unsigned char (1 byte, range 0-255); packing 0 always produces b'\\x00'; no prior struct spec packs '!B' with value 0 as a standalone; first extra222 anchor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: ["!B", 0]
  expected: !hex 00

invariant struct_extra222.pack_netH_0:
  description: "struct.pack('!H', 0) == b'\\x00\\x00' — network byte order unsigned short 0 produces two zero bytes; 'H' is unsigned short (2 bytes, range 0-65535); in big-endian order, 0 encodes as 0x00 0x00; no prior struct spec packs '!H' with value 0; first extra222 standalone for pack('!H', 0); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: ["!H", 0]
  expected: !hex 0000

invariant struct_extra222.pack_signed_byte_neg1:
  description: "struct.pack('!b', -1) == b'\\xff' — network byte order signed char -1; two's complement representation of -1 in 8 bits is all bits set = 0xff; 'b' (lowercase) is signed char (1 byte, range -128 to 127); contrasts with 'B' (uppercase, unsigned) where 255 also encodes as 0xff — same bytes, different interpretation; first extra222 standalone for signed byte pack; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: ["!b", -1]
  expected: !hex ff

invariant struct_extra222.unpack_signed_byte_neg1:
  description: "struct.unpack('!b', b'\\xff')[0] == -1 — network byte order signed char 0xff decodes to -1; two's complement signed interpretation of all-bits-set byte; result is a tuple (−1,); index [0] extracts the value; contrasts with unpack('!B', b'\\xff')==(255,) — same bytes, opposite sign interpretation; first extra222 standalone for unpack('!b'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: ["!b", !hex ff]
  expected: [-1]
