spec: theseus_uuid_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_uuid_cr2)
blocks: uuid

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html"
    - "RFC 4122 — UUID specification"
  notes:
    - "Clean-room extended UUID utilities. Do NOT import uuid."
    - "UUID(bytes=b): construct UUID from 16-byte string."
    - "UUID(int=n): construct UUID from 128-bit integer."
    - "uuid4(): generate a random UUID (version 4)."
    - "uuid2_from_bytes(): UUID(bytes=b'\\x12'*16).int > 0 — returns True."
    - "uuid2_from_int(): UUID(int=0).hex == '0'*32."
    - "uuid2_version4_variant(): uuid4().version == 4."
    - "Zero-arg invariant signatures — def uuid2_from_bytes(): return bool"
    - "UUID stores a 128-bit value; .hex is 32 hex chars; .int is the integer; .version is 1-5."
    - "uuid4 uses os.urandom(16) then sets version bits (version=4, variant=RFC4122)."
    - "Export: UUID class, uuid1(), uuid3(), uuid4(), uuid5(), NAMESPACE_DNS, etc."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_uuid_cr2.from_bytes:
  description: "UUID(bytes=b'\\x12'*16).int > 0"
  category: UUID
  kind: python_call_eq
  function: uuid2_from_bytes
  args: []
  expected: true

invariant theseus_uuid_cr2.from_int:
  description: "UUID(int=0).hex == '0'*32"
  category: UUID
  kind: python_call_eq
  function: uuid2_from_int
  args: []
  expected: "00000000000000000000000000000000"

invariant theseus_uuid_cr2.version4_variant:
  description: "uuid4().version == 4"
  category: uuid4
  kind: python_call_eq
  function: uuid2_version4_variant
  args: []
  expected: 4
