spec: struct_extra123
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra122.zspec.zsdl — covers struct.error/__name__/__qualname__/__class__.__name__ equality / struct.error/__bases__[0]/__name__ / struct.error/__mro__/__len__()==4 / Struct/__name__/__qualname__/__class__.__name__ equality / Struct.size/format/__name__ equality (table + invariants)."
    - "struct_extra121.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__ string equality ('Struct.pack' etc.) / method __objclass__.__name__ equality (table + invariants)."
    - "struct_extra120.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack method __doc__.__len__() and __doc__.__class__.__name__ (table + invariants)."
    - "struct_extra119.zspec.zsdl — covers struct module-level function __name__ equality (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack) / pack_into/unpack_from/iter_unpack __qualname__ equality (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths / Struct.size/format descriptor __doc__ string equality and lengths / struct module __doc__ length (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/format getset_descriptor __class__.__name__ / qualname/name lengths / __objclass__.__name__ (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / Struct/__module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier struct specs."
    - "Wave 298 theme: struct.Struct method __objclass__.__module__ and __objclass__.__qualname__ equality — pack/unpack/pack_into/unpack_from/iter_unpack method_descriptor objects' owning class attributes."
    - "struct.Struct.pack.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__objclass__.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__objclass__.__qualname__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__objclass__.__qualname__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__objclass__.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra121 anchors __objclass__.__name__=='Struct' for all five methods. This spec first anchors __objclass__.__module__=='_struct' and __objclass__.__qualname__=='Struct'. The __objclass__ on each method_descriptor is the Struct class from the _struct C extension, so its __module__ is '_struct' (not 'struct')."
    - "Note: __objclass__.__qualname__ == 'Struct' (same as __objclass__.__name__) because Struct is a top-level class in the _struct module — no enclosing scope so __qualname__==__name__. extra93 anchors Struct.__qualname__=='Struct'; this spec anchors it via __objclass__.__qualname__ traversal."
    - "Note: __objclass__.__class__.__name__=='type' confirms Struct is a type (not a metaclass subtype). extra91 anchors Struct.__class__.__name__=='type' directly; this spec anchors it through the __objclass__ indirection."
    - "Note: struct_extra98 anchors Struct.size.__objclass__.__name__=='Struct' and Struct.format.__objclass__.__name__=='Struct' (the getset_descriptor descriptors). This spec covers the method_descriptor methods (pack/unpack/pack_into/unpack_from/iter_unpack) — a different set of descriptors."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__module__.__eq__('_struct')
# struct.Struct.unpack.__objclass__.__module__.__eq__('_struct')
# struct.Struct.pack_into.__objclass__.__module__.__eq__('_struct')
# struct.Struct.unpack_from.__objclass__.__module__.__eq__('_struct')
# struct.Struct.iter_unpack.__objclass__.__module__.__eq__('_struct')
#
# Wave 298 theme: Struct method __objclass__.__module__ equality.
#
# __objclass__ on each method_descriptor is the Struct class from the _struct C
# extension. The Struct class's __module__ is '_struct' (the C extension module name),
# not 'struct' (the Python wrapper module). extra121 anchors __objclass__.__name__=='Struct'
# for these five methods; no prior struct spec anchors __objclass__.__module__=='_struct'
# for method_descriptor objects under structobjmod123.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra123.Struct_method_objclass_module:
  description: "struct.Struct.pack/__objclass__/__module__.__eq__('_struct')==True / Struct.unpack/__objclass__/__module__.__eq__('_struct')==True / Struct.pack_into/__objclass__/__module__.__eq__('_struct')==True / Struct.unpack_from/__objclass__/__module__.__eq__('_struct')==True / Struct.iter_unpack/__objclass__/__module__.__eq__('_struct')==True — all five method_descriptors point to the Struct class from _struct C extension; extra121 anchors __objclass__.__name__=='Struct'; first structobjmod123 anchor for __objclass__.__module__"
  kind: python_call_eq
  category: objclass_identity
  id_prefix: structobjmod123

  columns: [id, function, args, expected, description]
  rows:
    - [pack_objclass_module,      "Struct.pack.__objclass__.__module__.__eq__",      ["_struct"],  true,  "Struct.pack.__objclass__.__module__ is '_struct' (C extension; not the Python 'struct' wrapper)"]
    - [unpack_objclass_module,    "Struct.unpack.__objclass__.__module__.__eq__",    ["_struct"],  true,  "Struct.unpack.__objclass__.__module__ is '_struct' (C extension defining the Struct class)"]
    - [pack_into_objclass_module, "Struct.pack_into.__objclass__.__module__.__eq__", ["_struct"],  true,  "Struct.pack_into.__objclass__.__module__ is '_struct' (C extension)"]
    - [unpack_from_objclass_mod,  "Struct.unpack_from.__objclass__.__module__.__eq__",["_struct"], true,  "Struct.unpack_from.__objclass__.__module__ is '_struct' (C extension)"]
    - [iter_unpack_objclass_mod,  "Struct.iter_unpack.__objclass__.__module__.__eq__",["_struct"], true,  "Struct.iter_unpack.__objclass__.__module__ is '_struct' (C extension)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__qualname__.__eq__('Struct')
# struct.Struct.unpack.__objclass__.__qualname__.__eq__('Struct')
# struct.Struct.pack_into.__objclass__.__qualname__.__eq__('Struct')
# struct.Struct.pack.__objclass__.__class__.__name__.__eq__('type')
#
# Wave 298 theme: Struct method __objclass__.__qualname__ and __class__.__name__.
#
# All five method_descriptors' __objclass__.__qualname__ is 'Struct' — the same as
# __objclass__.__name__ because Struct is a top-level class (no enclosing scope).
# __objclass__.__class__.__name__ is 'type' (Struct is a regular class, not a
# metaclass subtype). extra93 anchors Struct.__module__/__qualname__/__bases__/__mro__;
# extra121 anchors __objclass__.__name__=='Struct'; no prior spec anchors
# __objclass__.__qualname__ or __objclass__.__class__.__name__ via this indirection.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra123.Struct_method_objclass_qualname:
  description: "struct.Struct.pack/__objclass__/__qualname__.__eq__('Struct')==True / Struct.unpack/__objclass__/__qualname__.__eq__('Struct')==True / Struct.pack_into/__objclass__/__qualname__.__eq__('Struct')==True / Struct.pack/__objclass__/__class__.__name__.__eq__('type')==True — __objclass__.__qualname__=='Struct' (top-level class, no enclosing scope, qualname==name); __objclass__.__class__.__name__=='type'; extra121 anchors __objclass__.__name__=='Struct'; first structobjmod123 anchor for __objclass__.__qualname__"
  kind: python_call_eq
  category: objclass_identity
  id_prefix: structobjmod123

  columns: [id, function, args, expected, description]
  rows:
    - [pack_objclass_qualname,      "Struct.pack.__objclass__.__qualname__.__eq__",       ["Struct"],  true,  "Struct.pack.__objclass__.__qualname__ is 'Struct' (equals __name__; no enclosing scope for _struct.Struct)"]
    - [unpack_objclass_qualname,    "Struct.unpack.__objclass__.__qualname__.__eq__",     ["Struct"],  true,  "Struct.unpack.__objclass__.__qualname__ is 'Struct' (top-level class in _struct C extension)"]
    - [pack_into_objclass_qualname, "Struct.pack_into.__objclass__.__qualname__.__eq__",  ["Struct"],  true,  "Struct.pack_into.__objclass__.__qualname__ is 'Struct' (same pattern; __qualname__==__name__)"]
    - [pack_objclass_class_type,    "Struct.pack.__objclass__.__class__.__name__.__eq__", ["type"],    true,  "Struct.pack.__objclass__.__class__.__name__ is 'type' (Struct is a regular class, metaclass is 'type')"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__module__.__eq__('_struct') (cross-check)
# struct.Struct.unpack_from.__objclass__.__module__.__eq__('_struct') (cross-check)
# struct.Struct.pack.__objclass__.__qualname__.__eq__('Struct') (cross-check)
# struct.Struct.iter_unpack.__objclass__.__qualname__.__eq__('Struct') (cross-check)
# struct.Struct.unpack.__objclass__.__class__.__name__.__eq__('type') (cross-check)
#
# Wave 298 theme: cross-check confirming __objclass__ consistency across methods.
#
# All five Struct methods point to the same __objclass__ (the Struct class).
# Therefore __objclass__.__module__, __objclass__.__qualname__, and
# __objclass__.__class__.__name__ are identical for all five methods.
# This cross-check table samples different methods to confirm consistency.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra123.Struct_objclass_cross_check:
  description: "struct.Struct.pack/__objclass__/__module__.__eq__('_struct')==True / Struct.unpack_from/__objclass__/__module__.__eq__('_struct')==True / Struct.pack/__objclass__/__qualname__.__eq__('Struct')==True / Struct.iter_unpack/__objclass__/__qualname__.__eq__('Struct')==True / Struct.unpack/__objclass__/__class__.__name__.__eq__('type')==True — all five methods share the same __objclass__; cross-check confirms consistency; first structobjmod123 cross-check"
  kind: python_call_eq
  category: objclass_identity
  id_prefix: structobjmod123

  columns: [id, function, args, expected, description]
  rows:
    - [pack_mod_xcheck,     "Struct.pack.__objclass__.__module__.__eq__",         ["_struct"],  true,  "Struct.pack.__objclass__.__module__ is '_struct' (cross-check)"]
    - [unpk_from_mod_xchk,  "Struct.unpack_from.__objclass__.__module__.__eq__",  ["_struct"],  true,  "Struct.unpack_from.__objclass__.__module__ is '_struct' (cross-check: same __objclass__ as pack)"]
    - [pack_qname_xcheck,   "Struct.pack.__objclass__.__qualname__.__eq__",        ["Struct"],   true,  "Struct.pack.__objclass__.__qualname__ is 'Struct' (cross-check)"]
    - [itrpk_qname_xcheck,  "Struct.iter_unpack.__objclass__.__qualname__.__eq__", ["Struct"],   true,  "Struct.iter_unpack.__objclass__.__qualname__ is 'Struct' (cross-check: same __objclass__)"]
    - [unpack_cls_xcheck,   "Struct.unpack.__objclass__.__class__.__name__.__eq__",["type"],     true,  "Struct.unpack.__objclass__.__class__.__name__ is 'type' (cross-check: Struct metaclass is 'type')"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__module__.__eq__('_struct') — standalone
#
# struct.Struct.pack.__objclass__.__module__ is '_struct'. The __objclass__ attribute
# on a method_descriptor identifies the class that defines it. For Struct.pack,
# __objclass__ is the Struct class from the _struct C extension. The C extension
# class's __module__ is '_struct' (the C module name), not 'struct' (the Python
# wrapper). This is consistent with Struct.__module__=='_struct' (anchored in
# extra93). No prior struct spec anchors Struct method __objclass__.__module__
# as a standalone under structobjmod123. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra123.pack_objclass_module_eq:
  description: "struct.Struct.pack.__objclass__.__module__.__eq__('_struct') == True — Struct.pack's __objclass__ is the _struct.Struct C class; its __module__ is '_struct'; extra93 anchors Struct.__module__=='_struct' directly; this standalone anchors it via __objclass__ indirection; first standalone under structobjmod123"
  category: objclass_identity
  kind: python_call_eq
  function: "Struct.pack.__objclass__.__module__.__eq__"
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__objclass__.__module__.__eq__('_struct') — standalone
#
# struct.Struct.iter_unpack.__objclass__.__module__ is '_struct'. iter_unpack is
# one of the five Struct method_descriptor objects, all pointing to the same
# __objclass__ (the Struct C class from _struct). iter_unpack is the method that
# returns an iterator of tuples when unpacking a buffer containing repeated
# struct data. Its __objclass__.__module__ == '_struct' confirms it is a C-extension
# method. No prior struct spec anchors iter_unpack.__objclass__.__module__ as a
# standalone under structobjmod123. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra123.iter_unpack_objclass_module_eq:
  description: "struct.Struct.iter_unpack.__objclass__.__module__.__eq__('_struct') == True — iter_unpack's __objclass__ is the _struct.Struct C class; same __module__ as pack/unpack/pack_into/unpack_from; confirms iter_unpack is a C-extension method; first standalone for iter_unpack.__objclass__.__module__ under structobjmod123"
  category: objclass_identity
  kind: python_call_eq
  function: "Struct.iter_unpack.__objclass__.__module__.__eq__"
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__qualname__.__eq__('Struct') — standalone
#
# struct.Struct.pack.__objclass__.__qualname__ is 'Struct'. The __objclass__ of
# Struct.pack is the Struct C class, whose __qualname__ is 'Struct' (equal to
# its __name__ since it is a top-level class in the _struct module). extra93
# anchors Struct.__qualname__=='Struct' directly; extra121 anchors
# pack.__objclass__.__name__=='Struct'; this standalone first anchors
# pack.__objclass__.__qualname__=='Struct' as a standalone under structobjmod123.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra123.pack_objclass_qualname_eq:
  description: "struct.Struct.pack.__objclass__.__qualname__.__eq__('Struct') == True — Struct.pack's __objclass__.__qualname__ is 'Struct' (top-level class; __qualname__==__name__); extra93 anchors Struct.__qualname__ directly; extra121 anchors __objclass__.__name__; first standalone for __objclass__.__qualname__ under structobjmod123"
  category: objclass_identity
  kind: python_call_eq
  function: "Struct.pack.__objclass__.__qualname__.__eq__"
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack.__objclass__.__qualname__.__eq__('Struct') — standalone
#
# struct.Struct.unpack.__objclass__.__qualname__ is 'Struct'. unpack is the
# inverse of pack — it unpacks bytes into a tuple of values. Its __objclass__
# is the same Struct class as pack, so __objclass__.__qualname__ is also 'Struct'.
# All five Struct methods (pack, unpack, pack_into, unpack_from, iter_unpack)
# share the same __objclass__, so __objclass__.__qualname__ is 'Struct' for all.
# No prior struct spec anchors unpack.__objclass__.__qualname__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra123.unpack_objclass_qualname_eq:
  description: "struct.Struct.unpack.__objclass__.__qualname__.__eq__('Struct') == True — Struct.unpack's __objclass__.__qualname__ is 'Struct'; same __objclass__ as pack; all five Struct methods share one __objclass__; first standalone for unpack.__objclass__.__qualname__ under structobjmod123"
  category: objclass_identity
  kind: python_call_eq
  function: "Struct.unpack.__objclass__.__qualname__.__eq__"
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__class__.__name__.__eq__('type') — standalone
#
# struct.Struct.pack.__objclass__.__class__.__name__ is 'type'. The __objclass__
# of Struct.pack is the Struct class. As a class, its __class__ is the metaclass
# 'type'. This means Struct is a regular C-extension class (no custom metaclass).
# extra91 anchors Struct.__class__.__name__=='type' by direct access; this standalone
# anchors the same fact via the __objclass__ indirection from Struct.pack.
# No prior struct spec anchors Struct.pack.__objclass__.__class__.__name__ as a
# standalone under structobjmod123. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra123.pack_objclass_class_type:
  description: "struct.Struct.pack.__objclass__.__class__.__name__.__eq__('type') == True — Struct.pack's __objclass__.__class__.__name__ is 'type'; Struct has no custom metaclass; extra91 anchors Struct.__class__.__name__=='type' directly; this standalone anchors it via __objclass__ indirection; first standalone under structobjmod123"
  category: objclass_identity
  kind: python_call_eq
  function: "Struct.pack.__objclass__.__class__.__name__.__eq__"
  args: ["type"]
  expected: true
