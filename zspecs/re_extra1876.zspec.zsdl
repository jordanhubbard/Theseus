spec: re_extra1876
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "re module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party regex extensions"
  notes:
    - "Tests attribute access protocol membership in re types"
    - "re.Pattern and re.Match are C types; __getattr__/__setattr__/__delattr__ are not in their __dict__"
    - "re.Match.__dict__ contains group, groups, groupdict, start, end, span, expand, __getitem__, pos, endpos"
  created_at: "2026-04-12"

table re_extra1876.attr_access_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["re1876-aa-001", "re.Pattern.__dict__.__contains__", ["__getattr__"], false]
    - ["re1876-aa-002", "re.Pattern.__dict__.__contains__", ["__setattr__"], false]
    - ["re1876-aa-003", "re.Pattern.__dict__.__contains__", ["__delattr__"], false]
    - ["re1876-aa-004", "re.Match.__dict__.__contains__", ["__getattr__"], false]
    - ["re1876-aa-005", "re.Match.__dict__.__contains__", ["__setattr__"], false]
    - ["re1876-aa-006", "re.error.__dict__.__contains__", ["__getattr__"], false]
    - ["re1876-aa-007", "re.error.__dict__.__contains__", ["__setattr__"], false]
    - ["re1876-aa-008", "re.RegexFlag.__dict__.__contains__", ["__getattr__"], false]

table re_extra1876.introspection_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["re1876-ip-001", "re.Pattern.__dict__.__contains__", ["__dir__"], false]
    - ["re1876-ip-002", "re.Pattern.__dict__.__contains__", ["__sizeof__"], false]
    - ["re1876-ip-003", "re.Match.__dict__.__contains__", ["__dir__"], false]
    - ["re1876-ip-004", "re.Match.__dict__.__contains__", ["__sizeof__"], false]
    - ["re1876-ip-005", "re.error.__dict__.__contains__", ["__dir__"], false]
    - ["re1876-ip-006", "re.RegexFlag.__dict__.__contains__", ["__dir__"], false]
    - ["re1876-ip-007", "re.Pattern.__dict__.__contains__", ["__slots__"], false]
    - ["re1876-ip-008", "re.Match.__dict__.__contains__", ["__slots__"], false]

table re_extra1876.match_named_groups:
  columns: [id, function, args, expected]
  rows:
    - ["re1876-mg-001", "re.Match.__dict__.__contains__", ["group"], true]
    - ["re1876-mg-002", "re.Match.__dict__.__contains__", ["groups"], true]
    - ["re1876-mg-003", "re.Match.__dict__.__contains__", ["groupdict"], true]
    - ["re1876-mg-004", "re.Match.__dict__.__contains__", ["start"], true]
    - ["re1876-mg-005", "re.Match.__dict__.__contains__", ["end"], true]
    - ["re1876-mg-006", "re.Match.__dict__.__contains__", ["span"], true]
    - ["re1876-mg-007", "re.Match.__dict__.__contains__", ["expand"], true]
    - ["re1876-mg-008", "re.Match.__dict__.__contains__", ["__getitem__"], true]
    - ["re1876-mg-009", "re.Match.__dict__.__contains__", ["pos"], true]
    - ["re1876-mg-010", "re.Match.__dict__.__contains__", ["endpos"], true]
