spec: threading_extra107
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra106.zspec.zsdl."
    - "This spec covers: threading.Event and threading.Barrier method class names (all are 'function' since both are pure-Python classes in Lib/threading.py); threading.Timer inheritance (__bases__[0].__name__ == 'Thread', __mro__.__len__() == 3); threading.Event and Barrier class identity (__name__, __module__, __bases__[0].__name__, __mro__.__len__); wave 259."
    - "threading.Event.set, Event.clear, Event.wait, Event.is_set: all type().__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Barrier.wait, Barrier.reset, Barrier.abort: all type().__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Event.__name__ == 'Event', __module__ == 'threading', __bases__[0].__name__ == 'object', __mro__.__len__() == 2. Verified with Python 3.14.3."
    - "threading.Barrier.__name__ == 'Barrier', __module__ == 'threading', __bases__[0].__name__ == 'object', __mro__.__len__() == 2. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread'. Verified with Python 3.14.3."
    - "threading.Timer.__mro__.__len__() == 3 — Timer -> Thread -> object. Verified with Python 3.14.3."
    - "threading.Timer.run: type().__name__ == 'function', Timer.run.__qualname__ == 'Timer.run'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Event method class names
#
# Wave 259 theme: threading.Event is a pure-Python class defined in
# Lib/threading.py. Its methods (set, clear, wait, is_set) are accessed
# as unbound attributes from the class and are plain Python 'function'
# objects — contrasting with threading.Lock whose methods are
# 'method_descriptor' (C extension type).
#
# type(threading.Event.set).__name__ == 'function'
# type(threading.Event.clear).__name__ == 'function'
# type(threading.Event.wait).__name__ == 'function'
# type(threading.Event.is_set).__name__ == 'function'
#
# New to extra107.
# ---------------------------------------------------------------------------

table threading_extra107.event_method_class_names:
  description: "threading.Event method type names: set/clear/wait/is_set are all 'function' — Event is a pure-Python class in Lib/threading.py; contrast with Lock methods which are 'method_descriptor'; wave 259; new to extra107"
  kind: python_call_eq
  category: class_names
  id_prefix: threadingevent107

  columns: [id, function, args, expected, description]
  rows:
    - [event_set_type_function,
       "Event.set.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Event.set.__class__.__name__.__eq__('function') == True — threading.Event is a pure-Python class defined in Lib/threading.py; Event.set is a Python def method; accessed unbound from the class it is a plain function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra107"]
    - [event_clear_type_function,
       "Event.clear.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Event.clear.__class__.__name__.__eq__('function') == True — Event.clear is a Python def method; accessed unbound from the class it is a plain function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra107"]
    - [event_wait_type_function,
       "Event.wait.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Event.wait.__class__.__name__.__eq__('function') == True — Event.wait is a Python def method; accessed unbound from the class it is a plain function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra107"]
    - [event_is_set_type_function,
       "Event.is_set.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Event.is_set.__class__.__name__.__eq__('function') == True — Event.is_set is a Python def method; accessed unbound from the class it is a plain function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra107"]
    - [event_set_qualname_eq,
       "Event.set.__qualname__.__eq__",
       ["Event.set"],
       true,
       "threading.Event.set.__qualname__.__eq__('Event.set') == True — Event.set is defined inside the Event class; its __qualname__ follows the 'ClassName.method_name' pattern and is 'Event.set'; str.__eq__('Event.set') returns True; new to extra107"]
    - [event_clear_qualname_eq,
       "Event.clear.__qualname__.__eq__",
       ["Event.clear"],
       true,
       "threading.Event.clear.__qualname__.__eq__('Event.clear') == True — Event.clear is defined inside the Event class; its __qualname__ is 'Event.clear'; str.__eq__('Event.clear') returns True; new to extra107"]

# ---------------------------------------------------------------------------
# Table 2: threading.Barrier method class names
#
# Wave 259 theme: threading.Barrier is a pure-Python class defined in
# Lib/threading.py. Its methods (wait, reset, abort) are accessed as
# unbound attributes from the class and are plain Python 'function'
# objects. Barrier.wait.__qualname__ is 'Barrier.wait'.
#
# type(threading.Barrier.wait).__name__ == 'function'
# type(threading.Barrier.reset).__name__ == 'function'
# type(threading.Barrier.abort).__name__ == 'function'
# threading.Barrier.wait.__qualname__ == 'Barrier.wait'
# threading.Barrier.__name__ == 'Barrier'
# threading.Barrier.__module__ == 'threading'
#
# New to extra107.
# ---------------------------------------------------------------------------

table threading_extra107.barrier_method_class_names:
  description: "threading.Barrier method type names: wait/reset/abort are all 'function'; Barrier is a pure-Python class in Lib/threading.py; plus Barrier class identity (__name__, __module__); wave 259; new to extra107"
  kind: python_call_eq
  category: class_names
  id_prefix: threadingbarrier107

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_wait_type_function,
       "Barrier.wait.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Barrier.wait.__class__.__name__.__eq__('function') == True — threading.Barrier is a pure-Python class defined in Lib/threading.py; Barrier.wait is a Python def method; accessed unbound from the class it is a plain function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra107"]
    - [barrier_reset_type_function,
       "Barrier.reset.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Barrier.reset.__class__.__name__.__eq__('function') == True — Barrier.reset is a Python def method; accessed unbound from the class it is a plain function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra107"]
    - [barrier_abort_type_function,
       "Barrier.abort.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Barrier.abort.__class__.__name__.__eq__('function') == True — Barrier.abort is a Python def method; accessed unbound from the class it is a plain function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra107"]
    - [barrier_wait_qualname_eq,
       "Barrier.wait.__qualname__.__eq__",
       ["Barrier.wait"],
       true,
       "threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True — Barrier.wait is defined inside the Barrier class; its __qualname__ is 'Barrier.wait'; str.__eq__('Barrier.wait') returns True; new to extra107"]
    - [barrier_name_eq,
       "Barrier.__name__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — threading.Barrier is the synchronization primitive for coordinating a fixed number of threads; its __name__ is 'Barrier'; str.__eq__('Barrier') returns True; new to extra107"]
    - [barrier_module_eq,
       "Barrier.__module__.__eq__",
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — threading.Barrier is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra107"]

# ---------------------------------------------------------------------------
# Table 3: threading.Timer inheritance and method identity
#
# Wave 259 theme: threading.Timer is a pure-Python class defined in
# Lib/threading.py that subclasses Thread. Its MRO is [Timer, Thread, object]
# with length 3 — making it the only threading class in these specs with
# MRO depth > 2. Timer.run is a Python 'function'. Event and Barrier
# have MRO depth 2 (inherit directly from object).
#
# threading.Timer.__bases__[0].__name__ == 'Thread'
# threading.Timer.__mro__.__len__() == 3
# threading.Timer.__name__ == 'Timer'
# threading.Timer.__module__ == 'threading'
# type(threading.Timer.run).__name__ == 'function'
# threading.Timer.run.__qualname__ == 'Timer.run'
# threading.Event.__mro__.__len__() == 2
# threading.Barrier.__mro__.__len__() == 2
#
# New to extra107.
# ---------------------------------------------------------------------------

table threading_extra107.timer_identity_and_mro:
  description: "threading.Timer inheritance: __bases__[0].__name__ == 'Thread', __mro__.__len__() == 3 (Timer->Thread->object); Timer.run is 'function'; Event and Barrier have MRO depth 2; wave 259; new to extra107"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingtimer107

  columns: [id, function, args, expected, description]
  rows:
    - ["timer_bases_0_name_thread",
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — threading.Timer is a subclass of Thread defined in Lib/threading.py; it inherits directly from Thread; __bases__[0] is Thread; Thread.__name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra107"]
    - [timer_mro_len_3,
       "Timer.__mro__.__len__",
       [],
       3,
       "threading.Timer.__mro__.__len__() == 3 — Timer inherits from Thread which inherits from object; its MRO is [Timer, Thread, object] with length 3; this is unique among threading classes covered here — Event and Barrier have MRO depth 2; new to extra107"]
    - [timer_name_eq,
       "Timer.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — threading.Timer is a Thread subclass for executing a function after a delay; its __name__ is 'Timer'; str.__eq__('Timer') returns True; new to extra107"]
    - [timer_module_eq,
       "Timer.__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — threading.Timer is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra107"]
    - [timer_run_type_function,
       "Timer.run.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Timer.run.__class__.__name__.__eq__('function') == True — Timer.run is a Python def method overriding Thread.run; accessed unbound from the class it is a plain function object; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra107"]
    - [timer_run_qualname_eq,
       "Timer.run.__qualname__.__eq__",
       ["Timer.run"],
       true,
       "threading.Timer.run.__qualname__.__eq__('Timer.run') == True — Timer.run is defined inside the Timer class; its __qualname__ follows 'ClassName.method_name' pattern and is 'Timer.run'; str.__eq__('Timer.run') returns True; new to extra107"]
    - [event_mro_len_2,
       "Event.__mro__.__len__",
       [],
       2,
       "threading.Event.__mro__.__len__() == 2 — threading.Event inherits directly from object; its MRO is [Event, object] with length 2; contrasts with Timer which has MRO depth 3; new to extra107"]
    - [barrier_mro_len_2,
       "Barrier.__mro__.__len__",
       [],
       2,
       "threading.Barrier.__mro__.__len__() == 2 — threading.Barrier inherits directly from object; its MRO is [Barrier, object] with length 2; contrasts with Timer which has MRO depth 3; new to extra107"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra107
# ---------------------------------------------------------------------------

invariant threading_extra107.event_set_function:
  description: "threading.Event.set.__class__.__name__ == 'function' — Event is a pure-Python class; its methods are function objects; wave 259; new to extra107"
  kind: python_call_eq
  function: Event.set.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra107.barrier_wait_function:
  description: "threading.Barrier.wait.__class__.__name__ == 'function' — Barrier is a pure-Python class; its methods are function objects; wave 259; new to extra107"
  kind: python_call_eq
  function: Barrier.wait.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra107.timer_mro_len:
  description: "threading.Timer.__mro__.__len__() == 3 — Timer subclasses Thread; MRO is [Timer, Thread, object]; unique depth-3 MRO among threading primitives; wave 259; new to extra107"
  kind: python_call_eq
  function: Timer.__mro__.__len__
  args: []
  expected: 3

invariant threading_extra107.timer_run_function:
  description: "threading.Timer.run.__class__.__name__ == 'function' — Timer.run overrides Thread.run as a Python def; unbound it is a function; wave 259; new to extra107"
  kind: python_call_eq
  function: Timer.run.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra107.event_mro_len:
  description: "threading.Event.__mro__.__len__() == 2 — Event inherits directly from object; MRO depth 2; contrast with Timer depth 3; wave 259; new to extra107"
  kind: python_call_eq
  function: Event.__mro__.__len__
  args: []
  expected: 2
