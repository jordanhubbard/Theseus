spec: functools_extra81
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec extends functools_extra80.zspec.zsdl."
    - "This spec covers: functools cached_property __dict__ content + partial method descriptor identity (Wave 242)."
    - "cached_property.__dict__.__contains__('__set_name__') == True — cached_property implements __set_name__ for the descriptor protocol. Verified with Python 3.14.3."
    - "partial.__doc__.__contains__('partial') == True — partial has a C-written docstring containing the word 'partial'. Verified with Python 3.14.3."
    - "partial.__dict__.__contains__('func') == True — func is a member_descriptor on partial class. Verified with Python 3.14.3."
    - "partial.__dict__.__contains__('args') == True — args is a member_descriptor on partial class. Verified with Python 3.14.3."
    - "partial.__dict__.__contains__('keywords') == True — keywords is a member_descriptor on partial class. Verified with Python 3.14.3."
    - "partial.func.__class__.__name__ == 'member_descriptor' — partial.func is a member_descriptor (C slot descriptor). Verified with Python 3.14.3."
    - "partial.args.__class__.__name__ == 'member_descriptor' — partial.args is a member_descriptor (C slot descriptor). Verified with Python 3.14.3."
    - "partial.keywords.__class__.__name__ == 'member_descriptor' — partial.keywords is a member_descriptor (C slot descriptor). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cached_property __dict__ extra content — extra81
#
# Wave 242 theme: cached_property __dict__ content.
#
# functools.cached_property.__dict__.__contains__('__set_name__') == True
#
# No prior functools spec checks cached_property.__dict__.__contains__('__set_name__') via functoolsmore81. New to extra81.
# ---------------------------------------------------------------------------

table functools_extra81.cached_property_dict_set_name:
  description: "cached_property.__dict__.__contains__('__set_name__')==True; wave 242 cached_property __dict__ content; new to extra81"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore81

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_dict_contains_set_name,
       cached_property.__dict__.__contains__,
       ["__set_name__"],
       true,
       "functools.cached_property.__dict__.__contains__('__set_name__') == True — cached_property implements the descriptor protocol's __set_name__ hook so it can record the attribute name on the owning class; mappingproxy.__contains__('__set_name__') returns True; no prior functools spec checks cached_property.__dict__.__contains__('__set_name__') via functoolsmore81; new to extra81"]

# ---------------------------------------------------------------------------
# partial.__doc__ content — extra81
#
# Wave 242 theme: partial docstring contains 'partial'.
#
# functools.partial.__doc__.__contains__('partial') == True
#
# No prior functools spec checks partial.__doc__.__contains__ via functoolsmore81. New to extra81.
# ---------------------------------------------------------------------------

table functools_extra81.partial_doc_content:
  description: "partial.__doc__.__contains__('partial')==True; wave 242 partial docstring content; new to extra81"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore81

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_contains_partial,
       partial.__doc__.__contains__,
       ["partial"],
       true,
       "functools.partial.__doc__.__contains__('partial') == True — partial is a C type defined in Modules/_functoolsmodule.c and its __doc__ attribute holds a C-written docstring; the word 'partial' appears in that docstring; str.__contains__('partial') returns True; no prior functools spec checks partial.__doc__.__contains__ via functoolsmore81; new to extra81"]

# ---------------------------------------------------------------------------
# partial.__dict__ descriptor presence — extra81
#
# Wave 242 theme: partial.__dict__ contains func/args/keywords.
#
# functools.partial.__dict__.__contains__('func')     == True
# functools.partial.__dict__.__contains__('args')     == True
# functools.partial.__dict__.__contains__('keywords') == True
#
# No prior functools spec checks partial.__dict__ descriptor keys via functoolsmore81. New to extra81.
# ---------------------------------------------------------------------------

table functools_extra81.partial_dict_descriptors:
  description: "partial.__dict__.__contains__('func')==True, __contains__('args')==True, __contains__('keywords')==True; wave 242 partial __dict__ content; new to extra81"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore81

  columns: [id, function, args, expected, description]
  rows:
    - [partial_dict_contains_func,
       partial.__dict__.__contains__,
       ["func"],
       true,
       "functools.partial.__dict__.__contains__('func') == True — partial is a C type; its class namespace holds a member_descriptor for the 'func' slot that exposes the underlying callable; mappingproxy.__contains__('func') returns True; no prior functools spec checks partial.__dict__.__contains__('func') via functoolsmore81; new to extra81"]
    - [partial_dict_contains_args,
       partial.__dict__.__contains__,
       ["args"],
       true,
       "functools.partial.__dict__.__contains__('args') == True — partial is a C type; its class namespace holds a member_descriptor for the 'args' slot that exposes the positional arguments tuple; mappingproxy.__contains__('args') returns True; no prior functools spec checks partial.__dict__.__contains__('args') via functoolsmore81; new to extra81"]
    - [partial_dict_contains_keywords,
       partial.__dict__.__contains__,
       ["keywords"],
       true,
       "functools.partial.__dict__.__contains__('keywords') == True — partial is a C type; its class namespace holds a member_descriptor for the 'keywords' slot that exposes the keyword arguments dict; mappingproxy.__contains__('keywords') returns True; no prior functools spec checks partial.__dict__.__contains__('keywords') via functoolsmore81; new to extra81"]

# ---------------------------------------------------------------------------
# partial descriptor class names — extra81
#
# Wave 242 theme: partial.func/args/keywords are member_descriptors.
#
# functools.partial.func.__class__.__name__     == 'member_descriptor'
# functools.partial.args.__class__.__name__     == 'member_descriptor'
# functools.partial.keywords.__class__.__name__ == 'member_descriptor'
#
# No prior functools spec checks partial slot descriptor class names via functoolsmore81. New to extra81.
# ---------------------------------------------------------------------------

table functools_extra81.partial_descriptor_class_names:
  description: "partial.func/__class__.__name__=='member_descriptor', same for args and keywords; wave 242 partial slot descriptor identity; new to extra81"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore81

  columns: [id, function, args, expected, description]
  rows:
    - [partial_func_class_name_eq_member_descriptor,
       partial.func.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.func.__class__.__name__.__eq__('member_descriptor') == True — partial.func is a C-level slot descriptor (member_descriptor) that provides access to the wrapped callable stored in the C struct; its metaclass is member_descriptor_type; __class__.__name__ == 'member_descriptor' (17 chars); str.__eq__('member_descriptor') returns True; no prior functools spec checks partial.func.__class__.__name__ via functoolsmore81; new to extra81"]
    - [partial_args_class_name_eq_member_descriptor,
       partial.args.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.args.__class__.__name__.__eq__('member_descriptor') == True — partial.args is a C-level slot descriptor (member_descriptor) that provides access to the positional args tuple stored in the C struct; __class__.__name__ == 'member_descriptor' (17 chars); str.__eq__('member_descriptor') returns True; no prior functools spec checks partial.args.__class__.__name__ via functoolsmore81; new to extra81"]
    - [partial_keywords_class_name_eq_member_descriptor,
       partial.keywords.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.keywords.__class__.__name__.__eq__('member_descriptor') == True — partial.keywords is a C-level slot descriptor (member_descriptor) that provides access to the keyword args dict stored in the C struct; __class__.__name__ == 'member_descriptor' (17 chars); str.__eq__('member_descriptor') returns True; no prior functools spec checks partial.keywords.__class__.__name__ via functoolsmore81; new to extra81"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra81
# ---------------------------------------------------------------------------

invariant functools_extra81.cached_property_dict_set_name:
  description: "functools.cached_property.__dict__.__contains__('__set_name__') == True — cached_property implements __set_name__; wave 242 cached_property __dict__ content; new to extra81"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__set_name__"]
  expected: true

invariant functools_extra81.partial_doc_contains_partial:
  description: "functools.partial.__doc__.__contains__('partial') == True — partial docstring contains 'partial'; wave 242 partial docstring content; new to extra81"
  kind: python_call_eq
  function: partial.__doc__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra81.partial_dict_contains_func:
  description: "functools.partial.__dict__.__contains__('func') == True — partial class dict contains 'func' member_descriptor; wave 242 partial __dict__ content; new to extra81"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["func"]
  expected: true

invariant functools_extra81.partial_func_class_name:
  description: "functools.partial.func.__class__.__name__.__eq__('member_descriptor') == True — partial.func is a member_descriptor; wave 242 partial slot descriptor identity; new to extra81"
  kind: python_call_eq
  function: partial.func.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra81.partial_keywords_class_name:
  description: "functools.partial.keywords.__class__.__name__.__eq__('member_descriptor') == True — partial.keywords is a member_descriptor; wave 242 partial slot descriptor identity; new to extra81"
  kind: python_call_eq
  function: partial.keywords.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true
