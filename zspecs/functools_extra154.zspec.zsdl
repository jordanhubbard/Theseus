spec: functools_extra154
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partial method qualnames — partial.__new__.__qualname__ 'partial.__new__' len 15, partial.__call__.__qualname__ 'partial.__call__' len 16, partial.__repr__.__qualname__ 'partial.__repr__' len 16, partial.__reduce__.__qualname__ 'partial.__reduce__' len 18; functools.partial.__dict__.__class__.__name__ 'mappingproxy' len 17; functools.partial method __class__.__name__ values (Wave 278)."
    - "functools.partial.__new__.__qualname__ == 'partial.__new__' (len 15); __class__.__name__ == 'builtin_function_or_method'; __name__ == '__new__'. Verified with Python 3.14.3."
    - "functools.partial.__call__.__qualname__ == 'partial.__call__' (len 16); __class__.__name__ == 'wrapper_descriptor'; __name__ == '__call__'. Verified with Python 3.14.3."
    - "functools.partial.__repr__.__qualname__ == 'partial.__repr__' (len 16); __class__.__name__ == 'wrapper_descriptor'; __name__ == '__repr__'. Verified with Python 3.14.3."
    - "functools.partial.__reduce__.__qualname__ == 'partial.__reduce__' (len 18); __class__.__name__ == 'method_descriptor'; __name__ == '__reduce__'. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__class__.__name__ == 'mappingproxy' — the class __dict__ of a C extension type is a mappingproxy. len(functools.partial.__dict__) == 17. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial method qualnames
#
# Wave 278 theme: functools.partial method __qualname__ attributes.
#
# functools.partial.__new__.__qualname__ == 'partial.__new__' (len 15)
# functools.partial.__call__.__qualname__ == 'partial.__call__' (len 16)
# functools.partial.__repr__.__qualname__ == 'partial.__repr__' (len 16)
# functools.partial.__reduce__.__qualname__ == 'partial.__reduce__' (len 18)
#
# Each C extension method on the partial type carries a __qualname__ that
# includes the class prefix 'partial.'. New to extra154.
# ---------------------------------------------------------------------------

table functools_extra154.partial_method_qualnames:
  description: "functools.partial method qualnames: __new__ 'partial.__new__' len 15, __call__ 'partial.__call__' len 16, __repr__ 'partial.__repr__' len 16, __reduce__ 'partial.__reduce__' len 18; wave 278; new to extra154"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspqn154

  columns: [id, function, args, expected, description]
  rows:
    - [partial_new_qualname_eq,
       "partial.__new__.__qualname__.__eq__",
       ["partial.__new__"],
       true,
       "functools.partial.__new__.__qualname__.__eq__('partial.__new__') == True — partial.__new__ is a C builtin_function_or_method; its __qualname__ includes the class prefix 'partial.__new__'; str.__eq__('partial.__new__') returns True; new to extra154"]
    - [partial_new_qualname_len_eq_15,
       "partial.__new__.__qualname__.__len__",
       [],
       15,
       "functools.partial.__new__.__qualname__.__len__() == 15 — __qualname__ is 'partial.__new__' which has 15 characters; len('partial.__new__') == 15; new to extra154"]
    - [partial_call_qualname_eq,
       "partial.__call__.__qualname__.__eq__",
       ["partial.__call__"],
       true,
       "functools.partial.__call__.__qualname__.__eq__('partial.__call__') == True — partial.__call__ is a wrapper_descriptor; its __qualname__ is 'partial.__call__'; str.__eq__('partial.__call__') returns True; new to extra154"]
    - [partial_call_qualname_len_eq_16,
       "partial.__call__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__call__.__qualname__.__len__() == 16 — __qualname__ is 'partial.__call__' which has 16 characters; len('partial.__call__') == 16; new to extra154"]
    - [partial_repr_qualname_eq,
       "partial.__repr__.__qualname__.__eq__",
       ["partial.__repr__"],
       true,
       "functools.partial.__repr__.__qualname__.__eq__('partial.__repr__') == True — partial.__repr__ is a wrapper_descriptor; its __qualname__ is 'partial.__repr__'; str.__eq__('partial.__repr__') returns True; new to extra154"]
    - [partial_repr_qualname_len_eq_16,
       "partial.__repr__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__repr__.__qualname__.__len__() == 16 — __qualname__ is 'partial.__repr__' which has 16 characters; len('partial.__repr__') == 16; new to extra154"]
    - [partial_reduce_qualname_eq,
       "partial.__reduce__.__qualname__.__eq__",
       ["partial.__reduce__"],
       true,
       "functools.partial.__reduce__.__qualname__.__eq__('partial.__reduce__') == True — partial.__reduce__ is a method_descriptor; its __qualname__ is 'partial.__reduce__'; str.__eq__('partial.__reduce__') returns True; new to extra154"]
    - [partial_reduce_qualname_len_eq_18,
       "partial.__reduce__.__qualname__.__len__",
       [],
       18,
       "functools.partial.__reduce__.__qualname__.__len__() == 18 — __qualname__ is 'partial.__reduce__' which has 18 characters; len('partial.__reduce__') == 18; new to extra154"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial method __class__.__name__ values
#
# Wave 278 theme: the C method types used by functools.partial methods.
#
# partial.__new__.__class__.__name__ == 'builtin_function_or_method'
# partial.__call__.__class__.__name__ == 'wrapper_descriptor'
# partial.__repr__.__class__.__name__ == 'wrapper_descriptor'
# partial.__reduce__.__class__.__name__ == 'method_descriptor'
#
# Different C-level slot types result in different wrapper class names.
# New to extra154.
# ---------------------------------------------------------------------------

table functools_extra154.partial_method_classes:
  description: "functools.partial method __class__.__name__: __new__ 'builtin_function_or_method', __call__ 'wrapper_descriptor', __repr__ 'wrapper_descriptor', __reduce__ 'method_descriptor'; wave 278; new to extra154"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspmcls154

  columns: [id, function, args, expected, description]
  rows:
    - [partial_new_class_eq_builtin,
       "partial.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partial.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — partial.__new__ is the C-level tp_new slot exposed as a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra154"]
    - [partial_call_class_eq_wrapper_descriptor,
       "partial.__call__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__call__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__call__ is the C-level tp_call slot exposed as a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__ returns True; new to extra154"]
    - [partial_repr_class_eq_wrapper_descriptor,
       "partial.__repr__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__repr__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial.__repr__ is the C-level tp_repr slot exposed as a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__ returns True; new to extra154"]
    - [partial_reduce_class_eq_method_descriptor,
       "partial.__reduce__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partial.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — partial.__reduce__ is a C-level method defined in _functoolsmodule.c exposed as a method_descriptor; __class__.__name__ is 'method_descriptor'; str.__eq__ returns True; new to extra154"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial.__dict__ — mappingproxy identity
#
# Wave 278 theme: functools.partial.__dict__ is a mappingproxy of len 17.
#
# functools.partial.__dict__.__class__.__name__ == 'mappingproxy'
# len(functools.partial.__dict__) == 17
#
# The class __dict__ of a C extension type is always a mappingproxy (read-only
# view of the type's tp_dict). The partial type has 17 entries in its dict.
# New to extra154.
# ---------------------------------------------------------------------------

table functools_extra154.partial_dict_identity:
  description: "functools.partial.__dict__: mappingproxy, len 17; C extension type class dict is always a mappingproxy; wave 278; new to extra154"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspdct154

  columns: [id, function, args, expected, description]
  rows:
    - [partial_dict_class_eq_mappingproxy,
       "partial.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "functools.partial.__dict__.__class__.__name__.__eq__('mappingproxy') == True — the class __dict__ of a C extension type is a read-only mappingproxy of its internal tp_dict; __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; new to extra154"]
    - [partial_dict_len_eq_17,
       "partial.__dict__.__len__",
       [],
       17,
       "functools.partial.__dict__.__len__() == 17 — functools.partial has 17 entries in its class dict including __new__, __call__, __repr__, __reduce__, func, args, keywords, __doc__, __module__, and other dunder methods; len == 17; verified with Python 3.14.3; new to extra154"]
    - [partial_new_name_eq,
       "partial.__new__.__name__.__eq__",
       ["__new__"],
       true,
       "functools.partial.__new__.__name__.__eq__('__new__') == True — the simple __name__ of the partial.__new__ method is '__new__' (without the class prefix); str.__eq__('__new__') returns True; new to extra154"]
    - [partial_reduce_name_eq,
       "partial.__reduce__.__name__.__eq__",
       ["__reduce__"],
       true,
       "functools.partial.__reduce__.__name__.__eq__('__reduce__') == True — the simple __name__ of the partial.__reduce__ method is '__reduce__'; str.__eq__('__reduce__') returns True; new to extra154"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra154
# ---------------------------------------------------------------------------

invariant functools_extra154.partial_new_qualname_eq:
  description: "functools.partial.__new__.__qualname__ == 'partial.__new__' — C method qualname includes class prefix; wave 278; new to extra154"
  kind: python_call_eq
  function: partial.__new__.__qualname__.__eq__
  args: ["partial.__new__"]
  expected: true

invariant functools_extra154.partial_new_qualname_len:
  description: "len(functools.partial.__new__.__qualname__) == 15 — 'partial.__new__' has 15 characters; wave 278; new to extra154"
  kind: python_call_eq
  function: partial.__new__.__qualname__.__len__
  args: []
  expected: 15

invariant functools_extra154.partial_call_qualname_len:
  description: "len(functools.partial.__call__.__qualname__) == 16 — 'partial.__call__' has 16 characters; wave 278; new to extra154"
  kind: python_call_eq
  function: partial.__call__.__qualname__.__len__
  args: []
  expected: 16

invariant functools_extra154.partial_repr_qualname_len:
  description: "len(functools.partial.__repr__.__qualname__) == 16 — 'partial.__repr__' has 16 characters; wave 278; new to extra154"
  kind: python_call_eq
  function: partial.__repr__.__qualname__.__len__
  args: []
  expected: 16

invariant functools_extra154.partial_reduce_qualname_len:
  description: "len(functools.partial.__reduce__.__qualname__) == 18 — 'partial.__reduce__' has 18 characters; wave 278; new to extra154"
  kind: python_call_eq
  function: partial.__reduce__.__qualname__.__len__
  args: []
  expected: 18

invariant functools_extra154.partial_dict_class_mappingproxy:
  description: "functools.partial.__dict__.__class__.__name__ == 'mappingproxy' — C extension type class dict is a mappingproxy; wave 278; new to extra154"
  kind: python_call_eq
  function: partial.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant functools_extra154.partial_dict_len:
  description: "len(functools.partial.__dict__) == 17 — partial class dict has 17 entries; wave 278; new to extra154"
  kind: python_call_eq
  function: partial.__dict__.__len__
  args: []
  expected: 17

invariant functools_extra154.partial_new_class_builtin:
  description: "functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method' — tp_new slot exposed as builtin; wave 278; new to extra154"
  kind: python_call_eq
  function: partial.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra154.partial_call_class_wrapper_descriptor:
  description: "functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor' — tp_call slot exposed as wrapper_descriptor; wave 278; new to extra154"
  kind: python_call_eq
  function: partial.__call__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant functools_extra154.partial_reduce_class_method_descriptor:
  description: "functools.partial.__reduce__.__class__.__name__ == 'method_descriptor' — C method exposed as method_descriptor; wave 278; new to extra154"
  kind: python_call_eq
  function: partial.__reduce__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
