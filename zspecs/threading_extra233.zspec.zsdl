spec: threading_extra233
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading.Thread method name contracts: start, run, join, is_alive."
    - "threading.Thread.start.__name__ == 'start' (len=5) — Python-level method in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start' — qualified name includes the class prefix 'Thread.'. Verified with Python 3.14.3."
    - "threading.Thread.run.__name__ == 'run' (len=3) — Python-level method in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__ == 'Thread.run' — qualified name includes the class prefix 'Thread.'. Verified with Python 3.14.3."
    - "threading.Thread.join.__name__ == 'join' (len=4) — Python-level method in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join' — qualified name includes the class prefix 'Thread.'. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__name__ == 'is_alive' (len=8) — Python-level method in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' — qualified name includes the class prefix 'Thread.'. Verified with Python 3.14.3."
    - "threading.Thread.__name__ == 'Thread' (len=6) — the Thread class __name__. Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading' — Thread is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread.start and threading.Thread.run method name contracts
#
# Thread.start.__name__ == 'start' (len=5)
# Thread.start.__qualname__ == 'Thread.start'
# Thread.run.__name__ == 'run' (len=3)
# Thread.run.__qualname__ == 'Thread.run'
# Thread.start.__module__ == 'threading'
#
# New to extra233.
# ---------------------------------------------------------------------------

table threading_extra233.thread_start_run_names:
  description: "threading.Thread.start and Thread.run method name contracts: __name__, __qualname__, __module__; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra233startrunid

  columns: [id, function, args, expected, description]
  rows:
    - [start_name_eq,
       Thread.start.__name__.__eq__,
       ["start"],
       true,
       "threading.Thread.start.__name__.__eq__('start') == True — start is a Python-level method in Lib/threading.py that starts a thread's activity; __name__ is 'start' (len=5); new to extra233"]
    - [start_qualname_eq,
       Thread.start.__qualname__.__eq__,
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — start is a method of the Thread class; its __qualname__ carries the class prefix 'Thread.start'; new to extra233"]
    - [start_name_len_5,
       Thread.start.__name__.__len__,
       [],
       5,
       "threading.Thread.start.__name__.__len__() == 5 — 'start' has exactly 5 characters (s-t-a-r-t); str.__len__() returns 5; new to extra233"]
    - [run_name_eq,
       Thread.run.__name__.__eq__,
       ["run"],
       true,
       "threading.Thread.run.__name__.__eq__('run') == True — run is a Python-level method in Lib/threading.py that is invoked in the new thread; __name__ is 'run' (len=3); new to extra233"]
    - [run_qualname_eq,
       Thread.run.__qualname__.__eq__,
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — run is a method of the Thread class; its __qualname__ carries the class prefix 'Thread.run'; new to extra233"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.join and threading.Thread.is_alive method name contracts
#
# Thread.join.__name__ == 'join' (len=4)
# Thread.join.__qualname__ == 'Thread.join'
# Thread.is_alive.__name__ == 'is_alive' (len=8)
# Thread.is_alive.__qualname__ == 'Thread.is_alive'
# Thread.run.__name__.__len__() == 3
#
# New to extra233.
# ---------------------------------------------------------------------------

table threading_extra233.thread_join_isalive_names:
  description: "threading.Thread.join and Thread.is_alive method name contracts: __name__, __qualname__, name lengths; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra233joinaliveid

  columns: [id, function, args, expected, description]
  rows:
    - [join_name_eq,
       Thread.join.__name__.__eq__,
       ["join"],
       true,
       "threading.Thread.join.__name__.__eq__('join') == True — join is a Python-level method in Lib/threading.py that waits until the thread finishes; __name__ is 'join' (len=4); new to extra233"]
    - [join_qualname_eq,
       Thread.join.__qualname__.__eq__,
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — join is a method of the Thread class; its __qualname__ carries the class prefix 'Thread.join'; new to extra233"]
    - [join_name_len_4,
       Thread.join.__name__.__len__,
       [],
       4,
       "threading.Thread.join.__name__.__len__() == 4 — 'join' has exactly 4 characters (j-o-i-n); str.__len__() returns 4; new to extra233"]
    - [is_alive_name_eq,
       Thread.is_alive.__name__.__eq__,
       ["is_alive"],
       true,
       "threading.Thread.is_alive.__name__.__eq__('is_alive') == True — is_alive is a Python-level method in Lib/threading.py that returns True while the thread is alive; __name__ is 'is_alive' (len=8); new to extra233"]
    - [is_alive_qualname_eq,
       Thread.is_alive.__qualname__.__eq__,
       ["Thread.is_alive"],
       true,
       "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True — is_alive is a method of the Thread class; its __qualname__ carries the class prefix 'Thread.is_alive'; new to extra233"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread class identity and method name lengths
#
# Thread.__name__ == 'Thread' (len=6)
# Thread.__module__ == 'threading'
# Thread.__qualname__ == 'Thread'
# Thread.is_alive.__name__.__len__() == 8
# Thread.run.__name__.__len__() == 3
#
# New to extra233.
# ---------------------------------------------------------------------------

table threading_extra233.thread_class_identity:
  description: "threading.Thread class identity and method name length contracts; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra233classid

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_eq,
       Thread.__name__.__eq__,
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — Thread is the main class in Lib/threading.py for managing threads; __name__ is 'Thread' (len=6); new to extra233"]
    - [thread_name_len_6,
       Thread.__name__.__len__,
       [],
       6,
       "threading.Thread.__name__.__len__() == 6 — 'Thread' has exactly 6 characters (T-h-r-e-a-d); str.__len__() returns 6; new to extra233"]
    - [thread_module_eq,
       Thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in Lib/threading.py; __module__ is 'threading'; new to extra233"]
    - [is_alive_name_len_8,
       Thread.is_alive.__name__.__len__,
       [],
       8,
       "threading.Thread.is_alive.__name__.__len__() == 8 — 'is_alive' has exactly 8 characters (i-s-_-a-l-i-v-e); str.__len__() returns 8; new to extra233"]
    - [run_name_len_3,
       Thread.run.__name__.__len__,
       [],
       3,
       "threading.Thread.run.__name__.__len__() == 3 — 'run' has exactly 3 characters (r-u-n); str.__len__() returns 3; new to extra233"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra233
# ---------------------------------------------------------------------------

invariant threading_extra233.start_name_eq:
  description: "threading.Thread.start.__name__ == 'start'; new to extra233"
  kind: python_call_eq
  function: Thread.start.__name__.__eq__
  args: ["start"]
  expected: true

invariant threading_extra233.start_qualname_eq:
  description: "threading.Thread.start.__qualname__ == 'Thread.start'; new to extra233"
  kind: python_call_eq
  function: Thread.start.__qualname__.__eq__
  args: ["Thread.start"]
  expected: true

invariant threading_extra233.start_name_len_5:
  description: "threading.Thread.start.__name__.__len__() == 5 — 'start' has 5 characters; new to extra233"
  kind: python_call_eq
  function: Thread.start.__name__.__len__
  args: []
  expected: 5

invariant threading_extra233.run_name_eq:
  description: "threading.Thread.run.__name__ == 'run'; new to extra233"
  kind: python_call_eq
  function: Thread.run.__name__.__eq__
  args: ["run"]
  expected: true

invariant threading_extra233.run_qualname_eq:
  description: "threading.Thread.run.__qualname__ == 'Thread.run'; new to extra233"
  kind: python_call_eq
  function: Thread.run.__qualname__.__eq__
  args: ["Thread.run"]
  expected: true

invariant threading_extra233.run_name_len_3:
  description: "threading.Thread.run.__name__.__len__() == 3 — 'run' has 3 characters; new to extra233"
  kind: python_call_eq
  function: Thread.run.__name__.__len__
  args: []
  expected: 3

invariant threading_extra233.join_name_eq:
  description: "threading.Thread.join.__name__ == 'join'; new to extra233"
  kind: python_call_eq
  function: Thread.join.__name__.__eq__
  args: ["join"]
  expected: true

invariant threading_extra233.join_qualname_eq:
  description: "threading.Thread.join.__qualname__ == 'Thread.join'; new to extra233"
  kind: python_call_eq
  function: Thread.join.__qualname__.__eq__
  args: ["Thread.join"]
  expected: true

invariant threading_extra233.join_name_len_4:
  description: "threading.Thread.join.__name__.__len__() == 4 — 'join' has 4 characters; new to extra233"
  kind: python_call_eq
  function: Thread.join.__name__.__len__
  args: []
  expected: 4

invariant threading_extra233.is_alive_name_eq:
  description: "threading.Thread.is_alive.__name__ == 'is_alive'; new to extra233"
  kind: python_call_eq
  function: Thread.is_alive.__name__.__eq__
  args: ["is_alive"]
  expected: true

invariant threading_extra233.is_alive_qualname_eq:
  description: "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive'; new to extra233"
  kind: python_call_eq
  function: Thread.is_alive.__qualname__.__eq__
  args: ["Thread.is_alive"]
  expected: true

invariant threading_extra233.is_alive_name_len_8:
  description: "threading.Thread.is_alive.__name__.__len__() == 8 — 'is_alive' has 8 characters; new to extra233"
  kind: python_call_eq
  function: Thread.is_alive.__name__.__len__
  args: []
  expected: 8

invariant threading_extra233.thread_name_eq:
  description: "threading.Thread.__name__ == 'Thread' (len=6); new to extra233"
  kind: python_call_eq
  function: Thread.__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra233.thread_module_eq:
  description: "threading.Thread.__module__ == 'threading'; new to extra233"
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true
