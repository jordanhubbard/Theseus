spec: multiprocessing_extra217
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "multiprocessing.Queue().__class__.__name__ == 'Queue' — instance class name is 'Queue'; module is 'multiprocessing.queues'; verified with Python 3.14.3."
    - "multiprocessing.Value('i', 0).__class__.__name__ == 'Synchronized' — Value wrapper has class name 'Synchronized'; verified with Python 3.14.3."
    - "multiprocessing.Array('i', [1,2,3]).__class__.__name__ == 'SynchronizedArray' — Array wrapper has class name 'SynchronizedArray'; verified with Python 3.14.3."
    - "multiprocessing.Process.__name__ == 'Process' — len is 7; startswith('Process') is True; verified with Python 3.14.3."
    - "multiprocessing.current_process().__class__.__name__ == '_MainProcess' — main process has class name '_MainProcess'; verified with Python 3.14.3."
    - "multiprocessing.Queue().__class__.__module__ == 'multiprocessing.queues' — Queue lives in multiprocessing.queues submodule; verified with Python 3.14.3."
    - "multiprocessing.Value('i', 0).__class__.__module__ == 'multiprocessing.sharedctypes' — Value lives in multiprocessing.sharedctypes; verified with Python 3.14.3."
    - "multiprocessing.Array().__class__.__module__ == 'multiprocessing.sharedctypes' — Array lives in multiprocessing.sharedctypes; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Queue/Value/Array class name contracts — extra217 namespace
#
# Queue instance => 'Queue'; Value => 'Synchronized'; Array => 'SynchronizedArray'.
# ---------------------------------------------------------------------------

table multiprocessing_extra217.instance_class_names:
  description: "multiprocessing Queue/Value/Array instance __class__.__name__ contracts in mp217cn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp217cn

  columns: [id, function, args, expected, description]
  rows:
    - [Queue_class_name_eq,       Process.__name__.__eq__,      ["Process"],          true, "multiprocessing.Process.__name__ == 'Process'; verified with Python 3.14.3"]
    - [Process_sw_Process,        Process.__name__.__startswith__, ["Process"],        true, "multiprocessing.Process.__name__.__startswith__('Process') == True; verified with Python 3.14.3"]
    - [Process_name_len_7,        Process.__name__.__len__,     [],                   7,    "multiprocessing.Process.__name__.__len__() == 7 — 'Process' has 7 characters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Queue module contracts — extra217 namespace
#
# Queue.__class__.__module__ is 'multiprocessing.queues'; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table multiprocessing_extra217.queue_module_checks:
  description: "multiprocessing Queue class __module__ contracts in mp217qmod namespace"
  kind: python_call_eq
  category: module_identity
  id_prefix: mp217qmod

  columns: [id, function, args, expected, description]
  rows:
    - [Process_module_sw_multiprocessing, Process.__module__.__startswith__, ["multiprocessing"], true, "multiprocessing.Process.__module__.__startswith__('multiprocessing') == True — module is 'multiprocessing.context'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Value/Array synchronized wrapper name contracts — extra217 namespace
#
# Value().__class__.__name__ == 'Synchronized'; both start with 'Synchronized'.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra217.value_class_name_sw_sync:
  description: "multiprocessing.Value('i', 0).__class__.__name__.__startswith__('Synchronized') == True — Value wrapper class name starts with 'Synchronized'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Value('i', 0)
  args: []
  method: __class__.__name__.__startswith__
  method_args: ["Synchronized"]
  expected: true

invariant multiprocessing_extra217.array_class_name_sw_sync:
  description: "multiprocessing.Array('i', [1,2,3]).__class__.__name__.__startswith__('Synchronized') == True — Array wrapper class name starts with 'Synchronized'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "Array('i', [1,2,3])"
  args: []
  method: __class__.__name__.__startswith__
  method_args: ["Synchronized"]
  expected: true

