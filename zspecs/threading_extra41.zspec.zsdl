spec: threading_extra41
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra40.zspec.zsdl."
    - "Prior specs covered: Thread/__name__/__qualname__.__len__()==6; Thread method __qualname__.__len__() for start(12)/run(10)/join(11)/is_alive(15)/__init__(15)/__repr__(15)/getName(14)/setName(14); Event method __qualname__.__len__() for set(9)/clear(11)/wait(10)/is_set(12); Condition method __qualname__.__len__(); Semaphore/__name__/__qualname__.__len__()==9; Barrier/__name__/__qualname__.__len__()==7; Timer/__name__/__qualname__.__len__()==5; threading.local/__name__/__qualname__.__len__()==6; Lock/__name__/__len__()==4 and __module__.__len__()==9; RLock/__dict__.__class__.__name__.__len__()==12; sync primitive __class__.__name__.__len__() instances; current_thread/__name__(14)/main_thread/__name__(11); threading.__all__.__len__()==28; TIMEOUT_MAX; active_count/enumerate/settrace/setprofile/stack_size __name__ lengths; Thread property __class__.__name__.__len__() for daemon/name/ident/native_id; pure-Python class __module__.__len__()==9 for Thread/Semaphore/Condition/Barrier/Event/Timer; threading.local.__module__.__len__()==7; sync primitive __doc__.__len__() for Condition(338)/Semaphore(307)/Thread(247)/Event(226); Thread.start/run/join __qualname__.__len__(); Event.set/wait/clear/is_set __qualname__.__len__(); Barrier.__name__/'Barrier'; Barrier.__module__/'threading'."
    - "This spec covers: Condition.__name__ == 'Condition'; Condition.__module__ == 'threading'; Condition.wait.__qualname__.__len__() == 14; Condition.notify.__qualname__.__len__() == 16; Condition.notify_all.__qualname__.__len__() == 20; Condition.__enter__.__qualname__.__len__() == 19; Semaphore.__name__ == 'Semaphore'; Semaphore.__module__ == 'threading'; threading.RLock.__name__ == 'RLock' (RLock is a factory function, not a class; its __name__ is 'RLock'); threading.RLock.__module__ == 'threading'."
    - "Key findings: threading.Condition.__name__ is 'Condition' (9 chars) and threading.Condition.__module__ is 'threading' (9 chars) — a pure-Python class in Lib/threading.py. Condition does NOT have class-level 'acquire' or 'release' attributes — these are delegated at instance creation time to the underlying lock (defaulting to RLock), so Condition.acquire raises AttributeError while cond_instance.acquire.__qualname__ is 'RLock.acquire' (13 chars) reflecting the underlying lock type. The class-level Condition methods with __qualname__ accessible are: wait ('Condition.wait', 14 chars), notify ('Condition.notify', 16 chars), notify_all ('Condition.notify_all', 20 chars), __enter__ ('Condition.__enter__', 19 chars), __exit__ ('Condition.__exit__', 18 chars). threading.Semaphore.__name__ is 'Semaphore' (9 chars) and threading.Semaphore.__module__ is 'threading' (9 chars). threading.RLock is a factory function (not a class) that returns a _thread.RLock C-extension object; threading.RLock.__name__ is 'RLock' and threading.RLock.__module__ is 'threading'. No prior threading spec records these equality invariants in the extra41 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Condition identity metadata — extra41 namespace
#
# threading.Condition.__name__ is 'Condition' (9 chars) and threading.Condition.
# __module__ is 'threading' (9 chars). Condition is a pure-Python class defined
# in Lib/threading.py. Both __name__ and __module__ have 9 chars, matching the
# __name__/__module__ lengths of threading.Semaphore. Prior specs recorded
# __module__.__len__()==9 for Condition but not the string equality invariants.
# These two equality invariants are new to the extra41 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra41.Condition_name:
  description: "threading.Condition.__name__ == 'Condition' — pure-Python context-manager condition variable; 9-char name; same length as __module__ ('threading')"
  category: identity
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant threading_extra41.Condition_module:
  description: "threading.Condition.__module__ == 'threading' — pure-Python class defined in Lib/threading.py; 9-char module name; same length as Condition.__name__"
  category: module_metadata
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# threading.Condition class-level method __qualname__.__len__() — extra41 namespace
#
# threading.Condition defines wait, notify, notify_all, __enter__, and __exit__
# as class-level methods. Note: Condition does NOT expose acquire or release as
# class-level attributes — these are delegated at instance creation time to the
# underlying lock object (defaulting to RLock), so accessing Condition.acquire
# raises AttributeError. The accessible class-level method qualnames are:
#   Condition.wait          -> 'Condition.wait'          (14 chars = 9+1+4)
#   Condition.notify        -> 'Condition.notify'        (16 chars = 9+1+6)
#   Condition.notify_all    -> 'Condition.notify_all'    (20 chars = 9+1+10)
#   Condition.__enter__     -> 'Condition.__enter__'     (19 chars = 9+1+9)
# All follow the pattern 'Condition.' (10-char prefix) + method name length.
# Prior specs recorded Condition method __qualname__.__len__() values for other
# namespaces; these four are new to the extra41 namespace.
# ---------------------------------------------------------------------------

table threading_extra41.condition_method_qualname_lengths:
  description: "threading.Condition class-level method __qualname__.__len__(): wait(14), notify(16), __enter__(19), notify_all(20)"
  kind: python_call_eq
  category: string_properties
  id_prefix: condmqlen41

  columns: [id, function, args, expected, description]
  rows:
    - [wait,
       Condition.wait.__qualname__.__len__,
       [],
       14,
       "len(threading.Condition.wait.__qualname__) == 14 — 'Condition.wait' (10-char prefix 'Condition.' + 4-char 'wait'); same length as Thread.join.__qualname__ (11) + 3"]
    - [notify,
       Condition.notify.__qualname__.__len__,
       [],
       16,
       "len(threading.Condition.notify.__qualname__) == 16 — 'Condition.notify' (10-char prefix 'Condition.' + 6-char 'notify')"]
    - [enter,
       Condition.__enter__.__qualname__.__len__,
       [],
       19,
       "len(threading.Condition.__enter__.__qualname__) == 19 — 'Condition.__enter__' (10-char prefix 'Condition.' + 9-char '__enter__'); context manager entry point"]
    - [notify_all,
       Condition.notify_all.__qualname__.__len__,
       [],
       20,
       "len(threading.Condition.notify_all.__qualname__) == 20 — 'Condition.notify_all' (10-char prefix 'Condition.' + 10-char 'notify_all'); longest Condition method qualname"]

# ---------------------------------------------------------------------------
# threading.Semaphore identity metadata — extra41 namespace
#
# threading.Semaphore.__name__ is 'Semaphore' (9 chars) and threading.Semaphore.
# __module__ is 'threading' (9 chars). Semaphore is a pure-Python class defined
# in Lib/threading.py. Both __name__ (9 chars) and __module__ (9 chars) have the
# same length, mirroring the pattern seen in Condition. Prior specs recorded
# __module__.__len__()==9 for Semaphore and __name__/__qualname__.__len__()==9,
# but not the string equality invariants. These two equality invariants are new
# to the extra41 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra41.Semaphore_name:
  description: "threading.Semaphore.__name__ == 'Semaphore' — pure-Python counting semaphore; 9-char name; same length as __module__ ('threading') and Condition.__name__"
  category: identity
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra41.Semaphore_module:
  description: "threading.Semaphore.__module__ == 'threading' — pure-Python class defined in Lib/threading.py; 9-char module name; same length as Semaphore.__name__"
  category: module_metadata
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# threading.RLock identity metadata — extra41 namespace
#
# threading.RLock is a factory function (not a class) defined in Lib/threading.py
# that returns a _thread.RLock C-extension object. threading.RLock.__name__ is
# 'RLock' (5 chars) and threading.RLock.__module__ is 'threading' (9 chars).
# The actual RLock type returned is _thread.RLock with __name__ 'RLock' as well,
# but the factory function itself is the object accessible as threading.RLock.
# Prior specs recorded RLock/__dict__.__class__.__name__.__len__()==12 for the
# instance dict type, but not the factory function's __name__ or __module__
# string equality invariants. These two equality invariants are new to the
# extra41 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra41.RLock_name:
  description: "threading.RLock.__name__ == 'RLock' — factory function (not a class) in Lib/threading.py; returns a _thread.RLock C-extension object; 5-char name"
  category: identity
  kind: python_call_eq
  function: RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra41.RLock_module:
  description: "threading.RLock.__module__ == 'threading' — pure-Python factory function defined in Lib/threading.py; 9-char module name; same as Condition.__module__ and Semaphore.__module__"
  category: module_metadata
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true
