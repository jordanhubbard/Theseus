spec: concurrent_futures_extra44
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra43.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens for all methods, class __dict__.__class__.__name__.__len__() tables, as_completed/wait __module__.__len__(), __all__.__len__()==14, __mro__.__len__() tables, __bases__[0].__name__.__len__() for all classes, Executor context manager qualname lens, wait sentinel string lengths, class qualname lengths, executor __init__ qualname lengths, map/__qualname__.__len__() for both executors, Future method __name__/__qualname__.__len__() tables, ThreadPoolExecutor submit/shutdown __name__/__qualname__.__len__() tables, InvalidStateError/__name__.__len__()==17, CancelledError/__qualname__.__len__()==14, BrokenExecutor/__name__/__qualname__.__len__()==14, BrokenExecutor/__module__.__len__()==24, CancelledError/__module__.__len__()==24, TimeoutError/__name__/__module__.__len__(), concurrent.futures.__package__.__len__()==18, ThreadPoolExecutor/__name__=='ThreadPoolExecutor', ProcessPoolExecutor/__name__=='ProcessPoolExecutor', executor __module__ string equality, wait/__name__=='wait', function __module__ string equality, Executor/__name__=='Executor'/__module__==concurrent.futures._base, Executor map/submit qualname lengths, InvalidStateError/BrokenExecutor __name__/__module__ string equality, ProcessPoolExecutor/ThreadPoolExecutor/__bases__[0].__name__=='Executor', Future/__bases__[0].__name__=='object', exception MRO depths, ProcessPoolExecutor/ThreadPoolExecutor/__mro__.__len__()==3, Future/__mro__.__len__()==2, Executor/__mro__.__len__()==2, ThreadPoolExecutor/__qualname__=='ThreadPoolExecutor', ProcessPoolExecutor/__qualname__=='ProcessPoolExecutor', Future/__qualname__=='Future', Executor/__qualname__=='Executor', CancelledError/__qualname__=='CancelledError', BrokenExecutor/__qualname__=='BrokenExecutor', all class __qualname__.__len__() tables (extra41), InvalidStateError/__qualname__=='InvalidStateError', TimeoutError/__qualname__=='TimeoutError', ThreadPoolExecutor/ProcessPoolExecutor/InvalidStateError/TimeoutError __module__.__len__(), module string equality for thread/process/builtins modules (extra42), Future method __module__ string equality and __module__.__len__()==24, Executor.map __module__ string equality and length (extra43)."
    - "This spec covers: ThreadPoolExecutor/__class__.__name__=='type'; ProcessPoolExecutor/__class__.__name__=='type'; Future/__class__.__name__=='type'; Executor/__class__.__name__=='type'; wait/__class__.__name__=='function'; as_completed/__class__.__name__=='function'; CancelledError/__class__.__name__=='type'; BrokenExecutor/__class__.__name__=='type'; class __class__.__name__.__len__()==4 for all six classes; function __class__.__name__.__len__()==8 for both functions."
    - "concurrent.futures.ThreadPoolExecutor.__class__.__name__ == 'type'. ThreadPoolExecutor is a plain Python class in concurrent.futures.thread; its metaclass is the built-in 'type'. __class__.__name__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__class__.__name__ == 'type'. ProcessPoolExecutor is a plain Python class in concurrent.futures.process; its metaclass is the built-in 'type'. __class__.__name__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "concurrent.futures.Future.__class__.__name__ == 'type'. Future is a plain Python class in concurrent.futures._base; its metaclass is the built-in 'type'. __class__.__name__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "concurrent.futures.Executor.__class__.__name__ == 'type'. Executor is the abstract base class; its metaclass is the built-in 'type'. __class__.__name__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "concurrent.futures.wait.__class__.__name__ == 'function'. wait is a plain Python function in _base.py; its __class__.__name__ == 'function' (8 chars). Verified with Python 3.14.3."
    - "concurrent.futures.as_completed.__class__.__name__ == 'function'. as_completed is a plain Python generator function in _base.py; its __class__.__name__ == 'function' (8 chars). Verified with Python 3.14.3."
    - "concurrent.futures.CancelledError.__class__.__name__ == 'type'. CancelledError is a class (exception type); its metaclass is the built-in 'type'. __class__.__name__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "concurrent.futures.BrokenExecutor.__class__.__name__ == 'type'. BrokenExecutor is a class (exception type); its metaclass is the built-in 'type'. __class__.__name__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "All six concurrent.futures classes (ThreadPoolExecutor, ProcessPoolExecutor, Future, Executor, CancelledError, BrokenExecutor) share __class__.__name__ == 'type' (4 chars). Both functions (wait, as_completed) share __class__.__name__ == 'function' (8 chars). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures class __class__.__name__ string equality — extra44
#
# All six concurrent.futures classes are instances of the built-in 'type':
#   ThreadPoolExecutor.__class__.__name__ == 'type'
#   ProcessPoolExecutor.__class__.__name__ == 'type'
#   Future.__class__.__name__             == 'type'
#   Executor.__class__.__name__           == 'type'
#   CancelledError.__class__.__name__     == 'type'
#   BrokenExecutor.__class__.__name__     == 'type'
# Prior specs captured __name__/__module__/__qualname__ string equality for these
# classes. Extra44 captures the metaclass identity via __class__.__name__ for
# the first time, showing that all use the standard 'type' metaclass.
# ---------------------------------------------------------------------------

table concurrent_futures_extra44.class_metaclass_name_eq:
  description: "concurrent.futures class __class__.__name__ string equality in extra44 namespace — six classes all have metaclass 'type'"
  kind: python_call_eq
  category: class_names
  id_prefix: cfClsMetaNameEq44

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__class__.__name__.__eq__,  ["type"], true, "ThreadPoolExecutor.__class__.__name__ == 'type' — plain Python class in thread.py; metaclass is built-in type (4 chars)"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__class__.__name__.__eq__, ["type"], true, "ProcessPoolExecutor.__class__.__name__ == 'type' — plain Python class in process.py; metaclass is built-in type (4 chars)"]
    - [Future,              Future.__class__.__name__.__eq__,              ["type"], true, "Future.__class__.__name__ == 'type' — plain Python class in _base.py; metaclass is built-in type (4 chars)"]
    - [Executor,            Executor.__class__.__name__.__eq__,            ["type"], true, "Executor.__class__.__name__ == 'type' — abstract base class in _base.py; metaclass is built-in type (4 chars)"]
    - [CancelledError,      CancelledError.__class__.__name__.__eq__,      ["type"], true, "CancelledError.__class__.__name__ == 'type' — exception class; metaclass is built-in type (4 chars)"]
    - [BrokenExecutor,      BrokenExecutor.__class__.__name__.__eq__,      ["type"], true, "BrokenExecutor.__class__.__name__ == 'type' — exception class; metaclass is built-in type (4 chars)"]

# ---------------------------------------------------------------------------
# concurrent.futures function __class__.__name__ string equality — extra44
#
# Both module-level functions have __class__.__name__ == 'function':
#   wait.__class__.__name__         == 'function'
#   as_completed.__class__.__name__ == 'function'
# wait is a regular function; as_completed is a generator function.
# Both are instances of the built-in 'function' type.
# Prior specs captured __name__/__module__/__qualname__ for these functions.
# Extra44 captures the __class__.__name__ identity.
# ---------------------------------------------------------------------------

table concurrent_futures_extra44.function_class_name_eq:
  description: "concurrent.futures function __class__.__name__ string equality in extra44 namespace — wait and as_completed are both 'function'"
  kind: python_call_eq
  category: class_names
  id_prefix: cfFuncClsNameEq44

  columns: [id, function, args, expected, description]
  rows:
    - [wait,         wait.__class__.__name__.__eq__,         ["function"], true, "wait.__class__.__name__ == 'function' — plain Python function in _base.py (8 chars)"]
    - [as_completed, as_completed.__class__.__name__.__eq__, ["function"], true, "as_completed.__class__.__name__ == 'function' — generator function in _base.py (8 chars)"]

# ---------------------------------------------------------------------------
# concurrent.futures class and function __class__.__name__.__len__() — extra44
#
# All six classes share __class__.__name__.__len__() == 4 ('type'):
#   ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor/CancelledError/BrokenExecutor == 4
# Both functions share __class__.__name__.__len__() == 8 ('function'):
#   wait/as_completed == 8
# ---------------------------------------------------------------------------

table concurrent_futures_extra44.class_metaclass_name_lengths:
  description: "concurrent.futures class and function __class__.__name__.__len__() in extra44 namespace — classes == 4, functions == 8"
  kind: python_call_eq
  category: class_names
  id_prefix: cfClsMetaNameLen44

  columns: [id, function, args, expected, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__class__.__name__.__len__,  [], 4, "ThreadPoolExecutor.__class__.__name__.__len__() == 4 — 'type' has 4 characters"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__class__.__name__.__len__, [], 4, "ProcessPoolExecutor.__class__.__name__.__len__() == 4 — 'type' has 4 characters"]
    - [Future,              Future.__class__.__name__.__len__,              [], 4, "Future.__class__.__name__.__len__() == 4 — 'type' has 4 characters"]
    - [Executor,            Executor.__class__.__name__.__len__,            [], 4, "Executor.__class__.__name__.__len__() == 4 — 'type' has 4 characters"]
    - [CancelledError,      CancelledError.__class__.__name__.__len__,      [], 4, "CancelledError.__class__.__name__.__len__() == 4 — 'type' has 4 characters"]
    - [BrokenExecutor,      BrokenExecutor.__class__.__name__.__len__,      [], 4, "BrokenExecutor.__class__.__name__.__len__() == 4 — 'type' has 4 characters"]
    - [wait,                wait.__class__.__name__.__len__,                [], 8, "wait.__class__.__name__.__len__() == 8 — 'function' has 8 characters"]
    - [as_completed,        as_completed.__class__.__name__.__len__,        [], 8, "as_completed.__class__.__name__.__len__() == 8 — 'function' has 8 characters"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra44
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra44.ThreadPoolExecutor_class_name_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__class__.__name__ == 'type' — plain Python class in thread.py; metaclass is built-in type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra44.ProcessPoolExecutor_class_name_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__class__.__name__ == 'type' — plain Python class in process.py; metaclass is built-in type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: ProcessPoolExecutor.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra44.Future_class_name_eq:
  description: "concurrent.futures.Future.__class__.__name__ == 'type' — plain Python class in _base.py; metaclass is built-in type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Future.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra44.Executor_class_name_eq:
  description: "concurrent.futures.Executor.__class__.__name__ == 'type' — abstract base class in _base.py; metaclass is built-in type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: Executor.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra44.wait_class_name_eq:
  description: "concurrent.futures.wait.__class__.__name__ == 'function' — plain Python function in _base.py; __class__.__name__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: wait.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant concurrent_futures_extra44.as_completed_class_name_eq:
  description: "concurrent.futures.as_completed.__class__.__name__ == 'function' — generator function in _base.py; __class__.__name__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: as_completed.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant concurrent_futures_extra44.CancelledError_class_name_eq:
  description: "concurrent.futures.CancelledError.__class__.__name__ == 'type' — exception class; metaclass is built-in type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: CancelledError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra44.BrokenExecutor_class_name_eq:
  description: "concurrent.futures.BrokenExecutor.__class__.__name__ == 'type' — exception class; metaclass is built-in type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: BrokenExecutor.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant concurrent_futures_extra44.ThreadPoolExecutor_class_name_len:
  description: "concurrent.futures.ThreadPoolExecutor.__class__.__name__.__len__() == 4 — 'type' has 4 characters"
  category: class_names
  kind: python_call_eq
  function: ThreadPoolExecutor.__class__.__name__.__len__
  args: []
  expected: 4

invariant concurrent_futures_extra44.wait_class_name_len:
  description: "concurrent.futures.wait.__class__.__name__.__len__() == 8 — 'function' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: wait.__class__.__name__.__len__
  args: []
  expected: 8

invariant concurrent_futures_extra44.as_completed_class_name_len:
  description: "concurrent.futures.as_completed.__class__.__name__.__len__() == 8 — 'function' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: as_completed.__class__.__name__.__len__
  args: []
  expected: 8
