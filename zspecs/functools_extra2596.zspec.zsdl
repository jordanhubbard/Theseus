spec: functools_extra2596
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2596 (_extra2596): __get__, __set__, __delete__ descriptor-protocol dict-presence checks for functools types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "functools.partial is a C extension type; it defines __get__ (non-data descriptor) but NOT __set__ or __delete__ in its own __dict__."
    - "functools.partialmethod is a pure-Python class; it defines __get__ (non-data descriptor) but NOT __set__ or __delete__ in its own __dict__."
    - "functools.cached_property is a pure-Python descriptor; it defines __get__ (non-data descriptor) but NOT __set__ or __delete__ in its own __dict__."
    - "functools.singledispatchmethod is a pure-Python descriptor; it defines __get__ (non-data descriptor) but NOT __set__ or __delete__ in its own __dict__."
    - "Data descriptors define both __get__ and __set__ (and/or __delete__); none of these functools types qualify as data descriptors."
    - "Non-data descriptors define __get__ only; partial, partialmethod, cached_property, and singledispatchmethod are all non-data descriptors."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __get__ dict-presence for functools types
#
# partial, partialmethod, cached_property, and singledispatchmethod all
# define __get__ in their own __dict__, making them non-data descriptors.
# A non-data descriptor defines __get__ but neither __set__ nor __delete__.
# ---------------------------------------------------------------------------

table functools_extra2596.get_protocol:
  description: "functools types __get__ dict-presence — partial/partialmethod/cached_property/singledispatchmethod are non-data descriptors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2596

  columns: [id, function, args, expected]
  rows:
    - ["ft2596001", "functools.partial.__dict__.__contains__", ["__get__"], true]
    - ["ft2596002", "functools.partialmethod.__dict__.__contains__", ["__get__"], true]
    - ["ft2596003", "functools.cached_property.__dict__.__contains__", ["__get__"], true]
    - ["ft2596004", "functools.singledispatchmethod.__dict__.__contains__", ["__get__"], true]

# ---------------------------------------------------------------------------
# Table 2: __set__ dict-presence for functools types
#
# None of partial, partialmethod, cached_property, or singledispatchmethod
# define __set__ in their own __dict__. The absence of __set__ (combined
# with the presence of __get__) confirms these are non-data descriptors,
# not data descriptors. Data descriptors take attribute-lookup precedence
# over instance __dict__; non-data descriptors do not.
# ---------------------------------------------------------------------------

table functools_extra2596.set_protocol:
  description: "functools types __set__ dict-presence — all False, confirming non-data descriptor status"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2596

  columns: [id, function, args, expected]
  rows:
    - ["ft2596005", "functools.partial.__dict__.__contains__", ["__set__"], false]
    - ["ft2596006", "functools.partialmethod.__dict__.__contains__", ["__set__"], false]
    - ["ft2596007", "functools.cached_property.__dict__.__contains__", ["__set__"], false]
    - ["ft2596008", "functools.singledispatchmethod.__dict__.__contains__", ["__set__"], false]

# ---------------------------------------------------------------------------
# Table 3: __delete__ dict-presence for functools types
#
# None of the four functools descriptor types define __delete__ in their
# own __dict__. Along with the absence of __set__, this confirms all four
# are strictly non-data descriptors (they bind via __get__ only, without
# intercepting attribute deletion).
# ---------------------------------------------------------------------------

table functools_extra2596.delete_protocol:
  description: "functools types __delete__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2596

  columns: [id, function, args, expected]
  rows:
    - ["ft2596009", "functools.partial.__dict__.__contains__", ["__delete__"], false]
    - ["ft2596010", "functools.partialmethod.__dict__.__contains__", ["__delete__"], false]
    - ["ft2596011", "functools.cached_property.__dict__.__contains__", ["__delete__"], false]
    - ["ft2596012", "functools.singledispatchmethod.__dict__.__contains__", ["__delete__"], false]

# ---------------------------------------------------------------------------
# Table 4: Cross-check — descriptor classification for all four types
#
# Confirms the full descriptor protocol picture for each type:
#   - __get__ present  → qualifies as a descriptor at all
#   - __set__ absent   → not a data descriptor
#   - __delete__ absent → not a data descriptor
# cached_property is the canonical stdlib non-data descriptor example;
# partial and partialmethod join it in this category.
# singledispatchmethod rounds out the four non-data descriptors in functools.
# ---------------------------------------------------------------------------

table functools_extra2596.descriptor_classification:
  description: "Full descriptor protocol cross-check for functools non-data descriptors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2596

  columns: [id, function, args, expected]
  rows:
    - ["ft2596013", "functools.cached_property.__dict__.__contains__", ["__get__"], true]
    - ["ft2596014", "functools.cached_property.__dict__.__contains__", ["__set__"], false]
    - ["ft2596015", "functools.cached_property.__dict__.__contains__", ["__delete__"], false]
    - ["ft2596016", "functools.singledispatchmethod.__dict__.__contains__", ["__get__"], true]
    - ["ft2596017", "functools.singledispatchmethod.__dict__.__contains__", ["__set__"], false]
    - ["ft2596018", "functools.singledispatchmethod.__dict__.__contains__", ["__delete__"], false]
    - ["ft2596019", "functools.partialmethod.__dict__.__contains__", ["__get__"], true]
    - ["ft2596020", "functools.partialmethod.__dict__.__contains__", ["__set__"], false]
