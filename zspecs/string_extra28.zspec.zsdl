spec: string_extra28
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/string.py"
    - "string_extra27.zspec.zsdl — covers Formatter method __qualname__.__len__() (format=16, vformat=17, parse=15, get_field=19, format_field=22, convert_field=23, check_unused_args=27, get_value=19), Template.substitute/__qualname__.__len__()==19, Template.safe_substitute/__qualname__.__len__()==24, capwords.__qualname__.__len__()==8."
    - "string_extra26.zspec.zsdl — covers Template/Formatter __module__.__len__()/__name__.__len__()/__qualname__.__len__(), capwords attrs, Template/Formatter __bases__[0].__name__, Template method __qualname__ eq checks."
  notes:
    - "This spec extends string_extra27.zspec.zsdl."
    - "Prior specs covered: Template/__name__/__module__/__qualname__ lengths, Formatter/__name__/__module__/__qualname__ lengths, capwords/__qualname__/__name__/__module__ lengths, Template/Formatter __bases__[0].__name__, Template/Formatter method __qualname__.__len__() for all major methods, Template.__init__.__qualname__.__len__()==17."
    - "This spec covers: __mro__.__len__() for Formatter (2) and Template (2); __bases__[0].__name__.__len__() for Formatter ('object', 6) and Template ('object', 6); string constant __len__() — printable (100), digits (10), hexdigits (22), ascii_letters (52), ascii_lowercase (26), ascii_uppercase (26), octdigits (8), punctuation (32), whitespace (6); printable.__class__.__name__.__len__()==3; Template.__init__.__qualname__.__len__()==17."
    - "string.Formatter.__mro__.__len__() == 2 — (Formatter, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.Template.__mro__.__len__() == 2 — (Template, object). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.Formatter.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.Template.__bases__[0].__name__ == 'object' (len 6). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.printable.__class__.__name__ == 'str' (len 3). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.printable.__len__() == 100. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.digits.__len__() == 10. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.hexdigits.__len__() == 22. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.ascii_letters.__len__() == 52. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.ascii_lowercase.__len__() == 26. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.ascii_uppercase.__len__() == 26. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.octdigits.__len__() == 8. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.punctuation.__len__() == 32. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.whitespace.__len__() == 6. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "string.Template.__init__.__qualname__.__len__() == 17 — 'Template.__init__' has 17 characters. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for Formatter and Template
#
# No prior spec checks __mro__.__len__() for string.Formatter or string.Template.
# Both directly extend only object: mro depth 2.
# ---------------------------------------------------------------------------

invariant string_extra28.Formatter.mro.len:
  description: "string.Formatter.__mro__.__len__() == 2 — (Formatter, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Formatter.__mro__.__len__
  args: []
  expected: 2

invariant string_extra28.Template.mro.len:
  description: "string.Template.__mro__.__len__() == 2 — (Template, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: Template.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() for Formatter and Template
#
# string_extra26 covers __bases__[0].__name__ as an equality check.
# No prior spec checks __bases__[0].__name__.__len__() for either class.
# Both Formatter and Template extend object: base name length 6.
# ---------------------------------------------------------------------------

invariant string_extra28.Formatter.bases0.name.len:
  description: "string.Formatter.__bases__[0].__name__.__len__() == 6 — base is 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "Formatter.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant string_extra28.Template.bases0.name.len:
  description: "string.Template.__bases__[0].__name__.__len__() == 6 — base is 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "Template.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# string.printable.__class__.__name__.__len__()
#
# printable is a str constant; its __class__.__name__ is 'str' (len 3).
# No prior spec checks printable.__class__.__name__.__len__().
# ---------------------------------------------------------------------------

invariant string_extra28.printable.class.name.len:
  description: "string.printable.__class__.__name__.__len__() == 3 — printable is a 'str' instance"
  category: string_length
  kind: python_call_eq
  function: printable.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# string.Template.__init__.__qualname__.__len__()
#
# string_extra27 covers Template.substitute and safe_substitute qualname
# lengths. No prior spec covers Template.__init__.__qualname__.__len__().
# 'Template.__init__' has 17 characters.
# ---------------------------------------------------------------------------

invariant string_extra28.Template.__init__.qualname.len:
  description: "string.Template.__init__.__qualname__.__len__() == 17 — 'Template.__init__' has 17 characters"
  category: string_length
  kind: python_call_eq
  function: Template.__init__.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# Table: __mro__.__len__() and __bases__[0].__name__.__len__() for Formatter
# and Template, plus printable class name length
#
# Groups hierarchy and class-name introspection checks. No prior spec groups
# these together.
# ---------------------------------------------------------------------------

table string_extra28.class_hierarchy:
  description: "string.Formatter and Template __mro__.__len__() (both 2) and __bases__[0].__name__.__len__() (both 6), plus printable class name check"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected, description]
  rows:
    - [Formatter_mro_len,
       Formatter.__mro__.__len__,
       [],
       2,
       "len(Formatter.__mro__) == 2"]
    - [Template_mro_len,
       Template.__mro__.__len__,
       [],
       2,
       "len(Template.__mro__) == 2"]
    - [Formatter_bases0_name_len,
       "Formatter.__bases__[0].__name__.__len__",
       [],
       6,
       "len('object') == 6 — Formatter base"]
    - [Template_bases0_name_len,
       "Template.__bases__[0].__name__.__len__",
       [],
       6,
       "len('object') == 6 — Template base"]
    - [printable_class_name_len,
       printable.__class__.__name__.__len__,
       [],
       3,
       "len('str') == 3 — printable.__class__.__name__"]
    - [Template_init_qualname_len,
       Template.__init__.__qualname__.__len__,
       [],
       17,
       "len('Template.__init__') == 17"]

# ---------------------------------------------------------------------------
# Table: string module constant __len__() values
#
# No prior spec checks __len__() for any string module constant.
# printable=100, digits=10, hexdigits=22, ascii_letters=52,
# ascii_lowercase=26, ascii_uppercase=26, octdigits=8, punctuation=32,
# whitespace=6.
# ---------------------------------------------------------------------------

table string_extra28.constant_lengths:
  description: "string module constant __len__() — printable (100), digits (10), hexdigits (22), ascii_letters (52), ascii_lowercase (26), ascii_uppercase (26), octdigits (8), punctuation (32), whitespace (6)"
  kind: python_call_eq
  category: string_length

  columns: [id, function, args, expected, description]
  rows:
    - [printable_len,
       printable.__len__,
       [],
       100,
       "len(string.printable) == 100"]
    - [digits_len,
       digits.__len__,
       [],
       10,
       "len(string.digits) == 10"]
    - [hexdigits_len,
       hexdigits.__len__,
       [],
       22,
       "len(string.hexdigits) == 22"]
    - [ascii_letters_len,
       ascii_letters.__len__,
       [],
       52,
       "len(string.ascii_letters) == 52"]
    - [ascii_lowercase_len,
       ascii_lowercase.__len__,
       [],
       26,
       "len(string.ascii_lowercase) == 26"]
    - [ascii_uppercase_len,
       ascii_uppercase.__len__,
       [],
       26,
       "len(string.ascii_uppercase) == 26"]
    - [octdigits_len,
       octdigits.__len__,
       [],
       8,
       "len(string.octdigits) == 8"]
    - [punctuation_len,
       punctuation.__len__,
       [],
       32,
       "len(string.punctuation) == 32"]
    - [whitespace_len,
       whitespace.__len__,
       [],
       6,
       "len(string.whitespace) == 6"]
