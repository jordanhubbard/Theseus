spec: inspect_extra2176
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
    - "inspect_extra2161.zspec.zsdl — covers fget/fset/fdel and __objclass__/__func__ dict-presence, property attribute checks, Signature.from_callable classmethod"
  notes:
    - "Wave 2176 (_extra2176): iterator/sequence protocol dict-presence theme — __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments, and inspect.FullArgSpec do NOT define any of the 8 iterator/sequence protocol dunders in their own __dict__."
    - "inspect.Parameter is a named-tuple-like class with slots for name, default, annotation, and kind; it is not iterable and has no __iter__ or __next__."
    - "inspect.Signature stores an OrderedDict of parameters and a return_annotation; it is not iterable directly."
    - "inspect.BoundArguments stores argument bindings after a Signature.bind() call; it is not an iterator."
    - "inspect.FullArgSpec is a namedtuple produced by getfullargspec(); as a namedtuple it does define __iter__ in the namedtuple base class (tuple), but FullArgSpec itself does NOT add __iter__ to its own __dict__."
    - "None of the four inspect classes define __await__ — they are synchronous inspection objects."
    - "None define __missing__ — they are not dict subclasses."
  created_at: "2026-04-12"
error_model: python_exceptions

table inspect_extra2176.iter_next_absent_core:
  description: "inspect.Parameter and Signature do NOT define __iter__ or __next__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2176
  columns: [id, function, args, expected]
  rows:
    - ["in2176001", "inspect.Parameter.__dict__.__contains__",      ["__iter__"],  false]
    - ["in2176002", "inspect.Parameter.__dict__.__contains__",      ["__next__"],  false]
    - ["in2176003", "inspect.Signature.__dict__.__contains__",      ["__iter__"],  false]
    - ["in2176004", "inspect.Signature.__dict__.__contains__",      ["__next__"],  false]
    - ["in2176005", "inspect.BoundArguments.__dict__.__contains__", ["__iter__"],  false]
    - ["in2176006", "inspect.BoundArguments.__dict__.__contains__", ["__next__"],  false]
    - ["in2176007", "inspect.FullArgSpec.__dict__.__contains__",    ["__iter__"],  false]
    - ["in2176008", "inspect.FullArgSpec.__dict__.__contains__",    ["__next__"],  false]

table inspect_extra2176.aiter_anext_absent:
  description: "inspect classes do NOT define __aiter__ or __anext__ — no async iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2176
  columns: [id, function, args, expected]
  rows:
    - ["in2176009",  "inspect.Parameter.__dict__.__contains__",      ["__aiter__"], false]
    - ["in2176010", "inspect.Parameter.__dict__.__contains__",      ["__anext__"], false]
    - ["in2176011", "inspect.Signature.__dict__.__contains__",      ["__aiter__"], false]
    - ["in2176012", "inspect.Signature.__dict__.__contains__",      ["__anext__"], false]
    - ["in2176013", "inspect.BoundArguments.__dict__.__contains__", ["__aiter__"], false]
    - ["in2176014", "inspect.BoundArguments.__dict__.__contains__", ["__anext__"], false]
    - ["in2176015", "inspect.FullArgSpec.__dict__.__contains__",    ["__aiter__"], false]
    - ["in2176016", "inspect.FullArgSpec.__dict__.__contains__",    ["__anext__"], false]

