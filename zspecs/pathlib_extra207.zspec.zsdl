spec: pathlib_extra207
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/parts/parent/joinpath/str/as_posix/relative_to"
    - "pathlib_extra206.zspec.zsdl — covers pathlib class __doc__.__class__.__name__ identity"
  notes:
    - "This spec covers pathlib class __class__.__name__ (metaclass) and __dict__.__class__.__name__ identity not covered by prior pathlib_extra specs."
    - "pathlib.Path.__class__.__name__ == 'type'; the concrete path class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__class__.__name__ == 'type'; abstract base for all pure paths; metaclass is type; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__class__.__name__ == 'type'; pure POSIX path class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "pathlib.PureWindowsPath.__class__.__name__ == 'type'; pure Windows path class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__class__.__name__ == 'type'; concrete POSIX path class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "pathlib.WindowsPath.__class__.__name__ == 'type'; concrete Windows path class; metaclass is type; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy'; class __dict__ is a mappingproxy; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__dict__.__class__.__name__ == 'mappingproxy'; class __dict__ is a mappingproxy; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib pure path class __class__.__name__ identity
# PurePath, PurePosixPath, PureWindowsPath — all 'type'
# ---------------------------------------------------------------------------

table pathlib_extra207.pure_path_class_names:
  description: "pathlib pure path class __class__.__name__: PurePath, PurePosixPath, PureWindowsPath — all 'type'"
  kind: python_call_eq
  category: metaclass_identity
  id_prefix: pathlibclasses207

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_class_name,       pathlib.PurePath.__class__.__name__.__eq__,       ["type"], true, "pathlib.PurePath.__class__.__name__ == 'type'; abstract base for all pure path classes; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_class_name,  pathlib.PurePosixPath.__class__.__name__.__eq__,  ["type"], true, "pathlib.PurePosixPath.__class__.__name__ == 'type'; pure POSIX path class requiring no filesystem access; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [purewindowspath_class_name, pathlib.PureWindowsPath.__class__.__name__.__eq__, ["type"], true, "pathlib.PureWindowsPath.__class__.__name__ == 'type'; pure Windows path class requiring no filesystem access; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [purepath_class_name_len,   pathlib.PurePath.__class__.__name__.__len__,       [], 4, "pathlib.PurePath.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [pureposixpath_class_name_len, pathlib.PurePosixPath.__class__.__name__.__len__, [], 4, "pathlib.PurePosixPath.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib concrete path class __class__.__name__ identity
# Path, PosixPath, WindowsPath — all 'type'
# ---------------------------------------------------------------------------

table pathlib_extra207.concrete_path_class_names:
  description: "pathlib concrete path class __class__.__name__: Path, PosixPath, WindowsPath — all 'type'"
  kind: python_call_eq
  category: metaclass_identity
  id_prefix: pathlibclasses207

  columns: [id, function, args, expected, description]
  rows:
    - [path_class_name,        pathlib.Path.__class__.__name__.__eq__,        ["type"], true, "pathlib.Path.__class__.__name__ == 'type'; main concrete path class; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [posixpath_class_name,   pathlib.PosixPath.__class__.__name__.__eq__,   ["type"], true, "pathlib.PosixPath.__class__.__name__ == 'type'; concrete POSIX path class for Unix systems; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [windowspath_class_name, pathlib.WindowsPath.__class__.__name__.__eq__, ["type"], true, "pathlib.WindowsPath.__class__.__name__ == 'type'; concrete Windows path class; metaclass is type; confirmed Python 3.14.3 macOS"]
    - [path_class_name_len,    pathlib.Path.__class__.__name__.__len__,        [], 4, "pathlib.Path.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]
    - [posixpath_class_name_len, pathlib.PosixPath.__class__.__name__.__len__, [], 4, "pathlib.PosixPath.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib class __dict__.__class__.__name__ identity
# Path.__dict__, PurePath.__dict__ — both 'mappingproxy'
# ---------------------------------------------------------------------------

table pathlib_extra207.path_dict_class_names:
  description: "pathlib class __dict__.__class__.__name__: Path.__dict__, PurePath.__dict__ — both 'mappingproxy'"
  kind: python_call_eq
  category: dict_identity
  id_prefix: pathlibclasses207

  columns: [id, function, args, expected, description]
  rows:
    - [path_dict_class_name,        pathlib.Path.__dict__.__class__.__name__.__eq__,        ["mappingproxy"], true, "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy'; class __dict__ is a read-only mappingproxy; confirmed Python 3.14.3 macOS"]
    - [purepath_dict_class_name,    pathlib.PurePath.__dict__.__class__.__name__.__eq__,    ["mappingproxy"], true, "pathlib.PurePath.__dict__.__class__.__name__ == 'mappingproxy'; class __dict__ is a read-only mappingproxy; confirmed Python 3.14.3 macOS"]
    - [path_dict_class_name_len,    pathlib.Path.__dict__.__class__.__name__.__len__,        [], 12, "pathlib.Path.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has m(1)a(2)p(3)p(4)i(5)n(6)g(7)p(8)r(9)o(10)x(11)y(12); confirmed Python 3.14.3 macOS"]
    - [purepath_dict_class_name_len, pathlib.PurePath.__dict__.__class__.__name__.__len__,  [], 12, "pathlib.PurePath.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has m(1)a(2)p(3)p(4)i(5)n(6)g(7)p(8)r(9)o(10)x(11)y(12); confirmed Python 3.14.3 macOS"]
    - [windowspath_class_name_len,  pathlib.WindowsPath.__class__.__name__.__len__,          [], 4, "pathlib.WindowsPath.__class__.__name__.__len__() == 4 — 'type' has t(1)y(2)p(3)e(4); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra207.path_class_name:
  description: "pathlib.Path.__class__.__name__ == 'type' — main concrete path class; metaclass is type; confirmed Python 3.14.3 macOS"
  category: metaclass_identity
  kind: python_call_eq
  function: pathlib.Path.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra207.purepath_class_name:
  description: "pathlib.PurePath.__class__.__name__ == 'type' — abstract base for all pure path classes; metaclass is type; confirmed Python 3.14.3 macOS"
  category: metaclass_identity
  kind: python_call_eq
  function: pathlib.PurePath.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra207.pureposixpath_class_name:
  description: "pathlib.PurePosixPath.__class__.__name__ == 'type' — pure POSIX path requiring no filesystem access; metaclass is type; confirmed Python 3.14.3 macOS"
  category: metaclass_identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra207.purewindowspath_class_name:
  description: "pathlib.PureWindowsPath.__class__.__name__ == 'type' — pure Windows path requiring no filesystem access; metaclass is type; confirmed Python 3.14.3 macOS"
  category: metaclass_identity
  kind: python_call_eq
  function: pathlib.PureWindowsPath.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra207.posixpath_class_name:
  description: "pathlib.PosixPath.__class__.__name__ == 'type' — concrete POSIX path for Unix systems; metaclass is type; confirmed Python 3.14.3 macOS"
  category: metaclass_identity
  kind: python_call_eq
  function: pathlib.PosixPath.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra207.windowspath_class_name:
  description: "pathlib.WindowsPath.__class__.__name__ == 'type' — concrete Windows path class; metaclass is type; confirmed Python 3.14.3 macOS"
  category: metaclass_identity
  kind: python_call_eq
  function: pathlib.WindowsPath.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra207.path_dict_class_name:
  description: "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a read-only mappingproxy object; confirmed Python 3.14.3 macOS"
  category: dict_identity
  kind: python_call_eq
  function: pathlib.Path.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant pathlib_extra207.purepath_dict_class_name:
  description: "pathlib.PurePath.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a read-only mappingproxy object; confirmed Python 3.14.3 macOS"
  category: dict_identity
  kind: python_call_eq
  function: pathlib.PurePath.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
