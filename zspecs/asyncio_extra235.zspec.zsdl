spec: asyncio_extra235
version: ">=3.9"
backend: python_module(asyncio.subprocess)

docs: https://docs.python.org/3/library/asyncio-subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-subprocess.html — asyncio subprocess documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/subprocess.py"
  notes:
    - "asyncio.subprocess.PIPE == -1 — int constant; same value as subprocess.PIPE; verified with Python 3.14.3."
    - "asyncio.subprocess.STDOUT == -2 — int constant; same value as subprocess.STDOUT; verified with Python 3.14.3."
    - "asyncio.subprocess.DEVNULL == -3 — int constant; same value as subprocess.DEVNULL; verified with Python 3.14.3."
    - "All three constants are plain int instances (class name 'int', module 'builtins'); verified with Python 3.14.3."
    - "PIPE.__eq__(-1) == True; STDOUT.__eq__(-2) == True; DEVNULL.__eq__(-3) == True; verified with Python 3.14.3."
    - "PIPE + 1 == 0; STDOUT + 1 == -1; DEVNULL + 1 == -2 — arithmetic consistent with int values; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.subprocess.PIPE/STDOUT/DEVNULL constant value contracts — extra235 namespace
#
# PIPE == -1, STDOUT == -2, DEVNULL == -3.
# All are plain int instances.
# __eq__ comparisons return True for the correct integer values.
# ---------------------------------------------------------------------------

table asyncio_extra235.subprocess_pipe_constants:
  description: "asyncio.subprocess PIPE/STDOUT/DEVNULL constant value and type contracts in aio235spc namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio235spc

  columns: [id, function, args, expected, description]
  rows:
    - [pipe_eq_neg1,        PIPE.__eq__,                  [-1],    true, "asyncio.subprocess.PIPE.__eq__(-1) == True — PIPE is -1; verified with Python 3.14.3"]
    - [pipe_class_name_eq,  PIPE.__class__.__name__.__eq__, ["int"], true, "asyncio.subprocess.PIPE.__class__.__name__ == 'int'; verified with Python 3.14.3"]
    - [pipe_add_1,          PIPE.__add__,                 [1],     0,    "asyncio.subprocess.PIPE + 1 == 0 — consistent with int value -1; verified with Python 3.14.3"]
    - [stdout_eq_neg2,      STDOUT.__eq__,                [-2],    true, "asyncio.subprocess.STDOUT.__eq__(-2) == True — STDOUT is -2; verified with Python 3.14.3"]
    - [stdout_class_name_eq, STDOUT.__class__.__name__.__eq__, ["int"], true, "asyncio.subprocess.STDOUT.__class__.__name__ == 'int'; verified with Python 3.14.3"]
    - [stdout_add_1,        STDOUT.__add__,               [1],     -1,   "asyncio.subprocess.STDOUT + 1 == -1 — consistent with int value -2; verified with Python 3.14.3"]
    - [devnull_eq_neg3,     DEVNULL.__eq__,               [-3],    true, "asyncio.subprocess.DEVNULL.__eq__(-3) == True — DEVNULL is -3; verified with Python 3.14.3"]
    - [devnull_class_name_eq, DEVNULL.__class__.__name__.__eq__, ["int"], true, "asyncio.subprocess.DEVNULL.__class__.__name__ == 'int'; verified with Python 3.14.3"]
    - [devnull_add_1,       DEVNULL.__add__,              [1],     -2,   "asyncio.subprocess.DEVNULL + 1 == -2 — consistent with int value -3; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.subprocess constant class module contracts — extra235 namespace
#
# All three constants have __class__.__module__ == 'builtins'.
# PIPE.__class__.__module__ == 'builtins'.
# STDOUT.__class__.__module__ == 'builtins'.
# DEVNULL.__class__.__module__ == 'builtins'.
# ---------------------------------------------------------------------------

table asyncio_extra235.subprocess_constant_class_module:
  description: "asyncio.subprocess constant __class__.__module__ contracts in aio235ccm namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio235ccm

  columns: [id, function, args, expected, description]
  rows:
    - [pipe_class_mod_eq,   PIPE.__class__.__module__.__eq__,   ["builtins"], true, "asyncio.subprocess.PIPE.__class__.__module__ == 'builtins'; verified with Python 3.14.3"]
    - [stdout_class_mod_eq, STDOUT.__class__.__module__.__eq__, ["builtins"], true, "asyncio.subprocess.STDOUT.__class__.__module__ == 'builtins'; verified with Python 3.14.3"]
    - [devnull_class_mod_eq, DEVNULL.__class__.__module__.__eq__, ["builtins"], true, "asyncio.subprocess.DEVNULL.__class__.__module__ == 'builtins'; verified with Python 3.14.3"]
