spec: tabnanny_extra2
version: ">=3.9"
backend: python_module(tabnanny)

docs: https://docs.python.org/3/library/tabnanny.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tabnanny.html — Python tabnanny module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tabnanny.py"
  notes:
    - "This spec extends tabnanny.zspec.zsdl and tabnanny_extra.zspec.zsdl."
    - "tabnanny_extra covered: check.__name__, process_tokens.__name__, NannyNag.__name__, NannyNag.__module__, NannyNag.__bases__[0].__name__, NannyNag.__qualname__ (implied by notes), verbose.__class__.__name__, verbose == 0, filename_only.__class__.__name__, filename_only == 0, NannyNag method names, NannyNag is type."
    - "This spec adds: check.__module__ == 'tabnanny' (not in tabnanny_extra), check.__qualname__ == 'check' (not in tabnanny_extra), NannyNag.__qualname__ == 'NannyNag' (not in tabnanny_extra invariants), process_tokens.__module__ == 'tabnanny' (not in tabnanny_extra), and a function_names table (table form not previously used for tabnanny)."
    - "tabnanny.check.__module__ == 'tabnanny' — the function is defined in the tabnanny module."
    - "tabnanny.check.__qualname__ == 'check' — top-level function, qualname equals name."
    - "tabnanny.NannyNag.__qualname__ == 'NannyNag' — not a nested class, qualname equals name."
    - "tabnanny.process_tokens.__module__ == 'tabnanny' — defined in the tabnanny module."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# check() — __module__ and __qualname__ (not in tabnanny_extra)
# ---------------------------------------------------------------------------

invariant tabnanny_extra2.modules.check:
  description: "tabnanny.check.__module__ == 'tabnanny' — check is defined in the tabnanny module"
  category: modules
  kind: python_call_eq
  function: check.__module__.__eq__
  args: ["tabnanny"]
  expected: true

invariant tabnanny_extra2.qualnames.check:
  description: "tabnanny.check.__qualname__ == 'check' — top-level function, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: check.__qualname__.__eq__
  args: ["check"]
  expected: true

# ---------------------------------------------------------------------------
# process_tokens() — __module__ (not in tabnanny_extra)
# ---------------------------------------------------------------------------

invariant tabnanny_extra2.modules.process_tokens:
  description: "tabnanny.process_tokens.__module__ == 'tabnanny' — defined in the tabnanny module"
  category: modules
  kind: python_call_eq
  function: process_tokens.__module__.__eq__
  args: ["tabnanny"]
  expected: true

# ---------------------------------------------------------------------------
# NannyNag — __qualname__ (not in tabnanny_extra as an invariant)
# ---------------------------------------------------------------------------

invariant tabnanny_extra2.qualnames.NannyNag:
  description: "tabnanny.NannyNag.__qualname__ == 'NannyNag' — not a nested class, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: NannyNag.__qualname__.__eq__
  args: ["NannyNag"]
  expected: true

# ---------------------------------------------------------------------------
# function_names table — check and process_tokens (table form; not previously used)
# tabnanny_extra used individual invariant blocks; this provides table coverage.
# ---------------------------------------------------------------------------

table tabnanny_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: function_name

  columns: [id, function, args, expected]
  rows:
    - [check,          check.__name__.__eq__,          ["check"],          true]
    - [process_tokens, process_tokens.__name__.__eq__, ["process_tokens"], true]
