spec: just_pick
version: ">=4.2.0"
backend: node(just-pick)

docs: https://www.npmjs.com/package/just-pick

provenance:
  derived_from:
    - "just-pick README — https://www.npmjs.com/package/just-pick"
    - "Test vectors verified with just-pick via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-pick source"
  notes:
    - "just-pick is an npm package. Install: npm install just-pick"
    - "The module exports a single function: pick(obj, keys) returns a new object with only the specified keys."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new object with only the picked keys."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_pick.pick:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: jpick

  columns: [id, args, expected]
  rows:
    - [two_keys, [{"a": 1, "b": 2, "c": 3}, ["a", "c"]], {"a": 1, "c": 3}]
    - [one_key,  [{"x": 10, "y": 20}, ["x"]],            {"x": 10}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:09:38Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
