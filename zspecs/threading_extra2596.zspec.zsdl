spec: threading_extra2596
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2596 (_extra2596): __get__, __set__, __delete__ descriptor-protocol dict-presence checks for threading module types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "threading.Thread, Lock, Event, Condition: synchronization primitive classes; none define descriptor dunders."
    - "threading.Semaphore, BoundedSemaphore, Timer, Barrier: additional synchronization types; none define descriptor dunders."
    - "threading.local: thread-local storage type; does NOT define __get__, __set__, or __delete__ in its own __dict__."
    - "No threading module type participates in the descriptor protocol. These types model thread lifecycle and synchronization state, not attribute binding."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __get__ dict-presence for threading synchronization types
#
# threading.Thread, Lock, Event, Condition, Semaphore, BoundedSemaphore,
# Timer, and Barrier are concurrency primitive types. None define __get__
# in their own __dict__, so none are descriptors of any kind.
# ---------------------------------------------------------------------------

table threading_extra2596.get_protocol:
  description: "threading types __get__ dict-presence — all False, no threading type is a descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2596

  columns: [id, function, args, expected]
  rows:
    - ["th2596001", "threading.Thread.__dict__.__contains__", ["__get__"], false]
    - ["th2596002", "threading.Lock.__dict__.__contains__", ["__get__"], false]
    - ["th2596003", "threading.Event.__dict__.__contains__", ["__get__"], false]
    - ["th2596004", "threading.Condition.__dict__.__contains__", ["__get__"], false]
    - ["th2596005", "threading.Semaphore.__dict__.__contains__", ["__get__"], false]
    - ["th2596006", "threading.BoundedSemaphore.__dict__.__contains__", ["__get__"], false]
    - ["th2596007", "threading.Timer.__dict__.__contains__", ["__get__"], false]

# ---------------------------------------------------------------------------
# Table 2: __set__ dict-presence for threading synchronization types
#
# None of the threading types define __set__. These types manage thread
# state and synchronization (acquire/release semantics) rather than
# Python attribute-setting interception. The absence of __set__ and
# __get__ confirms they are not data descriptors.
# ---------------------------------------------------------------------------

table threading_extra2596.set_protocol:
  description: "threading types __set__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2596

  columns: [id, function, args, expected]
  rows:
    - ["th2596008", "threading.Thread.__dict__.__contains__", ["__set__"], false]
    - ["th2596009", "threading.Lock.__dict__.__contains__", ["__set__"], false]
    - ["th2596010", "threading.Event.__dict__.__contains__", ["__set__"], false]
    - ["th2596011", "threading.Condition.__dict__.__contains__", ["__set__"], false]
    - ["th2596012", "threading.Semaphore.__dict__.__contains__", ["__set__"], false]
    - ["th2596013", "threading.BoundedSemaphore.__dict__.__contains__", ["__set__"], false]
    - ["th2596014", "threading.Barrier.__dict__.__contains__", ["__set__"], false]

# ---------------------------------------------------------------------------
# Table 3: __delete__ dict-presence for threading synchronization types
#
# None of the threading types define __delete__. Threading primitives
# expose methods (acquire, release, wait, notify) but do not participate
# in Python's attribute deletion machinery.
# ---------------------------------------------------------------------------

table threading_extra2596.delete_protocol:
  description: "threading types __delete__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2596

  columns: [id, function, args, expected]
  rows:
    - ["th2596015", "threading.Thread.__dict__.__contains__", ["__delete__"], false]
    - ["th2596016", "threading.Lock.__dict__.__contains__", ["__delete__"], false]
    - ["th2596017", "threading.Event.__dict__.__contains__", ["__delete__"], false]
    - ["th2596018", "threading.Condition.__dict__.__contains__", ["__delete__"], false]
    - ["th2596019", "threading.Semaphore.__dict__.__contains__", ["__delete__"], false]
    - ["th2596020", "threading.Timer.__dict__.__contains__", ["__delete__"], false]
    - ["th2596021", "threading.Barrier.__dict__.__contains__", ["__delete__"], false]

# ---------------------------------------------------------------------------
# Table 4: threading.local and Barrier — full descriptor protocol check
#
# threading.local provides thread-local storage; it is sometimes confused
# with a descriptor because it intercepts attribute access differently for
# each thread. However, it does NOT define __get__, __set__, or __delete__
# in its own __dict__ — it relies on C-level tp_getattro/tp_setattro slots,
# not Python's descriptor protocol.
# threading.Barrier and BoundedSemaphore complete the picture for these
# less-commonly checked threading types.
# ---------------------------------------------------------------------------

table threading_extra2596.local_and_barrier_descriptor_check:
  description: "threading.local and threading.Barrier full descriptor protocol check — not descriptors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2596

  columns: [id, function, args, expected]
  rows:
    - ["th2596022", "threading.local.__dict__.__contains__", ["__get__"], false]
    - ["th2596023", "threading.local.__dict__.__contains__", ["__set__"], false]
    - ["th2596024", "threading.local.__dict__.__contains__", ["__delete__"], false]
    - ["th2596025", "threading.Barrier.__dict__.__contains__", ["__get__"], false]
    - ["th2596026", "threading.Barrier.__dict__.__contains__", ["__delete__"], false]
    - ["th2596027", "threading.BoundedSemaphore.__dict__.__contains__", ["__get__"], false]
    - ["th2596028", "threading.BoundedSemaphore.__dict__.__contains__", ["__set__"], false]
    - ["th2596029", "threading.BoundedSemaphore.__dict__.__contains__", ["__delete__"], false]
