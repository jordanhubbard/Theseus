spec: socket_extra991
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module socket class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.socket method __qualname__ attributes for lifecycle, I/O, and configuration methods"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra991.lifecycle_method_qualnames:
  description: "socket.socket lifecycle method __qualname__ identity"
  kind: python_call_eq
  category: lifecycle_method_qualnames
  id_prefix: sk991lm
  columns: [id, function, args, expected]
  rows:
    - [sk991lm001, socket.socket.__init__.__qualname__.__eq__,    ["socket.__init__"],    true]
    - [sk991lm002, socket.socket.__repr__.__qualname__.__eq__,    ["socket.__repr__"],    true]
    - [sk991lm003, socket.socket.__enter__.__qualname__.__eq__,   ["socket.__enter__"],   true]
    - [sk991lm004, socket.socket.__exit__.__qualname__.__eq__,    ["socket.__exit__"],    true]
    - [sk991lm005, socket.socket.close.__qualname__.__eq__,       ["socket.close"],       true]
    - [sk991lm006, socket.socket.fileno.__qualname__.__eq__,      ["socket.fileno"],      true]

table socket_extra991.addressing_method_qualnames:
  description: "socket.socket addressing method __qualname__ identity"
  kind: python_call_eq
  category: addressing_method_qualnames
  id_prefix: sk991am
  columns: [id, function, args, expected]
  rows:
    - [sk991am001, socket.socket.getpeername.__qualname__.__eq__,  ["socket.getpeername"],  true]
    - [sk991am002, socket.socket.getsockname.__qualname__.__eq__,  ["socket.getsockname"],  true]
    - [sk991am003, socket.socket.bind.__qualname__.__eq__,         ["socket.bind"],         true]
    - [sk991am004, socket.socket.connect.__qualname__.__eq__,      ["socket.connect"],      true]
    - [sk991am005, socket.socket.listen.__qualname__.__eq__,       ["socket.listen"],       true]
    - [sk991am006, socket.socket.accept.__qualname__.__eq__,       ["socket.accept"],       true]

table socket_extra991.configuration_method_qualnames:
  description: "socket.socket configuration and I/O method __qualname__ identity"
  kind: python_call_eq
  category: configuration_method_qualnames
  id_prefix: sk991cm
  columns: [id, function, args, expected]
  rows:
    - [sk991cm001, socket.socket.setblocking.__qualname__.__eq__,  ["socket.setblocking"],  true]
    - [sk991cm002, socket.socket.getblocking.__qualname__.__eq__,  ["socket.getblocking"],  true]
    - [sk991cm003, socket.socket.makefile.__qualname__.__eq__,     ["socket.makefile"],     true]
    - [sk991cm004, socket.socket.settimeout.__qualname__.__eq__,   ["socket.settimeout"],   true]
    - [sk991cm005, socket.socket.gettimeout.__qualname__.__eq__,   ["socket.gettimeout"],   true]
    - [sk991cm006, socket.socket.__class__.__name__.__eq__,        ["type"],                true]
    - [sk991cm007, socket.socket.__module__.__eq__,                ["socket"],              true]
