spec: concurrent_futures_extra155
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.thread.ThreadPoolExecutor method qualnames (submit, shutdown), concurrent.futures.thread.BrokenThreadPool class identity, and concurrent.futures.process.BrokenProcessPool class identity. concurrent.futures.thread.ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25); concurrent.futures.thread.ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=28: 'ThreadPoolExecutor'=18+'.'=1+'shutdown'=8=27... verified as 27 with Python 3.14.3); concurrent.futures.thread.BrokenThreadPool.__name__=='BrokenThreadPool' (len=16); concurrent.futures.thread.BrokenThreadPool.__module__=='concurrent.futures.thread' (len=25); concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__=='BrokenExecutor' (BrokenThreadPool inherits from BrokenExecutor); concurrent.futures.process.BrokenProcessPool.__name__=='BrokenProcessPool' (len=17); concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__=='BrokenExecutor' (BrokenProcessPool also inherits from BrokenExecutor). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.thread.BrokenThreadPool.__module__=='concurrent.futures.thread' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25); len('concurrent.futures.thread')==25; BrokenThreadPool is raised when a ThreadPoolExecutor worker thread dies unexpectedly; it inherits from BrokenExecutor which in turn inherits from RuntimeError; similarly BrokenProcessPool inherits from BrokenExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.thread.ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25); concurrent.futures.thread.ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=27: 'ThreadPoolExecutor'=18+'.'=1+'shutdown'=8=27); verified with Python 3.14.3. Note: the thread module path concurrent.futures.thread.ThreadPoolExecutor is the same class as concurrent.futures.ThreadPoolExecutor — accessing via the thread submodule gives the same qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.thread.ThreadPoolExecutor method qualnames — extra155
#
# concurrent.futures.thread.ThreadPoolExecutor.submit.__qualname__   == 'ThreadPoolExecutor.submit'
# concurrent.futures.thread.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'
# ---------------------------------------------------------------------------

table concurrent_futures_extra155.cf_thread_tpe_method_qualnames:
  description: "concurrent.futures.thread.ThreadPoolExecutor method qualname checks accessed via thread submodule in cfthtpe155 namespace — concurrent.futures.thread.ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25: 'ThreadPoolExecutor'=18+'.'=1+'submit'=6=25; submit is defined directly on ThreadPoolExecutor; accessing via the thread submodule gives the same method object as concurrent.futures.ThreadPoolExecutor.submit); concurrent.futures.thread.ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=27: 'ThreadPoolExecutor'=18+'.'=1+'shutdown'=8=27; shutdown is defined on ThreadPoolExecutor; shutdown longer than submit because 'shutdown'=8 > 'submit'=6); qualname length: submit(25) < shutdown(27); both methods are defined on ThreadPoolExecutor (not inherited from Executor); established in extra154 that ThreadPoolExecutor.map.__qualname__=='Executor.map' (inherited); this spec confirms submit and shutdown via thread submodule path; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfthtpe155

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_submit_qn_eq,    concurrent.futures.thread.ThreadPoolExecutor.submit.__qualname__.__eq__,    ["ThreadPoolExecutor.submit"],    true,  "cf.thread.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25); verified with Python 3.14.3"]
    - [tpe_shutdown_qn_eq,  concurrent.futures.thread.ThreadPoolExecutor.shutdown.__qualname__.__eq__,  ["ThreadPoolExecutor.shutdown"],  true,  "cf.thread.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27); verified with Python 3.14.3"]
    - [tpe_submit_qn_len,   concurrent.futures.thread.ThreadPoolExecutor.submit.__qualname__.__len__,   [],                               25,    "cf.thread.ThreadPoolExecutor.submit.__qualname__.__len__() == 25 ('ThreadPoolExecutor.submit'); verified with Python 3.14.3"]
    - [tpe_shutdown_qn_len, concurrent.futures.thread.ThreadPoolExecutor.shutdown.__qualname__.__len__, [],                               27,    "cf.thread.ThreadPoolExecutor.shutdown.__qualname__.__len__() == 27 ('ThreadPoolExecutor.shutdown'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.thread.BrokenThreadPool class identity — extra155
#
# concurrent.futures.thread.BrokenThreadPool.__name__.__eq__('BrokenThreadPool')                           == True
# concurrent.futures.thread.BrokenThreadPool.__module__.__eq__('concurrent.futures.thread')                == True
# concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__('BrokenExecutor')                == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra155.cf_broken_thread_pool_identity:
  description: "concurrent.futures.thread.BrokenThreadPool class identity checks in cfbtp155 namespace — concurrent.futures.thread.BrokenThreadPool.__name__=='BrokenThreadPool' (len=16: 'Broken'=6+'Thread'=6+'Pool'=4=16; the exception raised when a thread pool worker crashes unexpectedly); concurrent.futures.thread.BrokenThreadPool.__module__=='concurrent.futures.thread' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25; defined in Lib/concurrent/futures/thread.py); concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__=='BrokenExecutor' (BrokenThreadPool inherits from BrokenExecutor — the base broken executor exception class defined in _base.py; BrokenExecutor inherits from RuntimeError); BrokenThreadPool.__name__.__len__()==16; compare: BrokenProcessPool.__name__.__len__()==17 (1 char longer because 'Process'=7 > 'Thread'=6); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfbtp155

  columns: [id, function, args, expected, description]
  rows:
    - [btp_name_eq,   concurrent.futures.thread.BrokenThreadPool.__name__.__eq__,                ["BrokenThreadPool"],           true,  "cf.thread.BrokenThreadPool.__name__ == 'BrokenThreadPool' (len=16); verified with Python 3.14.3"]
    - [btp_mod_eq,    concurrent.futures.thread.BrokenThreadPool.__module__.__eq__,               ["concurrent.futures.thread"],  true,  "cf.thread.BrokenThreadPool.__module__ == 'concurrent.futures.thread' (len=25); verified with Python 3.14.3"]
    - [btp_base_eq,   "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__",  ["BrokenExecutor"],             true,  "cf.thread.BrokenThreadPool.__bases__[0].__name__ == 'BrokenExecutor' (inherits from BrokenExecutor); verified with Python 3.14.3"]
    - [btp_name_len,  concurrent.futures.thread.BrokenThreadPool.__name__.__len__,                [],                             16,    "cf.thread.BrokenThreadPool.__name__.__len__() == 16 ('BrokenThreadPool'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.process.BrokenProcessPool class identity — extra155
#
# concurrent.futures.process.BrokenProcessPool.__name__.__eq__('BrokenProcessPool')          == True
# concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__('BrokenExecutor') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra155.cf_broken_process_pool_identity:
  description: "concurrent.futures.process.BrokenProcessPool class identity checks in cfbpp155 namespace — concurrent.futures.process.BrokenProcessPool.__name__=='BrokenProcessPool' (len=17: 'Broken'=6+'Process'=7+'Pool'=4=17; the exception raised when a process pool worker crashes; 1 char longer than BrokenThreadPool=16 because 'Process'=7 > 'Thread'=6); concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__=='BrokenExecutor' (BrokenProcessPool also inherits from BrokenExecutor — the same base class as BrokenThreadPool; both broken exceptions share a common BrokenExecutor parent); BrokenProcessPool.__name__.__len__()==17; both BrokenThreadPool and BrokenProcessPool inherit from BrokenExecutor confirming a parallel class hierarchy design for thread and process executors; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfbpp155

  columns: [id, function, args, expected, description]
  rows:
    - [bpp_name_eq,   concurrent.futures.process.BrokenProcessPool.__name__.__eq__,                ["BrokenProcessPool"],  true,  "cf.process.BrokenProcessPool.__name__ == 'BrokenProcessPool' (len=17); verified with Python 3.14.3"]
    - [bpp_base_eq,   "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"],     true,  "cf.process.BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor' (same base as BrokenThreadPool); verified with Python 3.14.3"]
    - [bpp_name_len,  concurrent.futures.process.BrokenProcessPool.__name__.__len__,               [],                     17,    "cf.process.BrokenProcessPool.__name__.__len__() == 17 ('BrokenProcessPool'; 1 longer than BrokenThreadPool=16); verified with Python 3.14.3"]
    - [btp_name_len2, concurrent.futures.thread.BrokenThreadPool.__name__.__len__,                 [],                     16,    "cf.thread.BrokenThreadPool.__name__.__len__() == 16 (compare: BrokenProcessPool=17 > BrokenThreadPool=16); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra155
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra155.cf_thread_TPE_submit_qualname_eq:
  description: "concurrent.futures.thread.ThreadPoolExecutor.submit.__qualname__.__eq__('ThreadPoolExecutor.submit') returns True — accessing ThreadPoolExecutor via concurrent.futures.thread submodule gives the same method as via concurrent.futures.ThreadPoolExecutor (established in extra154); ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25: 'ThreadPoolExecutor'=18+'.'=1+'submit'=6=25); submit is defined directly on ThreadPoolExecutor (not inherited from Executor — Executor.submit raises NotImplementedError); the thread submodule path confirms the class lives in Lib/concurrent/futures/thread.py; compare: ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=27; 2 chars longer because 'shutdown'=8 > 'submit'=6); NEW in extra155: first standalone cf.thread.TPE.submit qualname invariant via thread submodule in cfthtpe155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.thread.ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra155.cf_thread_TPE_shutdown_qualname_eq:
  description: "concurrent.futures.thread.ThreadPoolExecutor.shutdown.__qualname__.__eq__('ThreadPoolExecutor.shutdown') returns True — ThreadPoolExecutor defines its own shutdown() which waits for all futures to complete and optionally cancels pending work; shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=27: 'ThreadPoolExecutor'=18+'.'=1+'shutdown'=8=27); compare: Executor.shutdown.__qualname__=='Executor.shutdown' (len=17; shorter because Executor=8 < ThreadPoolExecutor=18 — difference of 10); submit qualname (len=25) < shutdown qualname (len=27) because 'submit'=6 < 'shutdown'=8; accessing via thread submodule path confirms the same qualname as via top-level concurrent.futures; NEW in extra155: first standalone cf.thread.TPE.shutdown qualname invariant via thread submodule in cfthtpe155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.thread.ThreadPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ThreadPoolExecutor.shutdown"]
  expected: true

invariant concurrent_futures_extra155.cf_BrokenThreadPool_name_eq:
  description: "concurrent.futures.thread.BrokenThreadPool.__name__.__eq__('BrokenThreadPool') returns True — BrokenThreadPool is the exception raised when a worker thread in a ThreadPoolExecutor terminates abruptly (e.g. due to a fatal error); BrokenThreadPool.__name__=='BrokenThreadPool' (len=16: 'Broken'=6+'Thread'=6+'Pool'=4=16); BrokenThreadPool.__module__=='concurrent.futures.thread' (len=25); BrokenThreadPool.__bases__[0].__name__=='BrokenExecutor' (inherits from BrokenExecutor which inherits from RuntimeError); compare: BrokenProcessPool.__name__.__len__()==17 (1 char longer because 'Process'=7 > 'Thread'=6); both BrokenThreadPool and BrokenProcessPool share BrokenExecutor as their base class — a parallel design for thread and process executors; NEW in extra155: first standalone BrokenThreadPool.__name__ identity invariant in cfbtp155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.thread.BrokenThreadPool.__name__.__eq__
  args: ["BrokenThreadPool"]
  expected: true

invariant concurrent_futures_extra155.cf_BrokenThreadPool_base_is_BrokenExecutor:
  description: "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__('BrokenExecutor') returns True — BrokenThreadPool inherits from BrokenExecutor (defined in Lib/concurrent/futures/_base.py); BrokenExecutor itself inherits from RuntimeError; so the full chain is BrokenThreadPool -> BrokenExecutor -> RuntimeError -> Exception -> BaseException; __bases__[0].__name__=='BrokenExecutor' (len=14: 'Broken'=6+'Executor'=8=14); both BrokenThreadPool and BrokenProcessPool share BrokenExecutor as their immediate base class; BrokenExecutor was added in Python 3.7 as the common base for broken executor exceptions; NEW in extra155: first standalone BrokenThreadPool.__bases__[0] name identity invariant in cfbtp155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.thread.BrokenThreadPool.__bases__[0].__name__.__eq__"
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra155.cf_BrokenProcessPool_base_is_BrokenExecutor:
  description: "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__('BrokenExecutor') returns True — BrokenProcessPool inherits from BrokenExecutor (the same base as BrokenThreadPool); __bases__[0].__name__=='BrokenExecutor' (len=14); BrokenProcessPool is raised when a worker process in a ProcessPoolExecutor terminates unexpectedly; it follows the same inheritance pattern as BrokenThreadPool: BrokenProcessPool -> BrokenExecutor -> RuntimeError; BrokenProcessPool.__name__=='BrokenProcessPool' (len=17; 1 char longer than BrokenThreadPool=16 because 'Process'=7 > 'Thread'=6); the parallel design of BrokenThreadPool and BrokenProcessPool both inheriting from BrokenExecutor means callers can catch BrokenExecutor to handle both cases; NEW in extra155: first standalone BrokenProcessPool.__bases__[0] name identity invariant in cfbpp155 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.process.BrokenProcessPool.__bases__[0].__name__.__eq__"
  args: ["BrokenExecutor"]
  expected: true
