  columns: [id, function, args, expected]
  rows:
    - ["uu2971001", operator.contains, [uuid.UUID.__dict__,     "__floor__"], false]
    - ["uu2971002", operator.contains, [uuid.SafeUUID.__dict__, "__floor__"], false]

