spec: uu2971
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid: UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 645 (uu2971): __floor__, __ceil__, __index__ dict-presence checks for uuid types."
    - "uuid.UUID is an immutable identifier class; uuid.SafeUUID is an Enum (not IntEnum) — neither defines floor, ceiling, or integer-index operators in its own __dict__."
    - "SafeUUID inherits from enum.Enum directly, not IntEnum, so __index__ is not defined there either."
    - "Verified types: uuid.UUID, uuid.SafeUUID."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu2971.floor:
  description: "uuid types __floor__ dict-presence checks; wave 645"
  kind: python_call_eq
  category: dict_contains
