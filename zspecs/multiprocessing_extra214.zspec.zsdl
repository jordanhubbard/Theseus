spec: multiprocessing_extra214
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "multiprocessing.__doc__ is None — the multiprocessing module has no module-level docstring; verified with Python 3.14.3."
    - "multiprocessing.Process.__doc__ is None — the Process class has no docstring; verified with Python 3.14.3."
    - "multiprocessing.Process.start.__doc__ is '\\nStart child process\\n' — contains 'Start' (uppercase) but NOT 'start' (lowercase); verified with Python 3.14.3."
    - "multiprocessing.Process.join.__doc__ is '\\nWait until child process terminates\\n' — contains 'Wait' but NOT 'join'; verified with Python 3.14.3."
    - "multiprocessing.Process.run.__doc__ is '\\nMethod to be run in sub-process; can be overridden in sub-class\\n' — contains 'run' (lowercase) in 'to be run in sub-process'; verified with Python 3.14.3."
    - "multiprocessing.pool.Pool.__doc__ contains 'async' — Pool.__doc__ is '\\nClass which supports an async version of applying functions to arguments.\\n'; 'async' is present; verified with Python 3.14.3."
    - "multiprocessing.pool.Pool.map.__doc__ contains 'Apply' (uppercase) — map.__doc__ starts with '\\nApply `func` to each element in `iterable`'; 'Apply' is present; 'map' (lowercase) is NOT present; verified with Python 3.14.3."
    - "multiprocessing.pool.Pool.apply.__doc__ contains 'Equivalent' (uppercase) — apply.__doc__ is '\\nEquivalent of `func(*args, **kwds)`.\\nPool must be running.\\n'; 'Equivalent' is present; 'apply' (lowercase) is NOT present; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process method __doc__ contains checks — extra214 namespace
#
# Process.start.__doc__ contains 'Start' (uppercase); NOT 'start' (lowercase).
# Process.join.__doc__ contains 'Wait' (uppercase); NOT 'join'.
# Process.run.__doc__ contains 'run' (lowercase).
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table multiprocessing_extra214.process_method_doc:
  description: "multiprocessing Process method __doc__.__contains__ checks in mp214doc namespace"
  kind: python_call_eq
  category: doc_contains
  id_prefix: mp214doc

  columns: [id, function, args, expected, description]
  rows:
    - [process_start_doc_has_Start, Process.start.__doc__.__contains__, ["Start"], true, "multiprocessing.Process.start.__doc__.__contains__('Start') == True — start.__doc__ is '\\nStart child process\\n'; 'Start' (uppercase) is present; note: 'start' (lowercase) is NOT present; verified with Python 3.14.3"]
    - [process_join_doc_has_Wait,   Process.join.__doc__.__contains__,  ["Wait"],  true, "multiprocessing.Process.join.__doc__.__contains__('Wait') == True — join.__doc__ is '\\nWait until child process terminates\\n'; 'Wait' (uppercase) is present; note: 'join' is NOT in the docstring; verified with Python 3.14.3"]
    - [process_run_doc_has_run,     Process.run.__doc__.__contains__,   ["run"],   true, "multiprocessing.Process.run.__doc__.__contains__('run') == True — run.__doc__ is '\\nMethod to be run in sub-process; can be overridden in sub-class\\n'; 'run' (lowercase) is present in 'to be run in sub-process'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool method __doc__ contains checks — extra214 namespace
#
# Pool.__doc__ contains 'async'; Pool.map.__doc__ contains 'Apply';
# Pool.apply.__doc__ contains 'Equivalent'.
# Note: Pool.__doc__ does NOT contain 'pool' or 'Pool';
#       Pool.map.__doc__ does NOT contain 'map' (lowercase);
#       Pool.apply.__doc__ does NOT contain 'apply' (lowercase).
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table multiprocessing_extra214.pool_doc:
  description: "multiprocessing.pool.Pool __doc__.__contains__ checks in mp214doc namespace"
  kind: python_call_eq
  category: doc_contains
  id_prefix: mp214doca

  columns: [id, function, args, expected, description]
  rows:
    - [pool_doc_has_async,             multiprocessing.pool.Pool.__doc__.__contains__,       ["async"],      true, "multiprocessing.pool.Pool.__doc__.__contains__('async') == True — Pool.__doc__ is '\\nClass which supports an async version of applying functions to arguments.\\n'; 'async' is present; verified with Python 3.14.3"]
    - [pool_map_doc_has_Apply,         multiprocessing.pool.Pool.map.__doc__.__contains__,   ["Apply"],      true, "multiprocessing.pool.Pool.map.__doc__.__contains__('Apply') == True — map.__doc__ starts with '\\nApply `func` to each element in `iterable`'; 'Apply' (uppercase) is present; 'map' (lowercase) is NOT present; verified with Python 3.14.3"]
    - [pool_apply_doc_has_Equivalent,  multiprocessing.pool.Pool.apply.__doc__.__contains__, ["Equivalent"], true, "multiprocessing.pool.Pool.apply.__doc__.__contains__('Equivalent') == True — apply.__doc__ is '\\nEquivalent of `func(*args, **kwds)`.\\nPool must be running.\\n'; 'Equivalent' (uppercase) is present; 'apply' (lowercase) is NOT present; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra214
# ---------------------------------------------------------------------------

invariant multiprocessing_extra214.process_run_doc_has_override:
  description: "multiprocessing.Process.run.__doc__.__contains__('override') == True — run.__doc__ is '\\nMethod to be run in sub-process; can be overridden in sub-class\\n'; 'override' is present as part of 'overridden'; NEW in extra214: first Process.run.__doc__ contains check for 'override'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: Process.run.__doc__.__contains__
  args: ["override"]
  expected: true
