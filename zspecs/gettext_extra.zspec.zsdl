spec: gettext_extra
version: ">=3.0"
backend: python_module(gettext)

docs: https://docs.python.org/3/library/gettext.html

provenance:
  derived_from:
    - "Python gettext documentation — https://docs.python.org/3/library/gettext.html"
    - "GNU gettext manual — https://www.gnu.org/software/gettext/manual/gettext.html"
    - "Test vectors verified by running Python 3.12 gettext module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gettext.py"
  notes:
    - "This spec extends gettext.zspec.zsdl with additional class identity and function name checks."
    - "NullTranslations is the base translation class; it returns input strings unchanged (passthrough)."
    - "GNUTranslations inherits directly from NullTranslations and adds .mo catalog parsing."
    - "pgettext and npgettext are context-aware variants of gettext and ngettext, added in Python 3.8."
    - "bindtextdomain, textdomain, find, translation, and install are module-level functions."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant gettext_extra.NullTranslations.class_name:
  description: "gettext.NullTranslations.__name__ == 'NullTranslations'"
  category: classnames
  kind: python_call_eq
  function: NullTranslations.__name__.__eq__
  args: ["NullTranslations"]
  expected: true

invariant gettext_extra.NullTranslations.module:
  description: "gettext.NullTranslations.__module__ == 'gettext'"
  category: classnames
  kind: python_call_eq
  function: NullTranslations.__module__.__eq__
  args: ["gettext"]
  expected: true

invariant gettext_extra.GNUTranslations.class_name:
  description: "gettext.GNUTranslations.__name__ == 'GNUTranslations'"
  category: classnames
  kind: python_call_eq
  function: GNUTranslations.__name__.__eq__
  args: ["GNUTranslations"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — GNUTranslations extends NullTranslations
# ---------------------------------------------------------------------------

invariant gettext_extra.GNUTranslations.base_class:
  description: "gettext.GNUTranslations.__bases__[0].__name__ == 'NullTranslations'"
  category: hierarchy
  kind: python_call_eq
  function: GNUTranslations.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "NullTranslations"

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table gettext_extra.func_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [gettext,        "gettext.__name__.__eq__",        ["gettext"],        true]
    - [ngettext,       "ngettext.__name__.__eq__",       ["ngettext"],       true]
    - [pgettext,       "pgettext.__name__.__eq__",       ["pgettext"],       true]
    - [npgettext,      "npgettext.__name__.__eq__",      ["npgettext"],      true]
    - [bindtextdomain, "bindtextdomain.__name__.__eq__", ["bindtextdomain"], true]
    - [textdomain,     "textdomain.__name__.__eq__",     ["textdomain"],     true]
    - [find,           "find.__name__.__eq__",           ["find"],           true]
    - [translation,    "translation.__name__.__eq__",    ["translation"],    true]
    - [install,        "install.__name__.__eq__",        ["install"],        true]
