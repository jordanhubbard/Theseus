spec: inspect_extra96
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra95

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra95.zspec.zsdl."
    - "This spec covers: inspect getfullargspec, getargvalues, formatargvalues, classify_class_attrs code attrs + one-arg predicate function co_argcount (Wave 254)."
    - "inspect.isbuiltin.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.ismethoddescriptor.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isdatadescriptor.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.ismemberdescriptor.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isgetsetdescriptor.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isroutine.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isabstract.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getfullargspec.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getargvalues.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.formatargvalues.__code__.co_argcount == 8. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getfullargspec.__code__.co_name == 'getfullargspec'. Verified with Python 3.14.3."
    - "inspect.getargvalues.__code__.co_name == 'getargvalues'. Verified with Python 3.14.3."
    - "inspect.formatargvalues.__code__.co_name == 'formatargvalues'. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__code__.co_name == 'classify_class_attrs'. Verified with Python 3.14.3."
    - "inspect.getfullargspec.__qualname__ == 'getfullargspec'. Verified with Python 3.14.3."
    - "inspect.formatargvalues.__qualname__ == 'formatargvalues'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: One-arg predicate functions co_argcount (all 1)
#
# Wave 254 theme: inspect one-argument predicate function co_argcount.
#
# inspect.isbuiltin.__code__.co_argcount == 1
# inspect.ismethoddescriptor.__code__.co_argcount == 1
# inspect.isdatadescriptor.__code__.co_argcount == 1
# inspect.ismemberdescriptor.__code__.co_argcount == 1
# inspect.isgetsetdescriptor.__code__.co_argcount == 1
# inspect.isroutine.__code__.co_argcount == 1
# inspect.isabstract.__code__.co_argcount == 1
#
# All these predicates take a single argument (the object to test).
# New to extra96.
# ---------------------------------------------------------------------------

table inspect_extra96.predicate_co_argcount:
  description: "inspect.isbuiltin/ismethoddescriptor/isdatadescriptor/ismemberdescriptor/isgetsetdescriptor/isroutine/isabstract __code__.co_argcount == 1; one-arg predicates; wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectutilityfns96

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_co_argcount_eq_1,
       "isbuiltin.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isbuiltin.__code__.co_argcount.__eq__(1) == True — isbuiltin(object) tests whether the object is a built-in function or method; it takes exactly one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra96"]
    - [ismethoddescriptor_co_argcount_eq_1,
       "ismethoddescriptor.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.ismethoddescriptor.__code__.co_argcount.__eq__(1) == True — ismethoddescriptor(object) tests whether the object is a method descriptor; takes one argument; co_argcount is 1; int.__eq__(1) returns True; new to extra96"]
    - [isdatadescriptor_co_argcount_eq_1,
       "isdatadescriptor.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isdatadescriptor.__code__.co_argcount.__eq__(1) == True — isdatadescriptor(object) tests whether the object is a data descriptor (has __set__ or __delete__); takes one argument; co_argcount is 1; int.__eq__(1) returns True; new to extra96"]
    - [ismemberdescriptor_co_argcount_eq_1,
       "ismemberdescriptor.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.ismemberdescriptor.__code__.co_argcount.__eq__(1) == True — ismemberdescriptor(object) tests whether the object is a member descriptor (e.g. for class __slots__); takes one argument; co_argcount is 1; int.__eq__(1) returns True; new to extra96"]
    - [isgetsetdescriptor_co_argcount_eq_1,
       "isgetsetdescriptor.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isgetsetdescriptor.__code__.co_argcount.__eq__(1) == True — isgetsetdescriptor(object) tests whether the object is a getset descriptor; takes one argument; co_argcount is 1; int.__eq__(1) returns True; new to extra96"]
    - [isroutine_co_argcount_eq_1,
       "isroutine.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isroutine.__code__.co_argcount.__eq__(1) == True — isroutine(object) tests whether the object is a function, method, or callable; takes one argument; co_argcount is 1; int.__eq__(1) returns True; new to extra96"]
    - [isabstract_co_argcount_eq_1,
       "isabstract.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isabstract.__code__.co_argcount.__eq__(1) == True — isabstract(object) tests whether the object is an abstract base class; takes one argument; co_argcount is 1; int.__eq__(1) returns True; new to extra96"]

# ---------------------------------------------------------------------------
# Table 2: Multi-arg utility functions co_argcount
#
# Wave 254 theme: inspect utility functions with varying co_argcount.
#
# inspect.getfullargspec.__code__.co_argcount == 1
# inspect.getargvalues.__code__.co_argcount == 1
# inspect.formatargvalues.__code__.co_argcount == 8
# inspect.classify_class_attrs.__code__.co_argcount == 1
#
# getfullargspec and getargvalues take one argument; formatargvalues takes 8
# (locals, args, varargs, varkw, formatarg, formatvarargs, formatvarkw, formatvalue).
# New to extra96.
# ---------------------------------------------------------------------------

table inspect_extra96.utility_fn_co_argcount:
  description: "inspect.getfullargspec/getargvalues/classify_class_attrs co_argcount == 1; formatargvalues co_argcount == 8; wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectutilityfns96

  columns: [id, function, args, expected, description]
  rows:
    - [getfullargspec_co_argcount_eq_1,
       "getfullargspec.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getfullargspec.__code__.co_argcount.__eq__(1) == True — getfullargspec(func) takes one argument (the function to inspect); co_argcount is 1; int.__eq__(1) returns True; new to extra96"]
    - [getargvalues_co_argcount_eq_1,
       "getargvalues.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getargvalues.__code__.co_argcount.__eq__(1) == True — getargvalues(frame) takes one argument (the frame object); co_argcount is 1; int.__eq__(1) returns True; new to extra96"]
    - [formatargvalues_co_argcount_eq_8,
       "formatargvalues.__code__.co_argcount.__eq__",
       [8],
       true,
       "inspect.formatargvalues.__code__.co_argcount.__eq__(8) == True — formatargvalues takes 8 positional arguments: locals, args, varargs, varkw, formatarg, formatvarargs, formatvarkw, formatvalue; co_argcount is 8; int.__eq__(8) returns True; new to extra96"]
    - [classify_class_attrs_co_argcount_eq_1,
       "classify_class_attrs.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.classify_class_attrs.__code__.co_argcount.__eq__(1) == True — classify_class_attrs(cls) takes one argument (the class to classify); co_argcount is 1; int.__eq__(1) returns True; new to extra96"]

# ---------------------------------------------------------------------------
# Table 3: Utility function co_name equality for selected functions
#
# Wave 254 theme: inspect utility function co_name matches function name.
#
# inspect.getfullargspec.__code__.co_name.__eq__('getfullargspec') == True
# inspect.getargvalues.__code__.co_name.__eq__('getargvalues') == True
# inspect.formatargvalues.__code__.co_name.__eq__('formatargvalues') == True
# inspect.classify_class_attrs.__code__.co_name.__eq__('classify_class_attrs') == True
#
# For module-level Python functions, co_name equals the function name as defined.
# New to extra96.
# ---------------------------------------------------------------------------

table inspect_extra96.utility_fn_co_name:
  description: "inspect.getfullargspec/getargvalues/formatargvalues/classify_class_attrs __code__.co_name matches function name; wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectutilityfns96

  columns: [id, function, args, expected, description]
  rows:
    - [getfullargspec_co_name_eq,
       "getfullargspec.__code__.co_name.__eq__",
       ["getfullargspec"],
       true,
       "inspect.getfullargspec.__code__.co_name.__eq__('getfullargspec') == True — for a module-level Python function, co_name is the function name as written in the 'def' statement; getfullargspec's co_name is 'getfullargspec'; str.__eq__('getfullargspec') returns True; new to extra96"]
    - [getargvalues_co_name_eq,
       "getargvalues.__code__.co_name.__eq__",
       ["getargvalues"],
       true,
       "inspect.getargvalues.__code__.co_name.__eq__('getargvalues') == True — getargvalues is a module-level Python function; co_name is 'getargvalues'; str.__eq__('getargvalues') returns True; new to extra96"]
    - [formatargvalues_co_name_eq,
       "formatargvalues.__code__.co_name.__eq__",
       ["formatargvalues"],
       true,
       "inspect.formatargvalues.__code__.co_name.__eq__('formatargvalues') == True — formatargvalues is a module-level Python function; co_name is 'formatargvalues'; str.__eq__('formatargvalues') returns True; new to extra96"]
    - [classify_class_attrs_co_name_eq,
       "classify_class_attrs.__code__.co_name.__eq__",
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__code__.co_name.__eq__('classify_class_attrs') == True — classify_class_attrs is a module-level Python function; co_name is 'classify_class_attrs'; str.__eq__('classify_class_attrs') returns True; new to extra96"]
    - [isbuiltin_co_name_eq,
       "isbuiltin.__code__.co_name.__eq__",
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__code__.co_name.__eq__('isbuiltin') == True — isbuiltin is a module-level Python function; co_name is 'isbuiltin'; str.__eq__('isbuiltin') returns True; new to extra96"]
    - [isroutine_co_name_eq,
       "isroutine.__code__.co_name.__eq__",
       ["isroutine"],
       true,
       "inspect.isroutine.__code__.co_name.__eq__('isroutine') == True — isroutine is a module-level Python function; co_name is 'isroutine'; str.__eq__('isroutine') returns True; new to extra96"]

# ---------------------------------------------------------------------------
# Table 4: Selected function __qualname__ equality
#
# Wave 254 theme: inspect utility function __qualname__ at module scope.
#
# inspect.getfullargspec.__qualname__.__eq__('getfullargspec') == True
# inspect.getargvalues.__qualname__.__eq__('getargvalues') == True
# inspect.formatargvalues.__qualname__.__eq__('formatargvalues') == True
# inspect.classify_class_attrs.__qualname__.__eq__('classify_class_attrs') == True
# inspect.isroutine.__qualname__.__eq__('isroutine') == True
#
# Module-level functions have __qualname__ equal to their simple name.
# New to extra96.
# ---------------------------------------------------------------------------

table inspect_extra96.utility_fn_qualname:
  description: "inspect.getfullargspec/getargvalues/formatargvalues/classify_class_attrs/isroutine __qualname__ matches simple function name; module-level functions; wave 254; new to extra96"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectutilityfns96

  columns: [id, function, args, expected, description]
  rows:
    - [getfullargspec_qualname_eq,
       "getfullargspec.__qualname__.__eq__",
       ["getfullargspec"],
       true,
       "inspect.getfullargspec.__qualname__.__eq__('getfullargspec') == True — getfullargspec is defined at module scope in Lib/inspect.py; its __qualname__ has no enclosing class prefix; str.__eq__('getfullargspec') returns True; new to extra96"]
    - [getargvalues_qualname_eq,
       "getargvalues.__qualname__.__eq__",
       ["getargvalues"],
       true,
       "inspect.getargvalues.__qualname__.__eq__('getargvalues') == True — getargvalues is defined at module scope; __qualname__ is 'getargvalues'; str.__eq__('getargvalues') returns True; new to extra96"]
    - [formatargvalues_qualname_eq,
       "formatargvalues.__qualname__.__eq__",
       ["formatargvalues"],
       true,
       "inspect.formatargvalues.__qualname__.__eq__('formatargvalues') == True — formatargvalues is defined at module scope; __qualname__ is 'formatargvalues'; str.__eq__('formatargvalues') returns True; new to extra96"]
    - [classify_class_attrs_qualname_eq,
       "classify_class_attrs.__qualname__.__eq__",
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__qualname__.__eq__('classify_class_attrs') == True — classify_class_attrs is defined at module scope; __qualname__ is 'classify_class_attrs'; str.__eq__('classify_class_attrs') returns True; new to extra96"]
    - [isroutine_qualname_eq,
       "isroutine.__qualname__.__eq__",
       ["isroutine"],
       true,
       "inspect.isroutine.__qualname__.__eq__('isroutine') == True — isroutine is defined at module scope in Lib/inspect.py; __qualname__ is 'isroutine'; str.__eq__('isroutine') returns True; new to extra96"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra96
# ---------------------------------------------------------------------------

invariant inspect_extra96.isbuiltin_co_argcount_eq_1:
  description: "inspect.isbuiltin.__code__.co_argcount == 1 — one-arg predicate function; wave 254; new to extra96"
  kind: python_call_eq
  function: isbuiltin.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra96.formatargvalues_co_argcount_eq_8:
  description: "inspect.formatargvalues.__code__.co_argcount == 8 — takes 8 positional arguments; wave 254; new to extra96"
  kind: python_call_eq
  function: formatargvalues.__code__.co_argcount.__eq__
  args: [8]
  expected: true

invariant inspect_extra96.getfullargspec_co_name_eq:
  description: "inspect.getfullargspec.__code__.co_name == 'getfullargspec' — co_name matches function name for module-level functions; wave 254; new to extra96"
  kind: python_call_eq
  function: getfullargspec.__code__.co_name.__eq__
  args: ["getfullargspec"]
  expected: true

invariant inspect_extra96.classify_class_attrs_qualname_eq:
  description: "inspect.classify_class_attrs.__qualname__ == 'classify_class_attrs' — module-level function qualname; wave 254; new to extra96"
  kind: python_call_eq
  function: classify_class_attrs.__qualname__.__eq__
  args: ["classify_class_attrs"]
  expected: true

invariant inspect_extra96.isabstract_co_argcount_eq_1:
  description: "inspect.isabstract.__code__.co_argcount == 1 — one-arg predicate for abstract base class detection; wave 254; new to extra96"
  kind: python_call_eq
  function: isabstract.__code__.co_argcount.__eq__
  args: [1]
  expected: true
