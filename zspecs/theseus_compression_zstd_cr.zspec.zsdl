spec: theseus_compression_zstd_cr
version: ">=3.14"
backend: python_cleanroom(theseus_compression_zstd_cr)
blocks: compression.zstd

docs: https://docs.python.org/3/library/compression.zstd.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/compression.zstd.html"
  not_derived_from:
    - "CPython source: Lib/compression/zstd/"
  notes:
    - "Clean-room compression.zstd module (Python 3.14+). Do NOT import compression.zstd."

error_model: python_exceptions

invariant theseus_compression_zstd_cr.czstd2_compress:
  description: "compress/decompress roundtrip works"
  category: behavior
  kind: python_call_eq
  function: czstd2_compress
  args: []
  expected: true

invariant theseus_compression_zstd_cr.czstd2_classes:
  description: "ZstdCompressor and ZstdDecompressor classes exist"
  category: behavior
  kind: python_call_eq
  function: czstd2_classes
  args: []
  expected: true

invariant theseus_compression_zstd_cr.czstd2_version:
  description: "zstd_version string is accessible"
  category: behavior
  kind: python_call_eq
  function: czstd2_version
  args: []
  expected: true
