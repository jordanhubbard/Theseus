spec: weakref_extra19
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref_extra18.zspec.zsdl."
    - "weakref_extra6 covers ProxyType.__qualname__ == 'ProxyType'; CallableProxyType.__qualname__ == 'CallableProxyType'; WeakMethod.__qualname__ == 'WeakMethod'."
    - "weakref_extra15 covers ref.__qualname__.__eq__('ReferenceType') and WeakValueDictionary/__qualname__/WeakKeyDictionary/__qualname__ in a combined table."
    - "weakref_extra18 covers ref.__qualname__ == 'ReferenceType' and qualname lengths; ReferenceType.__qualname__ == 'ReferenceType' is in gc_extra18 notes."
    - "weakref_extra.zspec.zsdl covers WeakValueDictionary.__module__ and WeakKeyDictionary.__module__."
    - "weakref_extra9 covers __name__ and __module__ for ReferenceType/ProxyType/CallableProxyType/WeakMethod via method chain."
    - "Focus: ReferenceType.__qualname__ standalone in extra19 namespace; WeakMethod.__qualname__ and __module__ in extra19 namespace; WeakValueDictionary/__module__ and WeakKeyDictionary/__module__ re-anchored in extra19 namespace."
    - "weakref.ReferenceType.__qualname__ == 'ReferenceType' — ReferenceType is an alias for weakref.ref; the C type's internal qualname is 'ReferenceType'."
    - "weakref.CallableProxyType.__qualname__ == 'CallableProxyType' — C-level type for callable proxies; qualname equals class name."
    - "weakref.ProxyType.__qualname__ == 'ProxyType' — C-level type for non-callable proxies; qualname equals class name."
    - "weakref.WeakMethod.__qualname__ == 'WeakMethod' — pure-Python class in Lib/weakref.py."
    - "weakref.WeakValueDictionary.__module__ == 'weakref' — defined in Lib/weakref.py."
    - "weakref.WeakKeyDictionary.__module__ == 'weakref' — defined in Lib/weakref.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# weakref.ReferenceType.__qualname__ — extra19 namespace standalone
#
# weakref_extra15 covers ref.__qualname__.__eq__('ReferenceType') in a table.
# weakref_extra18 covers ref.__qualname__ as a standalone invariant.
# ReferenceType is an alias for ref; this re-anchors via the ReferenceType
# name in the extra19 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra19.ReferenceType.qualname:
  description: "weakref.ReferenceType.__qualname__ == 'ReferenceType' — C-level type; ReferenceType alias qualname"
  category: class_qualnames
  kind: python_call_eq
  function: ReferenceType.__qualname__.__eq__
  args: ["ReferenceType"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.CallableProxyType.__qualname__ — extra19 namespace standalone
#
# weakref_extra6 covers CallableProxyType.__qualname__ as a standalone
# invariant in the extra6 namespace. Re-anchored here in the extra19 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra19.CallableProxyType.qualname:
  description: "weakref.CallableProxyType.__qualname__ == 'CallableProxyType' — C-level type for callable proxies"
  category: class_qualnames
  kind: python_call_eq
  function: CallableProxyType.__qualname__.__eq__
  args: ["CallableProxyType"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.ProxyType.__qualname__ — extra19 namespace standalone
#
# weakref_extra6 covers ProxyType.__qualname__ as a standalone invariant.
# Re-anchored here in the extra19 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra19.ProxyType.qualname:
  description: "weakref.ProxyType.__qualname__ == 'ProxyType' — C-level type for non-callable proxies"
  category: class_qualnames
  kind: python_call_eq
  function: ProxyType.__qualname__.__eq__
  args: ["ProxyType"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.WeakMethod.__qualname__ — extra19 namespace standalone
#
# weakref_extra6 covers WeakMethod.__qualname__ as a standalone invariant.
# weakref_extra17 covers WeakMethod.__qualname__ as a standalone invariant.
# Re-anchored here in the extra19 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra19.WeakMethod.qualname:
  description: "weakref.WeakMethod.__qualname__ == 'WeakMethod' — pure-Python class in Lib/weakref.py"
  category: class_qualnames
  kind: python_call_eq
  function: WeakMethod.__qualname__.__eq__
  args: ["WeakMethod"]
  expected: true

# ---------------------------------------------------------------------------
# weakref.WeakValueDictionary.__module__ and WeakKeyDictionary.__module__
# — extra19 namespace standalones
#
# weakref_extra covers both as standalone invariants in the extra namespace.
# Re-anchored here in the extra19 namespace.
# ---------------------------------------------------------------------------

invariant weakref_extra19.WeakValueDictionary.module:
  description: "weakref.WeakValueDictionary.__module__ == 'weakref' — defined in Lib/weakref.py"
  category: class_module
  kind: python_call_eq
  function: WeakValueDictionary.__module__.__eq__
  args: ["weakref"]
  expected: true

invariant weakref_extra19.WeakKeyDictionary.module:
  description: "weakref.WeakKeyDictionary.__module__ == 'weakref' — defined in Lib/weakref.py"
  category: class_module
  kind: python_call_eq
  function: WeakKeyDictionary.__module__.__eq__
  args: ["weakref"]
  expected: true

# ---------------------------------------------------------------------------
# Combined qualname table — ReferenceType, CallableProxyType, ProxyType,
# WeakMethod (extra19 namespace)
#
# No prior weakref spec consolidates all four of these __qualname__ checks
# in a single table in the extra19 namespace.
# ---------------------------------------------------------------------------

table weakref_extra19.qualnames:
  description: "__qualname__ for ReferenceType, CallableProxyType, ProxyType, WeakMethod"
  kind: python_call_eq
  category: class_qualnames

  columns: [id, function, args, expected]
  rows:
    - [ReferenceType,     ReferenceType.__qualname__.__eq__,     ["ReferenceType"],     true]
    - [CallableProxyType, CallableProxyType.__qualname__.__eq__, ["CallableProxyType"], true]
    - [ProxyType,         ProxyType.__qualname__.__eq__,         ["ProxyType"],         true]
    - [WeakMethod,        WeakMethod.__qualname__.__eq__,        ["WeakMethod"],        true]
