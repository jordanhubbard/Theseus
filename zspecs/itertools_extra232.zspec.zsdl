       [],
       2,
       "itertools.cycle.__mro__.__len__() == 2 — cycle inherits directly from object with no intermediate classes; the MRO has exactly 2 entries: [cycle, object]; new to extra232"]
    - [cycle_name_eq,
       cycle.__name__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — cycle is a C extension type for cycling indefinitely over an iterable; __name__ is 'cycle' (len=5); new to extra232"]
    - [cycle_module_eq,
       cycle.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.cycle.__module__.__eq__('itertools') == True — cycle is defined in the itertools C extension module; __module__ is 'itertools'; new to extra232"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra232
# ---------------------------------------------------------------------------

invariant itertools_extra232.count_mro_0_eq:
  description: "itertools.count.__mro__[0].__name__ == 'count' — count is first in its own MRO; new to extra232"
  kind: python_call_eq
  function: "count.__mro__[0].__name__.__eq__"
  args: ["count"]
  expected: true

invariant itertools_extra232.count_mro_1_eq:
  description: "itertools.count.__mro__[1].__name__ == 'object' — count's base class is object; new to extra232"
  kind: python_call_eq
  function: "count.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra232.count_mro_len_2:
  description: "itertools.count.__mro__.__len__() == 2 — count MRO has exactly 2 entries; new to extra232"
  kind: python_call_eq
  function: count.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra232.count_name_eq:
  description: "itertools.count.__name__ == 'count'; new to extra232"
  kind: python_call_eq
  function: count.__name__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra232.count_module_eq:
  description: "itertools.count.__module__ == 'itertools'; new to extra232"
  kind: python_call_eq
  function: count.__module__.__eq__
  args: ["itertools"]
  expected: true

