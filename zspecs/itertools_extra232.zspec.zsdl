spec: itertools_extra232
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.count, itertools.repeat, and itertools.cycle class hierarchy contracts."
    - "itertools.count.__mro__[0].__name__ == 'count' — count is the first entry in its own MRO. Verified with Python 3.14.3."
    - "itertools.count.__mro__[1].__name__ == 'object' — count's base class is object; MRO has exactly 2 entries. Verified with Python 3.14.3."
    - "itertools.count.__mro__.__len__() == 2 — count inherits directly from object with no intermediate classes. Verified with Python 3.14.3."
    - "itertools.repeat.__mro__[0].__name__ == 'repeat' — repeat is the first entry in its own MRO. Verified with Python 3.14.3."
    - "itertools.repeat.__mro__[1].__name__ == 'object' — repeat's base class is object. Verified with Python 3.14.3."
    - "itertools.cycle.__mro__[0].__name__ == 'cycle' — cycle is the first entry in its own MRO. Verified with Python 3.14.3."
    - "itertools.cycle.__mro__[1].__name__ == 'object' — cycle's base class is object. Verified with Python 3.14.3."
    - "itertools.count.__name__ == 'count' (len=5); itertools.repeat.__name__ == 'repeat' (len=6); itertools.cycle.__name__ == 'cycle' (len=5). Verified with Python 3.14.3."
    - "itertools.count.__module__ == 'itertools'; itertools.repeat.__module__ == 'itertools'; itertools.cycle.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.count class hierarchy contracts
#
# itertools.count.__mro__[0].__name__ == 'count'
# itertools.count.__mro__[1].__name__ == 'object'
# itertools.count.__mro__.__len__() == 2
# itertools.count.__name__ == 'count' (len=5)
# itertools.count.__module__ == 'itertools'
#
# count is a C extension type with a 2-entry MRO: [count, object].
# New to extra232.
# ---------------------------------------------------------------------------

table itertools_extra232.count_hierarchy:
  description: "itertools.count class hierarchy contracts: MRO entries, name, module; direct subclass of object; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra232counthier

  columns: [id, function, args, expected, description]
  rows:
    - [count_mro_0_eq,
       "count.__mro__[0].__name__.__eq__",
       ["count"],
       true,
       "itertools.count.__mro__[0].__name__.__eq__('count') == True — count is the first (self) entry in its MRO; a C extension type in itertoolsmodule.c; __mro__[0].__name__ is 'count'; new to extra232"]
    - [count_mro_1_eq,
       "count.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.count.__mro__[1].__name__.__eq__('object') == True — count's only base class is object; MRO index 1 is object; new to extra232"]
    - [count_mro_len_2,
       count.__mro__.__len__,
       [],
       2,
       "itertools.count.__mro__.__len__() == 2 — count inherits directly from object with no intermediate classes; the MRO has exactly 2 entries: [count, object]; new to extra232"]
    - [count_name_eq,
       count.__name__.__eq__,
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — count is a C extension type for infinite counting from a start value; __name__ is 'count' (len=5); new to extra232"]
    - [count_module_eq,
       count.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — count is defined in the itertools C extension module; __module__ is 'itertools'; new to extra232"]

# ---------------------------------------------------------------------------
# Table 2: itertools.repeat class hierarchy contracts
#
# itertools.repeat.__mro__[0].__name__ == 'repeat'
# itertools.repeat.__mro__[1].__name__ == 'object'
# itertools.repeat.__mro__.__len__() == 2
# itertools.repeat.__name__ == 'repeat' (len=6)
# itertools.repeat.__module__ == 'itertools'
#
# repeat is a C extension type with a 2-entry MRO: [repeat, object].
# New to extra232.
# ---------------------------------------------------------------------------

table itertools_extra232.repeat_hierarchy:
  description: "itertools.repeat class hierarchy contracts: MRO entries, name, module; direct subclass of object; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra232repeathier

  columns: [id, function, args, expected, description]
  rows:
    - [repeat_mro_0_eq,
       "repeat.__mro__[0].__name__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__mro__[0].__name__.__eq__('repeat') == True — repeat is the first (self) entry in its MRO; a C extension type in itertoolsmodule.c; __mro__[0].__name__ is 'repeat'; new to extra232"]
    - [repeat_mro_1_eq,
       "repeat.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.repeat.__mro__[1].__name__.__eq__('object') == True — repeat's only base class is object; MRO index 1 is object; new to extra232"]
    - [repeat_mro_len_2,
       repeat.__mro__.__len__,
       [],
       2,
       "itertools.repeat.__mro__.__len__() == 2 — repeat inherits directly from object with no intermediate classes; the MRO has exactly 2 entries: [repeat, object]; new to extra232"]
    - [repeat_name_eq,
       repeat.__name__.__eq__,
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — repeat is a C extension type for repeating a value; __name__ is 'repeat' (len=6); new to extra232"]
    - [repeat_module_eq,
       repeat.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.repeat.__module__.__eq__('itertools') == True — repeat is defined in the itertools C extension module; __module__ is 'itertools'; new to extra232"]

