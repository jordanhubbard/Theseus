table itertools_extra232.cycle_hierarchy:
  description: "itertools.cycle class hierarchy contracts: MRO entries, name, module; direct subclass of object; new to extra232"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra232cyclehier

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_mro_0_eq,
       "cycle.__mro__[0].__name__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__mro__[0].__name__.__eq__('cycle') == True — cycle is the first (self) entry in its MRO; a C extension type in itertoolsmodule.c; __mro__[0].__name__ is 'cycle'; new to extra232"]
    - [cycle_mro_1_eq,
       "cycle.__mro__[1].__name__.__eq__",
       ["object"],
