# co_varnames: (self, max_workers, mp_context, initializer, initargs, max_tasks_per_child, queue_size)
# ---------------------------------------------------------------------------

table concurrent_futures_extra71.ProcessPoolExecutor_init_varnames_len:
  description: "concurrent.futures ProcessPoolExecutor.__init__ co_varnames length check in cfmore71 namespace — wave 240 theme: ProcessPoolExecutor.__init__ code object details; co_varnames.__len__()==7 (self, max_workers, mp_context, initializer, initargs, max_tasks_per_child, queue_size); co_argcount==5 cross-check; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore71c

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_init_varnames_len,    ProcessPoolExecutor.__init__.__code__.co_varnames.__len__, [], 7,          "ProcessPoolExecutor.__init__.__code__.co_varnames.__len__() == 7 — (self, max_workers, mp_context, initializer, initargs, max_tasks_per_child, queue_size); verified with Python 3.14.3"]
    - [ppe_init_co_argcount_eq,  ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__,  [5], true,     "ProcessPoolExecutor.__init__.__code__.co_argcount == 5 — 5 positional-or-keyword params; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra71
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra71.ProcessPoolExecutor_init_co_name:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_name.__eq__('__init__') returns True — Python method in concurrent/futures/process.py; co_name is '__init__'; NEW in extra71: first standalone co_name invariant for ProcessPoolExecutor.__init__ in cfmore71 namespace; wave 240; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ProcessPoolExecutor.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant concurrent_futures_extra71.ProcessPoolExecutor_init_co_argcount:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__(5) returns True — self + max_workers + mp_context + initializer + initargs = 5; max_tasks_per_child and queue_size are keyword-only; NEW in extra71: first standalone co_argcount invariant for ProcessPoolExecutor.__init__ in cfmore71 namespace; wave 240; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__
  args: [5]
  expected: true

invariant concurrent_futures_extra71.InvalidStateError_mro_len:
  description: "concurrent.futures.InvalidStateError.__mro__.__len__() == 5 — MRO is (InvalidStateError, Error, Exception, BaseException, object); InvalidStateError subclasses the internal Error class; NEW in extra71: first standalone __mro__.__len__ invariant for InvalidStateError in cfmore71 namespace; wave 240; verified with Python 3.14.3"
  category: hierarchy
  kind: python_call_eq
  function: InvalidStateError.__mro__.__len__
  args: []
  expected: 5

invariant concurrent_futures_extra71.Executor_shutdown_co_name:
  description: "concurrent.futures.Executor.shutdown.__code__.co_name.__eq__('shutdown') returns True — Executor.shutdown is a Python method in concurrent/futures/_base.py; co_name is 'shutdown'; NEW in extra71: first standalone co_name invariant for Executor.shutdown in cfmore71 namespace; wave 240; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Executor.shutdown.__code__.co_name.__eq__
  args: ["shutdown"]
  expected: true

invariant concurrent_futures_extra71.Executor_shutdown_co_argcount:
  description: "concurrent.futures.Executor.shutdown.__code__.co_argcount.__eq__(2) returns True — self + wait are positional-or-keyword; cancel_futures is keyword-only; co_argcount is 2; NEW in extra71: first standalone co_argcount invariant for Executor.shutdown in cfmore71 namespace; wave 240; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Executor.shutdown.__code__.co_argcount.__eq__
  args: [2]
  expected: true
