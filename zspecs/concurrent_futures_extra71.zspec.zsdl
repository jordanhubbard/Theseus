spec: concurrent_futures_extra71
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra70.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, exception identity and bases, submit/map/shutdown __qualname__, class __dict__/__mro__/__all__ metadata, method qualname/name equality and length tables, __loader__/__spec__/__file__/__cached__ class names, __spec__ attributes, code object attribute chains, __defaults__/__kwdefaults__ class names, doc content, ThreadPoolExecutor/Future __init__ code object attributes, ThreadPoolExecutor MRO entry names, exception __name__/__module__/__qualname__, Future.result/cancel code objects, Executor.map/submit code objects, as_completed/wait code objects, ThreadPoolExecutor.__init__ co_varnames length."
    - "This spec covers (cfmore71 namespace): wave 240 theme — concurrent.futures ProcessPoolExecutor code attrs + InvalidStateError hierarchy. NEW in extra71: ProcessPoolExecutor.__init__.__code__.co_name=='__init__'; ProcessPoolExecutor.__init__.__code__.co_argcount==5 (self + max_workers + mp_context + initializer + initargs; max_tasks_per_child is keyword-only); ProcessPoolExecutor.__init__.__code__.co_varnames.__class__.__name__=='tuple'; InvalidStateError.__mro__.__len__()==5 (InvalidStateError, Error, Exception, BaseException, object); CancelledError.__mro__.__len__()==5; TimeoutError.__mro__.__len__()==5 (via OSError); Executor.shutdown.__code__.co_name=='shutdown'; Executor.shutdown.__code__.co_argcount==2 (self + wait)."
    - "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_name == '__init__'. ProcessPoolExecutor.__init__ is a Python method in concurrent/futures/process.py; its code object's co_name is '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount == 5. ProcessPoolExecutor.__init__ signature: def __init__(self, max_workers=None, mp_context=None, initializer=None, initargs=(), *, max_tasks_per_child=None, queue_size=None): — co_argcount counts positional-or-keyword parameters only (self, max_workers, mp_context, initializer, initargs = 5); max_tasks_per_child and queue_size are keyword-only. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'. Code object co_varnames is always a tuple in CPython; __class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__mro__.__len__() == 5. MRO is (InvalidStateError, Error, Exception, BaseException, object) — 5 entries. InvalidStateError subclasses the internal Error class which subclasses Exception. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.CancelledError.__mro__.__len__() == 5. MRO is (CancelledError, Error, Exception, BaseException, object) — 5 entries. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.TimeoutError.__mro__.__len__() == 5. MRO is (TimeoutError, OSError, Exception, BaseException, object) — 5 entries. concurrent.futures.TimeoutError is the built-in TimeoutError via OSError. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.shutdown.__code__.co_name == 'shutdown'. Executor.shutdown is a Python method in concurrent/futures/_base.py; co_name is 'shutdown'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.shutdown.__code__.co_argcount == 2. Executor.shutdown(self, wait=True, *, cancel_futures=False): — co_argcount is 2 (self + wait; cancel_futures is keyword-only). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ProcessPoolExecutor.__init__ code object checks — extra71
#
# Wave 240 theme: ProcessPoolExecutor code attrs + InvalidStateError hierarchy.
#
# ProcessPoolExecutor.__init__.__code__.co_name == '__init__'
# ProcessPoolExecutor.__init__.__code__.co_argcount == 5
# ProcessPoolExecutor.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'
# ---------------------------------------------------------------------------

table concurrent_futures_extra71.ProcessPoolExecutor_init_code:
  description: "concurrent.futures ProcessPoolExecutor.__init__ code object attribute checks in cfmore71 namespace — wave 240 theme: ProcessPoolExecutor code attrs; ProcessPoolExecutor.__init__.__code__.co_name=='__init__'; ProcessPoolExecutor.__init__.__code__.co_argcount==5 (self + max_workers + mp_context + initializer + initargs; max_tasks_per_child and queue_size are keyword-only); ProcessPoolExecutor.__init__.__code__.co_varnames.__class__.__name__=='tuple'; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore71

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_init_co_name,            ProcessPoolExecutor.__init__.__code__.co_name.__eq__,                    ["__init__"], true,    "ProcessPoolExecutor.__init__.__code__.co_name == '__init__' — Python method in concurrent/futures/process.py; verified with Python 3.14.3"]
    - [ppe_init_co_argcount,        ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__,                [5],          true,    "ProcessPoolExecutor.__init__.__code__.co_argcount == 5 — self + max_workers + mp_context + initializer + initargs; keyword-only excluded; verified with Python 3.14.3"]
    - [ppe_init_varnames_classname, ProcessPoolExecutor.__init__.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"],    true, "ProcessPoolExecutor.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple in CPython; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# InvalidStateError and CancelledError MRO checks — extra71
#
# InvalidStateError.__mro__.__len__() == 5
# CancelledError.__mro__.__len__() == 5
# ---------------------------------------------------------------------------

table concurrent_futures_extra71.exception_mro_len:
  description: "concurrent.futures InvalidStateError and CancelledError MRO length checks in cfmore71 namespace — wave 240 theme: exception hierarchy; InvalidStateError.__mro__.__len__()==5 (InvalidStateError, Error, Exception, BaseException, object); CancelledError.__mro__.__len__()==5 (CancelledError, Error, Exception, BaseException, object); verified with Python 3.14.3"
  kind: python_call_eq
  category: hierarchy
  id_prefix: cfmore71a

  columns: [id, function, args, expected, description]
  rows:
    - [invalidstateerror_mro_len, InvalidStateError.__mro__.__len__, [], 5, "InvalidStateError.__mro__.__len__() == 5 — MRO: (InvalidStateError, Error, Exception, BaseException, object); verified with Python 3.14.3"]
    - [cancellederror_mro_len,    CancelledError.__mro__.__len__,    [], 5, "CancelledError.__mro__.__len__() == 5 — MRO: (CancelledError, Error, Exception, BaseException, object); verified with Python 3.14.3"]
    - [timeouterror_mro_len,      TimeoutError.__mro__.__len__,      [], 5, "TimeoutError.__mro__.__len__() == 5 — MRO: (TimeoutError, OSError, Exception, BaseException, object); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Executor.shutdown code object checks — extra71
#
# Executor.shutdown.__code__.co_name == 'shutdown'
# Executor.shutdown.__code__.co_argcount == 2 (self + wait)
# ---------------------------------------------------------------------------

table concurrent_futures_extra71.Executor_shutdown_code:
  description: "concurrent.futures Executor.shutdown code object attribute checks in cfmore71 namespace — wave 240 theme: Executor.shutdown code attrs; Executor.shutdown.__code__.co_name=='shutdown'; Executor.shutdown.__code__.co_argcount==2 (self + wait; cancel_futures is keyword-only); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore71b

  columns: [id, function, args, expected, description]
  rows:
    - [executor_shutdown_co_name,     Executor.shutdown.__code__.co_name.__eq__,     ["shutdown"], true, "Executor.shutdown.__code__.co_name == 'shutdown' — Python method in concurrent/futures/_base.py; verified with Python 3.14.3"]
    - [executor_shutdown_co_argcount, Executor.shutdown.__code__.co_argcount.__eq__, [2],          true, "Executor.shutdown.__code__.co_argcount == 2 — self + wait; cancel_futures is keyword-only; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ProcessPoolExecutor.__init__ co_varnames length — extra71
#
