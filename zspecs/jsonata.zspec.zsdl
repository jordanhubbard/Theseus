spec: jsonata
version: ">=2.0.0"
backend: node(jsonata)

docs: https://jsonata.org

provenance:
  derived_from:
    - "JSONata docs — https://docs.jsonata.org"
    - "Test vectors verified with jsonata via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "jsonata source"
  notes:
    - "Lightweight query/transformation language for JSON — like XPath for JSON."
    - "Install: npm install jsonata"
    - "v2 CJS; module export IS the expression-compile factory."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Compiler throws JsonataError on malformed expressions; evaluate() returns Promise."
  stderr: "null"
  stickiness: "Compiled expressions are reusable across evaluate() calls."
  codes: {}

invariant jsonata.module_is_function:
  description: "Module export is the expression-compile factory"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant jsonata.compiled_expression_is_object:
  description: "jsonata('...') returns an Object (the expression)"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["a + b"]
  chain:
    - {get: "constructor.name"}
  expected: "Object"

invariant jsonata.expression_has_evaluate:
  description: "Compiled expression has .evaluate (async)"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["a + b"]
  chain:
    - {get: "evaluate.constructor.name"}
  expected: "AsyncFunction"

invariant jsonata.expression_has_assign:
  description: "Compiled expression has .assign for variables"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["a"]
  chain:
    - {get: "assign.constructor.name"}
  expected: "Function"

invariant jsonata.expression_has_registerFunction:
  description: "Compiled expression has .registerFunction (custom funcs)"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["a"]
  chain:
    - {get: "registerFunction.constructor.name"}
  expected: "Function"

invariant jsonata.expression_has_ast:
  description: "Compiled expression has .ast (parse tree access)"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["a + b"]
  chain:
    - {get: "ast.constructor.name"}
  expected: "Function"
