  notes:
    - "This spec covers: itertools.islice/__doc__.__class__.__name__ 'str'; itertools.starmap/__doc__.__class__.__name__ 'str'; itertools.zip_longest/__doc__.__class__.__name__ 'str'; itertools.accumulate/__doc__.__class__.__name__ 'str'; itertools.groupby/__doc__.__class__.__name__ 'str'; itertools.tee __doc__.__class__.__name__ 'str', __class__.__name__ 'builtin_function_or_method'; itertools.pairwise.__doc__.__class__.__name__ 'str' (Python 3.10+) (Wave 285)."
    - "itertools.islice.__doc__.__class__.__name__ == 'str' — islice is a C extension type; its __doc__ is a Python str. Verified with Python 3.14.3."
    - "itertools.starmap.__doc__.__class__.__name__ == 'str' — starmap is a C extension type; its __doc__ is a Python str. Verified with Python 3.14.3."
    - "itertools.zip_longest.__doc__.__class__.__name__ == 'str' — zip_longest is a C extension type; its __doc__ is a Python str. Verified with Python 3.14.3."
    - "itertools.accumulate.__doc__.__class__.__name__ == 'str' — accumulate is a C extension type; its __doc__ is a Python str. Verified with Python 3.14.3."
    - "itertools.groupby.__doc__.__class__.__name__ == 'str' — groupby is a C extension type; its __doc__ is a Python str. Verified with Python 3.14.3."
    - "itertools.tee.__doc__.__class__.__name__ == 'str' — tee is a C builtin function (not a class); its __doc__ is a Python str. Verified with Python 3.14.3."
    - "itertools.tee.__class__.__name__ == 'builtin_function_or_method' — tee is a C builtin function, not a class like the other itertools types; its __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.pairwise.__doc__.__class__.__name__ == 'str' — pairwise is a C extension type added in Python 3.10; its __doc__ is a Python str. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools islice, starmap, zip_longest, accumulate __doc__ class
#
# Wave 285 theme: itertools C extension type __doc__ attribute class identity.
#
# itertools.islice.__doc__.__class__.__name__ == 'str'
# itertools.starmap.__doc__.__class__.__name__ == 'str'
# itertools.zip_longest.__doc__.__class__.__name__ == 'str'
# itertools.accumulate.__doc__.__class__.__name__ == 'str'
#
# All itertools types (islice, starmap, zip_longest, accumulate) are C extension
# types defined in itertoolsmodule.c. Each one has a __doc__ that is a Python
# str object describing its behavior. New to extra156.
# ---------------------------------------------------------------------------

table itertools_extra156.islice_starmap_zip_longest_accumulate_doc_class:
  description: "itertools islice/starmap/zip_longest/accumulate: __doc__.__class__.__name__ 'str'; C extension types with str doc attributes; wave 285; new to extra156"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsiszlac156

  columns: [id, function, args, expected, description]
  rows:
    - [islice_doc_class_eq_str,
       "islice.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.islice.__doc__.__class__.__name__.__eq__('str') == True — islice is a C extension type that returns an iterator from a slice of another iterator; its __doc__ is a Python str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra156"]
    - [starmap_doc_class_eq_str,
       "starmap.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.starmap.__doc__.__class__.__name__.__eq__('str') == True — starmap is a C extension type that maps a function over iterables of argument tuples using starmap(func, iterable); its __doc__ is a Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra156"]
    - [zip_longest_doc_class_eq_str,
       "zip_longest.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.zip_longest.__doc__.__class__.__name__.__eq__('str') == True — zip_longest is a C extension type that zips iterables filling missing values with a fillvalue; its __doc__ is a Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra156"]
    - [accumulate_doc_class_eq_str,
       "accumulate.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.accumulate.__doc__.__class__.__name__.__eq__('str') == True — accumulate is a C extension type that returns running totals or accumulated results of a binary function; its __doc__ is a Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra156"]

# ---------------------------------------------------------------------------
# Table 2: itertools groupby, tee class identity, and pairwise __doc__ class
#
# Wave 285 theme: itertools groupby __doc__ class; tee C function identity;
# pairwise __doc__ class (Python 3.10+).
#
# itertools.groupby.__doc__.__class__.__name__ == 'str'
# itertools.tee.__doc__.__class__.__name__ == 'str'
# itertools.tee.__class__.__name__ == 'builtin_function_or_method'
# itertools.pairwise.__doc__.__class__.__name__ == 'str'
#
# groupby is a C extension type like the others. tee is unusual: it is a
# C builtin function (builtin_function_or_method) rather than a class/type;
# it creates n independent iterators from a single one. pairwise was added in
# Python 3.10 and is a C extension type producing consecutive overlapping pairs.
# New to extra156.
# ---------------------------------------------------------------------------

table itertools_extra156.groupby_tee_pairwise_doc_and_class:
  description: "itertools groupby: __doc__ class 'str'; itertools.tee: __doc__ class 'str', __class__.__name__ 'builtin_function_or_method'; pairwise (3.10+): __doc__ class 'str'; wave 285; new to extra156"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsgtpc156

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_doc_class_eq_str,
       "groupby.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.groupby.__doc__.__class__.__name__.__eq__('str') == True — groupby is a C extension type that groups consecutive elements with the same key; its __doc__ is a Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra156"]
    - [tee_doc_class_eq_str,
       "tee.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.tee.__doc__.__class__.__name__.__eq__('str') == True — tee is a C builtin function that creates n independent iterators from a single iterable; its __doc__ is a Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra156"]
    - [tee_class_eq_builtin_function,
       "tee.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.tee.__class__.__name__.__eq__('builtin_function_or_method') == True — unlike other itertools objects which are C extension types (classes), tee is a C builtin function; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra156"]
    - [pairwise_doc_class_eq_str,
       "pairwise.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.pairwise.__doc__.__class__.__name__.__eq__('str') == True — pairwise is a C extension type added in Python 3.10 that yields consecutive overlapping pairs from an iterable; its __doc__ is a Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra156"]

