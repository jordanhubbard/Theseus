spec: pathlib_extra486
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib.PurePath method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "with_stem and is_relative_to were added in Python 3.9"
    - "Checks class-level method __name__ attributes on PurePath"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra486.purepath_method_names:
  description: "pathlib.PurePath class-level method __name__ identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: pp

  columns: [id, function, args, expected]
  rows:
    - [pp001, pathlib.PurePath.joinpath.__name__.__eq__,       ["joinpath"],       true]
    - [pp002, pathlib.PurePath.with_name.__name__.__eq__,      ["with_name"],      true]
    - [pp003, pathlib.PurePath.with_stem.__name__.__eq__,      ["with_stem"],      true]
    - [pp004, pathlib.PurePath.with_suffix.__name__.__eq__,    ["with_suffix"],    true]
    - [pp005, pathlib.PurePath.relative_to.__name__.__eq__,    ["relative_to"],    true]
    - [pp006, pathlib.PurePath.is_relative_to.__name__.__eq__, ["is_relative_to"], true]
    - [pp007, pathlib.PurePath.match.__name__.__eq__,          ["match"],          true]
    - [pp008, pathlib.PurePath.as_posix.__name__.__eq__,       ["as_posix"],       true]
    - [pp009, pathlib.PurePath.as_uri.__name__.__eq__,         ["as_uri"],         true]
    - [pp010, pathlib.PurePath.is_absolute.__name__.__eq__,    ["is_absolute"],    true]
    - [pp011, pathlib.PurePath.is_reserved.__name__.__eq__,    ["is_reserved"],    true]
