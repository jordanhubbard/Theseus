spec: getpass
version: ">=3.0"
backend: python_module(getpass)

docs: https://docs.python.org/3/library/getpass.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/getpass.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-08"
    - "getpass source: getpass.py (PSF; source inspection permitted)"
  not_derived_from:
    - "getpass source: terminal interaction code"
  notes:
    - "getpass.getpass() is not tested because it requires an interactive terminal."
    - "getpass.getuser() returns the current login name — its exact value is environment-dependent and not pinned."
    - "getpass.getpass.__name__ is 'unix_getpass' on POSIX and 'win_getpass' on Windows; not tested here."
    - "GetPassWarning is a UserWarning subclass."
  created_at: "2026-04-08T00:00:00Z"

error_model:
  semantics: "getpass.getpass() may raise GetPassWarning when echo cannot be suppressed. getuser() raises KeyError when no user can be determined."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant getpass.GetPassWarning_name:
  description: "GetPassWarning class name is 'GetPassWarning'"
  category: classnames
  kind: python_call_eq
  function: GetPassWarning.__name__.__eq__
  args: ["GetPassWarning"]
  expected: true

invariant getpass.GetPassWarning_module:
  description: "GetPassWarning.__module__ is 'getpass'"
  category: classnames
  kind: python_call_eq
  function: GetPassWarning.__module__.__eq__
  args: ["getpass"]
  expected: true

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant getpass.getuser_name:
  description: "getuser function name is 'getuser'"
  category: functions
  kind: python_call_eq
  function: getuser.__name__.__eq__
  args: ["getuser"]
  expected: true

invariant getpass.getuser_module:
  description: "getuser.__module__ is 'getpass'"
  category: functions
  kind: python_call_eq
  function: getuser.__module__.__eq__
  args: ["getpass"]
  expected: true

# ---------------------------------------------------------------------------
# getuser runtime behaviour
# ---------------------------------------------------------------------------

invariant getpass.getuser_returns_nonempty:
  description: "getuser() returns a non-empty string (any str > '' is true in Python's lexicographic order)"
  category: functions
  kind: python_call_eq
  function: getuser
  args: []
  method: __gt__
  method_args: [""]
  expected: true
