spec: inspect_extra101
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra100

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra100.zspec.zsdl."
    - "This spec covers: inspect.__spec__ class name ('ModuleSpec') and class module ('_frozen_importlib'); inspect.__loader__ class name ('SourceFileLoader') and class module ('_frozen_importlib_external'); inspect.__package__ is empty string with length 0; inspect.__spec__.name == 'inspect' and has_location == True; inspect.__loader__.name == 'inspect'; wave 258."
    - "inspect.__spec__.__class__.__name__ == 'ModuleSpec' — inspect is a pure-Python module; its ModuleSpec is the import record. Verified with Python 3.14.3."
    - "inspect.__spec__.__class__.__module__ == '_frozen_importlib'. Verified with Python 3.14.3."
    - "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect.py is loaded from a .py file. Verified with Python 3.14.3."
    - "inspect.__loader__.__class__.__module__ == '_frozen_importlib_external'. Verified with Python 3.14.3."
    - "inspect.__package__ == '' — empty string (top-level module). Verified with Python 3.14.3."
    - "inspect.__spec__.name == 'inspect' (len 7). Verified with Python 3.14.3."
    - "inspect.__spec__.has_location == True — inspect.py has a file system path. Verified with Python 3.14.3."
    - "inspect.__loader__.name == 'inspect' (len 7). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.__spec__ class identity
#
# Wave 258 theme: inspect.__spec__ ModuleSpec class names.
#
# inspect.__spec__.__class__.__name__ == 'ModuleSpec'
# inspect.__spec__.__class__.__module__ == '_frozen_importlib'
# inspect.__spec__.__class__.__qualname__ == 'ModuleSpec'
# len('ModuleSpec') == 10
# len('_frozen_importlib') == 17
# inspect.__spec__.name == 'inspect' (len 7)
# inspect.__spec__.has_location == True
#
# inspect is a pure-Python module. Its ModuleSpec.origin points to the
# .py file on disk. has_location is True. New to extra101.
# ---------------------------------------------------------------------------

table inspect_extra101.spec_class_identity:
  description: "inspect.__spec__.__class__.__name__=='ModuleSpec'; __module__=='_frozen_importlib'; __qualname__=='ModuleSpec'; spec.name=='inspect'; spec.has_location==True; wave 258; new to extra101"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectspec101

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq_ModuleSpec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "inspect.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — inspect.__spec__ is the ModuleSpec object created by the import system for the inspect module; ModuleSpec is the import system's module descriptor class defined in importlib._bootstrap; __spec__.__class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra101"]
    - [spec_class_module_eq_frozen_importlib,
       "__spec__.__class__.__module__.__eq__",
       ["_frozen_importlib"],
       true,
       "inspect.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True — ModuleSpec is defined in importlib._bootstrap, which CPython freezes into the interpreter as '_frozen_importlib'; its __module__ is '_frozen_importlib'; str.__eq__('_frozen_importlib') returns True; new to extra101"]
    - [spec_class_qualname_eq_ModuleSpec,
       "__spec__.__class__.__qualname__.__eq__",
       ["ModuleSpec"],
       true,
       "inspect.__spec__.__class__.__qualname__.__eq__('ModuleSpec') == True — ModuleSpec is defined at module scope in _frozen_importlib; its __qualname__ is the simple class name 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra101"]
    - [spec_class_name_len_eq_10,
       "__spec__.__class__.__name__.__len__",
       [],
       10,
       "inspect.__spec__.__class__.__name__.__len__() == 10 — __class__.__name__ is 'ModuleSpec'; len('ModuleSpec') == 10 (M-o-d-u-l-e-S-p-e-c); new to extra101"]
    - [spec_name_eq_inspect,
       "__spec__.name.__eq__",
       ["inspect"],
       true,
       "inspect.__spec__.name.__eq__('inspect') == True — the ModuleSpec.name attribute holds the dotted name of the module; for the inspect module it is 'inspect'; str.__eq__('inspect') returns True; new to extra101"]
    - [spec_name_len_eq_7,
       "__spec__.name.__len__",
       [],
       7,
       "inspect.__spec__.name.__len__() == 7 — __spec__.name is 'inspect'; len('inspect') == 7 (i-n-s-p-e-c-t); new to extra101"]
    - [spec_has_location_eq_true,
       "__spec__.has_location.__eq__",
       [true],
       true,
       "inspect.__spec__.has_location.__eq__(True) == True — inspect is a pure-Python module loaded from inspect.py on the file system; has_location is True because the origin is a path to inspect.py; bool.__eq__(True) returns True; new to extra101"]

# ---------------------------------------------------------------------------
# Table 2: inspect.__loader__ class identity
#
# Wave 258 theme: inspect.__loader__ SourceFileLoader class names.
#
# inspect.__loader__.__class__.__name__ == 'SourceFileLoader'
# inspect.__loader__.__class__.__module__ == '_frozen_importlib_external'
# inspect.__loader__.__class__.__qualname__ == 'SourceFileLoader'
# len('SourceFileLoader') == 16
# len('_frozen_importlib_external') == 26
# inspect.__loader__.name == 'inspect'
#
# SourceFileLoader is CPython's loader for pure-Python .py files.
# It is defined in importlib._bootstrap_external, frozen as
# _frozen_importlib_external. New to extra101.
# ---------------------------------------------------------------------------

table inspect_extra101.loader_class_identity:
  description: "inspect.__loader__.__class__.__name__=='SourceFileLoader'; __module__=='_frozen_importlib_external'; __qualname__=='SourceFileLoader'; loader.name=='inspect'; wave 258; new to extra101"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectspec101

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name_eq_SourceFileLoader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — inspect is a pure-Python module loaded from inspect.py; CPython uses SourceFileLoader for .py source files; the loader's __class__.__name__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra101"]
    - [loader_class_module_eq_frozen_importlib_external,
       "__loader__.__class__.__module__.__eq__",
       ["_frozen_importlib_external"],
       true,
       "inspect.__loader__.__class__.__module__.__eq__('_frozen_importlib_external') == True — SourceFileLoader is defined in importlib._bootstrap_external, which CPython freezes as '_frozen_importlib_external'; the loader class's __module__ is '_frozen_importlib_external'; str.__eq__('_frozen_importlib_external') returns True; new to extra101"]
    - [loader_class_qualname_eq_SourceFileLoader,
       "__loader__.__class__.__qualname__.__eq__",
       ["SourceFileLoader"],
       true,
       "inspect.__loader__.__class__.__qualname__.__eq__('SourceFileLoader') == True — SourceFileLoader is defined at module scope in _frozen_importlib_external; its __qualname__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra101"]
    - [loader_class_name_len_eq_16,
       "__loader__.__class__.__name__.__len__",
       [],
       16,
       "inspect.__loader__.__class__.__name__.__len__() == 16 — __class__.__name__ is 'SourceFileLoader'; len('SourceFileLoader') == 16 (S-o-u-r-c-e-F-i-l-e-L-o-a-d-e-r); new to extra101"]
    - [loader_class_module_len_eq_26,
       "__loader__.__class__.__module__.__len__",
       [],
       26,
       "inspect.__loader__.__class__.__module__.__len__() == 26 — __class__.__module__ is '_frozen_importlib_external'; len('_frozen_importlib_external') == 26 (_-f-r-o-z-e-n-_-i-m-p-o-r-t-l-i-b-_-e-x-t-e-r-n-a-l); new to extra101"]
    - [loader_name_eq_inspect,
       "__loader__.name.__eq__",
       ["inspect"],
       true,
       "inspect.__loader__.name.__eq__('inspect') == True — the SourceFileLoader instance has a .name attribute holding the module's dotted name; for the inspect module it is 'inspect'; str.__eq__('inspect') returns True; new to extra101"]

# ---------------------------------------------------------------------------
# Table 3: inspect.__package__ and spec class module length
#
# Wave 258 theme: inspect.__package__ empty string and len checks.
#
# inspect.__package__ == '' (empty string)
# len(inspect.__package__) == 0
# inspect.__package__.__class__.__name__ == 'str'
# len('_frozen_importlib') == 17
# len('_frozen_importlib_external') == 26
#
# inspect is a top-level module with no package prefix, so __package__
# is the empty string. New to extra101.
# ---------------------------------------------------------------------------

table inspect_extra101.package_and_len_checks:
  description: "inspect.__package__=='' (empty string len 0); __package__.__class__.__name__=='str'; _frozen_importlib len 17; _frozen_importlib_external len 26; wave 258; new to extra101"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectspec101

  columns: [id, function, args, expected, description]
  rows:
    - [package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "inspect.__package__.__eq__('') == True — inspect is a top-level stdlib module with no parent package; its __package__ attribute is the empty string ''; str.__eq__('') returns True; new to extra101"]
    - [package_len_eq_0,
       "__package__.__len__",
       [],
       0,
       "inspect.__package__.__len__() == 0 — __package__ is the empty string ''; len('') == 0; a zero-length string indicates a top-level module with no package prefix; new to extra101"]
    - [package_class_name_eq_str,
       "__package__.__class__.__name__.__eq__",
       ["str"],
       true,
       "inspect.__package__.__class__.__name__.__eq__('str') == True — __package__ is the empty string ''; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra101"]
    - [spec_class_module_len_eq_17,
       "__spec__.__class__.__module__.__len__",
       [],
       17,
       "inspect.__spec__.__class__.__module__.__len__() == 17 — __class__.__module__ is '_frozen_importlib'; len('_frozen_importlib') == 17 (_-f-r-o-z-e-n-_-i-m-p-o-r-t-l-i-b); new to extra101"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra101
# ---------------------------------------------------------------------------

invariant inspect_extra101.spec_class_name:
  description: "inspect.__spec__.__class__.__name__ == 'ModuleSpec' — the import system record class; wave 258; new to extra101"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant inspect_extra101.loader_class_name:
  description: "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect.py loaded via SourceFileLoader; wave 258; new to extra101"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant inspect_extra101.package_len:
  description: "len(inspect.__package__) == 0 — inspect is a top-level module; __package__ is empty string; wave 258; new to extra101"
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0

invariant inspect_extra101.spec_name_len:
  description: "len(inspect.__spec__.name) == 7 — spec.name is 'inspect'; wave 258; new to extra101"
  kind: python_call_eq
  function: __spec__.name.__len__
  args: []
  expected: 7

invariant inspect_extra101.loader_name:
  description: "inspect.__loader__.name == 'inspect' — SourceFileLoader.name holds the module's dotted name; wave 258; new to extra101"
  kind: python_call_eq
  function: __loader__.name.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra101.loader_class_module:
  description: "inspect.__loader__.__class__.__module__ == '_frozen_importlib_external' — SourceFileLoader is in the external frozen bootstrap; wave 258; new to extra101"
  kind: python_call_eq
  function: __loader__.__class__.__module__.__eq__
  args: ["_frozen_importlib_external"]
  expected: true

