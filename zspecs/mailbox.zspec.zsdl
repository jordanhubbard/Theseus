spec: mailbox
version: ">=3.0"
backend: python_module(mailbox)

docs: https://docs.python.org/3/library/mailbox.html

provenance:
  derived_from:
    - "Python 3 mailbox documentation — https://docs.python.org/3/library/mailbox.html"
    - "RFC 4155 — The application/mbox Media Type"
    - "RFC 2822 — Internet Message Format"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/mailbox.py"
  notes:
    - "mailbox provides read/write access to Maildir, mbox, MH, Babyl, and MMDF mailbox formats."
    - "Mailbox is the abstract base class; Maildir, mbox, MH, Babyl, MMDF are concrete subclasses."
    - "Message is the base message class; MaildirMessage, mboxMessage, MHMessage, BabylMessage, MMDFMessage extend it for format-specific metadata."
    - "NoSuchMailboxError, NotEmptyError, ExternalClashError, FormatError are all subclasses of Error (which inherits from Exception)."
    - "Error is mailbox's own exception base class; it inherits from Exception."
    - "mailbox.Maildir.__bases__[0].__name__ == 'Mailbox' verified with Python 3.14 on macOS Darwin 25.4.0."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class_names — mailbox container classes
# ---------------------------------------------------------------------------

table mailbox.class_names.containers:
  kind: python_call_eq
  category: classes
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [Mailbox,       Mailbox.__name__.__eq__,       ["Mailbox"],       true]
    - [Maildir,       Maildir.__name__.__eq__,       ["Maildir"],       true]
    - [mbox,          mbox.__name__.__eq__,          ["mbox"],          true]
    - [MH,            MH.__name__.__eq__,            ["MH"],            true]
    - [Babyl,         Babyl.__name__.__eq__,         ["Babyl"],         true]
    - [MMDF,          MMDF.__name__.__eq__,          ["MMDF"],          true]

# ---------------------------------------------------------------------------
# class_names — mailbox message classes
# ---------------------------------------------------------------------------

table mailbox.class_names.messages:
  kind: python_call_eq
  category: classes
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [Message,         Message.__name__.__eq__,         ["Message"],         true]
    - [MaildirMessage,  MaildirMessage.__name__.__eq__,  ["MaildirMessage"],  true]
    - [mboxMessage,     mboxMessage.__name__.__eq__,     ["mboxMessage"],     true]
    - [MHMessage,       MHMessage.__name__.__eq__,       ["MHMessage"],       true]
    - [BabylMessage,    BabylMessage.__name__.__eq__,    ["BabylMessage"],    true]
    - [MMDFMessage,     MMDFMessage.__name__.__eq__,     ["MMDFMessage"],     true]

# ---------------------------------------------------------------------------
# class_names — mailbox exception classes
# ---------------------------------------------------------------------------

table mailbox.class_names.exceptions:
  kind: python_call_eq
  category: classes
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [NoSuchMailboxError,  NoSuchMailboxError.__name__.__eq__,  ["NoSuchMailboxError"],  true]
    - [NotEmptyError,       NotEmptyError.__name__.__eq__,       ["NotEmptyError"],       true]
    - [ExternalClashError,  ExternalClashError.__name__.__eq__,  ["ExternalClashError"],  true]
    - [FormatError,         FormatError.__name__.__eq__,         ["FormatError"],         true]

# ---------------------------------------------------------------------------
# module — Mailbox.__module__ == 'mailbox'
# ---------------------------------------------------------------------------

invariant mailbox.module.Mailbox:
  description: "Mailbox.__module__ == 'mailbox'"
  category: module
  kind: python_call_eq
  function: Mailbox.__module__.__eq__
  args: ["mailbox"]
  expected: true

# ---------------------------------------------------------------------------
# hierarchy — class inheritance
# ---------------------------------------------------------------------------

invariant mailbox.hierarchy.Maildir_base:
  description: "Maildir.__bases__[0].__name__ == 'Mailbox' — Maildir inherits directly from Mailbox"
  category: hierarchy
  kind: python_call_eq
  function: Maildir.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Mailbox"

invariant mailbox.hierarchy.NoSuchMailboxError_base:
  description: "NoSuchMailboxError.__bases__[0].__name__ == 'Error' — NoSuchMailboxError inherits from mailbox.Error"
  category: hierarchy
  kind: python_call_eq
  function: NoSuchMailboxError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

invariant mailbox.hierarchy.NotEmptyError_base:
  description: "NotEmptyError.__bases__[0].__name__ == 'Error' — NotEmptyError inherits from mailbox.Error"
  category: hierarchy
  kind: python_call_eq
  function: NotEmptyError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

invariant mailbox.hierarchy.ExternalClashError_base:
  description: "ExternalClashError.__bases__[0].__name__ == 'Error' — ExternalClashError inherits from mailbox.Error"
  category: hierarchy
  kind: python_call_eq
  function: ExternalClashError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"
