spec: natural_compare
version: ">=1.0.0"
backend: node(natural-compare)

docs: https://github.com/nicolo-ribaudo/natural-compare-lite#readme

provenance:
  derived_from:
    - "natural-compare README — https://github.com/litejs/natural-compare-lite#readme"
    - "Test vectors verified with natural-compare@1.4.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "natural-compare source"
  notes:
    - "natural-compare exports the comparison function directly as module.exports."
    - "Returns negative if a < b, positive if a > b, 0 if a === b (natural order)."
    - "Numbers embedded in strings are compared numerically: 'a10' > 'a9' in natural sort."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns integer. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table natural_compare.compare:
  kind: node_module_call_eq
  function: ~
  category: compare
  id_prefix: nc

  columns: [id, args, expected]
  rows:
    - [num_greater,  ["a10", "a9"],   1]
    - [num_less,     ["9", "10"],    -1]
    - [equal,        ["abc", "abc"],  0]
    - [alpha_less,   ["abc", "abd"], -1]
