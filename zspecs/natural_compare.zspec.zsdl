spec: natural_compare
version: ">=1.0.0"
backend: node(natural-compare)

docs: https://www.npmjs.com/package/natural-compare

provenance:
  derived_from:
    - "natural-compare README — https://www.npmjs.com/package/natural-compare"
    - "Test vectors verified with natural-compare@1.4.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "natural-compare source"
  notes:
    - "natural-compare exports a comparison function directly as module.exports."
    - "naturalCompare(a, b) returns negative if a < b, 0 if equal, positive if a > b."
    - "Numerically compares embedded numbers: 'a10' > 'a9' in natural order."
    - "Returns -1, 0, or 1 (or any negative/positive integer)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns comparison integer (negative, 0, positive)."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table natural_compare.natural_compare:
  kind: node_module_call_eq
  function: ~
  category: natural_compare
  id_prefix: natcmp

  columns: [id, args, expected]
  rows:
    - [natural_num,  ["a10", "a9"],   1]
    - [equal,        ["abc", "abc"],  0]
    - [alpha_less,   ["a1", "b1"],    -1]
    - [num_less,     ["a1", "a2"],    -1]
