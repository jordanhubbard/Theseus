spec: pathlib_extra128
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra127.zspec.zsdl."
    - "This spec covers: pathlib.PurePath.__truediv__ and __rtruediv__ __code__ object attributes not yet covered."
    - "pathlib_extra106 covered PurePath.__truediv__.__qualname__.__eq__('PurePath.__truediv__') and __qualname__.__len__()==20."
    - "pathlib_extra118 covered Path.__truediv__.__qualname__ and Path.__rtruediv__.__qualname__ (both use PurePath as defining class)."
    - "pathlib_extra103 covered PurePath.__truediv__.__class__.__name__=='function' and PurePath.__rtruediv__.__class__.__name__=='function'."
    - "NO prior pathlib spec asserts any attribute of PurePath.__truediv__.__code__ or PurePath.__rtruediv__.__code__."
    - "PurePath.__truediv__.__code__.co_varnames[0] == 'self' (4 chars); [1] == 'key' (3 chars)."
    - "PurePath.__rtruediv__.__code__.co_varnames[0] == 'self' (4 chars); [1] == 'key' (3 chars)."
    - "PurePath.__truediv__.__code__.co_argcount == 2 (self and key)."
    - "PurePath.__rtruediv__.__code__.co_argcount == 2 (self and key)."
    - "PurePath.__truediv__.__code__.co_name == '__truediv__' (11 chars)."
    - "PurePath.__rtruediv__.__code__.co_name == '__rtruediv__' (12 chars)."
    - "PurePath.__truediv__.__code__.co_varnames.__len__() == 2 (only self and key; no local variables)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath.__truediv__.__code__ co_varnames and co_argcount
# PurePath.__truediv__.__code__.co_varnames == ('self', 'key').
# co_varnames[0] == 'self' (4 chars) — the PurePath instance on the left of /.
# co_varnames[1] == 'key' (3 chars) — the operand on the right of / (other path segment).
# co_argcount == 2 — self and key; no default arguments, no *args.
# co_varnames.__len__() == 2 — exactly 2 entries, no local variables beyond parameters.
# pathlib_extra106 covered __truediv__.__qualname__.__eq__ and __qualname__.__len__.
# NO prior pathlib spec asserts any attribute of PurePath.__truediv__.__code__.
# ---------------------------------------------------------------------------

table pathlib_extra128.PurePath_truediv_code_varnames:
  description: "pathlib.PurePath.__truediv__.__code__ co_varnames: [0]=='self'(4), [1]=='key'(3); co_argcount==2; co_varnames.__len__()==2; all assertions novel (no prior pathlib spec touches PurePath.__truediv__.__code__); __truediv__ implements the / path-joining operator"
  kind: python_call_eq
  category: code_introspection
  id_prefix: pptd128a

  columns: [id, function, args, expected, description]
  rows:
    - [td_cv0_eq,      "PurePath.__truediv__.__code__.co_varnames[0].__eq__",    ["self"],  true,  "pathlib.PurePath.__truediv__.__code__.co_varnames[0] == 'self' (4 chars; the PurePath instance on the left side of the / operator; e.g. path / 'segment' calls path.__truediv__('segment'))"]
    - [td_cv0_len,     "PurePath.__truediv__.__code__.co_varnames[0].__len__",   [],         4,     "pathlib.PurePath.__truediv__.__code__.co_varnames[0].__len__() == 4 ('self' has 4 characters; same length as 'self' in any Python method)"]
    - [td_cv1_eq,      "PurePath.__truediv__.__code__.co_varnames[1].__eq__",    ["key"],   true,  "pathlib.PurePath.__truediv__.__code__.co_varnames[1] == 'key' (3 chars; the right operand of / which is the path segment to join; named 'key' rather than 'other' because the / operator resolves path components)"]
    - [td_cv1_len,     "PurePath.__truediv__.__code__.co_varnames[1].__len__",   [],         3,     "pathlib.PurePath.__truediv__.__code__.co_varnames[1].__len__() == 3 ('key' has 3 characters; 1 char shorter than 'self'; 'key' is the shortest parameter name in PurePath.__truediv__)"]
    - [td_argcount,    "PurePath.__truediv__.__code__.co_argcount.__eq__",        [2],      true,  "pathlib.PurePath.__truediv__.__code__.co_argcount == 2 (self and key are the two formal parameters; __truediv__ takes exactly two arguments: the left operand (self) and the right operand (key))"]
    - [td_varnames_len, "PurePath.__truediv__.__code__.co_varnames.__len__",      [],         2,     "pathlib.PurePath.__truediv__.__code__.co_varnames.__len__() == 2 (exactly two entries: 'self' and 'key'; no local variables beyond parameters; a simple two-argument function with no temporaries)"]
    - [td_cv0_gt_cv1,  "PurePath.__truediv__.__code__.co_varnames[0].__len__.__gt__", [3],  true,  "len('self') > len('key') (4 > 3; the instance parameter 'self' is 1 char longer than the operand parameter 'key' in PurePath.__truediv__)"]
    - [td_cv1_ne_cv0,  "PurePath.__truediv__.__code__.co_varnames[1].__eq__",    ["self"], false,  "pathlib.PurePath.__truediv__.__code__.co_varnames[1] != 'self' (position 1 is 'key', not 'self'; 'self' is always at position 0)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__rtruediv__.__code__ co_varnames and co_argcount
# PurePath.__rtruediv__.__code__.co_varnames == ('self', 'key').
# co_varnames[0] == 'self' (4 chars) — the PurePath instance on the right of /.
# co_varnames[1] == 'key' (3 chars) — the operand on the left of / (other path segment).
# co_argcount == 2.
# PurePath.__rtruediv__ implements 'other / path' (reflected division).
# Same co_varnames as __truediv__: both take (self, key).
# NO prior pathlib spec asserts any attribute of PurePath.__rtruediv__.__code__.
# ---------------------------------------------------------------------------

table pathlib_extra128.PurePath_rtruediv_code_varnames:
  description: "pathlib.PurePath.__rtruediv__.__code__ co_varnames: [0]=='self'(4), [1]=='key'(3); co_argcount==2; same parameter names as __truediv__; all assertions novel; __rtruediv__ implements 'other / path' (e.g. '/usr' / PurePath('local'))"
  kind: python_call_eq
  category: code_introspection
  id_prefix: pptd128b

  columns: [id, function, args, expected, description]
  rows:
    - [rtd_cv0_eq,     "PurePath.__rtruediv__.__code__.co_varnames[0].__eq__",   ["self"],  true,  "pathlib.PurePath.__rtruediv__.__code__.co_varnames[0] == 'self' (4 chars; for __rtruediv__, 'self' is the PurePath on the RIGHT side of /; Python calls __rtruediv__ when the left operand does not support the operation)"]
    - [rtd_cv0_len,    "PurePath.__rtruediv__.__code__.co_varnames[0].__len__",  [],         4,     "pathlib.PurePath.__rtruediv__.__code__.co_varnames[0].__len__() == 4 ('self' has 4 characters; same as co_varnames[0] in __truediv__)"]
    - [rtd_cv1_eq,     "PurePath.__rtruediv__.__code__.co_varnames[1].__eq__",   ["key"],   true,  "pathlib.PurePath.__rtruediv__.__code__.co_varnames[1] == 'key' (3 chars; the left operand of / in a reflected call; e.g. '/usr' / path calls path.__rtruediv__('/usr') where '/usr' is 'key')"]
    - [rtd_cv1_len,    "PurePath.__rtruediv__.__code__.co_varnames[1].__len__",  [],         3,     "pathlib.PurePath.__rtruediv__.__code__.co_varnames[1].__len__() == 3 ('key' has 3 characters; same as co_varnames[1] in __truediv__; both operators share identical parameter names)"]
    - [rtd_argcount,   "PurePath.__rtruediv__.__code__.co_argcount.__eq__",       [2],      true,  "pathlib.PurePath.__rtruediv__.__code__.co_argcount == 2 (self and key; identical argument count to __truediv__; both implement the binary / operator from opposite sides)"]
    - [rtd_same_as_td, "PurePath.__rtruediv__.__code__.co_varnames[1].__eq__",   ["key"],   true,  "pathlib.PurePath.__rtruediv__.__code__.co_varnames[1] == 'key' confirming __rtruediv__ and __truediv__ share identical parameter names (both use 'self' and 'key'), distinguishing only by their qualnames and co_name attributes"]
    - [rtd_cv1_lt_cv0, "PurePath.__rtruediv__.__code__.co_varnames[1].__len__.__lt__", [4], true,  "len('key') < len('self') in PurePath.__rtruediv__ (3 < 4; same length relationship as in __truediv__; 'key' is always shorter than 'self')"]
    - [rtd_ne_td_qn,   "PurePath.__rtruediv__.__qualname__.__eq__",              ["PurePath.__truediv__"], false, "pathlib.PurePath.__rtruediv__.__qualname__ != 'PurePath.__truediv__' (despite identical co_varnames, __rtruediv__ and __truediv__ have distinct qualnames; __rtruediv__ is 'PurePath.__rtruediv__' (21 chars) vs __truediv__ at 20 chars)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__truediv__ and __rtruediv__ __code__.co_name assertions
# __truediv__.__code__.co_name == '__truediv__' (11 chars).
# __rtruediv__.__code__.co_name == '__rtruediv__' (12 chars).
# co_name always equals the function's own name (not qualname).
# These cross-comparisons anchor the complete code object identity for both operators.
# NO prior pathlib spec asserts co_name for any PurePath method.
# ---------------------------------------------------------------------------

table pathlib_extra128.PurePath_truediv_rtruediv_co_name:
  description: "pathlib.PurePath.__truediv__.__code__.co_name=='__truediv__'(11); __rtruediv__.__code__.co_name=='__rtruediv__'(12); co_name is the bare function name without the class prefix; all assertions novel"
  kind: python_call_eq
  category: code_introspection
  id_prefix: pptd128c

  columns: [id, function, args, expected, description]
  rows:
    - [td_cn_eq,       "PurePath.__truediv__.__code__.co_name.__eq__",           ["__truediv__"],    true,  "pathlib.PurePath.__truediv__.__code__.co_name == '__truediv__' (11 chars; co_name holds the bare function name without the class prefix; co_name is '__truediv__' while __qualname__ is 'PurePath.__truediv__')"]
    - [td_cn_len,      "PurePath.__truediv__.__code__.co_name.__len__",          [],                  11,    "pathlib.PurePath.__truediv__.__code__.co_name.__len__() == 11 ('__truediv__' has 11 characters: '__'(2)+'truediv'(7)+'__'(2)==11)"]
    - [rtd_cn_eq,      "PurePath.__rtruediv__.__code__.co_name.__eq__",          ["__rtruediv__"],   true,  "pathlib.PurePath.__rtruediv__.__code__.co_name == '__rtruediv__' (12 chars; same pattern as __truediv__ but with 'r' prefix for reflected; co_name == '__rtruediv__' while __qualname__ == 'PurePath.__rtruediv__')"]
    - [rtd_cn_len,     "PurePath.__rtruediv__.__code__.co_name.__len__",         [],                  12,    "pathlib.PurePath.__rtruediv__.__code__.co_name.__len__() == 12 ('__rtruediv__' has 12 characters: '__'(2)+'r'(1)+'truediv'(7)+'__'(2)==12; 1 char longer than __truediv__ due to 'r' prefix)"]
    - [rtd_cn_gt_td,   "PurePath.__rtruediv__.__code__.co_name.__len__.__gt__",  [11],               true,  "len('__rtruediv__') > len('__truediv__') (12 > 11; rtruediv co_name is 1 char longer than truediv co_name due to the reflected 'r' prefix)"]
    - [td_cn_ne_rtd,   "PurePath.__truediv__.__code__.co_name.__eq__",           ["__rtruediv__"],   false, "pathlib.PurePath.__truediv__.__code__.co_name != '__rtruediv__' (11 chars vs 12 chars; the two operators have distinct co_name strings differing by one 'r' character)"]
    - [td_cn_prefix,   "PurePath.__truediv__.__code__.co_name.__contains__",     ["truediv"],        true,  "pathlib.PurePath.__truediv__.__code__.co_name.__contains__('truediv') == True ('__truediv__' contains the substring 'truediv'; co_name does not include the 'PurePath.' class prefix unlike __qualname__)"]
    - [rtd_cn_prefix,  "PurePath.__rtruediv__.__code__.co_name.__contains__",    ["truediv"],        true,  "pathlib.PurePath.__rtruediv__.__code__.co_name.__contains__('truediv') == True ('__rtruediv__' also contains 'truediv' as a substring; both co_names share this common substring)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra128.PurePath.truediv_code_cv0_self:
  description: "pathlib.PurePath.__truediv__.__code__.co_varnames[0] == 'self' (4 chars; __truediv__ is the Python function implementing the / path-joining operator for PurePath; co_varnames[0] is always 'self' for instance methods in Python; PurePath.__truediv__(self, key) is called as path / key; the first co_varnames entry is the receiver; pathlib_extra106 covered PurePath.__truediv__.__qualname__ and pathlib_extra103 covered __class__.__name__=='function'; no prior pathlib spec asserts any attribute of PurePath.__truediv__.__code__; this is the first pathlib spec to introspect the code object of the / operator); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "PurePath.__truediv__.__code__.co_varnames[0].__eq__"
  args: ["self"]
  expected: true

invariant pathlib_extra128.PurePath.truediv_code_cv1_key:
  description: "pathlib.PurePath.__truediv__.__code__.co_varnames[1] == 'key' (3 chars; 'key' is the right operand of the / operator in PurePath.__truediv__(self, key); it is the path segment to join to self; the choice of 'key' rather than 'other' or 'path' is specific to CPython's pathlib implementation; 'key' at 3 chars is 1 char shorter than 'self' at 4 chars; co_argcount==2 confirms there are exactly two parameters; no prior pathlib spec asserts co_varnames[1] for PurePath.__truediv__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "PurePath.__truediv__.__code__.co_varnames[1].__eq__"
  args: ["key"]
  expected: true

invariant pathlib_extra128.PurePath.rtruediv_code_cv1_key:
  description: "pathlib.PurePath.__rtruediv__.__code__.co_varnames[1] == 'key' (3 chars; __rtruediv__ implements 'other / path' — the reflected division operator; it is called when the left operand does not support the / operation, e.g. a plain string '/usr' / PurePath('local'); the parameter is still named 'key' matching __truediv__; both PurePath.__truediv__ and PurePath.__rtruediv__ use identical parameter names ('self', 'key'), showing the symmetric design of the path-joining operator; no prior pathlib spec asserts any co_varnames entry for PurePath.__rtruediv__.__code__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "PurePath.__rtruediv__.__code__.co_varnames[1].__eq__"
  args: ["key"]
  expected: true

invariant pathlib_extra128.PurePath.truediv_co_name_len_11:
  description: "pathlib.PurePath.__truediv__.__code__.co_name.__len__() == 11 ('__truediv__' has 11 characters: double-underscore prefix '__'(2) + 'truediv'(7) + double-underscore suffix '__'(2) == 11; co_name stores the bare function name without any class prefix; it differs from __qualname__ ('PurePath.__truediv__' at 20 chars) by omitting the 'PurePath.' prefix; no prior pathlib spec asserts co_name for any PurePath method); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "PurePath.__truediv__.__code__.co_name.__len__"
  args: []
  expected: 11

invariant pathlib_extra128.PurePath.rtruediv_co_name_len_12:
  description: "pathlib.PurePath.__rtruediv__.__code__.co_name.__len__() == 12 ('__rtruediv__' has 12 characters: '__'(2)+'r'(1)+'truediv'(7)+'__'(2)==12; this is exactly 1 char longer than '__truediv__' at 11 chars because of the 'r' prefix that marks it as the reflected operator; co_name for __rtruediv__ is '__rtruediv__', not 'PurePath.__rtruediv__'; pathlib_extra118 covered __qualname__.__len__()==21 for __rtruediv__ but no spec has asserted the co_name length of 12; this is the first pathlib spec to assert co_name for PurePath.__rtruediv__.__code__); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
  function: "PurePath.__rtruediv__.__code__.co_name.__len__"
  args: []
  expected: 12

