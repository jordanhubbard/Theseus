spec: concurrent_futures_extra245
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.ThreadPoolExecutor — ThreadPoolExecutor"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.ProcessPoolExecutor — ProcessPoolExecutor"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.Executor — Executor base class"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.Future — Future class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py (internal implementation)"
    - "CPython source: Lib/concurrent/futures/process.py (internal implementation)"
    - "CPython source: Lib/concurrent/futures/_base.py (internal implementation)"
  notes:
    - "This spec covers ThreadPoolExecutor, ProcessPoolExecutor, Executor, and Future class identity."
    - "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25); ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26)."
    - "Executor.__module__ == 'concurrent.futures._base' (len=24); Future.__module__ == 'concurrent.futures._base' (len=24)."
    - "Both ThreadPoolExecutor and ProcessPoolExecutor inherit directly from Executor."
    - "Executor.__bases__[0].__name__ == 'object'; Future.__bases__[0].__name__ == 'object' — no intermediate base class."
    - "ThreadPoolExecutor.__name__.__len__()==18; ProcessPoolExecutor.__name__.__len__()==19 (one character longer)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Executor class hierarchy identity
#
# Executor.__name__ == 'Executor' (len=8)
# Executor.__module__ == 'concurrent.futures._base' (len=24)
# Executor.__bases__[0].__name__ == 'object'
# ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (len=18)
# ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25)
# ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'
# ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (len=19)
# ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26)
# ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'
# ---------------------------------------------------------------------------

table concurrent_futures_extra245.executor_class_identity:
  description: "concurrent.futures executor class identity — Executor.__name__.__eq__('Executor')==True (len=8); Executor.__module__.__eq__('concurrent.futures._base')==True (len=24); Executor.__bases__[0].__name__.__eq__('object')==True (no intermediate base); ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor')==True (len=18); ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread')==True (len=25); ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True; ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor')==True (len=19); ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (len=26); ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cf245exec

  columns: [id, function, args, expected, description]
  rows:
    - [exec_name_eq,   Executor.__name__.__eq__,                         ["Executor"],                      true, "concurrent.futures.Executor.__name__ == 'Executor'; verified with Python 3.14.3"]
    - [exec_name_len,  Executor.__name__.__len__,                        [],                                8,    "concurrent.futures.Executor.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [exec_mod_eq,    Executor.__module__.__eq__,                       ["concurrent.futures._base"],      true, "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [exec_mod_len,   Executor.__module__.__len__,                      [],                                24,   "concurrent.futures.Executor.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [exec_base_eq,   "Executor.__bases__[0].__name__.__eq__",          ["object"],                        true, "concurrent.futures.Executor.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]
    - [tpe_name_eq,    ThreadPoolExecutor.__name__.__eq__,               ["ThreadPoolExecutor"],            true, "concurrent.futures.ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'; verified with Python 3.14.3"]
    - [tpe_name_len,   ThreadPoolExecutor.__name__.__len__,              [],                                18,   "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18; verified with Python 3.14.3"]
    - [tpe_mod_eq,     ThreadPoolExecutor.__module__.__eq__,             ["concurrent.futures.thread"],     true, "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [tpe_mod_len,    ThreadPoolExecutor.__module__.__len__,            [],                                25,   "concurrent.futures.ThreadPoolExecutor.__module__.__len__() == 25; verified with Python 3.14.3"]
    - [tpe_base_eq,    "ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                     true, "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]
    - [ppe_name_eq,    ProcessPoolExecutor.__name__.__eq__,              ["ProcessPoolExecutor"],           true, "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'; verified with Python 3.14.3"]
    - [ppe_name_len,   ProcessPoolExecutor.__name__.__len__,             [],                                19,   "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19; verified with Python 3.14.3"]
    - [ppe_mod_eq,     ProcessPoolExecutor.__module__.__eq__,            ["concurrent.futures.process"],    true, "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; verified with Python 3.14.3"]
    - [ppe_mod_len,    ProcessPoolExecutor.__module__.__len__,           [],                                26,   "concurrent.futures.ProcessPoolExecutor.__module__.__len__() == 26; verified with Python 3.14.3"]
    - [ppe_base_eq,    "ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                    true, "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Future class identity
#
# Future.__name__ == 'Future' (len=6)
# Future.__module__ == 'concurrent.futures._base' (len=24)
# Future.__bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

table concurrent_futures_extra245.future_class_identity:
  description: "concurrent.futures.Future class identity — Future.__name__.__eq__('Future')==True (len=6); Future.__module__.__eq__('concurrent.futures._base')==True (len=24, same module as Executor); Future.__bases__[0].__name__.__eq__('object')==True (no intermediate base class, inherits directly from object); Future.__name__.__len__()==6; Future.__module__.__len__()==24; contrast: Executor.__name__.__len__()==8 (longer name); ThreadPoolExecutor.__name__.__len__()==18; ProcessPoolExecutor.__name__.__len__()==19; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cf245fut

  columns: [id, function, args, expected, description]
  rows:
    - [fut_name_eq,   Future.__name__.__eq__,                  ["Future"],                    true, "concurrent.futures.Future.__name__ == 'Future'; verified with Python 3.14.3"]
    - [fut_name_len,  Future.__name__.__len__,                 [],                            6,    "concurrent.futures.Future.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [fut_mod_eq,    Future.__module__.__eq__,                ["concurrent.futures._base"],  true, "concurrent.futures.Future.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [fut_mod_len,   Future.__module__.__len__,               [],                            24,   "concurrent.futures.Future.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [fut_base_eq,   "Future.__bases__[0].__name__.__eq__",   ["object"],                    true, "concurrent.futures.Future.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra245
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra245.executor_name_eq:
  description: "concurrent.futures.Executor.__name__.__eq__('Executor') returns True — the abstract base class is named 'Executor' (len=8); it lives in concurrent.futures._base (len=24); Executor.__bases__[0].__name__ == 'object' (no intermediate base); ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' (inherits from it); ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' (also inherits from it); Future.__module__ == 'concurrent.futures._base' (same module as Executor); NEW in extra245: first standalone Executor name equality invariant in cf245exec namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Executor.__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra245.threadpoolexecutor_module_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread') returns True — ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py; __module__ == 'concurrent.futures.thread' (len=25); contrast with ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26); both executors inherit from Executor which lives in 'concurrent.futures._base' (len=24); ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (len=18); NEW in extra245: first standalone ThreadPoolExecutor module invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra245.processpoolexecutor_module_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process') returns True — ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py; __module__ == 'concurrent.futures.process' (len=26, one character longer than ThreadPoolExecutor's module); ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (len=19); ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'; contrast: ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25); NEW in extra245: first standalone ProcessPoolExecutor module invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra245.future_base_is_object:
  description: "concurrent.futures.Future.__bases__[0].__name__.__eq__('object') returns True — Future inherits directly from object with no intermediate base class; Future.__module__ == 'concurrent.futures._base' (len=24, same module as Executor); Future.__name__ == 'Future' (len=6, shortest name in this spec); Executor also inherits from object directly; contrast: ThreadPoolExecutor and ProcessPoolExecutor inherit from Executor (not object directly); NEW in extra245: first standalone Future base class invariant; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
