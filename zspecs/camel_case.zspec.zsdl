spec: camel_case
version: ">=5.0.0"
backend: node(camel-case)

docs: https://www.npmjs.com/package/camel-case

provenance:
  derived_from:
    - "camel-case README — https://www.npmjs.com/package/camel-case"
    - "Test vectors verified with camel-case via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "camel-case source"
  notes:
    - "camel-case is an npm package. Install: npm install camel-case"
    - "Converts a string to camelCase."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table camel_case.camelCase:
  kind: node_module_call_eq
  function: camelCase
  category: string
  id_prefix: cc

  columns: [id, args, expected]
  rows:
    - [spaces,  ["hello world"],  "helloWorld"]
    - [hyphen,  ["foo-bar"],      "fooBar"]
    - [snake,   ["foo_bar"],      "fooBar"]
