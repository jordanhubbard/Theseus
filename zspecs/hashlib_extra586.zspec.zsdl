spec: hashlib_extra586
version: ">=3.9"
backend: python_module(hashlib)
docs: "https://docs.python.org/3/library/hashlib.html"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib BLAKE2 hash objects"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__ and __module__ for blake2b and blake2s types and their methods"
  created_at: "2026-04-12T00:00:00Z"

table hashlib_extra586.blake2_type_identity:
  description: "blake2b and blake2s type qualname and module identity"
  columns: [id, function, args, expected]
  rows:
    - [hl586md01, hashlib.blake2b.__qualname__.__eq__, ["blake2b"], true]
    - [hl586md02, hashlib.blake2b.__module__.__eq__, ["_blake2"], true]
    - [hl586md03, hashlib.blake2s.__qualname__.__eq__, ["blake2s"], true]
    - [hl586md04, hashlib.blake2s.__module__.__eq__, ["_blake2"], true]

table hashlib_extra586.blake2b_method_qualnames:
  description: "blake2b method __qualname__ values"
  columns: [id, function, args, expected]
  rows:
    - [hl586qn01, hashlib.blake2b.update.__qualname__.__eq__, ["blake2b.update"], true]
    - [hl586qn02, hashlib.blake2b.digest.__qualname__.__eq__, ["blake2b.digest"], true]
    - [hl586qn03, hashlib.blake2b.hexdigest.__qualname__.__eq__, ["blake2b.hexdigest"], true]
    - [hl586qn04, hashlib.blake2b.copy.__qualname__.__eq__, ["blake2b.copy"], true]

table hashlib_extra586.blake2s_method_qualnames:
  description: "blake2s method __qualname__ values"
  columns: [id, function, args, expected]
  rows:
    - [hl586qn05, hashlib.blake2s.update.__qualname__.__eq__, ["blake2s.update"], true]
    - [hl586qn06, hashlib.blake2s.digest.__qualname__.__eq__, ["blake2s.digest"], true]
    - [hl586qn07, hashlib.blake2s.hexdigest.__qualname__.__eq__, ["blake2s.hexdigest"], true]
    - [hl586qn08, hashlib.blake2s.copy.__qualname__.__eq__, ["blake2s.copy"], true]
