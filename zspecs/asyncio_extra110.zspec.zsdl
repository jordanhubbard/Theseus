  args: []
  expected: 9

invariant asyncio_extra110.BoundedSemaphore_mro_len_5:
  description: "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — BoundedSemaphore has the longest MRO in this spec (length=5); BoundedSemaphore.__bases__[0].__name__=='Semaphore' (inherits from Semaphore); asyncio.Lock.__mro__.__len__()==4; asyncio.Semaphore.__mro__.__len__()==4; asyncio.Event.__mro__.__len__()==3 (shortest MRO in spec); compare MRO lengths: Event=3 < Lock=Semaphore=4 < BoundedSemaphore=5 (longest); BoundedSemaphore.__module__=='asyncio.locks'; BoundedSemaphore.__name__=='BoundedSemaphore' (len=16); BoundedSemaphore adds a _value bound check on top of Semaphore's counting logic, hence the override of release() to raise ValueError if the counter would exceed the initial bound; NEW in extra110: first standalone BoundedSemaphore MRO length invariant in asynciolock110 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__mro__.__len__
