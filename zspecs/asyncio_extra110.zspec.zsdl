invariant asyncio_extra110.Lock_acquire_co_argcount_1:
  description: "asyncio.Lock.acquire.__code__.co_argcount == 1 — acquire takes only self (all asyncio sync primitive acquire/release methods have co_argcount=1, using keyword-only or default args for timeout etc.); Lock.acquire.__qualname__=='Lock.acquire' (len=12); type(asyncio.Lock.acquire).__name__=='function' (Python-defined coroutine); compare: Lock.acquire co_argcount=1 == Lock.release=1 == Semaphore.acquire=1 == Semaphore.release=1 == BoundedSemaphore.release=1 == Event.set=1 == Event.clear=1 == Event.wait=1; all asyncio sync primitive methods have co_argcount=1; this pattern: async acquire/release operations take no extra positional args beyond self (timeout and other params are keyword-only, not counted by co_argcount); asyncio.Lock.__module__=='asyncio.locks'; asyncio.Lock.__mro__.__len__()==4; NEW in extra110: first standalone Lock.acquire argcount invariant in asynciolock110 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Lock.acquire.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant asyncio_extra110.Semaphore_release_qualname_len_17:
  description: "asyncio.Semaphore.release.__qualname__.__len__() == 17 — 'Semaphore.release' = 'Semaphore.'=10 + 'release'=7 = 17; Semaphore.acquire.__qualname__.__len__()==17 (tied with release); compare: Lock.acquire=Lock.release=12 (shorter) < Semaphore.acquire=Semaphore.release=17 (middle) < BoundedSemaphore.release=24 (longest in spec); asyncio.Semaphore.release.__code__.co_argcount==1 (self only); type(asyncio.Semaphore.release).__name__=='function' (Python-defined); asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin'; asyncio.Semaphore.__mro__.__len__()==4; asyncio.Semaphore.__module__=='asyncio.locks'; Semaphore.release is the method called to release the semaphore counter (increment the internal counter and wake waiting coroutines); NEW in extra110: first standalone Semaphore.release qualname length invariant in asynciolock110 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Semaphore.release.__qualname__.__len__
  args: []
  expected: 17

invariant asyncio_extra110.BoundedSemaphore_release_qualname_len_24:
  description: "asyncio.BoundedSemaphore.release.__qualname__.__len__() == 24 — 'BoundedSemaphore.release' = 'BoundedSemaphore.'=17 + 'release'=7 = 24; this is the longest qualname in this spec; BoundedSemaphore overrides release (qualname='BoundedSemaphore.release') to add the upper-bound check — contrast with acquire which is inherited from Semaphore (qualname='Semaphore.acquire', len=17); compare all qualname lengths: Event.set=9 (shortest) < Event.wait=10 < Event.clear=11 < Lock.acquire=Lock.release=12 < Semaphore.acquire=Semaphore.release=BoundedSemaphore.acquire(inherited)=17 < BoundedSemaphore.release=24 (longest); BoundedSemaphore.__mro__.__len__()==5 (longest MRO in spec); BoundedSemaphore.__bases__[0].__name__=='Semaphore'; NEW in extra110: first standalone BoundedSemaphore.release qualname length invariant in asynciolock110 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.release.__qualname__.__len__
  args: []
  expected: 24

invariant asyncio_extra110.Event_set_qualname_len_9:
  description: "asyncio.Event.set.__qualname__.__len__() == 9 — 'Event.set' = 'Event.'=6 + 'set'=3 = 9; this is the shortest qualname in this spec; asyncio.Event.set.__code__.co_argcount==1 (self only); type(asyncio.Event.set).__name__=='function' (Python-defined); compare: Event.set=9 (shortest) < Event.wait=10 < Event.clear=11; Event.set signals the event (sets internal flag to True, waking all coroutines waiting on Event.wait()); Event.clear resets the flag; Event.wait blocks until the flag is set; asyncio.Event.__bases__[0].__name__=='_LoopBoundMixin'; asyncio.Event.__mro__.__len__()==3; asyncio.Event.__module__=='asyncio.locks'; NEW in extra110: first standalone Event.set qualname length invariant in asynciolock110 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
