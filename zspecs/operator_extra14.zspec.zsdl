spec: operator_extra14
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra13.zspec.zsdl."
    - "operator_extra13 covers: __qualname__.__eq__ for add, sub, mul, truediv, pow, neg, pos, abs, eq, ne, lt, gt."
    - "No prior operator spec covers __module__ for add, sub, mul, eq, lt, truth, not_, or index."
    - "operator.add/sub/mul/eq/lt/truth/not_/index all have __module__ == '_operator' (the underlying C extension)."
    - "operator.itemgetter/attrgetter/methodcaller have __module__ == 'operator' (the public Python module)."
    - "operator.truth/__name__ == 'truth'; operator.not_/__name__ == 'not_'; operator.index/__name__ == 'index'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for C-level operator functions: add, sub, mul, eq, lt
#
# These are implemented in _operator.c and their __module__ is '_operator',
# not 'operator'. No prior operator spec records __module__ for these.
# ---------------------------------------------------------------------------

invariant operator_extra14.add.module:
  description: "operator.add.__module__ == '_operator' — C function in _operator extension"
  category: module_attrs
  kind: python_call_eq
  function: add.__module__.__eq__
  args: ["_operator"]
  expected: true

invariant operator_extra14.sub.module:
  description: "operator.sub.__module__ == '_operator' — C function in _operator extension"
  category: module_attrs
  kind: python_call_eq
  function: sub.__module__.__eq__
  args: ["_operator"]
  expected: true

invariant operator_extra14.mul.module:
  description: "operator.mul.__module__ == '_operator' — C function in _operator extension"
  category: module_attrs
  kind: python_call_eq
  function: mul.__module__.__eq__
  args: ["_operator"]
  expected: true

invariant operator_extra14.eq.module:
  description: "operator.eq.__module__ == '_operator' — C function in _operator extension"
  category: module_attrs
  kind: python_call_eq
  function: eq.__module__.__eq__
  args: ["_operator"]
  expected: true

invariant operator_extra14.lt.module:
  description: "operator.lt.__module__ == '_operator' — C function in _operator extension"
  category: module_attrs
  kind: python_call_eq
  function: lt.__module__.__eq__
  args: ["_operator"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for Python-level operator types: itemgetter, attrgetter, methodcaller
#
# These types are defined in the public 'operator' module (not '_operator'),
# so their __module__ is 'operator'. No prior spec records this distinction.
# ---------------------------------------------------------------------------

invariant operator_extra14.itemgetter.module:
  description: "operator.itemgetter.__module__ == 'operator' — type in public operator module"
  category: module_attrs
  kind: python_call_eq
  function: itemgetter.__module__.__eq__
  args: ["operator"]
  expected: true

invariant operator_extra14.attrgetter.module:
  description: "operator.attrgetter.__module__ == 'operator' — type in public operator module"
  category: module_attrs
  kind: python_call_eq
  function: attrgetter.__module__.__eq__
  args: ["operator"]
  expected: true

invariant operator_extra14.methodcaller.module:
  description: "operator.methodcaller.__module__ == 'operator' — type in public operator module"
  category: module_attrs
  kind: python_call_eq
  function: methodcaller.__module__.__eq__
  args: ["operator"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for additional C-level functions: truth, not_, index
#
# truth, not_, and index are all defined in _operator.c.
# No prior operator spec records __module__ for these functions.
# ---------------------------------------------------------------------------

invariant operator_extra14.truth.module:
  description: "operator.truth.__module__ == '_operator' — C function in _operator extension"
  category: module_attrs
  kind: python_call_eq
  function: truth.__module__.__eq__
  args: ["_operator"]
  expected: true

invariant operator_extra14.not_.module:
  description: "operator.not_.__module__ == '_operator' — C function in _operator extension"
  category: module_attrs
  kind: python_call_eq
  function: not_.__module__.__eq__
  args: ["_operator"]
  expected: true

invariant operator_extra14.index.module:
  description: "operator.index.__module__ == '_operator' — C function in _operator extension"
  category: module_attrs
  kind: python_call_eq
  function: index.__module__.__eq__
  args: ["_operator"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ for truth, not_, index — no prior spec records these
#
# These functions have __name__ matching their undecorated Python-side name.
# not_ uses the trailing underscore convention to avoid shadowing the keyword.
# ---------------------------------------------------------------------------

invariant operator_extra14.truth.name:
  description: "operator.truth.__name__ == 'truth' — simple function name"
  category: function_names
  kind: python_call_eq
  function: truth.__name__.__eq__
  args: ["truth"]
  expected: true

invariant operator_extra14.not_.name:
  description: "operator.not_.__name__ == 'not_' — trailing underscore avoids keyword clash"
  category: function_names
  kind: python_call_eq
  function: not_.__name__.__eq__
  args: ["not_"]
  expected: true

invariant operator_extra14.index.name:
  description: "operator.index.__name__ == 'index' — simple function name"
  category: function_names
  kind: python_call_eq
  function: index.__name__.__eq__
  args: ["index"]
  expected: true
