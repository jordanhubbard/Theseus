spec: xmlrpc_server
version: ">=3.0"
backend: python_module(xmlrpc.server)

docs: https://docs.python.org/3/library/xmlrpc.server.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/xmlrpc.server.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "xmlrpc.server source: Lib/xmlrpc/server.py (PSF; source inspection permitted)"
  not_derived_from:
    - "xmlrpc.server source: internal CGI handler and XML parsing details"
  notes:
    - "SimpleXMLRPCServer is a TCPServer subclass that serves XML-RPC requests over HTTP."
    - "SimpleXMLRPCServer.__bases__[0].__name__ == 'TCPServer' — it inherits from socketserver.TCPServer."
    - "MultiPathXMLRPCServer extends SimpleXMLRPCServer to dispatch to per-path handlers."
    - "SimpleXMLRPCRequestHandler handles individual HTTP requests for the XML-RPC server."
    - "SimpleXMLRPCDispatcher provides the XML-RPC method dispatch logic shared by both server variants."
    - "CGIXMLRPCRequestHandler handles XML-RPC requests received via a CGI script."
    - "register_function() registers a callable under a given name; register_instance() registers an object."
    - "register_multicall_functions() enables the system.multicall introspection method."
    - "register_introspection_functions() enables system.listMethods, system.methodSignature, system.methodHelp."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "XML-RPC faults from handler code are returned as xmlrpc.client.Fault objects in the response. HTTP-level errors are handled by SimpleXMLRPCRequestHandler and return appropriate HTTP error responses."
  stderr: "null"
  stickiness: "N/A — each server instance is independent."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks — exported server and handler classes
# ---------------------------------------------------------------------------

table xmlrpc_server.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [SimpleXMLRPCServer,          SimpleXMLRPCServer.__name__.__eq__,          ["SimpleXMLRPCServer"],          true]
    - [MultiPathXMLRPCServer,       MultiPathXMLRPCServer.__name__.__eq__,       ["MultiPathXMLRPCServer"],       true]
    - [SimpleXMLRPCRequestHandler,  SimpleXMLRPCRequestHandler.__name__.__eq__,  ["SimpleXMLRPCRequestHandler"],  true]
    - [SimpleXMLRPCDispatcher,      SimpleXMLRPCDispatcher.__name__.__eq__,      ["SimpleXMLRPCDispatcher"],      true]
    - [CGIXMLRPCRequestHandler,     CGIXMLRPCRequestHandler.__name__.__eq__,     ["CGIXMLRPCRequestHandler"],     true]

# ---------------------------------------------------------------------------
# Module check — SimpleXMLRPCServer lives in xmlrpc.server
# ---------------------------------------------------------------------------

invariant xmlrpc_server.SimpleXMLRPCServer.module:
  description: "xmlrpc.server.SimpleXMLRPCServer.__module__ == 'xmlrpc.server'"
  category: modules
  kind: python_call_eq
  function: SimpleXMLRPCServer.__module__.__eq__
  args: ["xmlrpc.server"]
  expected: true

# ---------------------------------------------------------------------------
# Inheritance — SimpleXMLRPCServer inherits from TCPServer
# ---------------------------------------------------------------------------

invariant xmlrpc_server.SimpleXMLRPCServer.base_is_TCPServer:
  description: "xmlrpc.server.SimpleXMLRPCServer.__bases__[0].__name__ == 'TCPServer'"
  category: hierarchy
  kind: python_call_eq
  function: SimpleXMLRPCServer.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "TCPServer"

# ---------------------------------------------------------------------------
# Function name checks — SimpleXMLRPCDispatcher methods
# ---------------------------------------------------------------------------

table xmlrpc_server.dispatcher_method_names:
  kind: python_call_eq
  category: names
  id_prefix: methname

  columns: [id, function, args, expected]
  rows:
    - [register_function,                SimpleXMLRPCDispatcher.register_function.__name__.__eq__,                ["register_function"],                true]
    - [register_instance,                SimpleXMLRPCDispatcher.register_instance.__name__.__eq__,                ["register_instance"],                true]
    - [register_multicall_functions,     SimpleXMLRPCDispatcher.register_multicall_functions.__name__.__eq__,     ["register_multicall_functions"],     true]
    - [register_introspection_functions, SimpleXMLRPCDispatcher.register_introspection_functions.__name__.__eq__, ["register_introspection_functions"], true]

# ---------------------------------------------------------------------------
# Type checks — core classes are types
# ---------------------------------------------------------------------------

table xmlrpc_server.type_checks:
  kind: python_call_eq
  category: types
  id_prefix: typecheck

  columns: [id, function, args, expected]
  rows:
    - [SimpleXMLRPCServer_is_type,     SimpleXMLRPCServer.__class__.__name__.__eq__,     ["type"], true]
    - [SimpleXMLRPCDispatcher_is_type, SimpleXMLRPCDispatcher.__class__.__name__.__eq__, ["type"], true]
    - [CGIXMLRPCRequestHandler_is_type, CGIXMLRPCRequestHandler.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# Docstring checks — dispatcher methods have docstrings
# ---------------------------------------------------------------------------

invariant xmlrpc_server.SimpleXMLRPCDispatcher.register_function.doc_is_str:
  description: "type(SimpleXMLRPCDispatcher.register_function.__doc__).__name__ == 'str'"
  category: docs
  kind: python_call_eq
  function: SimpleXMLRPCDispatcher.register_function.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
