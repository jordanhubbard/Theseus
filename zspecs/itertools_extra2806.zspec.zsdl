spec: itertools_extra2806
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "any proprietary source"
  notes:
    - "Wave 634 (_extra2806): __ilshift__, __irshift__, and __ipow__ dict-presence checks (in-place left-shift <<=, right-shift >>=, power **=)."
    - "All itertools types are lazy iterator wrappers — none define in-place shift or power operators."
    - "itertools.chain, count, repeat, cycle, islice, compress, dropwhile, takewhile: C-level types; no __ilshift__/__irshift__/__ipow__."
    - "itertools.starmap, groupby, filterfalse, accumulate, zip_longest: C-level types; no __ilshift__/__irshift__/__ipow__."
    - "itertools.pairwise, product, permutations, combinations, combinations_with_replacement: C-level types; no __ilshift__/__irshift__/__ipow__."
    - "Iterator protocol (__iter__/__next__) is unrelated to in-place shift or power operators."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __ilshift__ dict-presence (in-place left-shift <<=)
#
# Core itertools types: chain, count, repeat, cycle, islice, compress,
# dropwhile, takewhile, starmap, groupby — none define __ilshift__.
# ---------------------------------------------------------------------------

table itertools_extra2806.ilshift_protocol_core:
  description: "itertools core types __ilshift__ dict-presence checks — all False (no in-place left-shift protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2806
  columns: [id, function, args, expected]
  rows:
    - ["it2806001", "itertools.chain.__dict__.__contains__",     ["__ilshift__"], false]
    - ["it2806002", "itertools.count.__dict__.__contains__",     ["__ilshift__"], false]
    - ["it2806003", "itertools.repeat.__dict__.__contains__",    ["__ilshift__"], false]
    - ["it2806004", "itertools.cycle.__dict__.__contains__",     ["__ilshift__"], false]
    - ["it2806005", "itertools.islice.__dict__.__contains__",    ["__ilshift__"], false]
    - ["it2806006", "itertools.compress.__dict__.__contains__",  ["__ilshift__"], false]
    - ["it2806007", "itertools.dropwhile.__dict__.__contains__", ["__ilshift__"], false]
    - ["it2806008", "itertools.takewhile.__dict__.__contains__", ["__ilshift__"], false]
    - ["it2806009", "itertools.starmap.__dict__.__contains__",   ["__ilshift__"], false]
    - ["it2806010", "itertools.groupby.__dict__.__contains__",   ["__ilshift__"], false]

