    - ["it2806013", "itertools.zip_longest.__dict__.__contains__",                   ["__irshift__"], false]
    - ["it2806014", "itertools.pairwise.__dict__.__contains__",                      ["__irshift__"], false]
    - ["it2806015", "itertools.product.__dict__.__contains__",                       ["__irshift__"], false]
