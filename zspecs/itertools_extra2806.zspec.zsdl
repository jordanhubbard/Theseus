#
# Extended itertools types: filterfalse, accumulate, zip_longest, pairwise,
# product, permutations, combinations, combinations_with_replacement.
# None define __irshift__ — they produce sequences, not numeric values.
# ---------------------------------------------------------------------------

table itertools_extra2806.irshift_protocol_extended:
  description: "itertools extended types __irshift__ dict-presence checks — all False (no in-place right-shift protocol)"
  kind: python_call_eq
