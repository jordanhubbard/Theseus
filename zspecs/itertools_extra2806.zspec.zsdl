  rows:
    - ["it2806019", "itertools.product.__dict__.__contains__",                       ["__ipow__"], false]
    - ["it2806020", "itertools.permutations.__dict__.__contains__",                  ["__ipow__"], false]
    - ["it2806021", "itertools.combinations.__dict__.__contains__",                  ["__ipow__"], false]
    - ["it2806022", "itertools.combinations_with_replacement.__dict__.__contains__", ["__ipow__"], false]
    - ["it2806023", "itertools.chain.__dict__.__contains__",                         ["__ipow__"], false]
