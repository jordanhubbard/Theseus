    - ["it2806018", "itertools.combinations_with_replacement.__dict__.__contains__", ["__irshift__"], false]

# ---------------------------------------------------------------------------
# Table 3: __ipow__ dict-presence (in-place power **=)
#
# Combinatoric and filtering types: product, permutations, combinations,
# combinations_with_replacement, chain, compress, dropwhile, takewhile.
# None define __ipow__ — exponentiation has no iterator semantics.
# ---------------------------------------------------------------------------

table itertools_extra2806.ipow_protocol:
  description: "itertools types __ipow__ dict-presence checks — all False (no in-place power protocol)"
  kind: python_call_eq
