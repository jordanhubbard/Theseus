spec: asyncio_extra1651
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __init_subclass__, __set_name__, __class_getitem__"
    - "Covers: absence of __init_subclass__ in asyncio concurrency classes; presence of __class_getitem__ on generic-capable classes (Future, Task, Queue); module-level attr presence in asyncio namespace."
    - "Python 3.14.4 on macOS/Darwin 25.4.0: asyncio.Future, asyncio.Task, asyncio.Queue have __class_getitem__ in their __dict__ (they support T[X] generic alias syntax). asyncio.Lock, asyncio.Event, asyncio.Semaphore, asyncio.Condition, asyncio.Barrier, asyncio.BoundedSemaphore, asyncio.PriorityQueue, asyncio.LifoQueue, asyncio.StreamReader, asyncio.StreamWriter, asyncio.Protocol, asyncio.BaseProtocol, asyncio.DatagramProtocol, asyncio.SubprocessProtocol, asyncio.Server do NOT have __class_getitem__ in their __dict__. None of the asyncio classes define __init_subclass__ in their own __dict__ — the hook is inherited from object."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __init_subclass__ absence in asyncio classes
# No asyncio class defines __init_subclass__ in its own __dict__.
# The hook is inherited from object but not overridden.
# ---------------------------------------------------------------------------

table asyncio_extra1651.no_init_subclass:
  description: "asyncio concurrency classes do not define __init_subclass__ in their own __dict__ — the hook is inherited from object but not overridden by any asyncio class"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1651ni

  columns: [id, function, args, expected]
  rows:
    - ["as1651ni001", "asyncio.Future.__dict__.__contains__",              ["__init_subclass__"], false]
    - ["as1651ni002", "asyncio.Task.__dict__.__contains__",                ["__init_subclass__"], false]
    - ["as1651ni003", "asyncio.Lock.__dict__.__contains__",                ["__init_subclass__"], false]
    - ["as1651ni004", "asyncio.Event.__dict__.__contains__",               ["__init_subclass__"], false]
    - ["as1651ni005", "asyncio.Queue.__dict__.__contains__",               ["__init_subclass__"], false]
    - ["as1651ni006", "asyncio.Semaphore.__dict__.__contains__",           ["__init_subclass__"], false]
    - ["as1651ni007", "asyncio.Condition.__dict__.__contains__",           ["__init_subclass__"], false]
    - ["as1651ni008", "asyncio.Barrier.__dict__.__contains__",             ["__init_subclass__"], false]
    - ["as1651ni009", "asyncio.BoundedSemaphore.__dict__.__contains__",    ["__init_subclass__"], false]
    - ["as1651ni010", "asyncio.PriorityQueue.__dict__.__contains__",       ["__init_subclass__"], false]
    - ["as1651ni011", "asyncio.LifoQueue.__dict__.__contains__",           ["__init_subclass__"], false]
    - ["as1651ni012", "asyncio.StreamReader.__dict__.__contains__",        ["__init_subclass__"], false]
    - ["as1651ni013", "asyncio.StreamWriter.__dict__.__contains__",        ["__init_subclass__"], false]
    - ["as1651ni014", "asyncio.Protocol.__dict__.__contains__",            ["__init_subclass__"], false]
    - ["as1651ni015", "asyncio.BaseProtocol.__dict__.__contains__",        ["__init_subclass__"], false]
    - ["as1651ni016", "asyncio.DatagramProtocol.__dict__.__contains__",    ["__init_subclass__"], false]
    - ["as1651ni017", "asyncio.SubprocessProtocol.__dict__.__contains__",  ["__init_subclass__"], false]
    - ["as1651ni018", "asyncio.Server.__dict__.__contains__",              ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 2: __class_getitem__ presence — generic alias support
# asyncio.Future, asyncio.Task, asyncio.Queue define __class_getitem__
# (enabling Future[T], Task[T], Queue[T] generic alias syntax in 3.9+).
# Other asyncio classes do NOT define __class_getitem__ in their own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra1651.class_getitem_support:
  description: "asyncio.Future, Task, and Queue define __class_getitem__ in their __dict__ (supporting T[X] generic alias syntax); other asyncio classes do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1651cg

  columns: [id, function, args, expected]
  rows:
    - ["as1651cg001", "asyncio.Future.__dict__.__contains__",              ["__class_getitem__"], true]
    - ["as1651cg002", "asyncio.Task.__dict__.__contains__",                ["__class_getitem__"], true]
    - ["as1651cg003", "asyncio.Queue.__dict__.__contains__",               ["__class_getitem__"], true]
    - ["as1651cg004", "asyncio.Lock.__dict__.__contains__",                ["__class_getitem__"], false]
    - ["as1651cg005", "asyncio.Event.__dict__.__contains__",               ["__class_getitem__"], false]
    - ["as1651cg006", "asyncio.Semaphore.__dict__.__contains__",           ["__class_getitem__"], false]
    - ["as1651cg007", "asyncio.Condition.__dict__.__contains__",           ["__class_getitem__"], false]
    - ["as1651cg008", "asyncio.Barrier.__dict__.__contains__",             ["__class_getitem__"], false]
    - ["as1651cg009", "asyncio.BoundedSemaphore.__dict__.__contains__",    ["__class_getitem__"], false]
    - ["as1651cg010", "asyncio.PriorityQueue.__dict__.__contains__",       ["__class_getitem__"], false]
    - ["as1651cg011", "asyncio.LifoQueue.__dict__.__contains__",           ["__class_getitem__"], false]
    - ["as1651cg012", "asyncio.StreamReader.__dict__.__contains__",        ["__class_getitem__"], false]
    - ["as1651cg013", "asyncio.StreamWriter.__dict__.__contains__",        ["__class_getitem__"], false]
    - ["as1651cg014", "asyncio.Protocol.__dict__.__contains__",            ["__class_getitem__"], false]
    - ["as1651cg015", "asyncio.BaseProtocol.__dict__.__contains__",        ["__class_getitem__"], false]
    - ["as1651cg016", "asyncio.Server.__dict__.__contains__",              ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 3: asyncio module-level attribute presence
# Checks that key public names are present in asyncio.__dict__
# covering event loop API, coroutine utilities, and synchronization types.
# ---------------------------------------------------------------------------

table asyncio_extra1651.module_attr_presence:
  description: "asyncio module-level attribute presence — key public names must appear in asyncio.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1651mp

  columns: [id, function, args, expected]
  rows:
    - ["as1651mp001", "asyncio.__dict__.__contains__", ["get_event_loop"],         true]
    - ["as1651mp002", "asyncio.__dict__.__contains__", ["new_event_loop"],         true]
