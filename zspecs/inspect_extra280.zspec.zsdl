spec: inspect_extra280
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.getmembers is a pure-Python function: __module__ == 'inspect', __class__.__name__ == 'function'."
    - "getmembers.__name__ == 'getmembers' (10 chars); __qualname__ == 'getmembers' (top-level)."
    - "inspect.signature is a pure-Python function: __module__ == 'inspect', __class__.__name__ == 'function'."
    - "signature.__name__ == 'signature' (9 chars); __qualname__ == 'signature' (top-level)."
    - "inspect.Parameter.empty is a sentinel class: Parameter.empty is Parameter.empty (identity); __class__.__name__ == 'type'."
    - "inspect.Parameter.KEYWORD_ONLY is a _ParameterKind enum member with integer value 3."
    - "inspect.Parameter.POSITIONAL_ONLY == 0, POSITIONAL_OR_KEYWORD == 1, VAR_POSITIONAL == 2, KEYWORD_ONLY == 3, VAR_KEYWORD == 4."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.getmembers and inspect.signature — function identity
#
# Both are pure-Python functions in the inspect module.
# getmembers.__name__ == 'getmembers' (10 chars); signature.__name__ == 'signature' (9 chars).
# Both ship with non-None docstrings.
# ---------------------------------------------------------------------------

table inspect_extra280.getmembers_signature_identity:
  description: "inspect.getmembers and inspect.signature function identity — __name__, __module__, __qualname__, __class__.__name__, doc presence; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex280gsi

  columns: [id, function, args, expected, description]
  rows:
    - [gm_name_eq,  getmembers.__name__.__eq__,           ["getmembers"], true,  "inspect.getmembers.__name__ == 'getmembers'; verified with Python 3.14.3"]
    - [gm_name_len, getmembers.__name__.__len__,            [],            10,    "inspect.getmembers.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [gm_mod_eq,   getmembers.__module__.__eq__,           ["inspect"],   true,  "inspect.getmembers.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gm_qn_eq,    getmembers.__qualname__.__eq__,         ["getmembers"], true, "inspect.getmembers.__qualname__ == 'getmembers' (top-level function); verified with Python 3.14.3"]
    - [gm_cls_eq,   getmembers.__class__.__name__.__eq__,   ["function"],  true,  "inspect.getmembers.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [gm_doc_none, getmembers.__doc__.__eq__,              [null],        false, "inspect.getmembers.__doc__ is not None — getmembers ships with a docstring; verified with Python 3.14.3"]
    - [sg_name_eq,  signature.__name__.__eq__,              ["signature"], true,  "inspect.signature.__name__ == 'signature'; verified with Python 3.14.3"]
    - [sg_name_len, signature.__name__.__len__,              [],           9,     "inspect.signature.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [sg_mod_eq,   signature.__module__.__eq__,             ["inspect"],  true,  "inspect.signature.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [sg_cls_eq,   signature.__class__.__name__.__eq__,    ["function"],  true,  "inspect.signature.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect.Parameter — empty sentinel and KEYWORD_ONLY kind value
#
# Parameter.empty is a sentinel class: identity holds (empty is empty).
# Parameter.KEYWORD_ONLY is a _ParameterKind enum with int value 3.
# Kind integer values: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1,
#   VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4.
# ---------------------------------------------------------------------------

table inspect_extra280.parameter_kind_values:
  description: "inspect.Parameter kind integer values — POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2, KEYWORD_ONLY=3, VAR_KEYWORD=4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex280pkv

  columns: [id, function, args, expected, description]
  rows:
    - [pk_po_val,   "Parameter.POSITIONAL_ONLY.__eq__",           [0], true, "inspect.Parameter.POSITIONAL_ONLY == 0; verified with Python 3.14.3"]
    - [pk_pok_val,  "Parameter.POSITIONAL_OR_KEYWORD.__eq__",     [1], true, "inspect.Parameter.POSITIONAL_OR_KEYWORD == 1; verified with Python 3.14.3"]
    - [pk_vp_val,   "Parameter.VAR_POSITIONAL.__eq__",            [2], true, "inspect.Parameter.VAR_POSITIONAL == 2; verified with Python 3.14.3"]
    - [pk_ko_val,   "Parameter.KEYWORD_ONLY.__eq__",              [3], true, "inspect.Parameter.KEYWORD_ONLY == 3; verified with Python 3.14.3"]
    - [pk_vk_val,   "Parameter.VAR_KEYWORD.__eq__",               [4], true, "inspect.Parameter.VAR_KEYWORD == 4; verified with Python 3.14.3"]
    - [pk_ko_cls,   "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__", ["_ParameterKind"], true, "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra280
# ---------------------------------------------------------------------------

invariant inspect_extra280.getmembers_module_is_inspect:
  description: "inspect.getmembers.__module__ == 'inspect' — getmembers is defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra280.getmembers_is_function:
  description: "inspect.getmembers.__class__.__name__ == 'function' — getmembers is a pure-Python function, not a C builtin"
  category: identity
  kind: python_call_eq
  function: getmembers.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra280.getmembers_name_length_is_10:
  description: "inspect.getmembers.__name__.__len__() == 10 — 'getmembers' has 10 characters"
  category: identity
  kind: python_call_eq
  function: getmembers.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra280.signature_module_is_inspect:
  description: "inspect.signature.__module__ == 'inspect' — signature is defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra280.signature_name_length_is_9:
  description: "inspect.signature.__name__.__len__() == 9 — 'signature' has 9 characters"
  category: identity
  kind: python_call_eq
  function: signature.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra280.parameter_empty_is_type:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — the empty sentinel is a class (type) object"
  category: identity
  kind: python_call_eq
  function: "Parameter.empty.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

invariant inspect_extra280.parameter_keyword_only_equals_3:
  description: "inspect.Parameter.KEYWORD_ONLY == 3 — KEYWORD_ONLY has integer value 3 in the _ParameterKind enum"
  category: identity
  kind: python_call_eq
  function: "Parameter.KEYWORD_ONLY.__eq__"
  args: [3]
  expected: true

invariant inspect_extra280.parameter_keyword_only_class_name:
  description: "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind' — KEYWORD_ONLY is a _ParameterKind enum member"
  category: identity
  kind: python_call_eq
  function: "Parameter.KEYWORD_ONLY.__class__.__name__.__eq__"
  args: ["_ParameterKind"]
  expected: true
