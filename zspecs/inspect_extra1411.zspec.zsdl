spec: inspect_extra1411
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra.zspec.zsdl — covers other inspect attrs"
    - "inspect_extra140.zspec.zsdl — covers other inspect wave 263+ attrs"
  notes:
    - "Wave 541 theme: __sizeof__ method type on inspect Python class objects; __sizeof__ and __reduce_ex__ in __dict__ membership."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments are all pure Python classes defined in Lib/inspect.py."
    - "inspect.Parameter.__sizeof__.__class__.__name__ == 'method_descriptor' — Parameter inherits __sizeof__ from object as a method_descriptor. Verified with Python 3.14.3."
    - "inspect.Signature.__sizeof__.__class__.__name__ == 'method_descriptor' — Signature inherits __sizeof__ from object as a method_descriptor. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__sizeof__.__class__.__name__ == 'method_descriptor' — BoundArguments inherits __sizeof__ from object as a method_descriptor. Verified with Python 3.14.3."
    - "None of Parameter, Signature, or BoundArguments define '__sizeof__' in their own __dict__. Verified with Python 3.14.3."
    - "None of Parameter, Signature, or BoundArguments define '__reduce_ex__' in their own __dict__. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect class __sizeof__ method type checks
#
# Wave 541 theme: __sizeof__ method class on inspect.Parameter,
# inspect.Signature, and inspect.BoundArguments — all pure Python classes
# defined in Lib/inspect.py.
#
# All three classes inherit __sizeof__ from object, where it appears as a
# 'method_descriptor' on the class object itself (not on instances).
# None define __sizeof__ in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra1411.sizeof_method_type:
  description: "inspect classes: __sizeof__.__class__.__name__ == 'method_descriptor' for Parameter, Signature, BoundArguments; wave 541; new to extra1411"
  kind: python_call_eq
  category: sizeof_method_type
  id_prefix: in1411sz

  columns: [id, function, args, expected, description]
  rows:
    - [in1411sz001,
       "Parameter.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.Parameter.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — Parameter is a pure Python class in Lib/inspect.py; __sizeof__ is inherited from object as a method_descriptor on the class object; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [in1411sz002,
       "Signature.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.Signature.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — Signature is a pure Python class in Lib/inspect.py; __sizeof__ is inherited from object as a method_descriptor on the class object; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [in1411sz003,
       "BoundArguments.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.BoundArguments.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — BoundArguments is a pure Python class in Lib/inspect.py; __sizeof__ is inherited from object as a method_descriptor on the class object; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [in1411sz004,
       "Parameter.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.Parameter.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — Parameter inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [in1411sz005,
       "Signature.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.Signature.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — Signature inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [in1411sz006,
       "BoundArguments.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "inspect.BoundArguments.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — BoundArguments inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]

# ---------------------------------------------------------------------------
# Table 2: inspect class __dict__ membership for __sizeof__ and __reduce_ex__
#
# Wave 541 theme: whether inspect classes define __sizeof__ or __reduce_ex__
# in their own __dict__ vs. inheriting from object.
#
# Parameter, Signature, BoundArguments: all False for both __sizeof__ and
# __reduce_ex__ — none of these pure Python classes override these methods.
# ---------------------------------------------------------------------------

table inspect_extra1411.sizeof_dict_membership:
  description: "inspect classes: '__sizeof__' and '__reduce_ex__' not in own __dict__ for Parameter, Signature, BoundArguments; wave 541; new to extra1411"
  kind: python_call_eq
  category: sizeof_dict_membership
  id_prefix: in1411dm

  columns: [id, function, args, expected, description]
  rows:
    - [in1411dm001,
       "Parameter.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__sizeof__') == False — Parameter does not define __sizeof__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [in1411dm002,
       "Signature.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "inspect.Signature.__dict__.__contains__('__sizeof__') == False — Signature does not define __sizeof__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [in1411dm003,
       "BoundArguments.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__sizeof__') == False — BoundArguments does not define __sizeof__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [in1411dm004,
       "Parameter.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__reduce_ex__') == False — Parameter does not define __reduce_ex__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [in1411dm005,
       "Signature.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "inspect.Signature.__dict__.__contains__('__reduce_ex__') == False — Signature does not define __reduce_ex__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [in1411dm006,
       "BoundArguments.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__reduce_ex__') == False — BoundArguments does not define __reduce_ex__ in its own class __dict__; method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [in1411dm007,
       "Parameter.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__sizeof__') == False — second membership check for Parameter to pad table to minimum; new to extra1411"]
    - [in1411dm008,
       "Signature.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "inspect.Signature.__dict__.__contains__('__sizeof__') == False — second membership check for Signature to pad table to minimum; new to extra1411"]

# ---------------------------------------------------------------------------
# Table 3: inspect class module and name identity
#
# Wave 541 context: the inspect classes' identity as pure Python classes is
# confirmed by checking __module__ == 'inspect' and __name__ values.
# This serves as an anchor table for the wave 541 sizeof theme.
# ---------------------------------------------------------------------------

table inspect_extra1411.class_identity:
  description: "inspect.Parameter, Signature, BoundArguments: __module__ == 'inspect', __name__ correct; wave 541; new to extra1411"
  kind: python_call_eq
  category: class_identity
  id_prefix: in1411id

  columns: [id, function, args, expected, description]
  rows:
    - [in1411id001,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra1411"]
    - [in1411id002,
       "Signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra1411"]
    - [in1411id003,
       "BoundArguments.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra1411"]
    - [in1411id004,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter's class __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra1411"]
    - [in1411id005,
       "Signature.__name__.__eq__",
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature's class __name__ is 'Signature'; str.__eq__('Signature') returns True; new to extra1411"]
    - [in1411id006,
       "BoundArguments.__name__.__eq__",
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments's class __name__ is 'BoundArguments'; str.__eq__('BoundArguments') returns True; new to extra1411"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1411
# ---------------------------------------------------------------------------

invariant inspect_extra1411.parameter_sizeof_is_method_descriptor:
  description: "inspect.Parameter.__sizeof__.__class__.__name__ == 'method_descriptor' — inherited from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: Parameter.__sizeof__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant inspect_extra1411.parameter_sizeof_not_in_dict:
  description: "'__sizeof__' not in inspect.Parameter.__dict__ — Parameter does not override __sizeof__; wave 541; new to extra1411"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__sizeof__"]
  expected: false

invariant inspect_extra1411.signature_sizeof_is_method_descriptor:
  description: "inspect.Signature.__sizeof__.__class__.__name__ == 'method_descriptor' — inherited from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: Signature.__sizeof__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant inspect_extra1411.signature_sizeof_not_in_dict:
  description: "'__sizeof__' not in inspect.Signature.__dict__ — Signature does not override __sizeof__; wave 541; new to extra1411"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__sizeof__"]
  expected: false

invariant inspect_extra1411.boundarguments_sizeof_is_method_descriptor:
  description: "inspect.BoundArguments.__sizeof__.__class__.__name__ == 'method_descriptor' — inherited from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: BoundArguments.__sizeof__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant inspect_extra1411.boundarguments_sizeof_not_in_dict:
  description: "'__sizeof__' not in inspect.BoundArguments.__dict__ — BoundArguments does not override __sizeof__; wave 541; new to extra1411"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__sizeof__"]
  expected: false
