spec: inspect_extra204
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra.zspec.zsdl — covers __name__/__module__ checks for ismethod, isgenerator, iscoroutine, getsourcefile; isclass(int/str)==True, isbuiltin(len)==True, isfunction(len)==False; Parameter and Signature __name__ checks"
  notes:
    - "inspect.__all__ exists and is a list; confirmed with Python 3.14.3."
    - "inspect.__all__.__class__.__name__ == 'list' — the __all__ export list is a plain Python list."
    - "inspect.__all__.__len__() == 107 — there are exactly 107 public exports in Python 3.14.3."
    - "inspect.__all__.__contains__('signature') == True — signature is a public export."
    - "inspect.__all__.__contains__('getsource') == True — getsource is a public export."
    - "inspect.__all__.__contains__('getmembers') == True — getmembers is a public export."
    - "inspect.__all__.__contains__('isfunction') == True — isfunction is a public export."
    - "inspect.__all__.__contains__('isclass') == True — isclass is a public export."
    - "inspect.__all__.__contains__('isbuiltin') == True — isbuiltin is a public export."
    - "inspect.__all__.__contains__('getfile') == True — getfile is a public export."
    - "inspect.__all__.__contains__('getdoc') == True — getdoc is a public export."
    - "inspect.__all__.__contains__('missing_xyz') == False — a nonexistent name is not in __all__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.__all__ class identity and length
#
# inspect.__all__.__class__.__name__ == 'list'
# inspect.__all__.__len__() == 107
#
# The inspect module has an extensive __all__ list; in Python 3.14.3 it
# contains exactly 107 public names covering predicates, source utilities,
# signature objects, and frame introspection tools.
# ---------------------------------------------------------------------------

table inspect_extra204.all_identity:
  description: "inspect.__all__ is a list with exactly 107 entries; class name and length checks; new to extra204"
  kind: python_call_eq
  category: all_list
  id_prefix: inspectall204

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name_eq,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "inspect.__all__.__class__.__name__.__eq__('list') == True — __all__ is a plain Python list; verified with Python 3.14.3; new to extra204"]
    - [all_len_107,
       "__all__.__len__",
       [],
       107,
       "inspect.__all__.__len__() == 107 — there are exactly 107 public exports listed in inspect.__all__ in Python 3.14.3; verified with Python 3.14.3; new to extra204"]
    - [all_contains_signature,
       "__all__.__contains__",
       ["signature"],
       true,
       "inspect.__all__.__contains__('signature') == True — 'signature' is listed as a public export in inspect.__all__; verified with Python 3.14.3; new to extra204"]
    - [all_contains_getsource,
       "__all__.__contains__",
       ["getsource"],
       true,
       "inspect.__all__.__contains__('getsource') == True — 'getsource' is listed as a public export in inspect.__all__; verified with Python 3.14.3; new to extra204"]

# ---------------------------------------------------------------------------
# Table 2: inspect.__all__ membership — predicate functions
#
# Checks that isfunction, isclass, isbuiltin, getmembers are in __all__.
# These are among the most frequently used public inspect utilities.
# ---------------------------------------------------------------------------

table inspect_extra204.all_predicate_exports:
  description: "inspect.__all__ contains isfunction, isclass, isbuiltin, getmembers; new to extra204"
  kind: python_call_eq
  category: all_list
  id_prefix: inspectall204

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_isfunction,
       "__all__.__contains__",
       ["isfunction"],
       true,
       "inspect.__all__.__contains__('isfunction') == True — 'isfunction' is a public export; verified with Python 3.14.3; new to extra204"]
    - [all_contains_isclass,
       "__all__.__contains__",
       ["isclass"],
       true,
       "inspect.__all__.__contains__('isclass') == True — 'isclass' is a public export; verified with Python 3.14.3; new to extra204"]
    - [all_contains_isbuiltin,
       "__all__.__contains__",
       ["isbuiltin"],
       true,
       "inspect.__all__.__contains__('isbuiltin') == True — 'isbuiltin' is a public export; verified with Python 3.14.3; new to extra204"]
    - [all_contains_getmembers,
       "__all__.__contains__",
       ["getmembers"],
       true,
       "inspect.__all__.__contains__('getmembers') == True — 'getmembers' is a public export; verified with Python 3.14.3; new to extra204"]

# ---------------------------------------------------------------------------
# Table 3: inspect.__all__ — source/doc utilities and negation check
# ---------------------------------------------------------------------------

table inspect_extra204.all_source_and_negation:
  description: "inspect.__all__ contains getfile and getdoc; missing_xyz is absent; new to extra204"
  kind: python_call_eq
  category: all_list
  id_prefix: inspectall204

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_getfile,
       "__all__.__contains__",
       ["getfile"],
       true,
       "inspect.__all__.__contains__('getfile') == True — 'getfile' is a public export; verified with Python 3.14.3; new to extra204"]
    - [all_contains_getdoc,
       "__all__.__contains__",
       ["getdoc"],
       true,
       "inspect.__all__.__contains__('getdoc') == True — 'getdoc' is a public export; verified with Python 3.14.3; new to extra204"]
    - [all_not_contains_missing,
       "__all__.__contains__",
       ["missing_xyz"],
       false,
       "inspect.__all__.__contains__('missing_xyz') == False — 'missing_xyz' does not exist in inspect and is absent from __all__; verified with Python 3.14.3; new to extra204"]
    - [all_contains_ismodule,
       "__all__.__contains__",
       ["ismodule"],
       true,
       "inspect.__all__.__contains__('ismodule') == True — 'ismodule' is a public export; verified with Python 3.14.3; new to extra204"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra204
# ---------------------------------------------------------------------------

invariant inspect_extra204.all_is_list:
  description: "inspect.__all__.__class__.__name__ == 'list' — the module's public export list is a plain Python list; verified with Python 3.14.3; new to extra204"
  category: all_list
  kind: python_call_eq
  function: "__all__.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

invariant inspect_extra204.all_len_107:
  description: "inspect.__all__.__len__() == 107 — exactly 107 names are listed in inspect.__all__ in Python 3.14.3; verified with Python 3.14.3; new to extra204"
