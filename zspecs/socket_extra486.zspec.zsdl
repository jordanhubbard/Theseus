spec: socket_extra486
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module functions"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "create_server and has_dualstack_ipv6 were added in Python 3.8"
    - "socketpair may not be available on all platforms (notably Windows)"
    - "fromfd is POSIX-only"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra486.function_names:
  description: "socket module function __name__ identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: sck

  columns: [id, function, args, expected]
  rows:
    - [sck001, getaddrinfo.__name__.__eq__,         ["getaddrinfo"],         true]
    - [sck002, getnameinfo.__name__.__eq__,         ["getnameinfo"],         true]
    - [sck003, gethostbyaddr.__name__.__eq__,       ["gethostbyaddr"],       true]
    - [sck004, getservbyname.__name__.__eq__,       ["getservbyname"],       true]
    - [sck005, getservbyport.__name__.__eq__,       ["getservbyport"],       true]
    - [sck006, setdefaulttimeout.__name__.__eq__,   ["setdefaulttimeout"],   true]
    - [sck007, getdefaulttimeout.__name__.__eq__,   ["getdefaulttimeout"],   true]
    - [sck008, create_connection.__name__.__eq__,   ["create_connection"],   true]
    - [sck009, create_server.__name__.__eq__,       ["create_server"],       true]
    - [sck010, has_dualstack_ipv6.__name__.__eq__,  ["has_dualstack_ipv6"],  true]
    - [sck011, fromfd.__name__.__eq__,              ["fromfd"],              true]
    - [sck012, socketpair.__name__.__eq__,          ["socketpair"],          true]
