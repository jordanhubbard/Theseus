spec: gc_extra_rust
version: ">=3.9"
backend: rust_module(gc_extra_rust)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — gc stdlib"
  notes:
    - "gc provides garbage collector interface."
    - "gc.collect() returns number of objects collected."
    - "gc.get_count() returns tuple of counts."
    - "gc.isenabled() returns bool."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant gc_extra_rust.collect_returns_int:
  description: "gc.collect() returns non-negative int"
  category: collect
  kind: python_call_eq
  function: gc_extra_collect_returns_int
  args: []
  expected: true

invariant gc_extra_rust.get_count_is_tuple:
  description: "gc.get_count() returns a 3-tuple"
  category: get_count
  kind: python_call_eq
  function: gc_extra_get_count_len
  args: []
  expected: 3

invariant gc_extra_rust.isenabled_is_bool:
  description: "gc.isenabled() returns bool"
  category: isenabled
  kind: python_call_eq
  function: gc_extra_isenabled_is_bool
  args: []
  expected: true

