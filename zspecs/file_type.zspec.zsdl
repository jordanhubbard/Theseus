spec: file_type
version: ">=22.0.0"
backend: node(file-type)
esm: true

docs: https://github.com/sindresorhus/file-type#readme

provenance:
  derived_from:
    - "file-type README — https://github.com/sindresorhus/file-type#readme"
    - "Test vectors verified with file-type via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "file-type source"
  notes:
    - "Detect MIME type / extension from binary signatures (magic bytes)."
    - "Install: npm install file-type"
    - "v22 ESM only; named exports for fileTypeFromBuffer/Blob/File/Stream/Tokenizer + supportedExtensions/supportedMimeTypes Set + FileTypeParser class."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Resolves with undefined when no signature matches; throws on invalid input types."
  stderr: "null"
  stickiness: "FileTypeParser instances cache options; static helpers are independent."
  codes: {}

invariant file_type.has_fileTypeFromBuffer:
  description: "fileTypeFromBuffer is callable"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "fileTypeFromBuffer.constructor.name"}
  expected: "AsyncFunction"

invariant file_type.has_fileTypeFromBlob:
  description: "fileTypeFromBlob is callable"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "fileTypeFromBlob.constructor.name"}
  expected: "AsyncFunction"

invariant file_type.has_fileTypeFromStream:
  description: "fileTypeFromStream is callable"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "fileTypeFromStream.constructor.name"}
  expected: "AsyncFunction"

invariant file_type.has_fileTypeFromFile:
  description: "fileTypeFromFile is callable"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "fileTypeFromFile.constructor.name"}
  expected: "AsyncFunction"

invariant file_type.has_FileTypeParser_class:
  description: "FileTypeParser class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "FileTypeParser.constructor.name"}
  expected: "Function"

invariant file_type.supportedExtensions_is_Set:
  description: "supportedExtensions is a Set"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "supportedExtensions.constructor.name"}
  expected: "Set"

invariant file_type.supportedMimeTypes_is_Set:
  description: "supportedMimeTypes is a Set"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "supportedMimeTypes.constructor.name"}
  expected: "Set"

invariant file_type.supports_png_extension:
  description: "'png' is in supportedExtensions"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: supportedExtensions}
    - {method: has, args: ["png"]}
  expected: true

invariant file_type.supports_image_png_mime:
  description: "'image/png' is in supportedMimeTypes"
  category: contains
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: supportedMimeTypes}
    - {method: has, args: ["image/png"]}
  expected: true
