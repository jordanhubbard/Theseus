  columns: [id, function, args, expected]
  rows:
    - ["ab3061007", operator.contains, [abc.ABC.__dict__,                                 "__anext__"], false]
    - ["ab3061008", operator.contains, [abc.ABCMeta.__dict__,                             "__anext__"], false]
    - ["ab3061009", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__anext__"], false]

# ---------------------------------------------------------------------------
# combined — __aexit__, __await__, __anext__ across all 3 abc subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __aexit__:  all false — no async context manager support.
# __await__:  all false — no awaitable protocol.
# __anext__:  all false — no async iteration support.
# abc module types serve as abstract base class infrastructure and decorator
# helpers; none participate in any async protocol.
# ---------------------------------------------------------------------------

