spec: ab3061
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 651 (ab3061): __aexit__, __await__, __anext__ dict-presence for abc module types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "All three abc subjects return false for __aexit__, __await__, and __anext__ in their own __dict__."
    - "abc.ABC is a plain convenience base class providing no async protocol support."
    - "abc.ABCMeta is a metaclass for tracking abstract methods; it has no async protocol support."
    - "type(abc.abstractmethod(lambda: None)) is <class 'function'>; function objects implement neither __await__ nor __aexit__ nor __anext__."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aexit__ dict-presence — operator.contains(Cls.__dict__, '__aexit__')
#
# No abc class defines __aexit__ in its own __dict__; all results are false.
# abc types are abstract base class infrastructure and decorator helpers;
# none participate in the async context manager protocol.
# ---------------------------------------------------------------------------

table ab3061.aexit:
  description: "abc types __aexit__ dict-presence checks; wave 651"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3061

  columns: [id, function, args, expected]
  rows:
    - ["ab3061001", operator.contains, [abc.ABC.__dict__,                                 "__aexit__"], false]
    - ["ab3061002", operator.contains, [abc.ABCMeta.__dict__,                             "__aexit__"], false]
    - ["ab3061003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__aexit__"], false]

# ---------------------------------------------------------------------------
# __await__ dict-presence — operator.contains(Cls.__dict__, '__await__')
#
# No abc class defines __await__ in its own __dict__; all results are false.
# abc.ABC and abc.ABCMeta are metaclass infrastructure, not awaitable objects.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>; function objects
# are not awaitable unless decorated with async def.
# ---------------------------------------------------------------------------

table ab3061.await:
  description: "abc types __await__ dict-presence checks; wave 651"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3061

  columns: [id, function, args, expected]
  rows:
    - ["ab3061004", operator.contains, [abc.ABC.__dict__,                                 "__await__"], false]
    - ["ab3061005", operator.contains, [abc.ABCMeta.__dict__,                             "__await__"], false]
    - ["ab3061006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__await__"], false]

# ---------------------------------------------------------------------------
# __anext__ dict-presence — operator.contains(Cls.__dict__, '__anext__')
#
# No abc class defines __anext__ in its own __dict__; all results are false.
# abc machinery has no async iteration support.
# ---------------------------------------------------------------------------

table ab3061.anext:
  description: "abc types __anext__ dict-presence checks; wave 651"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
