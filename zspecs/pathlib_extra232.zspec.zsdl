spec: pathlib_extra232
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "This spec covers: pathlib module __dict__ membership for all public path classes."
    - "pathlib.__dict__.__contains__('os') == True — os IS imported into pathlib's namespace."
    - "pathlib.__dict__.__class__.__name__ == 'dict' — module __dict__ is always a plain dict."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib module __dict__ membership
# Verifies that the expected public path classes are present in pathlib's __dict__.
# ---------------------------------------------------------------------------

table pathlib_extra232.dict_membership:
  description: "pathlib.__dict__ contains the expected public path classes"
  kind: python_call_eq
  category: module_membership
  id_prefix: pathlibdictmember232

  columns: [id, function, args, expected]
  rows:
    - [path_present,            "__dict__.__contains__", ["Path"],            true]
    - [purepath_present,        "__dict__.__contains__", ["PurePath"],        true]
    - [posixpath_present,       "__dict__.__contains__", ["PosixPath"],       true]
    - [windowspath_present,     "__dict__.__contains__", ["WindowsPath"],     true]
    - [pureposixpath_present,   "__dict__.__contains__", ["PurePosixPath"],   true]
    - [purewindowspath_present, "__dict__.__contains__", ["PureWindowsPath"], true]
    - [os_present,              "__dict__.__contains__", ["os"],              true]

# ---------------------------------------------------------------------------
# pathlib.__dict__.__class__.__name__ == 'dict'
# ---------------------------------------------------------------------------

table pathlib_extra232.dict_class:
  description: "pathlib.__dict__.__class__.__name__ is 'dict'"
  kind: python_call_eq
  category: module_membership
  id_prefix: pathlibdictclass232

  columns: [id, function, args, expected]
  rows:
    - [dict_class_name, "__dict__.__class__.__name__.__eq__", ["dict"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra232.dict_contains_Path:
  description: "pathlib.__dict__.__contains__('Path') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Path"]
  expected: true

invariant pathlib_extra232.dict_contains_PurePath:
  description: "pathlib.__dict__.__contains__('PurePath') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra232.dict_contains_PosixPath:
  description: "pathlib.__dict__.__contains__('PosixPath') == True"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["PosixPath"]
  expected: true

invariant pathlib_extra232.dict_class_is_dict:
  description: "pathlib.__dict__.__class__.__name__ == 'dict'"
  category: module_membership
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true
