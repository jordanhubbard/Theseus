spec: asyncio_extra1126
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module __name__/__spec__/__doc__ identity, asyncio.Queue/Task/Future class module/qualname/name/doc, asyncio.StreamReader/StreamWriter class identity and method qualnames"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.__name__/__spec__.name/__doc__ class, asyncio.Queue/Task/Future module/qualname/name/__doc__ class, asyncio.StreamReader/StreamWriter module/qualname/name/method qualnames — behaviors not covered by extra1096 or extra1111"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1126.module_and_queue_identity:
  description: "asyncio module __name__, __spec__.name, __doc__ class, and asyncio.Queue module/qualname/name/__doc__ class identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: as1126mq
  columns: [id, function, args, expected]
  rows:
    - [as1126mq001, asyncio.__name__.__eq__,                           ["asyncio"],              true]
    - [as1126mq002, asyncio.__spec__.name.__eq__,                      ["asyncio"],              true]
    - [as1126mq003, asyncio.__doc__.__class__.__name__.__eq__,         ["str"],                  true]
    - [as1126mq004, asyncio.__spec__.__class__.__name__.__eq__,        ["ModuleSpec"],           true]
    - [as1126mq005, asyncio.Queue.__module__.__eq__,                   ["asyncio.queues"],       true]
    - [as1126mq006, asyncio.Queue.__qualname__.__eq__,                 ["Queue"],                true]
    - [as1126mq007, asyncio.Queue.__name__.__eq__,                     ["Queue"],                true]
    - [as1126mq008, asyncio.Queue.__doc__.__class__.__name__.__eq__,   ["str"],                  true]
    - [as1126mq009, asyncio.Queue.__class__.__name__.__eq__,           ["type"],                 true]
    - [as1126mq010, asyncio.Queue.put.__qualname__.__eq__,             ["Queue.put"],            true]
    - [as1126mq011, asyncio.Queue.get.__qualname__.__eq__,             ["Queue.get"],            true]
    - [as1126mq012, asyncio.Queue.put.__module__.__eq__,               ["asyncio.queues"],       true]

