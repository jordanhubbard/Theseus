spec: struct_extra90
version: ">=3.9"
extends: struct_extra89
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra89.zspec.zsdl — covers Struct.__dict__ membership for core methods and dunder attrs / module-level function __module__ cross-checks / struct.error and Struct.__dict__ cross-checks (table + invariants)."
    - "struct_extra88.zspec.zsdl — covers Struct.pack/pack_into/unpack/unpack_from/iter_unpack method_descriptor class names / Struct dunder and size class names / struct.error class identity / Struct.__dict__ method membership (table + invariants)."
    - "struct_extra87.zspec.zsdl — covers struct module identity cross-checks / module-level function class names / struct.Struct class identity (table + invariants)."
    - "struct_extra86.zspec.zsdl — covers struct.Struct dunder method class names / struct.error MRO chain / Struct.__dict__ dunder membership (table + invariants)."
    - "struct_extra85.zspec.zsdl — covers struct.Struct/__class__.__name__=='type' / Struct pack/unpack method_descriptor / module-level pack/unpack/calcsize builtin_function_or_method / error class identity (table + invariants)."
    - "struct_extra83.zspec.zsdl — covers module-level function __qualname__.__eq__ / Struct.__dict__.__contains__ for pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct_extra82.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__ / Struct.__name__/__qualname__/__bases__[0].__name__/__mro__.__len__() / Struct.__dict__.__class__.__name__=='mappingproxy' (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra89; it does NOT duplicate invariants present in those files."
    - "Wave 257 theme: struct module-level function __qualname__ values + Struct method __qualname__ values + Struct.__doc__ and struct.error.__doc__ class names + Struct method class name cross-checks."
    - "struct.pack.__qualname__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__qualname__ == 'Struct.size'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__doc__ is None; struct.error.__doc__.__class__.__name__ == 'NoneType'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__eq__('pack')
# struct.pack_into.__qualname__.__eq__('pack_into')
# struct.unpack.__qualname__.__eq__('unpack')
# struct.unpack_from.__qualname__.__eq__('unpack_from')
# struct.iter_unpack.__qualname__.__eq__('iter_unpack')
# struct.calcsize.__qualname__.__eq__('calcsize')
#
# Wave 257 theme: struct module-level function __qualname__ equality.
#
# The six module-level functions pack, pack_into, unpack, unpack_from,
# iter_unpack, and calcsize are all C-extension functions from _struct.
# Each has a __qualname__ equal to its own function name (no enclosing
# class or function). struct_extra83 first anchors these __qualname__
# values; this table cross-checks all six together under structmodulefns90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra90.struct_module_fn_qualname_eq:
  description: "struct/pack/__qualname__.__eq__('pack')==True / pack_into/__qualname__.__eq__('pack_into')==True / unpack/__qualname__.__eq__('unpack')==True / unpack_from/__qualname__.__eq__('unpack_from')==True / iter_unpack/__qualname__.__eq__('iter_unpack')==True / calcsize/__qualname__.__eq__('calcsize')==True — all six module-level C-extension functions have __qualname__ equal to their own name (no enclosing scope); struct_extra83 first anchors these; this table cross-checks all six together under structmodulefns90; first structmodulefns90 anchor for module-level function __qualname__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmodulefns90

  columns: [id, function, args, expected]
  rows:
    - [pack_qualname,        pack.__qualname__.__eq__,        ["pack"],        true]
    - [pack_into_qualname,   pack_into.__qualname__.__eq__,   ["pack_into"],   true]
    - [unpack_qualname,      unpack.__qualname__.__eq__,      ["unpack"],      true]
    - [unpack_from_qualname, unpack_from.__qualname__.__eq__, ["unpack_from"], true]
    - [iter_unpack_qualname, iter_unpack.__qualname__.__eq__, ["iter_unpack"], true]
    - [calcsize_qualname,    calcsize.__qualname__.__eq__,    ["calcsize"],    true]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack')
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into')
# struct.Struct.unpack.__qualname__.__eq__('Struct.unpack')
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from')
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack')
# struct.Struct.size.__qualname__.__eq__('Struct.size')
#
# Wave 257 theme: Struct method __qualname__ equality.
#
# The five method_descriptor methods and the getset_descriptor 'size' all have
# __qualname__ of the form 'Struct.<name>'. struct_extra82 first anchors
# pack/unpack/pack_into/unpack_from __qualname__; this table cross-checks all
# five plus size together under structmodulefns90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra90.struct_Struct_method_qualname_eq:
  description: "struct.Struct.pack/__qualname__.__eq__('Struct.pack')==True / pack_into/__qualname__.__eq__('Struct.pack_into')==True / unpack/__qualname__.__eq__('Struct.unpack')==True / unpack_from/__qualname__.__eq__('Struct.unpack_from')==True / iter_unpack/__qualname__.__eq__('Struct.iter_unpack')==True / size/__qualname__.__eq__('Struct.size')==True — all five method_descriptor methods and the size getset_descriptor have __qualname__=='Struct.<name>'; struct_extra82 first anchors pack/unpack/pack_into/unpack_from; this table cross-checks all six under structmodulefns90; first structmodulefns90 anchor for Struct method __qualname__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmodulefns90

  columns: [id, function, args, expected]
  rows:
    - [pack_qn,        "Struct.pack.__qualname__.__eq__",        ["Struct.pack"],        true]
    - [pack_into_qn,   "Struct.pack_into.__qualname__.__eq__",   ["Struct.pack_into"],   true]
    - [unpack_qn,      "Struct.unpack.__qualname__.__eq__",      ["Struct.unpack"],      true]
    - [unpack_from_qn, "Struct.unpack_from.__qualname__.__eq__", ["Struct.unpack_from"], true]
    - [iter_unpack_qn, "Struct.iter_unpack.__qualname__.__eq__", ["Struct.iter_unpack"], true]
    - [size_qn,        "Struct.size.__qualname__.__eq__",        ["Struct.size"],        true]

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__class__.__name__.__eq__('str')
# struct.error.__doc__.__class__.__name__.__eq__('NoneType')
#
# Wave 257 theme: Struct and error __doc__ class names.
#
# struct.Struct.__doc__ is a str (the Struct class has a docstring).
# struct.error.__doc__ is None (NoneType) — the error exception class does not
# have a docstring of its own. No prior struct spec anchors these two __doc__
# class name checks together under structmodulefns90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra90.struct_doc_class_names:
  description: "struct.Struct/__doc__/__class__/__name__.__eq__('str')==True / struct.error/__doc__/__class__/__name__.__eq__('NoneType')==True — Struct.__doc__ is a str (the Struct class has a docstring); struct.error.__doc__ is None (NoneType, no custom docstring); no prior struct spec anchors these two __doc__ class names together; first structmodulefns90 anchor for Struct and error __doc__ class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmodulefns90

  columns: [id, function, args, expected]
  rows:
    - [struct_doc_str,    "Struct.__doc__.__class__.__name__.__eq__", ["str"],      true]
    - [error_doc_nonetype, "error.__doc__.__class__.__name__.__eq__", ["NoneType"], true]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.unpack.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.iter_unpack.__class__.__name__.__eq__('method_descriptor')
# struct.Struct.size.__class__.__name__.__eq__('getset_descriptor')
# struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor')
#
# Wave 257 theme: Struct method class names cross-check.
#
# pack, unpack, and iter_unpack are method_descriptor (C-level methods).
# size is a getset_descriptor (C-level read-only property via __get__/__set__).
# __init__ is a wrapper_descriptor (from the C slot tp_init). struct_extra88
# first anchors pack/pack_into/unpack/unpack_from/iter_unpack as method_descriptor;
# this table cross-checks pack/unpack/iter_unpack and adds size/init class names.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra90.struct_Struct_method_class_names_xchk:
  description: "struct.Struct.pack/__class__.__name__.__eq__('method_descriptor')==True / unpack/__class__.__name__.__eq__('method_descriptor')==True / iter_unpack/__class__.__name__.__eq__('method_descriptor')==True / size/__class__.__name__.__eq__('getset_descriptor')==True / __init__/__class__.__name__.__eq__('wrapper_descriptor')==True — pack/unpack/iter_unpack are C-level method_descriptor; size is a getset_descriptor (read-only C property); __init__ is a wrapper_descriptor (C slot); struct_extra88 first anchors pack/unpack/iter_unpack; this table cross-checks and adds size/__init__; first structmodulefns90 anchor for this class name cross-check grouping"
  kind: python_call_eq
  category: type_identity
  id_prefix: structmodulefns90

  columns: [id, function, args, expected]
  rows:
    - [pack_method_desc,     "Struct.pack.__class__.__name__.__eq__",       ["method_descriptor"],  true]
    - [unpack_method_desc,   "Struct.unpack.__class__.__name__.__eq__",     ["method_descriptor"],  true]
    - [iter_unpack_meth_desc, "Struct.iter_unpack.__class__.__name__.__eq__", ["method_descriptor"], true]
    - [size_getset_desc,     "Struct.size.__class__.__name__.__eq__",       ["getset_descriptor"],  true]
    - [init_wrapper_desc,    "Struct.__init__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__eq__('pack') — standalone
#
# struct.pack.__qualname__ is 'pack'. pack is a module-level C-extension
# function from _struct; its __qualname__ matches its simple name (no class
# prefix). struct_extra83 first anchors this; this standalone re-anchors under
# structmodulefns90. First standalone for struct.pack __qualname__ under structmodulefns90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra90.pack_qualname:
  description: "struct.pack.__qualname__.__eq__('pack') == True — struct.pack is a C-extension function from _struct; its __qualname__ is 'pack' (no enclosing scope); struct_extra83 first anchors this; first standalone for struct.pack __qualname__ under structmodulefns90"
  category: type_identity
  kind: python_call_eq
  function: pack.__qualname__.__eq__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize.__qualname__.__eq__('calcsize') — standalone
#
# struct.calcsize.__qualname__ is 'calcsize'. calcsize is the function that
# returns the size of the struct described by a format string. It is a C-extension
# function from _struct with a simple __qualname__. struct_extra83 first anchors
# this; this standalone re-anchors under structmodulefns90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra90.calcsize_qualname:
  description: "struct.calcsize.__qualname__.__eq__('calcsize') == True — struct.calcsize returns the byte size described by a format string; it is a C-extension from _struct with __qualname__=='calcsize'; struct_extra83 first anchors this; first standalone for struct.calcsize __qualname__ under structmodulefns90"
  category: type_identity
  kind: python_call_eq
  function: calcsize.__qualname__.__eq__
  args: ["calcsize"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack') — standalone
#
# struct.Struct.pack.__qualname__ is 'Struct.pack'. struct_extra82 first anchors
# this; this standalone re-anchors under structmodulefns90. The 'Struct.' prefix
# in the qualname indicates pack is a method of the Struct class (not a closure
# or nested function). First standalone for Struct.pack __qualname__ under structmodulefns90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra90.struct_pack_qualname:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — Struct.pack is a C-level method_descriptor; its __qualname__ is 'Struct.pack' (the 'Struct.' prefix identifies it as a method of the Struct class); struct_extra82 first anchors this; first standalone for Struct.pack __qualname__ under structmodulefns90"
  category: type_identity
  kind: python_call_eq
  function: "Struct.pack.__qualname__.__eq__"
  args: ["Struct.pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') — standalone
#
# struct.Struct.size is a getset_descriptor. 'size' is a C-level read-only
# property that returns the precomputed byte size of a Struct format string.
# It uses the C get/set slot mechanism (PyGetSetDef), resulting in the class
# 'getset_descriptor'. This differs from the method_descriptor used by pack
# and unpack. No prior struct spec anchors Struct.size.__class__.__name__.__eq__
# as a standalone under structmodulefns90. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra90.size_getset_desc:
  description: "struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') == True — Struct.size is a C-level read-only property implemented as a PyGetSetDef slot; its class is 'getset_descriptor', distinguishing it from the method_descriptor used by pack/unpack; no prior struct spec anchors this as a standalone; first standalone for Struct.size class name under structmodulefns90"
  category: type_identity
  kind: python_call_eq
  function: "Struct.size.__class__.__name__.__eq__"
  args: ["getset_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__class__.__name__.__eq__('str') — standalone
#
# struct.Struct.__doc__.__class__.__name__ is 'str'. The Struct class has a
# docstring (describing its fmt constructor parameter), so __doc__ is a plain
# str. No prior struct spec anchors Struct.__doc__.__class__.__name__.__eq__('str')
# as a standalone under structmodulefns90. First standalone for Struct.__doc__ class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra90.struct_doc_str:
  description: "struct.Struct.__doc__.__class__.__name__.__eq__('str') == True — Struct has a class docstring describing its constructor (Struct(fmt)); __doc__.__class__.__name__ is 'str'; no prior struct spec anchors this as a standalone; first standalone for Struct.__doc__ class name under structmodulefns90"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true
