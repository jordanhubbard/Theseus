spec: theseus_sysconfig_cr
version: ">=3.9"
backend: python_cleanroom(theseus_sysconfig_cr)
blocks: sysconfig

docs: https://docs.python.org/3/library/sysconfig.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sysconfig.html"
  notes:
    - "Clean-room sysconfig utilities. Do NOT import sysconfig."
    - "get_python_version(): return major.minor string like '3.9'."
    - "get_platform(): return platform string like 'linux-x86_64'."
    - "get_scheme_names(): return tuple of known installation scheme names."
    - "get_config_vars(): return dict of config variable name → value."
    - "sysconfig_version_type(): isinstance(get_python_version(), str) == True."
    - "sysconfig_version_format(): '.' in get_python_version() == True."
    - "sysconfig_scheme_names_nonempty(): len(get_scheme_names()) > 0."
    - "Use sys.version_info for version; platform.system()/machine() for platform (import sys, platform allowed)."
    - "Export: get_python_version, get_platform, get_scheme_names, get_config_vars."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_sysconfig_cr.version_type:
  description: "get_python_version() returns a string"
  category: version
  kind: python_call_eq
  function: sysconfig_version_type
  args: []
  expected: true

invariant theseus_sysconfig_cr.version_format:
  description: "'.' in get_python_version()"
  category: version
  kind: python_call_eq
  function: sysconfig_version_format
  args: []
  expected: true

invariant theseus_sysconfig_cr.scheme_names_nonempty:
  description: "len(get_scheme_names()) > 0"
  category: scheme_names
  kind: python_call_eq
  function: sysconfig_scheme_names_nonempty
  args: []
  expected: true
