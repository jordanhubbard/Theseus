spec: abc_extra2101
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2101 (abc_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks."
    - "abc.ABCMeta does NOT define __class_getitem__ in its own __dict__ — ABCMeta is a metaclass (type subclass) and does not expose generic alias syntax."
    - "abc.ABC does NOT define __class_getitem__ in its own __dict__ on Python 3.14.4 — generic alias support is not defined directly on the ABC helper class."
    - "abc.abstractmethod does NOT define __class_getitem__ in its own __dict__."
    - "abc.ABCMeta does NOT define __init_subclass__ in its own __dict__ — inherited from type."
    - "abc.ABC does NOT define __init_subclass__ in its own __dict__ — inherited from object via ABCMeta."
    - "abc.abstractmethod does NOT define __init_subclass__ in its own __dict__."
    - "abc.ABCMeta does NOT define __subclasshook__ in its own __dict__ — ABCMeta defines __instancecheck__ and __subclasscheck__, not __subclasshook__."
    - "abc.ABC does NOT define __subclasshook__ in its own __dict__ — __subclasshook__ is inherited from object on Python 3.14.4."
    - "abc.abstractmethod does NOT define __subclasshook__ in its own __dict__."
    - "None of the checked abc objects define __mro_entries__ in their own __dict__ — MRO resolution protocol is absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2101.class_getitem_protocol:
  description: "abc classes __class_getitem__ dict-presence checks — generic alias protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2101

  columns: [id, function, args, expected]
  rows:
    - ["ab2101001", "abc.ABCMeta.__dict__.__contains__", ["__class_getitem__"], false]
    - ["ab2101002", "abc.ABC.__dict__.__contains__", ["__class_getitem__"], false]
    - ["ab2101003", "abc.abstractmethod.__dict__.__contains__", ["__class_getitem__"], false]

