spec: gc_extra32
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc_extra31.zspec.zsdl."
    - "Prior specs covered: collect/disable/enable/isenabled/get_count/get_threshold/set_threshold/get_objects/__name__.__len__() (extra30); collect/disable/enable/isenabled/get_count/get_threshold/set_threshold/get_objects/__module__.__len__()==2 (extra30, extra31); get_referrers/get_referents __name__/__module__/__qualname__.__len__() (extra31); get_count/get_threshold __qualname__.__len__() (extra31); gc.garbage/__class__/__name__/__eq__('list') (multiple specs); gc.get_count()/get_threshold() __class__/__name__/__eq__('tuple') (multiple specs); gc.__name__/__eq__('gc') and gc.__package__/__eq__('') (extra22)."
    - "This spec covers: gc.collect.__qualname__.__len__() (NOVEL — 'collect' has 7 characters; prior specs check __qualname__.__eq__ but not __len__()); gc.enable.__qualname__.__len__() (NOVEL — 'enable' has 6 characters); gc.disable.__qualname__.__len__() (NOVEL — 'disable' has 7 characters); gc.isenabled.__qualname__.__len__() (NOVEL — 'isenabled' has 9 characters); gc.set_threshold.__qualname__.__len__() (NOVEL — 'set_threshold' has 13 characters); gc.get_objects.__qualname__.__len__() (NOVEL — 'get_objects' has 11 characters); gc.garbage.__class__.__name__.__len__() (NOVEL — 'list' has 4 characters); gc.callbacks.__class__.__name__.__len__() (NOVEL — 'list' has 4 characters); gc.get_count().__class__.__name__.__len__() (NOVEL — 'tuple' has 5 characters); gc.get_threshold().__class__.__name__.__len__() (NOVEL — 'tuple' has 5 characters); gc.__name__.__len__() (NOVEL — 'gc' has 2 characters); gc.__package__.__len__() (NOVEL — empty string has 0 characters)."
    - "gc.collect.__qualname__ == 'collect' (len 7). Prior specs check __qualname__.__eq__; no prior spec checks __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.enable.__qualname__ == 'enable' (len 6). Novel __len__ check. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.disable.__qualname__ == 'disable' (len 7). Novel __len__ check. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.isenabled.__qualname__ == 'isenabled' (len 9). Novel __len__ check. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.set_threshold.__qualname__ == 'set_threshold' (len 13). No prior spec checks __qualname__.__len__() for set_threshold. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_objects.__qualname__ == 'get_objects' (len 11). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.garbage.__class__.__name__ == 'list' (len 4). Prior specs check __eq__('list'); no prior spec checks __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.callbacks.__class__.__name__ == 'list' (len 4). Novel __len__ check. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_count().__class__.__name__ == 'tuple' (len 5). Prior specs check __eq__('tuple'); no prior spec checks __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.get_threshold().__class__.__name__ == 'tuple' (len 5). Novel __len__ check. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.__name__ == 'gc' (len 2). extra22 checks __eq__('gc') but not __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "gc.__package__ == '' (len 0). extra22 checks __eq__('') but not __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# gc.collect/__qualname__.__len__() — novel
#
# Prior specs (extra11, extra24) check collect.__qualname__.__eq__('collect').
# No prior spec checks collect.__qualname__.__len__(). len('collect') == 7.
# ---------------------------------------------------------------------------

invariant gc_extra32.collect.qualname.len:
  description: "gc.collect.__qualname__.__len__() == 7 — 'collect' has 7 characters, novel invariant"
  category: string_length
  kind: python_call_eq
  function: collect.__qualname__.__len__
  args: []
  expected: 7

invariant gc_extra32.enable.qualname.len:
  description: "gc.enable.__qualname__.__len__() == 6 — 'enable' has 6 characters, novel invariant"
  category: string_length
  kind: python_call_eq
  function: enable.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Table: gc builtin function __qualname__.__len__() — novel invariants
#
# No prior spec checks __qualname__.__len__() for any of these gc builtins.
# For C builtins, __qualname__ equals __name__, so lengths match __name__:
# disable (7), isenabled (9), set_threshold (13), get_objects (11).
# ---------------------------------------------------------------------------

table gc_extra32.builtin_qualname_lengths:
  description: "gc.disable/isenabled/set_threshold/get_objects __qualname__.__len__() — novel invariants"
  kind: python_call_eq
  category: string_length
  id_prefix: gcbql32

  columns: [id, function, args, expected]
  rows:
    - [disable,       disable.__qualname__.__len__,       [], 7]
    - [isenabled,     isenabled.__qualname__.__len__,     [], 9]
    - [set_threshold, set_threshold.__qualname__.__len__, [], 13]
    - [get_objects,   get_objects.__qualname__.__len__,   [], 11]

# ---------------------------------------------------------------------------
# gc.garbage and gc.callbacks __class__.__name__.__len__() — novel
#
# Prior specs check garbage.__class__.__name__.__eq__('list').
# No prior spec checks __class__.__name__.__len__() for either attribute.
# Both are list objects: len('list') == 4.
# ---------------------------------------------------------------------------

invariant gc_extra32.garbage.classname.len:
  description: "gc.garbage.__class__.__name__.__len__() == 4 — 'list' has 4 characters, novel invariant"
  category: string_length
  kind: python_call_eq
  function: garbage.__class__.__name__.__len__
  args: []
  expected: 4

invariant gc_extra32.callbacks.classname.len:
  description: "gc.callbacks.__class__.__name__.__len__() == 4 — 'list' has 4 characters, novel invariant"
  category: string_length
  kind: python_call_eq
  function: callbacks.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Table: gc.get_count() and gc.get_threshold() return type name lengths
#
# Prior specs check get_count().__class__.__name__.__eq__('tuple').
# No prior spec checks __class__.__name__.__len__() for either call result.
# Both return tuples: len('tuple') == 5.
# Also groups gc.__name__.__len__() and gc.__package__.__len__() — both novel.
# gc.__name__ == 'gc' (len 2); gc.__package__ == '' (len 0).
# ---------------------------------------------------------------------------

table gc_extra32.return_type_name_lengths:
  description: "gc.get_count() and gc.get_threshold() return type class name len (5) plus module __name__/__package__ len — novel invariants"
  kind: python_call_eq
  category: string_length
  id_prefix: gcrtnl32

  columns: [id, function, args, expected]
  rows:
    - [get_count_classname_len,     get_count().__class__.__name__.__len__,     [], 5]
    - [get_threshold_classname_len, get_threshold().__class__.__name__.__len__, [], 5]
    - [module_name_len,             __name__.__len__,                           [], 2]
    - [module_package_len,          __package__.__len__,                        [], 0]
