spec: multiprocessing_extra82
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra81.zspec.zsdl."
    - "This spec covers: wave 246 theme — multiprocessing Process/exception __name__ and __qualname__ identity, and context-bound function __qualname__ values. NEW in extra82: Process.__name__=='Process'; Process.__qualname__=='Process'; ProcessError.__name__=='ProcessError'; AuthenticationError.__name__=='AuthenticationError'; BufferTooShort.__name__=='BufferTooShort'; TimeoutError.__name__=='TimeoutError'; ProcessError.__qualname__=='ProcessError'; AuthenticationError.__qualname__=='AuthenticationError'; cpu_count.__qualname__=='BaseContext.cpu_count' (bound method of context); current_process.__qualname__=='current_process' (module-level function); parent_process.__qualname__=='parent_process'; active_children.__qualname__=='active_children'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__name__ == 'Process'. Simple class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__qualname__ == 'Process'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__name__ == 'ProcessError'. Simple exception class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError'. Simple exception class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort'. Simple exception class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__name__ == 'TimeoutError'. Simple exception class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__qualname__ == 'ProcessError'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__qualname__ == 'AuthenticationError'. Simple unqualified class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count'. cpu_count is a bound method of the multiprocessing context object, so its qualname is qualified with BaseContext. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__qualname__ == 'current_process'. current_process is a module-level function with a simple qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.parent_process.__qualname__ == 'parent_process'. parent_process is a module-level function with a simple qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.active_children.__qualname__ == 'active_children'. active_children is a module-level function with a simple qualname. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process __name__ and __qualname__ identity — extra82
#
# Wave 246 theme: multiprocessing Process/exception __name__ and __qualname__ identity.
#
# Process.__name__ == 'Process'
# Process.__qualname__ == 'Process'
# ---------------------------------------------------------------------------

table multiprocessing_extra82.Process_name_and_qualname:
  description: "multiprocessing Process __name__ and __qualname__ identity checks in mpextra82 namespace — wave 246 theme: multiprocessing Process/exception __name__ and __qualname__ identity; Process.__name__=='Process'; Process.__qualname__=='Process'; ProcessError.__name__=='ProcessError'; ProcessError.__qualname__=='ProcessError'; all are simple top-level class names with no enclosing scope; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra82

  columns: [id, function, args, expected, description]
  rows:
    - [proc_name,      Process.__name__.__eq__,          ["Process"],      true, "Process.__name__ == 'Process' — simple top-level class name; verified with Python 3.14.3"]
    - [proc_qualname,  Process.__qualname__.__eq__,      ["Process"],      true, "Process.__qualname__ == 'Process' — simple unqualified class name; verified with Python 3.14.3"]
    - [pe_name,        ProcessError.__name__.__eq__,     ["ProcessError"], true, "ProcessError.__name__ == 'ProcessError' — simple exception class name; verified with Python 3.14.3"]
    - [pe_qualname,    ProcessError.__qualname__.__eq__,  ["ProcessError"], true, "ProcessError.__qualname__ == 'ProcessError' — simple unqualified class name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing exception __name__ checks — extra82
#
# AuthenticationError.__name__ == 'AuthenticationError'
# BufferTooShort.__name__ == 'BufferTooShort'
# TimeoutError.__name__ == 'TimeoutError'
# AuthenticationError.__qualname__ == 'AuthenticationError'
# ---------------------------------------------------------------------------

table multiprocessing_extra82.exception_names:
  description: "multiprocessing exception __name__ and __qualname__ checks in mpextra82 namespace — wave 246 theme: multiprocessing exception identity; AuthenticationError.__name__=='AuthenticationError'; BufferTooShort.__name__=='BufferTooShort'; TimeoutError.__name__=='TimeoutError'; AuthenticationError.__qualname__=='AuthenticationError'; all are simple top-level exception class names; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra82a

  columns: [id, function, args, expected, description]
  rows:
    - [auth_name,      AuthenticationError.__name__.__eq__,     ["AuthenticationError"], true, "AuthenticationError.__name__ == 'AuthenticationError' — simple exception class name; verified with Python 3.14.3"]
    - [buf_name,       BufferTooShort.__name__.__eq__,          ["BufferTooShort"],      true, "BufferTooShort.__name__ == 'BufferTooShort' — simple exception class name; verified with Python 3.14.3"]
    - [timeout_name,   TimeoutError.__name__.__eq__,            ["TimeoutError"],        true, "TimeoutError.__name__ == 'TimeoutError' — simple exception class name; verified with Python 3.14.3"]
    - [auth_qualname,  AuthenticationError.__qualname__.__eq__, ["AuthenticationError"], true, "AuthenticationError.__qualname__ == 'AuthenticationError' — simple unqualified class name; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing context-bound function __qualname__ checks — extra82
#
# cpu_count.__qualname__ == 'BaseContext.cpu_count'
# current_process.__qualname__ == 'current_process'
# parent_process.__qualname__ == 'parent_process'
# active_children.__qualname__ == 'active_children'
# ---------------------------------------------------------------------------

table multiprocessing_extra82.context_function_qualnames:
  description: "multiprocessing context-bound and module-level function __qualname__ checks in mpextra82 namespace — wave 246 theme: multiprocessing function __qualname__ identity; cpu_count.__qualname__=='BaseContext.cpu_count' (cpu_count is a bound method of the context object, so its qualname is qualified with BaseContext); current_process.__qualname__=='current_process' (module-level function); parent_process.__qualname__=='parent_process' (module-level function); active_children.__qualname__=='active_children' (module-level function); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra82b

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_count_qualname,       cpu_count.__qualname__.__eq__,       ["BaseContext.cpu_count"], true, "cpu_count.__qualname__ == 'BaseContext.cpu_count' — cpu_count is a bound method of the context object; verified with Python 3.14.3"]
    - [current_proc_qualname,    current_process.__qualname__.__eq__, ["current_process"],       true, "current_process.__qualname__ == 'current_process' — module-level function with simple qualname; verified with Python 3.14.3"]
    - [parent_proc_qualname,     parent_process.__qualname__.__eq__,  ["parent_process"],        true, "parent_process.__qualname__ == 'parent_process' — module-level function with simple qualname; verified with Python 3.14.3"]
    - [active_children_qualname, active_children.__qualname__.__eq__, ["active_children"],       true, "active_children.__qualname__ == 'active_children' — module-level function with simple qualname; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing cross-check table — extra82
# ---------------------------------------------------------------------------

table multiprocessing_extra82.identity_cross_checks:
  description: "multiprocessing identity cross-check table in mpextra82 namespace — wave 246 theme: multiprocessing identity attributes cross-check; Process.__name__=='Process' (cross-check); AuthenticationError.__name__=='AuthenticationError' (cross-check); cpu_count.__qualname__=='BaseContext.cpu_count' (cross-check: confirms cpu_count is a context method not a plain function); current_process.__qualname__=='current_process' (cross-check); BufferTooShort.__name__=='BufferTooShort' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpextra82c

  columns: [id, function, args, expected, description]
  rows:
    - [proc_name_cross,    Process.__name__.__eq__,             ["Process"],              true, "Process.__name__ == 'Process' — cross-check; verified with Python 3.14.3"]
    - [auth_name_cross,    AuthenticationError.__name__.__eq__, ["AuthenticationError"],  true, "AuthenticationError.__name__ == 'AuthenticationError' — cross-check; verified with Python 3.14.3"]
    - [cpu_qual_cross,     cpu_count.__qualname__.__eq__,       ["BaseContext.cpu_count"], true, "cpu_count.__qualname__ == 'BaseContext.cpu_count' — cross-check: confirms cpu_count is a context method; verified with Python 3.14.3"]
    - [curproc_qual_cross, current_process.__qualname__.__eq__, ["current_process"],      true, "current_process.__qualname__ == 'current_process' — cross-check; verified with Python 3.14.3"]
    - [buf_name_cross,     BufferTooShort.__name__.__eq__,      ["BufferTooShort"],       true, "BufferTooShort.__name__ == 'BufferTooShort' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra82
# ---------------------------------------------------------------------------

invariant multiprocessing_extra82.Process_name:
  description: "multiprocessing.Process.__name__.__eq__('Process') returns True — Process is a top-level class with a simple name; NEW in extra82: first standalone __name__ invariant for Process in mpextra82 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__name__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra82.AuthenticationError_name:
  description: "multiprocessing.AuthenticationError.__name__.__eq__('AuthenticationError') returns True — AuthenticationError is a top-level exception class in multiprocessing; NEW in extra82: first standalone __name__ invariant for AuthenticationError in mpextra82 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AuthenticationError.__name__.__eq__
  args: ["AuthenticationError"]
  expected: true

invariant multiprocessing_extra82.cpu_count_qualname:
  description: "multiprocessing.cpu_count.__qualname__.__eq__('BaseContext.cpu_count') returns True — cpu_count is a bound method of the multiprocessing context object (BaseContext), so its qualname is qualified with the class name; this distinguishes it from module-level functions like current_process; NEW in extra82: first standalone __qualname__ invariant for cpu_count in mpextra82 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: cpu_count.__qualname__.__eq__
  args: ["BaseContext.cpu_count"]
  expected: true

invariant multiprocessing_extra82.current_process_qualname:
  description: "multiprocessing.current_process.__qualname__.__eq__('current_process') returns True — current_process is a module-level function with a simple unqualified qualname, unlike cpu_count which is a context bound method; NEW in extra82: first standalone __qualname__ invariant for current_process in mpextra82 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: current_process.__qualname__.__eq__
  args: ["current_process"]
  expected: true

invariant multiprocessing_extra82.BufferTooShort_name:
  description: "multiprocessing.BufferTooShort.__name__.__eq__('BufferTooShort') returns True — BufferTooShort is a top-level exception class in multiprocessing used when a buffer is too small to receive a message; NEW in extra82: first standalone __name__ invariant for BufferTooShort in mpextra82 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BufferTooShort.__name__.__eq__
  args: ["BufferTooShort"]
  expected: true
