spec: split_string
version: ">=6.1.0"
backend: node(split-string)

docs: https://www.npmjs.com/package/split-string

provenance:
  derived_from:
    - "split-string README — https://www.npmjs.com/package/split-string"
    - "Test vectors verified with split-string via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "split-string source"
  notes:
    - "split-string is an npm package. Install: npm install split-string"
    - "Splits a dot-notated string into an array of path segments."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of strings."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table split_string.split:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: sstr

  columns: [id, args, expected]
  rows:
    - [three_parts,  ["a.b.c"],        ["a", "b", "c"]]
    - [two_parts,    ["foo.bar.baz"],   ["foo", "bar", "baz"]]
    - [single,       ["x"],            ["x"]]
