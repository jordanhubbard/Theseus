spec: io_extra275
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io.BufferedReader is a C-extension class; its methods are method_descriptor objects."
    - "BufferedReader methods: read, read1, readline, peek all have __class__.__name__ == 'method_descriptor'."
    - "BufferedReader method qualnames follow 'BufferedReader.<method_name>' pattern."
    - "io.BufferedWriter is also C-backed; its write and flush methods are method_descriptor objects."
    - "BufferedWriter method qualnames follow 'BufferedWriter.<method_name>' pattern."
    - "io.BufferedRandom.__module__ == '_io' (C extension module)."
    - "io.BufferedRandom.__name__ == 'BufferedRandom'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: BufferedReader and BufferedWriter method __name__ identity
# ---------------------------------------------------------------------------

table io_extra275.buffered_method_names:
  description: "io.BufferedReader and BufferedWriter method __name__ for read, read1, readline, peek, write, flush"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [read_name,     BufferedReader.read.__name__.__eq__,     ["read"],     true, "io.BufferedReader.read.__name__ == 'read'"]
    - [read1_name,    BufferedReader.read1.__name__.__eq__,    ["read1"],    true, "io.BufferedReader.read1.__name__ == 'read1'"]
    - [readline_name, BufferedReader.readline.__name__.__eq__, ["readline"], true, "io.BufferedReader.readline.__name__ == 'readline'"]
    - [peek_name,     BufferedReader.peek.__name__.__eq__,     ["peek"],     true, "io.BufferedReader.peek.__name__ == 'peek'"]
    - [write_name,    BufferedWriter.write.__name__.__eq__,    ["write"],    true, "io.BufferedWriter.write.__name__ == 'write'"]
    - [flush_name,    BufferedWriter.flush.__name__.__eq__,    ["flush"],    true, "io.BufferedWriter.flush.__name__ == 'flush'"]

# ---------------------------------------------------------------------------
# Table: BufferedReader and BufferedWriter method __class__.__name__ (all method_descriptor)
# ---------------------------------------------------------------------------

table io_extra275.buffered_method_classes:
  description: "io.BufferedReader and BufferedWriter method __class__.__name__ (all method_descriptor)"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [read_class,     BufferedReader.read.__class__.__name__.__eq__,     ["method_descriptor"], true, "io.BufferedReader.read.__class__.__name__ == 'method_descriptor'"]
    - [read1_class,    BufferedReader.read1.__class__.__name__.__eq__,    ["method_descriptor"], true, "io.BufferedReader.read1.__class__.__name__ == 'method_descriptor'"]
    - [readline_class, BufferedReader.readline.__class__.__name__.__eq__, ["method_descriptor"], true, "io.BufferedReader.readline.__class__.__name__ == 'method_descriptor'"]
    - [peek_class,     BufferedReader.peek.__class__.__name__.__eq__,     ["method_descriptor"], true, "io.BufferedReader.peek.__class__.__name__ == 'method_descriptor'"]
    - [write_class,    BufferedWriter.write.__class__.__name__.__eq__,    ["method_descriptor"], true, "io.BufferedWriter.write.__class__.__name__ == 'method_descriptor'"]
    - [flush_class,    BufferedWriter.flush.__class__.__name__.__eq__,    ["method_descriptor"], true, "io.BufferedWriter.flush.__class__.__name__ == 'method_descriptor'"]

# ---------------------------------------------------------------------------
# Standalone invariants: qualnames and BufferedRandom identity
# ---------------------------------------------------------------------------

invariant io_extra275.BufferedReader.read.qualname:
  description: "io.BufferedReader.read.__qualname__ == 'BufferedReader.read'"
  category: identity
  kind: python_call_eq
  function: BufferedReader.read.__qualname__.__eq__
  args: ["BufferedReader.read"]
  expected: true

invariant io_extra275.BufferedReader.read1.qualname:
  description: "io.BufferedReader.read1.__qualname__ == 'BufferedReader.read1'"
  category: identity
  kind: python_call_eq
  function: BufferedReader.read1.__qualname__.__eq__
  args: ["BufferedReader.read1"]
  expected: true

invariant io_extra275.BufferedWriter.write.qualname:
  description: "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write'"
  category: identity
  kind: python_call_eq
  function: BufferedWriter.write.__qualname__.__eq__
  args: ["BufferedWriter.write"]
  expected: true

invariant io_extra275.BufferedWriter.flush.qualname:
  description: "io.BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush'"
  category: identity
  kind: python_call_eq
  function: BufferedWriter.flush.__qualname__.__eq__
  args: ["BufferedWriter.flush"]
  expected: true

invariant io_extra275.BufferedRandom.name:
  description: "io.BufferedRandom.__name__ == 'BufferedRandom'"
  category: identity
  kind: python_call_eq
  function: BufferedRandom.__name__.__eq__
  args: ["BufferedRandom"]
  expected: true

invariant io_extra275.BufferedRandom.module:
  description: "io.BufferedRandom.__module__ == '_io' (C extension)"
  category: identity
  kind: python_call_eq
  function: BufferedRandom.__module__.__eq__
  args: ["_io"]
  expected: true
