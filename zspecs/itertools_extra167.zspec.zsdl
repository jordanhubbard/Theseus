spec: itertools_extra167
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.groupby.__name__ 'groupby'; itertools.groupby.__module__ 'itertools'; itertools.groupby.__bases__[0].__name__ 'object'; itertools.zip_longest.__name__ 'zip_longest'; itertools.zip_longest.__module__ 'itertools'; itertools.zip_longest.__bases__[0].__name__ 'object'; itertools.takewhile.__name__ 'takewhile'; itertools.takewhile.__module__ 'itertools'; itertools.takewhile.__bases__[0].__name__ 'object'; itertools.dropwhile.__name__ 'dropwhile'; itertools.dropwhile.__module__ 'itertools'; itertools.dropwhile.__bases__[0].__name__ 'object' (Wave 296)."
    - "itertools.groupby.__name__ == 'groupby' — itertools.groupby is a C extension type in itertoolsmodule.c that makes an iterator returning consecutive keys and groups from an iterable; its type __name__ is 'groupby'. Verified with Python 3.14.3."
    - "itertools.groupby.__module__ == 'itertools' — groupby is declared in the itertools C extension module; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.groupby.__bases__[0].__name__ == 'object' — groupby is a C extension type in itertoolsmodule.c that inherits directly from object. Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest' — itertools.zip_longest is a C extension type in itertoolsmodule.c that aggregates elements from each iterable, filling shorter iterables with fillvalue; its type __name__ is 'zip_longest'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools' — zip_longest is declared in the itertools C extension module; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__bases__[0].__name__ == 'object' — zip_longest is a C extension type that inherits directly from object. Verified with Python 3.14.3."
    - "itertools.takewhile.__name__ == 'takewhile' — itertools.takewhile is a C extension type that returns elements from an iterable as long as a predicate is true; its type __name__ is 'takewhile'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__name__ == 'dropwhile' — itertools.dropwhile is a C extension type that drops elements from an iterable as long as a predicate is true, then returns the rest; its type __name__ is 'dropwhile'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.groupby C extension type identity
#
# Wave 296 theme: itertools.groupby C extension type — __name__, __module__,
# __bases__[0], and __class__.__name__.
#
# itertools.groupby.__name__ == 'groupby'
# itertools.groupby.__module__ == 'itertools'
# itertools.groupby.__bases__[0].__name__ == 'object'
# itertools.groupby.__class__.__name__ == 'type'
#
# itertools.groupby(iterable, key=None) makes an iterator that returns
# consecutive keys and groups from an iterable. The key is a function computing
# a key value for each element; if not supplied, it defaults to an identity
# function. It is a C extension type in itertoolsmodule.c that inherits
# directly from object. New to extra167.
# ---------------------------------------------------------------------------

table itertools_extra167.groupby_identity:
  description: "itertools.groupby: __name__ 'groupby', __module__ 'itertools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 296; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsgbi167

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_name_groupby,
       "groupby.__name__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__name__.__eq__('groupby') == True — groupby is a C extension type in itertoolsmodule.c that makes an iterator returning consecutive keys and groups from an iterable; its type __name__ attribute is 'groupby'; str.__eq__('groupby') returns True; new to extra167"]
    - [groupby_module_itertools,
       "groupby.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.groupby.__module__.__eq__('itertools') == True — groupby is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra167"]
    - ["groupby_bases_0_object",
       "groupby.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.groupby.__bases__[0].__name__.__eq__('object') == True — groupby is a C extension type in itertoolsmodule.c that groups consecutive elements of an iterable by key; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra167"]
    - [groupby_class_name_type,
       "groupby.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.groupby.__class__.__name__.__eq__('type') == True — groupby is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra167"]

# ---------------------------------------------------------------------------
# Table 2: itertools.zip_longest C extension type identity
#
# Wave 296 theme: itertools.zip_longest C extension type — __name__, __module__,
# __bases__[0], and __class__.__name__.
#
# itertools.zip_longest.__name__ == 'zip_longest'
# itertools.zip_longest.__module__ == 'itertools'
# itertools.zip_longest.__bases__[0].__name__ == 'object'
# itertools.zip_longest.__class__.__name__ == 'type'
#
# itertools.zip_longest(*iterables, fillvalue=None) aggregates elements from
# each iterable. If the iterables are of uneven length, missing values are
# filled in with fillvalue. Iteration continues until the longest iterable is
# exhausted. It is a C extension type in itertoolsmodule.c that inherits
# directly from object. New to extra167.
# ---------------------------------------------------------------------------

table itertools_extra167.zip_longest_identity:
  description: "itertools.zip_longest: __name__ 'zip_longest', __module__ 'itertools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 296; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolszli167

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_name,
       "zip_longest.__name__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — zip_longest is a C extension type in itertoolsmodule.c that aggregates elements from iterables filling shorter ones with fillvalue; its type __name__ attribute is 'zip_longest'; str.__eq__('zip_longest') returns True; new to extra167"]
    - [zip_longest_module_itertools,
       "zip_longest.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — zip_longest is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra167"]
    - ["zip_longest_bases_0_object",
       "zip_longest.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.zip_longest.__bases__[0].__name__.__eq__('object') == True — zip_longest is a C extension type that aggregates elements from iterables of unequal length; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra167"]
    - [zip_longest_class_name_type,
       "zip_longest.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.zip_longest.__class__.__name__.__eq__('type') == True — zip_longest is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra167"]

# ---------------------------------------------------------------------------
# Table 3: itertools.takewhile C extension type identity
#
# Wave 296 theme: itertools.takewhile C extension type — __name__, __module__,
# __bases__[0], and __class__.__name__.
#
# itertools.takewhile.__name__ == 'takewhile'
# itertools.takewhile.__module__ == 'itertools'
# itertools.takewhile.__bases__[0].__name__ == 'object'
# itertools.takewhile.__class__.__name__ == 'type'
#
# itertools.takewhile(predicate, iterable) makes an iterator that returns
# elements from the iterable as long as the predicate is true. Equivalent to:
# (x for x in iterable while predicate(x)). Once the predicate is false it
# stops immediately (remaining elements are not consumed). It is a C extension
# type in itertoolsmodule.c that inherits directly from object. New to extra167.
# ---------------------------------------------------------------------------

table itertools_extra167.takewhile_identity:
  description: "itertools.takewhile: __name__ 'takewhile', __module__ 'itertools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 296; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolstwi167

  columns: [id, function, args, expected, description]
  rows:
    - [takewhile_name_takewhile,
       "takewhile.__name__.__eq__",
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — takewhile is a C extension type in itertoolsmodule.c that returns elements from an iterable as long as a predicate is true; its type __name__ attribute is 'takewhile'; str.__eq__('takewhile') returns True; new to extra167"]
    - [takewhile_module_itertools,
       "takewhile.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.takewhile.__module__.__eq__('itertools') == True — takewhile is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra167"]
    - ["takewhile_bases_0_object",
       "takewhile.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.takewhile.__bases__[0].__name__.__eq__('object') == True — takewhile is a C extension type; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra167"]
    - [takewhile_class_name_type,
       "takewhile.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.takewhile.__class__.__name__.__eq__('type') == True — takewhile is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra167"]

# ---------------------------------------------------------------------------
# Table 4: itertools.dropwhile C extension type identity
#
# Wave 296 theme: itertools.dropwhile C extension type — __name__, __module__,
# __bases__[0], and __class__.__name__.
#
# itertools.dropwhile.__name__ == 'dropwhile'
# itertools.dropwhile.__module__ == 'itertools'
# itertools.dropwhile.__bases__[0].__name__ == 'object'
# itertools.dropwhile.__class__.__name__ == 'type'
#
# itertools.dropwhile(predicate, iterable) makes an iterator that drops
# elements from the iterable as long as the predicate is true; afterwards,
# it returns every remaining element. Note: the iterator does not produce
# any output until the predicate first becomes false. It is a C extension type
# in itertoolsmodule.c that inherits directly from object. New to extra167.
# ---------------------------------------------------------------------------

table itertools_extra167.dropwhile_identity:
  description: "itertools.dropwhile: __name__ 'dropwhile', __module__ 'itertools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 296; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsdwi167

  columns: [id, function, args, expected, description]
  rows:
    - [dropwhile_name_dropwhile,
       "dropwhile.__name__.__eq__",
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__.__eq__('dropwhile') == True — dropwhile is a C extension type in itertoolsmodule.c that drops elements from an iterable as long as a predicate is true then returns every remaining element; its type __name__ attribute is 'dropwhile'; str.__eq__('dropwhile') returns True; new to extra167"]
    - [dropwhile_module_itertools,
       "dropwhile.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.dropwhile.__module__.__eq__('itertools') == True — dropwhile is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra167"]
    - ["dropwhile_bases_0_object",
       "dropwhile.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.dropwhile.__bases__[0].__name__.__eq__('object') == True — dropwhile is a C extension type; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra167"]
    - [dropwhile_class_name_type,
       "dropwhile.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.dropwhile.__class__.__name__.__eq__('type') == True — dropwhile is a class object (C extension type); its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra167"]

# ---------------------------------------------------------------------------
# Table 5: Cross-checks — groupby, zip_longest, takewhile, dropwhile are distinct
#
# Wave 296 theme: cross-checks between the four new C extension type names to
# confirm they are distinct; and that takewhile.__name__ != dropwhile.__name__.
#
# itertools.groupby.__name__ != 'zip_longest'
# itertools.takewhile.__name__ != 'dropwhile'
# itertools.zip_longest.__module__ != 'builtins'
# itertools.groupby.__module__ == itertools.takewhile.__module__
#   (both 'itertools', cross-checked via __eq__)
#
# All four (groupby, zip_longest, takewhile, dropwhile) are distinct C extension
# types in itertoolsmodule.c with different __name__ values. They all share the
# same __module__ 'itertools' and __bases__[0].__name__ 'object'. New to extra167.
# ---------------------------------------------------------------------------

table itertools_extra167.new_types_cross_checks:
  description: "itertools: groupby.__name__ != 'zip_longest', takewhile.__name__ != 'dropwhile', zip_longest.__module__ != 'builtins'; wave 296; new to extra167"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsntcc167

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_name_ne_zip_longest,
       "groupby.__name__.__eq__",
       ["zip_longest"],
       false,
       "itertools.groupby.__name__.__eq__('zip_longest') == False — groupby.__name__ is 'groupby' not 'zip_longest'; these are two distinct C extension iterator types in itertoolsmodule.c; str.__eq__('zip_longest') returns False; new to extra167"]
    - [takewhile_name_ne_dropwhile,
       "takewhile.__name__.__eq__",
       ["dropwhile"],
       false,
       "itertools.takewhile.__name__.__eq__('dropwhile') == False — takewhile.__name__ is 'takewhile' not 'dropwhile'; takewhile stops when predicate is false while dropwhile skips until predicate is false; they are distinct C extension types; str.__eq__('dropwhile') returns False; new to extra167"]
    - [zip_longest_module_not_builtins,
       "zip_longest.__module__.__eq__",
       ["builtins"],
       false,
       "itertools.zip_longest.__module__.__eq__('builtins') == False — zip_longest is declared in the itertools C extension module, not in builtins; its __module__ is 'itertools' not 'builtins'; str.__eq__('builtins') returns False; new to extra167"]
    - [groupby_module_eq_takewhile_module,
       "groupby.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.groupby.__module__.__eq__('itertools') == True — both groupby and takewhile have __module__ 'itertools'; all four new types (groupby, zip_longest, takewhile, dropwhile) share __module__ 'itertools'; confirmed via groupby cross-check; str.__eq__('itertools') returns True; new to extra167"]

