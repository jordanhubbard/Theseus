spec: pp3136
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 656 (pp3136): __call__, __len__, __getitem__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "No pathlib class defines __call__ in its own __dict__: path objects are not callable."
    - "No pathlib class defines __len__ in its own __dict__: path objects do not implement the sized protocol."
    - "No pathlib class defines __getitem__ in its own __dict__: path objects do not support subscript access."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __call__ dict-presence — operator.contains(Cls.__dict__, '__call__')
#
# No pathlib class defines __call__ in its own __dict__; all false.
# pathlib types represent filesystem paths, not callable objects.
# ---------------------------------------------------------------------------

table pp3136.call:
  description: "pathlib types __call__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3136

  columns: [id, function, args, expected]
  rows:
    - ["pp3136001", operator.contains, [pathlib.PurePath.__dict__,        "__call__"], false]
    - ["pp3136002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__call__"], false]
    - ["pp3136003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__call__"], false]
    - ["pp3136004", operator.contains, [pathlib.Path.__dict__,             "__call__"], false]
    - ["pp3136005", operator.contains, [pathlib.PosixPath.__dict__,        "__call__"], false]

