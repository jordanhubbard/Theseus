spec: io_extra2221
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2221 (io_extra2221): identity/display protocol dict-presence checks — __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__."
    - "io.IOBase is a C extension type: __doc__ and __module__ are present in its own __dict__; __hash__, __repr__, __str__, __qualname__, and __name__ are absent — the last two are not stored in C-type __dict__ entries."
    - "io.RawIOBase, io.BufferedIOBase, io.TextIOBase follow the same C-extension pattern: __doc__ and __module__ present, display/hash dunders absent."
    - "io.StringIO and io.BytesIO are concrete C extension classes: __doc__ and __module__ present in __dict__; no __hash__, __repr__, __str__, __qualname__, or __name__."
    - "io.FileIO uniquely defines __repr__ in its own __dict__ (returns a meaningful string like <_io.FileIO name=... mode=...>); __doc__ and __module__ also present; others absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table io_extra2221.iobase_identity_display:
  description: "io.IOBase identity/display protocol dict-presence — C extension base: __doc__ and __module__ present, display dunders absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2221

  columns: [id, function, args, expected]
  rows:
    - ["io2221001", "io.IOBase.__dict__.__contains__", ["__hash__"], false]
    - ["io2221002", "io.IOBase.__dict__.__contains__", ["__repr__"], false]
    - ["io2221003", "io.IOBase.__dict__.__contains__", ["__str__"], false]
    - ["io2221004", "io.IOBase.__dict__.__contains__", ["__doc__"], true]
    - ["io2221005", "io.IOBase.__dict__.__contains__", ["__module__"], true]
    - ["io2221006", "io.IOBase.__dict__.__contains__", ["__qualname__"], false]
    - ["io2221007", "io.IOBase.__dict__.__contains__", ["__name__"], false]

