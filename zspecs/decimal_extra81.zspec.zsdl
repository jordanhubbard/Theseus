spec: decimal_extra81
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra80."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for various dunders; Decimal comparison/equality/hash wrapper_descriptor identity; Context/__dict__ class and membership; getcontext/setcontext __class__.__name__ and __module__; Decimal division/power operator wrapper_descriptor identity and __dict__ membership; Context.__init__/__class__.__name__; Context arithmetic method __class__.__name__; Context/__dict__/__class__/__name__ and membership; Context.__bases__[0].__name__; Context.__mro__.__len__(); Decimal arithmetic/string/conversion dunder __qualname__ values and lengths; Decimal comparison operator __qualname__ lengths; Decimal to_*/normalize/quantize/sqrt/compare __qualname__ lengths; Decimal.__dict__.__contains__ for arithmetic/comparison/math operators; Decimal.__dict__.__class__.__name__; Decimal.__name__; Decimal.__module__; Decimal.__qualname__; Decimal.__qualname__.__len__(); Decimal.__module__.__len__(); Decimal.__bases__[0].__name__; Decimal.__mro__.__len__(); Context/__name__/__module__/__qualname__; getcontext/setcontext/localcontext __class__.__name__; ROUND_* constants __class__.__name__ and string equality; ROUND_UP/__len__(); ROUND_HALF_EVEN/__len__()."
    - "This spec covers: Decimal.__add__.__doc__.__class__.__name__ == 'str'; Decimal.__sub__.__doc__.__class__.__name__ == 'str'; Decimal.__mul__.__doc__.__class__.__name__ == 'str'; Decimal.__truediv__.__doc__.__class__.__name__ == 'str'; Decimal.__floordiv__.__doc__.__class__.__name__ == 'str'; Decimal.__mod__.__doc__.__class__.__name__ == 'str'; Decimal.__pow__.__doc__.__class__.__name__ == 'str'; Decimal.__neg__.__doc__.__class__.__name__ == 'str'; Decimal.__pos__.__doc__.__class__.__name__ == 'str'; Decimal.__abs__.__doc__.__class__.__name__ == 'str'; Decimal.__eq__.__doc__.__class__.__name__ == 'str'; Decimal.__lt__.__doc__.__class__.__name__ == 'str'; Decimal.sqrt.__doc__.__class__.__name__ == 'str'; Decimal.normalize.__doc__.__class__.__name__ == 'str'."
    - "Decimal.__add__.__doc__.__class__.__name__ == 'str' — the __doc__ attribute of Decimal's arithmetic operator methods is a plain str."
    - "Decimal.__sub__.__doc__.__class__.__name__ == 'str' — same pattern for subtraction."
    - "Decimal.__mul__.__doc__.__class__.__name__ == 'str' — same pattern for multiplication."
    - "Decimal.__truediv__.__doc__.__class__.__name__ == 'str' — same pattern for true division."
    - "Decimal.__floordiv__.__doc__.__class__.__name__ == 'str' — same pattern for floor division."
    - "Decimal.__mod__.__doc__.__class__.__name__ == 'str' — same pattern for modulo."
    - "Decimal.__pow__.__doc__.__class__.__name__ == 'str' — same pattern for power."
    - "Decimal.__neg__.__doc__.__class__.__name__ == 'str' — same pattern for unary negation."
    - "Decimal.__pos__.__doc__.__class__.__name__ == 'str' — same pattern for unary positive."
    - "Decimal.__abs__.__doc__.__class__.__name__ == 'str' — same pattern for absolute value."
    - "Decimal.__eq__.__doc__.__class__.__name__ == 'str' — same pattern for equality comparison."
    - "Decimal.__lt__.__doc__.__class__.__name__ == 'str' — same pattern for less-than comparison."
    - "Decimal.sqrt.__doc__.__class__.__name__ == 'str' — same pattern for sqrt method."
    - "Decimal.normalize.__doc__.__class__.__name__ == 'str' — same pattern for normalize method."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal arithmetic operator __doc__.__class__.__name__: add, sub, mul, truediv
# All arithmetic operator methods have __doc__ of type str.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra81.Decimal_arith_doc_classname_1:
  description: "Decimal.__add__/__sub__/__mul__/__truediv__ __doc__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: doc_class
  id_prefix: decimalextra81

  columns: [id, function, args, expected]
  rows:
    - [add_doc_cls,     Decimal.__add__.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [sub_doc_cls,     Decimal.__sub__.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [mul_doc_cls,     Decimal.__mul__.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [truediv_doc_cls, Decimal.__truediv__.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# Decimal arithmetic operator __doc__.__class__.__name__: floordiv, mod, pow
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra81.Decimal_arith_doc_classname_2:
  description: "Decimal.__floordiv__/__mod__/__pow__ __doc__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: doc_class
  id_prefix: decimalextra81

  columns: [id, function, args, expected]
  rows:
    - [floordiv_doc_cls, Decimal.__floordiv__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [mod_doc_cls,      Decimal.__mod__.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [pow_doc_cls,      Decimal.__pow__.__doc__.__class__.__name__.__eq__,      ["str"], true]

# ---------------------------------------------------------------------------
# Decimal unary operator __doc__.__class__.__name__: neg, pos, abs
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra81.Decimal_unary_doc_classname:
  description: "Decimal.__neg__/__pos__/__abs__ __doc__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: doc_class
  id_prefix: decimalextra81

  columns: [id, function, args, expected]
  rows:
    - [neg_doc_cls, Decimal.__neg__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pos_doc_cls, Decimal.__pos__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [abs_doc_cls, Decimal.__abs__.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# Decimal comparison and math method __doc__.__class__.__name__
# __eq__, __lt__, sqrt, normalize all have __doc__ of type str.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra81.Decimal_cmp_math_doc_classname:
  description: "Decimal.__eq__/__lt__/sqrt/normalize __doc__.__class__.__name__ == 'str'"
  kind: python_call_eq
  category: doc_class
  id_prefix: decimalextra81

  columns: [id, function, args, expected]
  rows:
    - [eq_doc_cls,        Decimal.__eq__.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [lt_doc_cls,        Decimal.__lt__.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [sqrt_doc_cls,      Decimal.sqrt.__doc__.__class__.__name__.__eq__,          ["str"], true]
    - [normalize_doc_cls, Decimal.normalize.__doc__.__class__.__name__.__eq__,     ["str"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra81.Decimal.__add__doc_class:
  description: "Decimal.__add__.__doc__.__class__.__name__ == 'str' (arithmetic op docstrings are plain str)"
  category: doc_class
  kind: python_call_eq
  function: Decimal.__add__.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

