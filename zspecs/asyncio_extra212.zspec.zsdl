    - [task_qualname_eq,
       Task.__qualname__.__eq__,
       ["Task"],
       true,
       "asyncio.Task.__qualname__.__eq__('Task') == True — Task is a top-level C-extension class; qualname equals name; new to asyncio_extra212; verified Python 3.14.3"]
    - [future_qualname_eq,
