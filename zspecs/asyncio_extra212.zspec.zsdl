  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec covers __qualname__ attributes of asyncio classes: Task, Future, Queue, Lock, Event, Semaphore."
    - "asyncio.Task.__qualname__ == 'Task' — top-level class; qualname equals simple name. len == 4. Verified Python 3.14.3."
    - "asyncio.Future.__qualname__ == 'Future' — top-level class; qualname equals simple name. len == 6. Verified Python 3.14.3."
    - "asyncio.Queue.__qualname__ == 'Queue' — top-level class; qualname equals simple name. len == 5. Verified Python 3.14.3."
    - "asyncio.Lock.__qualname__ == 'Lock' — top-level class; qualname equals simple name. len == 4. Verified Python 3.14.3."
    - "asyncio.Event.__qualname__ == 'Event' — top-level class; qualname equals simple name. len == 5. Verified Python 3.14.3."
    - "asyncio.Semaphore.__qualname__ == 'Semaphore' — top-level class; qualname equals simple name. len == 9. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio class __qualname__ equality — Task and Future
#
# asyncio.Task.__qualname__ == 'Task' (len 4)
# asyncio.Future.__qualname__ == 'Future' (len 6)
# asyncio.Queue.__qualname__ == 'Queue' (len 5)
# asyncio.Lock.__qualname__ == 'Lock' (len 4)
#
# These are top-level classes so qualname equals name. Task and Future are
# C-extension types from _asyncio; Queue and Lock are pure-Python.
# ---------------------------------------------------------------------------

