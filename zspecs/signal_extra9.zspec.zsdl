spec: signal_extra9
version: ">=3.9"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/signal.html — Python signal module documentation"
    - "POSIX.1-2017 — The Open Group Base Specifications Issue 7, 2018 Edition"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
  notes:
    - "Extends signal.zspec.zsdl through signal_extra8.zspec.zsdl."
    - "signal_extra covers: SIG_DFL/SIG_IGN/SIGABRT/SIGFPE/SIGILL/SIGINT/SIGSEGV/SIGTERM class names; function __name__ table."
    - "signal_extra2 covers: function __module__ table; SIG_DFL/SIG_IGN/SIGTERM/SIGINT class names; Signals/Handlers __name__/__bases__."
    - "signal_extra3 covers: SIGHUP/SIGKILL/SIGQUIT/SIGALRM/SIGPIPE class names; SIGHUP/SIGKILL .name; SIG_DFL/SIG_IGN .name; NSIG."
    - "signal_extra4 covers: function __qualname__ table (signal/getsignal/raise_signal/strsignal/valid_signals); Signals/Handlers __qualname__/__module__."
    - "signal_extra5 covers: SIGABRT/SIGFPE/SIGILL/SIGSEGV .name; Signals.SIGABRT.value/SIGHUP.value; strsignal SIGABRT/SIGFPE/SIGILL/SIGSEGV; valid_signals SIGHUP/SIGKILL/SIGQUIT/SIGABRT."
    - "signal_extra6 covers: NSIG==32; Signals.SIGQUIT/SIGALRM/SIGPIPE .value; SIGQUIT/SIGALRM/SIGPIPE .name."
    - "signal_extra7 covers: SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH .value/.name; strsignal and valid_signals for same."
    - "signal_extra8 covers: alarm __name__/__qualname__/__module__; SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH class names."
    - "This spec adds: valid_signals() membership for SIGFPE/SIGILL/SIGSEGV/SIGALRM/SIGPIPE (none in any prior spec); Handlers enum member .value checks for SIG_DFL and SIG_IGN (SIG_DFL.name/SIG_IGN.name covered in extra3 but .value never checked); Handlers.__len__() == 2 (not covered in any prior spec)."
    - "signal.SIGFPE, SIGILL, SIGSEGV, SIGALRM, SIGPIPE are all members of valid_signals() on macOS."
    - "signal_extra5 covers valid_signals for SIGHUP/SIGKILL/SIGQUIT/SIGABRT; signal_extra7 covers SIGUSR1/SIGUSR2/SIGCHLD/SIGWINCH; signal_extra covers SIGINT/SIGTERM. SIGFPE/SIGILL/SIGSEGV/SIGALRM/SIGPIPE are new here."
    - "signal.Handlers has exactly 2 members: SIG_DFL (value=0) and SIG_IGN (value=1)."
    - "Handlers.SIG_DFL.value == 0; Handlers.SIG_IGN.value == 1 — enum member values not covered by any prior spec."
    - "SIG_DFL.name and SIG_IGN.name are covered in signal_extra3; .value is new here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# valid_signals() — membership for SIGFPE, SIGILL, SIGSEGV, SIGALRM, SIGPIPE
#
# signal_extra covers SIGINT (2) and SIGTERM (15) in valid_signals().
# signal_extra5 covers SIGHUP (1), SIGKILL (9), SIGQUIT (3), SIGABRT (6).
# signal_extra7 covers SIGUSR1 (30), SIGUSR2 (31), SIGCHLD (20), SIGWINCH (28).
# New here: SIGFPE (8), SIGILL (4), SIGSEGV (11), SIGALRM (14), SIGPIPE (13).
# ---------------------------------------------------------------------------

table signal_extra9.valid_signals_membership:
  description: "SIGFPE/SIGILL/SIGSEGV/SIGALRM/SIGPIPE are all in valid_signals() on macOS"
  kind: python_call_eq
  category: valid_signals
  id_prefix: vs

  columns: [id, function, args, expected]
  rows:
    - [sigfpe,   "valid_signals().__contains__", [8],  true]
    - [sigill,   "valid_signals().__contains__", [4],  true]
    - [sigsegv,  "valid_signals().__contains__", [11], true]
    - [sigalrm,  "valid_signals().__contains__", [14], true]
    - [sigpipe,  "valid_signals().__contains__", [13], true]

# ---------------------------------------------------------------------------
# Handlers enum — .value attributes for SIG_DFL and SIG_IGN
#
# signal_extra3 covers SIG_DFL.name and SIG_IGN.name.
# No prior spec checks Handlers.SIG_DFL.value or Handlers.SIG_IGN.value.
# SIG_DFL.value == 0 and SIG_IGN.value == 1 — the two Handlers members.
# ---------------------------------------------------------------------------

invariant signal_extra9.Handlers.SIG_DFL_value:
  description: "signal.Handlers.SIG_DFL.value == 0 — SIG_DFL is the default-action handler"
  category: enum
  kind: python_call_eq
  function: Handlers.SIG_DFL.value.__eq__
  args: [0]
  expected: true

invariant signal_extra9.Handlers.SIG_IGN_value:
  description: "signal.Handlers.SIG_IGN.value == 1 — SIG_IGN is the ignore-action handler"
  category: enum
  kind: python_call_eq
  function: Handlers.SIG_IGN.value.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# Handlers enum — number of members
#
# The Handlers enum contains exactly two members: SIG_DFL and SIG_IGN.
# No prior spec checks len(signal.Handlers).
# ---------------------------------------------------------------------------

invariant signal_extra9.Handlers.len:
  description: "len(signal.Handlers) == 2 — Handlers enum has exactly SIG_DFL and SIG_IGN"
  category: enum
  kind: python_call_eq
  function: Handlers.__len__
  args: []
  expected: 2
