  function: Decimal.exp.__name__.__eq__
  args: ["exp"]
  expected: true

invariant decimal_extra178.ln_name_is_ln:
  description: "decimal.Decimal.ln.__name__ == 'ln' — natural logarithm; len('ln')==2: l(1)n(2); shortest method name in this spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
