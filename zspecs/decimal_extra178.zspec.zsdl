spec: decimal_extra178
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "decimal.Decimal arithmetic method __name__ values: quantize (len=8), normalize (len=9), sqrt (len=4), exp (len=3)."
    - "decimal.Decimal arithmetic method __name__ values (continued): ln (len=2), log10 (len=5), to_integral_value (len=17), to_eng_string (len=13)."
    - "All method __name__ values match the method's own name as a plain string; methods are defined on the C-level _decimal.Decimal."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal rounding/normalization method names
# quantize (len=8), normalize (len=9), sqrt (len=4)
# ---------------------------------------------------------------------------

table decimal_extra178.decimal_rounding_method_names:
  description: "decimal.Decimal rounding and normalization method __name__ values: quantize (len=8), normalize (len=9), sqrt (len=4)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmethods178

  columns: [id, function, args, expected, description]
  rows:
    - [quantize_name,     Decimal.quantize.__name__.__eq__,    ["quantize"],   true,  "decimal.Decimal.quantize.__name__ == 'quantize' — round to fixed exponent; len('quantize')==8; confirmed Python 3.14.3 macOS"]
    - [quantize_len,      Decimal.quantize.__name__.__len__,   [],             8,     "decimal.Decimal.quantize.__name__.__len__() == 8 — 'quantize': q(1)u(2)a(3)n(4)t(5)i(6)z(7)e(8); confirmed Python 3.14.3 macOS"]
    - [normalize_name,    Decimal.normalize.__name__.__eq__,   ["normalize"],  true,  "decimal.Decimal.normalize.__name__ == 'normalize' — reduce to shortest form; len('normalize')==9; confirmed Python 3.14.3 macOS"]
    - [normalize_len,     Decimal.normalize.__name__.__len__,  [],             9,     "decimal.Decimal.normalize.__name__.__len__() == 9 — 'normalize': n(1)o(2)r(3)m(4)a(5)l(6)i(7)z(8)e(9); confirmed Python 3.14.3 macOS"]
    - [sqrt_name,         Decimal.sqrt.__name__.__eq__,        ["sqrt"],       true,  "decimal.Decimal.sqrt.__name__ == 'sqrt' — square root; len('sqrt')==4; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal transcendental method names
# exp (len=3), ln (len=2), log10 (len=5)
# ---------------------------------------------------------------------------

table decimal_extra178.decimal_transcendental_method_names:
  description: "decimal.Decimal transcendental method __name__ values: exp (len=3), ln (len=2), log10 (len=5)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmethods178

  columns: [id, function, args, expected, description]
  rows:
    - [exp_name,    Decimal.exp.__name__.__eq__,    ["exp"],    true,  "decimal.Decimal.exp.__name__ == 'exp' — natural exponential e^x; len('exp')==3; confirmed Python 3.14.3 macOS"]
    - [exp_len,     Decimal.exp.__name__.__len__,   [],         3,     "decimal.Decimal.exp.__name__.__len__() == 3 — 'exp': e(1)x(2)p(3); confirmed Python 3.14.3 macOS"]
    - [ln_name,     Decimal.ln.__name__.__eq__,     ["ln"],     true,  "decimal.Decimal.ln.__name__ == 'ln' — natural logarithm; len('ln')==2; confirmed Python 3.14.3 macOS"]
    - [ln_len,      Decimal.ln.__name__.__len__,    [],         2,     "decimal.Decimal.ln.__name__.__len__() == 2 — 'ln': l(1)n(2); shortest arithmetic method name; confirmed Python 3.14.3 macOS"]
    - [log10_name,  Decimal.log10.__name__.__eq__,  ["log10"],  true,  "decimal.Decimal.log10.__name__ == 'log10' — base-10 logarithm; len('log10')==5; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal conversion method names
# to_integral_value (len=17), to_eng_string (len=13)
# ---------------------------------------------------------------------------

table decimal_extra178.decimal_conversion_method_names:
  description: "decimal.Decimal conversion method __name__ values: to_integral_value (len=17), to_eng_string (len=13)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalmethods178

  columns: [id, function, args, expected, description]
  rows:
    - [tiv_name,   Decimal.to_integral_value.__name__.__eq__,   ["to_integral_value"],  true,  "decimal.Decimal.to_integral_value.__name__ == 'to_integral_value' — round to integer; len('to_integral_value')==17; confirmed Python 3.14.3 macOS"]
    - [tiv_len,    Decimal.to_integral_value.__name__.__len__,  [],                     17,    "decimal.Decimal.to_integral_value.__name__.__len__() == 17 — 'to_integral_value': longest method name in this spec; confirmed Python 3.14.3 macOS"]
    - [tes_name,   Decimal.to_eng_string.__name__.__eq__,       ["to_eng_string"],      true,  "decimal.Decimal.to_eng_string.__name__ == 'to_eng_string' — engineering notation; len('to_eng_string')==13; confirmed Python 3.14.3 macOS"]
    - [tes_len,    Decimal.to_eng_string.__name__.__len__,      [],                     13,    "decimal.Decimal.to_eng_string.__name__.__len__() == 13 — 'to_eng_string': t(1)o(2)_(3)e(4)n(5)g(6)_(7)s(8)t(9)r(10)i(11)n(12)g(13); confirmed Python 3.14.3 macOS"]
    - [sqrt_len,   Decimal.sqrt.__name__.__len__,               [],                     4,     "decimal.Decimal.sqrt.__name__.__len__() == 4 — 'sqrt': s(1)q(2)r(3)t(4); cross-check between tables; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra178.quantize_name_is_quantize:
  description: "decimal.Decimal.quantize.__name__ == 'quantize' — round to fixed exponent method; len('quantize')==8: q(1)u(2)a(3)n(4)t(5)i(6)z(7)e(8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.quantize.__name__.__eq__
  args: ["quantize"]
  expected: true

invariant decimal_extra178.quantize_name_len_is_8:
  description: "decimal.Decimal.quantize.__name__.__len__() == 8 — 'quantize' has 8 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.quantize.__name__.__len__
  args: []
  expected: 8

invariant decimal_extra178.normalize_name_is_normalize:
  description: "decimal.Decimal.normalize.__name__ == 'normalize' — reduce to shortest form; len('normalize')==9: n(1)o(2)r(3)m(4)a(5)l(6)i(7)z(8)e(9); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.normalize.__name__.__eq__
  args: ["normalize"]
  expected: true

invariant decimal_extra178.sqrt_name_is_sqrt:
  description: "decimal.Decimal.sqrt.__name__ == 'sqrt' — square root; len('sqrt')==4: s(1)q(2)r(3)t(4); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Decimal.sqrt.__name__.__eq__
  args: ["sqrt"]
  expected: true

invariant decimal_extra178.exp_name_is_exp:
  description: "decimal.Decimal.exp.__name__ == 'exp' — natural exponential e^x; len('exp')==3: e(1)x(2)p(3); confirmed Python 3.14.3 macOS"
  category: identity
