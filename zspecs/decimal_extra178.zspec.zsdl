invariant decimal_extra178.log10_name_is_log10:
  description: "decimal.Decimal.log10.__name__ == 'log10' — base-10 logarithm; len('log10')==5: l(1)o(2)g(3)1(4)0(5); confirmed Python 3.14.3 macOS"
  category: identity
