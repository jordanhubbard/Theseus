spec: email_extra10
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/email.html — Python email module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/"
    - "email_extra4.zspec.zsdl — covers email.utils parseaddr/formataddr __qualname__.__eq__ and __module__.__eq__; email.errors MessageError/HeaderParseError/MessageDefect __qualname__.__eq__ and __module__.__eq__; email.policy class qualnames; email.generator qualnames"
    - "email_extra8.zspec.zsdl — covers message.Message/__name__.__eq__, mime.text.MIMEText/__name__.__eq__, mime.multipart.MIMEMultipart/__name__.__eq__ (all __name__, not __qualname__)"
    - "email_extra9.zspec.zsdl — covers email.errors class __bases__[0].__name__ hierarchy; message.Message/__bases__[0].__name__; headerregistry.Address/__bases__[0].__name__"
  notes:
    - "This spec extends the email family through email_extra9; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__ for email.message.Message, email.mime.text.MIMEText, email.mime.multipart.MIMEMultipart, and email.header.Header — no prior email spec checks __qualname__ for any of these four classes. email_extra4 covers errors/generator/utils/policy/headerregistry qualnames but not these four; email_extra8 covers __name__ (not __qualname__) for Message/MIMEText/MIMEMultipart. Also covers __qualname__.__len__() for parseaddr/formataddr (extra4 checks __qualname__.__eq__ but not length) and header.Header.__module__."
    - "email.message.Message.__qualname__ == 'Message' — no prior email spec checks message.Message.__qualname__. email_extra8 checks __name__.__eq__('Message') for Message. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "email.mime.text.MIMEText.__qualname__ == 'MIMEText' — no prior email spec checks MIMEText.__qualname__. email_extra8 checks __name__.__eq__('MIMEText'). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "email.mime.multipart.MIMEMultipart.__qualname__ == 'MIMEMultipart' — no prior email spec checks MIMEMultipart.__qualname__. email_extra8 checks __name__.__eq__('MIMEMultipart'). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "email.header.Header.__qualname__ == 'Header' — no prior email spec checks header.Header.__qualname__. email_header.zspec.zsdl covers behavioral use; qualname is new. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "email.utils.parseaddr.__qualname__.__len__() == 9 — len('parseaddr') == 9. extra4 checks __qualname__.__eq__; length is a distinct axis. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "email.utils.formataddr.__qualname__.__len__() == 10 — len('formataddr') == 10. extra4 checks __qualname__.__eq__; length is a distinct axis. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "email.header.Header.__module__ == 'email.header' — no prior email spec checks header.Header.__module__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email.message.Message / email.mime.text.MIMEText /
# email.mime.multipart.MIMEMultipart / email.header.Header __qualname__
#
# email_extra8 verifies __name__ for Message, MIMEText, MIMEMultipart.
# email_extra4 verifies __qualname__ for errors/generator/utils/policy classes.
# No prior email spec checks __qualname__ for Message, MIMEText, MIMEMultipart,
# or header.Header. These are four distinct symbols not previously qualname-checked.
# ---------------------------------------------------------------------------

table email_extra10.class_qualnames:
  description: "__qualname__ for email core classes — Message, MIMEText, MIMEMultipart, Header"
  kind: python_call_eq
  category: qualnames
  id_prefix: clsqname10

  columns: [id, function, args, expected]
  rows:
    - [Message,       message.Message.__qualname__.__eq__,              ["Message"],       true]
    - [MIMEText,      mime.text.MIMEText.__qualname__.__eq__,           ["MIMEText"],      true]
    - [MIMEMultipart, mime.multipart.MIMEMultipart.__qualname__.__eq__, ["MIMEMultipart"], true]
    - [Header,        header.Header.__qualname__.__eq__,                ["Header"],        true]

# ---------------------------------------------------------------------------
# email.utils.parseaddr / formataddr __qualname__.__len__()
#
# email_extra4 checks parseaddr.__qualname__.__eq__('parseaddr') and
# formataddr.__qualname__.__eq__('formataddr') in a table.
# No prior email spec checks the length of these __qualname__ strings.
# len('parseaddr') == 9; len('formataddr') == 10.
# ---------------------------------------------------------------------------

invariant email_extra10.utils.parseaddr.qualname_len:
  description: "email.utils.parseaddr.__qualname__.__len__() == 9 — len('parseaddr') == 9"
  category: qualnames
  kind: python_call_eq
  function: utils.parseaddr.__qualname__.__len__
  args: []
  expected: 9

invariant email_extra10.utils.formataddr.qualname_len:
  description: "email.utils.formataddr.__qualname__.__len__() == 10 — len('formataddr') == 10"
  category: qualnames
  kind: python_call_eq
  function: utils.formataddr.__qualname__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# email.header.Header.__module__ == 'email.header'
#
# No prior email spec checks the __module__ attribute of email.header.Header.
# email_header.zspec.zsdl covers behavioral aspects of Header; metadata is new.
# email_extra4 covers __module__ for errors/policy/generator classes but not Header.
# Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant email_extra10.header.Header.module:
  description: "email.header.Header.__module__ == 'email.header'"
  category: modules
  kind: python_call_eq
  function: header.Header.__module__.__eq__
  args: ["email.header"]
  expected: true
