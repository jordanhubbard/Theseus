spec: pprint_extra15
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint.zspec.zsdl through pprint_extra14.zspec.zsdl."
    - "pprint_extra14 covers: PrettyPrinter.__bases__[0].__name__=='object'; pformat/pprint/isreadable/isrecursive/saferepr __qualname__ standalones; pformat.__module__; function_qualnames table; class_and_module table."
    - "pprint_extra12 covers: PrettyPrinter.__qualname__ standalone; pprint_extra13 covers PrettyPrinter.__module__ standalone."
    - "pprint_extra5 covers: pp.__qualname__=='pp'; pp.__module__=='pprint'."
    - "pprint_extra8 covers: pp.__name__=='pp' standalone (extra8 namespace)."
    - "This spec covers: PrettyPrinter.__init__.__qualname__=='PrettyPrinter.__init__'; PrettyPrinter.__init__.__name__=='__init__'; pp.__qualname__ extra15-namespace anchor; pp.__name__ extra15-namespace anchor; pp.__module__ extra15-namespace anchor; PrettyPrinter.__qualname__.__len__()==13; pp.__qualname__.__len__()==2."
    - "pprint.PrettyPrinter.__init__.__qualname__ == 'PrettyPrinter.__init__' — method qualname includes the owning class. Verified at runtime."
    - "pprint.PrettyPrinter.__init__.__name__ == '__init__' — constructor method simple name. Verified at runtime."
    - "pprint.pp.__qualname__ == 'pp' — extra15-namespace anchor; first covered in pprint_extra5. Verified at runtime."
    - "pprint.PrettyPrinter.__qualname__.__len__() == 13 — len('PrettyPrinter') == 13. Verified at runtime."
    - "pprint.pp.__qualname__.__len__() == 2 — len('pp') == 2. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PrettyPrinter.__init__ method identity — __qualname__ and __name__
#
# No prior spec verifies PrettyPrinter.__init__.__qualname__ as a standalone
# invariant. For a method defined in class PrettyPrinter, __qualname__ takes
# the form 'PrettyPrinter.__init__'. Verified at runtime.
# PrettyPrinter.__init__.__name__ == '__init__' is the simple name, also new
# as a standalone invariant in any namespace.
# ---------------------------------------------------------------------------

invariant pprint_extra15.PrettyPrinter.init_qualname:
  description: "pprint.PrettyPrinter.__init__.__qualname__ == 'PrettyPrinter.__init__' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter.__init__.__qualname__.__eq__
  args: ["PrettyPrinter.__init__"]
  expected: true

invariant pprint_extra15.PrettyPrinter.init_name:
  description: "pprint.PrettyPrinter.__init__.__name__ == '__init__' — constructor method simple name"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# pp function identity — extra15-namespace anchors
#
# pprint_extra5 covers pp.__qualname__ and pp.__module__.
# pprint_extra8 covers pp.__name__ in the extra8 namespace.
# This spec re-anchors all three under the extra15 namespace to complete the
# function identity coverage set alongside PrettyPrinter.__init__ above.
# Verified: __qualname__=='pp', __name__=='pp', __module__=='pprint'.
# ---------------------------------------------------------------------------

invariant pprint_extra15.pp.qualname:
  description: "pprint.pp.__qualname__ == 'pp' — module-level function qualname equals name (extra15 anchor)"
  category: function_identity
  kind: python_call_eq
  function: pp.__qualname__.__eq__
  args: ["pp"]
  expected: true

invariant pprint_extra15.pp.name:
  description: "pprint.pp.__name__ == 'pp' — module-level function simple name (extra15 anchor)"
  category: function_identity
  kind: python_call_eq
  function: pp.__name__.__eq__
  args: ["pp"]
  expected: true

invariant pprint_extra15.pp.module:
  description: "pprint.pp.__module__ == 'pprint' — pp defined in pprint module (extra15 anchor)"
  category: function_identity
  kind: python_call_eq
  function: pp.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ string lengths — PrettyPrinter and pp
#
# pprint_extra10 covers pformat.__qualname__.__len__() == 7 and
# PrettyPrinter.__name__.__len__() == 13.
# No prior spec verifies PrettyPrinter.__qualname__.__len__() or
# pp.__qualname__.__len__() as standalone invariants.
# 'PrettyPrinter' has 13 characters; 'pp' has 2 characters.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra15.PrettyPrinter.qualname_len:
  description: "pprint.PrettyPrinter.__qualname__.__len__() == 13 — len('PrettyPrinter') == 13"
  category: class_identity
  kind: python_call_eq
  function: PrettyPrinter.__qualname__.__len__
  args: []
  expected: 13

invariant pprint_extra15.pp.qualname_len:
  description: "pprint.pp.__qualname__.__len__() == 2 — len('pp') == 2"
  category: function_identity
  kind: python_call_eq
  function: pp.__qualname__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Table: PrettyPrinter.__init__ method identity
#
# Groups the __qualname__ and __name__ checks for PrettyPrinter.__init__.
# ---------------------------------------------------------------------------

table pprint_extra15.PrettyPrinter_init_identity:
  description: "pprint.PrettyPrinter.__init__ method identity — __qualname__ and __name__"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [pprint_extra15.PrettyPrinter_init_identity.qualname,
       PrettyPrinter.__init__.__qualname__.__eq__,
       ["PrettyPrinter.__init__"],
       true,
       "PrettyPrinter.__init__.__qualname__ == 'PrettyPrinter.__init__'"]
    - [pprint_extra15.PrettyPrinter_init_identity.name,
       PrettyPrinter.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "PrettyPrinter.__init__.__name__ == '__init__'"]

# ---------------------------------------------------------------------------
# Table: pp function identity and qualname length
#
# Groups the pp identity anchors and the qualname string-length check.
# ---------------------------------------------------------------------------

table pprint_extra15.pp_identity:
  description: "pprint.pp function identity — __qualname__, __name__, __module__, and qualname length"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [pprint_extra15.pp_identity.qualname,
       pp.__qualname__.__eq__,
       ["pp"],
       true,
       "pp.__qualname__ == 'pp'"]
    - [pprint_extra15.pp_identity.name,
       pp.__name__.__eq__,
       ["pp"],
       true,
       "pp.__name__ == 'pp'"]
    - [pprint_extra15.pp_identity.module,
       pp.__module__.__eq__,
       ["pprint"],
       true,
       "pp.__module__ == 'pprint'"]
    - [pprint_extra15.pp_identity.qualname_len,
       pp.__qualname__.__len__,
       [],
       2,
       "pp.__qualname__.__len__() == 2 — len('pp') == 2"]
