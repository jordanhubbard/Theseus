spec: netrc
version: ">=3.0"
backend: python_module(netrc)

docs: https://docs.python.org/3/library/netrc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/netrc.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/netrc.py"
  notes:
    - "netrc.netrc requires a file path to instantiate; it cannot be called without a valid netrc-format file."
    - "Tests focus on class/function attribute checks that do not require I/O."
    - "netrc.netrc is a plain Python class (type); type(netrc).__name__ == 'type'."
    - "netrc.NetrcParseError is the exception raised on malformed netrc files."
    - "NetrcParseError inherits directly from Exception."
    - "netrc.netrc.authenticators is an instance method accessible via the class object."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — netrc and NetrcParseError
# ---------------------------------------------------------------------------

invariant netrc.netrc.class_name:
  description: "netrc.netrc.__name__ == 'netrc'"
  category: classnames
  kind: python_call_eq
  function: netrc.__name__.__eq__
  args: ["netrc"]
  expected: true

invariant netrc.NetrcParseError.class_name:
  description: "netrc.NetrcParseError.__name__ == 'NetrcParseError'"
  category: classnames
  kind: python_call_eq
  function: NetrcParseError.__name__.__eq__
  args: ["NetrcParseError"]
  expected: true

# ---------------------------------------------------------------------------
# Module checks — both classes belong to the netrc module
# ---------------------------------------------------------------------------

invariant netrc.netrc.module_name:
  description: "netrc.netrc.__module__ == 'netrc'"
  category: module
  kind: python_call_eq
  function: netrc.__module__.__eq__
  args: ["netrc"]
  expected: true

invariant netrc.NetrcParseError.module_name:
  description: "netrc.NetrcParseError.__module__ == 'netrc'"
  category: module
  kind: python_call_eq
  function: NetrcParseError.__module__.__eq__
  args: ["netrc"]
  expected: true

# ---------------------------------------------------------------------------
# Type checks — both are type objects (classes)
# ---------------------------------------------------------------------------

invariant netrc.netrc.is_type:
  description: "type(netrc.netrc).__name__ == 'type' — netrc is a class"
  category: types
  kind: python_call_eq
  function: netrc.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant netrc.NetrcParseError.is_type:
  description: "type(netrc.NetrcParseError).__name__ == 'type' — NetrcParseError is a class"
  category: types
  kind: python_call_eq
  function: NetrcParseError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Inheritance — NetrcParseError extends Exception
# ---------------------------------------------------------------------------

invariant netrc.NetrcParseError.base_is_Exception:
  description: "netrc.NetrcParseError.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: NetrcParseError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Method name check — authenticators is accessible on the class
# ---------------------------------------------------------------------------

invariant netrc.netrc.authenticators_method_name:
  description: "netrc.netrc.authenticators.__name__ == 'authenticators'"
  category: methods
  kind: python_call_eq
  function: netrc.authenticators.__name__.__eq__
  args: ["authenticators"]
  expected: true

# ---------------------------------------------------------------------------
# NetrcParseError attributes — msg and filename are part of the public API
# ---------------------------------------------------------------------------

invariant netrc.NetrcParseError.has_msg_attr:
  description: "NetrcParseError.__init__ is accessible on the class"
  category: methods
  kind: python_call_eq
  function: NetrcParseError.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant netrc.NetrcParseError.str_method_present:
  description: "NetrcParseError.__str__ is accessible on the class"
  category: methods
  kind: python_call_eq
  function: NetrcParseError.__str__.__name__.__eq__
  args: ["__str__"]
  expected: true
