spec: asyncio_extra251
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "https://docs.python.org/3/library/asyncio-runner.html#asyncio.run — asyncio.run"
    - "https://docs.python.org/3/library/asyncio-task.html#asyncio.sleep — asyncio.sleep"
    - "https://docs.python.org/3/library/asyncio-task.html#asyncio.gather — asyncio.gather"
    - "https://docs.python.org/3/library/asyncio-task.html#asyncio.wait_for — asyncio.wait_for"
    - "https://docs.python.org/3/library/asyncio-task.html#asyncio.create_task — asyncio.create_task"
    - "https://docs.python.org/3/library/asyncio-eventloop.html#asyncio.get_event_loop — asyncio.get_event_loop"
    - "https://docs.python.org/3/library/asyncio-eventloop.html#asyncio.new_event_loop — asyncio.new_event_loop"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/runners.py (internal implementation)"
    - "CPython source: Lib/asyncio/tasks.py (internal implementation)"
    - "CPython source: Lib/asyncio/events.py (internal implementation)"
  notes:
    - "asyncio.run.__name__ == 'run' (len=3); __module__ == 'asyncio.runners' (len=15); __class__.__name__ == 'function'."
    - "asyncio.sleep.__name__ == 'sleep' (len=5); __module__ == 'asyncio.tasks' (len=13); __class__.__name__ == 'function'."
    - "asyncio.gather.__name__ == 'gather' (len=6); __module__ == 'asyncio.tasks' (len=13); __class__.__name__ == 'function'."
    - "asyncio.wait_for.__name__ == 'wait_for' (len=8); __module__ == 'asyncio.tasks' (len=13); __class__.__name__ == 'function'."
    - "asyncio.create_task.__name__ == 'create_task' (len=11); __module__ == 'asyncio.tasks' (len=13); __class__.__name__ == 'function'."
    - "asyncio.get_event_loop.__name__ == 'get_event_loop' (len=14); __module__ == '_asyncio' (len=8); __class__.__name__ == 'builtin_function_or_method' (C extension)."
    - "asyncio.new_event_loop.__name__ == 'new_event_loop' (len=14); __module__ == 'asyncio.events' (len=14); __class__.__name__ == 'function'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio module-level function __name__ identity
#
# asyncio.run.__name__ == 'run' (len=3)
# asyncio.sleep.__name__ == 'sleep' (len=5)
# asyncio.gather.__name__ == 'gather' (len=6)
# asyncio.wait_for.__name__ == 'wait_for' (len=8)
# asyncio.create_task.__name__ == 'create_task' (len=11)
# asyncio.get_event_loop.__name__ == 'get_event_loop' (len=14)
# asyncio.new_event_loop.__name__ == 'new_event_loop' (len=14)
# ---------------------------------------------------------------------------

table asyncio_extra251.function_name_identity:
  description: "asyncio module-level function __name__ identity — run(len=3), sleep(len=5), gather(len=6), wait_for(len=8), create_task(len=11), get_event_loop(len=14), new_event_loop(len=14); all __name__ attributes are simple unqualified names matching the attribute used to access them on the asyncio module; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio251fn

  columns: [id, function, args, expected, description]
  rows:
    - [fn_run_eq,           run.__name__.__eq__,            ["run"],            true, "asyncio.run.__name__ == 'run'; verified with Python 3.14.3"]
    - [fn_run_len,          run.__name__.__len__,           [],                 3,    "asyncio.run.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [fn_sleep_eq,         sleep.__name__.__eq__,          ["sleep"],          true, "asyncio.sleep.__name__ == 'sleep'; verified with Python 3.14.3"]
    - [fn_sleep_len,        sleep.__name__.__len__,         [],                 5,    "asyncio.sleep.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [fn_gather_eq,        gather.__name__.__eq__,         ["gather"],         true, "asyncio.gather.__name__ == 'gather'; verified with Python 3.14.3"]
    - [fn_gather_len,       gather.__name__.__len__,        [],                 6,    "asyncio.gather.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [fn_wait_for_eq,      wait_for.__name__.__eq__,       ["wait_for"],       true, "asyncio.wait_for.__name__ == 'wait_for'; verified with Python 3.14.3"]
    - [fn_wait_for_len,     wait_for.__name__.__len__,      [],                 8,    "asyncio.wait_for.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [fn_create_eq,        create_task.__name__.__eq__,    ["create_task"],    true, "asyncio.create_task.__name__ == 'create_task'; verified with Python 3.14.3"]
    - [fn_create_len,       create_task.__name__.__len__,   [],                 11,   "asyncio.create_task.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [fn_get_el_eq,        get_event_loop.__name__.__eq__, ["get_event_loop"], true, "asyncio.get_event_loop.__name__ == 'get_event_loop'; verified with Python 3.14.3"]
    - [fn_get_el_len,       get_event_loop.__name__.__len__, [],                14,   "asyncio.get_event_loop.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [fn_new_el_eq,        new_event_loop.__name__.__eq__, ["new_event_loop"], true, "asyncio.new_event_loop.__name__ == 'new_event_loop'; verified with Python 3.14.3"]
    - [fn_new_el_len,       new_event_loop.__name__.__len__, [],                14,   "asyncio.new_event_loop.__name__.__len__() == 14; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio module-level function __module__ identity
#
# asyncio.run.__module__ == 'asyncio.runners' (len=15)
# asyncio.sleep.__module__ == 'asyncio.tasks' (len=13)
# asyncio.gather.__module__ == 'asyncio.tasks' (len=13)
# asyncio.wait_for.__module__ == 'asyncio.tasks' (len=13)
# asyncio.create_task.__module__ == 'asyncio.tasks' (len=13)
# asyncio.get_event_loop.__module__ == '_asyncio' (len=8; C extension)
# asyncio.new_event_loop.__module__ == 'asyncio.events' (len=14)
# ---------------------------------------------------------------------------

table asyncio_extra251.function_module_identity:
  description: "asyncio module-level function __module__ identity — run comes from asyncio.runners(len=15); sleep/gather/wait_for/create_task all come from asyncio.tasks(len=13); get_event_loop comes from _asyncio(len=8) C extension; new_event_loop comes from asyncio.events(len=14); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio251fm

  columns: [id, function, args, expected, description]
  rows:
    - [fm_run_eq,        run.__module__.__eq__,            ["asyncio.runners"],  true, "asyncio.run.__module__ == 'asyncio.runners'; verified with Python 3.14.3"]
    - [fm_run_len,       run.__module__.__len__,           [],                   15,   "asyncio.run.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [fm_sleep_eq,      sleep.__module__.__eq__,          ["asyncio.tasks"],    true, "asyncio.sleep.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [fm_sleep_len,     sleep.__module__.__len__,         [],                   13,   "asyncio.sleep.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [fm_gather_eq,     gather.__module__.__eq__,         ["asyncio.tasks"],    true, "asyncio.gather.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [fm_gather_len,    gather.__module__.__len__,        [],                   13,   "asyncio.gather.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [fm_wait_for_eq,   wait_for.__module__.__eq__,       ["asyncio.tasks"],    true, "asyncio.wait_for.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [fm_wait_for_len,  wait_for.__module__.__len__,      [],                   13,   "asyncio.wait_for.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [fm_create_eq,     create_task.__module__.__eq__,    ["asyncio.tasks"],    true, "asyncio.create_task.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [fm_create_len,    create_task.__module__.__len__,   [],                   13,   "asyncio.create_task.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [fm_get_el_eq,     get_event_loop.__module__.__eq__, ["_asyncio"],         true, "asyncio.get_event_loop.__module__ == '_asyncio' (C extension); verified with Python 3.14.3"]
    - [fm_get_el_len,    get_event_loop.__module__.__len__, [],                  8,    "asyncio.get_event_loop.__module__.__len__() == 8; verified with Python 3.14.3"]
    - [fm_new_el_eq,     new_event_loop.__module__.__eq__, ["asyncio.events"],   true, "asyncio.new_event_loop.__module__ == 'asyncio.events'; verified with Python 3.14.3"]
    - [fm_new_el_len,    new_event_loop.__module__.__len__, [],                  14,   "asyncio.new_event_loop.__module__.__len__() == 14; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio module-level function __class__.__name__ identity
#
# run, sleep, gather, wait_for, create_task, new_event_loop -> 'function'
# get_event_loop -> 'builtin_function_or_method' (C extension)
# ---------------------------------------------------------------------------

table asyncio_extra251.function_class_identity:
  description: "asyncio module-level function __class__.__name__ identity — run/sleep/gather/wait_for/create_task/new_event_loop are all Python functions (__class__.__name__=='function'); get_event_loop is a C builtin (__class__.__name__=='builtin_function_or_method', len=26); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio251fc

  columns: [id, function, args, expected, description]
  rows:
    - [fc_run_eq,       run.__class__.__name__.__eq__,            ["function"],                    true, "asyncio.run.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]
    - [fc_sleep_eq,     sleep.__class__.__name__.__eq__,          ["function"],                    true, "asyncio.sleep.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]
    - [fc_gather_eq,    gather.__class__.__name__.__eq__,         ["function"],                    true, "asyncio.gather.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]
    - [fc_wait_for_eq,  wait_for.__class__.__name__.__eq__,       ["function"],                    true, "asyncio.wait_for.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]
    - [fc_create_eq,    create_task.__class__.__name__.__eq__,    ["function"],                    true, "asyncio.create_task.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]
    - [fc_get_el_eq,    get_event_loop.__class__.__name__.__eq__, ["builtin_function_or_method"],  true, "asyncio.get_event_loop.__class__.__name__ == 'builtin_function_or_method' (C extension); verified with Python 3.14.3"]
    - [fc_new_el_eq,    new_event_loop.__class__.__name__.__eq__, ["function"],                    true, "asyncio.new_event_loop.__class__.__name__ == 'function' (pure Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra251
# ---------------------------------------------------------------------------

invariant asyncio_extra251.run_module_is_asyncio_runners:
  description: "asyncio.run.__module__.__eq__('asyncio.runners') returns True — asyncio.run is defined in asyncio.runners submodule (len=15), not asyncio.tasks (len=13) where sleep/gather/wait_for/create_task live; asyncio.run.__name__ == 'run' (len=3); asyncio.run.__class__.__name__ == 'function'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: run.__module__.__eq__
  args: ["asyncio.runners"]
  expected: true

invariant asyncio_extra251.get_event_loop_is_c_builtin:
  description: "asyncio.get_event_loop.__module__.__eq__('_asyncio') returns True — get_event_loop is the only one of the seven functions in this spec implemented as a C builtin in _asyncio (len=8); its __class__.__name__ == 'builtin_function_or_method' (len=26) rather than 'function'; asyncio.get_event_loop.__name__ == 'get_event_loop' (len=14); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_event_loop.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra251.sleep_gather_wait_for_share_module:
  description: "asyncio.sleep.__module__.__eq__('asyncio.tasks') returns True — sleep, gather, wait_for, and create_task all share asyncio.tasks (len=13) as their __module__; this confirms they are all defined in the same submodule; asyncio.sleep.__name__ == 'sleep' (len=5); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: sleep.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true
