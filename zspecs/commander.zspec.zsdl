spec: commander
version: ">=11.0.0"
backend: node(commander)

docs: https://github.com/tj/commander.js#readme

provenance:
  derived_from:
    - "commander README — https://github.com/tj/commander.js#readme"
    - "Test vectors verified with commander via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "commander source"
  notes:
    - "commander is an npm package. Install: npm install commander"
    - "Usage: const { Command } = require('commander'); new Command().option(...).parse(argv, {from:'user'}).opts()"
    - "{from:'user'} tells parse() that argv contains only user args (no node/script prefix)."
    - "node_chain_eq is the spec kind for fluent builder APIs that need 3+ chained method calls."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Returns parsed options/args object; .opts() returns a plain object."
  stderr: "null"
  stickiness: "N/A — each Command instance is independent."
  codes: {}

# ── opts() — declared options ────────────────────────────────────────────────

table commander.opts:
  kind: node_chain_eq
  category: opts
  entry: constructor
  class: Command
  entry_args: []
  id_prefix: opts

  columns: [id, chain, expected]
  rows:
    - [long_flag_with_value,
       [{method: option, args: ["--foo <val>"]},
        {method: parse,  args: [["--foo", "bar"], {from: "user"}]},
        {method: opts,   args: []}],
       {foo: "bar"}]

    - [short_boolean_flag,
       [{method: option, args: ["-v, --verbose"]},
        {method: parse,  args: [["-v"], {from: "user"}]},
        {method: opts,   args: []}],
       {verbose: true}]

    - [negation_flag,
       [{method: option, args: ["--no-color"]},
        {method: parse,  args: [["--no-color"], {from: "user"}]},
        {method: opts,   args: []}],
       {color: false}]

    - [default_when_missing,
       [{method: option, args: ["-p, --port <n>", "port", "8080"]},
        {method: parse,  args: [[], {from: "user"}]},
        {method: opts,   args: []}],
       {port: "8080"}]

    - [variadic_option,
       [{method: option, args: ["--items <items...>"]},
        {method: parse,  args: [["--items", "a", "b", "c"], {from: "user"}]},
        {method: opts,   args: []}],
       {items: ["a", "b", "c"]}]

    - [equals_syntax,
       [{method: option, args: ["--name <s>"]},
        {method: parse,  args: [["--name=Alice"], {from: "user"}]},
        {method: opts,   args: []}],
       {name: "Alice"}]

    - [boolean_with_default_false,
       [{method: option, args: ["-d, --debug", "debug", false]},
        {method: parse,  args: [[], {from: "user"}]},
        {method: opts,   args: []}],
       {debug: false}]

    - [empty_when_no_options,
       [{method: parse, args: [[], {from: "user"}]},
        {method: opts,  args: []}],
       {}]

# ── args — positional arguments via .argument() ─────────────────────────────

table commander.args:
  kind: node_chain_eq
  category: args
  entry: constructor
  class: Command
  entry_args: []
  id_prefix: args

  columns: [id, chain, expected]
  rows:
    - [variadic_argument,
       [{method: argument, args: ["<files...>"]},
        {method: parse,    args: [["a.txt", "b.txt", "c.txt"], {from: "user"}]},
        {get: args}],
       ["a.txt", "b.txt", "c.txt"]]

    - [single_required_argument,
       [{method: argument, args: ["<name>"]},
        {method: parse,    args: [["alice"], {from: "user"}]},
        {get: args}],
       ["alice"]]
