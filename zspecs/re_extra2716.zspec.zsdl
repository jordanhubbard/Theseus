spec: re_extra2716
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2701.zspec.zsdl — covers __lshift__/__rshift__/__invert__ dict-presence"
  notes:
    - "Wave 628 (re_extra2716) theme: __neg__, __pos__, and __abs__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __neg__, __pos__, or __abs__ in its own __dict__."
    - "__neg__ is the unary negation operator (-x); regex objects are pattern-matching types, not numeric types."
    - "__pos__ is the unary positive operator (+x); regex objects do not implement unary numeric semantics."
    - "__abs__ is the absolute value operator (abs(x)); regex objects do not implement absolute-value semantics."
    - "Covers re.Pattern (type(re.compile(''))) and re.Match (type(re.match('', '')))."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __neg__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2716.no_neg_in_re_classes:
  description: "__neg__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the unary negation protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2716

  columns: [id, function, args, expected]
  rows:
    - ["re2716001", "re.Pattern.__dict__.__contains__", ["__neg__"], false]
    - ["re2716002", "re.Match.__dict__.__contains__",   ["__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2716.no_pos_in_re_classes:
  description: "__pos__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the unary positive protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2716

  columns: [id, function, args, expected]
  rows:
    - ["re2716003", "re.Pattern.__dict__.__contains__", ["__pos__"], false]
    - ["re2716004", "re.Match.__dict__.__contains__",   ["__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2716.no_abs_in_re_classes:
  description: "__abs__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the absolute-value protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2716

  columns: [id, function, args, expected]
  rows:
    - ["re2716005", "re.Pattern.__dict__.__contains__", ["__abs__"], false]
    - ["re2716006", "re.Match.__dict__.__contains__",   ["__abs__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods but not unary numeric hooks
# Confirms that regex objects are pattern-matching types, not numeric types
# ---------------------------------------------------------------------------

table re_extra2716.re_has_regex_methods_not_unary_numeric_hooks:
  description: "re.Pattern defines match/search/sub/findall but NOT __neg__/__pos__/__abs__; re.Match defines group/groups/start/end but NOT __neg__/__pos__/__abs__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2716

  columns: [id, function, args, expected]
  rows:
    - ["re2716007", "re.Pattern.__dict__.__contains__", ["match"],   true]
    - ["re2716008", "re.Pattern.__dict__.__contains__", ["search"],  true]
    - ["re2716009", "re.Pattern.__dict__.__contains__", ["sub"],     true]
    - ["re2716010", "re.Pattern.__dict__.__contains__", ["findall"], true]
    - ["re2716011", "re.Pattern.__dict__.__contains__", ["__neg__"], false]
    - ["re2716012", "re.Pattern.__dict__.__contains__", ["__pos__"], false]
    - ["re2716013", "re.Pattern.__dict__.__contains__", ["__abs__"], false]
    - ["re2716014", "re.Match.__dict__.__contains__",   ["group"],   true]
    - ["re2716015", "re.Match.__dict__.__contains__",   ["groups"],  true]
    - ["re2716016", "re.Match.__dict__.__contains__",   ["start"],   true]
    - ["re2716017", "re.Match.__dict__.__contains__",   ["end"],     true]
    - ["re2716018", "re.Match.__dict__.__contains__",   ["__neg__"], false]
    - ["re2716019", "re.Match.__dict__.__contains__",   ["__pos__"], false]
    - ["re2716020", "re.Match.__dict__.__contains__",   ["__abs__"], false]
