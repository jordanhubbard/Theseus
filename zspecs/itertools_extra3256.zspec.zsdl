spec: it3256
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 664 (it3256): __rpow__, __rlshift__, __rrshift__ dict-presence checks for itertools types."
    - "Theme: __rpow__/__rlshift__/__rrshift__ reflected power/shift dict-presence."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — callable/iterator/inspection/synchronization types have no reflected arithmetic."
    - "No itertools iterator type defines __rpow__, __rlshift__, or __rrshift__ in its own __dict__."
    - "All 18 itertools iterator types are C-level types; they implement iterator protocol (__iter__/__next__), not reflected power/shift protocols."
    - "itertools.pairwise requires Python >= 3.10."
    - "All 18 itertools iterator types are checked."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

