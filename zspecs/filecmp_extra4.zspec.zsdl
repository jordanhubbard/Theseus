spec: filecmp_extra4
version: ">=3.9"
backend: python_module(filecmp)

docs: https://docs.python.org/3/library/filecmp.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/filecmp.html — Python filecmp documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/filecmp.py"
  notes:
    - "This spec extends filecmp.zspec.zsdl and prior extras."
    - "filecmp.zspec.zsdl covers: cmp/cmpfiles/clear_cache __name__ table, dircmp.__name__, cmp.__module__, dircmp method names table, DEFAULT_IGNORES type and .git membership, clear_cache() return value."
    - "filecmp_extra.zspec.zsdl covers: dircmp.__bases__[0].__name__, dircmp.__module__, dircmp.__class__.__name__, DEFAULT_IGNORES VCS entries table and length, cmpfiles/clear_cache module, dircmp.hide type, cmpfiles/cmp __class__.__name__."
    - "filecmp_extra2.zspec.zsdl covers: cmp.__name__, cmpfiles.__name__, dircmp.__name__, DEFAULT_IGNORES.__class__.__name__, dircmp.__module__, dircmp.__bases__[0].__name__."
    - "filecmp_extra3.zspec.zsdl covers: clear_cache.__name__/__module__, function_names table, dircmp.__qualname__, DEFAULT_BUFSIZE class name and minimum value, cmpfiles.__module__, cmp.__name__/__module__, dircmp.__name__/__module__/__bases__."
    - "This spec adds: __qualname__ checks for cmp, cmpfiles, and clear_cache functions; dircmp method __qualname__ checks (report, report_full_closure, report_partial_closure); DEFAULT_IGNORES.__len__ minimum size check."
    - "filecmp.cmp.__qualname__ == 'cmp' — cmp is a module-level function so __qualname__ == __name__."
    - "filecmp.cmpfiles.__qualname__ == 'cmpfiles' — same rationale."
    - "filecmp.clear_cache.__qualname__ == 'clear_cache' — same rationale."
    - "dircmp method __qualname__ values use 'dircmp.<method>' form."
    - "filecmp.DEFAULT_IGNORES has at least 4 entries (RCS, CVS, tags, .nfs*)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ checks — cmp, cmpfiles, clear_cache
# Module-level functions have __qualname__ == __name__.
# Not covered in any prior filecmp spec.
# ---------------------------------------------------------------------------

table filecmp_extra4.function_qualnames:
  description: "filecmp module-level functions have __qualname__ equal to their __name__"
  kind: python_call_eq
  category: functions
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [cmp,         cmp.__qualname__.__eq__,         ["cmp"],         true]
    - [cmpfiles,    cmpfiles.__qualname__.__eq__,     ["cmpfiles"],    true]
    - [clear_cache, clear_cache.__qualname__.__eq__,  ["clear_cache"], true]

# ---------------------------------------------------------------------------
# dircmp method __qualname__ checks
# Methods defined inside a class body have __qualname__ == 'ClassName.method'.
# Not covered in any prior filecmp spec.
# ---------------------------------------------------------------------------

table filecmp_extra4.dircmp_method_qualnames:
  description: "dircmp methods have __qualname__ of the form 'dircmp.<method>'"
  kind: python_call_eq
  category: dircmp_methods
  id_prefix: dircmp_mqname

  columns: [id, function, args, expected]
  rows:
    - [report,                dircmp.report.__qualname__.__eq__,                ["dircmp.report"],                true]
    - [report_full_closure,   dircmp.report_full_closure.__qualname__.__eq__,   ["dircmp.report_full_closure"],   true]
    - [report_partial_closure, dircmp.report_partial_closure.__qualname__.__eq__, ["dircmp.report_partial_closure"], true]

# ---------------------------------------------------------------------------
# DEFAULT_IGNORES — minimum length check
# The list must contain at least 4 entries.
# Not covered in any prior filecmp spec (extra covered exact length and VCS membership).
# ---------------------------------------------------------------------------

invariant filecmp_extra4.DEFAULT_IGNORES.is_list:
  description: "filecmp.DEFAULT_IGNORES is a list"
  category: constants
  kind: python_call_eq
  function: DEFAULT_IGNORES.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant filecmp_extra4.DEFAULT_IGNORES.minimum_length:
  description: "filecmp.DEFAULT_IGNORES has at least 4 entries"
  category: constants
  kind: python_call_eq
  function: DEFAULT_IGNORES.__len__
  args: []
  method: __ge__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# dircmp method __module__ checks
# Methods defined in a class inside filecmp have __module__ == 'filecmp'.
# Not covered in any prior filecmp spec.
# ---------------------------------------------------------------------------

invariant filecmp_extra4.dircmp.report.module:
  description: "filecmp.dircmp.report.__module__ == 'filecmp'"
  category: dircmp_methods
  kind: python_call_eq
  function: dircmp.report.__module__.__eq__
  args: ["filecmp"]
  expected: true

invariant filecmp_extra4.dircmp.report_full_closure.module:
  description: "filecmp.dircmp.report_full_closure.__module__ == 'filecmp'"
  category: dircmp_methods
  kind: python_call_eq
  function: dircmp.report_full_closure.__module__.__eq__
  args: ["filecmp"]
  expected: true
