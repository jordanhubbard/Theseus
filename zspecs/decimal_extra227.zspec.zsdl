spec: decimal_extra227
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal method __name__ contracts for arithmetic and conversion methods."
    - "decimal.Decimal.__add__.__name__ == '__add__' — Decimal.__add__ method name; verified Python 3.14.3 macOS."
    - "decimal.Decimal.__sub__.__name__ == '__sub__' — Decimal.__sub__ method name; verified Python 3.14.3 macOS."
    - "decimal.Decimal.__mul__.__name__ == '__mul__' — Decimal.__mul__ method name; verified Python 3.14.3 macOS."
    - "decimal.Decimal.__truediv__.__name__ == '__truediv__' — Decimal.__truediv__ method name; length 11; verified Python 3.14.3 macOS."
    - "decimal.Decimal.__str__.__name__ == '__str__' — Decimal.__str__ method name; verified Python 3.14.3 macOS."
    - "decimal.Decimal.__repr__.__name__ == '__repr__' — Decimal.__repr__ method name; verified Python 3.14.3 macOS."
    - "decimal.Decimal.quantize.__name__ == 'quantize' — Decimal.quantize method name; length 8; verified Python 3.14.3 macOS."
    - "decimal.Decimal.sqrt.__name__ == 'sqrt' — Decimal.sqrt method name; length 4; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal arithmetic method __name__ contracts
# __add__, __sub__, __mul__, __truediv__ carry their dunder names.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra227.Decimal_arithmetic_method_names:
  description: "decimal.Decimal arithmetic method __name__ contracts — __add__, __sub__, __mul__, __truediv__; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_name
  id_prefix: decimalarthmnames227

  columns: [id, function, args, expected]
  rows:
    - [dec_add_name,      Decimal.__add__.__name__.__eq__,      ["__add__"],      true]
    - [dec_sub_name,      Decimal.__sub__.__name__.__eq__,      ["__sub__"],      true]
    - [dec_mul_name,      Decimal.__mul__.__name__.__eq__,      ["__mul__"],      true]
    - [dec_truediv_name,  Decimal.__truediv__.__name__.__eq__,  ["__truediv__"],  true]

# ---------------------------------------------------------------------------
# decimal.Decimal conversion method __name__ contracts
# __str__ and __repr__ carry their dunder names.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra227.Decimal.__str__.name:
  description: "decimal.Decimal.__str__.__name__ == '__str__' — Decimal.__str__ method name is '__str__'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Decimal.__str__.__name__.__eq__
  args: ["__str__"]
  expected: true

invariant decimal_extra227.Decimal.__str__.name_length:
  description: "decimal.Decimal.__str__.__name__.__len__() == 7 — '__str__' has 7 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Decimal.__str__.__name__.__len__
  args: []
  expected: 7

invariant decimal_extra227.Decimal.__repr__.name:
  description: "decimal.Decimal.__repr__.__name__ == '__repr__' — Decimal.__repr__ method name is '__repr__'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Decimal.__repr__.__name__.__eq__
  args: ["__repr__"]
  expected: true

invariant decimal_extra227.Decimal.__repr__.name_length:
  description: "decimal.Decimal.__repr__.__name__.__len__() == 8 — '__repr__' has 8 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Decimal.__repr__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# decimal.Decimal numeric method __name__ contracts
# quantize and sqrt carry their plain names.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra227.Decimal.quantize.name:
  description: "decimal.Decimal.quantize.__name__ == 'quantize' — Decimal.quantize method name is 'quantize'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Decimal.quantize.__name__.__eq__
  args: ["quantize"]
  expected: true

invariant decimal_extra227.Decimal.quantize.name_length:
  description: "decimal.Decimal.quantize.__name__.__len__() == 8 — 'quantize' has 8 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Decimal.quantize.__name__.__len__
  args: []
  expected: 8

invariant decimal_extra227.Decimal.sqrt.name:
  description: "decimal.Decimal.sqrt.__name__ == 'sqrt' — Decimal.sqrt method name is 'sqrt'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Decimal.sqrt.__name__.__eq__
  args: ["sqrt"]
  expected: true

invariant decimal_extra227.Decimal.sqrt.name_length:
  description: "decimal.Decimal.sqrt.__name__.__len__() == 4 — 'sqrt' has 4 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Decimal.sqrt.__name__.__len__
  args: []
  expected: 4

invariant decimal_extra227.Decimal.__truediv__.name_length:
  description: "decimal.Decimal.__truediv__.__name__.__len__() == 11 — '__truediv__' has 11 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Decimal.__truediv__.__name__.__len__
  args: []
  expected: 11
