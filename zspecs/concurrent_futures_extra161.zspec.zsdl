spec: concurrent_futures_extra161
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html#threadpoolexecutor

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.thread.ThreadPoolExecutor __dict__ membership. ThreadPoolExecutor.__dict__.__contains__('submit')==True; __dict__.__contains__('shutdown')==True; __dict__.__contains__('__init__')==True; __dict__.__contains__('__reduce__')==False (NOT in ThreadPoolExecutor.__dict__); __dict__.__contains__('map')==False (NOT in ThreadPoolExecutor.__dict__ — 'map' is inherited from Executor); __dict__.__len__()==12. Key finding: 'map' is in Executor.__dict__ (True) but NOT in ThreadPoolExecutor.__dict__ (False) because map() is defined on the abstract Executor base class and ThreadPoolExecutor inherits it without overriding. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ThreadPoolExecutor.__dict__ keys in Python 3.14.3: '__module__', '__firstlineno__', 'BROKEN', '_counter', 'prepare_context', '__init__', 'submit', '_adjust_thread_count', '_initializer_failed', 'shutdown', '__static_attributes__', '__doc__'; total 12 keys; 'map' is NOT among them — map() is defined on Executor (Executor.__dict__.__contains__('map')==True) and inherited by ThreadPoolExecutor without override; 'submit' IS in ThreadPoolExecutor.__dict__ — submit is ThreadPoolExecutor's own implementation that creates a Future and submits work to the thread pool; 'shutdown' IS in ThreadPoolExecutor.__dict__ — ThreadPoolExecutor.shutdown() has thread-specific cleanup logic. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25); ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18); compare: Executor.__module__=='concurrent.futures._base' (len=24) — thread submodule path (len=25) is 1 char longer than _base submodule path (len=24) because 'thread'=6 > '_base'=5 by 1; ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py while Executor and Future are in Lib/concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.__dict__ membership — extra161
#
# concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__('submit')    == True
# concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__('shutdown')  == True
# concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__('__init__')  == True
# concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__('map')       == False
# ---------------------------------------------------------------------------

table concurrent_futures_extra161.cf_tpe_dict_contains:
  description: "concurrent.futures.thread.ThreadPoolExecutor.__dict__ membership checks in cftpedict161 namespace — ThreadPoolExecutor.__dict__.__contains__('submit')==True (submit(fn, *args, **kwargs) is defined directly on ThreadPoolExecutor; submit schedules fn to run and returns a Future; submit is ThreadPoolExecutor's core method that creates a Future, adds the work item to the queue, and adjusts the number of worker threads if needed); ThreadPoolExecutor.__dict__.__contains__('shutdown')==True (shutdown(wait=True, cancel_futures=False) is defined directly on ThreadPoolExecutor with thread-pool-specific cleanup logic: signals all threads to finish their current work and join them); ThreadPoolExecutor.__dict__.__contains__('__init__')==True (__init__ is defined directly on ThreadPoolExecutor; initializes the thread pool with max_workers, thread_name_prefix, initializer, initargs, max_tasks_per_child); ThreadPoolExecutor.__dict__.__contains__('map')==False (KEY FINDING: 'map' is NOT in ThreadPoolExecutor.__dict__ — map() is defined on the base Executor class and ThreadPoolExecutor inherits it without override; Executor.__dict__.__contains__('map')==True confirming map lives on the base class); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpedict161

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_has_submit,   concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__,  ["submit"],    true,   "TPE.__dict__.__contains__('submit') == True (directly defined; ThreadPoolExecutor's core method); verified with Python 3.14.3"]
    - [tpe_has_shutdown, concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__,  ["shutdown"],  true,   "TPE.__dict__.__contains__('shutdown') == True (directly defined; thread-pool cleanup logic); verified with Python 3.14.3"]
    - [tpe_has_init,     concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__,  ["__init__"],  true,   "TPE.__dict__.__contains__('__init__') == True (directly defined; initializes thread pool); verified with Python 3.14.3"]
    - [tpe_no_map,       concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__,  ["map"],       false,  "TPE.__dict__.__contains__('map') == False (NOT in TPE.__dict__; 'map' is inherited from Executor); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.__dict__ membership continued — extra161
#
# ThreadPoolExecutor.__dict__.__contains__('__reduce__')     == False
# concurrent.futures.Executor.__dict__.__contains__('map')   == True
# ThreadPoolExecutor.__dict__.__len__()                      == 12
# ---------------------------------------------------------------------------

table concurrent_futures_extra161.cf_tpe_dict_len_and_executor:
  description: "ThreadPoolExecutor.__dict__ length and Executor.map membership checks in cftpedlx161 namespace — ThreadPoolExecutor.__dict__.__len__()==12 (exactly 12 keys directly defined on ThreadPoolExecutor in Python 3.14.3: '__module__', '__firstlineno__', 'BROKEN', '_counter', 'prepare_context', '__init__', 'submit', '_adjust_thread_count', '_initializer_failed', 'shutdown', '__static_attributes__', '__doc__'; 12 is the total count); ThreadPoolExecutor.__dict__.__contains__('__reduce__')==False ('__reduce__' is NOT directly in ThreadPoolExecutor.__dict__; __reduce__ for pickle support is not defined on ThreadPoolExecutor itself); concurrent.futures.Executor.__dict__.__contains__('map')==True (KEY: 'map' IS in Executor.__dict__ — this confirms map() is inherited by ThreadPoolExecutor from the Executor base class, explaining why 'map' is False in TPE.__dict__ but True in Executor.__dict__); Executor.map() takes a function and an iterable and returns an iterator over the results — it calls submit() internally; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpedlx161

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_dict_len,       concurrent.futures.thread.ThreadPoolExecutor.__dict__.__len__,           [],            12,     "TPE.__dict__.__len__() == 12 (12 directly-defined entries in Python 3.14.3); verified with Python 3.14.3"]
    - [tpe_no_reduce,      concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__,      ["__reduce__"],  false,  "TPE.__dict__.__contains__('__reduce__') == False (NOT directly in TPE.__dict__); verified with Python 3.14.3"]
    - [exec_has_map,       concurrent.futures.Executor.__dict__.__contains__,                       ["map"],         true,   "Executor.__dict__.__contains__('map') == True (map defined on base Executor, inherited by TPE); verified with Python 3.14.3"]
    - [tpe_has_prepare_ctx, concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__,     ["prepare_context"],  true,   "TPE.__dict__.__contains__('prepare_context') == True (directly defined on TPE); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor class identity — extra161
#
# ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor')  == True
# ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra161.cf_tpe_class_identity:
  description: "concurrent.futures.thread.ThreadPoolExecutor class identity checks in cftpeid161 namespace — ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18; the thread-based concurrent executor; manages a pool of reusable worker threads; submit() dispatches callables to the thread pool; shutdown() signals workers to stop); ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25; ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py; compare: Executor.__module__=='concurrent.futures._base' (len=24; 1 shorter because '_base'=5 < 'thread'=6)); ThreadPoolExecutor.__name__.__len__()==18 ('ThreadPoolExecutor'=18: 'Thread'=6+'Pool'=4+'Executor'=8=18; note 'PoolExecutor'=12 as a unit); compare: concurrent.futures._base.Future.__name__.__len__()==6 (Future=6; ThreadPoolExecutor=18 is 12 chars longer); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpeid161

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_name_eq,   concurrent.futures.thread.ThreadPoolExecutor.__name__.__eq__,    ["ThreadPoolExecutor"],          true,  "TPE.__name__ == 'ThreadPoolExecutor' (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18); verified with Python 3.14.3"]
    - [tpe_mod_eq,    concurrent.futures.thread.ThreadPoolExecutor.__module__.__eq__,  ["concurrent.futures.thread"],   true,  "TPE.__module__ == 'concurrent.futures.thread' (len=25; thread submodule; 1 longer than _base=24); verified with Python 3.14.3"]
    - [tpe_name_len,  concurrent.futures.thread.ThreadPoolExecutor.__name__.__len__,   [],                              18,    "TPE.__name__.__len__() == 18 ('ThreadPoolExecutor'; 'Thread'=6+'Pool'=4+'Executor'=8=18); verified with Python 3.14.3"]
    - [tpe_mod_len,   concurrent.futures.thread.ThreadPoolExecutor.__module__.__len__, [],                              25,    "TPE.__module__.__len__() == 25 ('concurrent.futures.thread'; 1 longer than _base=24); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra161
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra161.cf_TPE_dict_has_submit:
  description: "concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__('submit') returns True — 'submit' is defined directly in ThreadPoolExecutor.__dict__; submit(fn, *args, **kwargs) is the core method of ThreadPoolExecutor that schedules fn to be executed in a worker thread; submit() creates a Future, puts a _WorkItem on the internal work queue, calls _adjust_thread_count() to start new worker threads if needed (up to max_workers), and returns the Future; ThreadPoolExecutor overrides submit() from Executor with its thread-pool implementation; compare: 'map' is NOT in ThreadPoolExecutor.__dict__ (map is inherited from Executor without override) but 'submit' IS directly on ThreadPoolExecutor; compare: concurrent.futures.Executor.__dict__.__contains__('submit')==False (Executor's submit raises NotImplementedError — each concrete executor must implement it); NEW in extra161: first standalone TPE.__dict__.__contains__('submit') invariant in cftpedict161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra161.cf_TPE_dict_has_shutdown:
  description: "concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__('shutdown') returns True — 'shutdown' is defined directly in ThreadPoolExecutor.__dict__; shutdown(wait=True, cancel_futures=False) signals all worker threads to finish and optionally waits for them to complete; ThreadPoolExecutor.shutdown() has thread-pool-specific cleanup: it sets the _broken flag, puts sentinel values on the work queue for each thread, and joins the threads; compare: Executor has a shutdown method too, but ThreadPoolExecutor's shutdown in __dict__ is its own override with thread-specific logic; 'shutdown' (len=8) is longer than 'submit' (len=6) by 2 chars; compare: '__init__' is also directly in TPE.__dict__ (len=8 like 'shutdown'); verified that both 'submit' and 'shutdown' are directly on ThreadPoolExecutor while 'map' is only on Executor; NEW in extra161: first standalone TPE.__dict__.__contains__('shutdown') invariant in cftpedict161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__
  args: ["shutdown"]
  expected: true

invariant concurrent_futures_extra161.cf_TPE_dict_no_map:
  description: "concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__('map') returns False — 'map' is NOT in ThreadPoolExecutor.__dict__; ThreadPoolExecutor does NOT define its own map() method; map() is defined on the base Executor class (concurrent.futures.Executor.__dict__.__contains__('map')==True) and ThreadPoolExecutor inherits it via the MRO without overriding; Executor.map(fn, *iterables, timeout=None, chunksize=1) calls submit() for each item and returns an iterator over results; because ThreadPoolExecutor's submit() is what actually dispatches work, Executor.map() works correctly when called on a ThreadPoolExecutor instance through inheritance; this is a key example of how abstract executor methods can be defined once on Executor and work for any concrete implementation; compare: 'submit' and 'shutdown' ARE in TPE.__dict__ (those methods have thread-specific implementations); NEW in extra161: first standalone TPE.__dict__.__contains__('map') false-membership invariant in cftpedict161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__
  args: ["map"]
  expected: false

invariant concurrent_futures_extra161.cf_TPE_dict_len:
  description: "concurrent.futures.thread.ThreadPoolExecutor.__dict__.__len__() returns 12 — ThreadPoolExecutor.__dict__ has exactly 12 entries in Python 3.14.3: '__module__', '__firstlineno__', 'BROKEN', '_counter', 'prepare_context', '__init__', 'submit', '_adjust_thread_count', '_initializer_failed', 'shutdown', '__static_attributes__', '__doc__'; the dict length of 12 reflects the directly-defined attributes and methods on ThreadPoolExecutor; 'BROKEN' is a class-level sentinel attribute; '_counter' is a class-level counter for thread naming; '_adjust_thread_count' and '_initializer_failed' are private helper methods; compare: multiprocessing.pool.Pool.__dict__.__len__()==42 (Pool has many more methods directly defined); concurrent.futures._base.Future.__dict__ membership was established in prior specs (extra159) with methods like result, exception, set_result, set_exception; NEW in extra161: first standalone TPE.__dict__.__len__ invariant in cftpedlx161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.thread.ThreadPoolExecutor.__dict__.__len__
  args: []
  expected: 12

invariant concurrent_futures_extra161.cf_Executor_dict_has_map:
  description: "concurrent.futures.Executor.__dict__.__contains__('map') returns True — 'map' IS in Executor.__dict__; this confirms that map() is defined on the abstract Executor base class, NOT on ThreadPoolExecutor; Executor.map(fn, *iterables, timeout=None, chunksize=1) provides a default map implementation that calls self.submit() for each item from the iterables and returns an iterator of futures; because map() calls self.submit() internally, it works correctly for any Executor subclass that implements submit(); concurrent.futures.Executor.__dict__.__contains__('map')==True vs concurrent.futures.thread.ThreadPoolExecutor.__dict__.__contains__('map')==False demonstrates the inheritance: map lives on Executor, submit lives on ThreadPoolExecutor (and ProcessPoolExecutor); this is one of the core design patterns of the concurrent.futures framework; compare: asyncio.AbstractEventLoop.__dict__.__contains__('run_forever')==True (established in extra162 — abstract base defines the interface); NEW in extra161: first standalone Executor.__dict__.__contains__('map') invariant in cftpedlx161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.__dict__.__contains__
  args: ["map"]
  expected: true
