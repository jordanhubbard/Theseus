spec: sade
version: ">=1.0.0"
backend: node(sade)

docs: https://github.com/lukeed/sade#readme

provenance:
  derived_from:
    - "sade README — https://github.com/lukeed/sade#readme"
    - "Test vectors verified with sade via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "sade source"
  notes:
    - "Smooth CLI builder — define commands, options, parse argv."
    - "Install: npm install sade"
    - "v1 CJS; module export IS the sade(name) factory."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws on duplicate command/option names."
  stderr: "null"
  stickiness: "Builder accumulates state via .command() / .option() / .action() calls."
  codes: {}

invariant sade.module_is_function:
  description: "Module export is the sade factory"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant sade.factory_arity:
  description: "sade takes (name, isSingle?) — function.length 2"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 2

invariant sade.instance_has_command:
  description: "Instance has .command method"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["my-cli"]
  chain:
    - {get: "command.constructor.name"}
  expected: "Function"

invariant sade.instance_has_option:
  description: "Instance has .option method"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["my-cli"]
  chain:
    - {get: "option.constructor.name"}
  expected: "Function"

invariant sade.instance_has_action:
  description: "Instance has .action method"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["my-cli"]
  chain:
    - {get: "action.constructor.name"}
  expected: "Function"

invariant sade.instance_has_describe:
  description: "Instance has .describe method"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["my-cli"]
  chain:
    - {get: "describe.constructor.name"}
  expected: "Function"

invariant sade.instance_has_parse:
  description: "Instance has .parse method"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["my-cli"]
  chain:
    - {get: "parse.constructor.name"}
  expected: "Function"

invariant sade.instance_has_help:
  description: "Instance has .help method"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["my-cli"]
  chain:
    - {get: "help.constructor.name"}
  expected: "Function"
