spec: itertools_extra1501
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 547 theme: __await__, __aiter__, __anext__ async protocol checks and __aenter__/__aexit__ async context manager checks for itertools classes."
    - "itertools.chain: no async protocol methods in __dict__. Verified with Python 3.12."
    - "itertools.count: no async protocol methods in __dict__. Verified with Python 3.12."
    - "itertools.cycle: no async protocol methods in __dict__. Verified with Python 3.12."
    - "itertools.repeat: no async protocol methods in __dict__. Verified with Python 3.12."
    - "itertools.accumulate: no async protocol methods in __dict__. Verified with Python 3.12."
    - "itertools.combinations: no async protocol methods in __dict__. Verified with Python 3.12."
    - "All itertools classes implement the synchronous iterator protocol (__iter__ and __next__) but none implement any async protocol."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain and itertools.count — async protocol absence checks
#
# Wave 547 theme: chain concatenates iterables; count counts indefinitely.
#
# itertools.chain.__dict__.__contains__("__await__") == False
# itertools.chain.__dict__.__contains__("__aiter__") == False
# itertools.chain.__dict__.__contains__("__anext__") == False
# itertools.chain.__dict__.__contains__("__aenter__") == False
# itertools.chain.__dict__.__contains__("__aexit__") == False
#
# Both are synchronous iterators. They have __iter__ and __next__ in __dict__
# but no async protocol methods. New to extra1501.
# ---------------------------------------------------------------------------

table itertools_extra1501.chain_count_async_protocol_absence:
  description: "itertools.chain and count have no async protocol methods in __dict__; both are synchronous iterators implementing __iter__ and __next__ only; wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1501cc

  columns: [id, function, args, expected, description]
  rows:
    - [it1501cc001,
       "chain.__dict__.__contains__",
       ["__await__"],
       false,
       "itertools.chain.__dict__.__contains__('__await__') == False — chain is a synchronous iterator that concatenates multiple iterables into a single sequence; it does not implement the awaitable protocol; __await__ is not in chain.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cc002,
       "chain.__dict__.__contains__",
       ["__aiter__"],
       false,
       "itertools.chain.__dict__.__contains__('__aiter__') == False — chain does not implement the async iterator protocol; __aiter__ is not in chain.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cc003,
       "chain.__dict__.__contains__",
       ["__anext__"],
       false,
       "itertools.chain.__dict__.__contains__('__anext__') == False — chain does not implement the async iterator protocol; __anext__ is not in chain.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cc004,
       "chain.__dict__.__contains__",
       ["__aenter__"],
       false,
       "itertools.chain.__dict__.__contains__('__aenter__') == False — chain does not implement the async context manager protocol; __aenter__ is not in chain.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cc005,
       "count.__dict__.__contains__",
       ["__await__"],
       false,
       "itertools.count.__dict__.__contains__('__await__') == False — count is a synchronous infinite counter iterator; it does not implement the awaitable protocol; __await__ is not in count.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cc006,
       "count.__dict__.__contains__",
       ["__aiter__"],
       false,
       "itertools.count.__dict__.__contains__('__aiter__') == False — count does not implement the async iterator protocol; __aiter__ is not in count.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cc007,
       "chain.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.chain.__dict__.__contains__('__iter__') == True — chain IS a synchronous iterator and defines __iter__ in its __dict__; this is the synchronous iterator protocol, not the async iterator protocol; verified with Python 3.12; new to extra1501"]
    - [it1501cc008,
       "chain.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.chain.__dict__.__contains__('__next__') == True — chain defines __next__ in its __dict__ confirming it is a synchronous iterator; __next__ is the synchronous counterpart to __anext__; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Table 2: itertools.cycle, itertools.repeat, itertools.accumulate —
# async protocol absence checks
#
# Wave 547 theme: cycle cycles a sequence forever; repeat repeats a value;
# accumulate computes running aggregates.
#
# itertools.cycle.__dict__.__contains__("__await__") == False
# itertools.repeat.__dict__.__contains__("__aiter__") == False
# itertools.accumulate.__dict__.__contains__("__anext__") == False
#
# All are synchronous iterators with __iter__ and __next__ in __dict__.
# New to extra1501.
# ---------------------------------------------------------------------------

table itertools_extra1501.cycle_repeat_accumulate_async_protocol_absence:
  description: "itertools.cycle, repeat, and accumulate have no async protocol methods in __dict__; all are synchronous iterators; wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1501cr

  columns: [id, function, args, expected, description]
  rows:
    - [it1501cr001,
       "cycle.__dict__.__contains__",
       ["__await__"],
       false,
       "itertools.cycle.__dict__.__contains__('__await__') == False — cycle is a synchronous iterator that cycles through a sequence indefinitely; it does not implement the awaitable protocol; __await__ is not in cycle.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cr002,
       "cycle.__dict__.__contains__",
       ["__aiter__"],
       false,
       "itertools.cycle.__dict__.__contains__('__aiter__') == False — cycle does not implement the async iterator protocol; __aiter__ is not in cycle.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cr003,
       "repeat.__dict__.__contains__",
       ["__anext__"],
       false,
       "itertools.repeat.__dict__.__contains__('__anext__') == False — repeat is a synchronous iterator that repeats a single value N times or indefinitely; it does not implement the async iterator protocol; __anext__ is not in repeat.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cr004,
       "repeat.__dict__.__contains__",
       ["__aenter__"],
       false,
       "itertools.repeat.__dict__.__contains__('__aenter__') == False — repeat does not implement the async context manager protocol; __aenter__ is not in repeat.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cr005,
       "accumulate.__dict__.__contains__",
       ["__await__"],
       false,
       "itertools.accumulate.__dict__.__contains__('__await__') == False — accumulate is a synchronous iterator that computes running totals or aggregates; it does not implement the awaitable protocol; __await__ is not in accumulate.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cr006,
       "accumulate.__dict__.__contains__",
       ["__aexit__"],
       false,
       "itertools.accumulate.__dict__.__contains__('__aexit__') == False — accumulate does not implement the async context manager protocol; __aexit__ is not in accumulate.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cr007,
       "cycle.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.cycle.__dict__.__contains__('__iter__') == True — cycle IS a synchronous iterator and defines __iter__ in its __dict__; this is the synchronous iterator protocol, not the async protocol; verified with Python 3.12; new to extra1501"]
    - [it1501cr008,
       "accumulate.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.accumulate.__dict__.__contains__('__next__') == True — accumulate defines __next__ in its __dict__ confirming it is a synchronous iterator; this is the synchronous counterpart to __anext__; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Table 3: itertools.combinations — async protocol absence checks
#
# Wave 547 theme: combinations produces r-length subsequences.
#
# itertools.combinations.__dict__.__contains__("__await__") == False
# itertools.combinations.__dict__.__contains__("__aiter__") == False
# itertools.combinations.__dict__.__contains__("__anext__") == False
# itertools.combinations.__dict__.__contains__("__aenter__") == False
# itertools.combinations.__dict__.__contains__("__aexit__") == False
#
# combinations is a synchronous iterator. It has __iter__ and __next__
# but no async protocol methods. New to extra1501.
# ---------------------------------------------------------------------------

table itertools_extra1501.combinations_async_protocol_absence:
  description: "itertools.combinations has no async protocol methods in __dict__; combinations is a synchronous iterator yielding r-length subsequences; wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1501cb

  columns: [id, function, args, expected, description]
  rows:
    - [it1501cb001,
       "combinations.__dict__.__contains__",
       ["__await__"],
       false,
       "itertools.combinations.__dict__.__contains__('__await__') == False — combinations is a synchronous iterator yielding r-length subsequences from an input iterable; it does not implement the awaitable protocol; __await__ is not in combinations.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cb002,
       "combinations.__dict__.__contains__",
       ["__aiter__"],
       false,
       "itertools.combinations.__dict__.__contains__('__aiter__') == False — combinations does not implement the async iterator protocol; __aiter__ is not in combinations.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cb003,
       "combinations.__dict__.__contains__",
       ["__anext__"],
       false,
       "itertools.combinations.__dict__.__contains__('__anext__') == False — combinations does not implement the async iterator protocol; __anext__ is not in combinations.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cb004,
       "combinations.__dict__.__contains__",
       ["__aenter__"],
       false,
       "itertools.combinations.__dict__.__contains__('__aenter__') == False — combinations does not implement the async context manager protocol; __aenter__ is not in combinations.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cb005,
       "combinations.__dict__.__contains__",
       ["__aexit__"],
       false,
       "itertools.combinations.__dict__.__contains__('__aexit__') == False — combinations does not implement the async context manager protocol; __aexit__ is not in combinations.__dict__; verified with Python 3.12; new to extra1501"]
    - [it1501cb006,
       "combinations.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.combinations.__dict__.__contains__('__iter__') == True — combinations IS a synchronous iterator and defines __iter__ in its __dict__; this is the synchronous iterator protocol, not any async protocol; verified with Python 3.12; new to extra1501"]
    - [it1501cb007,
       "combinations.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.combinations.__dict__.__contains__('__next__') == True — combinations defines __next__ in its __dict__ confirming it is a synchronous iterator; __next__ is the synchronous counterpart to the absent __anext__; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1501
# ---------------------------------------------------------------------------

invariant itertools_extra1501.chain_no_await:
  description: "itertools.chain.__dict__ does not contain '__await__' — chain is a synchronous iterator, not an awaitable; wave 547; new to extra1501"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant itertools_extra1501.chain_no_aiter:
  description: "itertools.chain.__dict__ does not contain '__aiter__' — chain does not implement the async iterator protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__aiter__"]
  expected: false

invariant itertools_extra1501.cycle_no_aenter:
  description: "itertools.cycle.__dict__ does not contain '__aenter__' — cycle does not implement the async context manager protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: cycle.__dict__.__contains__
  args: ["__aenter__"]
  expected: false

invariant itertools_extra1501.repeat_no_await:
  description: "itertools.repeat.__dict__ does not contain '__await__' — repeat is a synchronous iterator, not an awaitable; wave 547; new to extra1501"
  kind: python_call_eq
  function: repeat.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant itertools_extra1501.accumulate_no_aiter:
  description: "itertools.accumulate.__dict__ does not contain '__aiter__' — accumulate does not implement the async iterator protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: accumulate.__dict__.__contains__
  args: ["__aiter__"]
  expected: false

invariant itertools_extra1501.combinations_no_anext:
  description: "itertools.combinations.__dict__ does not contain '__anext__' — combinations does not implement the async iterator protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: combinations.__dict__.__contains__
  args: ["__anext__"]
  expected: false

invariant itertools_extra1501.combinations_has_next:
  description: "itertools.combinations.__dict__ contains '__next__' — combinations IS a synchronous iterator; wave 547; new to extra1501"
  kind: python_call_eq
  function: combinations.__dict__.__contains__
  args: ["__next__"]
  expected: true
