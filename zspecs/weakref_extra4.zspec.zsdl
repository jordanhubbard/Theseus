spec: weakref_extra4
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends prior weakref specs."
    - "Focus: __module__ and __name__ for weakref classes and functions."
    - "weakref.ref is a callable class for creating weak references."
    - "weakref.WeakValueDictionary, weakref.WeakKeyDictionary are mapping classes."
    - "weakref.WeakSet is a set-like class for weak references."
    - "weakref.finalize is a class for running a callback when an object is garbage collected."
    - "weakref.getweakrefcount.__name__ == 'getweakrefcount'."
    - "weakref.getweakrefs.__name__ == 'getweakrefs'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table weakref_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [ref,                  ref.__name__.__eq__,                  ["ref"],                  true]
    - [WeakValueDictionary,  WeakValueDictionary.__name__.__eq__,  ["WeakValueDictionary"],  true]
    - [WeakKeyDictionary,    WeakKeyDictionary.__name__.__eq__,    ["WeakKeyDictionary"],    true]
    - [WeakSet,              WeakSet.__name__.__eq__,              ["WeakSet"],              true]
    - [finalize,             finalize.__name__.__eq__,             ["finalize"],             true]

table weakref_extra4.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [WeakValueDictionary, WeakValueDictionary.__module__.__eq__, ["weakref"], true]
    - [WeakKeyDictionary,   WeakKeyDictionary.__module__.__eq__,   ["weakref"], true]
    - [WeakSet,             WeakSet.__module__.__eq__,             ["weakref"], true]
    - [finalize,            finalize.__module__.__eq__,            ["weakref"], true]

table weakref_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [getweakrefcount, getweakrefcount.__name__.__eq__, ["getweakrefcount"], true]
    - [getweakrefs,     getweakrefs.__name__.__eq__,     ["getweakrefs"],     true]

invariant weakref_extra4.WeakValueDictionary.instance_class:
  description: "weakref.WeakValueDictionary().__class__.__name__ == 'WeakValueDictionary'"
  category: WeakValueDictionary
  kind: python_call_eq
  function: WeakValueDictionary
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["WeakValueDictionary"]
  expected: true

invariant weakref_extra4.WeakKeyDictionary.instance_class:
  description: "weakref.WeakKeyDictionary().__class__.__name__ == 'WeakKeyDictionary'"
  category: WeakKeyDictionary
  kind: python_call_eq
  function: WeakKeyDictionary
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["WeakKeyDictionary"]
  expected: true

invariant weakref_extra4.WeakSet.instance_class:
  description: "weakref.WeakSet().__class__.__name__ == 'WeakSet'"
  category: WeakSet
  kind: python_call_eq
  function: WeakSet
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["WeakSet"]
  expected: true
