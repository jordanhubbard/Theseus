spec: traceback
version: ">=3.5"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/traceback.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
    - "traceback source: traceback.py (PSF; source inspection permitted)"
  not_derived_from:
    - "traceback source: internal CPython frame/code object implementation details"
  notes:
    - "traceback.format_exc() with no active exception returns 'NoneType: None\\n'."
    - "traceback.extract_stack() returns a StackSummary (subclass of list) with at least one frame."
    - "traceback.TracebackException, traceback.StackSummary, and traceback.FrameSummary are public classes added in Python 3.5."
    - "traceback.format_list, format_exception, format_exception_only all return lists of strings."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "traceback functions raise TypeError for wrong argument types; passing non-traceback objects raises AttributeError."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table traceback.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [format_exc,            format_exc.__name__.__eq__,            ["format_exc"],            true]
    - [format_tb,             format_tb.__name__.__eq__,             ["format_tb"],             true]
    - [format_list,           format_list.__name__.__eq__,           ["format_list"],           true]
    - [format_exception,      format_exception.__name__.__eq__,      ["format_exception"],      true]
    - [format_exception_only, format_exception_only.__name__.__eq__,  ["format_exception_only"], true]
    - [format_stack,          format_stack.__name__.__eq__,          ["format_stack"],          true]
    - [extract_tb,            extract_tb.__name__.__eq__,            ["extract_tb"],            true]
    - [extract_stack,         extract_stack.__name__.__eq__,         ["extract_stack"],         true]
    - [print_exc,             print_exc.__name__.__eq__,             ["print_exc"],             true]
    - [print_tb,              print_tb.__name__.__eq__,              ["print_tb"],              true]
    - [print_exception,       print_exception.__name__.__eq__,       ["print_exception"],       true]
    - [print_stack,           print_stack.__name__.__eq__,           ["print_stack"],           true]
    - [clear_frames,          clear_frames.__name__.__eq__,          ["clear_frames"],          true]
    - [walk_stack,            walk_stack.__name__.__eq__,            ["walk_stack"],            true]
    - [walk_tb,               walk_tb.__name__.__eq__,               ["walk_tb"],               true]

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table traceback.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [TracebackException, TracebackException.__name__.__eq__, ["TracebackException"], true]
    - [StackSummary,       StackSummary.__name__.__eq__,       ["StackSummary"],       true]
    - [FrameSummary,       FrameSummary.__name__.__eq__,       ["FrameSummary"],       true]

# ---------------------------------------------------------------------------
# format_exc — with no active exception returns a fixed sentinel string
# ---------------------------------------------------------------------------

invariant traceback.format_exc.no_exception:
  description: "traceback.format_exc() with no active exception returns 'NoneType: None\\n'"
  category: format_exc
  kind: python_call_eq
  function: format_exc
  args: []
  expected: "NoneType: None\n"

# ---------------------------------------------------------------------------
# extract_stack — returns a StackSummary (non-empty, even at module scope)
# ---------------------------------------------------------------------------

invariant traceback.extract_stack.class_name:
  description: "traceback.extract_stack().__class__.__name__ == 'StackSummary'"
  category: extract_stack
  kind: python_call_eq
  function: extract_stack().__class__.__name__.__eq__
  args: ["StackSummary"]
  expected: true

invariant traceback.extract_stack.nonempty:
  description: "len(traceback.extract_stack()) >= 1 — always at least one frame"
  category: extract_stack
  kind: python_call_eq
  function: extract_stack().__len__().__ge__
  args: [1]
  expected: true
