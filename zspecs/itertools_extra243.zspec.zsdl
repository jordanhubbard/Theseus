spec: itertools_extra243
version: ">=3.0"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools_extra242.zspec.zsdl — covers islice and takewhile class identity"
    - "itertools_extra241.zspec.zsdl — covers dropwhile and chain class identity"
    - "itertools_extra.zspec.zsdl — covers combinations/permutations/product/compress/zip_longest names"
    - "itertools.zspec.zsdl — covers itertools class names and module identity"
  notes:
    - "This spec covers itertools.filterfalse and itertools.starmap class identity contracts."
    - "itertools.filterfalse.__name__ == 'filterfalse' (len=11) — filterfalse is a C-level type in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.filterfalse.__module__ == 'itertools' (len=9) — filterfalse is exposed in the itertools namespace. Verified with Python 3.14.3."
    - "itertools.filterfalse.__bases__[0].__name__ == 'object' — filterfalse inherits directly from object. Verified with Python 3.14.3."
    - "itertools.filterfalse.__class__.__name__ == 'type' — filterfalse is a C extension type. Verified with Python 3.14.3."
    - "itertools.starmap.__name__ == 'starmap' (len=7) — starmap is a C-level type in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.starmap.__module__ == 'itertools' (len=9) — starmap is exposed in the itertools namespace. Verified with Python 3.14.3."
    - "itertools.starmap.__bases__[0].__name__ == 'object' — starmap inherits directly from object. Verified with Python 3.14.3."
    - "itertools.starmap.__class__.__name__ == 'type' — starmap is a C extension type. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.filterfalse class identity contracts
#
# itertools.filterfalse.__name__ == 'filterfalse' (len=11)
# itertools.filterfalse.__module__ == 'itertools' (len=9)
# itertools.filterfalse.__qualname__ == 'filterfalse' (len=11)  [not tested, C type]
# itertools.filterfalse.__class__.__name__ == 'type'
# itertools.filterfalse.__name__.__len__() == 11
#
# filterfalse is a C-level type in itertoolsmodule.c. New to extra243.
# ---------------------------------------------------------------------------

table itertools_extra243.filtfal243_identity:
  description: "itertools.filterfalse class identity: name, module, bases, class; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: filtfal243

  columns: [id, function, args, expected, description]
  rows:
    - [ff_name_eq,
       filterfalse.__name__.__eq__,
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__.__eq__('filterfalse') == True — filterfalse is a C-level type in itertoolsmodule.c; __name__ is 'filterfalse' (len=11); new to extra243"]
    - [ff_name_len_11,
       filterfalse.__name__.__len__,
       [],
       11,
       "itertools.filterfalse.__name__.__len__() == 11 — 'filterfalse' has exactly 11 characters; str.__len__() returns 11; new to extra243"]
    - [ff_module_eq,
       filterfalse.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.filterfalse.__module__.__eq__('itertools') == True — filterfalse is exposed in the itertools namespace; __module__ is 'itertools' (len=9); new to extra243"]
    - [ff_module_len_9,
       filterfalse.__module__.__len__,
       [],
       9,
       "itertools.filterfalse.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra243"]
    - [ff_bases_0_is_object,
       "filterfalse.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.filterfalse.__bases__[0].__name__.__eq__('object') == True — filterfalse inherits directly from object; __bases__[0] is object; new to extra243"]

# ---------------------------------------------------------------------------
# Table 2: itertools.filterfalse class type and content checks
#
# itertools.filterfalse.__class__.__name__ == 'type'
# itertools.filterfalse.__name__.__contains__('false') == True
# itertools.filterfalse.__name__.__contains__('filter') == True
# itertools.filterfalse.__module__.__contains__('itertools') == True
# itertools.filterfalse.__bases__[0].__name__.__len__() == 6
#
# New to extra243.
# ---------------------------------------------------------------------------

table itertools_extra243.filtfal243_class:
  description: "itertools.filterfalse class type, name/module content checks; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: filtfal243c

  columns: [id, function, args, expected, description]
  rows:
    - [ff_class_is_type,
       filterfalse.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.filterfalse.__class__.__name__.__eq__('type') == True — filterfalse is a C extension type; its metaclass is the built-in type; new to extra243"]
    - [ff_name_contains_false,
       filterfalse.__name__.__contains__,
       ["false"],
       true,
       "itertools.filterfalse.__name__.__contains__('false') == True — 'filterfalse' contains the suffix 'false'; new to extra243"]
    - [ff_name_contains_filter,
       filterfalse.__name__.__contains__,
       ["filter"],
       true,
       "itertools.filterfalse.__name__.__contains__('filter') == True — 'filterfalse' contains the prefix 'filter'; new to extra243"]
    - [ff_module_contains_itertools,
       filterfalse.__module__.__contains__,
       ["itertools"],
       true,
       "itertools.filterfalse.__module__.__contains__('itertools') == True — 'itertools' contains the substring 'itertools'; new to extra243"]
    - [ff_bases_0_len_6,
       "filterfalse.__bases__[0].__name__.__len__",
       [],
       6,
       "itertools.filterfalse.__bases__[0].__name__.__len__() == 6 — 'object' has exactly 6 characters; new to extra243"]

# ---------------------------------------------------------------------------
# Table 3: itertools.starmap class identity contracts
#
# itertools.starmap.__name__ == 'starmap' (len=7)
# itertools.starmap.__module__ == 'itertools' (len=9)
# itertools.starmap.__bases__[0].__name__ == 'object'
# itertools.starmap.__class__.__name__ == 'type'
# itertools.starmap.__name__.__len__() == 7
#
# starmap is a C-level type in itertoolsmodule.c. New to extra243.
# ---------------------------------------------------------------------------

table itertools_extra243.starmap243_identity:
  description: "itertools.starmap class identity: name, module, bases, class; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: starmap243

  columns: [id, function, args, expected, description]
  rows:
    - [sm_name_eq,
       starmap.__name__.__eq__,
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — starmap is a C-level type in itertoolsmodule.c; __name__ is 'starmap' (len=7); new to extra243"]
    - [sm_name_len_7,
       starmap.__name__.__len__,
       [],
       7,
       "itertools.starmap.__name__.__len__() == 7 — 'starmap' has exactly 7 characters; str.__len__() returns 7; new to extra243"]
    - [sm_module_eq,
       starmap.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.starmap.__module__.__eq__('itertools') == True — starmap is exposed in the itertools namespace; __module__ is 'itertools' (len=9); new to extra243"]
    - [sm_module_len_9,
       starmap.__module__.__len__,
       [],
       9,
       "itertools.starmap.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra243"]
    - [sm_bases_0_is_object,
       "starmap.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.starmap.__bases__[0].__name__.__eq__('object') == True — starmap inherits directly from object; __bases__[0] is object; new to extra243"]

# ---------------------------------------------------------------------------
# Table 4: itertools.starmap class type and content checks
#
# itertools.starmap.__class__.__name__ == 'type'
# itertools.starmap.__name__.__contains__('star') == True
# itertools.starmap.__name__.__contains__('map') == True
# itertools.starmap.__module__.__contains__('itertools') == True
# itertools.starmap.__bases__[0].__name__.__len__() == 6
#
# New to extra243.
# ---------------------------------------------------------------------------

table itertools_extra243.starmap243_class:
  description: "itertools.starmap class type, name/module content checks; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: starmap243c

  columns: [id, function, args, expected, description]
  rows:
    - [sm_class_is_type,
       starmap.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.starmap.__class__.__name__.__eq__('type') == True — starmap is a C extension type; its metaclass is the built-in type; new to extra243"]
    - [sm_name_contains_star,
       starmap.__name__.__contains__,
       ["star"],
       true,
       "itertools.starmap.__name__.__contains__('star') == True — 'starmap' contains the prefix 'star'; new to extra243"]
    - [sm_name_contains_map,
       starmap.__name__.__contains__,
       ["map"],
       true,
       "itertools.starmap.__name__.__contains__('map') == True — 'starmap' contains the suffix 'map'; new to extra243"]
    - [sm_module_contains_itertools,
       starmap.__module__.__contains__,
       ["itertools"],
       true,
       "itertools.starmap.__module__.__contains__('itertools') == True — 'itertools' contains the substring 'itertools'; new to extra243"]
    - [sm_bases_0_len_6,
       "starmap.__bases__[0].__name__.__len__",
       [],
       6,
       "itertools.starmap.__bases__[0].__name__.__len__() == 6 — 'object' has exactly 6 characters; new to extra243"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra243
# ---------------------------------------------------------------------------

invariant itertools_extra243.ff_name_eq:
  description: "itertools.filterfalse.__name__ == 'filterfalse' (len=11); new to extra243"
  kind: python_call_eq
  function: filterfalse.__name__.__eq__
  args: ["filterfalse"]
  expected: true

invariant itertools_extra243.ff_module_eq:
  description: "itertools.filterfalse.__module__ == 'itertools' — C-level type in itertools namespace; new to extra243"
  kind: python_call_eq
  function: filterfalse.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra243.ff_bases_0_is_object:
  description: "itertools.filterfalse.__bases__[0].__name__ == 'object' — inherits from object; new to extra243"
  kind: python_call_eq
  function: "filterfalse.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra243.ff_class_is_type:
  description: "itertools.filterfalse.__class__.__name__ == 'type' — C extension type; new to extra243"
  kind: python_call_eq
  function: filterfalse.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra243.ff_name_len_11:
  description: "itertools.filterfalse.__name__.__len__() == 11; new to extra243"
  kind: python_call_eq
  function: filterfalse.__name__.__len__
  args: []
  expected: 11

invariant itertools_extra243.sm_name_eq:
  description: "itertools.starmap.__name__ == 'starmap' (len=7); new to extra243"
  kind: python_call_eq
  function: starmap.__name__.__eq__
  args: ["starmap"]
  expected: true

invariant itertools_extra243.sm_module_eq:
  description: "itertools.starmap.__module__ == 'itertools' — C-level type in itertools namespace; new to extra243"
  kind: python_call_eq
  function: starmap.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra243.sm_bases_0_is_object:
  description: "itertools.starmap.__bases__[0].__name__ == 'object' — inherits from object; new to extra243"
  kind: python_call_eq
  function: "starmap.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra243.sm_class_is_type:
  description: "itertools.starmap.__class__.__name__ == 'type' — C extension type; new to extra243"
  kind: python_call_eq
  function: starmap.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra243.sm_name_len_7:
  description: "itertools.starmap.__name__.__len__() == 7; new to extra243"
  kind: python_call_eq
  function: starmap.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra243.ff_name_contains_filter:
  description: "itertools.filterfalse.__name__ contains 'filter'; new to extra243"
  kind: python_call_eq
  function: filterfalse.__name__.__contains__
  args: ["filter"]
  expected: true

invariant itertools_extra243.sm_name_contains_star:
  description: "itertools.starmap.__name__ contains 'star'; new to extra243"
  kind: python_call_eq
  function: starmap.__name__.__contains__
  args: ["star"]
  expected: true
