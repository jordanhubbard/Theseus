spec: doctest_extra7
version: ">=3.9"
backend: python_module(doctest)

docs: https://docs.python.org/3/library/doctest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/doctest.html — Python doctest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/doctest.py"
  notes:
    - "Extends doctest.zspec.zsdl through doctest_extra6.zspec.zsdl."
    - "doctest (base) covers: testmod/testfile/run_docstring_examples/register_optionflag/__name__, DocTest/DocTestFinder/DocTestRunner/DocTestParser/OutputChecker/Example/DocTestFailure/UnexpectedException/DebugRunner/TestResults.__name__, ELLIPSIS/NORMALIZE_WHITESPACE/IGNORE_EXCEPTION_DETAIL/SKIP/FAIL_FAST is_int."
    - "doctest_extra through doctest_extra6 cover: __name__, __module__, __qualname__, __bases__[0] for all major classes; flag constant numeric values; flag class name checks via __eq__; class __name__ identity checks for DocTestSuite/DocFileSuite."
    - "NEW in this spec: remaining flag constant numeric values (DONT_ACCEPT_BLANKLINE/REPORT_UDIFF/REPORT_CDIFF/REPORT_NDIFF/REPORT_ONLY_FIRST_FAILURE/COMPARISON_FLAGS/REPORTING_FLAGS); Example/__name__/__module__/__qualname__; TestResults/__name__/__module__/__qualname__; UnexpectedException/__bases__[0].__name__; DocTestFailure/__bases__[0].__name__."
    - "doctest.DONT_ACCEPT_BLANKLINE == 2 — prevents blank lines from matching BLANKLINE directives."
    - "doctest.REPORT_UDIFF == 64 — show unified diffs in failure reports."
    - "doctest.REPORT_CDIFF == 128 — show context diffs in failure reports."
    - "doctest.REPORT_NDIFF == 256 — show ndiff-style diffs."
    - "doctest.REPORT_ONLY_FIRST_FAILURE == 512 — stop reporting after first failure."
    - "doctest.COMPARISON_FLAGS == 63 — bitmask of all comparison option flags."
    - "doctest.REPORTING_FLAGS == 1984 — bitmask of all reporting option flags."
    - "doctest.Example.__module__ == 'doctest', __qualname__ == 'Example', __bases__[0].__name__ == 'object'."
    - "doctest.TestResults.__module__ == 'doctest', __qualname__ == 'TestResults', __bases__[0].__name__ == 'TestResults' (namedtuple)."
    - "doctest.UnexpectedException.__bases__[0].__name__ == 'Exception'."
    - "doctest.DocTestFailure.__bases__[0].__name__ == 'Exception'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Remaining flag constant numeric values — not covered in prior specs
#
# doctest_extra2 covers ELLIPSIS==8, NORMALIZE_WHITESPACE==2, SKIP==16.
# doctest_extra3 covers IGNORE_EXCEPTION_DETAIL==32, FAIL_FAST==64.
# These seven constants have not yet had their numeric values verified.
# ---------------------------------------------------------------------------

table doctest_extra7.flag_values:
  kind: python_call_eq
  category: flag_constants
  id_prefix: flag

  columns: [id, function, args, expected]
  rows:
    - [dont_accept_blankline,      DONT_ACCEPT_BLANKLINE.__eq__,      [2],    true]
    - [report_udiff,               REPORT_UDIFF.__eq__,               [64],   true]
    - [report_cdiff,               REPORT_CDIFF.__eq__,               [128],  true]
    - [report_ndiff,               REPORT_NDIFF.__eq__,               [256],  true]
    - [report_only_first_failure,  REPORT_ONLY_FIRST_FAILURE.__eq__,  [512],  true]
    - [comparison_flags,           COMPARISON_FLAGS.__eq__,           [63],   true]
    - [reporting_flags,            REPORTING_FLAGS.__eq__,            [1984], true]

# ---------------------------------------------------------------------------
# Example class metadata — __name__, __module__, __qualname__
# Prior specs confirm Example.__name__ via table but not __module__/__qualname__.
# ---------------------------------------------------------------------------

invariant doctest_extra7.Example_name:
  description: "doctest.Example.__name__ == 'Example'"
  category: class_names
  kind: python_call_eq
  function: Example.__name__.__eq__
  args: ["Example"]
  expected: true

invariant doctest_extra7.Example_module:
  description: "doctest.Example.__module__ == 'doctest'"
  category: class_modules
  kind: python_call_eq
  function: Example.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra7.Example_qualname:
  description: "doctest.Example.__qualname__ == 'Example'"
  category: class_qualnames
  kind: python_call_eq
  function: Example.__qualname__.__eq__
  args: ["Example"]
  expected: true

# ---------------------------------------------------------------------------
# TestResults class metadata — __name__, __module__, __qualname__
# TestResults is a namedtuple; __bases__[0].__name__ == 'TestResults'
# (the auto-generated namedtuple class).  Not covered in prior specs.
# ---------------------------------------------------------------------------

invariant doctest_extra7.TestResults_name:
  description: "doctest.TestResults.__name__ == 'TestResults'"
  category: class_names
  kind: python_call_eq
  function: TestResults.__name__.__eq__
  args: ["TestResults"]
  expected: true

invariant doctest_extra7.TestResults_module:
  description: "doctest.TestResults.__module__ == 'doctest'"
  category: class_modules
  kind: python_call_eq
  function: TestResults.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra7.TestResults_qualname:
  description: "doctest.TestResults.__qualname__ == 'TestResults'"
  category: class_qualnames
  kind: python_call_eq
  function: TestResults.__qualname__.__eq__
  args: ["TestResults"]
  expected: true

# ---------------------------------------------------------------------------
# Exception subclass hierarchy — UnexpectedException and DocTestFailure
# both inherit directly from Exception.  Not covered in prior specs via
# the __bases__[0].__name__ form used here.
# ---------------------------------------------------------------------------

invariant doctest_extra7.UnexpectedException_base:
  description: "doctest.UnexpectedException.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: UnexpectedException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant doctest_extra7.DocTestFailure_base:
  description: "doctest.DocTestFailure.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: DocTestFailure.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"
