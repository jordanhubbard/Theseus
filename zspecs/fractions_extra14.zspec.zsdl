spec: fractions_extra14
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and prior extras (fractions_extra through fractions_extra13)."
    - "fractions_extra2 covers: MRO[1].__name__ == 'Rational'; fractions_extra5 covers MRO[2].__name__ == 'Real'."
    - "fractions_extra6 covers: Fraction.__mro__.__len__() == 6; MRO[0].__name__ == 'Fraction'; MRO[3].__name__ == 'Complex'."
    - "fractions_extra7 covers: MRO[4].__name__ == 'Number'; MRO[5].__name__ == 'object'."
    - "fractions_extra9 covers: Fraction.limit_denominator.__name__ == 'limit_denominator'."
    - "No prior spec covers Fraction.__doc__.__class__.__name__ == 'str'."
    - "No prior spec covers Fraction.from_decimal.__qualname__ == 'Fraction.from_decimal'."
    - "No prior spec covers Fraction.limit_denominator.__qualname__ == 'Fraction.limit_denominator'."
    - "No prior spec covers Fraction.from_decimal.__module__ == 'fractions'."
    - "No prior spec covers Fraction.limit_denominator.__module__ == 'fractions'."
    - "No prior spec covers a table of Fraction(n,d).__class__.__name__ for multiple n/d inputs in one table."
    - "Fraction.__doc__.__class__.__name__ == 'str' — the docstring is a str object."
    - "Fraction.from_decimal.__qualname__ == 'Fraction.from_decimal' — qualname encodes the enclosing class."
    - "Fraction.limit_denominator.__qualname__ == 'Fraction.limit_denominator' — qualname encodes the enclosing class."
    - "Fraction.from_decimal.__module__ == 'fractions' — from_decimal is defined in the fractions module."
    - "Fraction.limit_denominator.__module__ == 'fractions' — limit_denominator is defined in the fractions module."
    - "Fraction(n,d).__class__.__name__ == 'Fraction' for all valid n/d inputs."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction.__doc__ type
#
# No prior spec checks the type of the Fraction class docstring.
# Fraction.__doc__ is a str. Verified by checking __class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant fractions_extra14.Fraction.doc_class_name:
  description: "Fraction.__doc__.__class__.__name__ == 'str' — the Fraction docstring is a str object"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Fraction.from_decimal and limit_denominator __qualname__
#
# fractions_extra9 covers Fraction.limit_denominator.__name__ == 'limit_denominator'.
# No prior spec covers the __qualname__ of either method, which includes the
# enclosing class name as a dotted prefix.
# ---------------------------------------------------------------------------

invariant fractions_extra14.Fraction.from_decimal_qualname:
  description: "Fraction.from_decimal.__qualname__ == 'Fraction.from_decimal' — qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: Fraction.from_decimal.__qualname__.__eq__
  args: ["Fraction.from_decimal"]
  expected: true

invariant fractions_extra14.Fraction.limit_denominator_qualname:
  description: "Fraction.limit_denominator.__qualname__ == 'Fraction.limit_denominator' — qualname includes class prefix"
  category: function_identity
  kind: python_call_eq
  function: Fraction.limit_denominator.__qualname__.__eq__
  args: ["Fraction.limit_denominator"]
  expected: true

# ---------------------------------------------------------------------------
# Fraction.from_decimal and limit_denominator __module__
#
# No prior spec covers the __module__ of these two Fraction class methods.
# Both methods are defined in the fractions module itself.
# ---------------------------------------------------------------------------

invariant fractions_extra14.Fraction.from_decimal_module:
  description: "Fraction.from_decimal.__module__ == 'fractions' — from_decimal is defined in fractions"
  category: function_identity
  kind: python_call_eq
  function: Fraction.from_decimal.__module__.__eq__
  args: ["fractions"]
  expected: true

invariant fractions_extra14.Fraction.limit_denominator_module:
  description: "Fraction.limit_denominator.__module__ == 'fractions' — limit_denominator is defined in fractions"
  category: function_identity
  kind: python_call_eq
  function: Fraction.limit_denominator.__module__.__eq__
  args: ["fractions"]
  expected: true

# ---------------------------------------------------------------------------
# Fraction(n,d).__class__.__name__ for several (n,d) inputs
#
# Prior specs cover this for specific inputs (Fraction(1,2), Fraction(1,3), etc.)
# but not as a unified table. This table checks multiple pairs in one place.
# fractions_extra2 covers Fraction(0) and Fraction(1) (single-arg integer).
# fractions_extra11 covers Fraction(1,3).__class__.__name__ (two-arg form).
# This table adds Fraction(2,3), Fraction(3,4), Fraction(5,6), and Fraction(-3,7).
# ---------------------------------------------------------------------------

table fractions_extra14.instance_class_name:
  kind: python_call_eq
  category: class_identity
  id_prefix: class_name

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [two_thirds,         Fraction, [2, 3],   __class__.__name__.__eq__, ["Fraction"], true]
    - [three_quarters,     Fraction, [3, 4],   __class__.__name__.__eq__, ["Fraction"], true]
    - [five_sixths,        Fraction, [5, 6],   __class__.__name__.__eq__, ["Fraction"], true]
    - [neg_three_sevenths, Fraction, [-3, 7],  __class__.__name__.__eq__, ["Fraction"], true]
    - [seven_halves,       Fraction, [7, 2],   __class__.__name__.__eq__, ["Fraction"], true]
