spec: struct_extra27
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra26.zspec.zsdl — covers struct.__all__.__len__() (8) and __class__.__name__ ('list'); __spec__.__class__.__name__ ('ModuleSpec'); Struct/__reduce__/__qualname__/__len__() (17); error.__reduce__/__qualname__/__len__() (24); Struct.__name__.__len__() (6); error.__name__.__len__() (5)."
    - "struct_extra25.zspec.zsdl — covers __module__.__len__() for all six functions and both classes; __name__.__len__() for pack/unpack/calcsize/pack_into."
    - "struct_extra20.zspec.zsdl — covers __qualname__.__len__() for pack/unpack/pack_into/unpack_from/calcsize/iter_unpack."
  notes:
    - "This spec extends struct_extra26.zspec.zsdl."
    - "Prior specs covered: all function and class __qualname__/__name__/__module__ strings and lengths; __all__ length (8) and class name ('list'); Struct and error __reduce__ qualname lengths."
    - "This spec covers: struct.Struct.__mro__.__len__() (2); struct.Struct.__bases__[0].__name__.__len__() (6, 'object'); struct.error.__mro__.__len__() (4); struct.error.__bases__[0].__name__.__len__() (9, 'Exception'); struct.Struct.__dict__.__class__.__name__.__len__() (12, 'mappingproxy'); struct.error.__dict__.__class__.__name__.__len__() (12, 'mappingproxy'); struct.Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "struct.Struct.__mro__.__len__() == 2 — (Struct, object). Verified."
    - "struct.Struct.__bases__[0].__name__ == 'object', len == 6. Verified."
    - "struct.error.__mro__.__len__() == 4 — (error, Exception, BaseException, object). Verified."
    - "struct.error.__bases__[0].__name__ == 'Exception', len == 9. Verified."
    - "struct.Struct.__dict__.__class__.__name__ == 'mappingproxy', len == 12. Verified."
    - "struct.error.__dict__.__class__.__name__ == 'mappingproxy', len == 12. Verified."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack', len == 11. Verified."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack', len == 13. Verified."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into', len == 16. Verified."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from', len == 18. Verified."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack', len == 18. Verified."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: MRO and base class structure for Struct and error
#
# struct.Struct is a direct C extension type with MRO == (Struct, object),
# so __mro__.__len__() == 2. struct.error is a pure-Python exception subclass
# with MRO == (error, Exception, BaseException, object), so __mro__.__len__() == 4.
# No prior struct spec covers __mro__ lengths or __bases__[0].__name__.
# The base class name for Struct is 'object' (len 6); for error it is
# 'Exception' (len 9). Verified.
# ---------------------------------------------------------------------------

table struct_extra27.class_hierarchy:
  description: "struct.Struct and error MRO lengths and base class name lengths — Struct(2/6), error(4/9)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: hier27

  columns: [id, function, args, expected]
  rows:
    - [Struct_mro_len,         "Struct.__mro__.__len__",                [], 2]
    - [error_mro_len,          "error.__mro__.__len__",                 [], 4]
    - [Struct_base_name_len,   "Struct.__bases__[0].__name__.__len__",  [], 6]
    - [error_base_name_len,    "error.__bases__[0].__name__.__len__",   [], 9]

# ---------------------------------------------------------------------------
# Table: Struct method __qualname__.__len__() — five instance methods
#
# struct.Struct exposes pack, unpack, pack_into, unpack_from, iter_unpack.
# Their qualnames follow the pattern 'Struct.METHOD': pack=11, unpack=13,
# pack_into=16, unpack_from=18, iter_unpack=18. No prior struct spec covers
# Struct instance method __qualname__.__len__() values. struct_extra20 covers
# the module-level function qualname lengths (e.g. pack.__qualname__='pack',
# len 4) but not Struct-bound method qualnames.
# Verified: all five values above.
# id_prefix smql27 is novel.
# ---------------------------------------------------------------------------

table struct_extra27.struct_method_qualname_lens:
  description: "struct.Struct method __qualname__.__len__() — pack(11)/unpack(13)/pack_into(16)/unpack_from(18)/iter_unpack(18)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: smql27

  columns: [id, function, args, expected]
  rows:
    - [pack,        "Struct.pack.__qualname__.__len__",        [], 11]
    - [unpack,      "Struct.unpack.__qualname__.__len__",      [], 13]
    - [pack_into,   "Struct.pack_into.__qualname__.__len__",   [], 16]
    - [unpack_from, "Struct.unpack_from.__qualname__.__len__", [], 18]
    - [iter_unpack, "Struct.iter_unpack.__qualname__.__len__", [], 18]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy'
#
# struct.Struct.__dict__ is a mappingproxy (the type used for class __dict__
# in CPython). 'mappingproxy' has 12 characters. No prior struct spec covers
# __dict__.__class__.__name__ for Struct or error. The same length (12) applies
# to both, because both class namespaces use the same mappingproxy type.
# Verified: struct.Struct.__dict__.__class__.__name__ == 'mappingproxy'.
# ---------------------------------------------------------------------------

invariant struct_extra27.Struct.dict_class_name_len:
  description: "struct.Struct.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"
  category: class_identity
  kind: python_call_eq
  function: "Struct.__dict__.__class__.__name__.__len__"
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# struct.error.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy'
#
# struct.error.__dict__ is also a mappingproxy. Length 12, same as Struct.
# Standalone invariant for error in extra27 to confirm both class namespaces
# use the identical proxy type, regardless of inheritance depth differences.
# Verified: struct.error.__dict__.__class__.__name__ == 'mappingproxy'.
# ---------------------------------------------------------------------------

invariant struct_extra27.error.dict_class_name_len:
  description: "struct.error.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"
  category: class_identity
  kind: python_call_eq
  function: "error.__dict__.__class__.__name__.__len__"
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__len__() == 9 — len('Exception') == 9
#
# struct.error directly inherits from Exception. 'Exception' has 9 characters.
# No prior struct spec covers error.__bases__[0].__name__ or its length.
# Complements the error.__mro__.__len__() == 4 check in the table above.
# Verified: struct.error.__bases__[0].__name__ == 'Exception'.
# ---------------------------------------------------------------------------

invariant struct_extra27.error.base_name_len:
  description: "struct.error.__bases__[0].__name__.__len__() == 9 — error inherits directly from Exception; len('Exception') == 9"
  category: class_hierarchy
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__qualname__.__len__() == 18 — standalone anchor
#
# 'Struct.unpack_from' has 18 characters — the longest among the five Struct
# instance methods (tied with iter_unpack). Standalone invariant in extra27
# for unpack_from, which mirrors the module-level unpack_from.__qualname__ ==
# 'unpack_from' (len 11) from struct_extra20.
# Verified: len('Struct.unpack_from') == 18.
# ---------------------------------------------------------------------------

invariant struct_extra27.Struct_unpack_from.qualname_len:
  description: "struct.Struct.unpack_from.__qualname__.__len__() == 18 — 'Struct.unpack_from' has 18 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "Struct.unpack_from.__qualname__.__len__"
  args: []
  expected: 18

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__len__() == 11 — standalone anchor
#
# 'Struct.pack' has 11 characters — the shortest among the five Struct instance
# methods. Contrasts with the module-level pack.__qualname__ == 'pack' (len 4)
# from struct_extra20; the Struct-bound method qualname is 7 characters longer
# due to the 'Struct.' prefix. Verified: len('Struct.pack') == 11.
# ---------------------------------------------------------------------------

invariant struct_extra27.Struct_pack.qualname_len:
  description: "struct.Struct.pack.__qualname__.__len__() == 11 — 'Struct.pack' has 11 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "Struct.pack.__qualname__.__len__"
  args: []
  expected: 11
