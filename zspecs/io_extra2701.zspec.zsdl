spec: io_extra2701
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2686.zspec.zsdl — covers __and__/__or__/__xor__ dict-presence"
  notes:
    - "Wave 627 (io_extra2701) theme: __lshift__, __rshift__, and __invert__ dict-presence checks."
    - "None of the io classes define __lshift__, __rshift__, or __invert__ in their own __dict__."
    - "__lshift__ is the left-shift operator (<<); io stream classes are sequential I/O objects, not integers."
    - "__rshift__ is the right-shift operator (>>); io stream classes do not implement bit-shift semantics."
    - "__invert__ is the bitwise NOT operator (~); io stream classes do not implement bitwise inversion."
    - "Covers io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and io.TextIOWrapper."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2701.no_lshift_in_io_classes:
  description: "__lshift__ is absent from all io class __dict__s — io stream classes do not implement the left-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2701

  columns: [id, function, args, expected]
  rows:
    - ["io2701001", "io.IOBase.__dict__.__contains__",         ["__lshift__"], false]
    - ["io2701002", "io.RawIOBase.__dict__.__contains__",      ["__lshift__"], false]
    - ["io2701003", "io.BufferedIOBase.__dict__.__contains__", ["__lshift__"], false]
    - ["io2701004", "io.TextIOBase.__dict__.__contains__",     ["__lshift__"], false]
    - ["io2701005", "io.BytesIO.__dict__.__contains__",        ["__lshift__"], false]
    - ["io2701006", "io.StringIO.__dict__.__contains__",       ["__lshift__"], false]

# ---------------------------------------------------------------------------
# __rshift__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2701.no_rshift_in_io_classes:
  description: "__rshift__ is absent from all io class __dict__s — io stream classes do not implement the right-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2701

  columns: [id, function, args, expected]
  rows:
    - ["io2701007", "io.IOBase.__dict__.__contains__",          ["__rshift__"], false]
    - ["io2701008", "io.FileIO.__dict__.__contains__",          ["__rshift__"], false]
    - ["io2701009", "io.BufferedReader.__dict__.__contains__",  ["__rshift__"], false]
    - ["io2701010", "io.BufferedWriter.__dict__.__contains__",  ["__rshift__"], false]
    - ["io2701011", "io.BufferedRandom.__dict__.__contains__",  ["__rshift__"], false]
    - ["io2701012", "io.TextIOWrapper.__dict__.__contains__",   ["__rshift__"], false]

# ---------------------------------------------------------------------------
# __invert__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2701.no_invert_in_io_classes:
  description: "__invert__ is absent from all io class __dict__s — io stream classes do not implement the bitwise NOT protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2701

  columns: [id, function, args, expected]
  rows:
    - ["io2701013", "io.IOBase.__dict__.__contains__",         ["__invert__"], false]
    - ["io2701014", "io.BytesIO.__dict__.__contains__",        ["__invert__"], false]
    - ["io2701015", "io.StringIO.__dict__.__contains__",       ["__invert__"], false]
    - ["io2701016", "io.FileIO.__dict__.__contains__",         ["__invert__"], false]
    - ["io2701017", "io.BufferedReader.__dict__.__contains__", ["__invert__"], false]
    - ["io2701018", "io.BufferedWriter.__dict__.__contains__", ["__invert__"], false]

# ---------------------------------------------------------------------------
# Complementary: io stream classes have I/O methods but not bit-shift or bitwise-NOT hooks
# Confirms that io classes are sequential I/O objects, not integer types
# ---------------------------------------------------------------------------

table io_extra2701.io_has_stream_methods_not_shift_hooks:
  description: "io.BytesIO defines read/write/seek/tell but NOT __lshift__/__rshift__/__invert__; io.StringIO similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2701

  columns: [id, function, args, expected]
  rows:
    - ["io2701019", "io.BytesIO.__dict__.__contains__",  ["read"],      true]
    - ["io2701020", "io.BytesIO.__dict__.__contains__",  ["write"],     true]
    - ["io2701021", "io.BytesIO.__dict__.__contains__",  ["seek"],      true]
    - ["io2701022", "io.BytesIO.__dict__.__contains__",  ["tell"],      true]
    - ["io2701023", "io.BytesIO.__dict__.__contains__",  ["__lshift__"], false]
    - ["io2701024", "io.BytesIO.__dict__.__contains__",  ["__rshift__"], false]
    - ["io2701025", "io.BytesIO.__dict__.__contains__",  ["__invert__"], false]
    - ["io2701026", "io.StringIO.__dict__.__contains__", ["read"],      true]
    - ["io2701027", "io.StringIO.__dict__.__contains__", ["write"],     true]
    - ["io2701028", "io.StringIO.__dict__.__contains__", ["seek"],      true]
    - ["io2701029", "io.StringIO.__dict__.__contains__", ["tell"],      true]
    - ["io2701030", "io.StringIO.__dict__.__contains__", ["__lshift__"], false]
    - ["io2701031", "io.StringIO.__dict__.__contains__", ["__rshift__"], false]
    - ["io2701032", "io.StringIO.__dict__.__contains__", ["__invert__"], false]
