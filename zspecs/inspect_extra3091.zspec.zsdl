spec: in3091
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 653 (in3091): __hash__, __eq__, __bool__ dict-presence checks for inspect types."
    - "inspect.Parameter defines both __hash__ and __eq__ in its __dict__ (value object with structural equality)."
    - "inspect.Signature defines both __hash__ and __eq__ in its __dict__ (value object with structural equality)."
    - "inspect.BoundArguments defines __eq__ in its __dict__ AND __hash__ = None (explicitly unhashable); operator.contains returns true for __hash__ because the key is present even though the value is None."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses; none define __hash__, __eq__, or __bool__ in their own __dict__."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception classes; none define __hash__, __eq__, or __bool__ in their own __dict__."
    - "No inspect type defines __bool__ in its own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3091.hash:
  description: "inspect types __hash__ dict-presence checks; wave 653"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3091
  columns: [id, function, args, expected]
  rows:
    - ["in3091001", operator.contains, [inspect.Parameter.__dict__,           "__hash__"], true]
    - ["in3091002", operator.contains, [inspect.Signature.__dict__,           "__hash__"], true]
    - ["in3091003", operator.contains, [inspect.BoundArguments.__dict__,      "__hash__"], true]
    - ["in3091004", operator.contains, [inspect.FrameInfo.__dict__,           "__hash__"], false]
    - ["in3091005", operator.contains, [inspect.ArgInfo.__dict__,             "__hash__"], false]
    - ["in3091006", operator.contains, [inspect.FullArgSpec.__dict__,         "__hash__"], false]
    - ["in3091007", operator.contains, [inspect.Attribute.__dict__,           "__hash__"], false]
    - ["in3091008", operator.contains, [inspect.ClassFoundException.__dict__, "__hash__"], false]
    - ["in3091009", operator.contains, [inspect.EndOfBlock.__dict__,          "__hash__"], false]

