spec: multiprocessing_extra26
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra25.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__, Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, Lock/Event/Semaphore/Value/Array __module__=='multiprocessing.context', managers/shared_memory __name__, Pool.__qualname__=='BaseContext.Pool', cpu_count/get_start_method/set_start_method/get_context/__name__."
    - "This spec covers: Process.__module__.__len__(); Process.__name__.__len__(); ProcessError/__module__ and __len__(); AuthenticationError/BufferTooShort/TimeoutError __module__; cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__."
    - "Process.__module__ == 'multiprocessing.context' — length 23. Process is injected via the default context, so __module__ is 'multiprocessing.context'."
    - "ProcessError.__module__ == 'multiprocessing.context' — length 23."
    - "AuthenticationError.__module__ == 'multiprocessing.context' — length 23."
    - "BufferTooShort.__module__ == 'multiprocessing.context' — length 23."
    - "TimeoutError.__module__ == 'multiprocessing.context' — length 23."
    - "cpu_count.__qualname__ == 'BaseContext.cpu_count' — context-bound method (length 21)."
    - "get_start_method.__qualname__ == 'DefaultContext.get_start_method' — DefaultContext override (length 31)."
    - "set_start_method.__qualname__ == 'DefaultContext.set_start_method' — DefaultContext override (length 31)."
    - "get_context.__qualname__ == 'DefaultContext.get_context' — DefaultContext override (length 26)."
    - "active_children.__qualname__ == 'active_children' — module-level function (length 15)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Process class __module__ and __name__ lengths — extra26 namespace
#
# multiprocessing.Process is injected via the default context; at runtime
# its __module__ == 'multiprocessing.context' (length 23).
# Process.__name__ == 'Process' (length 7).
# Prior specs check the string values; this spec adds the __len__() axis.
# ---------------------------------------------------------------------------

table multiprocessing_extra26.process_attr_lengths:
  description: "multiprocessing.Process __module__ and __name__ lengths in extra26 namespace"
  kind: python_call_eq
  category: class_modules
  id_prefix: proclen26

  columns: [id, function, args, expected]
  rows:
    - [module, Process.__module__.__len__, [], 23]
    - [name,   Process.__name__.__len__,   [], 7]

# ---------------------------------------------------------------------------
# Exception class __module__ table — extra26 namespace
#
# All four multiprocessing exception classes are injected via the default
# context (BaseContext/DefaultContext) and their __module__ is
# 'multiprocessing.context' (length 23):
#   ProcessError, AuthenticationError, BufferTooShort, TimeoutError.
# Prior specs cover __bases__ hierarchy; this spec covers __module__ values.
# ---------------------------------------------------------------------------

table multiprocessing_extra26.exception_modules:
  description: "multiprocessing exception class __module__ values in extra26 namespace"
  kind: python_call_eq
  category: class_modules
  id_prefix: excmod26

  columns: [id, function, args, expected]
  rows:
    - [ProcessError,        ProcessError.__module__.__eq__,        ["multiprocessing.context"], true]
    - [AuthenticationError, AuthenticationError.__module__.__eq__, ["multiprocessing.context"], true]
    - [BufferTooShort,      BufferTooShort.__module__.__eq__,      ["multiprocessing.context"], true]
    - [TimeoutError,        TimeoutError.__module__.__eq__,        ["multiprocessing.context"], true]

# ---------------------------------------------------------------------------
# Exception class __module__ length table — extra26 namespace
#
# All four exception classes have __module__ == 'multiprocessing.context'
# (length 23). This table adds the __len__() axis.
# ---------------------------------------------------------------------------

table multiprocessing_extra26.exception_module_lengths:
  description: "multiprocessing exception class __module__ lengths in extra26 namespace"
  kind: python_call_eq
  category: class_modules
  id_prefix: excmodlen26

  columns: [id, function, args, expected]
  rows:
    - [ProcessError,        ProcessError.__module__.__len__,        [], 23]
    - [AuthenticationError, AuthenticationError.__module__.__len__, [], 23]
    - [BufferTooShort,      BufferTooShort.__module__.__len__,      [], 23]
    - [TimeoutError,        TimeoutError.__module__.__len__,        [], 23]

# ---------------------------------------------------------------------------
# Context-bound and module-level function __qualname__ table — extra26 namespace
#
# multiprocessing exposes several functions via the default context:
#   cpu_count.__qualname__ == 'BaseContext.cpu_count' (21) — BaseContext method
#   get_start_method.__qualname__ == 'DefaultContext.get_start_method' (31) — overridden in DefaultContext
#   set_start_method.__qualname__ == 'DefaultContext.set_start_method' (31) — overridden in DefaultContext
#   get_context.__qualname__ == 'DefaultContext.get_context' (26) — overridden in DefaultContext
#   active_children.__qualname__ == 'active_children' (15) — pure module-level function
# No prior spec checks __qualname__ for any of these functions.
# ---------------------------------------------------------------------------

table multiprocessing_extra26.function_qualnames:
  description: "multiprocessing function __qualname__ values in extra26 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: fqualname26

  columns: [id, function, args, expected]
  rows:
    - [cpu_count,        cpu_count.__qualname__.__eq__,        ["BaseContext.cpu_count"],               true]
    - [get_start_method, get_start_method.__qualname__.__eq__, ["DefaultContext.get_start_method"],      true]
    - [set_start_method, set_start_method.__qualname__.__eq__, ["DefaultContext.set_start_method"],      true]
    - [get_context,      get_context.__qualname__.__eq__,      ["DefaultContext.get_context"],           true]
    - [active_children,  active_children.__qualname__.__eq__,  ["active_children"],                     true]
