spec: tunnel_agent
version: ">=0.6.0"
backend: node(tunnel-agent)

docs: https://github.com/mikeal/tunnel-agent#readme

provenance:
  derived_from:
    - "tunnel-agent README — https://github.com/mikeal/tunnel-agent#readme"
    - "Test vectors verified with tunnel-agent via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "tunnel-agent source"
  notes:
    - "HTTP/HTTPS proxy tunneling agent — used by request, axios, npm internals."
    - "Install: npm install tunnel-agent"
    - "v0.6 CJS; named exports httpOverHttp / httpsOverHttp / httpOverHttps / httpsOverHttps factories."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factories; never throw."
  stderr: "null"
  stickiness: "N/A — each agent independent."
  codes: {}

invariant tunnel_agent.has_httpOverHttp:
  description: "httpOverHttp factory is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "httpOverHttp.constructor.name"}
  expected: "Function"

invariant tunnel_agent.has_httpsOverHttp:
  description: "httpsOverHttp factory is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "httpsOverHttp.constructor.name"}
  expected: "Function"

invariant tunnel_agent.has_httpOverHttps:
  description: "httpOverHttps factory is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "httpOverHttps.constructor.name"}
  expected: "Function"

invariant tunnel_agent.has_httpsOverHttps:
  description: "httpsOverHttps factory is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "httpsOverHttps.constructor.name"}
  expected: "Function"

invariant tunnel_agent.factory_arity:
  description: "Factory functions take a single options argument"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "httpOverHttp.length"}
  expected: 1

invariant tunnel_agent.has_debug_export:
  description: "debug helper is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "debug.constructor.name"}
  expected: "Function"
