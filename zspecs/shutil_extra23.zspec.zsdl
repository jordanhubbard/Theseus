spec: shutil_extra23
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
    - "shutil_extra22.zspec.zsdl — covers make_archive/unpack_archive/get_terminal_size __qualname__ equality as standalone invariants and table."
    - "shutil_extra21.zspec.zsdl — covers get_archive_formats/get_unpack_formats/make_archive/unpack_archive/get_terminal_size __qualname__.__len__()."
    - "shutil_extra19.zspec.zsdl — covers __qualname__ equality table and length invariants for copy/copy2/copytree/rmtree/disk_usage/which."
    - "shutil_extra20.zspec.zsdl — covers __qualname__.__len__() for copyfile/copystat/copymode/move."
  notes:
    - "This spec extends shutil_extra22; it does NOT duplicate invariants present in prior specs."
    - "Prior specs covered: __qualname__ equality and length for all major shutil functions; __qualname__ equality for archive/terminal-size functions (extra22); length for archive/terminal-size functions (extra21)."
    - "This spec covers: shutil.__all__.__len__() == 25 (NOVEL — no prior shutil spec checks __all__ length); shutil.__all__.__class__.__name__.__len__() == 4 (NOVEL, 'list'); shutil.Error.__dict__.__class__.__name__.__len__() == 12 (NOVEL — 'mappingproxy'); shutil.SameFileError.__dict__.__class__.__name__.__len__() == 12 (NOVEL); shutil.Error.__bases__[0].__name__ == 'OSError', len == 7 (NOVEL — no prior shutil spec checks Error.__bases__[0].__name__); shutil.SameFileError.__bases__[0].__name__ == 'Error', len == 5 (NOVEL); shutil.Error.__mro__.__len__() == 5 (NOVEL); shutil.SameFileError.__mro__.__len__() == 6 (NOVEL); shutil.SameFileError.__name__.__len__() == 13 (NOVEL); shutil.Error.__name__.__len__() == 5 (NOVEL)."
    - "shutil.__all__.__len__() == 25: shutil publishes 25 names in __all__. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "shutil.Error.__bases__[0].__name__ == 'OSError' (len 7): shutil.Error directly inherits from OSError. Note: the task description says 'OSError' len == 9 but 'OSError' actually has 7 characters. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "shutil.SameFileError.__bases__[0].__name__ == 'Error' (len 5): SameFileError directly inherits from shutil.Error. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "shutil.Error.__mro__ == [Error, OSError, Exception, BaseException, object] — len 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "shutil.SameFileError.__mro__ == [SameFileError, Error, OSError, Exception, BaseException, object] — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "shutil.SameFileError.__name__ == 'SameFileError' — len 13. shutil.Error.__name__ == 'Error' — len 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# shutil.__all__ — length and type
#
# No prior shutil spec checks __all__.__len__() or __all__.__class__.__name__.
# shutil exports 25 public names; __all__ is a plain Python list.
# ---------------------------------------------------------------------------

invariant shutil_extra23.all.len:
  description: "shutil.__all__.__len__() == 25 — shutil exports exactly 25 public names"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 25

invariant shutil_extra23.all.class_name_len:
  description: "shutil.__all__.__class__.__name__.__len__() == 4 — len('list') == 4"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# shutil.Error and shutil.SameFileError — __dict__.__class__.__name__.__len__()
#
# Class __dict__ objects in CPython are mappingproxy instances.
# len('mappingproxy') == 12. No prior shutil spec checks this for either class.
# ---------------------------------------------------------------------------

invariant shutil_extra23.Error.dict_class_name_len:
  description: "shutil.Error.__dict__.__class__.__name__.__len__() == 12 — len('mappingproxy') == 12"
  category: class_identity
  kind: python_call_eq
  function: Error.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant shutil_extra23.SameFileError.dict_class_name_len:
  description: "shutil.SameFileError.__dict__.__class__.__name__.__len__() == 12 — len('mappingproxy') == 12"
  category: class_identity
  kind: python_call_eq
  function: SameFileError.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# shutil.Error — inheritance and MRO
#
# shutil.Error inherits directly from OSError. No prior shutil spec checks
# Error.__bases__[0].__name__ or Error.__mro__.__len__(). The function value
# for __bases__[0] contains '[', so it must be quoted per ZSDL rules.
# ---------------------------------------------------------------------------

invariant shutil_extra23.Error.bases_name:
  description: "shutil.Error.__bases__[0].__name__ == 'OSError' — Error directly inherits from OSError"
  category: class_hierarchy
  kind: python_call_eq
  function: "Error.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant shutil_extra23.Error.mro_len:
  description: "shutil.Error.__mro__.__len__() == 5 — MRO: [Error, OSError, Exception, BaseException, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: Error.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# shutil.SameFileError — inheritance and MRO
#
# SameFileError inherits from shutil.Error (not directly from OSError).
# No prior shutil spec checks SameFileError.__bases__[0].__name__ or
# SameFileError.__mro__.__len__(). Function with '[' must be quoted.
# ---------------------------------------------------------------------------

invariant shutil_extra23.SameFileError.bases_name:
  description: "shutil.SameFileError.__bases__[0].__name__ == 'Error' — SameFileError directly inherits from shutil.Error"
  category: class_hierarchy
  kind: python_call_eq
  function: "SameFileError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true

invariant shutil_extra23.SameFileError.mro_len:
  description: "shutil.SameFileError.__mro__.__len__() == 6 — MRO: [SameFileError, Error, OSError, Exception, BaseException, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: SameFileError.__mro__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# shutil.SameFileError.__name__.__len__() and shutil.Error.__name__.__len__()
#
# No prior shutil spec checks __name__.__len__() for either exception class.
# SameFileError.__name__ == 'SameFileError' (len 13);
# Error.__name__ == 'Error' (len 5).
# ---------------------------------------------------------------------------

invariant shutil_extra23.SameFileError.name_len:
  description: "shutil.SameFileError.__name__.__len__() == 13 — 'SameFileError' has 13 characters"
  category: class_identity
  kind: python_call_eq
  function: SameFileError.__name__.__len__
  args: []
  expected: 13

invariant shutil_extra23.Error.name_len:
  description: "shutil.Error.__name__.__len__() == 5 — 'Error' has 5 characters"
  category: class_identity
  kind: python_call_eq
  function: Error.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# Table: exception class hierarchy properties — Error and SameFileError
#
# Groups __dict__.__class__.__name__.__len__(), __mro__.__len__(), and
# __name__.__len__() for both shutil exception classes. All are novel.
# ---------------------------------------------------------------------------

table shutil_extra23.exception_class_properties:
  description: "shutil.Error and SameFileError __dict__/__mro__/__name__ length checks — novel invariants"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: sle23

  columns: [id, function, args, expected]
  rows:
    - [Error_dict_len,          Error.__dict__.__class__.__name__.__len__,      [], 12]
    - [SameFileError_dict_len,  SameFileError.__dict__.__class__.__name__.__len__, [], 12]
    - [Error_mro_len,           Error.__mro__.__len__,                          [], 5]
    - [SameFileError_mro_len,   SameFileError.__mro__.__len__,                  [], 6]
    - [Error_name_len,          Error.__name__.__len__,                         [], 5]
    - [SameFileError_name_len,  SameFileError.__name__.__len__,                 [], 13]
