invariant multiprocessing_extra139.spec_name_len_15:
  description: "multiprocessing.__spec__.name.__len__() == 15 — multiprocessing.__spec__.name is 'multiprocessing' (15 chars); __package__ also 'multiprocessing' (len=15); __spec__.__class__.__name__=='ModuleSpec' (len=10); name len (15) equals multiprocessing.process module string 'multiprocessing.process' minus '.process' (7+1=8); NEW in extra139: first standalone multiprocessing spec name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.__spec__.name.__len__
  args: []
  expected: 15

invariant multiprocessing_extra139.base_process_name_len_11:
  description: "multiprocessing.process.BaseProcess.__name__.__len__() == 11 — BaseProcess.__name__ is 'BaseProcess' (11 chars: 'Base'=4+'Process'=7=11); BaseProcess.__module__=='multiprocessing.process' (len=23); BaseProcess.__init__ co_argcount==6; co_varnames.__len__()==8; name len (11) is 4 more than Pool name len (4) and equal to multiprocessing.connection.Connection len (10) plus 1; NEW in extra139: first standalone BaseProcess name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.process.BaseProcess.__name__.__len__
  args: []
  expected: 11

invariant multiprocessing_extra139.pool_module_len_20:
  description: "multiprocessing.pool.Pool.__module__.__len__() == 20 — Pool.__module__ is 'multiprocessing.pool' (20 chars: 'multiprocessing'=15+'.'=1+'pool'=4=20); distinct from 'multiprocessing.queues' (len=22) and 'multiprocessing.process' (len=23); Pool.__name__=='Pool' (len=4, shortest class name in this spec); Pool.__init__ co_argcount==6; co_varnames.__len__()==8; NEW in extra139: first standalone Pool module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__module__.__len__
  args: []
  expected: 20

invariant multiprocessing_extra139.queues_module_len_22:
  description: "multiprocessing.queues.Queue.__module__.__len__() == 22 — Queue.__module__ is 'multiprocessing.queues' (22 chars: 'multiprocessing'=15+'.'=1+'queues'=6=22); distinct from asyncio.queues (len=14) and multiprocessing.pool (len=20); Queue.__init__ co_argcount==2; co_varnames.__len__()==3 (adds 'ctx' for multiprocessing context); NEW in extra139: first standalone multiprocessing.queues module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.queues.Queue.__module__.__len__
  args: []
  expected: 22

invariant multiprocessing_extra139.pool_init_co_varnames_len_8:
  description: "multiprocessing.pool.Pool.__init__.__code__.co_varnames.__len__() == 8 — Pool.__init__.__code__.co_varnames is ('self','processes','initializer','initargs','maxtasksperchild','context','p','sentinels') (len=8); co_argcount==6 ('self','processes','initializer','initargs','maxtasksperchild','context'); 'p' and 'sentinels' are locals; same co_varnames len as BaseProcess.__init__ (also len=8); NEW in extra139: first standalone Pool.__init__ co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__init__.__code__.co_varnames.__len__
  args: []
  expected: 8
