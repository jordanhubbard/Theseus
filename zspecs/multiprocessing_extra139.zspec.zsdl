table multiprocessing_extra139.spec_metadata:
  description: "multiprocessing module spec metadata checks — __spec__.__class__.__name__.__eq__('ModuleSpec')==True (len=10: 'Module'=6+'Spec'=4=10); __spec__.name.__eq__('multiprocessing')==True (len=15: 'multiprocessing'=15); __package__.__eq__('multiprocessing')==True (len=15: same as spec name for this top-level package); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpspec139

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_eq,   multiprocessing.__spec__.__class__.__name__.__eq__,  ["ModuleSpec"],       true,  "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec' (len=10); verified with Python 3.14.3"]
    - [spec_cls_len,  multiprocessing.__spec__.__class__.__name__.__len__,  [],                  10,    "multiprocessing.__spec__.__class__.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [spec_name_eq,  multiprocessing.__spec__.name.__eq__,                ["multiprocessing"],  true,  "multiprocessing.__spec__.name == 'multiprocessing' (len=15); verified with Python 3.14.3"]
    - [spec_name_len, multiprocessing.__spec__.name.__len__,                [],                  15,    "multiprocessing.__spec__.name.__len__() == 15; verified with Python 3.14.3"]
    - [pkg_eq,        multiprocessing.__package__.__eq__,                  ["multiprocessing"],  true,  "multiprocessing.__package__ == 'multiprocessing' (len=15); verified with Python 3.14.3"]

