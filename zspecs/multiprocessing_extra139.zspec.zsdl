spec: multiprocessing_extra139
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#the-process-class — multiprocessing.Process documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py, Lib/multiprocessing/pool.py, Lib/multiprocessing/queues.py"
  notes:
    - "This spec covers: multiprocessing.__spec__.__class__.__name__=='ModuleSpec' (len=10); __spec__.name=='multiprocessing' (len=15); __package__=='multiprocessing' (len=15). multiprocessing.process.BaseProcess — __name__=='BaseProcess' (len=11), __module__=='multiprocessing.process' (len=23); BaseProcess.__init__ co_argcount==6, co_varnames.__len__()==8; BaseProcess.start co_argcount==1, co_varnames.__len__()==1; BaseProcess.run co_argcount==1, co_varnames.__len__()==1. multiprocessing.pool.Pool — __name__=='Pool' (len=4), __module__=='multiprocessing.pool' (len=20); Pool.__init__ co_argcount==6, co_varnames.__len__()==8; Pool.map co_argcount==4, co_varnames.__len__()==4; Pool.map_async co_argcount==6, co_varnames.__len__()==6. multiprocessing.queues.Queue — __name__=='Queue' (len=5), __module__=='multiprocessing.queues' (len=22); Queue.__init__ co_argcount==2, co_varnames.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.process.BaseProcess.__module__=='multiprocessing.process' (len=23: 'multiprocessing'=15+'.'=1+'process'=7=23); BaseProcess.__init__ co_varnames==('self','group','target','name','args','kwargs','daemon','count') (len=8); co_argcount==6 ('self','group','target','name','args','kwargs'). BaseProcess.start.__qualname__=='BaseProcess.start' (len=17); co_varnames==('self',) (len=1). Pool.__module__=='multiprocessing.pool' (len=20); Pool.__init__ co_varnames==('self','processes','initializer','initargs','maxtasksperchild','context','p','sentinels') (len=8); co_argcount==6. Pool.map co_varnames==('self','func','iterable','chunksize') (len=4). Pool.map_async co_varnames==('self','func','iterable','chunksize','callback','error_callback') (len=6). multiprocessing.queues.Queue.__module__=='multiprocessing.queues' (len=22); Queue.__init__ co_varnames==('self','maxsize','ctx') (len=3); co_argcount==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

