# ---------------------------------------------------------------------------
# Standalone invariants — extra95
# ---------------------------------------------------------------------------

invariant asyncio_extra95.Lock_acquire_qualname_eq:
  description: "asyncio.Lock.acquire.__qualname__.__eq__('Lock.acquire') returns True — Lock.acquire is a coroutine method defined directly on Lock; its qualified name uses the simple 'ClassName.method' pattern; __qualname__ length is 12; NEW in extra95: first standalone __qualname__.__eq__ invariant for Lock.acquire in asynciolocksmethods95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Lock.acquire.__qualname__.__eq__
  args: ["Lock.acquire"]
  expected: true

invariant asyncio_extra95.Lock_release_qualname_eq:
  description: "asyncio.Lock.release.__qualname__.__eq__('Lock.release') returns True — Lock.release is defined directly on Lock; its __qualname__ length equals Lock.acquire (both are 12 chars); NEW in extra95: first standalone __qualname__.__eq__ invariant for Lock.release in asynciolocksmethods95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Lock.release.__qualname__.__eq__
  args: ["Lock.release"]
  expected: true

invariant asyncio_extra95.Event_is_set_qualname_eq:
  description: "asyncio.Event.is_set.__qualname__.__eq__('Event.is_set') returns True — Event.is_set is the longest of the Event public methods (len=12), equal in length to Lock.acquire and Lock.release; the underscore in 'is_set' adds a char vs 'Event.set' (len=9); NEW in extra95: first standalone __qualname__.__eq__ invariant for Event.is_set in asynciolocksmethods95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Event.is_set.__qualname__.__eq__
  args: ["Event.is_set"]
  expected: true

invariant asyncio_extra95.Semaphore_acquire_qualname_eq:
  description: "asyncio.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') returns True — Semaphore.acquire is a coroutine method; its __qualname__ is 17 chars, making it the longest of the acquire methods across Lock (12), Event (no acquire), and Semaphore (17); NEW in extra95: first standalone __qualname__.__eq__ invariant for Semaphore.acquire in asynciolocksmethods95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true

invariant asyncio_extra95.Condition_notify_all_qualname_eq:
  description: "asyncio.Condition.notify_all.__qualname__.__eq__('Condition.notify_all') returns True — Condition.notify_all has the longest __qualname__ of all Condition public methods (len=20); it is longer than Condition.notify (16), Condition.wait_for (18), and Condition.wait (14); NEW in extra95: first standalone __qualname__.__eq__ invariant for Condition.notify_all in asynciolocksmethods95 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Condition.notify_all.__qualname__.__eq__
  args: ["Condition.notify_all"]
  expected: true
