spec: asyncio_extra95
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra94

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra94.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio Lock, Event, Semaphore, and Condition method __qualname__ lengths. NEW in extra95: Lock.acquire.__qualname__ len==12; Lock.release.__qualname__ len==12; Lock.locked.__qualname__ len==11; Event.set.__qualname__ len==9; Event.clear.__qualname__ len==11; Event.wait.__qualname__ len==10; Event.is_set.__qualname__ len==12; Semaphore.acquire.__qualname__ len==17; Semaphore.release.__qualname__ len==17; Semaphore.locked.__qualname__ len==16; Condition.wait.__qualname__ len==14; Condition.wait_for.__qualname__ len==18; Condition.notify.__qualname__ len==16; Condition.notify_all.__qualname__ len==20. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire' (len=12). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.release.__qualname__ == 'Lock.release' (len=12). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.locked.__qualname__ == 'Lock.locked' (len=11). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.set.__qualname__ == 'Event.set' (len=9). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.clear.__qualname__ == 'Event.clear' (len=11). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.wait.__qualname__ == 'Event.wait' (len=10). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.is_set.__qualname__ == 'Event.is_set' (len=12). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len=17). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.release.__qualname__ == 'Semaphore.release' (len=17). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.locked.__qualname__ == 'Semaphore.locked' (len=16). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.wait.__qualname__ == 'Condition.wait' (len=14). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.wait_for.__qualname__ == 'Condition.wait_for' (len=18). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.notify.__qualname__ == 'Condition.notify' (len=16). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Lock method __qualname__ lengths — extra95
#
# Wave 254 theme: asyncio Lock, Event, Semaphore, Condition method __qualname__ lengths.
#
# Lock.acquire.__qualname__.__len__() == 12
# Lock.release.__qualname__.__len__() == 12
# Lock.locked.__qualname__.__len__() == 11
# ---------------------------------------------------------------------------

table asyncio_extra95.lock_method_qualname_lengths:
  description: "asyncio Lock method __qualname__ length checks in asynciolocksmethods95 namespace — wave 254 theme: asyncio synchronization primitive method qualnames; Lock.acquire.__qualname__.__len__()==12 ('Lock.acquire'); Lock.release.__qualname__.__len__()==12 ('Lock.release'); Lock.locked.__qualname__.__len__()==11 ('Lock.locked'); lengths derived from 'Lock.' prefix (5 chars) plus method name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolocksmethods95

  columns: [id, function, args, expected, description]
  rows:
    - [lock_acquire_len, Lock.acquire.__qualname__.__len__, [], 12, "Lock.acquire.__qualname__.__len__() == 12 — qualname is 'Lock.acquire'; verified with Python 3.14.3"]
    - [lock_release_len, Lock.release.__qualname__.__len__, [], 12, "Lock.release.__qualname__.__len__() == 12 — qualname is 'Lock.release'; verified with Python 3.14.3"]
    - [lock_locked_len,  Lock.locked.__qualname__.__len__,  [], 11, "Lock.locked.__qualname__.__len__() == 11 — qualname is 'Lock.locked'; verified with Python 3.14.3"]

