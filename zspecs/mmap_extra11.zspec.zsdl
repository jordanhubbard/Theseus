spec: mmap_extra11
version: ">=3.9"
backend: python_module(mmap)

docs: https://docs.python.org/3/library/mmap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mmap.html — Python mmap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mmapmodule.c"
    - "mmap.zspec.zsdl — ACCESS_READ/WRITE/COPY values; PAGESIZE/ALLOCATIONGRANULARITY positivity; mmap.__name__."
    - "mmap_extra.zspec.zsdl through mmap_extra10.zspec.zsdl — prior extras."
  notes:
    - "This spec extends mmap.zspec.zsdl through mmap_extra10.zspec.zsdl."
    - "mmap_extra3 covers __qualname__ for: seek, tell, close, find, flush."
    - "mmap_extra4 covers __qualname__ for: read, write, rfind, readline, read_byte, write_byte, move."
    - "mmap_extra5 covers __qualname__ for: resize."
    - "mmap_extra8 covers __name__ for: madvise (but not __qualname__)."
    - "No prior mmap spec checks __qualname__ for: size, seekable, madvise, closed."
    - "This spec adds NEW axes:"
    - "  (1) mmap.mmap.size.__qualname__ == 'mmap.size' — C slot wrapper for the size method."
    - "  (2) mmap.mmap.seekable.__qualname__ == 'mmap.seekable' — C slot wrapper for seekable."
    - "  (3) mmap.mmap.madvise.__qualname__ == 'mmap.madvise' — C slot wrapper for madvise."
    - "  (4) mmap.mmap.closed.__qualname__ == 'mmap.closed' — getset_descriptor for the closed property."
    - "mmap.mmap.size.__qualname__ == 'mmap.size' — Verified Python 3.12 macOS."
    - "mmap.mmap.seekable.__qualname__ == 'mmap.seekable' — Verified."
    - "mmap.mmap.madvise.__qualname__ == 'mmap.madvise' — Verified."
    - "mmap.mmap.closed.__qualname__ == 'mmap.closed' — Verified (getset_descriptor has __qualname__)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mmap method __qualname__ — remaining methods not covered in any prior spec
#
# Coverage summary of prior specs:
#   mmap_extra3: seek, tell, close, find, flush
#   mmap_extra4: read, write, rfind, readline, read_byte, write_byte, move
#   mmap_extra5: resize
#   mmap_extra8: madvise.__name__ (not __qualname__)
#
# Remaining: size, seekable, madvise (qualname), closed (property descriptor).
# For C slot wrappers on mmap, __qualname__ is 'mmap.<method>'.
# closed is a getset_descriptor (property); it also has __qualname__ == 'mmap.closed'.
# ---------------------------------------------------------------------------

table mmap_extra11.mmap.method_qualnames_remaining:
  description: "mmap.mmap method __qualname__ attributes not covered in any prior mmap spec"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mmq11

  columns: [id, function, args, expected]
  rows:
    - [size,     mmap.size.__qualname__.__eq__,     ["mmap.size"],     true]
    - [seekable, mmap.seekable.__qualname__.__eq__,  ["mmap.seekable"], true]
    - [madvise,  mmap.madvise.__qualname__.__eq__,   ["mmap.madvise"],  true]
    - [closed,   mmap.closed.__qualname__.__eq__,   ["mmap.closed"],   true]
