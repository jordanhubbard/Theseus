spec: concurrent_futures_extra24
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra23.zspec.zsdl."
    - "concurrent_futures_extra23 covers: Executor __qualname__ and __module__; ThreadPoolExecutor/ProcessPoolExecutor __bases__[0].__name__ (Executor); CancelledError/TimeoutError __qualname__; Future.__module__."
    - "concurrent_futures_extra9 covers: InvalidStateError __qualname__, __module__, and __bases__[0].__name__ (Error); Future method names (cancelled/running/done/exception/set_result)."
    - "concurrent_futures_extra8 covers: FIRST_COMPLETED/__len__ (15); FIRST_EXCEPTION/__len__ (15); ALL_COMPLETED/__len__ (13); as_completed/wait __class__.__name__ (function)."
    - "concurrent_futures_extra6 covers: as_completed/wait __qualname__; FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED __class__.__name__ (str)."
    - "NOT yet covered in any prior spec: concurrent.futures.CancelledError.__bases__[0].__name__ in extra24 namespace."
    - "NOT yet covered: concurrent.futures.TimeoutError.__bases__[0].__name__ in extra24 namespace."
    - "NOT yet covered: concurrent.futures.BrokenExecutor.__bases__[0].__name__ in extra24 namespace."
    - "NOT yet covered: concurrent.futures.InvalidStateError.__bases__[0].__name__ in extra24 namespace."
    - "NOT yet covered: concurrent.futures.thread.__name__ in extra24 namespace."
    - "NOT yet covered: concurrent.futures.process.__name__ in extra24 namespace."
    - "NOT yet covered: FIRST_COMPLETED value string eq in extra24 namespace."
    - "NOT yet covered: FIRST_EXCEPTION value string eq in extra24 namespace."
    - "NOT yet covered: ALL_COMPLETED value string eq in extra24 namespace."
    - "NOT yet covered: as_completed.__name__ string eq in extra24 namespace."
    - "NOT yet covered: wait.__name__ string eq in extra24 namespace."
    - "CancelledError.__bases__[0].__name__ == 'Error' — CancelledError inherits from the internal _base.Error class (length 5)."
    - "TimeoutError.__bases__[0].__name__ == 'OSError' — concurrent.futures.TimeoutError is the builtin TimeoutError, which inherits from OSError (length 7)."
    - "BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — BrokenExecutor directly inherits from RuntimeError (length 12)."
    - "InvalidStateError.__bases__[0].__name__ == 'Error' — InvalidStateError inherits from the internal _base.Error class (length 5)."
    - "concurrent.futures.thread.__name__ == 'concurrent.futures.thread' — fully-qualified submodule name (length 25)."
    - "concurrent.futures.process.__name__ == 'concurrent.futures.process' — fully-qualified submodule name (length 26)."
    - "FIRST_COMPLETED == 'FIRST_COMPLETED' — string sentinel value (length 15)."
    - "FIRST_EXCEPTION == 'FIRST_EXCEPTION' — string sentinel value (length 15)."
    - "ALL_COMPLETED == 'ALL_COMPLETED' — string sentinel value (length 13)."
    - "as_completed.__name__ == 'as_completed' — module-level iterator function (length 12)."
    - "wait.__name__ == 'wait' — module-level wait function (length 4)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class base names — extra24 namespace
#
# No prior spec checks __bases__[0].__name__ for CancelledError, TimeoutError,
# BrokenExecutor, or InvalidStateError in this namespace.
#   CancelledError → Error (internal _base.Error sentinel class)
#   TimeoutError   → OSError (concurrent.futures.TimeoutError is the builtin TimeoutError)
#   BrokenExecutor → RuntimeError (direct RuntimeError subclass)
#   InvalidStateError → Error (same internal _base.Error as CancelledError)
# ---------------------------------------------------------------------------

table concurrent_futures_extra24.exception_bases:
  description: "concurrent.futures exception class __bases__[0].__name__ values in extra24 namespace"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: excbase24

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [CancelledError,    CancelledError.__bases__.__getitem__,    [0], "Error",        __name__, [], "concurrent.futures.CancelledError.__bases__[0].__name__ == 'Error'"]
    - [TimeoutError,      TimeoutError.__bases__.__getitem__,      [0], "OSError",      __name__, [], "concurrent.futures.TimeoutError.__bases__[0].__name__ == 'OSError'"]
    - [BrokenExecutor,    BrokenExecutor.__bases__.__getitem__,    [0], "RuntimeError", __name__, [], "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"]
    - [InvalidStateError, InvalidStateError.__bases__.__getitem__, [0], "Error",        __name__, [], "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error'"]

# ---------------------------------------------------------------------------
# Module-level function __name__ table — extra24 namespace
#
# concurrent_futures_extra8 checks as_completed/wait via __class__.__name__.
# concurrent_futures_extra6 checks as_completed/wait via __qualname__.
# No prior spec checks as_completed.__name__ or wait.__name__ directly as
# string equality. This spec adds that axis.
# as_completed.__name__ == 'as_completed' (length 12).
# wait.__name__ == 'wait' (length 4).
# ---------------------------------------------------------------------------

table concurrent_futures_extra24.function_names:
  description: "concurrent.futures module-level function __name__ values in extra24 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: fname24

  columns: [id, function, args, expected]
  rows:
    - [as_completed, as_completed.__name__.__eq__, ["as_completed"], true]
    - [wait,         wait.__name__.__eq__,         ["wait"],         true]

# ---------------------------------------------------------------------------
# Wait constant value table — extra24 namespace
#
# concurrent_futures_extra8 checks FIRST_COMPLETED/__len__ (15),
# FIRST_EXCEPTION/__len__ (15), ALL_COMPLETED/__len__ (13).
# concurrent_futures_extra6 checks __class__.__name__ ('str') for each.
# No prior spec checks the actual string values via __eq__. This spec adds
# that direct equality check.
# ---------------------------------------------------------------------------

table concurrent_futures_extra24.wait_constants:
  description: "concurrent.futures wait constant string values in extra24 namespace"
  kind: python_call_eq
  category: constants
  id_prefix: wconst24

  columns: [id, function, args, expected]
  rows:
    - [FIRST_COMPLETED, FIRST_COMPLETED.__eq__, ["FIRST_COMPLETED"], true]
    - [FIRST_EXCEPTION, FIRST_EXCEPTION.__eq__, ["FIRST_EXCEPTION"], true]
    - [ALL_COMPLETED,   ALL_COMPLETED.__eq__,   ["ALL_COMPLETED"],   true]

# ---------------------------------------------------------------------------
# Submodule __name__ table — extra24 namespace
#
# concurrent.futures.thread and concurrent.futures.process are the two
# implementation submodules. Their __name__ attributes give their fully-
# qualified module names. No prior spec checks these values.
# thread.__name__ == 'concurrent.futures.thread' (length 25).
# process.__name__ == 'concurrent.futures.process' (length 26).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra24.thread_module_name:
  description: "concurrent.futures.thread.__name__ == 'concurrent.futures.thread' — submodule fully-qualified name"
  category: module_names
  kind: python_call_eq
  function: thread.__name__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra24.process_module_name:
  description: "concurrent.futures.process.__name__ == 'concurrent.futures.process' — submodule fully-qualified name"
  category: module_names
  kind: python_call_eq
  function: process.__name__.__eq__
  args: ["concurrent.futures.process"]
  expected: true
