spec: threading_extra34
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra33.zspec.zsdl."
    - "Prior specs covered: Thread.__name__/__module__/__qualname__ (identity), Lock/RLock/Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier class names/modules, Thread/__mro__.__len__() (2), BoundedSemaphore/__mro__.__len__() (3), class __mro__.__len__() for Event(2)/Timer(3)/Condition(2)/Barrier(2), Barrier/__bases__[0].__name__=='object'/Condition/__bases__[0].__name__=='object', TIMEOUT_MAX/__class__.__name__.__len__()==5, threading.__all__.__len__()==28, Semaphore/__mro__.__len__()==2, BoundedSemaphore/__bases__[0].__name__.__len__()==9, Barrier.wait/abort/reset __qualname__.__len__(), local/__qualname__/__mro__/__bases__[0].__name__ (table), class __dict__.__class__.__name__.__len__() for Thread/Event/Timer/Barrier/Condition/Semaphore/BoundedSemaphore/local/RLock."
    - "This spec covers: Thread.__name__.__len__() (6 — 'Thread'); Thread.__qualname__.__len__() (6 — 'Thread'); threading.Lock.__name__.__len__() (4 — surprisingly 'lock', lowercase); threading.RLock.__name__.__len__() (5 — 'RLock', factory function); Event.__name__.__len__() (5 — 'Event'); Event.__qualname__.__len__() (5 — 'Event'); Thread method __qualname__.__len__() for start(12)/run(10)/join(11)/is_alive(15); threading.__name__.__len__() (9 — 'threading'); threading.__spec__.__class__.__name__.__len__() (10 — 'ModuleSpec'); threading.__doc__.__class__.__name__.__len__() (3 — 'str'); threading.__loader__.__class__.__name__.__len__() (16 — 'SourceFileLoader')."
    - "Key findings: threading.Lock.__name__ is 'lock' (lowercase, 4 chars) — the underlying C type has a different name than the public Python alias. threading.RLock.__name__ is 'RLock' (5 chars) — RLock is a factory function (type 'function'), and its __name__ differs from what Lock does. Thread.is_alive.__qualname__ is 'Thread.is_alive' (15 chars) — the longest Thread method qualname. threading.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars) — threading is a pure-Python module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread.__name__/__qualname__ lengths and Lock/__RLock/__Event __name__ lengths table
#
# threading.Thread.__name__ is 'Thread' (6 chars). threading.Thread.__qualname__
# is also 'Thread' (6 chars). threading.Lock.__name__ is 'lock' (4 chars, lowercase)
# — the C extension type name differs from the public Python alias 'Lock'.
# threading.RLock.__name__ is 'RLock' (5 chars) — RLock is a factory function.
# threading.Event.__name__ is 'Event' (5 chars). threading.Event.__qualname__ is
# also 'Event' (5 chars). Prior specs confirmed Thread identity but not these
# __len__() values explicitly. No prior threading spec records these six values
# together in a combined table in the extra34 namespace.
# ---------------------------------------------------------------------------

table threading_extra34.core_class_name_lengths:
  description: "threading core class __name__/__qualname__ lengths for Thread/Lock/RLock/Event"
  kind: python_call_eq
  category: string_properties
  id_prefix: corenamelen34

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_name,
       Thread.__name__.__len__,
       [],
       6,
       "len(threading.Thread.__name__) == 6 — 'Thread'"]
    - [Thread_qualname,
       Thread.__qualname__.__len__,
       [],
       6,
       "len(threading.Thread.__qualname__) == 6 — 'Thread' (not a nested class)"]
    - [Lock_name,
       threading.Lock.__name__.__len__,
       [],
       4,
       "len(threading.Lock.__name__) == 4 — 'lock' (lowercase C type name, not 'Lock')"]
    - [RLock_name,
       threading.RLock.__name__.__len__,
       [],
       5,
       "len(threading.RLock.__name__) == 5 — 'RLock' (factory function, not a class)"]
    - [Event_name,
       Event.__name__.__len__,
       [],
       5,
       "len(threading.Event.__name__) == 5 — 'Event'"]
    - [Event_qualname,
       Event.__qualname__.__len__,
       [],
       5,
       "len(threading.Event.__qualname__) == 5 — 'Event' (not a nested class)"]

# ---------------------------------------------------------------------------
# Thread method __qualname__.__len__() table — extra34 namespace
#
# threading.Thread.start.__qualname__ is 'Thread.start' (12 chars).
# threading.Thread.run.__qualname__ is 'Thread.run' (10 chars).
# threading.Thread.join.__qualname__ is 'Thread.join' (11 chars).
# threading.Thread.is_alive.__qualname__ is 'Thread.is_alive' (15 chars).
# Thread.is_alive is the longest method qualname because of the underscore in
# 'is_alive'. Prior specs covered Barrier.wait/abort/reset qualname lengths in
# extra33, and Thread/Event/Semaphore/Condition method qualnames in earlier specs,
# but Thread.start/run/join/is_alive qualname lengths were not explicitly recorded.
# No prior threading spec records these four values together in the extra34 namespace.
# ---------------------------------------------------------------------------

table threading_extra34.thread_method_qualname_lengths:
  description: "threading.Thread method __qualname__.__len__() for start/run/join/is_alive"
  kind: python_call_eq
  category: method_names
  id_prefix: threadmqualname34

  columns: [id, function, args, expected, description]
  rows:
    - [start,
       Thread.start.__qualname__.__len__,
       [],
       12,
       "len(threading.Thread.start.__qualname__) == 12 — 'Thread.start'"]
    - [run,
       Thread.run.__qualname__.__len__,
       [],
       10,
       "len(threading.Thread.run.__qualname__) == 10 — 'Thread.run'"]
    - [join,
       Thread.join.__qualname__.__len__,
       [],
       11,
       "len(threading.Thread.join.__qualname__) == 11 — 'Thread.join'"]
    - [is_alive,
       Thread.is_alive.__qualname__.__len__,
       [],
       15,
       "len(threading.Thread.is_alive.__qualname__) == 15 — 'Thread.is_alive'"]

# ---------------------------------------------------------------------------
# threading module metadata table — extra34 namespace
#
# threading.__name__ is 'threading' (9 chars). threading.__spec__.__class__.__name__
# is 'ModuleSpec' (10 chars) — same as for other pure-Python modules loaded by the
# import system. threading.__doc__.__class__.__name__ is 'str' (3 chars) — the module
# docstring is a plain Python string. threading.__loader__.__class__.__name__ is
# 'SourceFileLoader' (16 chars) — threading is a pure-Python module loaded from a
# .py file, unlike built-in C extension modules. No prior threading spec records
# these four module metadata values together in a combined table in the extra34 namespace.
# ---------------------------------------------------------------------------

table threading_extra34.module_metadata:
  description: "threading module metadata: __name__, __spec__.__class__.__name__, __doc__.__class__.__name__, __loader__.__class__.__name__ lengths"
  kind: python_call_eq
  category: module_metadata
  id_prefix: modmeta34

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_len,
       threading.__name__.__len__,
       [],
       9,
       "len(threading.__name__) == 9 — 'threading'"]
    - [spec_classname_len,
       threading.__spec__.__class__.__name__.__len__,
       [],
       10,
       "len(threading.__spec__.__class__.__name__) == 10 — 'ModuleSpec'"]
    - [doc_classname_len,
       threading.__doc__.__class__.__name__.__len__,
       [],
       3,
       "len(threading.__doc__.__class__.__name__) == 3 — module docstring is 'str'"]
    - [loader_classname_len,
       threading.__loader__.__class__.__name__.__len__,
       [],
       16,
       "len(threading.__loader__.__class__.__name__) == 16 — 'SourceFileLoader' (pure-Python module)"]

# ---------------------------------------------------------------------------
# threading.Lock.__name__.__len__() == 4 — standalone invariant
#
# threading.Lock.__name__ is 'lock' (lowercase, 4 chars). The public Python alias
# 'Lock' refers to the underlying C extension type _thread.lock, whose __name__
# is 'lock' — lowercase with no package qualifier. This is a notable discrepancy
# from the Python-level name 'Lock'. No prior threading spec records
# threading.Lock.__name__.__len__() as a standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra34.Lock_name_len:
  description: "len(threading.Lock.__name__) == 4 — Lock.__name__ is 'lock' (lowercase C type name, not 'Lock')"
  category: string_properties
  kind: python_call_eq
  function: threading.Lock.__name__.__len__
  args: []
  expected: 4
