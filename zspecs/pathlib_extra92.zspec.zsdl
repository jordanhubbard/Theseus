spec: pathlib_extra92
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra91."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for many methods; PurePath/__dict__ membership; Path/__dict__ membership; Path properties as descriptors; Path method co_name and co_argcount for open/read_text/write_text/iterdir/mkdir/rmdir/stat/lstat/exists/unlink/rename/resolve/absolute/expanduser; PurePath/__name__/__module__/__bases__/__mro__; PosixPath identity; Path.__init__/__new__ co_name and co_argcount; Path.is_dir/is_file/is_symlink/is_mount/is_absolute/is_relative_to/exists/samefile __code__ attributes; Path.__dict__.__contains__ for read_text/write_text/read_bytes/write_bytes/mkdir/iterdir/glob/exists/is_dir/stat; Path.__dict__.__class__.__name__; Path.__qualname__/__name__/__module__; PurePath.__dict__.__contains__ for __str__/__repr__/__eq__/__hash__/__lt__/__truediv__/parent/name/suffix/suffixes (all True); PurePath.__name__/__module__; Path.__bases__[0].__name__ == 'PurePath'; Path.__mro__.__len__() == 3; PurePosixPath/PureWindowsPath __bases__/__mro__; PosixPath.__bases__[0].__name__ == 'Path'; PosixPath.__mro__.__len__() == 5; Path/PurePath/PosixPath __qualname__ equality."
    - "This spec covers: pathlib.Path.glob.__code__.co_name == 'glob' and co_argcount == 2; pathlib.Path.rglob.__code__.co_name == 'rglob' and co_argcount == 2; pathlib.Path.walk.__code__.co_name == 'walk' and co_argcount == 4; pathlib.Path.match.__code__.co_name == 'match' and co_argcount == 2; pathlib.Path.relative_to.__code__.co_name == 'relative_to' and co_argcount == 2; pathlib.Path.with_name.__code__.co_name == 'with_name' and co_argcount == 2; pathlib.Path.with_suffix.__code__.co_name == 'with_suffix' and co_argcount == 2."
    - "pathlib.Path.glob.__code__.co_name == 'glob' — verified on Python 3.14.3 macOS."
    - "pathlib.Path.glob.__code__.co_argcount == 2 — self + pattern (case_sensitive is keyword-only); verified on Python 3.14.3 macOS."
    - "pathlib.Path.rglob.__code__.co_name == 'rglob' — verified on Python 3.14.3 macOS."
    - "pathlib.Path.rglob.__code__.co_argcount == 2 — self + pattern (case_sensitive is keyword-only); verified on Python 3.14.3 macOS."
    - "pathlib.Path.walk.__code__.co_name == 'walk' — verified on Python 3.14.3 macOS."
    - "pathlib.Path.walk.__code__.co_argcount == 4 — self + top_down + on_error + follow_symlinks; verified on Python 3.14.3 macOS."
    - "pathlib.Path.match.__code__.co_name == 'match' — verified on Python 3.14.3 macOS."
    - "pathlib.Path.match.__code__.co_argcount == 2 — self + pattern (case_sensitive is keyword-only); verified on Python 3.14.3 macOS."
    - "pathlib.Path.relative_to.__code__.co_name == 'relative_to' — verified on Python 3.14.3 macOS."
    - "pathlib.Path.relative_to.__code__.co_argcount == 2 — self + other (walk_up is keyword-only); verified on Python 3.14.3 macOS."
    - "pathlib.Path.with_name.__code__.co_name == 'with_name' — verified on Python 3.14.3 macOS."
    - "pathlib.Path.with_name.__code__.co_argcount == 2 — self + name; verified on Python 3.14.3 macOS."
    - "pathlib.Path.with_suffix.__code__.co_name == 'with_suffix' — verified on Python 3.14.3 macOS."
    - "pathlib.Path.with_suffix.__code__.co_argcount == 2 — self + suffix; verified on Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.glob and rglob __code__ attributes: co_name, co_argcount
# glob(self, pattern, *, case_sensitive=None) -> co_argcount == 2 (kw-only excluded)
# rglob(self, pattern, *, case_sensitive=None) -> co_argcount == 2
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra92.Path_glob_rglob_code:
  description: "pathlib.Path.glob/rglob __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attr
  id_prefix: pathlibextra92

  columns: [id, function, args, expected]
  rows:
    - [glob_coname,    "Path.glob.__code__.co_name.__eq__",     ["glob"],  true]
    - [glob_coargc,    "Path.glob.__code__.co_argcount.__eq__", [2],       true]
    - [rglob_coname,   "Path.rglob.__code__.co_name.__eq__",    ["rglob"], true]
    - [rglob_coargc,   "Path.rglob.__code__.co_argcount.__eq__", [2],      true]

# ---------------------------------------------------------------------------
# pathlib.Path.walk __code__ attributes: co_name, co_argcount
# walk(self, top_down=True, on_error=None, follow_symlinks=False) -> co_argcount == 4
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra92.Path_walk_code:
  description: "pathlib.Path.walk __code__.co_name == 'walk' and co_argcount == 4"
  kind: python_call_eq
  category: code_attr
  id_prefix: pathlibextra92

  columns: [id, function, args, expected]
  rows:
    - [walk_coname,  "Path.walk.__code__.co_name.__eq__",     ["walk"], true]
    - [walk_coargc,  "Path.walk.__code__.co_argcount.__eq__", [4],      true]

# ---------------------------------------------------------------------------
# pathlib.Path.match and relative_to __code__ attributes: co_name, co_argcount
# match(self, pattern, *, case_sensitive=None) -> co_argcount == 2
# relative_to(self, other, *, walk_up=False) -> co_argcount == 2
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra92.Path_match_relative_to_code:
  description: "pathlib.Path.match/relative_to __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attr
  id_prefix: pathlibextra92

  columns: [id, function, args, expected]
  rows:
    - [match_coname,       "Path.match.__code__.co_name.__eq__",          ["match"],       true]
    - [match_coargc,       "Path.match.__code__.co_argcount.__eq__",      [2],             true]
    - [rel_coname,         "Path.relative_to.__code__.co_name.__eq__",    ["relative_to"], true]
    - [rel_coargc,         "Path.relative_to.__code__.co_argcount.__eq__", [2],            true]

# ---------------------------------------------------------------------------
# pathlib.Path.with_name and with_suffix __code__ attributes: co_name, co_argcount
# with_name(self, name) -> co_argcount == 2
# with_suffix(self, suffix) -> co_argcount == 2
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra92.Path_with_name_suffix_code:
  description: "pathlib.Path.with_name/with_suffix __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attr
  id_prefix: pathlibextra92

  columns: [id, function, args, expected]
  rows:
    - [wname_coname,   "Path.with_name.__code__.co_name.__eq__",      ["with_name"],   true]
    - [wname_coargc,   "Path.with_name.__code__.co_argcount.__eq__",  [2],             true]
    - [wsuffix_coname, "Path.with_suffix.__code__.co_name.__eq__",    ["with_suffix"], true]
    - [wsuffix_coargc, "Path.with_suffix.__code__.co_argcount.__eq__", [2],            true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra92.Path.glob_co_name:
  description: "pathlib.Path.glob.__code__.co_name == 'glob' (verified on Python 3.14.3 macOS)"
  category: code_attr
  kind: python_call_eq
  function: "Path.glob.__code__.co_name.__eq__"
  args: ["glob"]
  expected: true

invariant pathlib_extra92.Path.glob_co_argcount:
  description: "pathlib.Path.glob.__code__.co_argcount == 2 (self + pattern; case_sensitive is keyword-only)"
  category: code_attr
  kind: python_call_eq
  function: "Path.glob.__code__.co_argcount.__eq__"
  args: [2]
  expected: true

invariant pathlib_extra92.Path.walk_co_argcount:
  description: "pathlib.Path.walk.__code__.co_argcount == 4 (self + top_down + on_error + follow_symlinks)"
  category: code_attr
  kind: python_call_eq
  function: "Path.walk.__code__.co_argcount.__eq__"
  args: [4]
  expected: true

invariant pathlib_extra92.Path.with_name_co_name:
  description: "pathlib.Path.with_name.__code__.co_name == 'with_name' (verified on Python 3.14.3 macOS)"
  category: code_attr
  kind: python_call_eq
  function: "Path.with_name.__code__.co_name.__eq__"
  args: ["with_name"]
  expected: true

invariant pathlib_extra92.Path.with_suffix_co_name:
  description: "pathlib.Path.with_suffix.__code__.co_name == 'with_suffix' (verified on Python 3.14.3 macOS)"
  category: code_attr
  kind: python_call_eq
  function: "Path.with_suffix.__code__.co_name.__eq__"
  args: ["with_suffix"]
  expected: true
