spec: theseus_importlib_cr
version: ">=3.0"
backend: python_cleanroom(theseus_importlib_cr)
blocks: importlib

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/importlib.html"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
  notes:
    - "Clean-room importlib module. Do NOT import importlib."

error_model: python_exceptions

invariant theseus_importlib_cr.importlib2_import:
  description: "import_module() imports a stdlib module"
  category: behavior
  kind: python_call_eq
  function: importlib2_import
  args: []
  expected: true

invariant theseus_importlib_cr.importlib2_invalidate:
  description: "invalidate_caches() runs without error"
  category: behavior
  kind: python_call_eq
  function: importlib2_invalidate
  args: []
  expected: true

invariant theseus_importlib_cr.importlib2_reload:
  description: "reload() can reload an already-imported module"
  category: behavior
  kind: python_call_eq
  function: importlib2_reload
  args: []
  expected: true
