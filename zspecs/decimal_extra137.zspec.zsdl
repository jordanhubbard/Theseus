spec: decimal_extra137
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal arithmetic wrapper_descriptor identity (__add__, __sub__, __mul__, __truediv__, __mod__, __pow__, __floordiv__, __divmod__, __radd__, __rsub__, __rmul__), decimal.Context method_descriptor qualnames (create_decimal, sqrt, exp, ln, log10, clear_flags, copy, add, subtract, multiply, divide), and decimal exception class identity (DecimalException, InvalidOperation, DivisionByZero, Overflow)."
    - "Decimal arithmetic operators are all wrapper_descriptor (C slot wrappers), same as comparison/unary operators in prior specs."
    - "Decimal.__add__/__sub__/__mul__/__mod__/__pow__ qualnames all have length 15."
    - "Decimal.__truediv__ qualname length == 19; __floordiv__ length == 20; __divmod__ length == 18."
    - "Decimal.__radd__/__rsub__/__rmul__ qualnames all have length 16 (reflected operators)."
    - "Context.create_decimal.__qualname__ == 'Context.create_decimal' (22); the longest Context method qualname covered."
    - "decimal.DecimalException.__name__ == 'DecimalException' (16); __bases__[0].__name__ == 'ArithmeticError'; MRO length == 5."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation' (16); MRO length == 6."
    - "decimal.DivisionByZero.__name__ == 'DivisionByZero' (14); MRO length == 7 (longest in the exception hierarchy)."
    - "decimal.Overflow.__name__ == 'Overflow' (8); __bases__ == ['Inexact', 'Rounded'] (multiple inheritance); MRO length == 8."
    - "Note: DecimalException, InvalidOperation, DivisionByZero, Overflow all have __doc__ == None."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal arithmetic wrapper_descriptor identity
# __add__, __sub__, __mul__, __mod__, __pow__ are wrapper_descriptor.
# All five have qualname length 15 ('Decimal.__XXX__').
# __truediv__ qualname length == 19; __floordiv__ == 20; __divmod__ == 18.
# ---------------------------------------------------------------------------

