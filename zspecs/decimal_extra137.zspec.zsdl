# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra137.Decimal.__floordiv__is_wrapper_descriptor:
  description: "decimal.Decimal.__floordiv__.__class__.__name__ == 'wrapper_descriptor' (floor division is a C slot wrapper via nb_floor_divide; Decimal.__floordiv__ implements floor division consistent with the IEEE 754 decimal arithmetic standard)"
  category: wrapper_descriptor
  kind: python_call_eq
  function: "Decimal.__floordiv__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra137.Decimal.__floordiv__qualname_len_20:
  description: "decimal.Decimal.__floordiv__.__qualname__.__len__() == 20 ('Decimal.__floordiv__' has 20 characters; the longest qualname among Decimal arithmetic operator slot wrappers — one more than __truediv__ (19))"
  category: wrapper_descriptor
  kind: python_call_eq
  function: "Decimal.__floordiv__.__qualname__.__len__"
  args: []
  expected: 20

invariant decimal_extra137.Decimal.__radd__qualname_len_16:
  description: "decimal.Decimal.__radd__.__qualname__.__len__() == 16 ('Decimal.__radd__' has 16 characters; all three reflected operators __radd__, __rsub__, __rmul__ share this length — one more than the forward operators __add__/__sub__/__mul__ (15 each))"
  category: wrapper_descriptor
  kind: python_call_eq
  function: "Decimal.__radd__.__qualname__.__len__"
  args: []
  expected: 16

invariant decimal_extra137.Context.create_decimal_qualname_len_22:
  description: "decimal.Context.create_decimal.__qualname__.__len__() == 22 ('Context.create_decimal' has 22 characters; the longest qualname among the covered Context methods — create_decimal creates a new Decimal from various input types using the context's precision and rounding)"
  category: method_descriptor
  kind: python_call_eq
  function: Context.create_decimal.__qualname__.__len__
  args: []
  expected: 22

invariant decimal_extra137.DecimalException.mro_len_5:
  description: "decimal.DecimalException.__mro__.__len__() == 5 (MRO is: DecimalException, ArithmeticError, Exception, BaseException, object; the root of the decimal exception hierarchy sits 4 levels above object)"
  category: class_identity
  kind: python_call_eq
  function: "DecimalException.__mro__.__len__"
  args: []
  expected: 5

invariant decimal_extra137.Overflow.mro_len_8:
  description: "decimal.Overflow.__mro__.__len__() == 8 (the deepest MRO in the decimal exception hierarchy; Overflow inherits from both Inexact and Rounded, merging two chains: Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object)"
  category: class_identity
  kind: python_call_eq
  function: "Overflow.__mro__.__len__"
  args: []
  expected: 8

invariant decimal_extra137.Context.ln_qualname_len_10:
  description: "decimal.Context.ln.__qualname__.__len__() == 10 ('Context.ln' has 10 characters; the shortest qualname among the Context transcendental methods — shorter than exp (11), log10 (13), sqrt (12), because 'ln' is the shortest method name)"
  category: method_descriptor
  kind: python_call_eq
  function: Context.ln.__qualname__.__len__
  args: []
  expected: 10

