invariant asyncio_extra147.tasks_name_len_13:
  description: "asyncio.tasks.__name__.__len__() == 13 — asyncio.tasks.__name__ is 'asyncio.tasks' (13 chars: 'asyncio'=7+'.'=1+'tasks'=5=13); this ties with asyncio.locks.__name__.__len__()==13 for shortest submodule name in this spec; the two longest are asyncio.futures and asyncio.streams at 15 each; asyncio.queues and asyncio.events are mid-length at 14; asyncio.tasks.__package__=='asyncio' (len=7); asyncio.tasks.__spec__.name=='asyncio.tasks' (same as __name__); NEW in extra147: first standalone asyncio.tasks __name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.tasks.__name__.__len__
  args: []
  expected: 13

