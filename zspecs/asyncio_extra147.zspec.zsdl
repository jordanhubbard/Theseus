spec: asyncio_extra147
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio tasks documentation"
    - "https://docs.python.org/3/library/asyncio-future.html — asyncio futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py, Lib/asyncio/futures.py, Lib/asyncio/queues.py, Lib/asyncio/streams.py, Lib/asyncio/locks.py, Lib/asyncio/events.py"
  notes:
    - "This spec covers asyncio submodule __name__ attributes. asyncio.tasks.__name__=='asyncio.tasks' (len=13: 'asyncio'=7+'.'=1+'tasks'=5=13). asyncio.futures.__name__=='asyncio.futures' (len=15: 'asyncio'=7+'.'=1+'futures'=7=15). asyncio.queues.__name__=='asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14). asyncio.streams.__name__=='asyncio.streams' (len=15: tied with asyncio.futures at len=15). asyncio.locks.__name__=='asyncio.locks' (len=13: tied with asyncio.tasks at len=13). asyncio.events.__name__=='asyncio.events' (len=14: tied with asyncio.queues at len=14). All submodules share __package__=='asyncio' (len=7). All use SourceFileLoader. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.futures and asyncio.streams are the longest submodule names (len=15). asyncio.tasks and asyncio.locks are the shortest (len=13). asyncio.queues and asyncio.events are mid-length (len=14). All __package__ values are 'asyncio' (len=7). All __spec__.name values equal the corresponding __name__ values. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio submodule __name__ attributes — extra147
#
# asyncio.tasks.__name__   == 'asyncio.tasks'   (len=13)
# asyncio.futures.__name__ == 'asyncio.futures' (len=15)
# asyncio.queues.__name__  == 'asyncio.queues'  (len=14)
# asyncio.streams.__name__ == 'asyncio.streams' (len=15)
# asyncio.locks.__name__   == 'asyncio.locks'   (len=13)
# asyncio.events.__name__  == 'asyncio.events'  (len=14)
# ---------------------------------------------------------------------------

table asyncio_extra147.submodule_names_tasks_futures_queues:
  description: "asyncio.tasks, asyncio.futures, and asyncio.queues __name__ attribute checks — tasks.__name__.__eq__('asyncio.tasks')==True (len=13: 'asyncio'=7+'.'=1+'tasks'=5=13; tied with asyncio.locks for shortest submodule name in this spec); tasks.__name__.__len__()==13; futures.__name__.__eq__('asyncio.futures')==True (len=15: 'asyncio'=7+'.'=1+'futures'=7=15; tied with asyncio.streams for longest submodule name in this spec); futures.__name__.__len__()==15; queues.__name__.__eq__('asyncio.queues')==True (len=14: 'asyncio'=7+'.'=1+'queues'=6=14; tied with asyncio.events); queues.__name__.__len__()==14; all three submodules share __package__=='asyncio' (len=7); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio_snm147a

  columns: [id, function, args, expected, description]
  rows:
    - [tasks_nm_eq,   asyncio.tasks.__name__.__eq__,    ["asyncio.tasks"],    true,  "asyncio.tasks.__name__ == 'asyncio.tasks' (len=13); verified with Python 3.14.3"]
    - [tasks_nm_len,  asyncio.tasks.__name__.__len__,    [],                   13,    "asyncio.tasks.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [tasks_pkg_eq,  asyncio.tasks.__package__.__eq__, ["asyncio"],           true,  "asyncio.tasks.__package__ == 'asyncio' (len=7); verified with Python 3.14.3"]
    - [tasks_pkg_len, asyncio.tasks.__package__.__len__, [],                   7,     "asyncio.tasks.__package__.__len__() == 7; verified with Python 3.14.3"]
    - [fut_nm_eq,     asyncio.futures.__name__.__eq__,  ["asyncio.futures"],  true,  "asyncio.futures.__name__ == 'asyncio.futures' (len=15); verified with Python 3.14.3"]
    - [fut_nm_len,    asyncio.futures.__name__.__len__,  [],                   15,    "asyncio.futures.__name__.__len__() == 15 (longest in this spec); verified with Python 3.14.3"]
    - [fut_pkg_eq,    asyncio.futures.__package__.__eq__, ["asyncio"],         true,  "asyncio.futures.__package__ == 'asyncio' (len=7); verified with Python 3.14.3"]
    - [que_nm_eq,     asyncio.queues.__name__.__eq__,   ["asyncio.queues"],   true,  "asyncio.queues.__name__ == 'asyncio.queues' (len=14); verified with Python 3.14.3"]
    - [que_nm_len,    asyncio.queues.__name__.__len__,   [],                   14,    "asyncio.queues.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [que_pkg_eq,    asyncio.queues.__package__.__eq__, ["asyncio"],          true,  "asyncio.queues.__package__ == 'asyncio' (len=7); verified with Python 3.14.3"]

