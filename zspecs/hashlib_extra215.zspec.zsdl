spec: hashlib_extra215
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All __doc__ contains checks verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.new.__doc__ contains 'hash' and 'algorithm' — it is the generic hashing factory function."
    - "hashlib.md5.__doc__ contains 'md5'; hashlib.sha1.__doc__ contains 'sha1'; hashlib.sha256.__doc__ contains 'sha256'; hashlib.sha512.__doc__ contains 'sha512'."
    - "hashlib.pbkdf2_hmac.__doc__ contains 'Password' (capital P) and 'HMAC' and 'key'."
    - "hashlib.file_digest.__doc__ contains 'digest' and 'file' (lowercase)."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new and hashlib.md5/sha1 — __doc__ contains checks
#
# hashlib.new.__doc__ contains 'hash', 'algorithm'
# hashlib.md5.__doc__ contains 'md5'
# hashlib.sha1.__doc__ contains 'sha1'
# ---------------------------------------------------------------------------

table hashlib_extra215.new_and_digest_doc_contains:
  description: "hashlib.new, hashlib.md5, hashlib.sha1 __doc__ contains checks in hashlibdoc215 namespace — wave 259 theme: hashlib.new.__doc__.__contains__('hash')==True; hashlib.new.__doc__.__contains__('algorithm')==True; hashlib.md5.__doc__.__contains__('md5')==True; hashlib.sha1.__doc__.__contains__('sha1')==True; all __doc__ strings are non-None on Python 3.14.3 macOS; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdoc215

  columns: [id, function, args, expected, description]
  rows:
    - [new_doc_has_hash,       hashlib.new.__doc__.__contains__,  ["hash"],      true, "hashlib.new.__doc__ contains 'hash'; factory returns hashing object; verified with Python 3.14.3"]
    - [new_doc_has_algorithm,  hashlib.new.__doc__.__contains__,  ["algorithm"], true, "hashlib.new.__doc__ contains 'algorithm'; references named algorithm; verified with Python 3.14.3"]
    - [md5_doc_has_md5,        hashlib.md5.__doc__.__contains__,  ["md5"],       true, "hashlib.md5.__doc__ contains 'md5'; doc names the algorithm; verified with Python 3.14.3"]
    - [sha1_doc_has_sha1,      hashlib.sha1.__doc__.__contains__, ["sha1"],      true, "hashlib.sha1.__doc__ contains 'sha1'; doc names the algorithm; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.sha256 and hashlib.sha512 — __doc__ contains checks
#
# hashlib.sha256.__doc__ contains 'sha256'
# hashlib.sha512.__doc__ contains 'sha512'
# ---------------------------------------------------------------------------

table hashlib_extra215.sha256_sha512_doc_contains:
  description: "hashlib.sha256 and hashlib.sha512 __doc__ contains checks in hashlibdoc215a namespace — wave 259 theme: hashlib.sha256.__doc__.__contains__('sha256')==True; hashlib.sha512.__doc__.__contains__('sha512')==True; the doc string for each OpenSSL-backed constructor names its algorithm; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdoc215a

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_doc_has_sha256, hashlib.sha256.__doc__.__contains__, ["sha256"], true, "hashlib.sha256.__doc__ contains 'sha256'; doc names the algorithm; verified with Python 3.14.3"]
    - [sha512_doc_has_sha512, hashlib.sha512.__doc__.__contains__, ["sha512"], true, "hashlib.sha512.__doc__ contains 'sha512'; doc names the algorithm; verified with Python 3.14.3"]
    - [sha256_doc_not_sha512, hashlib.sha256.__doc__.__contains__, ["sha512"], false, "hashlib.sha256.__doc__ does not contain 'sha512'; sha256 and sha512 docs are distinct; verified with Python 3.14.3"]
    - [sha512_doc_not_sha256, hashlib.sha512.__doc__.__contains__, ["sha256"], false, "hashlib.sha512.__doc__ does not contain 'sha256'; sha256 and sha512 docs are distinct; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac and hashlib.file_digest — __doc__ contains checks
#
# hashlib.pbkdf2_hmac.__doc__ contains 'Password', 'HMAC', 'key'
# hashlib.file_digest.__doc__ contains 'digest', 'file'
# ---------------------------------------------------------------------------

table hashlib_extra215.pbkdf2_and_file_digest_doc_contains:
  description: "hashlib.pbkdf2_hmac and hashlib.file_digest __doc__ contains checks in hashlibdoc215b namespace — wave 259 theme: hashlib.pbkdf2_hmac.__doc__.__contains__('Password')==True; hashlib.pbkdf2_hmac.__doc__.__contains__('HMAC')==True; hashlib.pbkdf2_hmac.__doc__.__contains__('key')==True; hashlib.file_digest.__doc__.__contains__('digest')==True; hashlib.file_digest.__doc__.__contains__('file')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibdoc215b

  columns: [id, function, args, expected, description]
  rows:
    - [pbkdf2_doc_has_Password, hashlib.pbkdf2_hmac.__doc__.__contains__, ["Password"], true, "hashlib.pbkdf2_hmac.__doc__ contains 'Password' (capital P); PBKDF2 is password-based; verified with Python 3.14.3"]
    - [pbkdf2_doc_has_HMAC,     hashlib.pbkdf2_hmac.__doc__.__contains__, ["HMAC"],     true, "hashlib.pbkdf2_hmac.__doc__ contains 'HMAC'; uses HMAC as pseudorandom function; verified with Python 3.14.3"]
    - [pbkdf2_doc_has_key,      hashlib.pbkdf2_hmac.__doc__.__contains__, ["key"],      true, "hashlib.pbkdf2_hmac.__doc__ contains 'key'; derives a cryptographic key; verified with Python 3.14.3"]
    - [fd_doc_has_digest,       hashlib.file_digest.__doc__.__contains__, ["digest"],   true, "hashlib.file_digest.__doc__ contains 'digest'; returns a digest object; verified with Python 3.14.3"]
    - [fd_doc_has_file,         hashlib.file_digest.__doc__.__contains__, ["file"],     true, "hashlib.file_digest.__doc__ contains 'file'; hashes a file-like object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — hashlib_extra215
# ---------------------------------------------------------------------------

invariant hashlib_extra215.new_doc_contains_hash:
  description: "hashlib.new.__doc__.__contains__('hash') returns True — hashlib.new is the generic hashing factory function whose docstring reads 'Return a new hashing object using the named algorithm'; it contains the word 'hash' which describes its primary purpose; this is the public entry point for creating hash objects by algorithm name; compare: hashlib.md5 and hashlib.sha256 are specific constructors whose docs name the specific algorithm; NEW in hashlib_extra215: first standalone new.__doc__.__contains__ invariant in hashlibdoc215 namespace; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.new.__doc__.__contains__
  args: ["hash"]
  expected: true

invariant hashlib_extra215.new_doc_contains_algorithm:
  description: "hashlib.new.__doc__.__contains__('algorithm') returns True — hashlib.new's docstring explicitly references the 'named algorithm' parameter; the word 'algorithm' appears in the doc 'Return a new hashing object using the named algorithm'; this distinguishes hashlib.new (which dispatches by algorithm name) from specific constructors like hashlib.md5 (which are hard-coded to one algorithm); NEW in hashlib_extra215: first standalone new.__doc__.__contains__('algorithm') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.new.__doc__.__contains__
  args: ["algorithm"]
  expected: true

invariant hashlib_extra215.pbkdf2_doc_contains_Password:
  description: "hashlib.pbkdf2_hmac.__doc__.__contains__('Password') returns True — pbkdf2_hmac's docstring begins 'Password based key derivation function 2 (PKCS #5 v2.0) with HMAC as pseudorandom function'; the capital-P 'Password' reflects the PKCS #5 v2.0 standard name for PBKDF2; pbkdf2_hmac derives cryptographic keys from passwords using iterated HMAC; the presence of 'Password' in the doc confirms it is the password-based KDF; __contains__ is case-sensitive so only the capital-P spelling returns True; NEW in hashlib_extra215: first standalone pbkdf2_hmac.__doc__.__contains__('Password') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__doc__.__contains__
  args: ["Password"]
  expected: true

invariant hashlib_extra215.pbkdf2_doc_contains_HMAC:
  description: "hashlib.pbkdf2_hmac.__doc__.__contains__('HMAC') returns True — pbkdf2_hmac's docstring contains 'HMAC' (all caps) referring to the keyed-hash message authentication code used as the pseudorandom function; HMAC is specified in RFC 2104 and used in PBKDF2 per RFC 2898/PKCS #5; the uppercase 'HMAC' in the doc distinguishes the algorithm name from surrounding prose; __contains__ is case-sensitive; 'hmac' (lowercase) would return False; NEW in hashlib_extra215: first standalone pbkdf2_hmac.__doc__.__contains__('HMAC') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__doc__.__contains__
  args: ["HMAC"]
  expected: true

invariant hashlib_extra215.file_digest_doc_contains_digest:
  description: "hashlib.file_digest.__doc__.__contains__('digest') returns True — hashlib.file_digest's docstring reads 'Hash the contents of a file-like object. Returns a digest object.' and contains the word 'digest' which names the return type; file_digest was added in Python 3.11 to provide a standard way to compute a hash of a file; the function returns a digest object (the hash result) rather than the raw bytes; the word 'digest' appears both in 'Returns a digest object' and in the parameter description '*digest* must either be a hash algorithm name'; NEW in hashlib_extra215: first standalone file_digest.__doc__.__contains__('digest') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.file_digest.__doc__.__contains__
  args: ["digest"]
  expected: true

invariant hashlib_extra215.file_digest_doc_contains_file:
  description: "hashlib.file_digest.__doc__.__contains__('file') returns True — hashlib.file_digest's docstring contains 'file' multiple times: 'Hash the contents of a file-like object', '*fileobj* must be a file-like object opened for reading in binary mode', 'The function may bypass Python's I/O and use the file descriptor *fileno* directly'; the word 'file' (lowercase) is central to the function's purpose of hashing file contents; this is distinct from memory-based hashing done by hashlib.new().update(); NEW in hashlib_extra215: first standalone file_digest.__doc__.__contains__('file') invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.file_digest.__doc__.__contains__
  args: ["file"]
  expected: true

invariant hashlib_extra215.sha256_doc_contains_sha256:
  description: "hashlib.sha256.__doc__.__contains__('sha256') returns True — hashlib.sha256's docstring reads 'Returns a sha256 hash object; optionally initialized with a string'; the algorithm name 'sha256' (lowercase) appears in the doc; this is consistent with hashlib.md5 ('md5'), hashlib.sha1 ('sha1'), and hashlib.sha512 ('sha512') whose docs all name their respective algorithm; all these constructor docs follow the pattern 'Returns a <algorithm> hash object'; NEW in hashlib_extra215: first standalone sha256.__doc__.__contains__ invariant; wave 259; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: hashlib.sha256.__doc__.__contains__
  args: ["sha256"]
  expected: true

