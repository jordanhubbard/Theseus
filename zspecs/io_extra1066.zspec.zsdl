spec: io_extra1066
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module RawIOBase, BufferedIOBase, and TextIOBase documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks RawIOBase, BufferedIOBase, and TextIOBase method __qualname__ values, which reflect the private C-layer class names (_RawIOBase, _BufferedIOBase, _TextIOBase, _IOBase)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1066.rawiobase_method_qualnames:
  description: "io.RawIOBase method __qualname__ checks (qualnames come from private C class _RawIOBase)"
  kind: python_call_eq
  category: rawiobase_method_qualnames
  id_prefix: io1066ra
  columns: [id, function, args, expected]
  rows:
    - [io1066ra001, io.RawIOBase.read.__qualname__.__eq__,      ["_RawIOBase.read"],      true]
    - [io1066ra002, io.RawIOBase.readinto.__qualname__.__eq__,  ["_RawIOBase.readinto"],  true]
    - [io1066ra003, io.RawIOBase.write.__qualname__.__eq__,     ["_RawIOBase.write"],     true]
    - [io1066ra004, io.RawIOBase.__name__.__eq__,               ["RawIOBase"],            true]
    - [io1066ra005, io.RawIOBase.__module__.__eq__,             ["io"],                   true]
    - [io1066ra006, io.RawIOBase.__qualname__.__eq__,           ["RawIOBase"],            true]
    - [io1066ra007, io.RawIOBase.read.__class__.__name__.__eq__, ["method_descriptor"],   true]

table io_extra1066.bufferediobase_method_qualnames:
  description: "io.BufferedIOBase method __qualname__ checks (qualnames come from private C class _BufferedIOBase)"
  kind: python_call_eq
  category: bufferediobase_method_qualnames
  id_prefix: io1066ba
  columns: [id, function, args, expected]
  rows:
    - [io1066ba001, io.BufferedIOBase.read.__qualname__.__eq__,      ["_BufferedIOBase.read"],      true]
    - [io1066ba002, io.BufferedIOBase.read1.__qualname__.__eq__,     ["_BufferedIOBase.read1"],     true]
    - [io1066ba003, io.BufferedIOBase.readinto.__qualname__.__eq__,  ["_BufferedIOBase.readinto"],  true]
    - [io1066ba004, io.BufferedIOBase.write.__qualname__.__eq__,     ["_BufferedIOBase.write"],     true]
    - [io1066ba005, io.BufferedIOBase.detach.__qualname__.__eq__,    ["_BufferedIOBase.detach"],    true]
    - [io1066ba006, io.BufferedIOBase.__name__.__eq__,               ["BufferedIOBase"],            true]
    - [io1066ba007, io.BufferedIOBase.__module__.__eq__,             ["io"],                        true]

table io_extra1066.textiobase_method_qualnames:
  description: "io.TextIOBase method __qualname__ checks (qualnames come from private C classes _TextIOBase/_IOBase)"
  kind: python_call_eq
  category: textiobase_method_qualnames
  id_prefix: io1066ta
  columns: [id, function, args, expected]
  rows:
    - [io1066ta001, io.TextIOBase.read.__qualname__.__eq__,     ["_TextIOBase.read"],     true]
    - [io1066ta002, io.TextIOBase.readline.__qualname__.__eq__, ["_TextIOBase.readline"], true]
    - [io1066ta003, io.TextIOBase.write.__qualname__.__eq__,    ["_TextIOBase.write"],    true]
    - [io1066ta004, io.TextIOBase.detach.__qualname__.__eq__,   ["_TextIOBase.detach"],   true]
    - [io1066ta005, io.TextIOBase.seek.__qualname__.__eq__,     ["_IOBase.seek"],         true]
    - [io1066ta006, io.TextIOBase.tell.__qualname__.__eq__,     ["_IOBase.tell"],         true]
    - [io1066ta007, io.TextIOBase.__name__.__eq__,              ["TextIOBase"],           true]
    - [io1066ta008, io.TextIOBase.__module__.__eq__,            ["io"],                   true]
