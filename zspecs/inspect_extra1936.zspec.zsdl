spec: inspect_extra1936
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol dict-presence checks, __set_name__ dict presence, __class__ attribute value checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "inspect.Parameter, Signature, and BoundArguments do NOT define __get__, __set__, __delete__, or __set_name__ in their own __dict__."
    - "inspect.Parameter.__dict__ has 'kind' (True) because it is a property descriptor defined on the class."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' (empty is a class, not an instance)."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' (enum member)."
  created_at: "2026-04-12"
error_model: python_exceptions

table inspect_extra1936.descriptor_protocol_parameter:
  description: "inspect.Parameter __get__/__set__/__delete__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1936
  columns: [id, function, args, expected]
  rows:
    - ["in1936001", "inspect.Parameter.__dict__.__contains__",     ["__get__"],    false]
    - ["in1936002", "inspect.Parameter.__dict__.__contains__",     ["__set__"],    false]
    - ["in1936003", "inspect.Parameter.__dict__.__contains__",     ["__delete__"], false]
    - ["in1936004", "inspect.Signature.__dict__.__contains__",     ["__get__"],    false]
    - ["in1936005", "inspect.Signature.__dict__.__contains__",     ["__set__"],    false]
    - ["in1936006", "inspect.Signature.__dict__.__contains__",     ["__delete__"], false]
    - ["in1936007", "inspect.BoundArguments.__dict__.__contains__", ["__get__"],   false]
    - ["in1936008", "inspect.BoundArguments.__dict__.__contains__", ["__set__"],   false]
    - ["in1936009", "inspect.BoundArguments.__dict__.__contains__", ["__delete__"], false]

table inspect_extra1936.set_name_presence:
  description: "inspect classes __set_name__ dict-presence checks — none present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1936
  columns: [id, function, args, expected]
  rows:
    - ["in1936010", "inspect.Parameter.__dict__.__contains__",      ["__set_name__"], false]
    - ["in1936011", "inspect.Signature.__dict__.__contains__",      ["__set_name__"], false]
    - ["in1936012", "inspect.BoundArguments.__dict__.__contains__", ["__set_name__"], false]

table inspect_extra1936.parameter_property_presence:
  description: "inspect.Parameter property descriptor dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1936
  columns: [id, function, args, expected]
  rows:
    - ["in1936013", "inspect.Parameter.__dict__.__contains__",     ["kind"],       true]
    - ["in1936014", "inspect.Parameter.__dict__.__contains__",     ["default"],    true]
    - ["in1936015", "inspect.Parameter.__dict__.__contains__",     ["annotation"], true]
    - ["in1936016", "inspect.Parameter.__dict__.__contains__",     ["name"],       true]
    - ["in1936017", "inspect.Signature.__dict__.__contains__",     ["parameters"], true]
    - ["in1936018", "inspect.Signature.__dict__.__contains__",     ["return_annotation"], true]
    - ["in1936019", "inspect.Signature.__dict__.__contains__",     ["bind"],       true]
    - ["in1936020", "inspect.BoundArguments.__dict__.__contains__", ["arguments"], true]
    - ["in1936021", "inspect.BoundArguments.__dict__.__contains__", ["args"],      true]
    - ["in1936022", "inspect.BoundArguments.__dict__.__contains__", ["kwargs"],    true]

table inspect_extra1936.class_name_checks:
  description: "inspect type and module __class__.__name__ identity checks"
  kind: python_call_eq
  category: class_name
  id_prefix: in1936
  columns: [id, function, args, expected]
  rows:
    - ["in1936023", "inspect.__class__.__name__.__eq__",                              ["module"],        true]
    - ["in1936024", "inspect.Parameter.__class__.__name__.__eq__",                   ["type"],          true]
    - ["in1936025", "inspect.Signature.__class__.__name__.__eq__",                   ["type"],          true]
    - ["in1936026", "inspect.BoundArguments.__class__.__name__.__eq__",              ["type"],          true]
    - ["in1936027", "inspect.Parameter.empty.__class__.__name__.__eq__",             ["type"],          true]
    - ["in1936028", "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__",   ["_ParameterKind"], true]
    - ["in1936029", "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__", ["_ParameterKind"], true]
    - ["in1936030", "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__",    ["_ParameterKind"], true]
    - ["in1936031", "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__",      ["_ParameterKind"], true]
    - ["in1936032", "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__",       ["_ParameterKind"], true]

table inspect_extra1936.parameter_module_checks:
  description: "inspect class module and qualname identity checks"
  kind: python_call_eq
  category: qualname
  id_prefix: in1936
  columns: [id, function, args, expected]
  rows:
    - ["in1936033", "inspect.Parameter.__module__.__eq__",       ["inspect"], true]
    - ["in1936034", "inspect.Signature.__module__.__eq__",       ["inspect"], true]
    - ["in1936035", "inspect.BoundArguments.__module__.__eq__",  ["inspect"], true]
    - ["in1936036", "inspect.Parameter.__qualname__.__eq__",     ["Parameter"], true]
    - ["in1936037", "inspect.Signature.__qualname__.__eq__",     ["Signature"], true]
    - ["in1936038", "inspect.BoundArguments.__qualname__.__eq__", ["BoundArguments"], true]
