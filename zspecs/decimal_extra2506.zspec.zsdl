spec: decimal_extra2506
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification, Version 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers is_nan/is_infinite/is_zero/is_signed predicates, to_eng_string, rounding constants"
    - "decimal_extra1876.zspec.zsdl — covers attribute access protocol, introspection protocol, to_eng_string/normalize/quantize"
  notes:
    - "Theme: __add__, __sub__, __mul__ arithmetic operator dict-presence for decimal.Decimal."
    - "decimal.Decimal is a full numeric type; it defines ALL standard arithmetic operators directly in its class __dict__."
    - "decimal.Decimal.__dict__ dunder arithmetic keys (verified Python 3.14): __abs__, __add__, __bool__, __ceil__, __complex__, __divmod__, __float__, __floor__, __floordiv__, __format__, __int__, __mod__, __mul__, __neg__, __pos__, __pow__, __radd__, __rdivmod__, __rfloordiv__, __rmod__, __rmul__, __round__, __rpow__, __rsub__, __rtruediv__, __sub__, __truediv__, __trunc__."
    - "Both forward operators (__add__, __sub__, __mul__, __truediv__, __floordiv__, __mod__, __pow__) and reflected operators (__radd__, __rsub__, __rmul__, __rtruediv__, __rfloordiv__, __rmod__, __rpow__) are defined."
    - "Unary operators __neg__, __pos__, __abs__ are also present."
    - "Numeric coercion: __int__, __float__, __complex__, __ceil__, __floor__, __round__, __trunc__ are all defined."
    - "Context manager protocol (__enter__/__exit__) is defined on decimal.Context, not on Decimal itself."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal — forward arithmetic operators present
#
# Decimal implements the full numeric protocol. __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __mod__, and __pow__ are all in __dict__.
# This is the main positive result: Decimal IS a numeric type with arithmetic.
# ---------------------------------------------------------------------------

table decimal_extra2506.decimal_forward_arith:
  description: "__add__, __sub__, __mul__, __truediv__, __floordiv__, __mod__, __pow__ present in Decimal __dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dc2506

  columns: [id, function, args, expected]
  rows:
    - ["dc2506-001", "decimal.Decimal.__dict__.__contains__", ["__add__"],      true]
    - ["dc2506-002", "decimal.Decimal.__dict__.__contains__", ["__sub__"],      true]
    - ["dc2506-003", "decimal.Decimal.__dict__.__contains__", ["__mul__"],      true]
    - ["dc2506-004", "decimal.Decimal.__dict__.__contains__", ["__truediv__"],  true]
    - ["dc2506-005", "decimal.Decimal.__dict__.__contains__", ["__floordiv__"], true]
    - ["dc2506-006", "decimal.Decimal.__dict__.__contains__", ["__mod__"],      true]
    - ["dc2506-007", "decimal.Decimal.__dict__.__contains__", ["__pow__"],      true]

# ---------------------------------------------------------------------------
# Table 2: decimal.Decimal — reflected arithmetic operators present
#
# Python's reflected operators (__radd__, __rsub__, etc.) are called when the
# left operand does not support the operation (e.g., int + Decimal invokes
# Decimal.__radd__). All reflected operators are defined on Decimal.
# ---------------------------------------------------------------------------

table decimal_extra2506.decimal_reflected_arith:
  description: "__radd__, __rsub__, __rmul__, __rtruediv__, __rfloordiv__, __rmod__, __rpow__ present in Decimal __dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: dc2506

  columns: [id, function, args, expected]
  rows:
    - ["dc2506-008", "decimal.Decimal.__dict__.__contains__", ["__radd__"],      true]
    - ["dc2506-009", "decimal.Decimal.__dict__.__contains__", ["__rsub__"],      true]
    - ["dc2506-010", "decimal.Decimal.__dict__.__contains__", ["__rmul__"],      true]
    - ["dc2506-011", "decimal.Decimal.__dict__.__contains__", ["__rtruediv__"],  true]
    - ["dc2506-012", "decimal.Decimal.__dict__.__contains__", ["__rfloordiv__"], true]
    - ["dc2506-013", "decimal.Decimal.__dict__.__contains__", ["__rmod__"],      true]
    - ["dc2506-014", "decimal.Decimal.__dict__.__contains__", ["__rpow__"],      true]

# ---------------------------------------------------------------------------
# Table 3: decimal.Decimal — unary arithmetic and numeric coercion operators
#
# Unary operators (__neg__, __pos__, __abs__) and numeric coercion methods
# (__int__, __float__, __complex__, __round__, __ceil__, __floor__, __trunc__)
# are all defined on Decimal, completing the full numeric protocol.
# ---------------------------------------------------------------------------

table decimal_extra2506.decimal_unary_and_coerce:
  description: "__neg__, __pos__, __abs__, __int__, __float__, __complex__, __round__, __ceil__, __floor__, __trunc__ present in Decimal __dict__"
