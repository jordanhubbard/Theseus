  columns: [id, function, args, expected]
  rows:
    - ["dc2506-015", "decimal.Decimal.__dict__.__contains__", ["__neg__"],     true]
    - ["dc2506-016", "decimal.Decimal.__dict__.__contains__", ["__pos__"],     true]
