spec: pickle_extra17
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra16.zspec.zsdl."
    - "pickle_extra16 covers: Pickler.dump/__qualname__; Pickler.persistent_id/__qualname__; Unpickler.load/__qualname__; Unpickler.find_class/__qualname__."
    - "pickle_extra15 covers: PickleError/PicklingError/UnpicklingError __qualname__.__class__.__name__; Pickler/__qualname__.__class__.__name__; Unpickler/__qualname__.__class__.__name__."
    - "pickle_extra14 covers: Pickler/__qualname__; Unpickler/__qualname__; PickleBuffer/__qualname__; loads/__qualname__; load/__qualname__; dump/__qualname__."
    - "pickle_extra10 covers: PickleError/__qualname__; PicklingError/__qualname__; UnpicklingError/__qualname__."
    - "Focus: __qualname__ for additional Pickler and Unpickler methods — clear_memo, dispatch_table, persistent_load."
    - "No prior pickle spec checks Pickler.clear_memo.__qualname__."
    - "No prior pickle spec checks Pickler.dispatch_table.__qualname__."
    - "No prior pickle spec checks Unpickler.persistent_load.__qualname__."
    - "pickle.Pickler.clear_memo.__qualname__ == 'Pickler.clear_memo' — C-accelerated method; compound dotted qualname."
    - "pickle.Pickler.dispatch_table.__qualname__ == 'Pickler.dispatch_table' — C-accelerated descriptor; compound dotted qualname."
    - "pickle.Unpickler.persistent_load.__qualname__ == 'Unpickler.persistent_load' — C-accelerated descriptor; compound dotted qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pickler additional method/descriptor __qualname__ values
#
# pickle_extra16 checks Pickler.dump.__qualname__ and Pickler.persistent_id.__qualname__.
# No prior pickle spec checks clear_memo or dispatch_table __qualname__.
# For C-accelerated methods and descriptors in class Pickler, __qualname__
# uses the compound dotted form 'Pickler.attr'.
# ---------------------------------------------------------------------------

invariant pickle_extra17.Pickler.clear_memo.qualname:
  description: "pickle.Pickler.clear_memo.__qualname__ == 'Pickler.clear_memo' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Pickler.clear_memo.__qualname__.__eq__
  args: ["Pickler.clear_memo"]
  expected: true

invariant pickle_extra17.Pickler.dispatch_table.qualname:
  description: "pickle.Pickler.dispatch_table.__qualname__ == 'Pickler.dispatch_table' — compound descriptor qualname"
  category: method_attrs
  kind: python_call_eq
  function: Pickler.dispatch_table.__qualname__.__eq__
  args: ["Pickler.dispatch_table"]
  expected: true

# ---------------------------------------------------------------------------
# Unpickler additional method/descriptor __qualname__ values
#
# pickle_extra16 checks Unpickler.load.__qualname__ and Unpickler.find_class.__qualname__.
# No prior pickle spec checks persistent_load __qualname__.
# ---------------------------------------------------------------------------

invariant pickle_extra17.Unpickler.persistent_load.qualname:
  description: "pickle.Unpickler.persistent_load.__qualname__ == 'Unpickler.persistent_load' — compound descriptor qualname"
  category: method_attrs
  kind: python_call_eq
  function: Unpickler.persistent_load.__qualname__.__eq__
  args: ["Unpickler.persistent_load"]
  expected: true

# ---------------------------------------------------------------------------
# Pickler and Unpickler additional method __qualname__ table
#
# Consolidates the three additional method qualname checks into a single table.
# All three are first covered in this spec (pickle_extra17).
# ---------------------------------------------------------------------------

table pickle_extra17.additional_method_qualnames:
  description: "pickle Pickler/Unpickler additional method __qualname__ — compound dotted names"
  kind: python_call_eq
  category: method_attrs
  id_prefix: pmq17

  columns: [id, function, args, expected]
  rows:
    - [Pickler_clear_memo_qn,        Pickler.clear_memo.__qualname__.__eq__,        ["Pickler.clear_memo"],        true]
    - [Pickler_dispatch_table_qn,    Pickler.dispatch_table.__qualname__.__eq__,    ["Pickler.dispatch_table"],    true]
    - [Unpickler_persistent_load_qn, Unpickler.persistent_load.__qualname__.__eq__, ["Unpickler.persistent_load"], true]
