spec: ruamel_yaml_rust
version: ">=3.9"
backend: rust_module(ruamel_yaml_rust)

docs: https://yaml.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://yaml.readthedocs.io/en/latest/ — ruamel.yaml documentation"
  not_derived_from:
    - "ruamel.yaml source: ruamel/yaml/__init__.py"
  notes:
    - "ruamel.yaml provides YAML round-trip parsing with comment preservation."
    - "from ruamel.yaml import YAML; yaml = YAML()."
    - "yaml.load('key: value', Loader=yaml.Loader)['key'] == 'value'."
    - "YAML(typ='safe').load('x: 42')['x'] == 42."
    - "YAML(typ='safe').load('lst: [1,2,3]')['lst'] == [1,2,3]."
    - "Expose ruamel_loads_str(yaml_str, key) -> str: YAML(typ='safe').load(yaml_str)[key]."
    - "Expose ruamel_loads_int(yaml_str, key) -> int: YAML(typ='safe').load(yaml_str)[key]."
    - "All test vectors verified against ruamel.yaml 0.18.10."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# ruamel_loads_str — string value from YAML
table ruamel_yaml_rust.parse.loads_str:
  kind: python_call_eq
  category: loads_str
  id_prefix: rml_s
  function: ruamel_loads_str

  columns: [id, args, expected]
  rows:
    - [simple, ["key: value", "key"],   "value"]
    - [name,   ["name: Alice", "name"], "Alice"]

# ruamel_loads_int — integer value from YAML
table ruamel_yaml_rust.parse.loads_int:
  kind: python_call_eq
  category: loads_int
  id_prefix: rml_i
  function: ruamel_loads_int

  columns: [id, args, expected]
  rows:
    - [forty2, ["x: 42", "x"], 42]
    - [zero,   ["n: 0",  "n"],  0]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
