spec: functools_extra70
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra69.zspec.zsdl."
    - "Wave 231 theme: __code__ attribute chains — co_varnames, co_filename, co_flags for wraps/update_wrapper/lru_cache."
    - "wraps.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple of local variable names in CPython code objects. Verified with Python 3.14.3."
    - "wraps.__code__.co_varnames[0] == 'wrapped' — the first argument of functools.wraps is 'wrapped' as defined in def wraps(wrapped, assigned=..., updated=...). Verified with Python 3.14.3."
    - "update_wrapper.__code__.co_varnames[0] == 'wrapper' — the first argument of update_wrapper is 'wrapper'. Verified with Python 3.14.3."
    - "lru_cache.__code__.co_varnames[0] == 'maxsize' — the first argument of lru_cache is 'maxsize' (def lru_cache(maxsize=128, typed=False)). Verified with Python 3.14.3."
    - "wraps.__code__.co_filename.__class__.__name__ == 'str' — co_filename is always a str object holding the source file path. Verified with Python 3.14.3."
    - "wraps.__code__.co_filename.__contains__('.py') == True — functools is a pure-Python module (Lib/functools.py), so co_filename ends with '.py'. Verified with Python 3.14.3."
    - "update_wrapper.__code__.co_filename.__contains__('.py') == True — same reasoning; co_filename is the path to Lib/functools.py. Verified with Python 3.14.3."
    - "lru_cache.__code__.co_filename.__contains__('.py') == True — lru_cache is pure-Python (Lib/functools.py). Verified with Python 3.14.3."
    - "wraps.__code__.co_flags.__class__.__name__ == 'int' — co_flags is always a plain Python int (a bitmask of code object flags). Verified with Python 3.14.3."
    - "update_wrapper.__code__.co_flags.__class__.__name__ == 'int' — same invariant for update_wrapper. Verified with Python 3.14.3."
    - "lru_cache.__code__.co_flags.__class__.__name__ == 'int' — same invariant for lru_cache. Verified with Python 3.14.3."
    - "No prior functools spec checks co_varnames[0] (the first local variable name), co_filename, or co_flags for any functools function. All checks in this spec are new to extra70."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools __code__.co_varnames.__class__.__name__ — extra70
#
# Wave 231 theme: co_varnames is always a tuple.
#
# co_varnames (PyCodeObject.co_varnames) is a tuple of strings containing the
# names of all local variables (parameters first, then locals) in a code
# object. In CPython this is always stored as a Python tuple.
#
# wraps.__code__.co_varnames.__class__.__name__ == 'tuple'
# update_wrapper.__code__.co_varnames.__class__.__name__ == 'tuple'
# lru_cache.__code__.co_varnames.__class__.__name__ == 'tuple'
#
# No prior functools spec checks co_varnames.__class__.__name__. New to extra70.
# ---------------------------------------------------------------------------

table functools_extra70.co_varnames_class_name:
  description: "functools function __code__.co_varnames.__class__.__name__.__eq__('tuple')==true — co_varnames is always a tuple in CPython; wave 231 co_varnames chains; new to extra70"
  kind: python_call_eq
  category: co_varnames
  id_prefix: functoolscode3_70

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_code_co_varnames_class_name_eq_tuple,
       wraps.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.wraps.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — wraps is a pure-Python function (Lib/functools.py); its __code__ is a PyCodeObject; PyCodeObject.co_varnames is a tuple of strings containing all local variable names (parameters first); the tuple built-in type has __name__ == 'tuple' (5 chars); __eq__ returns True; no prior functools spec checks co_varnames.__class__.__name__ for wraps; new to extra70"]
    - [update_wrapper_code_co_varnames_class_name_eq_tuple,
       update_wrapper.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.update_wrapper.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — update_wrapper is a pure-Python function (Lib/functools.py); its co_varnames is a tuple of strings for all local variable names; tuple.__name__ == 'tuple'; __eq__ returns True; no prior functools spec checks co_varnames.__class__.__name__ for update_wrapper; new to extra70"]
    - [lru_cache_code_co_varnames_class_name_eq_tuple,
       lru_cache.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.lru_cache.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — lru_cache is a pure-Python function (Lib/functools.py); its co_varnames is a tuple of strings for all local variable names; tuple.__name__ == 'tuple'; __eq__ returns True; no prior functools spec checks co_varnames.__class__.__name__ for lru_cache; new to extra70"]

# ---------------------------------------------------------------------------
# functools __code__.co_varnames[0] — extra70
#
# Wave 231 theme: co_varnames[0] is the first parameter name.
#
# co_varnames[0] is the name of the first positional parameter, since
# co_varnames lists all locals with parameters first. For pure-Python
# functions without *args before regular args, co_varnames[0] is always
# the first named parameter in the function signature.
#
# wraps(wrapped, assigned=..., updated=...) → co_varnames[0] == 'wrapped'
# update_wrapper(wrapper, wrapped, ...) → co_varnames[0] == 'wrapper'
# lru_cache(maxsize=128, typed=False) → co_varnames[0] == 'maxsize'
#
# Function values containing '[' MUST be double-quoted in table rows.
# No prior functools spec checks co_varnames[0]. New to extra70.
# ---------------------------------------------------------------------------

table functools_extra70.co_varnames_first_arg:
  description: "functools function __code__.co_varnames[0].__eq__ — first parameter name; wave 231 co_varnames first arg; new to extra70"
  kind: python_call_eq
  category: co_varnames
  id_prefix: functoolscode3_70

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_code_co_varnames_0_eq_wrapped,
       "wraps.__code__.co_varnames[0].__eq__",
       ["wrapped"],
       true,
       "functools.wraps.__code__.co_varnames[0].__eq__('wrapped') == True — wraps is a pure-Python function (Lib/functools.py) with signature wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES); co_varnames lists all locals with parameters first; co_varnames[0] is the first parameter name, which is 'wrapped' (7 chars); __eq__ on the str 'wrapped' returns True when the argument equals 'wrapped'; no prior functools spec checks co_varnames[0] for wraps; new to extra70"]
    - [update_wrapper_code_co_varnames_0_eq_wrapper,
       "update_wrapper.__code__.co_varnames[0].__eq__",
       ["wrapper"],
       true,
       "functools.update_wrapper.__code__.co_varnames[0].__eq__('wrapper') == True — update_wrapper is a pure-Python function (Lib/functools.py) with signature update_wrapper(wrapper, wrapped, assigned=..., updated=...); co_varnames[0] is the first parameter name, which is 'wrapper' (7 chars); __eq__ returns True; no prior functools spec checks co_varnames[0] for update_wrapper; new to extra70"]
    - [lru_cache_code_co_varnames_0_eq_maxsize,
       "lru_cache.__code__.co_varnames[0].__eq__",
       ["maxsize"],
       true,
       "functools.lru_cache.__code__.co_varnames[0].__eq__('maxsize') == True — lru_cache is a pure-Python function (Lib/functools.py) with signature lru_cache(maxsize=128, typed=False); co_varnames[0] is the first parameter name, which is 'maxsize' (7 chars); __eq__ returns True; no prior functools spec checks co_varnames[0] for lru_cache; new to extra70"]

# ---------------------------------------------------------------------------
# functools __code__.co_filename.__class__.__name__ — extra70
#
# Wave 231 theme: co_filename is always a str.
#
# co_filename (PyCodeObject.co_filename) stores the path of the source file
# where the function was defined, as a Python str. For functools (a pure-Python
# module in Lib/functools.py), co_filename is a str object.
#
# wraps.__code__.co_filename.__class__.__name__ == 'str'
# update_wrapper.__code__.co_filename.__class__.__name__ == 'str'
# lru_cache.__code__.co_filename.__class__.__name__ == 'str'
#
# No prior functools spec checks co_filename.__class__.__name__. New to extra70.
# ---------------------------------------------------------------------------

table functools_extra70.co_filename_class_name:
  description: "functools function __code__.co_filename.__class__.__name__.__eq__('str')==true — co_filename is always a str; wave 231 co_filename chains; new to extra70"
  kind: python_call_eq
  category: co_filename
  id_prefix: functoolscode3_70

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_code_co_filename_class_name_eq_str,
       wraps.__code__.co_filename.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.wraps.__code__.co_filename.__class__.__name__.__eq__('str') == True — wraps is a pure-Python function (Lib/functools.py); its __code__ is a PyCodeObject; PyCodeObject.co_filename is a str holding the absolute path of the source file; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior functools spec checks co_filename.__class__.__name__ for wraps; new to extra70"]
    - [update_wrapper_code_co_filename_class_name_eq_str,
       update_wrapper.__code__.co_filename.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.update_wrapper.__code__.co_filename.__class__.__name__.__eq__('str') == True — update_wrapper is a pure-Python function (Lib/functools.py); co_filename is a str holding the path to Lib/functools.py; str.__name__ == 'str'; __eq__ returns True; no prior functools spec checks co_filename.__class__.__name__ for update_wrapper; new to extra70"]
    - [lru_cache_code_co_filename_class_name_eq_str,
       lru_cache.__code__.co_filename.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.lru_cache.__code__.co_filename.__class__.__name__.__eq__('str') == True — lru_cache is a pure-Python function (Lib/functools.py); co_filename is a str holding the path to Lib/functools.py; str.__name__ == 'str'; __eq__ returns True; no prior functools spec checks co_filename.__class__.__name__ for lru_cache; new to extra70"]

# ---------------------------------------------------------------------------
# functools __code__.co_filename.__contains__('.py') — extra70
#
# Wave 231 theme: co_filename ends with '.py' for pure-Python functools.
#
# functools is a pure-Python module (Lib/functools.py). Therefore the
# co_filename attribute of every function defined there contains the
# substring '.py' (the file extension). This is verified via __contains__.
#
# wraps.__code__.co_filename.__contains__('.py') == True
# update_wrapper.__code__.co_filename.__contains__('.py') == True
# lru_cache.__code__.co_filename.__contains__('.py') == True
#
# No prior functools spec checks co_filename.__contains__. New to extra70.
# ---------------------------------------------------------------------------

table functools_extra70.co_filename_contains_py:
  description: "functools function __code__.co_filename.__contains__('.py')==true — functools is pure-Python so co_filename contains '.py'; wave 231 co_filename chains; new to extra70"
  kind: python_call_eq
  category: co_filename
  id_prefix: functoolscode3_70

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_code_co_filename_contains_py,
       wraps.__code__.co_filename.__contains__,
       [".py"],
       true,
       "functools.wraps.__code__.co_filename.__contains__('.py') == True — wraps is defined in Lib/functools.py; PyCodeObject.co_filename is the absolute path to that file as a str; the path necessarily contains the substring '.py' (the .py file extension); str.__contains__ returns True at the first occurrence; no prior functools spec checks co_filename.__contains__('.py') for wraps; new to extra70"]
    - [update_wrapper_code_co_filename_contains_py,
       update_wrapper.__code__.co_filename.__contains__,
       [".py"],
       true,
       "functools.update_wrapper.__code__.co_filename.__contains__('.py') == True — update_wrapper is defined in Lib/functools.py; co_filename is the absolute path to Lib/functools.py; the path contains '.py'; __contains__ returns True; no prior functools spec checks co_filename.__contains__('.py') for update_wrapper; new to extra70"]
    - [lru_cache_code_co_filename_contains_py,
       lru_cache.__code__.co_filename.__contains__,
       [".py"],
       true,
       "functools.lru_cache.__code__.co_filename.__contains__('.py') == True — lru_cache is defined in Lib/functools.py; co_filename is the absolute path to Lib/functools.py; the path contains '.py'; __contains__ returns True; no prior functools spec checks co_filename.__contains__('.py') for lru_cache; new to extra70"]

# ---------------------------------------------------------------------------
# functools __code__.co_flags.__class__.__name__ — extra70
#
# Wave 231 theme: co_flags is always an int.
#
# co_flags (PyCodeObject.co_flags) is a bitmask of integer flags describing
# properties of the code object (e.g., CO_OPTIMIZED, CO_NEWLOCALS,
# CO_VARARGS, CO_VARKEYWORDS, CO_NESTED, CO_GENERATOR, etc.). In CPython this
# field is always a plain Python int.
#
# wraps.__code__.co_flags.__class__.__name__ == 'int'
# update_wrapper.__code__.co_flags.__class__.__name__ == 'int'
# lru_cache.__code__.co_flags.__class__.__name__ == 'int'
#
# No prior functools spec checks co_flags.__class__.__name__. New to extra70.
# ---------------------------------------------------------------------------

table functools_extra70.co_flags_class_name:
  description: "functools function __code__.co_flags.__class__.__name__.__eq__('int')==true — co_flags is always a plain int bitmask; wave 231 co_flags chains; new to extra70"
  kind: python_call_eq
  category: co_flags
  id_prefix: functoolscode3_70

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_code_co_flags_class_name_eq_int,
       wraps.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "functools.wraps.__code__.co_flags.__class__.__name__.__eq__('int') == True — wraps is a pure-Python function (Lib/functools.py); its __code__ is a PyCodeObject; PyCodeObject.co_flags is a bitmask of integer flags (e.g., CO_OPTIMIZED, CO_NEWLOCALS) stored as a Python int; int.__name__ == 'int' (3 chars); __eq__ returns True; no prior functools spec checks co_flags.__class__.__name__ for wraps; new to extra70"]
    - [update_wrapper_code_co_flags_class_name_eq_int,
       update_wrapper.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "functools.update_wrapper.__code__.co_flags.__class__.__name__.__eq__('int') == True — update_wrapper is a pure-Python function (Lib/functools.py); co_flags is a Python int bitmask; int.__name__ == 'int'; __eq__ returns True; no prior functools spec checks co_flags.__class__.__name__ for update_wrapper; new to extra70"]
    - [lru_cache_code_co_flags_class_name_eq_int,
       lru_cache.__code__.co_flags.__class__.__name__.__eq__,
       ["int"],
       true,
       "functools.lru_cache.__code__.co_flags.__class__.__name__.__eq__('int') == True — lru_cache is a pure-Python function (Lib/functools.py); co_flags is a Python int bitmask; int.__name__ == 'int'; __eq__ returns True; no prior functools spec checks co_flags.__class__.__name__ for lru_cache; new to extra70"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra70
# ---------------------------------------------------------------------------

invariant functools_extra70.wraps_co_varnames_tuple:
  description: "functools.wraps.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple in CPython; wave 231 co_varnames chains; new to extra70"
  kind: python_call_eq
  function: wraps.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra70.wraps_co_varnames_first_arg:
  description: "functools.wraps.__code__.co_varnames[0].__eq__('wrapped') == True — first parameter of wraps is 'wrapped'; wave 231 co_varnames first arg; new to extra70"
  kind: python_call_eq
  function: "wraps.__code__.co_varnames[0].__eq__"
  args: ["wrapped"]
  expected: true

invariant functools_extra70.wraps_co_filename_str:
  description: "functools.wraps.__code__.co_filename.__class__.__name__.__eq__('str') == True — co_filename is always a str; wave 231 co_filename chains; new to extra70"
  kind: python_call_eq
  function: wraps.__code__.co_filename.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra70.wraps_co_filename_contains_py:
  description: "functools.wraps.__code__.co_filename.__contains__('.py') == True — functools is pure-Python so co_filename contains '.py'; wave 231 co_filename chains; new to extra70"
  kind: python_call_eq
  function: wraps.__code__.co_filename.__contains__
  args: [".py"]
  expected: true

invariant functools_extra70.wraps_co_flags_int:
  description: "functools.wraps.__code__.co_flags.__class__.__name__.__eq__('int') == True — co_flags is always a plain int bitmask; wave 231 co_flags chains; new to extra70"
  kind: python_call_eq
  function: wraps.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true
