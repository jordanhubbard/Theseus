spec: hashlib_extra61
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra60.zspec.zsdl — covers hashlib.__all__.__contains__ for sha256/sha1/sha512/sha3_256 (table); blake2b/blake2s/md5/sha1 __doc__.__class__.__qualname__.__eq__('str'); __all__.__contains__('algorithms_guaranteed') (invariant)."
    - "hashlib_extra58.zspec.zsdl — covers hashlib.__spec__.name.__eq__('hashlib') and __spec__.name.__len__()==7."
    - "hashlib_extra36.zspec.zsdl — covers hashlib.__spec__.__name__.__len__()==7 and hashlib.__loader__.__class__.__name__.__len__()==16."
    - "hashlib_extra55.zspec.zsdl — covers hashlib.__name__.__eq__('hashlib') and __name__.__len__()==7; algorithms_guaranteed.__contains__ for sha224/sha384/blake2b/blake2s/sha3_256/sha3_512."
    - "hashlib_extra34.zspec.zsdl — covers hashlib.__all__.__class__.__name__.__eq__('tuple') and __all__.__len__()==19."
    - "hashlib.zspec — covers hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra60; it does NOT duplicate invariants present in those files."
    - "Wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__/__cached__ class name checks."
    - "hashlib is a hybrid module: hashlib.py is a pure Python wrapper that imports C extension hash implementations. Its loader is therefore SourceFileLoader (not ExtensionFileLoader or BuiltinImporter). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 1: hashlib_extra36 checks hashlib.__loader__.__class__.__name__.__len__()==16 (length axis). hashlib_extra36 documents the loader class name as 'SourceFileLoader' in notes but covers it only via __len__; no prior hashlib spec checks hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') (the equality axis). The two axes are independent regression vectors: __len__ catches length changes (e.g., a rename to 'SourceLoader') while __eq__ catches exact identity (e.g., a loader renamed to 'PYCFileLoader' with the same length). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader'. hashlib.py is a pure-Python module loaded by importlib.machinery.SourceFileLoader. hashlib_extra36 covers __loader__.__class__.__name__.__len__()==16 but NOT __eq__('SourceFileLoader'). No prior hashlib spec checks __loader__.__class__.__name__.__eq__('SourceFileLoader'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: hashlib_extra36 checks hashlib.__spec__.__name__.__len__()==7 (the ModuleSpec's .name via .__name__). hashlib_extra58 checks hashlib.__spec__.name.__eq__('hashlib') (the .name attribute without dunder). No prior hashlib spec checks hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') — confirming the type of the __spec__ object itself. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.__class__.__name__ == 'ModuleSpec'. The hashlib module's __spec__ attribute is an instance of importlib.machinery.ModuleSpec; its class name is 'ModuleSpec'. hashlib_extra36 and hashlib_extra58 probe the __spec__.name value but NOT the type of __spec__ itself. No prior hashlib spec checks __spec__.__class__.__name__.__eq__('ModuleSpec'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior hashlib spec checks hashlib.__file__.__class__.__name__.__eq__('str'). hashlib.py is a Python source file; its __file__ attribute is a path string (e.g., '.../hashlib.py'). str.__class__.__name__ == 'str'. This confirms that the __file__ attribute is a string object, anchoring the fact that hashlib has a file path (as opposed to C built-in modules that lack __file__). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__file__.__class__.__name__ == 'str'. hashlib is loaded from a .py source file; its __file__ attribute is a Python str path. No prior hashlib spec checks hashlib.__file__.__class__.__name__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 4: No prior hashlib spec checks hashlib.__cached__.__class__.__name__.__eq__('str'). hashlib.py is compiled to a .pyc bytecode cache file stored under __pycache__; its __cached__ attribute is a str path to that .pyc file. This is a distinct axis from __file__: __file__ is the source path, __cached__ is the bytecode path. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__cached__.__class__.__name__ == 'str'. hashlib.py has a compiled bytecode cache; its __cached__ attribute is a Python str path to the .pyc file. No prior hashlib spec checks hashlib.__cached__.__class__.__name__.__eq__('str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib loader identity + module spec/file/cached class name checks
#
# Wave 225 theme: __loader__ identity + __spec__ attribute chains +
# __file__/__cached__ class name checks.
#
# hashlib is a pure-Python wrapper (hashlib.py) that imports C extension
# hash implementations. Its loader is SourceFileLoader (not ExtensionFileLoader
# or BuiltinImporter). Prior specs cover __len__ axes; this spec covers __eq__
# axes for the loader class name, spec class name, file class name, and cached
# class name — all of which are novel for the hashlib module.
# ---------------------------------------------------------------------------

table hashlib_extra61.loader_spec_file_cached:
  description: "hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') — loader/spec/file/cached class identity for the hashlib Python wrapper module; hashlib_extra36 covers __loader__.__class__.__name__.__len__()==16 and __spec__.__name__.__len__()==7 (length axes) but no prior hashlib spec checks these via __eq__; all four are novel equality anchors"
  kind: python_call_eq
  category: module_structure
  id_prefix: hashlibload61

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_eq,  __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [spec_class_name_eq,    __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],       true]
    - [file_class_name_eq,    __file__.__class__.__name__.__eq__,    ["str"],              true]
    - [cached_class_name_eq,  __cached__.__class__.__name__.__eq__,  ["str"],              true]

# ---------------------------------------------------------------------------
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# hashlib_extra36 covers __loader__.__class__.__name__.__len__()==16 (length
# axis). No prior hashlib spec checks the equality axis for the loader class
# name. SourceFileLoader identity confirms that hashlib.py is loaded as a
# pure-Python source file — not as a C extension (.so) or a built-in module.
# This is the primary loader identity anchor for the hashlib module.
# ---------------------------------------------------------------------------

invariant hashlib_extra61.loader_class_name_sourcefileloader:
  description: "hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — hashlib.py is a pure-Python wrapper loaded by SourceFileLoader; hashlib_extra36 covers __loader__.__class__.__name__.__len__()==16 (length axis) but no prior hashlib spec checks __eq__('SourceFileLoader'); primary loader identity anchor for hashlib"
  category: module_structure
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true
