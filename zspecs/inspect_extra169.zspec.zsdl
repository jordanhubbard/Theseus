spec: inspect_extra169
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.isbuiltin.__name__ 'isbuiltin'; inspect.isbuiltin.__module__ 'inspect'; inspect.isgenerator.__name__ 'isgenerator'; inspect.isgenerator.__module__ 'inspect'; inspect.isawaitable.__name__ 'isawaitable'; inspect.isawaitable.__module__ 'inspect'; inspect.iscoroutinefunction.__name__ 'iscoroutinefunction'; inspect.isasyncgenfunction.__name__ 'isasyncgenfunction'; inspect.isasyncgenfunction.__module__ 'inspect' (Wave 298)."
    - "inspect.isbuiltin.__name__ == 'isbuiltin' — inspect.isbuiltin is a Python function defined in Lib/inspect.py that returns True if the object is a built-in function or method (e.g., len, print, dict.get); its __name__ is 'isbuiltin'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__module__ == 'inspect' — isbuiltin is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.isgenerator.__name__ == 'isgenerator' — inspect.isgenerator is a Python function defined in Lib/inspect.py that returns True if the object is a generator object; its __name__ is 'isgenerator'. Verified with Python 3.14.3."
    - "inspect.isgenerator.__module__ == 'inspect' — isgenerator is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.isawaitable.__name__ == 'isawaitable' — inspect.isawaitable is a Python function defined in Lib/inspect.py that returns True if the object can be used in an await expression; its __name__ is 'isawaitable'. Verified with Python 3.14.3."
    - "inspect.isawaitable.__module__ == 'inspect' — isawaitable is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction' — inspect.iscoroutinefunction is a Python function defined in Lib/inspect.py that returns True if the object is a coroutine function (async def); its __name__ is 'iscoroutinefunction'. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__module__ == 'inspect' — iscoroutinefunction is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction.__name__ == 'isasyncgenfunction' — inspect.isasyncgenfunction is a Python function defined in Lib/inspect.py that returns True if the object is an asynchronous generator function; its __name__ is 'isasyncgenfunction'. Verified with Python 3.14.3."
    - "inspect.isasyncgenfunction.__module__ == 'inspect' — isasyncgenfunction is defined in Lib/inspect.py; its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.isbuiltin Python function identity — __name__, __module__,
# __class__.__name__
#
# Wave 298 theme: inspect.isbuiltin Python function identity — __name__,
# __module__, and __class__.__name__.
#
# inspect.isbuiltin.__name__ == 'isbuiltin'
# inspect.isbuiltin.__module__ == 'inspect'
# inspect.isbuiltin.__class__.__name__ == 'function'
# inspect.isbuiltin.__name__ != 'isgenerator'
#
# inspect.isbuiltin(object) returns True if the object is a built-in function
# or bound built-in method (e.g., len, print, dict.get, [].append). It is
# distinct from inspect.isfunction() which tests for Python-defined functions.
# It is a Python function defined in Lib/inspect.py. New to extra169.
# ---------------------------------------------------------------------------

table inspect_extra169.isbuiltin_identity:
  description: "inspect.isbuiltin: __name__ 'isbuiltin', __module__ 'inspect', __class__.__name__ 'function'; wave 298; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: inspectibui169

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_name_isbuiltin,
       "isbuiltin.__name__.__eq__",
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__name__.__eq__('isbuiltin') == True — inspect.isbuiltin is a Python function defined in Lib/inspect.py that returns True if an object is a built-in function or bound built-in method; its __name__ attribute is 'isbuiltin'; str.__eq__('isbuiltin') returns True; new to extra169"]
    - [isbuiltin_module_inspect,
       "isbuiltin.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — inspect.isbuiltin is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra169"]
    - [isbuiltin_class_name_function,
       "isbuiltin.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.isbuiltin.__class__.__name__.__eq__('function') == True — inspect.isbuiltin is a regular Python function defined in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra169"]
    - [isbuiltin_name_ne_isgenerator,
       "isbuiltin.__name__.__eq__",
       ["isgenerator"],
       false,
       "inspect.isbuiltin.__name__.__eq__('isgenerator') == False — isbuiltin.__name__ is 'isbuiltin', not 'isgenerator'; isbuiltin tests for C builtin callables while isgenerator tests for generator objects; they are distinct predicate functions; str.__eq__('isgenerator') returns False; new to extra169"]

# ---------------------------------------------------------------------------
# Table 2: inspect.isgenerator Python function identity — __name__, __module__,
# __class__.__name__
#
# Wave 298 theme: inspect.isgenerator Python function identity — __name__,
# __module__, and __class__.__name__.
#
# inspect.isgenerator.__name__ == 'isgenerator'
# inspect.isgenerator.__module__ == 'inspect'
# inspect.isgenerator.__class__.__name__ == 'function'
# inspect.isgenerator.__name__ != 'isawaitable'
#
# inspect.isgenerator(object) returns True if the object is a generator object
# (the result of calling a generator function — one that contains yield). It is
# distinct from inspect.isgeneratorfunction() which tests the generator function
# itself rather than the yielded generator object. Both are Python functions in
# Lib/inspect.py. New to extra169.
# ---------------------------------------------------------------------------

table inspect_extra169.isgenerator_identity:
  description: "inspect.isgenerator: __name__ 'isgenerator', __module__ 'inspect', __class__.__name__ 'function'; wave 298; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: inspectigi169

  columns: [id, function, args, expected, description]
  rows:
    - [isgenerator_name_isgenerator,
       "isgenerator.__name__.__eq__",
       ["isgenerator"],
       true,
       "inspect.isgenerator.__name__.__eq__('isgenerator') == True — inspect.isgenerator is a Python function defined in Lib/inspect.py that returns True if an object is a generator object (the result of calling a function containing yield); its __name__ attribute is 'isgenerator'; str.__eq__('isgenerator') returns True; new to extra169"]
    - [isgenerator_module_inspect,
       "isgenerator.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isgenerator.__module__.__eq__('inspect') == True — inspect.isgenerator is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra169"]
    - [isgenerator_class_name_function,
       "isgenerator.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.isgenerator.__class__.__name__.__eq__('function') == True — inspect.isgenerator is a regular Python function defined in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra169"]
    - [isgenerator_name_ne_isawaitable,
       "isgenerator.__name__.__eq__",
       ["isawaitable"],
       false,
       "inspect.isgenerator.__name__.__eq__('isawaitable') == False — isgenerator.__name__ is 'isgenerator', not 'isawaitable'; isgenerator tests for generator objects (yield-based) while isawaitable tests for objects usable in await expressions; they are distinct predicate functions; str.__eq__('isawaitable') returns False; new to extra169"]

# ---------------------------------------------------------------------------
# Table 3: inspect.isawaitable Python function identity — __name__, __module__,
# __class__.__name__
#
# Wave 298 theme: inspect.isawaitable Python function identity — __name__,
# __module__, and __class__.__name__.
#
# inspect.isawaitable.__name__ == 'isawaitable'
# inspect.isawaitable.__module__ == 'inspect'
# inspect.isawaitable.__class__.__name__ == 'function'
# inspect.isawaitable.__name__ != 'iscoroutinefunction'
#
# inspect.isawaitable(object) returns True if the object can be used in an
# await expression: this includes coroutine objects, objects with __await__(),
# and objects for which inspect.iscoroutine() returns True. It is a Python
# function defined in Lib/inspect.py. New to extra169.
# ---------------------------------------------------------------------------

table inspect_extra169.isawaitable_identity:
  description: "inspect.isawaitable: __name__ 'isawaitable', __module__ 'inspect', __class__.__name__ 'function'; wave 298; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: inspectiai169

  columns: [id, function, args, expected, description]
  rows:
    - [isawaitable_name_isawaitable,
       "isawaitable.__name__.__eq__",
       ["isawaitable"],
       true,
       "inspect.isawaitable.__name__.__eq__('isawaitable') == True — inspect.isawaitable is a Python function defined in Lib/inspect.py that returns True if an object can be used in an await expression (coroutine objects, objects with __await__(), etc.); its __name__ attribute is 'isawaitable'; str.__eq__('isawaitable') returns True; new to extra169"]
    - [isawaitable_module_inspect,
       "isawaitable.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isawaitable.__module__.__eq__('inspect') == True — inspect.isawaitable is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra169"]
    - [isawaitable_class_name_function,
       "isawaitable.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.isawaitable.__class__.__name__.__eq__('function') == True — inspect.isawaitable is a regular Python function defined in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra169"]
    - [isawaitable_name_ne_iscoroutinefunction,
       "isawaitable.__name__.__eq__",
       ["iscoroutinefunction"],
       false,
       "inspect.isawaitable.__name__.__eq__('iscoroutinefunction') == False — isawaitable.__name__ is 'isawaitable', not 'iscoroutinefunction'; isawaitable tests whether an object can be awaited while iscoroutinefunction tests whether a callable is an async def function; they are distinct predicate functions; str.__eq__('iscoroutinefunction') returns False; new to extra169"]

# ---------------------------------------------------------------------------
# Table 4: inspect.iscoroutinefunction and inspect.isasyncgenfunction identity
#
# Wave 298 theme: inspect.iscoroutinefunction and inspect.isasyncgenfunction
# Python function identity — __name__, __module__, and __class__.__name__.
#
# inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction'
# inspect.iscoroutinefunction.__module__ == 'inspect'
# inspect.isasyncgenfunction.__name__ == 'isasyncgenfunction'
# inspect.isasyncgenfunction.__module__ == 'inspect'
#
# inspect.iscoroutinefunction(object) returns True if the object is an async
# def function (a coroutine function). inspect.isasyncgenfunction(object) returns
# True if the object is an asynchronous generator function (an async def function
# containing yield). Both are Python functions in Lib/inspect.py. New to extra169.
# ---------------------------------------------------------------------------

table inspect_extra169.iscoroutinefn_isasyncgenfn_identity:
  description: "inspect.iscoroutinefunction and isasyncgenfunction: __name__ and __module__ 'inspect'; wave 298; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: inspectcfagf169

  columns: [id, function, args, expected, description]
  rows:
    - [iscoroutinefn_name,
       "iscoroutinefunction.__name__.__eq__",
       ["iscoroutinefunction"],
       true,
       "inspect.iscoroutinefunction.__name__.__eq__('iscoroutinefunction') == True — inspect.iscoroutinefunction is a Python function defined in Lib/inspect.py that returns True if an object is an async def coroutine function; its __name__ attribute is 'iscoroutinefunction'; str.__eq__('iscoroutinefunction') returns True; new to extra169"]
    - [iscoroutinefn_module_inspect,
       "iscoroutinefunction.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.iscoroutinefunction.__module__.__eq__('inspect') == True — inspect.iscoroutinefunction is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra169"]
    - [isasyncgenfn_name,
       "isasyncgenfunction.__name__.__eq__",
       ["isasyncgenfunction"],
       true,
       "inspect.isasyncgenfunction.__name__.__eq__('isasyncgenfunction') == True — inspect.isasyncgenfunction is a Python function defined in Lib/inspect.py that returns True if an object is an asynchronous generator function (async def with yield); its __name__ attribute is 'isasyncgenfunction'; str.__eq__('isasyncgenfunction') returns True; new to extra169"]
    - [isasyncgenfn_module_inspect,
       "isasyncgenfunction.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isasyncgenfunction.__module__.__eq__('inspect') == True — inspect.isasyncgenfunction is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra169"]

# ---------------------------------------------------------------------------
# Table 5: cross-checks — all eight new predicate functions are distinct and
# share module 'inspect'
#
# Wave 298 theme: cross-checks confirming that isbuiltin, isgenerator,
# isawaitable, iscoroutinefunction, isasyncgenfunction all have distinct names
# and none has __module__ 'builtins'.
#
# inspect.isbuiltin.__module__ != 'builtins'
# inspect.isgenerator.__module__ != 'builtins'
# inspect.iscoroutinefunction.__name__ != 'isasyncgenfunction'
# inspect.isasyncgenfunction.__class__.__name__ == 'function'
#
# All five are Python functions defined in Lib/inspect.py. They are NOT builtins
# (unlike isinstance() or hasattr() which live in the builtins module). Their
# names are distinct; none equals another's. New to extra169.
# ---------------------------------------------------------------------------

table inspect_extra169.new_predicates_cross_checks:
  description: "inspect: isbuiltin, isgenerator __module__ != 'builtins'; iscoroutinefunction.__name__ != 'isasyncgenfunction'; isasyncgenfunction class 'function'; wave 298; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: inspectncpcc169

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_module_not_builtins,
       "isbuiltin.__module__.__eq__",
       ["builtins"],
       false,
       "inspect.isbuiltin.__module__.__eq__('builtins') == False — inspect.isbuiltin tests for C builtin callables but is itself a Python function in Lib/inspect.py with __module__ 'inspect'; it is NOT in builtins; str.__eq__('builtins') returns False; new to extra169"]
    - [isgenerator_module_not_builtins,
       "isgenerator.__module__.__eq__",
       ["builtins"],
       false,
       "inspect.isgenerator.__module__.__eq__('builtins') == False — inspect.isgenerator is defined in Lib/inspect.py with __module__ 'inspect', NOT in builtins; str.__eq__('builtins') returns False; new to extra169"]
    - [iscoroutinefn_name_ne_isasyncgenfn,
       "iscoroutinefunction.__name__.__eq__",
       ["isasyncgenfunction"],
       false,
       "inspect.iscoroutinefunction.__name__.__eq__('isasyncgenfunction') == False — iscoroutinefunction.__name__ is 'iscoroutinefunction', not 'isasyncgenfunction'; iscoroutinefunction tests for async def functions while isasyncgenfunction tests for async def functions that also contain yield; they are distinct predicate functions; str.__eq__('isasyncgenfunction') returns False; new to extra169"]
    - [isasyncgenfn_class_function,
       "isasyncgenfunction.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.isasyncgenfunction.__class__.__name__.__eq__('function') == True — inspect.isasyncgenfunction is a regular Python function defined in Lib/inspect.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra169"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra169
# ---------------------------------------------------------------------------

invariant inspect_extra169.isbuiltin_name_isbuiltin:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin' — Python function returning True if object is a C built-in function or bound built-in method; wave 298; new to extra169"
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra169.isbuiltin_module_inspect:
  description: "inspect.isbuiltin.__module__ == 'inspect' — isbuiltin is defined in Lib/inspect.py; wave 298; new to extra169"
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra169.isgenerator_name_isgenerator:
  description: "inspect.isgenerator.__name__ == 'isgenerator' — Python function returning True if object is a generator object (result of calling a yield function); wave 298; new to extra169"
  kind: python_call_eq
  function: isgenerator.__name__.__eq__
  args: ["isgenerator"]
  expected: true

invariant inspect_extra169.isgenerator_module_inspect:
  description: "inspect.isgenerator.__module__ == 'inspect' — isgenerator is defined in Lib/inspect.py; wave 298; new to extra169"
  kind: python_call_eq
  function: isgenerator.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra169.isawaitable_name_isawaitable:
  description: "inspect.isawaitable.__name__ == 'isawaitable' — Python function returning True if object can be used in an await expression; wave 298; new to extra169"
  kind: python_call_eq
  function: isawaitable.__name__.__eq__
  args: ["isawaitable"]
  expected: true

invariant inspect_extra169.isawaitable_module_inspect:
  description: "inspect.isawaitable.__module__ == 'inspect' — isawaitable is defined in Lib/inspect.py; wave 298; new to extra169"
  kind: python_call_eq
  function: isawaitable.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra169.iscoroutinefunction_name:
  description: "inspect.iscoroutinefunction.__name__ == 'iscoroutinefunction' — Python function returning True if object is an async def coroutine function; wave 298; new to extra169"
  kind: python_call_eq
  function: iscoroutinefunction.__name__.__eq__
  args: ["iscoroutinefunction"]
  expected: true

invariant inspect_extra169.isasyncgenfunction_name:
  description: "inspect.isasyncgenfunction.__name__ == 'isasyncgenfunction' — Python function returning True if object is an async def function containing yield; wave 298; new to extra169"
  kind: python_call_eq
  function: isasyncgenfunction.__name__.__eq__
  args: ["isasyncgenfunction"]
  expected: true
