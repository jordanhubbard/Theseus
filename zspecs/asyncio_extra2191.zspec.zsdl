    - ["as2191010", "asyncio.Semaphore.__dict__.__contains__", ["__exit__"], false]
    - ["as2191011", "asyncio.Semaphore.__dict__.__contains__", ["__aenter__"], false]
    - ["as2191012", "asyncio.Semaphore.__dict__.__contains__", ["__aexit__"], false]
    - ["as2191013", "asyncio.Semaphore.__dict__.__contains__", ["acquire"], true]
    - ["as2191014", "asyncio.Semaphore.__dict__.__contains__", ["release"], true]
    - ["as2191015", "asyncio.Semaphore.__dict__.__contains__", ["__wrapped__"], false]

