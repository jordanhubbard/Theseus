    - ["as2191016", "asyncio.BoundedSemaphore.__dict__.__contains__", ["acquire"], false]
    - ["as2191017", "asyncio.BoundedSemaphore.__dict__.__contains__", ["release"], true]
    - ["as2191018", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__aenter__"], false]
    - ["as2191019", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__aexit__"], false]
    - ["as2191020", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__enter__"], false]

