spec: asyncio_extra2191
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "asyncio.Lock.acquire and asyncio.Lock.release are defined directly in asyncio.Lock.__dict__."
    - "asyncio.Lock does NOT define __aenter__ or __aexit__ in its own __dict__; those are inherited from asyncio.locks._ContextManagerMixin."
    - "asyncio.Semaphore similarly defines acquire/release directly but inherits __aenter__/__aexit__ from _ContextManagerMixin."
    - "asyncio.BoundedSemaphore defines only release in its own __dict__; acquire is inherited from Semaphore."
    - "asyncio.TaskGroup defines __aenter__ and __aexit__ directly in its own __dict__ (added in Python 3.11)."
    - "asyncio.Timeout defines __aenter__ and __aexit__ directly in its own __dict__ (added in Python 3.11)."
    - "asyncio.Runner defines __enter__ and __exit__ (sync context manager) directly in its own __dict__ (added in Python 3.11)."
    - "asyncio.AbstractServer defines __aenter__ and __aexit__ directly in its own __dict__."
    - "asyncio.Task, asyncio.Future, asyncio.Event, and asyncio.Queue do not define any context manager or lock protocol in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2191.lock_protocol:
  description: "asyncio.Lock dict-presence checks — acquire/release direct, __aenter__/__aexit__ inherited from _ContextManagerMixin"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2191

  columns: [id, function, args, expected]
  rows:
    - ["as2191001", "asyncio.Lock.__dict__.__contains__", ["__enter__"], false]
    - ["as2191002", "asyncio.Lock.__dict__.__contains__", ["__exit__"], false]
    - ["as2191003", "asyncio.Lock.__dict__.__contains__", ["__aenter__"], false]
    - ["as2191004", "asyncio.Lock.__dict__.__contains__", ["__aexit__"], false]
    - ["as2191005", "asyncio.Lock.__dict__.__contains__", ["acquire"], true]
    - ["as2191006", "asyncio.Lock.__dict__.__contains__", ["release"], true]
    - ["as2191007", "asyncio.Lock.__dict__.__contains__", ["__wrapped__"], false]
    - ["as2191008", "asyncio.Lock.__dict__.__contains__", ["__closure__"], false]

