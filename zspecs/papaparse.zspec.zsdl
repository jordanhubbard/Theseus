spec: papaparse
version: ">=5.0.0"
backend: node(papaparse)

docs: https://www.papaparse.com/docs

provenance:
  derived_from:
    - "PapaParse documentation — https://www.papaparse.com/docs"
    - "Test vectors verified with papaparse via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "papaparse source"
  notes:
    - "papaparse is an npm package. Install: npm install papaparse"
    - "Papa.parse(str, config) parses a CSV string synchronously."
    - "Returns {data, errors, meta} object."
    - "header:false returns rows as arrays; header:true uses first row as field names."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns parse result object with data, errors, and meta fields."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table papaparse.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: pap

  columns: [id, args, expected]
  rows:
    - [no_header,   ["a,b\n1,2\n3,4", {"header": false}],
       {"data": [["a","b"],["1","2"],["3","4"]],
        "errors": [],
        "meta": {"delimiter": ",", "linebreak": "\n", "aborted": false,
                 "truncated": false, "cursor": 11, "renamedHeaders": null}}]
    - [with_header, ["x,y\n10,20", {"header": true}],
       {"data": [{"x": "10", "y": "20"}],
        "errors": [],
        "meta": {"delimiter": ",", "linebreak": "\n", "aborted": false,
                 "truncated": false, "cursor": 9, "renamedHeaders": null,
                 "fields": ["x", "y"]}}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:28:23Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
