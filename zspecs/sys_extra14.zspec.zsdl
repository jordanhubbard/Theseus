spec: sys_extra14
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "This spec extends sys.zspec.zsdl and prior extras through sys_extra13.zspec.zsdl."
    - "sys_extra6 covers version_info.major and version_info.minor."
    - "sys_extra13 covers implementation.version.major/minor/micro and intern.__module__."
    - "No prior sys spec covers sys.maxsize.__class__.__name__ or sys.maxsize >= 2**31 - 1."
    - "No prior sys spec covers sys.float_info.mant_dig or sys.float_info.max_exp."
    - "No prior sys spec covers sys.int_info.bits_per_digit."
    - "No prior sys spec covers sys.hash_info.width."
    - "No prior sys spec covers sys.byteorder.__class__.__name__ (type of byteorder string)."
    - "No prior sys spec covers sys.builtin_module_names.__class__.__name__ (type is 'tuple')."
    - "No prior sys spec covers sys.path.__class__.__name__ (type is 'list')."
    - "sys.maxsize is always >= 2**31 - 1 (2147483647) — guaranteed across 32-bit and 64-bit platforms."
    - "sys.float_info.mant_dig == 53 — IEEE 754 double precision mantissa bits (always 53 on CPython)."
    - "sys.float_info.max_exp == 1024 — IEEE 754 double precision max binary exponent."
    - "sys.int_info.bits_per_digit == 30 on CPython — 30-bit digits in the arbitrary precision int representation."
    - "sys.hash_info.width == 64 on 64-bit CPython — hash modulus bit width."
    - "sys.byteorder is always a str ('little' or 'big'); type is 'str' regardless of platform."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sys.maxsize — type and lower bound
#
# No prior sys spec covers sys.maxsize. It is always an int and is always
# >= 2**31 - 1 (2147483647) — the minimum guaranteed value across all
# CPython platforms (32-bit and 64-bit).
# ---------------------------------------------------------------------------

invariant sys_extra14.maxsize.is_int:
  description: "sys.maxsize.__class__.__name__ == 'int' — maxsize is always an int"
  category: attributes
  kind: python_call_eq
  function: maxsize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant sys_extra14.maxsize.ge_min:
  description: "sys.maxsize >= 2147483647 — maxsize is at least 2**31 - 1 on all platforms"
  category: attributes
  kind: python_call_eq
  function: maxsize.__ge__
  args: [2147483647]
  expected: true

# ---------------------------------------------------------------------------
# sys.float_info — IEEE 754 double precision constants
#
# No prior sys spec covers sys.float_info fields. mant_dig == 53 (mantissa
# bits in IEEE 754 double) and max_exp == 1024 (maximum binary exponent)
# are fixed by the IEEE 754 standard on all CPython platforms.
# ---------------------------------------------------------------------------

invariant sys_extra14.float_info.mant_dig:
  description: "sys.float_info.mant_dig == 53 — IEEE 754 double precision has 53 mantissa bits"
  category: float_info
  kind: python_call_eq
  function: float_info.mant_dig.__eq__
  args: [53]
  expected: true

invariant sys_extra14.float_info.max_exp:
  description: "sys.float_info.max_exp == 1024 — IEEE 754 double precision max binary exponent"
  category: float_info
  kind: python_call_eq
  function: float_info.max_exp.__eq__
  args: [1024]
  expected: true

# ---------------------------------------------------------------------------
# sys.int_info — CPython arbitrary precision int representation
#
# No prior sys spec covers sys.int_info. bits_per_digit == 30 on CPython —
# each digit in the internal representation holds 30 bits of the integer value.
# ---------------------------------------------------------------------------

invariant sys_extra14.int_info.bits_per_digit:
  description: "sys.int_info.bits_per_digit == 30 — CPython uses 30-bit digits in its int representation"
  category: int_info
  kind: python_call_eq
  function: int_info.bits_per_digit.__eq__
  args: [30]
  expected: true

# ---------------------------------------------------------------------------
# sys.hash_info — hash modulus width
#
# No prior sys spec covers sys.hash_info. width == 64 on 64-bit CPython —
# the hash modulus is 2**61 - 1 on 64-bit, using 64-bit hash values.
# ---------------------------------------------------------------------------

invariant sys_extra14.hash_info.width:
  description: "sys.hash_info.width == 64 on 64-bit CPython — hash modulus bit width"
  category: hash_info
  kind: python_call_eq
  function: hash_info.width.__eq__
  args: [64]
  expected: true

# ---------------------------------------------------------------------------
# sys.byteorder — type check
#
# No prior sys spec covers sys.byteorder type. byteorder is always a str,
# with value 'little' or 'big' depending on the platform's byte order.
# The type check is portable; the value is platform-dependent.
# ---------------------------------------------------------------------------

invariant sys_extra14.byteorder.is_str:
  description: "sys.byteorder.__class__.__name__ == 'str' — byteorder is always a str"
  category: attributes
  kind: python_call_eq
  function: byteorder.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sys.builtin_module_names — type check
#
# sys_extra10 covers builtin_module_names.__contains__ for 'sys', 'builtins',
# and '_thread'. No prior spec checks the type of builtin_module_names itself.
# It is always a tuple of strings.
# ---------------------------------------------------------------------------

invariant sys_extra14.builtin_module_names.is_tuple:
  description: "sys.builtin_module_names.__class__.__name__ == 'tuple' — builtin_module_names is always a tuple"
  category: attributes
  kind: python_call_eq
  function: builtin_module_names.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# sys.path — type check
#
# No prior sys spec covers sys.path type. sys.path is always a list of strings
# (the module search path). The type is 'list'.
# ---------------------------------------------------------------------------

invariant sys_extra14.path.is_list:
  description: "sys.path.__class__.__name__ == 'list' — sys.path is always a list"
  category: attributes
  kind: python_call_eq
  function: path.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# sys.float_info — class name
#
# No prior sys spec covers sys.float_info.__class__.__name__. It is 'float_info'
# — a C struct_sequence type defined in Python/sysmodule.c.
# ---------------------------------------------------------------------------

invariant sys_extra14.float_info.class_name:
  description: "sys.float_info.__class__.__name__ == 'float_info' — the float_info struct_sequence type"
  category: float_info
  kind: python_call_eq
  function: float_info.__class__.__name__.__eq__
  args: ["float_info"]
  expected: true

invariant sys_extra14.int_info.class_name:
  description: "sys.int_info.__class__.__name__ == 'int_info' — the int_info struct_sequence type"
  category: int_info
  kind: python_call_eq
  function: int_info.__class__.__name__.__eq__
  args: ["int_info"]
  expected: true
