spec: threading_extra323
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.Thread(target=None).__class__.__name__ == 'Thread'."
    - "daemon defaults to False for a newly constructed Thread (inherits from the creating thread, which is non-daemon in main context)."
    - "is_alive() returns False for a Thread that has not been started."
    - "name is a str; auto-generated names follow the pattern 'Thread-N' (e.g. 'Thread-1')."
    - "ident is None until the thread is started; native_id is likewise None."
    - "Thread.__doc__ is a str (class-level docstring)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread instance — class name
#
# threading.Thread(target=None) constructs a Thread. The instance's
# __class__.__name__ is 'Thread'.
# ---------------------------------------------------------------------------

invariant threading_extra323.Thread.class_name:
  description: "threading.Thread(target=None).__class__.__name__ == 'Thread'"
  category: Thread_instance
  kind: python_call_eq
  function: Thread
  args: [{target: null}]
  method: __class__
  method_args: []
  method_chain: __name__.__eq__
  method_chain_args: ["Thread"]
  expected: true

# ---------------------------------------------------------------------------
# Thread instance — daemon attribute
#
# daemon defaults to False for a new Thread constructed in the main thread
# context (which is not a daemon thread).
# ---------------------------------------------------------------------------

invariant threading_extra323.Thread.daemon_false:
  description: "threading.Thread(target=None).daemon == False by default"
  category: Thread_instance
  kind: python_call_eq
  function: Thread
  args: [{target: null}]
  method: daemon
  method_chain: __eq__
  method_chain_args: [false]
  expected: true

# ---------------------------------------------------------------------------
# Thread instance — is_alive() returns False before start
# ---------------------------------------------------------------------------

invariant threading_extra323.Thread.is_alive_false:
  description: "threading.Thread(target=None).is_alive() == False before start()"
  category: Thread_instance
  kind: python_call_eq
  function: Thread
  args: [{target: null}]
  method: is_alive
  expected: false

# ---------------------------------------------------------------------------
# Thread instance — name is a str
# ---------------------------------------------------------------------------

invariant threading_extra323.Thread.name_class:
  description: "threading.Thread(target=None).name.__class__.__name__ == 'str'"
  category: Thread_instance
  kind: python_call_eq
  function: Thread
  args: [{target: null}]
  method: name
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Thread instance — name contains 'Thread'
#
# Auto-generated names follow the pattern 'Thread-N'.
# ---------------------------------------------------------------------------

invariant threading_extra323.Thread.name_contains_thread:
  description: "threading.Thread(target=None).name.__contains__('Thread') == True"
  category: Thread_instance
  kind: python_call_eq
  function: Thread
  args: [{target: null}]
  method: name
  method_chain: __contains__
  method_chain_args: ["Thread"]
  expected: true

# ---------------------------------------------------------------------------
# Thread instance — ident is None before start
# ---------------------------------------------------------------------------

invariant threading_extra323.Thread.ident_none:
  description: "threading.Thread(target=None).ident is None before start()"
  category: Thread_instance
  kind: python_call_eq
  function: Thread
  args: [{target: null}]
  method: ident
  method_chain: __eq__
  method_chain_args: [null]
  expected: true

# ---------------------------------------------------------------------------
# Thread instance — native_id is None before start
# ---------------------------------------------------------------------------

invariant threading_extra323.Thread.native_id_none:
  description: "threading.Thread(target=None).native_id is None before start()"
  category: Thread_instance
  kind: python_call_eq
  function: Thread
  args: [{target: null}]
  method: native_id
  method_chain: __eq__
  method_chain_args: [null]
  expected: true

# ---------------------------------------------------------------------------
# Thread class — __doc__ is a str
# ---------------------------------------------------------------------------

invariant threading_extra323.Thread.doc_class_name:
  description: "threading.Thread.__doc__.__class__.__name__ == 'str'"
  category: Thread_class
  kind: python_call_eq
  function: Thread.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
