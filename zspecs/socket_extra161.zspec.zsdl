spec: socket_extra161
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra160.zspec.zsdl — covers socket.socket.bind/__listen/__accept/__close qualname strings and lengths / bind and listen are method_descriptor / accept and close are function (table + invariants)."
    - "socket_extra159.zspec.zsdl — covers socket.socket.__name__.__eq__('socket') / socket.__module__.__eq__('socket') / socket.__bases__[0].__name__/__module__ / socket.__init__.__qualname__.__eq__('socket.__init__') / socket.connect.__qualname__.__eq__('socket.connect') (table + invariants)."
    - "socket_extra158.zspec.zsdl — covers socket.AF_INET.__eq__(2) / AF_INET6.__eq__(30) / SOCK_STREAM.__eq__(1) / SOCK_DGRAM.__eq__(2) / AF_INET.__class__.__name__.__eq__('AddressFamily') / SOCK_STREAM.__class__.__name__.__eq__('SocketKind') (table + invariants)."
    - "socket_extra156.zspec.zsdl — covers socket.__spec__.__class__.__name__.__eq__('ModuleSpec') / socket.socket makefile/__setblocking/__settimeout/__getpeername/__getsockname/__setsockopt qualnames and lengths (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra160."
    - "Wave 343 theme: socket.socket method qualnames for send, recv, sendto, recvfrom — qualname strings and lengths; all four are method_descriptor (inherited from _socket.socket C class); qualname lengths: send==recv(11) < sendto(13) < recvfrom(15); send and recv tie at 11 chars; sendto is 13 chars; recvfrom is 15 chars (longest in this spec)."
    - "socket.socket.send.__qualname__ == 'socket.send'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__ == 'socket.recv'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendto.__qualname__ == 'socket.sendto'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__qualname__ == 'socket.recvfrom'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__qualname__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendto.__qualname__.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__qualname__.__len__() == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendto.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recvfrom.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.send.__qualname__ == 'socket.send' (11 chars = 'socket.'=7 + 'send'=4). send() is a method_descriptor inherited from the C base class _socket.socket (in Modules/socketmodule.c). send(data[, flags]) sends data to the socket; the socket must be connected. 'send' (4 chars) ties 'recv' (4 chars), giving both 'socket.send' and 'socket.recv' the same qualname length of 11 chars. This is the same length as 'socket.bind' (11 chars; extra160)."
    - "Note: socket.socket.recv.__qualname__ == 'socket.recv' (11 chars = 'socket.'=7 + 'recv'=4). recv() is a method_descriptor inherited from _socket.socket. recv(bufsize[, flags]) receives up to bufsize bytes from the socket. 'recv' (4 chars) ties 'send' (4 chars) at 11-char qualname length. Unlike send/recv, sendto and recvfrom are longer because they include address parameters (UDP-style)."
    - "Note: socket.socket.sendto.__qualname__ == 'socket.sendto' (13 chars = 'socket.'=7 + 'sendto'=6). sendto() is a method_descriptor inherited from _socket.socket. sendto(data, address) or sendto(data, flags, address) sends data to a specific address without requiring a connected socket (UDP style). 'sendto' (6 chars) = 'send'=4 + 'to'=2. 'socket.sendto' (13 chars) ties 'socket.listen' and 'socket.accept' (both 13 chars; extra160)."
    - "Note: socket.socket.recvfrom.__qualname__ == 'socket.recvfrom' (15 chars = 'socket.'=7 + 'recvfrom'=8). recvfrom() is a method_descriptor inherited from _socket.socket. recvfrom(bufsize[, flags]) receives up to bufsize bytes and also returns the sender's address as a (data, address) tuple. 'recvfrom' (8 chars) = 'recv'=4 + 'from'=4. 'socket.recvfrom' (15 chars) is the longest method qualname in this spec. All four methods (send/recv/sendto/recvfrom) are method_descriptor objects."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.send.__qualname__.__eq__('socket.send')
# socket.socket.recv.__qualname__.__eq__('socket.recv')
# socket.socket.sendto.__qualname__.__eq__('socket.sendto')
# socket.socket.recvfrom.__qualname__.__eq__('socket.recvfrom')
#
# Wave 343 theme: send/recv/sendto/recvfrom qualname strings.
#
# socket.send.__qualname__ == 'socket.send' (11 chars = 'socket.'=7 + 'send'=4).
# socket.recv.__qualname__ == 'socket.recv' (11 chars = 'socket.'=7 + 'recv'=4).
# socket.sendto.__qualname__ == 'socket.sendto' (13 chars = 'socket.'=7 + 'sendto'=6).
# socket.recvfrom.__qualname__ == 'socket.recvfrom' (15 chars = 'socket.'=7 + 'recvfrom'=8).
# No prior socket spec anchors send/recv/sendto/recvfrom qualnames as a table under
# socksend161. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra161.socket_send_recv_qualnames:
  description: "socket.socket.send.__qualname__.__eq__('socket.send')==True / socket.recv.__qualname__.__eq__('socket.recv')==True / socket.sendto.__qualname__.__eq__('socket.sendto')==True / socket.recvfrom.__qualname__.__eq__('socket.recvfrom')==True — send.__qualname__ is 'socket.send' (11 chars = 'socket.'=7 + 'send'=4; method_descriptor from _socket.socket; send(data[, flags]) sends to connected socket; ties 'socket.bind' from extra160 at 11 chars); recv.__qualname__ is 'socket.recv' (11 chars = 'socket.'=7 + 'recv'=4; method_descriptor; recv(bufsize[, flags]) receives bytes; ties send at 11 chars; send and recv are symmetric); sendto.__qualname__ is 'socket.sendto' (13 chars = 'socket.'=7 + 'sendto'=6; method_descriptor; sendto(data, address) UDP-style send to specific address; ties listen/accept from extra160 at 13 chars); recvfrom.__qualname__ is 'socket.recvfrom' (15 chars = 'socket.'=7 + 'recvfrom'=8; method_descriptor; recvfrom(bufsize) returns (data, address) tuple; longest in this spec); first socksend161 anchor for send/recv/sendto/recvfrom qualname strings"
  kind: python_call_eq
  category: identity
  id_prefix: socksend161

  columns: [id, function, args, expected, description]
  rows:
    - [send_qualname_socket_send,       "socket.send.__qualname__.__eq__",     ["socket.send"],     true, "socket.socket.send.__qualname__ == 'socket.send' (11 chars = 'socket.'=7 + 'send'=4; method_descriptor; sends to connected socket; ties bind at 11 chars)"]
    - [recv_qualname_socket_recv,       "socket.recv.__qualname__.__eq__",     ["socket.recv"],     true, "socket.socket.recv.__qualname__ == 'socket.recv' (11 chars = 'socket.'=7 + 'recv'=4; method_descriptor; receives bytes; ties send at 11 chars)"]
    - [sendto_qualname_socket_sendto,   "socket.sendto.__qualname__.__eq__",   ["socket.sendto"],   true, "socket.socket.sendto.__qualname__ == 'socket.sendto' (13 chars = 'socket.'=7 + 'sendto'=6; method_descriptor; UDP-style; ties listen/accept at 13)"]
    - [recvfrom_qualname_socket_recvfm, "socket.recvfrom.__qualname__.__eq__", ["socket.recvfrom"], true, "socket.socket.recvfrom.__qualname__ == 'socket.recvfrom' (15 chars = 'socket.'=7 + 'recvfrom'=8; method_descriptor; returns (data, addr) tuple; longest here)"]

# ---------------------------------------------------------------------------
# socket.socket method qualname lengths for send/recv/sendto/recvfrom
#
# Wave 343 theme: qualname length ordering for send/recv/sendto/recvfrom.
#
# socket.send.__qualname__.__len__() == 11.
# socket.recv.__qualname__.__len__() == 11.
# socket.sendto.__qualname__.__len__() == 13.
# socket.recvfrom.__qualname__.__len__() == 15.
# Length ordering: send==recv(11) < sendto(13) < recvfrom(15).
# No prior socket spec anchors send/recv/sendto/recvfrom qualname lengths as a table under
# socksend161. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra161.socket_send_recv_qualname_lengths:
  description: "socket.socket.send.__qualname__.__len__()==11 / socket.recv.__qualname__.__len__()==11 / socket.sendto.__qualname__.__len__()==13 / socket.recvfrom.__qualname__.__len__()==15 — send.__qualname__ is 11 chars ('socket.send' = 'socket.'=7 + 'send'=4; same length as 'socket.bind' from extra160 and 'socket.recv'); recv.__qualname__ is 11 chars ('socket.recv' = 'socket.'=7 + 'recv'=4; ties send; send and recv are symmetric pair); sendto.__qualname__ is 13 chars ('socket.sendto' = 'socket.'=7 + 'sendto'=6; 'sendto'=6 chars same as 'listen'=6 and 'accept'=6 from extra160; ties both at 13 chars); recvfrom.__qualname__ is 15 chars ('socket.recvfrom' = 'socket.'=7 + 'recvfrom'=8; 'recvfrom'=8 chars; longest method qualname in this spec; 2 chars longer than '__init__'=15 chars from extra159... actually equal to __init__ at 15 chars but different methods); length ordering: send==recv(11) < sendto(13) < recvfrom(15); first socksend161 anchor for these four qualname lengths"
  kind: python_call_eq
  category: identity
  id_prefix: socksend161

  columns: [id, function, args, expected, description]
  rows:
    - [send_qualname_len_11,    "socket.send.__qualname__.__len__",     [], 11, "socket.socket.send.__qualname__.__len__() is 11 ('socket.send' = 'socket.'=7 + 'send'=4; ties recv at 11; same as bind from extra160)"]
    - [recv_qualname_len_11,    "socket.recv.__qualname__.__len__",     [], 11, "socket.socket.recv.__qualname__.__len__() is 11 ('socket.recv' = 'socket.'=7 + 'recv'=4; ties send at 11; send/recv symmetric pair)"]
    - [sendto_qualname_len_13,  "socket.sendto.__qualname__.__len__",   [], 13, "socket.socket.sendto.__qualname__.__len__() is 13 ('socket.sendto' = 'socket.'=7 + 'sendto'=6; ties listen/accept from extra160 at 13)"]
    - [recvfrom_qualname_len_15,"socket.recvfrom.__qualname__.__len__", [], 15, "socket.socket.recvfrom.__qualname__.__len__() is 15 ('socket.recvfrom' = 'socket.'=7 + 'recvfrom'=8; ties __init__ from extra159 at 15 chars)"]

# ---------------------------------------------------------------------------
# socket.socket send/recv/sendto/recvfrom method types
#
# Wave 343 theme: all four are method_descriptor (C methods, not Python functions).
#
# socket.send.__class__.__name__ == 'method_descriptor'.
# socket.recv.__class__.__name__ == 'method_descriptor'.
# socket.sendto.__class__.__name__ == 'method_descriptor'.
# socket.recvfrom.__class__.__name__ == 'method_descriptor'.
# All four are inherited from _socket.socket (C extension); none are Python function overrides.
# Contrast with accept/close which are 'function' (extra160). No prior socket spec anchors
# send/recv/sendto/recvfrom __class__.__name__ as a table under socksend161.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra161.socket_send_recv_method_types:
  description: "socket.socket.send.__class__.__name__.__eq__('method_descriptor')==True / socket.recv.__class__.__name__.__eq__('method_descriptor')==True / socket.sendto.__class__.__name__.__eq__('method_descriptor')==True / socket.recvfrom.__class__.__name__.__eq__('method_descriptor')==True — all four (send/recv/sendto/recvfrom) are method_descriptor (17 chars; inherited from _socket.socket C class; not Python function overrides unlike accept/close from extra160); send.__class__.__name__ is 'method_descriptor' (17 chars; C method; inherited; same type as bind/listen from extra160 and connect from extra159); recv.__class__.__name__ is 'method_descriptor' (17 chars; same type as send; recv and send are both C methods); sendto.__class__.__name__ is 'method_descriptor' (17 chars; C method; UDP-style send); recvfrom.__class__.__name__ is 'method_descriptor' (17 chars; C method; UDP-style recv); all four tie as method_descriptor; contrast: accept/close are 'function' (8 chars; extra160); first socksend161 anchor for all four method types"
  kind: python_call_eq
  category: identity
  id_prefix: socksend161

  columns: [id, function, args, expected, description]
  rows:
    - [send_class_method_d,    "socket.send.__class__.__name__.__eq__",     ["method_descriptor"], true, "socket.socket.send.__class__.__name__ == 'method_descriptor' (17 chars; C method from _socket.socket; same type as bind/listen/connect)"]
    - [recv_class_method_d,    "socket.recv.__class__.__name__.__eq__",     ["method_descriptor"], true, "socket.socket.recv.__class__.__name__ == 'method_descriptor' (17 chars; C method; symmetric with send; both inherited from _socket.socket)"]
    - [sendto_class_method_d,  "socket.sendto.__class__.__name__.__eq__",   ["method_descriptor"], true, "socket.socket.sendto.__class__.__name__ == 'method_descriptor' (17 chars; C method; sendto for UDP; inherited from _socket.socket)"]
    - [recvfrom_class_method_d,"socket.recvfrom.__class__.__name__.__eq__", ["method_descriptor"], true, "socket.socket.recvfrom.__class__.__name__ == 'method_descriptor' (17 chars; C method; recvfrom for UDP; all four send/recv methods are method_descriptor)"]

# ---------------------------------------------------------------------------
# socket.socket.send.__qualname__.__eq__('socket.send') — standalone
#
# socket.socket.send.__qualname__ is 'socket.send' (11 chars = 'socket.'=7 + 'send'=4).
# socket.socket.send is a method_descriptor inherited from the C base class _socket.socket
# (Modules/socketmodule.c). send(data[, flags]) transmits data to the connected socket.
# Unlike sendto(), send() requires the socket to be in a connected state. 'send' (4 chars)
# ties 'recv' (4 chars), giving both 'socket.send' and 'socket.recv' qualname length 11.
# This also ties 'socket.bind' (11 chars; extra160). All four send/recv/sendto/recvfrom
# are method_descriptor objects (C methods from _socket.socket), unlike accept and close
# which are Python function overrides. No prior socket spec anchors socket.send.__qualname__
# as a standalone under socksend161. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra161.sock_send_qualname_eq:
  description: "socket.socket.send.__qualname__.__eq__('socket.send') == True — 11 chars = 'socket.'=7 + 'send'=4; method_descriptor inherited from _socket.socket (C class); send(data[, flags]) transmits to connected socket; 'send'=4 chars (ties 'recv'=4 and 'bind'=4 from extra160); qualname length ordering: send==recv(11) < sendto(13) < recvfrom(15); all four send/recv methods are method_descriptor (not Python function overrides); contrasts with accept/close (extra160) which are 'function' overrides; no prior socket spec anchors this as a standalone; first standalone under socksend161"
  category: identity
  kind: python_call_eq
  function: socket.send.__qualname__.__eq__
  args: ["socket.send"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.recv.__qualname__.__eq__('socket.recv') — standalone
#
# socket.socket.recv.__qualname__ is 'socket.recv' (11 chars = 'socket.'=7 + 'recv'=4).
# socket.socket.recv is a method_descriptor inherited from _socket.socket. recv(bufsize[, flags])
# receives up to bufsize bytes from the socket and returns a bytes object. Like send(), recv()
# operates on a connected socket. 'recv' (4 chars) ties 'send' (4 chars), giving 'socket.recv'
# (11 chars) the same qualname length as 'socket.send' (11 chars). recv and send form a
# symmetric pair: send() transmits data, recv() receives data. Both are C methods
# (method_descriptor). No prior socket spec anchors socket.recv.__qualname__ as a standalone
# under socksend161. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra161.sock_recv_qualname_eq:
  description: "socket.socket.recv.__qualname__.__eq__('socket.recv') == True — 11 chars = 'socket.'=7 + 'recv'=4; method_descriptor inherited from _socket.socket; recv(bufsize[, flags]) receives up to bufsize bytes; returns bytes object; 'recv'=4 chars (ties 'send'=4); send and recv are symmetric: send transmits, recv receives; qualname length: send==recv(11) < sendto(13) < recvfrom(15); no prior socket spec anchors this as a standalone; first standalone under socksend161"
  category: identity
  kind: python_call_eq
  function: socket.recv.__qualname__.__eq__
  args: ["socket.recv"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.sendto.__qualname__.__eq__('socket.sendto') — standalone
#
# socket.socket.sendto.__qualname__ is 'socket.sendto' (13 chars = 'socket.'=7 + 'sendto'=6).
# socket.socket.sendto is a method_descriptor inherited from _socket.socket. sendto(data, address)
# or sendto(data, flags, address) sends data to a specific address, typically used with UDP
# (SOCK_DGRAM) sockets that do not need to be connected. 'sendto' (6 chars) = 'send'=4 + 'to'=2.
# 'socket.sendto' (13 chars) ties 'socket.listen' and 'socket.accept' (both 13 chars; extra160).
# sendto is always a method_descriptor (unlike accept which is a Python function override).
# No prior socket spec anchors socket.sendto.__qualname__ as a standalone under socksend161.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra161.sock_sendto_qualname_eq:
  description: "socket.socket.sendto.__qualname__.__eq__('socket.sendto') == True — 13 chars = 'socket.'=7 + 'sendto'=6; method_descriptor inherited from _socket.socket; sendto(data, address) sends to specific address without requiring connected state; UDP-style; 'sendto'=6 chars = 'send'=4 + 'to'=2; ties 'socket.listen' and 'socket.accept' at 13 chars (extra160); sendto is method_descriptor (unlike accept which is Python 'function' override); qualname length ordering: send==recv(11) < sendto(13) < recvfrom(15); no prior socket spec anchors this as a standalone; first standalone under socksend161"
  category: identity
  kind: python_call_eq
  function: socket.sendto.__qualname__.__eq__
  args: ["socket.sendto"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.recvfrom.__qualname__.__eq__('socket.recvfrom') — standalone
#
# socket.socket.recvfrom.__qualname__ is 'socket.recvfrom' (15 chars = 'socket.'=7 + 'recvfrom'=8).
# socket.socket.recvfrom is a method_descriptor inherited from _socket.socket. recvfrom(bufsize[, flags])
# receives up to bufsize bytes and also returns the address of the sender as a (data, address) tuple.
# recvfrom() is the receiving counterpart to sendto(): sendto() sends to a specific address,
# recvfrom() receives and reports the sender's address. 'recvfrom' (8 chars) = 'recv'=4 + 'from'=4.
# 'socket.recvfrom' (15 chars) ties 'socket.__init__' (15 chars; extra159). recvfrom is always
# a method_descriptor (same type as all four send/recv/sendto/recvfrom methods).
# No prior socket spec anchors socket.recvfrom.__qualname__ as a standalone under socksend161.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra161.sock_recvfrom_qualname_eq:
  description: "socket.socket.recvfrom.__qualname__.__eq__('socket.recvfrom') == True — 15 chars = 'socket.'=7 + 'recvfrom'=8; method_descriptor inherited from _socket.socket; recvfrom(bufsize[, flags]) returns (data, address) tuple; counterpart to sendto(); 'recvfrom'=8 chars = 'recv'=4 + 'from'=4; ties 'socket.__init__' at 15 chars (extra159); longest method qualname in this spec; qualname length ordering: send==recv(11) < sendto(13) < recvfrom(15); all four send/recv/sendto/recvfrom are method_descriptor (not Python function overrides); no prior socket spec anchors this as a standalone; first standalone under socksend161"
  category: identity
  kind: python_call_eq
  function: socket.recvfrom.__qualname__.__eq__
  args: ["socket.recvfrom"]
  expected: true
