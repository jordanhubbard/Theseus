spec: multiprocessing_extra269
version: ">=3.4"
backend: python_module(multiprocessing.synchronize)

docs: https://docs.python.org/3/library/multiprocessing.html#synchronization-between-processes

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/synchronize.py"
    - "multiprocessing_extra268.zspec.zsdl — covers multiprocessing.reduction module identity and ForkingPickler/AbstractReducer class identity"
  notes:
    - "This spec covers: multiprocessing.synchronize module identity; Semaphore, Lock, Event, RLock, BoundedSemaphore, Condition class identity from multiprocessing.synchronize directly. NEW in extra269: multiprocessing.synchronize.__name__=='multiprocessing.synchronize' (len=27); Semaphore.__module__=='multiprocessing.synchronize'; Lock.__module__=='multiprocessing.synchronize'; Event.__module__=='multiprocessing.synchronize'; RLock.__module__=='multiprocessing.synchronize'; BoundedSemaphore.__module__=='multiprocessing.synchronize'; Condition.__module__=='multiprocessing.synchronize'; Semaphore.__bases__[0].__name__=='SemLock'; Lock.__bases__[0].__name__=='SemLock'; Event.__bases__[0].__name__=='object'; Condition.__bases__[0].__name__=='object'; BoundedSemaphore.__bases__[0].__name__=='Semaphore'; Semaphore.__mro__.__len__()==3; Lock.__mro__.__len__()==3; Event.__mro__.__len__()==2 (shortest); BoundedSemaphore.__mro__.__len__()==4 (deepest). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.synchronize.Event.__bases__[0].__name__ == 'object' — Event is a direct subclass of object (MRO len=2), unlike Lock and Semaphore which inherit from SemLock (MRO len=3). Event uses a Condition+Value internally, not a SemLock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__() == 4 — BoundedSemaphore's MRO is [BoundedSemaphore, Semaphore, SemLock, object] (length=4); it has the deepest MRO in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.synchronize.__name__ == 'multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.synchronize'=12). This is the longest submodule name in the multiprocessing package. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.synchronize module identity — extra269
#
# multiprocessing.synchronize.__name__             == 'multiprocessing.synchronize'
# multiprocessing.synchronize.__spec__.name        == 'multiprocessing.synchronize'
# multiprocessing.synchronize.__name__.__len__()   == 27
# ---------------------------------------------------------------------------

table multiprocessing_extra269.mp_synchronize_module_identity:
  description: "multiprocessing.synchronize module identity checks in mpsync269 namespace — multiprocessing.synchronize is defined in Lib/multiprocessing/synchronize.py; its __name__ is 'multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.synchronize'=12); __spec__.name is also 'multiprocessing.synchronize'; __name__.__len__()==27; the module contains Semaphore, BoundedSemaphore, Lock, RLock, Condition, Event (all built on top of SemLock except Event and Condition); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsync269

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,   multiprocessing.synchronize.__name__.__eq__,        ["multiprocessing.synchronize"],  true, "multiprocessing.synchronize.__name__ == 'multiprocessing.synchronize'; verified with Python 3.14.3"]
    - [mod_spec_eq,   multiprocessing.synchronize.__spec__.name.__eq__,   ["multiprocessing.synchronize"],  true, "multiprocessing.synchronize.__spec__.name == 'multiprocessing.synchronize'; verified with Python 3.14.3"]
    - [mod_name_len,  multiprocessing.synchronize.__name__.__len__,       [],                               27,   "multiprocessing.synchronize.__name__.__len__() == 27 ('multiprocessing.synchronize'=27); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.synchronize class identity — extra269
#
# Semaphore.__name__                    == 'Semaphore'
# Semaphore.__module__                  == 'multiprocessing.synchronize'
# Semaphore.__bases__[0].__name__       == 'SemLock'
# Semaphore.__mro__.__len__()           == 3
# Lock.__name__                         == 'Lock'
# Lock.__module__                       == 'multiprocessing.synchronize'
# Lock.__bases__[0].__name__            == 'SemLock'
# Lock.__mro__.__len__()                == 3
# Event.__name__                        == 'Event'
# Event.__module__                      == 'multiprocessing.synchronize'
# Event.__bases__[0].__name__           == 'object'
# Event.__mro__.__len__()               == 2
# BoundedSemaphore.__name__             == 'BoundedSemaphore'
# BoundedSemaphore.__module__           == 'multiprocessing.synchronize'
# BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
# BoundedSemaphore.__mro__.__len__()    == 4
# Condition.__name__                    == 'Condition'
# Condition.__module__                  == 'multiprocessing.synchronize'
# Condition.__bases__[0].__name__       == 'object'
# Condition.__mro__.__len__()           == 2
# RLock.__name__                        == 'RLock'
# RLock.__module__                      == 'multiprocessing.synchronize'
# RLock.__bases__[0].__name__           == 'SemLock'
# RLock.__mro__.__len__()               == 3
# ---------------------------------------------------------------------------

table multiprocessing_extra269.mp_synchronize_class_identity:
  description: "multiprocessing.synchronize class identity checks in mpsync269a namespace — all six sync primitive classes are defined in Lib/multiprocessing/synchronize.py; Semaphore inherits from SemLock (MRO len=3); Lock inherits from SemLock (MRO len=3); RLock inherits from SemLock (MRO len=3); Event inherits from object (MRO len=2, shortest); Condition inherits from object (MRO len=2, tied with Event); BoundedSemaphore inherits from Semaphore (MRO len=4, deepest); all share __module__ 'multiprocessing.synchronize' (len=27); Semaphore.__name__.__eq__('Semaphore')==True; Lock.__name__.__eq__('Lock')==True; Event.__name__.__eq__('Event')==True; RLock.__name__.__eq__('RLock')==True; BoundedSemaphore.__name__.__eq__('BoundedSemaphore')==True; Condition.__name__.__eq__('Condition')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsync269a

  columns: [id, function, args, expected, description]
  rows:
    - [sem_name_eq,    multiprocessing.synchronize.Semaphore.__name__.__eq__,                          ["Semaphore"],                    true, "multiprocessing.synchronize.Semaphore.__name__ == 'Semaphore'; verified with Python 3.14.3"]
    - [sem_mod_eq,     multiprocessing.synchronize.Semaphore.__module__.__eq__,                        ["multiprocessing.synchronize"],  true, "multiprocessing.synchronize.Semaphore.__module__ == 'multiprocessing.synchronize' (len=27); verified with Python 3.14.3"]
    - [sem_base0_eq,   "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__",           ["SemLock"],                      true, "multiprocessing.synchronize.Semaphore.__bases__[0].__name__ == 'SemLock'; verified with Python 3.14.3"]
    - [sem_mro_len,    multiprocessing.synchronize.Semaphore.__mro__.__len__,                          [],                               3,    "multiprocessing.synchronize.Semaphore.__mro__.__len__() == 3 — [Semaphore, SemLock, object]; verified with Python 3.14.3"]
    - [lock_name_eq,   multiprocessing.synchronize.Lock.__name__.__eq__,                               ["Lock"],                         true, "multiprocessing.synchronize.Lock.__name__ == 'Lock'; verified with Python 3.14.3"]
    - [lock_mod_eq,    multiprocessing.synchronize.Lock.__module__.__eq__,                             ["multiprocessing.synchronize"],  true, "multiprocessing.synchronize.Lock.__module__ == 'multiprocessing.synchronize'; verified with Python 3.14.3"]
    - [lock_base0_eq,  "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__",                ["SemLock"],                      true, "multiprocessing.synchronize.Lock.__bases__[0].__name__ == 'SemLock'; verified with Python 3.14.3"]
    - [lock_mro_len,   multiprocessing.synchronize.Lock.__mro__.__len__,                               [],                               3,    "multiprocessing.synchronize.Lock.__mro__.__len__() == 3 — [Lock, SemLock, object]; verified with Python 3.14.3"]
    - [ev_name_eq,     multiprocessing.synchronize.Event.__name__.__eq__,                              ["Event"],                        true, "multiprocessing.synchronize.Event.__name__ == 'Event'; verified with Python 3.14.3"]
    - [ev_mod_eq,      multiprocessing.synchronize.Event.__module__.__eq__,                            ["multiprocessing.synchronize"],  true, "multiprocessing.synchronize.Event.__module__ == 'multiprocessing.synchronize'; verified with Python 3.14.3"]
    - [ev_base0_eq,    "multiprocessing.synchronize.Event.__bases__[0].__name__.__eq__",               ["object"],                       true, "multiprocessing.synchronize.Event.__bases__[0].__name__ == 'object' (direct subclass, no SemLock); verified with Python 3.14.3"]
    - [ev_mro_len,     multiprocessing.synchronize.Event.__mro__.__len__,                              [],                               2,    "multiprocessing.synchronize.Event.__mro__.__len__() == 2 — [Event, object] (shortest in spec); verified with Python 3.14.3"]
    - [bs_name_eq,     multiprocessing.synchronize.BoundedSemaphore.__name__.__eq__,                   ["BoundedSemaphore"],             true, "multiprocessing.synchronize.BoundedSemaphore.__name__ == 'BoundedSemaphore'; verified with Python 3.14.3"]
    - [bs_mod_eq,      multiprocessing.synchronize.BoundedSemaphore.__module__.__eq__,                 ["multiprocessing.synchronize"],  true, "multiprocessing.synchronize.BoundedSemaphore.__module__ == 'multiprocessing.synchronize'; verified with Python 3.14.3"]
    - [bs_base0_eq,    "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__",    ["Semaphore"],                    true, "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'; verified with Python 3.14.3"]
    - [bs_mro_len,     multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__,                   [],                               4,    "multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__() == 4 — [BoundedSemaphore, Semaphore, SemLock, object] (deepest in spec); verified with Python 3.14.3"]
    - [cond_name_eq,   multiprocessing.synchronize.Condition.__name__.__eq__,                          ["Condition"],                    true, "multiprocessing.synchronize.Condition.__name__ == 'Condition'; verified with Python 3.14.3"]
    - [cond_mod_eq,    multiprocessing.synchronize.Condition.__module__.__eq__,                        ["multiprocessing.synchronize"],  true, "multiprocessing.synchronize.Condition.__module__ == 'multiprocessing.synchronize'; verified with Python 3.14.3"]
    - [cond_base0_eq,  "multiprocessing.synchronize.Condition.__bases__[0].__name__.__eq__",           ["object"],                       true, "multiprocessing.synchronize.Condition.__bases__[0].__name__ == 'object' (direct subclass, like Event); verified with Python 3.14.3"]
    - [cond_mro_len,   multiprocessing.synchronize.Condition.__mro__.__len__,                          [],                               2,    "multiprocessing.synchronize.Condition.__mro__.__len__() == 2 — [Condition, object] (tied with Event for shortest); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra269
# ---------------------------------------------------------------------------

invariant multiprocessing_extra269.synchronize_name_eq:
  description: "multiprocessing.synchronize.__name__.__eq__('multiprocessing.synchronize') returns True — the module's __name__ is 'multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.synchronize'=12); this is the longest submodule name in the multiprocessing package; compare with multiprocessing.reduction.__name__.__len__() == 25; multiprocessing.synchronize.__spec__.name is also 'multiprocessing.synchronize'; the module provides cross-process synchronization primitives built on top of SemLock; NEW in extra269: first standalone synchronize.__name__ invariant in mpsync269 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.__name__.__eq__
  args: ["multiprocessing.synchronize"]
  expected: true

invariant multiprocessing_extra269.Semaphore_module_is_synchronize:
  description: "multiprocessing.synchronize.Semaphore.__module__.__eq__('multiprocessing.synchronize') returns True — Semaphore is defined in Lib/multiprocessing/synchronize.py; its __module__ is 'multiprocessing.synchronize' (len=27); Semaphore inherits from SemLock (a C-level semaphore wrapper), giving it MRO [Semaphore, SemLock, object] (len=3); Semaphore.__qualname__ is 'Semaphore'; compare: the top-level multiprocessing.Semaphore is a factory function, while multiprocessing.synchronize.Semaphore is the actual class; NEW in extra269: first standalone Semaphore.__module__ invariant in mpsync269 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.Semaphore.__module__.__eq__
  args: ["multiprocessing.synchronize"]
  expected: true

invariant multiprocessing_extra269.Lock_module_is_synchronize:
  description: "multiprocessing.synchronize.Lock.__module__.__eq__('multiprocessing.synchronize') returns True — Lock is defined in Lib/multiprocessing/synchronize.py; its __module__ is 'multiprocessing.synchronize' (len=27, shared with all sync primitives); Lock inherits from SemLock (same as Semaphore and RLock); Lock.__mro__.__len__() is 3 ([Lock, SemLock, object]); Lock.__qualname__ is 'Lock'; Lock.__name__.__len__() is 4 ('Lock'=4, shortest class name in spec); NEW in extra269: first standalone Lock.__module__ invariant in mpsync269 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.Lock.__module__.__eq__
  args: ["multiprocessing.synchronize"]
  expected: true

invariant multiprocessing_extra269.Event_base_is_object:
  description: "multiprocessing.synchronize.Event.__bases__[0].__name__.__eq__('object') returns True — Event is a direct subclass of object (MRO [Event, object], len=2); unlike Lock, Semaphore, and RLock which inherit from SemLock, Event does not use SemLock as its base; Event uses an internal Condition and Value to implement its set/wait/clear semantics; Event.__mro__.__len__() is 2 (shortest in spec, tied with Condition); Event.__module__ is 'multiprocessing.synchronize'; Event.__qualname__ is 'Event'; NEW in extra269: first standalone Event base-is-object invariant in mpsync269 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.synchronize.Event.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra269.BoundedSemaphore_mro_len_is_4:
  description: "multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__() == 4 — BoundedSemaphore's MRO is [BoundedSemaphore, Semaphore, SemLock, object] (length=4); this is the deepest MRO in this spec; BoundedSemaphore inherits from Semaphore, which in turn inherits from SemLock; the depth reflects the specialisation: BoundedSemaphore adds an upper bound check on top of Semaphore; compare MRO depths: Event=2 and Condition=2 (shortest), Semaphore=3, Lock=3, RLock=3, BoundedSemaphore=4 (deepest); BoundedSemaphore.__module__ is 'multiprocessing.synchronize'; NEW in extra269: first standalone BoundedSemaphore MRO length invariant in mpsync269 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra269.Event_mro_len_is_2:
  description: "multiprocessing.synchronize.Event.__mro__.__len__() == 2 — Event's MRO is [Event, object] (length=2); this is the shortest MRO in this spec (tied with Condition); Event is a direct subclass of object with no SemLock base; compare MRO depths: Event=2, Condition=2, Semaphore=3, Lock=3, RLock=3, BoundedSemaphore=4; Event.__bases__[0].__name__ is 'object'; Event.__module__ is 'multiprocessing.synchronize'; Event.__name__.__len__() is 5 ('Event'=5); NEW in extra269: first standalone Event MRO length invariant in mpsync269 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.Event.__mro__.__len__
  args: []
  expected: 2
