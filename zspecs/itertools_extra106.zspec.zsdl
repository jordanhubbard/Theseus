# ---------------------------------------------------------------------------
# Table 1: itertools simple iterator type __name__ values (group 1)
#
# Wave 259 theme: itertools C-extension type __name__ string equality.
# All 18 itertools types have __name__ equal to their lowercase class name.
# This table covers: count, cycle, repeat, chain, compress, dropwhile,
# takewhile, islice, starmap, product.
#
# itertools.count.__name__ == 'count'
# itertools.cycle.__name__ == 'cycle'
# itertools.repeat.__name__ == 'repeat'
# itertools.chain.__name__ == 'chain'
# itertools.compress.__name__ == 'compress'
# itertools.dropwhile.__name__ == 'dropwhile'
# itertools.takewhile.__name__ == 'takewhile'
# itertools.islice.__name__ == 'islice'
# itertools.starmap.__name__ == 'starmap'
# itertools.product.__name__ == 'product'
#
# New to extra106.
# ---------------------------------------------------------------------------

