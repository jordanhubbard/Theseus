# ---------------------------------------------------------------------------
# Table 3: itertools type __name__ equals __qualname__ (top-level types)
#
# Wave 259 theme: for all itertools C-extension types, __name__ == __qualname__
# since they are all top-level types (not nested). This is verified by
# checking that __name__.__eq__(__qualname__) returns True.
#
# itertools.chain.__name__ == itertools.chain.__qualname__ == 'chain'
# itertools.accumulate.__name__ == itertools.accumulate.__qualname__ == 'accumulate'
# itertools.combinations.__name__ == itertools.combinations.__qualname__ == 'combinations'
# itertools.zip_longest.__name__ == itertools.zip_longest.__qualname__ == 'zip_longest'
# itertools.filterfalse.__name__ == itertools.filterfalse.__qualname__ == 'filterfalse'
# itertools.pairwise.__name__ == itertools.pairwise.__qualname__ == 'pairwise'
#
# New to extra106.
# ---------------------------------------------------------------------------

