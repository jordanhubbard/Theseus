spec: ab3016
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 648 — theme: __iter__, __next__, __reversed__ dict-presence (iterator protocol)."
    - "Tests operator.contains(SomeClass.__dict__, '__iter__') etc. for abc module classes."
    - "Classes covered: ABC, ABCMeta, abstractmethod, abstractproperty, abstractclassmethod, abstractstaticmethod."
    - "None of these abc classes define __iter__, __next__, or __reversed__ in their own __dict__."
    - "abc.ABC is the convenience base class; its __dict__ has no iterator protocol slots."
    - "abc.ABCMeta is the metaclass; it defines abstract method tracking machinery, not iteration."
    - "abc.abstractmethod is a decorator class; its instances wrap callables and expose no iteration."
    - "abstractproperty, abstractclassmethod, abstractstaticmethod are deprecated since Python 3.3 but still present in CPython 3.14 with no iterator slots."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# No abc class defines __iter__; all results are false.
# abc classes are metaclass machinery and decorator helpers, not sequences.
# ---------------------------------------------------------------------------

table ab3016.iter:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: iter_iter
  id_prefix: it

  columns: [id, function, args, expected]
  rows:
    - ["it_ABC",                  operator.contains, [ABC.__dict__,                  "__iter__"], false]
    - ["it_ABCMeta",              operator.contains, [ABCMeta.__dict__,              "__iter__"], false]
    - ["it_abstractmethod",       operator.contains, [abstractmethod.__dict__,       "__iter__"], false]
    - ["it_abstractproperty",     operator.contains, [abstractproperty.__dict__,     "__iter__"], false]
    - ["it_abstractclassmethod",  operator.contains, [abstractclassmethod.__dict__,  "__iter__"], false]
    - ["it_abstractstaticmethod", operator.contains, [abstractstaticmethod.__dict__, "__iter__"], false]

# ---------------------------------------------------------------------------
# __next__ dict-presence — operator.contains(Cls.__dict__, '__next__')
#
# No abc class defines __next__; all results are false.
# ---------------------------------------------------------------------------

table ab3016.next:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: iter_next
  id_prefix: nx

  columns: [id, function, args, expected]
  rows:
    - ["nx_ABC",                  operator.contains, [ABC.__dict__,                  "__next__"], false]
    - ["nx_ABCMeta",              operator.contains, [ABCMeta.__dict__,              "__next__"], false]
    - ["nx_abstractmethod",       operator.contains, [abstractmethod.__dict__,       "__next__"], false]
    - ["nx_abstractproperty",     operator.contains, [abstractproperty.__dict__,     "__next__"], false]
    - ["nx_abstractclassmethod",  operator.contains, [abstractclassmethod.__dict__,  "__next__"], false]
    - ["nx_abstractstaticmethod", operator.contains, [abstractstaticmethod.__dict__, "__next__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — operator.contains(Cls.__dict__, '__reversed__')
#
# No abc class defines __reversed__; all results are false.
# abc metaclass machinery has no concept of ordered reversal.
# ---------------------------------------------------------------------------

table ab3016.reversed:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: iter_reversed
  id_prefix: rv

  columns: [id, function, args, expected]
  rows:
    - ["rv_ABC",                  operator.contains, [ABC.__dict__,                  "__reversed__"], false]
    - ["rv_ABCMeta",              operator.contains, [ABCMeta.__dict__,              "__reversed__"], false]
    - ["rv_abstractmethod",       operator.contains, [abstractmethod.__dict__,       "__reversed__"], false]
    - ["rv_abstractproperty",     operator.contains, [abstractproperty.__dict__,     "__reversed__"], false]
    - ["rv_abstractclassmethod",  operator.contains, [abstractclassmethod.__dict__,  "__reversed__"], false]
    - ["rv_abstractstaticmethod", operator.contains, [abstractstaticmethod.__dict__, "__reversed__"], false]

# ---------------------------------------------------------------------------
# combined — all three iterator protocol methods across all abc classes
#
# Confirms no abc class exposes any part of the iterator protocol in its
# own __dict__.  6 classes x 3 methods = 18 rows.
# ---------------------------------------------------------------------------

table ab3016.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: iter_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_ABC_it",                  operator.contains, [ABC.__dict__,                  "__iter__"],     false]
    - ["comb_ABC_nx",                  operator.contains, [ABC.__dict__,                  "__next__"],     false]
    - ["comb_ABC_rv",                  operator.contains, [ABC.__dict__,                  "__reversed__"], false]
    - ["comb_ABCMeta_it",              operator.contains, [ABCMeta.__dict__,              "__iter__"],     false]
    - ["comb_ABCMeta_nx",              operator.contains, [ABCMeta.__dict__,              "__next__"],     false]
    - ["comb_ABCMeta_rv",              operator.contains, [ABCMeta.__dict__,              "__reversed__"], false]
    - ["comb_abstractmethod_it",       operator.contains, [abstractmethod.__dict__,       "__iter__"],     false]
    - ["comb_abstractmethod_nx",       operator.contains, [abstractmethod.__dict__,       "__next__"],     false]
    - ["comb_abstractmethod_rv",       operator.contains, [abstractmethod.__dict__,       "__reversed__"], false]
    - ["comb_abstractproperty_it",     operator.contains, [abstractproperty.__dict__,     "__iter__"],     false]
    - ["comb_abstractproperty_nx",     operator.contains, [abstractproperty.__dict__,     "__next__"],     false]
    - ["comb_abstractproperty_rv",     operator.contains, [abstractproperty.__dict__,     "__reversed__"], false]
    - ["comb_abstractclassmethod_it",  operator.contains, [abstractclassmethod.__dict__,  "__iter__"],     false]
    - ["comb_abstractclassmethod_nx",  operator.contains, [abstractclassmethod.__dict__,  "__next__"],     false]
    - ["comb_abstractclassmethod_rv",  operator.contains, [abstractclassmethod.__dict__,  "__reversed__"], false]
    - ["comb_abstractstatic_it",       operator.contains, [abstractstaticmethod.__dict__, "__iter__"],     false]
    - ["comb_abstractstatic_nx",       operator.contains, [abstractstaticmethod.__dict__, "__next__"],     false]
    - ["comb_abstractstatic_rv",       operator.contains, [abstractstaticmethod.__dict__, "__reversed__"], false]
