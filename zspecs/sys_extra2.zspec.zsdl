spec: sys_extra2
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "Python 3 sys module documentation — https://docs.python.org/3/library/sys.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "This spec provides additional invariants for the sys module."
    - "sys.version.__class__.__name__ == 'str' — the full version string is always a str."
    - "sys.platform.__class__.__name__ == 'str' — platform identifier is always a str."
    - "sys.maxsize.__class__.__name__ == 'int' — max integer size is an int."
    - "sys.maxunicode.__class__.__name__ == 'int' — max Unicode code point is an int."
    - "sys.maxunicode == 1114111 — always 0x10FFFF on all modern Python builds."
    - "sys.byteorder.__class__.__name__ == 'str' — 'little' or 'big', always a str."
    - "sys.builtin_module_names.__class__.__name__ == 'tuple' — immutable tuple of built-in module names."
    - "sys.getrecursionlimit.__name__ == 'getrecursionlimit'."
    - "sys.setrecursionlimit.__name__ == 'setrecursionlimit'."
    - "sys.getdefaultencoding.__name__ == 'getdefaultencoding'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module attribute type checks
# ---------------------------------------------------------------------------

invariant sys_extra2.version.class_name:
  description: "sys.version.__class__.__name__ == 'str'"
  category: attributes
  kind: python_call_eq
  function: version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sys_extra2.platform.class_name:
  description: "sys.platform.__class__.__name__ == 'str'"
  category: attributes
  kind: python_call_eq
  function: platform.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sys_extra2.maxsize.class_name:
  description: "sys.maxsize.__class__.__name__ == 'int'"
  category: attributes
  kind: python_call_eq
  function: maxsize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant sys_extra2.maxunicode.class_name:
  description: "sys.maxunicode.__class__.__name__ == 'int'"
  category: attributes
  kind: python_call_eq
  function: maxunicode.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant sys_extra2.maxunicode.value:
  description: "sys.maxunicode == 1114111"
  category: attributes
  kind: python_call_eq
  function: maxunicode.__eq__
  args: [1114111]
  expected: true

invariant sys_extra2.byteorder.class_name:
  description: "sys.byteorder.__class__.__name__ == 'str'"
  category: attributes
  kind: python_call_eq
  function: byteorder.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sys_extra2.builtin_module_names.class_name:
  description: "sys.builtin_module_names.__class__.__name__ == 'tuple'"
  category: attributes
  kind: python_call_eq
  function: builtin_module_names.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# Built-in function name checks
# ---------------------------------------------------------------------------

invariant sys_extra2.getrecursionlimit.name:
  description: "sys.getrecursionlimit.__name__ == 'getrecursionlimit'"
  category: functions
  kind: python_call_eq
  function: getrecursionlimit.__name__.__eq__
  args: ["getrecursionlimit"]
  expected: true

invariant sys_extra2.setrecursionlimit.name:
  description: "sys.setrecursionlimit.__name__ == 'setrecursionlimit'"
  category: functions
  kind: python_call_eq
  function: setrecursionlimit.__name__.__eq__
  args: ["setrecursionlimit"]
  expected: true

invariant sys_extra2.getdefaultencoding.name:
  description: "sys.getdefaultencoding.__name__ == 'getdefaultencoding'"
  category: functions
  kind: python_call_eq
  function: getdefaultencoding.__name__.__eq__
  args: ["getdefaultencoding"]
  expected: true
