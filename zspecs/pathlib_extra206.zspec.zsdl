spec: pathlib_extra206
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/parts/parent/joinpath/str/as_posix/relative_to"
    - "pathlib_extra.zspec.zsdl — covers Path/PurePosixPath class names, modules, components, predicates"
  notes:
    - "This spec covers pathlib class and method __doc__.__class__.__name__ identity not covered by prior pathlib_extra specs."
    - "pathlib.Path.__doc__.__class__.__name__ == 'str'; the concrete path class has a str docstring; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__doc__.__class__.__name__ == 'str'; the abstract pure path base has a str docstring; confirmed Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__doc__.__class__.__name__ == 'str'; pure POSIX path has a str docstring; confirmed Python 3.14.3 macOS."
    - "pathlib.PureWindowsPath.__doc__.__class__.__name__ == 'str'; pure Windows path has a str docstring; confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__doc__.__class__.__name__ == 'str'; concrete POSIX path has a str docstring; confirmed Python 3.14.3 macOS."
    - "pathlib.WindowsPath.__doc__.__class__.__name__ == 'str'; concrete Windows path has a str docstring; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.open.__doc__.__class__.__name__ == 'str'; Path.open() method has a str docstring; confirmed Python 3.14.3 macOS."
    - "pathlib.Path.glob.__doc__.__class__.__name__ == 'str'; Path.glob() method has a str docstring; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib pure path class __doc__.__class__.__name__ identity
# PurePath, PurePosixPath, PureWindowsPath — all 'str'
# ---------------------------------------------------------------------------

table pathlib_extra206.pure_path_doc_class_names:
  description: "pathlib pure path class __doc__.__class__.__name__: PurePath, PurePosixPath, PureWindowsPath — all 'str'"
  kind: python_call_eq
  category: doc_identity
  id_prefix: pathlibdocs206

  columns: [id, function, args, expected, description]
  rows:
    - [purepath_doc_class_name,       pathlib.PurePath.__doc__.__class__.__name__.__eq__,       ["str"], true, "pathlib.PurePath.__doc__.__class__.__name__ == 'str'; abstract base for all pure path classes; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [pureposixpath_doc_class_name,  pathlib.PurePosixPath.__doc__.__class__.__name__.__eq__,  ["str"], true, "pathlib.PurePosixPath.__doc__.__class__.__name__ == 'str'; pure POSIX path class requiring no filesystem access; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [purewindowspath_doc_class_name, pathlib.PureWindowsPath.__doc__.__class__.__name__.__eq__, ["str"], true, "pathlib.PureWindowsPath.__doc__.__class__.__name__ == 'str'; pure Windows path class requiring no filesystem access; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [purepath_doc_class_name_len,   pathlib.PurePath.__doc__.__class__.__name__.__len__,       [], 3, "pathlib.PurePath.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]
    - [pureposixpath_doc_class_name_len, pathlib.PurePosixPath.__doc__.__class__.__name__.__len__, [], 3, "pathlib.PurePosixPath.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib concrete path class __doc__.__class__.__name__ identity
# Path, PosixPath, WindowsPath — all 'str'
# ---------------------------------------------------------------------------

table pathlib_extra206.concrete_path_doc_class_names:
  description: "pathlib concrete path class __doc__.__class__.__name__: Path, PosixPath, WindowsPath — all 'str'"
  kind: python_call_eq
  category: doc_identity
  id_prefix: pathlibdocs206

  columns: [id, function, args, expected, description]
  rows:
    - [path_doc_class_name,        pathlib.Path.__doc__.__class__.__name__.__eq__,        ["str"], true, "pathlib.Path.__doc__.__class__.__name__ == 'str'; main concrete path class; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [posixpath_doc_class_name,   pathlib.PosixPath.__doc__.__class__.__name__.__eq__,   ["str"], true, "pathlib.PosixPath.__doc__.__class__.__name__ == 'str'; concrete POSIX path class for Unix systems; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [windowspath_doc_class_name, pathlib.WindowsPath.__doc__.__class__.__name__.__eq__, ["str"], true, "pathlib.WindowsPath.__doc__.__class__.__name__ == 'str'; concrete Windows path class; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [path_doc_class_name_len,    pathlib.Path.__doc__.__class__.__name__.__len__,        [], 3, "pathlib.Path.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]
    - [posixpath_doc_class_name_len, pathlib.PosixPath.__doc__.__class__.__name__.__len__, [], 3, "pathlib.PosixPath.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib Path method __doc__.__class__.__name__ identity
# Path.open, Path.glob — all 'str'
# ---------------------------------------------------------------------------

table pathlib_extra206.path_method_doc_class_names:
  description: "pathlib Path method __doc__.__class__.__name__: Path.open, Path.glob — all 'str'"
  kind: python_call_eq
  category: doc_identity
  id_prefix: pathlibdocs206

  columns: [id, function, args, expected, description]
  rows:
    - [path_open_doc_class_name,  pathlib.Path.open.__doc__.__class__.__name__.__eq__,  ["str"], true, "pathlib.Path.open.__doc__.__class__.__name__ == 'str'; Path.open() opens the file in the given mode; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [path_glob_doc_class_name,  pathlib.Path.glob.__doc__.__class__.__name__.__eq__,  ["str"], true, "pathlib.Path.glob.__doc__.__class__.__name__ == 'str'; Path.glob() iterates over matching paths; docstring is a str; confirmed Python 3.14.3 macOS"]
    - [path_open_doc_class_name_len, pathlib.Path.open.__doc__.__class__.__name__.__len__, [], 3, "pathlib.Path.open.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]
    - [path_glob_doc_class_name_len, pathlib.Path.glob.__doc__.__class__.__name__.__len__, [], 3, "pathlib.Path.glob.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]
    - [windowspath_doc_class_name_len, pathlib.WindowsPath.__doc__.__class__.__name__.__len__, [], 3, "pathlib.WindowsPath.__doc__.__class__.__name__.__len__() == 3 — 'str' has s(1)t(2)r(3); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra206.path_doc_class_name:
  description: "pathlib.Path.__doc__.__class__.__name__ == 'str' — main concrete path class; __doc__ is a non-None str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: pathlib.Path.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra206.purepath_doc_class_name:
  description: "pathlib.PurePath.__doc__.__class__.__name__ == 'str' — abstract base for all pure path classes; __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: pathlib.PurePath.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra206.pureposixpath_doc_class_name:
  description: "pathlib.PurePosixPath.__doc__.__class__.__name__ == 'str' — pure POSIX path requiring no filesystem access; __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: pathlib.PurePosixPath.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra206.purewindowspath_doc_class_name:
  description: "pathlib.PureWindowsPath.__doc__.__class__.__name__ == 'str' — pure Windows path requiring no filesystem access; __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: pathlib.PureWindowsPath.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra206.posixpath_doc_class_name:
  description: "pathlib.PosixPath.__doc__.__class__.__name__ == 'str' — concrete POSIX path for Unix systems; __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: pathlib.PosixPath.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra206.windowspath_doc_class_name:
  description: "pathlib.WindowsPath.__doc__.__class__.__name__ == 'str' — concrete Windows path class; __doc__ is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: pathlib.WindowsPath.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra206.path_open_doc_class_name:
  description: "pathlib.Path.open.__doc__.__class__.__name__ == 'str' — Path.open() method docstring is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: pathlib.Path.open.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra206.path_glob_doc_class_name:
  description: "pathlib.Path.glob.__doc__.__class__.__name__ == 'str' — Path.glob() method docstring is a str; confirmed Python 3.14.3 macOS"
  category: doc_identity
  kind: python_call_eq
  function: pathlib.Path.glob.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
