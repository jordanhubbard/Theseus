spec: theseus_email_utils_cr
version: ">=3.0"
backend: python_cleanroom(theseus_email_utils_cr)
blocks: email.utils

docs: https://docs.python.org/3/library/email.utils.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.utils.html"
  not_derived_from:
    - "CPython source: Lib/email/utils.py"
  notes:
    - "Clean-room email.utils module. Do NOT import email.utils."

error_model: python_exceptions

invariant theseus_email_utils_cr.emailutils2_parseaddr:
  description: "parseaddr() parses 'Name <addr>' format"
  category: behavior
  kind: python_call_eq
  function: emailutils2_parseaddr
  args: []
  expected: true

invariant theseus_email_utils_cr.emailutils2_formataddr:
  description: "formataddr() formats (name, addr) tuple"
  category: behavior
  kind: python_call_eq
  function: emailutils2_formataddr
  args: []
  expected: true

invariant theseus_email_utils_cr.emailutils2_mktime_tz:
  description: "mktime_tz() converts tuple to timestamp"
  category: behavior
  kind: python_call_eq
  function: emailutils2_mktime_tz
  args: []
  expected: true
