spec: socket_extra721
version: ">=3.9"
backend: python_module(socket)
docs: "Behavioral spec covering socket class and exception qualnames"
error_model: python_exceptions

provenance:
  derived_from: "socket stdlib documentation and CPython source"
  not_derived_from: "any third-party socket extension"
  notes: "socket.error is an alias for OSError; timeout, gaierror, herror are subclasses defined in socket module; AddressFamily and SocketKind are IntEnum subclasses"
  created_at: "2026-04-12"

table socket_extra721.socket_qualnames:
  description: "socket class and exception qualnames and module attributes"
  kind: python_call_eq
  category: qualname
  id_prefix: sk721qn
  columns: [id, function, args, expected]
  rows:
    - [sk721qn001, socket.socket.__qualname__.__eq__, ["socket"], true]
    - [sk721qn002, socket.socket.__module__.__eq__, ["socket"], true]
    - [sk721qn003, socket.error.__qualname__.__eq__, ["OSError"], true]
    - [sk721qn004, socket.timeout.__qualname__.__eq__, ["timeout"], true]
    - [sk721qn005, socket.timeout.__module__.__eq__, ["socket"], true]
    - [sk721qn006, socket.gaierror.__qualname__.__eq__, ["gaierror"], true]
    - [sk721qn007, socket.gaierror.__module__.__eq__, ["socket"], true]
    - [sk721qn008, socket.herror.__qualname__.__eq__, ["herror"], true]
    - [sk721qn009, socket.herror.__module__.__eq__, ["socket"], true]
    - [sk721qn010, socket.AddressFamily.__qualname__.__eq__, ["AddressFamily"], true]
    - [sk721qn011, socket.AddressFamily.__module__.__eq__, ["socket"], true]
    - [sk721qn012, socket.SocketKind.__qualname__.__eq__, ["SocketKind"], true]
