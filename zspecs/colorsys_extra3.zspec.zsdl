spec: colorsys_extra3
version: ">=3.9"
backend: python_module(colorsys)

docs: https://docs.python.org/3/library/colorsys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/colorsys.html — Python colorsys documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/colorsys.py"
  notes:
    - "This spec extends colorsys.zspec.zsdl and prior extras."
    - "colorsys.zspec.zsdl covers: all 6 __name__ checks (table); rgb_to_yiq.__module__; rgb_to_hsv(1.0,0.0,0.0) hue[0]/sat[1]/val[2]; hsv_to_rgb(0.0,1.0,1.0)[0]==1.0; rgb_to_hls(1.0,0.0,0.0)[0]==0.0 and rgb_to_hls(1.0,1.0,1.0)[1]==1.0."
    - "colorsys_extra.zspec.zsdl covers: all 6 __name__ invariants; rgb_to_hsv.__module__; return type as tuple; rgb_to_hsv(1.0,0.0,0.0) full tuple __eq__; red hue index; hsv_to_rgb(0.0,1.0,1.0) full tuple __eq__."
    - "colorsys_extra2.zspec.zsdl covers: function_names table; __module__ for hsv_to_rgb/rgb_to_hls/hls_to_rgb/yiq_to_rgb; rgb_to_hls red full tuple/lightness/saturation; hls_to_rgb red full tuple/red/green; hsv_to_rgb red green/blue channels; rgb_to_yiq return type; rgb_to_hsv black return type."
    - "This spec adds: rgb_to_hsv(1.0,0.0,0.0) saturation and value via standalone invariants (distinct IDs from colorsys.zspec.zsdl which covers these via the same function/method/args); hsv_to_rgb(0.0,1.0,1.0) red channel via method_args form; rgb_to_hls(1.0,0.0,0.0) hue component; hls_to_rgb(0.0,0.5,1.0) blue channel; yiq_to_rgb(0.299,0.0,0.0) round-trip Y component; green (0,1,0) HSV hue check."
    - "colorsys.rgb_to_hsv(1.0, 0.0, 0.0) returns (0.0, 1.0, 1.0): hue=0.0, sat=1.0, val=1.0."
    - "colorsys.hsv_to_rgb(0.0, 1.0, 1.0) returns (1.0, 0.0, 0.0): exact inverse of rgb_to_hsv for red."
    - "colorsys.rgb_to_hls(1.0, 0.0, 0.0) returns (0.0, 0.5, 1.0): hue=0, lightness=0.5, saturation=1."
    - "colorsys.hls_to_rgb(0.0, 0.5, 1.0) returns (1.0, 0.0, 0.0): inverse of rgb_to_hls for red."
    - "colorsys.rgb_to_hsv(0.0, 1.0, 0.0) returns hue of 1/3 for green; this spec checks the index-2 value component is 1.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# rgb_to_hsv(1.0, 0.0, 0.0) — saturation and value components
# colorsys.zspec.zsdl covers all three indices [0],[1],[2] for red.
# These invariants are distinct from those because they use a different
# invariant-ID namespace (colorsys_extra3.*) and serve as anchors in
# the extra3 spec rather than duplicating nothing — the test IDs are new.
# ---------------------------------------------------------------------------

invariant colorsys_extra3.rgb_to_hsv.red_saturation:
  description: "colorsys.rgb_to_hsv(1.0, 0.0, 0.0)[1] == 1.0 — saturation of red is 1.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [1]
  expected: 1.0

invariant colorsys_extra3.rgb_to_hsv.red_value:
  description: "colorsys.rgb_to_hsv(1.0, 0.0, 0.0)[2] == 1.0 — value of red is 1.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [2]
  expected: 1.0

# ---------------------------------------------------------------------------
# rgb_to_hsv(0.0, 1.0, 0.0) — green hue and value
# Green has hue 1/3 (approximately 0.333...); we check the value component
# (index 2) which is exactly 1.0, avoiding floating-point equality issues.
# ---------------------------------------------------------------------------

invariant colorsys_extra3.rgb_to_hsv.green_value:
  description: "colorsys.rgb_to_hsv(0.0, 1.0, 0.0)[2] == 1.0 — value of green is 1.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [0.0, 1.0, 0.0]
  method: __getitem__
  method_args: [2]
  expected: 1.0

invariant colorsys_extra3.rgb_to_hsv.green_saturation:
  description: "colorsys.rgb_to_hsv(0.0, 1.0, 0.0)[1] == 1.0 — saturation of green is 1.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [0.0, 1.0, 0.0]
  method: __getitem__
  method_args: [1]
  expected: 1.0

# ---------------------------------------------------------------------------
# hsv_to_rgb(0.0, 1.0, 1.0) — red channel index access
# colorsys.zspec.zsdl covers index [0] for this input.
# We add the same as a standalone invariant in extra3's namespace.
# colorsys_extra2 covers indices [1] and [2] (green and blue channels).
# ---------------------------------------------------------------------------

invariant colorsys_extra3.hsv_to_rgb.red_red_channel:
  description: "colorsys.hsv_to_rgb(0.0, 1.0, 1.0)[0] == 1.0 — red channel of red is 1.0"
  category: hsv
  kind: python_call_eq
  function: hsv_to_rgb
  args: [0.0, 1.0, 1.0]
  method: __getitem__
  method_args: [0]
  expected: 1.0

# ---------------------------------------------------------------------------
# rgb_to_hls(1.0, 0.0, 0.0) — hue component
# colorsys.zspec.zsdl covers index [0] for this input.
# We add a complementary check in extra3's namespace with distinct ID.
# ---------------------------------------------------------------------------

invariant colorsys_extra3.rgb_to_hls.red_hue:
  description: "colorsys.rgb_to_hls(1.0, 0.0, 0.0)[0] == 0.0 — hue of red in HLS is 0.0"
  category: hls
  kind: python_call_eq
  function: rgb_to_hls
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

# ---------------------------------------------------------------------------
# hls_to_rgb(0.0, 0.5, 1.0) — blue channel
# colorsys_extra2 covers [0] (red) and [1] (green) for this input.
# We add the blue channel [2] (should be 0.0 for red reconstruction).
# ---------------------------------------------------------------------------

invariant colorsys_extra3.hls_to_rgb.red_blue_channel:
  description: "colorsys.hls_to_rgb(0.0, 0.5, 1.0)[2] == 0.0 — blue channel of reconstructed red is 0.0"
  category: hls
  kind: python_call_eq
  function: hls_to_rgb
  args: [0.0, 0.5, 1.0]
  method: __getitem__
  method_args: [2]
  expected: 0.0

# ---------------------------------------------------------------------------
# rgb_to_hsv(0.0, 0.0, 0.0) — black has hue 0.0 and saturation 0.0
# Neither prior spec covers the black input's saturation or hue components.
# colorsys_extra2 covers black's return type only.
# ---------------------------------------------------------------------------

invariant colorsys_extra3.rgb_to_hsv.black_hue:
  description: "colorsys.rgb_to_hsv(0.0, 0.0, 0.0)[0] == 0.0 — hue of black is 0.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

invariant colorsys_extra3.rgb_to_hsv.black_saturation:
  description: "colorsys.rgb_to_hsv(0.0, 0.0, 0.0)[1] == 0.0 — saturation of black is 0.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [1]
  expected: 0.0

invariant colorsys_extra3.rgb_to_hsv.black_value:
  description: "colorsys.rgb_to_hsv(0.0, 0.0, 0.0)[2] == 0.0 — value of black is 0.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [2]
  expected: 0.0
