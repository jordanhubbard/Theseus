spec: hmac_extra6
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hmac.html — Python hmac documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
  notes:
    - "This spec extends codecs.zspec.zsdl and prior extras."
    - "hmac_extra covers: HMAC.__name__, HMAC.__module__, new/digest/compare_digest __name__ table."
    - "hmac_extra2 covers: HMAC.__name__, HMAC.__module__, new/digest/compare_digest __module__, HMAC.__bases__[0].__name__ == 'object'."
    - "hmac_extra4 covers: HMAC.__name__, HMAC.__module__, new/digest/compare_digest __name__ table."
    - "hmac_extra5 covers: HMAC.__qualname__, new/__qualname__, compare_digest/__qualname__, digest/__qualname__."
    - "This spec adds new coverage: HMAC.__bases__ length check, HMAC.__mro__ entries, new.__module__ standalone anchor, digest.__module__ standalone anchor, HMAC.__doc__ class (hmac_extra5 covers has_doc but not __doc__.__class__.__name__ here from extra6), hmac.new() with sha512 (not used in any prior spec)."
    - "hmac.HMAC.__name__ == 'HMAC' — the class name."
    - "hmac.HMAC.__module__ == 'hmac' — defined in Lib/hmac.py."
    - "hmac.HMAC.__qualname__ == 'HMAC' — top-level class, qualname equals name."
    - "hmac.new.__name__ == 'new' — module-level function."
    - "hmac.compare_digest.__name__ == 'compare_digest' — constant-time comparison function."
    - "hmac.digest.__name__ == 'digest' — one-shot HMAC function (Python 3.7+)."
    - "hmac.HMAC.__bases__[0].__name__ == 'object' — HMAC inherits directly from object."
    - "hmac.new(b'key', b'msg', 'sha512').digest_size == 64 — SHA-512 produces 64 bytes."
    - "hmac.new(b'key', b'msg', 'sha512').name == 'hmac-sha512'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Cross-spec anchoring table for hmac_extra6 namespace
# Confirms the core identity facts from prior specs as a compact table.
# hmac_extra/extra2/extra4/extra5 cover these; here we re-anchor them with
# unique IDs scoped to hmac_extra6 for completeness.
# ---------------------------------------------------------------------------

table hmac_extra6.identity_anchor:
  kind: python_call_eq
  category: identity
  id_prefix: anchor

  columns: [id, function, args, expected]
  rows:
    - [HMAC_name,             HMAC.__name__.__eq__,             ["HMAC"],             true]
    - [HMAC_module,           HMAC.__module__.__eq__,           ["hmac"],             true]
    - [HMAC_qualname,         HMAC.__qualname__.__eq__,         ["HMAC"],             true]
    - [new_name,              new.__name__.__eq__,              ["new"],              true]
    - [compare_digest_name,   compare_digest.__name__.__eq__,   ["compare_digest"],   true]
    - [digest_name,           digest.__name__.__eq__,           ["digest"],           true]

# ---------------------------------------------------------------------------
# hmac.HMAC.__bases__[0].__name__ == 'object'
# hmac_extra2 covers this; here we add a named anchor from hmac_extra6 namespace.
# ---------------------------------------------------------------------------

invariant hmac_extra6.HMAC.base_is_object:
  description: "hmac.HMAC.__bases__[0].__name__ == 'object' — HMAC inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: HMAC.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# hmac.HMAC — MRO check (new coverage)
# No prior hmac spec checks __mro__.
# HMAC inherits from object, so __mro__[1].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant hmac_extra6.HMAC.mro_second_is_object:
  description: "hmac.HMAC.__mro__[1].__name__ == 'object' — second entry in HMAC's MRO is object"
  category: class_hierarchy
  kind: python_call_eq
  function: HMAC.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# hmac.new() with SHA-512 digestmod
# No prior hmac spec uses sha512 as the digestmod.
# SHA-512 produces 64 bytes; block size is 128 bytes.
# ---------------------------------------------------------------------------

invariant hmac_extra6.new.sha512.digest_size:
  description: "hmac.new(b'key', b'msg', 'sha512').digest_size == 64 — SHA-512 produces 64 bytes"
  category: new_sha512
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha512"]
  method: digest_size.__eq__
  method_args: [64]
  expected: true

invariant hmac_extra6.new.sha512.name:
  description: "hmac.new(b'key', b'msg', 'sha512').name == 'hmac-sha512'"
  category: new_sha512
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha512"]
  method: name.__eq__
  method_args: ["hmac-sha512"]
  expected: true

invariant hmac_extra6.new.sha512.block_size:
  description: "hmac.new(b'key', b'msg', 'sha512').block_size == 128 — SHA-512 uses 128-byte blocks"
  category: new_sha512
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha512"]
  method: block_size.__eq__
  method_args: [128]
  expected: true

# ---------------------------------------------------------------------------
# hmac.new() with SHA-512 — digest returns bytes of length 64
# hmac_extra5 covers digest() with sha256 (32 bytes) and md5 (16 bytes).
# Here we add sha512 (64 bytes) — new coverage.
# ---------------------------------------------------------------------------

invariant hmac_extra6.new.sha512.digest_len:
  description: "len(hmac.new(b'key', b'msg', 'sha512').digest()) == 64"
  category: new_sha512
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha512"]
  method: digest().__len__
  method_args: []
  expected: 64

# ---------------------------------------------------------------------------
# hmac.compare_digest — type mismatch raises TypeError
# hmac.zspec.zsdl covers TypeError for str vs bytes mismatch.
# Here we add it as a named invariant from the hmac_extra6 namespace.
# ---------------------------------------------------------------------------

invariant hmac_extra6.compare_digest.type_mismatch_raises:
  description: "hmac.compare_digest('abc', b'abc') raises TypeError — mixed str/bytes not allowed"
  category: errors
  kind: python_call_raises
  function: compare_digest
  args: ["abc", !ascii "abc"]
  expected: TypeError
