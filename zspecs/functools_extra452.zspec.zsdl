spec: functools_extra452
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers cached_property, singledispatch, total_ordering, wraps, WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES identity"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra452.name_identity:
  description: "functools symbol __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [fname001, functools.cached_property.__name__.__eq__, ["cached_property"], true]
    - [fname002, functools.singledispatch.__name__.__eq__, ["singledispatch"], true]
    - [fname003, functools.total_ordering.__name__.__eq__, ["total_ordering"], true]
    - [fname004, functools.wraps.__name__.__eq__, ["wraps"], true]

table functools_extra452.module_identity:
  description: "functools symbol __module__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [fmod001, functools.cached_property.__module__.__eq__, ["functools"], true]
    - [fmod002, functools.singledispatch.__module__.__eq__, ["functools"], true]
    - [fmod003, functools.total_ordering.__module__.__eq__, ["functools"], true]
    - [fmod004, functools.wraps.__module__.__eq__, ["functools"], true]

table functools_extra452.bases_identity:
  description: "functools class __bases__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: fbas

  columns: [id, function, args, expected]
  rows:
    - [fbas001, "functools.cached_property.__bases__[0].__name__.__eq__", ["object"], true]

table functools_extra452.constants_identity:
  description: "functools WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES class name checks"
  kind: python_call_eq
  category: identity
  id_prefix: fcon

  columns: [id, function, args, expected]
  rows:
    - [fcon001, functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__, ["tuple"], true]
    - [fcon002, functools.WRAPPER_UPDATES.__class__.__name__.__eq__, ["tuple"], true]
