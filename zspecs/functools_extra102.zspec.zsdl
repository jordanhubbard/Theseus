spec: functools_extra102
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra101

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec extends functools_extra101.zspec.zsdl."
    - "This spec covers: functools cached_property method class names; _CacheInfo namedtuple identity; total_ordering code attrs; WRAPPER_ASSIGNMENTS contents membership (Wave 254)."
    - "functools.cached_property.__init__.__class__.__name__ == 'function' — cached_property is a pure-Python class; __init__ is a Python function. Verified with Python 3.14.3."
    - "functools.cached_property.__set_name__.__class__.__name__ == 'function' — cached_property.__set_name__ is a Python function. Verified with Python 3.14.3."
    - "functools.cached_property.__get__.__class__.__name__ == 'function' — cached_property.__get__ implements the descriptor protocol; it is a Python function. Verified with Python 3.14.3."
    - "functools.cached_property.__class_getitem__.__class__.__name__ == 'method' — cached_property.__class_getitem__ is a classmethod. Verified with Python 3.14.3."
    - "functools.cached_property.__set__: NOT FOUND — cached_property does not define __set__. Verified with Python 3.14.3."
    - "functools.cached_property.__delete__: NOT FOUND — cached_property does not define __delete__. Verified with Python 3.14.3."
    - "functools._CacheInfo.__name__ == 'CacheInfo' — the namedtuple's __name__ attribute. Verified with Python 3.14.3."
    - "functools._CacheInfo.__module__ == 'functools' — _CacheInfo is defined in the functools module. Verified with Python 3.14.3."
    - "functools._CacheInfo.__bases__[0].__name__ == 'tuple' — _CacheInfo inherits from tuple (namedtuple base). Verified with Python 3.14.3."
    - "functools._CacheInfo.__mro__.__len__() == 3 — MRO is [CacheInfo, tuple, object]. Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_name == 'total_ordering'. Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering'. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — tuple of 6 strings in Python 3.14.3. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS contains '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: cached_property method class names
#
# Wave 254 theme: functools.cached_property pure-Python class method class names.
#
# functools.cached_property.__init__.__class__.__name__ == 'function'
# functools.cached_property.__set_name__.__class__.__name__ == 'function'
# functools.cached_property.__get__.__class__.__name__ == 'function'
# functools.cached_property.__class_getitem__.__class__.__name__ == 'method'
#
# cached_property is a pure-Python descriptor class defined in Lib/functools.py.
# __set__ and __delete__ are not defined (NOT FOUND). New to extra102.
# ---------------------------------------------------------------------------

table functools_extra102.cached_property_method_class_names:
  description: "functools.cached_property method class names: __init__/function, __set_name__/function, __get__/function, __class_getitem__/method; wave 254; new to extra102"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscachedprop102

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_init_class_name_eq_function,
       "cached_property.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cached_property.__init__.__class__.__name__.__eq__('function') == True — cached_property is a pure-Python class defined in Lib/functools.py; __init__ is a Python function accepting the function to cache; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra102"]
    - [cached_property_set_name_class_name_eq_function,
       "cached_property.__set_name__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cached_property.__set_name__.__class__.__name__.__eq__('function') == True — cached_property.__set_name__ is called when the descriptor is assigned in a class body; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra102"]
    - [cached_property_get_class_name_eq_function,
       "cached_property.__get__.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.cached_property.__get__.__class__.__name__.__eq__('function') == True — cached_property.__get__ implements the non-data descriptor protocol; it stores the result in the instance __dict__ on first access; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra102"]
    - [cached_property_class_getitem_class_name_eq_method,
       "cached_property.__class_getitem__.__class__.__name__.__eq__",
       ["method"],
       true,
       "functools.cached_property.__class_getitem__.__class__.__name__.__eq__('method') == True — cached_property.__class_getitem__ is a classmethod supporting the generic syntax cached_property[T]; when accessed on the class, a classmethod becomes a bound method; __class__.__name__ is 'method'; str.__eq__('method') returns True; new to extra102"]

# ---------------------------------------------------------------------------
# Table 2: _CacheInfo namedtuple identity
#
# Wave 254 theme: functools._CacheInfo namedtuple class identity attributes.
#
# functools._CacheInfo.__name__ == 'CacheInfo'
# functools._CacheInfo.__module__ == 'functools'
# functools._CacheInfo.__bases__[0].__name__ == 'tuple'
# functools._CacheInfo.__mro__.__len__() == 3
#
# _CacheInfo is the namedtuple used to report lru_cache statistics.
# Its MRO is [CacheInfo, tuple, object] — length 3. New to extra102.
# ---------------------------------------------------------------------------

table functools_extra102.cacheinfo_namedtuple_identity:
  description: "functools._CacheInfo namedtuple identity: __name__/CacheInfo, __module__/functools, __bases__[0].__name__/tuple, __mro__.__len__()/3; wave 254; new to extra102"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscachedprop102

  columns: [id, function, args, expected, description]
  rows:
    - [cacheinfo_name_eq_CacheInfo,
       "_CacheInfo.__name__.__eq__",
       ["CacheInfo"],
       true,
       "functools._CacheInfo.__name__.__eq__('CacheInfo') == True — _CacheInfo is a namedtuple generated by collections.namedtuple in Lib/functools.py; its __name__ attribute is 'CacheInfo' (the name passed to namedtuple()); str.__eq__('CacheInfo') returns True; new to extra102"]
    - [cacheinfo_module_eq_functools,
       "_CacheInfo.__module__.__eq__",
       ["functools"],
       true,
       "functools._CacheInfo.__module__.__eq__('functools') == True — _CacheInfo is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra102"]
    - [cacheinfo_bases_0_name_eq_tuple,
       "_CacheInfo.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "functools._CacheInfo.__bases__[0].__name__.__eq__('tuple') == True — namedtuple-generated classes inherit directly from tuple; _CacheInfo.__bases__[0] is tuple; __name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra102"]
    - [cacheinfo_mro_len_eq_3,
       "_CacheInfo.__mro__.__len__",
       [],
       3,
       "functools._CacheInfo.__mro__.__len__() == 3 — the method resolution order for _CacheInfo is [CacheInfo, tuple, object]; len is 3; tuple.__len__() returns 3; verified with Python 3.14.3; new to extra102"]

# ---------------------------------------------------------------------------
# Table 3: total_ordering code attrs
#
# Wave 254 theme: functools.total_ordering function code object attributes.
#
# functools.total_ordering.__code__.co_name == 'total_ordering'
# functools.total_ordering.__code__.co_argcount == 1
# functools.total_ordering.__qualname__ == 'total_ordering'
#
# total_ordering is a module-level Python function (decorator) that takes
# one argument (the class to augment). New to extra102.
# ---------------------------------------------------------------------------

table functools_extra102.total_ordering_code_attrs:
  description: "functools.total_ordering code attrs: co_name/'total_ordering', co_argcount/1, __qualname__/'total_ordering'; module-level decorator; wave 254; new to extra102"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscachedprop102

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_co_name_eq,
       "total_ordering.__code__.co_name.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True — total_ordering is a module-level Python function; its code object co_name equals the function name as written in the 'def' statement; str.__eq__('total_ordering') returns True; new to extra102"]
    - [total_ordering_co_argcount_eq_1,
       "total_ordering.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering(cls) takes exactly one argument (the class to augment with comparison methods); co_argcount is 1; int.__eq__(1) returns True; new to extra102"]
    - [total_ordering_qualname_eq,
       "total_ordering.__qualname__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — total_ordering is defined at module scope in Lib/functools.py; its __qualname__ has no enclosing class prefix; str.__eq__('total_ordering') returns True; new to extra102"]

# ---------------------------------------------------------------------------
# Table 4: WRAPPER_ASSIGNMENTS contents membership
#
# Wave 254 theme: functools.WRAPPER_ASSIGNMENTS tuple contents.
#
# WRAPPER_ASSIGNMENTS.__len__() == 6
# WRAPPER_ASSIGNMENTS.__contains__('__module__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__name__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True
#
# In Python 3.14.3, WRAPPER_ASSIGNMENTS has 6 entries (added __annotate__
# and __type_params__ for PEP 695/749 annotation support). New to extra102.
# ---------------------------------------------------------------------------

table functools_extra102.wrapper_assignments_membership:
  description: "functools.WRAPPER_ASSIGNMENTS tuple membership: __module__/True, __name__/True, __qualname__/True, __doc__/True, __annotate__/True, __type_params__/True; len 6; wave 254; new to extra102"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscachedprop102

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_len_eq_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS is a tuple of attribute names copied by update_wrapper/wraps; in Python 3.14.3 it has 6 entries: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; tuple.__len__() returns 6; new to extra102"]
    - [wrapper_assignments_contains_module,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — __module__ is one of the attributes copied by update_wrapper from the wrapped function to the wrapper; tuple.__contains__('__module__') returns True; new to extra102"]
    - [wrapper_assignments_contains_name,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — __name__ is one of the attributes copied by update_wrapper so the wrapper appears to have the wrapped function's name; tuple.__contains__('__name__') returns True; new to extra102"]
    - [wrapper_assignments_contains_qualname,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — __qualname__ is one of the attributes copied by update_wrapper so the wrapper has the correct qualified name; tuple.__contains__('__qualname__') returns True; new to extra102"]
    - [wrapper_assignments_contains_doc,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__doc__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — __doc__ is one of the attributes copied by update_wrapper so the wrapper preserves the wrapped function's docstring; tuple.__contains__('__doc__') returns True; new to extra102"]
    - [wrapper_assignments_contains_annotate,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__annotate__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True — __annotate__ was added for PEP 749 annotation support in Python 3.14; it is one of the 6 attributes copied by update_wrapper; tuple.__contains__('__annotate__') returns True; new to extra102"]
    - [wrapper_assignments_contains_type_params,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__type_params__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True — __type_params__ was added for PEP 695 type parameter syntax support; it is one of the 6 attributes copied by update_wrapper; tuple.__contains__('__type_params__') returns True; new to extra102"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra102
# ---------------------------------------------------------------------------

invariant functools_extra102.cached_property_init_class_name_eq_function:
  description: "functools.cached_property.__init__.__class__.__name__ == 'function' — pure-Python descriptor class method; wave 254; new to extra102"
  kind: python_call_eq
  function: cached_property.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra102.cacheinfo_mro_len_eq_3:
  description: "functools._CacheInfo.__mro__.__len__() == 3 — MRO is [CacheInfo, tuple, object]; wave 254; new to extra102"
  kind: python_call_eq
  function: _CacheInfo.__mro__.__len__
  args: []
  expected: 3

invariant functools_extra102.total_ordering_co_argcount_eq_1:
  description: "functools.total_ordering.__code__.co_argcount == 1 — takes one class argument; wave 254; new to extra102"
  kind: python_call_eq
  function: total_ordering.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant functools_extra102.wrapper_assignments_len_eq_6:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — tuple of 6 attribute names in Python 3.14.3; wave 254; new to extra102"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra102.wrapper_assignments_contains_type_params:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True — added for PEP 695 type parameter syntax; wave 254; new to extra102"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__type_params__"]
  expected: true
