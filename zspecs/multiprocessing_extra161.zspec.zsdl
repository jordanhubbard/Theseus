spec: multiprocessing_extra161
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing-ctypes

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/synchronize.py"
    - "CPython source: Modules/_multiprocessing/semaphore.c"
  notes:
    - "This spec covers: multiprocessing.synchronize module class identity for Lock and Semaphore. multiprocessing.synchronize.Lock.__name__=='Lock' (len=4: 'L'+'o'+'c'+'k'=4); multiprocessing.synchronize.Lock.__module__=='multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.'=1+'synchronize'=11=27; the synchronize submodule houses all multiprocessing synchronization primitives — distinct from multiprocessing.pool and multiprocessing.context established in prior specs); multiprocessing.synchronize.Lock.__bases__[0].__name__=='SemLock' (len=7: 'Sem'=3+'Lock'=4=7; KEY FINDING: multiprocessing.synchronize.Lock inherits from SemLock, NOT from object; SemLock is the C-level semaphore/lock class from _multiprocessing extension module); multiprocessing.synchronize.Semaphore.__name__=='Semaphore' (len=9); multiprocessing.synchronize.Semaphore.__module__=='multiprocessing.synchronize' (same module as Lock); multiprocessing.synchronize.Semaphore.__bases__[0].__name__=='SemLock' (len=7; Semaphore also inherits from SemLock — same base as Lock; both Lock and Semaphore share SemLock as their direct base class). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.synchronize.Lock.__bases__[0].__name__=='SemLock' (len=7: 'Sem'=3+'Lock'=4=7) — SemLock is the C-extension class from _multiprocessing that wraps a platform semaphore or mutex; both multiprocessing.synchronize.Lock and multiprocessing.synchronize.Semaphore directly inherit from SemLock; the shared base SemLock (same object: Lock.__bases__[0] is Semaphore.__bases__[0] == True) reflects that both primitives are implemented using the same underlying OS semaphore mechanism; SemLock.__module__ is '_multiprocessing' (the C extension module); compare: asyncio.Lock.__bases__[0].__name__=='_ContextManagerMixin' (asyncio uses pure Python mixins) vs multiprocessing.synchronize.Lock.__bases__[0].__name__=='SemLock' (multiprocessing uses a C-level base class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.synchronize module (len=27) — 'multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.'=1+'synchronize'=11=27; 'synchronize'=11: 'sync'=4+'hronize'=7=11); compare module lengths in the multiprocessing family: pool(len=20) < context(len=23) < process(len=23) < synchronize(len=27); 'multiprocessing.synchronize' (len=27) is the longest multiprocessing submodule path covered in this spec series; 'synchronize'=11 is the longest submodule name: 'pool'=4 < 'context'=7 == 'process'=7 < 'synchronize'=11. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (NOT SemLock) — BoundedSemaphore in multiprocessing.synchronize inherits from Semaphore (one level deeper: SemLock -> Semaphore -> BoundedSemaphore); this parallels asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (established in extra161); in both asyncio and multiprocessing.synchronize, BoundedSemaphore is a direct subclass of Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.synchronize.Lock class identity — extra161
#
# multiprocessing.synchronize.Lock.__name__.__eq__('Lock')                        == True
# multiprocessing.synchronize.Lock.__module__.__eq__('multiprocessing.synchronize') == True
# multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__('SemLock')        == True
# ---------------------------------------------------------------------------

table multiprocessing_extra161.mp_synchronize_lock_identity:
  description: "multiprocessing.synchronize.Lock class identity checks in mpsynclock161 namespace — multiprocessing.synchronize.Lock.__name__=='Lock' (len=4: 'L'+'o'+'c'+'k'=4; the multiprocessing lock class; a non-recursive mutual exclusion lock; acquire() and release() methods for cross-process locking; supports context manager protocol 'with'); multiprocessing.synchronize.Lock.__module__=='multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.'=1+'synchronize'=11=27; synchronize is the longest multiprocessing submodule name at 11 chars; compare: 'pool'=4 < 'context'=7 == 'process'=7 < 'synchronize'=11); multiprocessing.synchronize.Lock.__bases__[0].__name__=='SemLock' (len=7: 'Sem'=3+'Lock'=4=7; KEY FINDING: Lock inherits from SemLock, the C-extension class wrapping the OS semaphore; this is very different from asyncio.Lock.__bases__[0].__name__=='_ContextManagerMixin' — multiprocessing uses a C-level base while asyncio uses pure Python mixins); Lock.__name__.__len__()==4 — the shortest name among synchronize primitives; compare: RLock(5) < Event(5) == Condition(9)... actually Lock(4) < RLock(5) < Semaphore(9) == Condition(9) < BoundedSemaphore(16); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsynclock161

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,   multiprocessing.synchronize.Lock.__name__.__eq__,                ["Lock"],                          true,  "mp.synchronize.Lock.__name__ == 'Lock' (len=4; shortest name in synchronize module); verified with Python 3.14.3"]
    - [lock_mod_eq,    multiprocessing.synchronize.Lock.__module__.__eq__,               ["multiprocessing.synchronize"],   true,  "mp.synchronize.Lock.__module__ == 'multiprocessing.synchronize' (len=27; longest mp submodule path); verified with Python 3.14.3"]
    - [lock_base_eq,   "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__",  ["SemLock"],                       true,  "mp.synchronize.Lock.__bases__[0].__name__ == 'SemLock' (C-level base; NOT object or _ContextManagerMixin); verified with Python 3.14.3"]
    - [lock_name_len,  multiprocessing.synchronize.Lock.__name__.__len__,                [],                                4,     "mp.synchronize.Lock.__name__.__len__() == 4 ('Lock'; shortest synchronize class name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.synchronize.Semaphore class identity — extra161
#
# multiprocessing.synchronize.Semaphore.__name__.__eq__('Semaphore')              == True
# multiprocessing.synchronize.Semaphore.__module__.__eq__('multiprocessing.synchronize') == True
# multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__('SemLock')   == True
# ---------------------------------------------------------------------------

table multiprocessing_extra161.mp_synchronize_semaphore_identity:
  description: "multiprocessing.synchronize.Semaphore class identity checks in mpsyncsema161 namespace — multiprocessing.synchronize.Semaphore.__name__=='Semaphore' (len=9: 'S'+'e'+'m'+'a'+'p'+'h'+'o'+'r'+'e'=9; the multiprocessing counting semaphore; a process-safe semaphore backed by a SemLock C-level object; acquire() decrements the count, release() increments it); multiprocessing.synchronize.Semaphore.__module__=='multiprocessing.synchronize' (len=27; same module as Lock — both synchronization primitives are in the synchronize submodule); multiprocessing.synchronize.Semaphore.__bases__[0].__name__=='SemLock' (len=7: 'Sem'=3+'Lock'=4=7; KEY: Semaphore also inherits from SemLock — the same base as Lock; both Lock and Semaphore are direct subclasses of SemLock; compare: asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (asyncio.Semaphore inherits from the Python mixin); Semaphore.__name__.__len__()==9; compare: Lock.__name__.__len__()==4 (Semaphore is 5 chars longer than Lock)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsyncsema161

  columns: [id, function, args, expected, description]
  rows:
    - [sema_name_eq,   multiprocessing.synchronize.Semaphore.__name__.__eq__,                ["Semaphore"],                     true,  "mp.synchronize.Semaphore.__name__ == 'Semaphore' (len=9; 5 longer than Lock=4); verified with Python 3.14.3"]
    - [sema_mod_eq,    multiprocessing.synchronize.Semaphore.__module__.__eq__,               ["multiprocessing.synchronize"],   true,  "mp.synchronize.Semaphore.__module__ == 'multiprocessing.synchronize' (len=27; same module as Lock); verified with Python 3.14.3"]
    - [sema_base_eq,   "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__",  ["SemLock"],                       true,  "mp.synchronize.Semaphore.__bases__[0].__name__ == 'SemLock' (same C-level base as Lock); verified with Python 3.14.3"]
    - [sema_name_len,  multiprocessing.synchronize.Semaphore.__name__.__len__,                [],                                9,     "mp.synchronize.Semaphore.__name__.__len__() == 9 ('Semaphore'; 5 chars longer than Lock=4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.synchronize.RLock and BoundedSemaphore identity — extra161
#
# RLock.__bases__[0].__name__.__eq__('SemLock')             == True
# BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra161.mp_synchronize_rlock_boundedsema_identity:
  description: "multiprocessing.synchronize.RLock and BoundedSemaphore identity checks in mpsyncrlbs161 namespace — multiprocessing.synchronize.RLock.__name__=='RLock' (len=5: 'R'+'L'+'o'+'c'+'k'=5; a recursive (re-entrant) lock that can be acquired multiple times by the same process; must be released the same number of times it was acquired); multiprocessing.synchronize.RLock.__module__=='multiprocessing.synchronize' (len=27; same module as Lock and Semaphore); multiprocessing.synchronize.RLock.__bases__[0].__name__=='SemLock' (len=7; RLock also inherits from SemLock — same base as Lock and Semaphore; all three non-bounded primitives use SemLock as their direct base); multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (len=9; BoundedSemaphore inherits from Semaphore — one level deeper than SemLock; the pattern parallels asyncio.BoundedSemaphore inheriting from asyncio.Semaphore established in extra161); inheritance chains: SemLock -> Lock; SemLock -> RLock; SemLock -> Semaphore -> BoundedSemaphore; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsyncrlbs161

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_name_eq,    multiprocessing.synchronize.RLock.__name__.__eq__,                      ["RLock"],      true,  "mp.synchronize.RLock.__name__ == 'RLock' (len=5; re-entrant lock); verified with Python 3.14.3"]
    - [rlock_base_eq,    "multiprocessing.synchronize.RLock.__bases__[0].__name__.__eq__",        ["SemLock"],    true,  "mp.synchronize.RLock.__bases__[0].__name__ == 'SemLock' (same C-level base as Lock and Semaphore); verified with Python 3.14.3"]
    - [bsema_base_eq,    "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__",  ["Semaphore"],  true,  "mp.synchronize.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' (NOT SemLock; inherits from Semaphore); verified with Python 3.14.3"]
    - [lock_mod_len,     multiprocessing.synchronize.Lock.__module__.__len__,                    [],             27,    "mp.synchronize.Lock.__module__.__len__() == 27 ('multiprocessing.synchronize'; longest mp submodule path); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra161
# ---------------------------------------------------------------------------

invariant multiprocessing_extra161.mp_sync_Lock_name_eq:
  description: "multiprocessing.synchronize.Lock.__name__.__eq__('Lock') returns True — multiprocessing.synchronize.Lock is the process-safe mutual exclusion lock; Lock.__name__=='Lock' (len=4: 'L'+'o'+'c'+'k'=4); Lock is the shortest-named synchronization primitive in multiprocessing.synchronize; Lock provides acquire() and release() for cross-process mutual exclusion; Lock.__module__=='multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.'=1+'synchronize'=11=27; the longest multiprocessing submodule path in the spec series — synchronize(27) > process(23) == context(23) > pool(20)); Lock.__bases__[0].__name__=='SemLock' (len=7; KEY: Lock uses a C-extension base SemLock from _multiprocessing, unlike asyncio.Lock which uses pure Python _ContextManagerMixin); compare: RLock.__name__=='RLock' (len=5; 1 longer than Lock=4); NEW in extra161: first standalone mp.synchronize.Lock.__name__ identity invariant in mpsynclock161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant multiprocessing_extra161.mp_sync_Lock_module_eq:
  description: "multiprocessing.synchronize.Lock.__module__.__eq__('multiprocessing.synchronize') returns True — multiprocessing.synchronize.Lock is defined in Lib/multiprocessing/synchronize.py; __module__=='multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.'=1+'synchronize'=11=27); 'multiprocessing.synchronize' (len=27) is the longest submodule path in the multiprocessing spec series: pool(len=20) < context(len=23) == process(len=23) < synchronize(len=27); 'synchronize'=11 is the longest submodule name: 'pool'=4 < 'context'=7 == 'process'=7 < 'synchronize'=11; Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition all share __module__=='multiprocessing.synchronize' (same module, len=27); compare: asyncio.Lock.__module__=='asyncio.locks' (len=13; much shorter than multiprocessing.synchronize=27); NEW in extra161: first standalone mp.synchronize.Lock.__module__ identity invariant in mpsynclock161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.Lock.__module__.__eq__
  args: ["multiprocessing.synchronize"]
  expected: true

invariant multiprocessing_extra161.mp_sync_Lock_base_is_SemLock:
  description: "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__('SemLock') returns True — multiprocessing.synchronize.Lock inherits from SemLock; __bases__[0].__name__=='SemLock' (len=7: 'Sem'=3+'Lock'=4=7); SemLock is the C-extension class in _multiprocessing that wraps the platform-specific semaphore or mutex; SemLock is defined in Modules/_multiprocessing/semaphore.c; Lock.__bases__[0] is Semaphore.__bases__[0] (both Lock and Semaphore share the exact same SemLock class object as their base); contrast: asyncio.Lock.__bases__[0].__name__=='_ContextManagerMixin' (asyncio Lock inherits from pure Python mixin) vs multiprocessing.synchronize.Lock.__bases__[0].__name__=='SemLock' (multiprocessing Lock inherits from C-extension); contrast: multiprocessing.pool.Pool.__bases__[0].__name__=='object' (Pool inherits from object); NEW in extra161: first standalone mp.synchronize.Lock.__bases__[0].__name__ identity invariant in mpsynclock161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__"
  args: ["SemLock"]
  expected: true

invariant multiprocessing_extra161.mp_sync_Semaphore_name_eq:
  description: "multiprocessing.synchronize.Semaphore.__name__.__eq__('Semaphore') returns True — multiprocessing.synchronize.Semaphore is the process-safe counting semaphore; Semaphore.__name__=='Semaphore' (len=9: 'S'+'e'+'m'+'a'+'p'+'h'+'o'+'r'+'e'=9); Semaphore.__module__=='multiprocessing.synchronize' (len=27; same module as Lock); Semaphore.__bases__[0].__name__=='SemLock' (len=7; same C-level base as Lock — both Lock and Semaphore are direct subclasses of SemLock); Semaphore.__name__.__len__()==9 is 5 chars longer than Lock.__name__.__len__()==4; compare: asyncio.Semaphore.__name__=='Semaphore' (len=9; same name length as multiprocessing.synchronize.Semaphore) but asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' vs multiprocessing.synchronize.Semaphore.__bases__[0].__name__=='SemLock'; same class name, different inheritance hierarchy; NEW in extra161: first standalone mp.synchronize.Semaphore.__name__ identity invariant in mpsyncsema161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant multiprocessing_extra161.mp_sync_Semaphore_base_is_SemLock:
  description: "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__('SemLock') returns True — multiprocessing.synchronize.Semaphore inherits from SemLock; __bases__[0].__name__=='SemLock' (len=7); SemLock is the C-extension class from _multiprocessing that provides the underlying OS-level semaphore; both Lock and Semaphore inherit directly from SemLock (they are siblings in the hierarchy: SemLock -> Lock; SemLock -> Semaphore); Lock.__bases__[0] is Semaphore.__bases__[0] (both point to the same SemLock class object); contrast: asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (asyncio Semaphore uses pure Python mixin); contrast: multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (BoundedSemaphore is one level deeper: SemLock -> Semaphore -> BoundedSemaphore); NEW in extra161: first standalone mp.synchronize.Semaphore.__bases__[0].__name__ identity invariant in mpsyncsema161 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__"
  args: ["SemLock"]
  expected: true

