spec: io_extra293
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — BytesIO and StringIO method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/bytesio.c, Modules/_io/stringio.c"
  notes:
    - "BytesIO and StringIO are in-memory stream implementations"
    - "__qualname__ attributes verified for both BytesIO and StringIO methods"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table io_extra293.bytesio_qualnames:
  description: "BytesIO method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: iob293

  columns: [id, function, args, expected, description]
  rows:
    - [iob293_001, io.BytesIO.read.__qualname__, [], "BytesIO.read", "BytesIO.read qualname"]
    - [iob293_002, io.BytesIO.write.__qualname__, [], "BytesIO.write", "BytesIO.write qualname"]
    - [iob293_003, io.BytesIO.seek.__qualname__, [], "BytesIO.seek", "BytesIO.seek qualname"]
    - [iob293_004, io.BytesIO.tell.__qualname__, [], "BytesIO.tell", "BytesIO.tell qualname"]
    - [iob293_005, io.BytesIO.getvalue.__qualname__, [], "BytesIO.getvalue", "BytesIO.getvalue qualname"]
    - [iob293_006, io.BytesIO.close.__qualname__, [], "BytesIO.close", "BytesIO.close qualname"]
    - [iob293_007, io.BytesIO.flush.__qualname__, [], "BytesIO.flush", "BytesIO.flush qualname"]
    - [iob293_008, io.BytesIO.readable.__qualname__, [], "BytesIO.readable", "BytesIO.readable qualname"]
    - [iob293_009, io.BytesIO.writable.__qualname__, [], "BytesIO.writable", "BytesIO.writable qualname"]
    - [iob293_010, io.BytesIO.seekable.__qualname__, [], "BytesIO.seekable", "BytesIO.seekable qualname"]

table io_extra293.stringio_qualnames:
  description: "StringIO method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: ios293

  columns: [id, function, args, expected, description]
  rows:
    - [ios293_001, io.StringIO.read.__qualname__, [], "StringIO.read", "StringIO.read qualname"]
    - [ios293_002, io.StringIO.write.__qualname__, [], "StringIO.write", "StringIO.write qualname"]
    - [ios293_003, io.StringIO.getvalue.__qualname__, [], "StringIO.getvalue", "StringIO.getvalue qualname"]
    - [ios293_004, io.StringIO.seek.__qualname__, [], "StringIO.seek", "StringIO.seek qualname"]
    - [ios293_005, io.StringIO.readline.__qualname__, [], "StringIO.readline", "StringIO.readline qualname"]
    - [ios293_006, io.StringIO.tell.__qualname__, [], "StringIO.tell", "StringIO.tell qualname"]
    - [ios293_007, io.StringIO.truncate.__qualname__, [], "StringIO.truncate", "StringIO.truncate qualname"]

invariant io_extra293.bytesio_read_qualname:
  description: "BytesIO.read qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: io.BytesIO.read.__qualname__
  args: []
  expected: "BytesIO.read"

invariant io_extra293.bytesio_write_qualname:
  description: "BytesIO.write qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: io.BytesIO.write.__qualname__
  args: []
  expected: "BytesIO.write"

invariant io_extra293.stringio_read_qualname:
  description: "StringIO.read qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: io.StringIO.read.__qualname__
  args: []
  expected: "StringIO.read"

invariant io_extra293.stringio_getvalue_qualname:
  description: "StringIO.getvalue qualname is confirmed"
  category: identity
  kind: python_call_eq
  function: io.StringIO.getvalue.__qualname__
  args: []
  expected: "StringIO.getvalue"
