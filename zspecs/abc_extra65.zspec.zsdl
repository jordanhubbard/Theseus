spec: abc_extra65
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#abstract-base-classes — Python ABC documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra64.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, update_abstractmethods/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, all length tables, abstractproperty/abstractclassmethod/abstractstaticmethod qualnames/names/bases, ABCMeta.register/__instancecheck__/__subclasscheck__ qualname string equality and code attribute chains, class __mro__.__len__() tables, class __dict__ tables, class __class__ identity, __repr__/__weakref__/__eq__ class names, abc.__package__/__all__ membership, __loader__/__spec__/__file__ class names, __spec__ attributes, ABCMeta.__doc__.__contains__('Abstract'), ABC/__doc__.__class__.__name__=='str', abstractmethod/update_abstractmethods/get_cache_token __doc__.__class__.__name__, code object attribute chains, __defaults__/__kwdefaults__ class names, ABCMeta method __qualname__ string equality, ABCMeta.register code attribute type chains, abc.__spec__.__class__.__name__=='ModuleSpec', abc.__spec__.name=='abc', abc.__name__=='abc'."
    - "This spec covers (abcmore65 namespace): wave 236 theme — abc module doc content and spec origin identity. NEW in extra65: abstractmethod.__doc__.__class__.__name__.__eq__('str'); abstractmethod.__doc__.__contains__('abstract')==True; update_abstractmethods.__doc__.__class__.__name__.__eq__('str'); update_abstractmethods.__doc__.__contains__('abstract')==True; ABC.__doc__.__contains__('inheritance')==True; ABCMeta.__doc__.__contains__('Base')==True; abc.__spec__.origin.__eq__('frozen'); abc.__loader__.__class__.__name__.__eq__('type')."
    - "abc.abstractmethod.__doc__.__class__.__name__ == 'str'. abstractmethod is a Python class with a docstring; abstractmethod.__doc__.__class__.__name__ is 'str'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__doc__.__contains__('abstract') == True. abstractmethod's docstring discusses abstract methods; the word 'abstract' appears in the docstring. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__doc__.__class__.__name__ == 'str'. update_abstractmethods is a Python function with a docstring; update_abstractmethods.__doc__.__class__.__name__ is 'str'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__doc__.__contains__('abstract') == True. update_abstractmethods' docstring discusses abstract methods; the word 'abstract' appears in the docstring. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__doc__.__contains__('inheritance') == True. ABC's docstring says 'Helper class that provides a standard way to create an ABC using inheritance, if desired'; it contains 'inheritance'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__doc__.__contains__('Base') == True. ABCMeta's docstring says 'Metaclass for defining Abstract Base Classes (ABCs)'; it contains 'Base'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__spec__.origin == 'frozen'. abc is a frozen module (implemented partly in _abc C extension and loaded by FrozenImporter for the Python wrapper); abc.__spec__.origin is 'frozen'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.__loader__.__class__.__name__ == 'type'. abc is a frozen module; its __loader__ is the FrozenImporter class object (not an instance); FrozenImporter is a class, so FrozenImporter.__class__.__name__ is 'type'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc abstractmethod __doc__ checks — extra65
#
# Wave 236 theme: abstractmethod decorator doc content.
#
# abstractmethod.__doc__.__class__.__name__ == 'str'
# abstractmethod.__doc__.__contains__('abstract') == True
# ---------------------------------------------------------------------------

table abc_extra65.abstractmethod_doc:
  description: "abc abstractmethod/__doc__.__class__.__name__ and __doc__.__contains__('abstract') checks in abcmore65 namespace — wave 236 theme: abstractmethod decorator doc content; abstractmethod.__doc__.__class__.__name__=='str' (abstractmethod is a Python class with a docstring); abstractmethod.__doc__.__contains__('abstract')==True (the docstring discusses abstract methods; the word 'abstract' appears); NEW in extra65: first __doc__.__class__.__name__ and __doc__.__contains__('abstract') checks for abstractmethod in the abcmore65 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: abcmore65

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_doc_class,    abstractmethod.__doc__.__class__.__name__.__eq__, ["str"],      true, "abstractmethod.__doc__.__class__.__name__ == 'str' — abc.abstractmethod is a Python class with a docstring; abstractmethod.__doc__ is a str; __doc__.__class__.__name__ is 'str'; NEW in extra65: first __doc__.__class__.__name__.__eq__('str') check for abstractmethod in the abcmore65 namespace; verified with Python 3.14.3"]
    - [abstractmethod_doc_abstract, abstractmethod.__doc__.__contains__,              ["abstract"], true, "abstractmethod.__doc__.__contains__('abstract') == True — abc.abstractmethod's docstring discusses abstract methods; the word 'abstract' appears in the docstring; __doc__.__contains__('abstract') returns True; NEW in extra65: first __doc__.__contains__('abstract') check for abstractmethod in the abcmore65 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc update_abstractmethods __doc__ checks — extra65
#
# Wave 236 theme: update_abstractmethods function doc content.
#
# update_abstractmethods.__doc__.__class__.__name__ == 'str'
# update_abstractmethods.__doc__.__contains__('abstract') == True
# ---------------------------------------------------------------------------

table abc_extra65.update_abstractmethods_doc:
  description: "abc update_abstractmethods/__doc__.__class__.__name__ and __doc__.__contains__('abstract') checks in abcmore65 namespace — wave 236 theme: update_abstractmethods function doc content; update_abstractmethods.__doc__.__class__.__name__=='str' (update_abstractmethods is a Python function added in 3.10 with a docstring); update_abstractmethods.__doc__.__contains__('abstract')==True (the docstring discusses abstract methods; the word 'abstract' appears); NEW in extra65: first __doc__.__class__.__name__ and __doc__.__contains__('abstract') checks for update_abstractmethods in the abcmore65 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: abcmore65a

  columns: [id, function, args, expected, description]
  rows:
    - [update_doc_class,    update_abstractmethods.__doc__.__class__.__name__.__eq__, ["str"],      true, "update_abstractmethods.__doc__.__class__.__name__ == 'str' — abc.update_abstractmethods is a Python function with a docstring; update_abstractmethods.__doc__ is a str; __doc__.__class__.__name__ is 'str'; NEW in extra65: first __doc__.__class__.__name__.__eq__('str') check for update_abstractmethods in the abcmore65 namespace; verified with Python 3.14.3"]
    - [update_doc_abstract, update_abstractmethods.__doc__.__contains__,              ["abstract"], true, "update_abstractmethods.__doc__.__contains__('abstract') == True — abc.update_abstractmethods' docstring discusses abstract methods; the word 'abstract' appears in the docstring; __doc__.__contains__('abstract') returns True; NEW in extra65: first __doc__.__contains__('abstract') check for update_abstractmethods in the abcmore65 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABC and ABCMeta __doc__ novel content checks — extra65
#
# Wave 236 theme: ABC and ABCMeta doc content (novel strings).
#
# ABC.__doc__.__contains__('inheritance') == True
# ABCMeta.__doc__.__contains__('Base') == True
# ---------------------------------------------------------------------------

table abc_extra65.ABC_ABCMeta_doc_novel:
  description: "abc ABC/__doc__.__contains__('inheritance') and ABCMeta/__doc__.__contains__('Base') checks in abcmore65 namespace — wave 236 theme: ABC and ABCMeta doc content (novel strings not covered in prior specs); ABC.__doc__.__contains__('inheritance')==True (ABC docstring says 'Helper class that provides a standard way to create an ABC using inheritance, if desired'; prior specs covered __contains__('ABC') — 'inheritance' is novel); ABCMeta.__doc__.__contains__('Base')==True (ABCMeta docstring says 'Metaclass for defining Abstract Base Classes (ABCs)'; prior specs covered __contains__('Abstract') — 'Base' is novel); NEW in extra65: first __doc__.__contains__('inheritance') check for ABC and first __doc__.__contains__('Base') check for ABCMeta in the abcmore65 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: abcmore65b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_inheritance,  ABC.__doc__.__contains__,    ["inheritance"], true, "ABC.__doc__.__contains__('inheritance') == True — abc.ABC's docstring says 'Helper class that provides a standard way to create an ABC using inheritance, if desired'; the word 'inheritance' appears in the docstring; prior specs covered __contains__('ABC') for ABC; 'inheritance' is a novel distinct vector; __doc__.__contains__('inheritance') returns True; NEW in extra65: first __doc__.__contains__('inheritance') check for ABC in the abcmore65 namespace; verified with Python 3.14.3"]
    - [abcmeta_doc_Base,     ABCMeta.__doc__.__contains__, ["Base"],       true, "ABCMeta.__doc__.__contains__('Base') == True — abc.ABCMeta's docstring says 'Metaclass for defining Abstract Base Classes (ABCs)'; the word 'Base' appears in the docstring; prior specs covered __contains__('Abstract') for ABCMeta; 'Base' is a novel distinct vector; __doc__.__contains__('Base') returns True; NEW in extra65: first __doc__.__contains__('Base') check for ABCMeta in the abcmore65 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module __spec__.origin and __loader__ class checks — extra65
#
# Wave 236 theme: abc module loader and spec origin identity.
#
# abc.__spec__.origin == 'frozen'
# abc.__loader__.__class__.__name__ == 'type'
# ---------------------------------------------------------------------------

table abc_extra65.abc_spec_origin:
  description: "abc module __spec__.origin and __loader__.__class__.__name__ checks in abcmore65 namespace — wave 236 theme: abc module loader and spec origin identity; abc.__spec__.origin=='frozen' (abc is a frozen module; its ModuleSpec.origin is 'frozen'); abc.__loader__.__class__.__name__=='type' (abc's __loader__ is the FrozenImporter class object itself, not an instance; a class object's __class__ is 'type'); NEW in extra65: first __spec__.origin and __loader__.__class__.__name__ checks for abc in the abcmore65 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmore65c

  columns: [id, function, args, expected, description]
  rows:
    - [abc_spec_origin,      abc.__spec__.origin.__eq__,              ["frozen"], true, "abc.__spec__.origin == 'frozen' — abc is a frozen module; its ModuleSpec stores the origin as 'frozen'; abc.__spec__.origin is 'frozen'; __eq__('frozen') returns True; NEW in extra65: first __spec__.origin.__eq__('frozen') check for abc in the abcmore65 namespace; verified with Python 3.14.3"]
    - [abc_loader_cls_name,  abc.__loader__.__class__.__name__.__eq__, ["type"],   true, "abc.__loader__.__class__.__name__ == 'type' — abc is a frozen module; its __loader__ is the FrozenImporter class object (not an instance); a class object's metaclass is 'type'; abc.__loader__.__class__.__name__ is 'type'; __eq__('type') returns True; NEW in extra65: first __loader__.__class__.__name__.__eq__('type') check for abc in the abcmore65 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra65
# ---------------------------------------------------------------------------

invariant abc_extra65.abstractmethod_doc_str:
  description: "abc.abstractmethod.__doc__.__class__.__name__.__eq__('str') returns True — abc.abstractmethod is a Python class with a docstring; abstractmethod.__doc__ is a str; __doc__.__class__.__name__.__eq__('str') returns True; NEW in extra65: first standalone __doc__.__class__.__name__.__eq__('str') invariant for abstractmethod in the abcmore65 namespace; wave 236 first doc class name invariant for abstractmethod; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: abstractmethod.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra65.abstractmethod_doc_abstract:
  description: "abc.abstractmethod.__doc__.__contains__('abstract') returns True — abc.abstractmethod's docstring discusses abstract methods; the word 'abstract' appears in the docstring; __doc__.__contains__('abstract') returns True; NEW in extra65: first standalone __doc__.__contains__('abstract') invariant for abstractmethod in the abcmore65 namespace; wave 236 first doc content invariant for abstractmethod; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: abstractmethod.__doc__.__contains__
  args: ["abstract"]
  expected: true

invariant abc_extra65.ABC_doc_inheritance:
  description: "abc.ABC.__doc__.__contains__('inheritance') returns True — abc.ABC's docstring says 'Helper class that provides a standard way to create an ABC using inheritance, if desired'; __doc__.__contains__('inheritance') returns True; NEW in extra65: first standalone __doc__.__contains__('inheritance') invariant for ABC in the abcmore65 namespace; wave 236 first 'inheritance' doc content invariant for ABC; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: ABC.__doc__.__contains__
  args: ["inheritance"]
  expected: true

invariant abc_extra65.ABCMeta_doc_Base:
  description: "abc.ABCMeta.__doc__.__contains__('Base') returns True — abc.ABCMeta's docstring says 'Metaclass for defining Abstract Base Classes (ABCs)'; __doc__.__contains__('Base') returns True; NEW in extra65: first standalone __doc__.__contains__('Base') invariant for ABCMeta in the abcmore65 namespace; wave 236 first 'Base' doc content invariant for ABCMeta; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: ABCMeta.__doc__.__contains__
  args: ["Base"]
  expected: true

invariant abc_extra65.abc_spec_origin_frozen:
  description: "abc.__spec__.origin.__eq__('frozen') returns True — abc is a frozen module; its ModuleSpec stores the origin as 'frozen'; abc.__spec__.origin is 'frozen'; __eq__('frozen') returns True; NEW in extra65: first standalone __spec__.origin.__eq__('frozen') invariant for abc in the abcmore65 namespace; wave 236 first spec origin invariant for abc; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.__spec__.origin.__eq__
  args: ["frozen"]
  expected: true
