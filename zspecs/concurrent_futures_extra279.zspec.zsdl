spec: concurrent_futures_extra279
version: ">=3.2"
backend: python_module(concurrent.futures._base)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#future-objects — Future state constants"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "concurrent_futures_extra28.zspec.zsdl — covers __all__ metadata, class __dict__ mappingproxy lengths, Future internal method qualnames, function __module__ lengths"
  notes:
    - "This spec covers: concurrent.futures._base.Future.__doc__ is not None (type str); concurrent.futures._base.Executor.__doc__ is not None (type str); _base state string constants PENDING/RUNNING/FINISHED/CANCELLED string lengths (7/7/8/9); CANCELLED_AND_NOTIFIED string length (22); state constant __class__.__name__ checks (all str). NEW in extra279: cfbase.Future.__doc__.__class__.__name__=='str'; cfbase.Executor.__doc__.__class__.__name__=='str'; cfbase.PENDING.__len__()==7; cfbase.RUNNING.__len__()==7; cfbase.FINISHED.__len__()==8; cfbase.CANCELLED.__len__()==9; cfbase.CANCELLED_AND_NOTIFIED.__len__()==22; all five state constants are str. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures._base.PENDING == 'PENDING' (len=7) — the initial state for a Future not yet attached to an executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures._base.RUNNING == 'RUNNING' (len=7) — PENDING and RUNNING have equal length (7); both shorter than FINISHED (8) and CANCELLED (9). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures._base.FINISHED == 'FINISHED' (len=8) — the terminal success state. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures._base.CANCELLED == 'CANCELLED' (len=9) — the terminal cancellation state. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures._base.CANCELLED_AND_NOTIFIED == 'CANCELLED_AND_NOTIFIED' (len=22) — the longest state string by far; used internally to track that cancellation callbacks have been dispatched. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Future.__doc__ is a str (not None) — the docstring 'Represents the result of an asynchronous computation.' is present on the class. Same for Executor.__doc__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future and Executor __doc__ type checks — extra279 namespace
#
# concurrent.futures._base.Future.__doc__ is a str (not None).
# concurrent.futures._base.Executor.__doc__ is a str (not None).
# The docstrings confirm that both classes carry user-facing documentation.
# ---------------------------------------------------------------------------

table concurrent_futures_extra279.doc_type_checks:
  description: "concurrent.futures._base Future and Executor __doc__ type checks in cfbase279 namespace — Future.__doc__.__class__.__name__=='str'; Executor.__doc__.__class__.__name__=='str'; both docstrings are present (not None) and are plain str objects; Future.__doc__ is 'Represents the result of an asynchronous computation.' (confirmed non-None); Executor.__doc__ is also a non-None str; prior specs have not measured __doc__ type for these classes; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_structure
  id_prefix: cfbase279

  columns: [id, function, args, expected]
  rows:
    - [Future_doc_class,   Future.__doc__.__class__.__name__.__eq__,   ["str"],  true]
    - [Executor_doc_class, Executor.__doc__.__class__.__name__.__eq__, ["str"],  true]

# ---------------------------------------------------------------------------
# State constant string length table — extra279 namespace
#
# _base defines five state string constants for Future instances:
#   PENDING                == 'PENDING'               (len=7)
#   RUNNING                == 'RUNNING'               (len=7)
#   FINISHED               == 'FINISHED'              (len=8)
#   CANCELLED              == 'CANCELLED'             (len=9)
#   CANCELLED_AND_NOTIFIED == 'CANCELLED_AND_NOTIFIED' (len=22)
#
# PENDING and RUNNING are equal length (7); FINISHED adds one char (8);
# CANCELLED adds one more (9); CANCELLED_AND_NOTIFIED is far longer at 22,
# reflecting that it encodes two pieces of state in one string.
# ---------------------------------------------------------------------------

table concurrent_futures_extra279.state_constant_lengths:
  description: "concurrent.futures._base state string constant lengths in cfbasestate279 namespace — PENDING.__len__()==7; RUNNING.__len__()==7 (equal to PENDING); FINISHED.__len__()==8; CANCELLED.__len__()==9; CANCELLED_AND_NOTIFIED.__len__()==22 (longest, encodes two pieces of state); all five constants are str objects; prior specs have not measured the length of these _base-level state constants; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: cfbasestate279

  columns: [id, function, args, expected]
  rows:
    - [PENDING,                concurrent.futures._base.PENDING.__len__,                [], 7]
    - [RUNNING,                concurrent.futures._base.RUNNING.__len__,                [], 7]
    - [FINISHED,               concurrent.futures._base.FINISHED.__len__,               [], 8]
    - [CANCELLED,              concurrent.futures._base.CANCELLED.__len__,              [], 9]
    - [CANCELLED_AND_NOTIFIED, concurrent.futures._base.CANCELLED_AND_NOTIFIED.__len__, [], 22]

# ---------------------------------------------------------------------------
# Standalone invariants — extra279
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra279.Future_doc_is_str:
  description: "concurrent.futures._base.Future.__doc__.__class__.__name__.__eq__('str') returns True — Future.__doc__ is a str (not None); the docstring is 'Represents the result of an asynchronous computation.'; its __class__.__name__ is 'str'; prior specs confirmed Future.__name__, __module__, __qualname__, __mro__, method qualnames, and __dict__ properties, but not __doc__; the presence of a str docstring confirms the class carries user-facing documentation; Executor also has a str __doc__; NEW in extra279: first standalone Future.__doc__ type check in cfbase279 namespace; verified with Python 3.14.3"
  category: class_structure
  kind: python_call_eq
  function: Future.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra279.Executor_doc_is_str:
  description: "concurrent.futures._base.Executor.__doc__.__class__.__name__.__eq__('str') returns True — Executor.__doc__ is a str (not None); Executor is the abstract base class for ThreadPoolExecutor and ProcessPoolExecutor; its docstring describes the interface; Executor.__doc__.__class__.__name__ is 'str'; prior specs confirmed Executor.__name__, __module__, __qualname__, __mro__, and Executor.map qualname, but not __doc__; NEW in extra279: first standalone Executor.__doc__ type check in cfbase279 namespace; verified with Python 3.14.3"
  category: class_structure
  kind: python_call_eq
  function: Executor.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra279.PENDING_len_is_7:
  description: "concurrent.futures._base.PENDING.__len__() == 7 — PENDING == 'PENDING' (7 characters); PENDING is the initial state of a Future before it is attached to an executor; RUNNING is also length 7 (equal to PENDING); FINISHED is 8 (one more than PENDING/RUNNING); CANCELLED is 9; CANCELLED_AND_NOTIFIED is 22 (far longer); PENDING.__class__.__name__ is 'str'; prior specs have not measured _base state constant lengths; NEW in extra279: first standalone PENDING length invariant in cfbasestate279 namespace; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: concurrent.futures._base.PENDING.__len__
  args: []
  expected: 7

invariant concurrent_futures_extra279.CANCELLED_AND_NOTIFIED_len_is_22:
  description: "concurrent.futures._base.CANCELLED_AND_NOTIFIED.__len__() == 22 — CANCELLED_AND_NOTIFIED == 'CANCELLED_AND_NOTIFIED' (22 characters); this is the longest of the five Future state strings; CANCELLED_AND_NOTIFIED is an internal state used after Future.cancel() has been called and all done-callbacks have been dispatched; compare lengths: PENDING=7, RUNNING=7, FINISHED=8, CANCELLED=9, CANCELLED_AND_NOTIFIED=22; CANCELLED_AND_NOTIFIED is 13 chars longer than CANCELLED; CANCELLED_AND_NOTIFIED.__class__.__name__ is 'str'; NEW in extra279: first standalone CANCELLED_AND_NOTIFIED length invariant in cfbasestate279 namespace; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: concurrent.futures._base.CANCELLED_AND_NOTIFIED.__len__
  args: []
  expected: 22

invariant concurrent_futures_extra279.FINISHED_len_is_8:
  description: "concurrent.futures._base.FINISHED.__len__() == 8 — FINISHED == 'FINISHED' (8 characters); FINISHED is the terminal success state of a Future; compare: PENDING=7, RUNNING=7, FINISHED=8, CANCELLED=9; FINISHED is one character longer than PENDING/RUNNING and one shorter than CANCELLED; FINISHED.__class__.__name__ is 'str'; NEW in extra279: first standalone FINISHED length invariant in cfbasestate279 namespace; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: concurrent.futures._base.FINISHED.__len__
  args: []
  expected: 8
