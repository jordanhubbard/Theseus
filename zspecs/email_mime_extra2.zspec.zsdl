spec: email_mime_extra2
version: ">=3.0"
backend: python_module(email.mime.image)

docs: https://docs.python.org/3/library/email.mime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/email.mime.html — Python email.mime documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/mime/image.py"
    - "CPython source: Lib/email/mime/nonmultipart.py"
  notes:
    - "This spec extends email_mime.zspec.zsdl and email_mime_extra.zspec.zsdl."
    - "email_mime.zspec.zsdl covers: MIMEText __name__/__module__/__bases__[0].__name__; MIMEText content_type (plain/html/default); MIMEText payload (plain/html); MIMEText get_content_maintype/get_content_subtype."
    - "email_mime_extra.zspec.zsdl covers: MIMEMultipart/MIMEText/MIMEBase __name__ table; MIMEMultipart/MIMEText/MIMEBase __module__ table; MIMEText/__bases__[0], MIMEMultipart/__bases__[0], MIMEBase/__bases__[0] hierarchy; MIMEMultipart default content type and is_multipart; MIMEText default content type and is_multipart; MIMEBase content type and maintype."
    - "Focus: MIMEImage and MIMENonMultipart — not covered in any prior email.mime spec."
    - "MIMEImage.__name__ == 'MIMEImage' — identity check for image MIME class."
    - "MIMEImage.__module__ == 'email.mime.image' — module check."
    - "MIMEImage.__qualname__ == 'MIMEImage' — qualname check."
    - "MIMEImage.__bases__[0].__name__ == 'MIMENonMultipart' — inherits from MIMENonMultipart."
    - "MIMENonMultipart.__name__ == 'MIMENonMultipart' — identity check."
    - "MIMENonMultipart.__module__ == 'email.mime.nonmultipart'."
    - "MIMENonMultipart.__bases__[0].__name__ == 'MIMEBase' — inherits from MIMEBase."
    - "MIMEImage(b'GIF89a', _subtype='gif').get_content_type() == 'image/gif'."
    - "MIMEMultipart('alternative') content type == 'multipart/alternative' — new subtype axis."
    - "MIMEMultipart('related') content type == 'multipart/related' — new subtype axis."
    - "MIMEText __qualname__ and MIMEBase __qualname__ and MIMEMultipart __qualname__ — not checked in prior specs."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MIMEImage — class identity checks
#
# No prior email.mime spec mentions MIMEImage. It lives in email.mime.image
# and inherits from MIMENonMultipart.
# ---------------------------------------------------------------------------

table email_mime_extra2.MIMEImage_identity:
  kind: python_call_eq
  category: MIMEImage
  id_prefix: img

  columns: [id, function, args, expected]
  rows:
    - [name,     MIMEImage.__name__.__eq__,          ["MIMEImage"],        true]
    - [module,   MIMEImage.__module__.__eq__,         ["email.mime.image"], true]
    - [qualname, MIMEImage.__qualname__.__eq__,       ["MIMEImage"],        true]

invariant email_mime_extra2.MIMEImage_base:
  description: "MIMEImage.__bases__[0].__name__ == 'MIMENonMultipart'"
  category: hierarchy
  kind: python_call_eq
  function: MIMEImage.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "MIMENonMultipart"

# ---------------------------------------------------------------------------
# MIMEImage behavioral — content type for an explicit subtype
#
# MIMEImage requires image bytes and an explicit _subtype.
# image/gif with a minimal GIF header is verified below.
# ---------------------------------------------------------------------------

invariant email_mime_extra2.MIMEImage_gif_content_type:
  description: "MIMEImage(b'GIF89a', _subtype='gif').get_content_type() == 'image/gif'"
  category: MIMEImage
  kind: python_call_eq
  function: MIMEImage
  args: [!ascii "GIF89a"]
  kwargs: {_subtype: "gif"}
  method: get_content_type
  method_args: []
  expected: "image/gif"

invariant email_mime_extra2.MIMEImage_gif_maintype:
  description: "MIMEImage(b'GIF89a', _subtype='gif').get_content_maintype() == 'image'"
  category: MIMEImage
  kind: python_call_eq
  function: MIMEImage
  args: [!ascii "GIF89a"]
  kwargs: {_subtype: "gif"}
  method: get_content_maintype
  method_args: []
  expected: "image"

# ---------------------------------------------------------------------------
# MIMENonMultipart — class identity checks
#
# No prior email.mime spec checks MIMENonMultipart directly.
# It is imported from email.mime.nonmultipart.
# ---------------------------------------------------------------------------

table email_mime_extra2.MIMENonMultipart_identity:
  kind: python_call_eq
  category: MIMENonMultipart
  id_prefix: nmmp

  columns: [id, function, args, expected]
  rows:
    - [name,     MIMENonMultipart.__name__.__eq__,     ["MIMENonMultipart"],          true]
    - [module,   MIMENonMultipart.__module__.__eq__,    ["email.mime.nonmultipart"],   true]
    - [qualname, MIMENonMultipart.__qualname__.__eq__,  ["MIMENonMultipart"],          true]

invariant email_mime_extra2.MIMENonMultipart_base:
  description: "MIMENonMultipart.__bases__[0].__name__ == 'MIMEBase'"
  category: hierarchy
  kind: python_call_eq
  function: MIMENonMultipart.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "MIMEBase"

# ---------------------------------------------------------------------------
# MIMEMultipart __qualname__ — not checked in prior specs
#
# email_mime_extra checks MIMEMultipart __name__ and __module__ but NOT __qualname__.
# ---------------------------------------------------------------------------

invariant email_mime_extra2.MIMEMultipart_qualname:
  description: "MIMEMultipart.__qualname__ == 'MIMEMultipart'"
  category: MIMEMultipart
  kind: python_call_eq
  function: MIMEMultipart.__qualname__.__eq__
  args: ["MIMEMultipart"]
  expected: true

# ---------------------------------------------------------------------------
# MIMEText __qualname__ — not checked in prior specs
#
# email_mime checks MIMEText __name__ and __module__ but NOT __qualname__.
# ---------------------------------------------------------------------------

invariant email_mime_extra2.MIMEText_qualname:
  description: "MIMEText.__qualname__ == 'MIMEText'"
  category: MIMEText
  kind: python_call_eq
  function: MIMEText.__qualname__.__eq__
  args: ["MIMEText"]
  expected: true

# ---------------------------------------------------------------------------
# MIMEMultipart non-default subtypes — 'alternative' and 'related'
#
# email_mime_extra checks MIMEMultipart() default ('multipart/mixed') only.
# The 'alternative' and 'related' subtypes are new axes.
# ---------------------------------------------------------------------------

invariant email_mime_extra2.MIMEMultipart_alternative:
  description: "MIMEMultipart('alternative').get_content_type() == 'multipart/alternative'"
  category: MIMEMultipart
  kind: python_call_eq
  function: MIMEMultipart
  args: ["alternative"]
  method: get_content_type
  method_args: []
  expected: "multipart/alternative"

invariant email_mime_extra2.MIMEMultipart_related:
  description: "MIMEMultipart('related').get_content_type() == 'multipart/related'"
  category: MIMEMultipart
  kind: python_call_eq
  function: MIMEMultipart
  args: ["related"]
  method: get_content_type
  method_args: []
  expected: "multipart/related"
