    - [SOCK_STREAM_class_SockKind,  "SOCK_STREAM.__class__.__name__.__eq__",   ["SocketKind"], true, "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' (10 chars; IntEnum from Python 3.4+; subclass of int)"]
    - [SOCK_DGRAM_class_SockKind,   "SOCK_DGRAM.__class__.__name__.__eq__",    ["SocketKind"], true, "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' (10 chars; same IntEnum class as SOCK_STREAM; datagram type)"]

# ---------------------------------------------------------------------------
# AddressFamily vs SocketKind class name lengths and values together
#
# Wave 340 theme: class name lengths and all four constant values in one table.
#
# 'AddressFamily' is 13 chars (AF_INET and AF_INET6).
# 'SocketKind' is 10 chars (SOCK_STREAM and SOCK_DGRAM).
# AF_INET(2) < AF_INET6(30). SOCK_STREAM(1) < SOCK_DGRAM(2).
# Also: AF_INET == SOCK_DGRAM == 2 (same integer value, different semantic types).
# No prior socket spec anchors AddressFamily/SocketKind class name lengths or this
# cross-type value coincidence as a table under sockaf158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra158.AF_SOCK_class_name_lengths_and_values:
  description: "socket.AF_INET.__class__.__name__.__len__()==13 / SOCK_STREAM.__class__.__name__.__len__()==10 / AF_INET.__eq__(2)==True / SOCK_STREAM.__eq__(1)==True — 'AddressFamily' is 13 chars (AF_INET and AF_INET6 share this class; 13 > 10 > 3); 'SocketKind' is 10 chars (SOCK_STREAM and SOCK_DGRAM share this class; Python 3.4+ IntEnum); AF_INET is 2 (POSIX; IPv4; cross-platform); SOCK_STREAM is 1 (POSIX; byte-stream; cross-platform; SOCK_STREAM(1) < SOCK_DGRAM(2) < AF_INET(2)); AF_INET(2) == SOCK_DGRAM(2) numerically (same int value, different semantic IntEnum types); length ordering: SocketKind(10) < AddressFamily(13); first sockaf158 anchor for class name lengths"
  kind: python_call_eq
  category: identity
  id_prefix: sockaf158

  columns: [id, function, args, expected, description]
  rows:
    - [AF_class_name_len_13,   "AF_INET.__class__.__name__.__len__",     [], 13, "socket.AF_INET.__class__.__name__.__len__() is 13 ('AddressFamily' = 13 chars; IntEnum for IPv4/IPv6 address families)"]
    - [SOCK_class_name_len_10, "SOCK_STREAM.__class__.__name__.__len__", [], 10, "socket.SOCK_STREAM.__class__.__name__.__len__() is 10 ('SocketKind' = 10 chars; IntEnum for socket types; shorter than AddressFamily)"]
    - [AF_INET_val_2,          "AF_INET.__eq__",                         [2], true, "socket.AF_INET == 2 (POSIX IPv4; cross-platform; same integer value as SOCK_DGRAM==2 but different IntEnum type)"]
    - [SOCK_STREAM_val_1,      "SOCK_STREAM.__eq__",                     [1], true, "socket.SOCK_STREAM == 1 (POSIX TCP-style; cross-platform; SOCK_STREAM(1) < SOCK_DGRAM(2) <= AF_INET(2))"]

# ---------------------------------------------------------------------------
# socket.AF_INET.__eq__(2) — standalone
#
# socket.AF_INET is 2. AF_INET is the POSIX-standardized address family constant for
# IPv4 (Internet Protocol version 4) sockets. The value 2 is standardized across all
# POSIX platforms (Linux, macOS, FreeBSD, Solaris, Windows). AF_INET is used as the
# first argument to socket.socket() to create IPv4 sockets:
# socket.socket(socket.AF_INET, socket.SOCK_STREAM) creates a TCP/IPv4 socket.
# socket.AF_INET is an AddressFamily IntEnum member (Python 3.4+), so AF_INET.__class__
# is socket.AddressFamily (subclass of int and enum.IntEnum). This contrasts with
# IPPROTO_TCP (value 6) which is a plain int (not IntEnum). AF_INET(2) == SOCK_DGRAM(2)
# numerically. No prior socket spec anchors AF_INET.__eq__(2) as a standalone under
# sockaf158. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra158.AF_INET_eq_2:
  description: "socket.AF_INET.__eq__(2) == True — POSIX-standardized IPv4 address family; cross-platform (Linux/macOS/FreeBSD/Windows); used in socket(AF_INET, SOCK_STREAM) for TCP/IPv4; AddressFamily IntEnum member (Python 3.4+; contrasts with IPPROTO_TCP plain 'int'); AF_INET(2)==SOCK_DGRAM(2) numerically (different types); AF_INET.__class__.__name__=='AddressFamily' (13 chars); no prior socket spec anchors this as a standalone; first standalone under sockaf158"
  category: identity
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET6.__eq__(30) — standalone (macOS-specific)
#
# socket.AF_INET6 is 30 on macOS/BSD systems. AF_INET6 is the address family constant
# for IPv6 (Internet Protocol version 6) sockets. On macOS and BSD systems, AF_INET6
# is defined as 30 in <sys/socket.h>. On Linux, AF_INET6 is 10. This platform
# difference is significant: macOS inherited the BSD socket constants which use higher
# values for AF_INET6. Like AF_INET, AF_INET6 is a member of the socket.AddressFamily
# IntEnum. AF_INET6 is used with socket.socket(AF_INET6, SOCK_STREAM) for TCP/IPv6 sockets
# and with SOCK_DGRAM for UDP/IPv6. No prior socket spec anchors AF_INET6.__eq__(30) as
# a standalone under sockaf158. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra158.AF_INET6_eq_30_macos:
  description: "socket.AF_INET6.__eq__(30) == True — macOS/BSD-specific (Linux uses 10); IPv6 address family; defined as 30 in BSD <sys/socket.h>; used in socket(AF_INET6, SOCK_STREAM) for TCP/IPv6; AddressFamily IntEnum member (same class as AF_INET); AF_INET(2) < AF_INET6(30) on macOS; AF_INET6.__class__.__name__=='AddressFamily' (13 chars); no prior socket spec anchors this as a standalone; first standalone under sockaf158"
  category: identity
  kind: python_call_eq
  function: AF_INET6.__eq__
  args: [30]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') — standalone
#
# socket.SOCK_STREAM.__class__.__name__ is 'SocketKind' (10 chars). socket.SocketKind
# is an IntEnum introduced in Python 3.4 (PEP 435) for socket type constants. Members
# include SOCK_STREAM (1), SOCK_DGRAM (2), SOCK_RAW (3), SOCK_RDM (4), SOCK_SEQPACKET (5).
# 'SocketKind' (10 chars) is shorter than 'AddressFamily' (13 chars). Both are
# socket module IntEnums with __module__ == 'socket'. SocketKind contrasts with
# IPPROTO_* constants (extra157 anchors IPPROTO_TCP.__class__.__name__=='int'; plain int).
# No prior socket spec anchors SOCK_STREAM.__class__.__name__ as a standalone under
# sockaf158. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra158.SOCK_STREAM_class_SocketKind:
  description: "socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') == True — 'SocketKind' (10 chars); IntEnum from Python 3.4+ (PEP 435); socket type constants: SOCK_STREAM=1, SOCK_DGRAM=2, SOCK_RAW=3, SOCK_RDM=4, SOCK_SEQPACKET=5; __module__=='socket' (6 chars); contrasts with IPPROTO_* plain 'int' (3 chars; extra157); 'SocketKind'(10) < 'AddressFamily'(13); issubclass(SocketKind, int)==True; no prior socket spec anchors this as a standalone; first standalone under sockaf158"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_DGRAM.__eq__(2) — standalone
#
# socket.SOCK_DGRAM is 2. SOCK_DGRAM is the socket type constant for datagram sockets,
# which provide connectionless, unreliable, fixed-length messages. UDP (User Datagram
# Protocol) uses SOCK_DGRAM: socket.socket(AF_INET, SOCK_DGRAM) creates a UDP socket.
# SOCK_DGRAM is 2 on all POSIX platforms (cross-platform). SOCK_DGRAM(2) numerically
# equals AF_INET(2), illustrating that IntEnum values can coincide across different
# enum types while retaining distinct semantic meanings. SOCK_STREAM(1) < SOCK_DGRAM(2).
# Both are SocketKind IntEnum members (__class__.__name__ == 'SocketKind' = 10 chars).
# No prior socket spec anchors SOCK_DGRAM.__eq__(2) as a standalone under sockaf158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra158.SOCK_DGRAM_eq_2:
  description: "socket.SOCK_DGRAM.__eq__(2) == True — POSIX-standardized datagram socket type; cross-platform; UDP uses SOCK_DGRAM (socket(AF_INET, SOCK_DGRAM)); connectionless/unreliable/fixed-length messages; SOCK_DGRAM(2)==AF_INET(2) numerically (same integer value, different IntEnum types: SocketKind vs AddressFamily); SOCK_STREAM(1) < SOCK_DGRAM(2); SocketKind IntEnum member (10 chars); no prior socket spec anchors this as a standalone; first standalone under sockaf158"
  category: identity
  kind: python_call_eq
  function: SOCK_DGRAM.__eq__
  args: [2]
  expected: true

