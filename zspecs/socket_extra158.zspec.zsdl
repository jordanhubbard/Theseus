    - [AF_INET6_class_AddrFamily, "AF_INET6.__class__.__name__.__eq__",  ["AddressFamily"],  true, "socket.AF_INET6.__class__.__name__ == 'AddressFamily' (13 chars; same IntEnum class as AF_INET; IPv6 family)"]

