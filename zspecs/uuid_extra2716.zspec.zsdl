spec: uuid_extra2716
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/uuid.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 628 theme: __neg__, __pos__, and __abs__ dict-presence checks (unary minus, unary plus, absolute value)."
    - "uuid.UUID is a value-object class representing a universally unique identifier; it does not implement unary arithmetic protocols."
    - "uuid.SafeUUID is an IntEnum subclass representing whether a UUID was generated safely; IntEnum defines __neg__, __pos__, and __abs__ in the int MRO, but SafeUUID itself does NOT define them in its own __dict__."
    - "None of the uuid public classes define __neg__, __pos__, or __abs__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __neg__ dict-presence — absent from all uuid classes
# ---------------------------------------------------------------------------

table uuid_extra2716.neg_protocol:
  description: "__neg__ is absent from all uuid class __dict__s — none implement unary minus in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2716

  columns: [id, function, args, expected]
  rows:
    - ["uu2716001", "uuid.UUID.__dict__.__contains__",     ["__neg__"], false]
    - ["uu2716002", "uuid.SafeUUID.__dict__.__contains__", ["__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — absent from all uuid classes
# ---------------------------------------------------------------------------

table uuid_extra2716.pos_protocol:
  description: "__pos__ is absent from all uuid class __dict__s — none implement unary plus in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2716

  columns: [id, function, args, expected]
  rows:
    - ["uu2716003", "uuid.UUID.__dict__.__contains__",     ["__pos__"], false]
    - ["uu2716004", "uuid.SafeUUID.__dict__.__contains__", ["__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — absent from all uuid classes
# ---------------------------------------------------------------------------

table uuid_extra2716.abs_protocol:
  description: "__abs__ is absent from all uuid class __dict__s — none implement absolute value in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2716

  columns: [id, function, args, expected]
  rows:
    - ["uu2716005", "uuid.UUID.__dict__.__contains__",     ["__abs__"], false]
    - ["uu2716006", "uuid.SafeUUID.__dict__.__contains__", ["__abs__"], false]

# ---------------------------------------------------------------------------
# Combined view — UUID and SafeUUID vs. all three protocols
# ---------------------------------------------------------------------------

table uuid_extra2716.uuid_unary_combined:
  description: "uuid.UUID and uuid.SafeUUID define none of __neg__, __pos__, __abs__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2716

  columns: [id, function, args, expected]
  rows:
    - ["uu2716007", "uuid.UUID.__dict__.__contains__",     ["__neg__"], false]
    - ["uu2716008", "uuid.UUID.__dict__.__contains__",     ["__pos__"], false]
    - ["uu2716009", "uuid.UUID.__dict__.__contains__",     ["__abs__"], false]
    - ["uu2716010", "uuid.SafeUUID.__dict__.__contains__", ["__neg__"], false]
    - ["uu2716011", "uuid.SafeUUID.__dict__.__contains__", ["__pos__"], false]
    - ["uu2716012", "uuid.SafeUUID.__dict__.__contains__", ["__abs__"], false]
