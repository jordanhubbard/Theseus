spec: asyncio_extra991
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio Synchronization Primitives and Queues documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.Semaphore, asyncio.Condition, and asyncio.Queue method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra991.semaphore_qualnames:
  description: "asyncio.Semaphore method __qualname__ identity"
  kind: python_call_eq
  category: semaphore_qualnames
  id_prefix: as991sq
  columns: [id, function, args, expected]
  rows:
    - [as991sq001, asyncio.Semaphore.acquire.__qualname__.__eq__, ["Semaphore.acquire"], true]
    - [as991sq002, asyncio.Semaphore.release.__qualname__.__eq__, ["Semaphore.release"], true]
    - [as991sq003, asyncio.Semaphore.__init__.__qualname__.__eq__, ["Semaphore.__init__"], true]
    - [as991sq004, asyncio.Semaphore.locked.__qualname__.__eq__, ["Semaphore.locked"], true]
    - [as991sq005, asyncio.Semaphore.__repr__.__qualname__.__eq__, ["Semaphore.__repr__"], true]

table asyncio_extra991.condition_qualnames:
  description: "asyncio.Condition method __qualname__ identity"
  kind: python_call_eq
  category: condition_qualnames
  id_prefix: as991cq
  columns: [id, function, args, expected]
  rows:
    - [as991cq001, asyncio.Condition.acquire.__qualname__.__eq__, ["Condition.acquire"], true]
    - [as991cq002, asyncio.Condition.release.__qualname__.__eq__, ["Condition.release"], true]
    - [as991cq003, asyncio.Condition.wait.__qualname__.__eq__, ["Condition.wait"], true]
    - [as991cq004, asyncio.Condition.notify.__qualname__.__eq__, ["Condition.notify"], true]
    - [as991cq005, asyncio.Condition.notify_all.__qualname__.__eq__, ["Condition.notify_all"], true]
    - [as991cq006, asyncio.Condition.__init__.__qualname__.__eq__, ["Condition.__init__"], true]
    - [as991cq007, asyncio.Condition.wait_for.__qualname__.__eq__, ["Condition.wait_for"], true]

table asyncio_extra991.queue_qualnames:
  description: "asyncio.Queue method __qualname__ identity"
  kind: python_call_eq
  category: queue_qualnames
  id_prefix: as991qq
  columns: [id, function, args, expected]
  rows:
    - [as991qq001, asyncio.Queue.get_nowait.__qualname__.__eq__, ["Queue.get_nowait"], true]
    - [as991qq002, asyncio.Queue.put_nowait.__qualname__.__eq__, ["Queue.put_nowait"], true]
    - [as991qq003, asyncio.Queue.task_done.__qualname__.__eq__, ["Queue.task_done"], true]
    - [as991qq004, asyncio.Queue.get.__qualname__.__eq__, ["Queue.get"], true]
    - [as991qq005, asyncio.Queue.put.__qualname__.__eq__, ["Queue.put"], true]
    - [as991qq006, asyncio.Queue.qsize.__qualname__.__eq__, ["Queue.qsize"], true]
    - [as991qq007, asyncio.Queue.join.__qualname__.__eq__, ["Queue.join"], true]
