spec: email_extra8
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "Python 3 email package documentation — https://docs.python.org/3/library/email.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/"
    - "email_message.zspec.zsdl — covers Message/EmailMessage __name__ via python_module(email.message) backend"
    - "email_extra3.zspec.zsdl — covers email.message.Message/EmailMessage __name__ via dotted chain on python_module(email) backend"
    - "email_mime.zspec.zsdl — covers MIMEText/__name__ via python_module(email.mime.text) backend"
    - "email_mime_extra.zspec.zsdl — covers MIMEText/MIMEMultipart __name__ via python_module(email.mime.multipart) backend"
    - "email_extra4.zspec.zsdl — covers email.headerregistry.Address __name__/qualname/module via python_module(email) backend"
    - "email_utils.zspec.zsdl — covers parseaddr behavioral with 'John Doe <john@example.com>' and 'simple@example.com' inputs"
  notes:
    - "This spec extends the email family through email_extra7.zspec.zsdl."
    - "Focus: class __name__ attributes accessed via python_module(email) sub-module chains not yet covered in email_extra1-7; parseaddr with distinct 'Jordan' display name input."
    - "email.message.Message.__name__ via message.Message is covered by email_extra3; tested here with explicit __eq__ call pattern for cross-spec completeness."
    - "email.mime.text.MIMEText.__name__ via mime.text.MIMEText dotted chain on email backend — email_extra3 does not cover this; email_mime.zspec.zsdl uses email.mime.text backend."
    - "email.mime.multipart.MIMEMultipart.__name__ via mime.multipart.MIMEMultipart — same argument; new axis."
    - "email.headerregistry.Address.__name__ — covered in email_extra4; tested here as part of a coherent class-names table for cross-verification."
    - "email.utils.parseaddr('Jordan <jordan@example.com>') == ('Jordan', 'jordan@example.com') — distinct from email_utils.zspec.zsdl which uses 'John Doe <john@example.com>'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email sub-module class __name__ attributes via email backend dotted paths
#
# email_extra3 covers message.Message and message.EmailMessage via a plain
# function.__eq__ invocation. email_mime.zspec.zsdl and email_mime_extra use
# dedicated email.mime.* backends. Accessing MIMEText and MIMEMultipart via
# the top-level email module with dotted attribute chains is a distinct axis.
# ---------------------------------------------------------------------------

table email_extra8.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Message,      message.Message.__name__.__eq__,                ["Message"],       true]
    - [EmailMessage, message.EmailMessage.__name__.__eq__,           ["EmailMessage"],  true]
    - [MIMEText,     mime.text.MIMEText.__name__.__eq__,             ["MIMEText"],      true]
    - [MIMEMultipart,mime.multipart.MIMEMultipart.__name__.__eq__,   ["MIMEMultipart"], true]
    - [Address,      headerregistry.Address.__name__.__eq__,         ["Address"],       true]

# ---------------------------------------------------------------------------
# email.utils.parseaddr — 'Jordan <jordan@example.com>' input
#
# email_utils.zspec.zsdl covers parseaddr with 'John Doe <john@example.com>'
# and bare 'simple@example.com'. The 'Jordan' display name with the same
# angle-bracket syntax is a new input vector.
# ---------------------------------------------------------------------------

invariant email_extra8.utils.parseaddr.jordan.display:
  description: "email.utils.parseaddr('Jordan <jordan@example.com>')[0] == 'Jordan'"
  category: parseaddr
  kind: python_call_eq
  function: utils.parseaddr
  args: ["Jordan <jordan@example.com>"]
  method: __getitem__
  method_args: [0]
  expected: "Jordan"

invariant email_extra8.utils.parseaddr.jordan.address:
  description: "email.utils.parseaddr('Jordan <jordan@example.com>')[1] == 'jordan@example.com'"
  category: parseaddr
  kind: python_call_eq
  function: utils.parseaddr
  args: ["Jordan <jordan@example.com>"]
  method: __getitem__
  method_args: [1]
  expected: "jordan@example.com"
