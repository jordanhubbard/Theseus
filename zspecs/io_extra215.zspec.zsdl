spec: io_extra215
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* constants, TextIOWrapper, BufferedRandom, UnsupportedOperation class metadata"
    - "io_extra214.zspec.zsdl — covers io.IOBase, RawIOBase, BufferedIOBase, TextIOBase __dict__ membership"
  notes:
    - "io.TextIOWrapper.__dict__ contains concrete method implementations: read, write, readline, flush, seek, tell."
    - "io.BytesIO.__dict__ contains concrete method implementations: read, write, getvalue, seek, tell."
    - "io.StringIO.__dict__ contains concrete method implementations: read, write, getvalue, seek."
    - "TextIOWrapper and BytesIO are concrete (non-abstract) classes backed by the _io C extension."
    - "All __dict__.__contains__ checks return True for these concrete methods; confirmed Python 3.14.3 macOS."
    - "io.TextIOWrapper.__dict__.__contains__('read') == True; confirmed Python 3.14.3 macOS."
    - "io.BytesIO.__dict__.__contains__('read') == True; confirmed Python 3.14.3 macOS."
    - "io.StringIO.__dict__.__contains__('getvalue') == True; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.TextIOWrapper.__dict__ membership — concrete read/write methods
# read, write, readline are present in TextIOWrapper.__dict__ (concrete impl)
# ---------------------------------------------------------------------------

table io_extra215.textiowrapper_dict_rw_methods:
  description: "io.TextIOWrapper.__dict__ contains concrete read/write/readline method implementations"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioannotations215

  columns: [id, function, args, expected, description]
  rows:
    - [textwrapper_has_read,      "io.TextIOWrapper.__dict__.__contains__",  ["read"],      true,  "io.TextIOWrapper.__dict__.__contains__('read') == True; read is a concrete method on TextIOWrapper; confirmed Python 3.14.3 macOS"]
    - [textwrapper_has_write,     "io.TextIOWrapper.__dict__.__contains__",  ["write"],     true,  "io.TextIOWrapper.__dict__.__contains__('write') == True; write is a concrete method on TextIOWrapper; confirmed Python 3.14.3 macOS"]
    - [textwrapper_has_readline,  "io.TextIOWrapper.__dict__.__contains__",  ["readline"],  true,  "io.TextIOWrapper.__dict__.__contains__('readline') == True; readline is a concrete method on TextIOWrapper; confirmed Python 3.14.3 macOS"]
    - [textwrapper_has_flush,     "io.TextIOWrapper.__dict__.__contains__",  ["flush"],     true,  "io.TextIOWrapper.__dict__.__contains__('flush') == True; flush is a concrete method on TextIOWrapper; confirmed Python 3.14.3 macOS"]
    - [textwrapper_has_seek,      "io.TextIOWrapper.__dict__.__contains__",  ["seek"],      true,  "io.TextIOWrapper.__dict__.__contains__('seek') == True; seek is a concrete method on TextIOWrapper; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.BytesIO.__dict__ membership — concrete read/write/getvalue/seek/tell
# BytesIO is a concrete in-memory bytes buffer; all I/O methods live in __dict__
# ---------------------------------------------------------------------------

table io_extra215.bytesio_dict_methods:
  description: "io.BytesIO.__dict__ contains concrete I/O method implementations"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioannotations215

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_has_read,      "io.BytesIO.__dict__.__contains__",  ["read"],      true,  "io.BytesIO.__dict__.__contains__('read') == True; read is a concrete method on BytesIO; confirmed Python 3.14.3 macOS"]
    - [bytesio_has_write,     "io.BytesIO.__dict__.__contains__",  ["write"],     true,  "io.BytesIO.__dict__.__contains__('write') == True; write is a concrete method on BytesIO; confirmed Python 3.14.3 macOS"]
    - [bytesio_has_getvalue,  "io.BytesIO.__dict__.__contains__",  ["getvalue"],  true,  "io.BytesIO.__dict__.__contains__('getvalue') == True; getvalue is a concrete method on BytesIO; confirmed Python 3.14.3 macOS"]
    - [bytesio_has_seek,      "io.BytesIO.__dict__.__contains__",  ["seek"],      true,  "io.BytesIO.__dict__.__contains__('seek') == True; seek is a concrete method on BytesIO; confirmed Python 3.14.3 macOS"]
    - [bytesio_has_tell,      "io.BytesIO.__dict__.__contains__",  ["tell"],      true,  "io.BytesIO.__dict__.__contains__('tell') == True; tell is a concrete method on BytesIO; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
