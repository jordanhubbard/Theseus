spec: errno_extra5
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/errno.html"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "Extends errno.zspec.zsdl through errno_extra4.zspec.zsdl."
    - "errno.zspec covers: EPERM=1, ENOENT=2, ESRCH=3, EINTR=4, EIO=5, EBADF=9, ENOMEM=12, EACCES=13, EINVAL=22 values; errorcode type/lookups 1/2/22."
    - "errno_extra covers: class names for ENOENT/EACCES/EEXIST/EPERM; errorcode class name; errorcode[2] eq 'ENOENT' via method; contains key 2."
    - "errno_extra2 covers: class names EPERM/ENOENT/ESRCH/EINTR/EIO/ENXIO/EACCES/EEXIST/ENOTDIR/EISDIR; errorcode class/len>=50; positivity EPERM/ENOENT/EACCES."
    - "errno_extra3 covers: class names EBADF/ENOMEM/EINVAL; errorcode lookups 9/12; contains 9/12."
    - "errno_extra4 covers: class names ENOSPC/EPIPE/ERANGE/EMFILE/ENFILE; errorcode lookups 5/13/28/32; positivity ESRCH/EINTR/EIO."
    - "This spec adds: constant values for ECHILD=10, EFAULT=14, ENOTDIR=20, EISDIR=21, ENXIO=6 (not previously checked as values, only class names); errorcode reverse-lookups for keys 3 (ESRCH), 4 (EINTR), 6 (ENXIO), 10 (ECHILD), 14 (EFAULT); errorcode __contains__ for keys 5, 13, 22; positivity checks for EBADF, ENOMEM, EINVAL."
    - "errno.ECHILD == 10 on POSIX (no child processes)."
    - "errno.EFAULT == 14 on POSIX (bad address)."
    - "errno.ENOTDIR == 20 on POSIX (not a directory)."
    - "errno.EISDIR == 21 on POSIX (is a directory)."
    - "errno.ENXIO == 6 on POSIX (device not configured / no such device or address)."
    - "errorcode[3] == 'ESRCH', [4] == 'EINTR', [6] == 'ENXIO', [10] == 'ECHILD', [14] == 'EFAULT' — all verified on macOS/Darwin 25.4.0."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Constant values for ECHILD, EFAULT, ENOTDIR, EISDIR, ENXIO
#
# These constants had their class names verified in prior specs (errno_extra2
# for ENOTDIR/EISDIR/ENXIO), but their numeric values were never checked.
# ECHILD and EFAULT are new on every axis.
# ---------------------------------------------------------------------------

table errno_extra5.constant_values:
  description: "ECHILD, EFAULT, ENOTDIR, EISDIR, ENXIO have correct POSIX numeric values"
  kind: python_call_eq
  category: constants
  id_prefix: val

  columns: [id, function, args, expected]
  rows:
    - [ENXIO,   ENXIO.__eq__,   [6],  true]
    - [ECHILD,  ECHILD.__eq__,  [10], true]
    - [EFAULT,  EFAULT.__eq__,  [14], true]
    - [ENOTDIR, ENOTDIR.__eq__, [20], true]
    - [EISDIR,  EISDIR.__eq__,  [21], true]

# ---------------------------------------------------------------------------
# errorcode reverse-lookups — keys 3, 4, 6, 10, 14
#
# errno.zspec covers 1, 2, 22; errno_extra3 covers 9, 12;
# errno_extra4 covers 5, 13, 28, 32. New here: 3, 4, 6, 10, 14.
# ---------------------------------------------------------------------------

invariant errno_extra5.errorcode.esrch_lookup:
  description: "errno.errorcode[3] == 'ESRCH' — reverse-lookup of errno 3 (no such process)"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [3]
  expected: "ESRCH"

invariant errno_extra5.errorcode.eintr_lookup:
  description: "errno.errorcode[4] == 'EINTR' — reverse-lookup of errno 4 (interrupted system call)"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [4]
  expected: "EINTR"

invariant errno_extra5.errorcode.enxio_lookup:
  description: "errno.errorcode[6] == 'ENXIO' — reverse-lookup of errno 6 (no such device or address)"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [6]
  expected: "ENXIO"

invariant errno_extra5.errorcode.echild_lookup:
  description: "errno.errorcode[10] == 'ECHILD' — reverse-lookup of errno 10 (no child processes)"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [10]
  expected: "ECHILD"

invariant errno_extra5.errorcode.efault_lookup:
  description: "errno.errorcode[14] == 'EFAULT' — reverse-lookup of errno 14 (bad address)"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [14]
  expected: "EFAULT"

# ---------------------------------------------------------------------------
# errorcode __contains__ — keys 5, 13, 22 not yet checked with __contains__
#
# errno_extra covers key 2; errno_extra3 covers 9, 12. New: 5, 13, 22.
# ---------------------------------------------------------------------------

invariant errno_extra5.errorcode.contains_eio_key:
  description: "5 in errno.errorcode — EIO key is present on all POSIX platforms"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [5]
  expected: true

invariant errno_extra5.errorcode.contains_eacces_key:
  description: "13 in errno.errorcode — EACCES key is present on all POSIX platforms"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [13]
  expected: true

invariant errno_extra5.errorcode.contains_einval_key:
  description: "22 in errno.errorcode — EINVAL key is present on all POSIX platforms"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [22]
  expected: true

# ---------------------------------------------------------------------------
# Positivity checks — EBADF, ENOMEM, EINVAL not yet checked for positivity
#
# errno_extra2 covers EPERM/ENOENT/EACCES; errno_extra4 covers ESRCH/EINTR/EIO.
# New here: EBADF (9), ENOMEM (12), EINVAL (22).
# ---------------------------------------------------------------------------

invariant errno_extra5.EBADF_positive:
  description: "errno.EBADF > 0 — EBADF == 9 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: EBADF.__gt__
  args: [0]
  expected: true

invariant errno_extra5.ENOMEM_positive:
  description: "errno.ENOMEM > 0 — ENOMEM == 12 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: ENOMEM.__gt__
  args: [0]
  expected: true

invariant errno_extra5.EINVAL_positive:
  description: "errno.EINVAL > 0 — EINVAL == 22 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: EINVAL.__gt__
  args: [0]
  expected: true
