spec: builtins_extra15
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/functions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functions.html — Python built-in functions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins_extra.zspec.zsdl — covers abs/divmod/pow/round/sum/max/min function calls"
    - "builtins_extra13.zspec.zsdl — covers str/list/dict/tuple/set __name__; len/__name__/__class__.__name__; print/__class__.__name__; bool/int/str __bases__.__len__()"
    - "builtins_extra14.zspec.zsdl — covers abs/divmod/sum/round/pow/max/min additional vectors"
  notes:
    - "This spec extends builtins.zspec.zsdl and prior extras through builtins_extra14.zspec.zsdl."
    - "isinstance.__name__ == 'isinstance' — built-in function name attribute matches identifier."
    - "issubclass.__name__ == 'issubclass' — built-in function name attribute matches identifier."
    - "hasattr.__name__ == 'hasattr' — built-in function name attribute matches identifier."
    - "getattr.__name__ == 'getattr' — built-in function name attribute matches identifier."
    - "setattr.__name__ == 'setattr' — built-in function name attribute matches identifier."
    - "delattr.__name__ == 'delattr' — built-in function name attribute matches identifier."
    - "callable.__name__ == 'callable' — built-in function name attribute matches identifier."
    - "isinstance/issubclass/hasattr/getattr/setattr/delattr/callable all have __module__ == 'builtins'."
    - "type.__qualname__ == 'type' — the type metaclass has qualname equal to its name."
    - "object.__qualname__ == 'object' — the root base class has qualname equal to its name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# isinstance, issubclass, hasattr, getattr, setattr, delattr, callable
# — __name__ attributes
#
# No prior builtins spec covers the __name__ attributes of these introspection
# and attribute-manipulation built-ins. Each function's __name__ equals its
# own identifier string.
# ---------------------------------------------------------------------------

table builtins_extra15.introspection_names:
  description: "isinstance/issubclass/hasattr/getattr/setattr/delattr/callable __name__ attributes"
  kind: python_call_eq
  category: function_names

  columns: [id, function, args, expected]
  rows:
    - [isinstance,  isinstance.__name__.__eq__,  ["isinstance"],  true]
    - [issubclass,  issubclass.__name__.__eq__,  ["issubclass"],  true]
    - [hasattr,     hasattr.__name__.__eq__,     ["hasattr"],     true]
    - [getattr,     getattr.__name__.__eq__,     ["getattr"],     true]
    - [setattr,     setattr.__name__.__eq__,     ["setattr"],     true]
    - [delattr,     delattr.__name__.__eq__,     ["delattr"],     true]
    - [callable,    callable.__name__.__eq__,    ["callable"],    true]

# ---------------------------------------------------------------------------
# isinstance, issubclass, hasattr, getattr, setattr, delattr, callable
# — __module__ attributes
#
# All of these introspection built-ins are defined in the 'builtins' module.
# No prior spec covers their __module__ attributes as a group.
# ---------------------------------------------------------------------------

table builtins_extra15.introspection_modules:
  description: "isinstance/issubclass/hasattr/getattr/setattr/delattr/callable __module__ == 'builtins'"
  kind: python_call_eq
  category: function_modules

  columns: [id, function, args, expected]
  rows:
    - [isinstance,  isinstance.__module__.__eq__,  ["builtins"], true]
    - [issubclass,  issubclass.__module__.__eq__,  ["builtins"], true]
    - [hasattr,     hasattr.__module__.__eq__,     ["builtins"], true]
    - [getattr,     getattr.__module__.__eq__,     ["builtins"], true]
    - [setattr,     setattr.__module__.__eq__,     ["builtins"], true]
    - [delattr,     delattr.__module__.__eq__,     ["builtins"], true]
    - [callable,    callable.__module__.__eq__,    ["builtins"], true]

# ---------------------------------------------------------------------------
# type and object — __qualname__
#
# type and object are the two fundamental classes in Python's type system.
# No prior builtins spec checks their __qualname__ attributes.
# Both are simple non-nested classes so qualname equals name.
# ---------------------------------------------------------------------------

invariant builtins_extra15.type.qualname:
  description: "type.__qualname__ == 'type' — the type metaclass qualname equals its name"
  category: classes
  kind: python_call_eq
  function: type.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant builtins_extra15.object.qualname:
  description: "object.__qualname__ == 'object' — the root base class qualname equals its name"
  category: classes
  kind: python_call_eq
  function: object.__qualname__.__eq__
  args: ["object"]
  expected: true
