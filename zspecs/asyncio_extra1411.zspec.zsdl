spec: asyncio_extra1411
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio queue documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio tasks documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py, Lib/asyncio/queues.py, Lib/asyncio/tasks.py"
  notes:
    - "Wave 541 (_extra1411): focuses on __sizeof__ method type and presence, plus __reduce_ex__ checks for asyncio classes."
    - "All asyncio synchronization primitive classes (Queue, Task, Future, Lock, Event, Semaphore, Barrier, TaskGroup) have __sizeof__ with type 'method_descriptor' and __reduce_ex__ with type 'method_descriptor'."
    - "None of these classes define __sizeof__ or __reduce_ex__ in their own __dict__ — both are inherited from object."
    - "asyncio.Queue.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in asyncio.Queue.__dict__."
    - "asyncio.Task.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in asyncio.Task.__dict__."
    - "asyncio.Future.__sizeof__.__class__.__name__ == 'method_descriptor'; '__sizeof__' not in asyncio.Future.__dict__."
    - "asyncio.Lock.__reduce_ex__.__class__.__name__ == 'method_descriptor'; '__reduce_ex__' not in asyncio.Lock.__dict__."
    - "asyncio.Event.__reduce_ex__.__class__.__name__ == 'method_descriptor'; '__reduce_ex__' not in asyncio.Event.__dict__."
    - "asyncio.Semaphore.__reduce_ex__.__class__.__name__ == 'method_descriptor'; '__reduce_ex__' not in asyncio.Semaphore.__dict__."
    - "asyncio.Barrier.__sizeof__.__class__.__name__ == 'method_descriptor'; asyncio.TaskGroup.__sizeof__.__class__.__name__ == 'method_descriptor'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra1411.sizeof_class_name:
  description: "asyncio class __sizeof__.__class__.__name__ identity checks — all asyncio sync primitive classes inherit __sizeof__ from object hierarchy; type is 'method_descriptor' for all pure-Python class types; none define __sizeof__ in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: sizeof_class_name
  id_prefix: as1411sz
  columns: [id, function, args, expected]
  rows:
    - [as1411sz001, asyncio.Queue.__sizeof__.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [as1411sz002, asyncio.Task.__sizeof__.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [as1411sz003, asyncio.Future.__sizeof__.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [as1411sz004, asyncio.Lock.__sizeof__.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [as1411sz005, asyncio.Event.__sizeof__.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [as1411sz006, asyncio.Semaphore.__sizeof__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [as1411sz007, asyncio.Barrier.__sizeof__.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [as1411sz008, asyncio.TaskGroup.__sizeof__.__class__.__name__.__eq__, ["method_descriptor"], true]

table asyncio_extra1411.sizeof_not_in_dict:
  description: "asyncio class __sizeof__ absence from own __dict__ — none of the asyncio sync primitive classes define __sizeof__ directly; they all inherit it from object; __dict__.__contains__('__sizeof__') is False for each; verified with Python 3.14.3"
  kind: python_call_eq
  category: sizeof_dict_membership
  id_prefix: as1411sd
  columns: [id, function, args, expected]
  rows:
    - [as1411sd001, asyncio.Queue.__dict__.__contains__,     ["__sizeof__"], false]
    - [as1411sd002, asyncio.Task.__dict__.__contains__,      ["__sizeof__"], false]
    - [as1411sd003, asyncio.Future.__dict__.__contains__,    ["__sizeof__"], false]
    - [as1411sd004, asyncio.Lock.__dict__.__contains__,      ["__sizeof__"], false]
    - [as1411sd005, asyncio.Event.__dict__.__contains__,     ["__sizeof__"], false]
    - [as1411sd006, asyncio.Semaphore.__dict__.__contains__,  ["__sizeof__"], false]
    - [as1411sd007, asyncio.Barrier.__dict__.__contains__,   ["__sizeof__"], false]
    - [as1411sd008, asyncio.TaskGroup.__dict__.__contains__,  ["__sizeof__"], false]

