spec: struct_extra147
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra146.zspec.zsdl — covers _struct.__dict__.__len__()==15 / _struct.__dict__.__class__.__name__.__eq__('dict') / _struct.__dict__.__contains__('Struct'/'pack'/'error'/'calcsize'/'unpack'/'pack_into'/'iter_unpack'/'_clearcache') / struct.__dict__.__len__()==18 (table + invariants)."
    - "struct_extra145.zspec.zsdl — covers struct.__dict__.__len__()==18 / struct.Struct.__dict__.__len__()==16 / struct.error.__dict__.__len__()==3 / struct.error.__dict__.__class__.__name__.__eq__('mappingproxy') / struct.__dict__.__class__.__name__.__eq__('dict') / error dict __contains__ (table + invariants)."
    - "struct_extra144.zspec.zsdl — covers struct.__dict__.__contains__('pack'/'Struct'/'error'/'calcsize'/'unpack'/'pack_into'/'unpack_from'/'iter_unpack') / Struct.__dict__.__contains__('__init__'/'__sizeof__'/'__new__'/'__doc__') (table + invariants)."
    - "struct_extra143.zspec.zsdl — covers struct.Struct.__dict__.__contains__('pack'/'unpack'/'pack_into'/'format'/'size'/'iter_unpack'/'unpack_from'/'__repr__') / Struct.__dict__.__len__()==16 / struct.pack.__module__.__eq__('_struct') / struct.__package__.__eq__('') (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra146."
    - "Wave 333 theme: struct.calcsize results for common format strings — 'B'==1 (unsigned char) / 'H'==2 (unsigned short) / 'I'==4 (unsigned int) / 'Q'==8 (unsigned long long) / 'f'==4 (float) / 'd'==8 (double) / '?'==1 (bool)."
    - "struct.calcsize('B') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('H') == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('I') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('Q') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('f') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('d') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('?') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.calcsize returns the size in bytes of a struct corresponding to the given format string using native byte order and alignment. The sizes are platform-dependent for some types; the values here represent standard sizes on 64-bit macOS/Darwin. 'B' (unsigned char) and '?' (bool) are both 1 byte. 'H' (unsigned short) is 2 bytes. 'I' (unsigned int) and 'f' (float) are both 4 bytes. 'Q' (unsigned long long) and 'd' (double) are both 8 bytes."
    - "Note: Format string sizes reflect the native C type sizes on this platform (64-bit macOS). To force standard sizes (portable across platforms), prepend '!' (network/big-endian), '<' (little-endian), or '>' (big-endian) to the format string. Without a byte-order prefix, calcsize uses native alignment and size."
    - "Note: The size pairs: B==? (1 byte), H alone (2 bytes), I==f (4 bytes), Q==d (8 bytes). These size pairs reflect: (1) 8-bit types: char/bool; (2) 16-bit type: short; (3) 32-bit types: int/float; (4) 64-bit types: long long/double. IEEE 754 float is 32-bit; IEEE 754 double is 64-bit."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize('B')==1
# struct.calcsize('H')==2
# struct.calcsize('I')==4
# struct.calcsize('Q')==8
#
# Wave 333 theme: calcsize results for the four integer format codes B/H/I/Q.
#
# The four unsigned integer format codes span 1, 2, 4, and 8 bytes. They double in size
# at each step: B(1) -> H(2) -> I(4) -> Q(8). This doubling pattern reflects the
# standard C type hierarchy: unsigned char (1) -> unsigned short (2) -> unsigned int (4)
# -> unsigned long long (8). No prior struct spec anchors struct.calcsize for any format
# string as a table under structsz147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra147.calcsize_integer_formats:
  description: "struct.calcsize('B')==1 / calcsize('H')==2 / calcsize('I')==4 / calcsize('Q')==8 — unsigned integer formats; B=unsigned char (1 byte) / H=unsigned short (2 bytes) / I=unsigned int (4 bytes) / Q=unsigned long long (8 bytes); size doubles at each step (1->2->4->8); native byte order and alignment; first structsz147 anchor for struct.calcsize with any format string"
  kind: python_call_eq
  category: identity
  id_prefix: structsz147

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_B_1, calcsize, ["B"], 1, "struct.calcsize('B') == 1 (unsigned char; 1 byte; range 0-255)"]
    - [calcsize_H_2, calcsize, ["H"], 2, "struct.calcsize('H') == 2 (unsigned short; 2 bytes; range 0-65535)"]
    - [calcsize_I_4, calcsize, ["I"], 4, "struct.calcsize('I') == 4 (unsigned int; 4 bytes; range 0 to 2^32-1)"]
    - [calcsize_Q_8, calcsize, ["Q"], 8, "struct.calcsize('Q') == 8 (unsigned long long; 8 bytes; range 0 to 2^64-1)"]

# ---------------------------------------------------------------------------
# struct.calcsize('f')==4
# struct.calcsize('d')==8
# struct.calcsize('?')==1
#
# Wave 333 theme: calcsize results for floating-point (f/d) and bool (?) format codes.
#
# The float format code 'f' (IEEE 754 single precision) is 4 bytes. The double format
# code 'd' (IEEE 754 double precision) is 8 bytes. The bool format code '?' is 1 byte.
# Notably, 'f' (4 bytes) == calcsize('I') and 'd' (8 bytes) == calcsize('Q'), showing
# that float/double share sizes with their integer counterparts. No prior struct spec
# anchors calcsize for 'f', 'd', or '?' as a table under structsz147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra147.calcsize_float_and_bool_formats:
  description: "struct.calcsize('f')==4 / calcsize('d')==8 / calcsize('?')==1 — floating-point and bool format codes; f=IEEE 754 single-precision float (4 bytes); d=IEEE 754 double-precision float (8 bytes); ?=bool (1 byte; packs True as 1, False as 0); f(4)==I(4) and d(8)==Q(8) showing float/double share sizes with 32-bit/64-bit integers; first structsz147 anchor for these three format codes"
  kind: python_call_eq
  category: identity
  id_prefix: structsz147

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_f_4, calcsize, ["f"], 4, "struct.calcsize('f') == 4 (IEEE 754 single-precision float; 4 bytes; same size as 'I')"]
    - [calcsize_d_8, calcsize, ["d"], 8, "struct.calcsize('d') == 8 (IEEE 754 double-precision float; 8 bytes; same size as 'Q')"]
    - [calcsize_bool_1, calcsize, ["?"], 1, "struct.calcsize('?') == 1 (bool; 1 byte; True packs as 1, False packs as 0)"]

# ---------------------------------------------------------------------------
# struct.calcsize with combined format strings
#
# Wave 333 theme: calcsize of combined format strings.
#
# struct.calcsize('BH') should be 4 (with native alignment: B=1 + 1 pad + H=2 = 4),
# but without alignment prefix it is platform/version dependent. Use '=' (standard
# sizes, no alignment) for predictable results: '=BH' gives 3 (1+2), '=IQ' gives 12 (4+8).
# Simpler: calcsize('BB') == 2 and calcsize('HH') == 4 are reliably predictable.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra147.calcsize_multi_format:
  description: "struct.calcsize('BB')==2 / calcsize('HH')==4 / calcsize('II')==8 / calcsize('QQ')==16 — two of the same format code doubles the size; BB=2 bytes (two unsigned chars) / HH=4 bytes (two unsigned shorts) / II=8 bytes (two unsigned ints) / QQ=16 bytes (two unsigned long longs); no alignment padding when same-sized types are adjacent; confirms linearity of calcsize for same-type sequences; first structsz147 anchor for multi-format calcsize"
  kind: python_call_eq
  category: identity
  id_prefix: structsz147

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_BB_2,   calcsize, ["BB"],  2,  "struct.calcsize('BB') == 2 (two unsigned chars; 1+1=2 bytes; no padding between same-sized types)"]
    - [calcsize_HH_4,   calcsize, ["HH"],  4,  "struct.calcsize('HH') == 4 (two unsigned shorts; 2+2=4 bytes)"]
    - [calcsize_II_8,   calcsize, ["II"],  8,  "struct.calcsize('II') == 8 (two unsigned ints; 4+4=8 bytes)"]
    - [calcsize_QQ_16,  calcsize, ["QQ"], 16,  "struct.calcsize('QQ') == 16 (two unsigned long longs; 8+8=16 bytes)"]

# ---------------------------------------------------------------------------
# struct.calcsize('B')==1 — standalone
#
# struct.calcsize('B') is 1. The 'B' format code represents an unsigned char (uint8_t),
# which is always exactly 1 byte on all platforms. This is the smallest addressable unit
# in C, so 'B' is always 1 regardless of byte order or alignment prefix. It can represent
# values from 0 to 255. The complementary signed format 'b' (signed char) also returns 1
# from calcsize. No prior struct spec anchors struct.calcsize with any format string as
# a standalone under structsz147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra147.calcsize_B_eq_1:
  description: "struct.calcsize('B') == 1 — 'B' is unsigned char (uint8_t); 1 byte; range 0-255; smallest struct format; 1 byte regardless of platform or byte-order prefix; signed variant 'b' also returns 1; no prior struct spec anchors calcsize('B') as a standalone; first standalone under structsz147"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["B"]
  expected: 1

# ---------------------------------------------------------------------------
# struct.calcsize('I')==4 — standalone
#
# struct.calcsize('I') is 4. The 'I' format code represents an unsigned int (uint32_t),
# which is 4 bytes on 64-bit macOS. The same size applies to 'f' (float), since both
# IEEE 754 single-precision float and unsigned int are 32-bit values. In standard mode
# (using '>' or '<' prefix), 'I' is also guaranteed to be 4 bytes. On some older
# platforms without a byte-order prefix, 'I' could theoretically differ, but on modern
# 64-bit systems it is always 4. No prior struct spec anchors struct.calcsize('I') as a
# standalone under structsz147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra147.calcsize_I_eq_4:
  description: "struct.calcsize('I') == 4 — 'I' is unsigned int (uint32_t); 4 bytes; range 0 to 2^32-1; same size as 'f' (single-precision float); both are 32-bit values; '=I' also 4 in standard mode; no prior struct spec anchors calcsize('I') as a standalone; first standalone under structsz147"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["I"]
  expected: 4

# ---------------------------------------------------------------------------
# struct.calcsize('Q')==8 — standalone
#
# struct.calcsize('Q') is 8. The 'Q' format code represents an unsigned long long
# (uint64_t), which is 8 bytes on 64-bit macOS. The same size applies to 'd' (double),
# since both IEEE 754 double-precision float and unsigned long long are 64-bit values.
# 'Q' is the largest of the standard integer format codes in struct. No prior struct spec
# anchors struct.calcsize('Q') as a standalone under structsz147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra147.calcsize_Q_eq_8:
  description: "struct.calcsize('Q') == 8 — 'Q' is unsigned long long (uint64_t); 8 bytes; range 0 to 2^64-1; same size as 'd' (double-precision float); both are 64-bit values; largest standard integer format code in struct; no prior struct spec anchors calcsize('Q') as a standalone; first standalone under structsz147"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["Q"]
  expected: 8

# ---------------------------------------------------------------------------
# struct.calcsize('?')==1 — standalone
#
# struct.calcsize('?') is 1. The '?' format code represents a C99 _Bool (bool), which
# is 1 byte. When packing, Python True maps to b'\x01' and Python False maps to b'\x00'.
# When unpacking, any nonzero byte becomes True and b'\x00' becomes False. The bool
# format code '?' was added in Python 2.6 as part of support for C99 _Bool. At 1 byte,
# it is the same size as 'B' (unsigned char) and 'b' (signed char). No prior struct spec
# anchors struct.calcsize('?') as a standalone under structsz147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra147.calcsize_bool_eq_1:
  description: "struct.calcsize('?') == 1 — '?' is C99 _Bool (bool); 1 byte; True packs as b'\\x01', False as b'\\x00'; any nonzero byte unpacks as True; same size as 'B' and 'b'; added Python 2.6 for C99 _Bool support; no prior struct spec anchors calcsize('?') as a standalone; first standalone under structsz147"
  category: identity
  kind: python_call_eq
  function: calcsize
  args: ["?"]
  expected: 1
