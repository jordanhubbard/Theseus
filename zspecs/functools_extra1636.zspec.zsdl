spec: functools_extra1636
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __subclasshook__/__instancecheck__/__subclasscheck__"
    - "functools classes (partial, partialmethod, cached_property) are not ABCs and do not define virtual subclassing hooks"
    - "functools.partial is a C extension type; its __dict__ does NOT contain __subclasshook__, __instancecheck__, or __subclasscheck__"
    - "functools.partialmethod is a pure Python class; similarly does not define any ABC virtual subclassing hooks"
    - "functools.cached_property is a pure Python class; no virtual subclassing hooks present"
    - "functools.lru_cache is a Python function (decorator factory), not a class — has no type __dict__ in the class sense"
    - "ABCMeta.__instancecheck__ and ABCMeta.__subclasscheck__ are present only on the ABCMeta metaclass, not on functools classes"
    - "isinstance(functools.partial(int), functools.partial) uses normal C-level type.__instancecheck__, not a virtual hook"
    - "issubclass(functools.partial, object) is True because all Python types ultimately inherit from object"
    - "issubclass(functools.partial, type) is False — partial's metaclass is type but partial itself is not a metaclass"
    - "singledispatch is a Python function (decorator factory); it has no class __dict__ and does not define __subclasshook__"
  created_at: "2026-04-12"
error_model: python_exceptions

table functools_extra1636.partial_no_virtual_subclassing:
  description: "functools.partial is a C extension type; its class __dict__ does not contain any ABC virtual subclassing hooks (__subclasshook__, __instancecheck__, __subclasscheck__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1636pn

  columns: [id, function, args, expected]
  rows:
    - ["fu1636pn001", "functools.partial.__dict__.__contains__", ["__subclasshook__"],   false]
    - ["fu1636pn002", "functools.partial.__dict__.__contains__", ["__instancecheck__"],  false]
    - ["fu1636pn003", "functools.partial.__dict__.__contains__", ["__subclasscheck__"],  false]
    - ["fu1636pn004", "functools.partialmethod.__dict__.__contains__", ["__subclasshook__"],   false]
    - ["fu1636pn005", "functools.partialmethod.__dict__.__contains__", ["__instancecheck__"],  false]
    - ["fu1636pn006", "functools.partialmethod.__dict__.__contains__", ["__subclasscheck__"],  false]
    - ["fu1636pn007", "functools.cached_property.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["fu1636pn008", "functools.cached_property.__dict__.__contains__", ["__instancecheck__"], false]
    - ["fu1636pn009", "functools.cached_property.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["fu1636pn010", "functools.partial.__dict__.__contains__", ["__abstractmethods__"],  false]
    - ["fu1636pn011", "functools.partialmethod.__dict__.__contains__", ["__abstractmethods__"],  false]
    - ["fu1636pn012", "functools.cached_property.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["fu1636pn013", "functools.partial.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["fu1636pn014", "functools.partialmethod.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["fu1636pn015", "functools.cached_property.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["fu1636pn016", "functools.partial.__class__.__name__.__eq__", ["type"],            true]
    - ["fu1636pn017", "functools.partialmethod.__class__.__name__.__eq__", ["type"],      true]
    - ["fu1636pn018", "functools.cached_property.__class__.__name__.__eq__", ["type"],   true]
    - ["fu1636pn019", "functools.partial.__name__.__eq__", ["partial"],                   true]
    - ["fu1636pn020", "functools.partialmethod.__name__.__eq__", ["partialmethod"],       true]
    - ["fu1636pn021", "functools.cached_property.__name__.__eq__", ["cached_property"],  true]
    - ["fu1636pn022", "functools.partial.__module__.__eq__", ["functools"],               true]
    - ["fu1636pn023", "functools.partialmethod.__module__.__eq__", ["functools"],         true]
    - ["fu1636pn024", "functools.cached_property.__module__.__eq__", ["functools"],       true]
    - ["fu1636pn025", "functools.partial.__dict__.__contains__", ["__call__"],            true]

