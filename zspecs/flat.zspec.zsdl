spec: flat
version: ">=5.0.0"
backend: node(flat)

docs: https://www.npmjs.com/package/flat

provenance:
  derived_from:
    - "flat README — https://www.npmjs.com/package/flat"
    - "Test vectors verified with flat@5.0.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "flat source"
  notes:
    - "flat exports {flatten, unflatten} functions."
    - "flatten(object) converts nested object to dot-notation keys."
    - "unflatten(object) converts dot-notation keys back to nested object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns flattened or unflattened object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table flat.flatten:
  kind: node_module_call_eq
  function: flatten
  category: flatten
  id_prefix: flatf

  columns: [id, args, expected]
  rows:
    - [nested,  [{"a": {"b": {"c": 1}}}],   {"a.b.c": 1}]
    - [mixed,   [{"a": 1, "b": {"c": 2}}],  {"a": 1, "b.c": 2}]
    - [shallow, [{"a": {"b": 1, "c": 2}}],  {"a.b": 1, "a.c": 2}]

table flat.unflatten:
  kind: node_module_call_eq
  function: unflatten
  category: unflatten
  id_prefix: flatu

  columns: [id, args, expected]
  rows:
    - [nested,  [{"a.b.c": 1}],            {"a": {"b": {"c": 1}}}]
    - [mixed,   [{"a": 1, "b.c": 2}],      {"a": 1, "b": {"c": 2}}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:15:05Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
