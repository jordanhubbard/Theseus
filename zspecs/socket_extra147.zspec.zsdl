spec: socket_extra147
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra146.zspec.zsdl — covers socket.__all__.__contains__('socket'/'AF_INET'/'SOCK_STREAM'/'gethostname'/'error'/'AF_INET6') / __all__.__len__()==238 / socket.socket.__init__.__qualname__.__eq__('socket.__init__') / __init__.__class__.__name__.__eq__('function') (table + invariants)."
    - "socket_extra145.zspec.zsdl — covers socket.AF_UNSPEC/__class__.__name__.__eq__('AddressFamily') / AF_UNIX.name.__eq__('AF_UNIX') and __len__()==7 / IPPROTO_TCP/__class__.__name__.__eq__('int') / __spec__.name.__eq__('socket') / __doc__.__len__()==2021 (table + invariants)."
    - "socket_extra144.zspec.zsdl — covers socket.socket.__module__/__qualname__/__eq__('socket') / socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') / __mro__.__len__()==3 (table + invariants)."
    - "socket_extra143.zspec.zsdl — covers socket.socket method __qualname__ string equality for connect/bind/listen/accept/recv / accept/__class__.__name__=='function' (table + invariants)."
    - "socket_extra142.zspec.zsdl — covers socket.AF_INET/AF_INET6 enum member .name values / SOCK_STREAM/SOCK_DGRAM .name values / AddressFamily/SocketKind class __name__ values (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO class identity."
    - "socket_extra97.zspec.zsdl — covers socket.socket.send/sendall/fileno __qualname__.__eq__ / socket.socket.__init__/accept/makefile/close __class__.__name__=='function'."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra146."
    - "Wave 319 theme: socket.socket class __dict__ membership checks — socket.__dict__.__contains__('accept')==True / __dict__.__contains__('makefile')==True / __dict__.__contains__('close')==True / __dict__.__contains__('__init__')==True / __dict__.__contains__('__slots__')==True / socket.__dict__.__len__()==28 / socket.__package__.__eq__('') / socket.__loader__.__class__.__name__.__eq__('SourceFileLoader')."
    - "socket.socket.__dict__.__contains__('accept') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('makefile') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('close') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__init__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__slots__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__len__() == 28. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__package__ == '' (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__loader__.__class__.__name__ == 'SourceFileLoader' (len 16). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.__dict__ has 28 entries (verified Python 3.14.3 macOS/Darwin 25.4.0). The entries include Python-level methods (accept, makefile, close, detach, dup, sendfile, __init__, __repr__, __enter__, __exit__, __getstate__, _check_sendfile_params, _decref_socketios, _real_close, _sendfile_use_send, _sendfile_use_sendfile), property descriptors (family, type), and slot/metadata attributes (__slots__, __weakref__, __doc__, __module__, __firstlineno__, __static_attributes__, _io_refs, _closed)."
    - "Note: socket.socket.__dict__.__len__() == 28. Comparing class __dict__ sizes across the stdlib series: struct.Struct (16) < socket.socket (28) << uuid.UUID (37). socket.socket is intermediate: it has more entries than Struct (because it is a Python subclass of the C _socket.socket with many Python-level method overrides) but fewer than UUID (which has many property descriptors and slot descriptors)."
    - "Note: The key Python-level methods in socket.socket.__dict__ are accept, makefile, close, detach, dup, sendfile, __init__, __repr__, __enter__, __exit__. These contrast with the C-level method_descriptors (connect, bind, listen, recv, send, etc.) which are inherited from _socket.socket and are NOT in socket.socket.__dict__."
    - "Note: socket.__package__ == '' and socket.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars). socket is a pure-Python module (Lib/socket.py) wrapping the _socket C extension. Both struct and uuid have the same loader class. The 16-char SourceFileLoader name is consistent across all three pure-Python stdlib module wrappers."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('accept')
# socket.socket.__dict__.__contains__('makefile')
# socket.socket.__dict__.__contains__('close')
# socket.socket.__dict__.__contains__('__init__')
#
# Wave 319 theme: socket.socket class __dict__ contains Python-level method names.
#
# accept, makefile, close, and __init__ are all Python-level functions defined in
# Lib/socket.py and stored directly in socket.socket.__dict__. They contrast with
# C-level methods like connect, bind, listen, recv which are inherited from
# _socket.socket and are NOT in socket.socket.__dict__. extra143 anchors accept as
# a 'function' class; no prior socket spec anchors __dict__.__contains__ checks
# as a table under sockdict147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra147.socket_dict_contains_python_methods:
  description: "socket.socket.__dict__.__contains__('accept')==True / __dict__.__contains__('makefile')==True / __dict__.__contains__('close')==True / __dict__.__contains__('__init__')==True — all four are Python-level functions in Lib/socket.py; contrasts with C-level methods (connect/bind/listen/recv) inherited from _socket.socket that are NOT in socket.socket.__dict__; extra143 anchors accept as 'function' class; first sockdict147 anchor for __dict__.__contains__ method checks"
  kind: python_call_eq
  category: identity
  id_prefix: sockdict147

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_accept,   socket.__dict__.__contains__, ["accept"],   true, "socket.socket.__dict__.__contains__('accept') == True (Python-level function; wraps C accept with address handling)"]
    - [dict_contains_makefile, socket.__dict__.__contains__, ["makefile"], true, "socket.socket.__dict__.__contains__('makefile') == True (Python-level function; creates a file-like object from socket)"]
    - [dict_contains_close,    socket.__dict__.__contains__, ["close"],    true, "socket.socket.__dict__.__contains__('close') == True (Python-level function; cleans up socket IOs before closing)"]
    - [dict_contains_init,     socket.__dict__.__contains__, ["__init__"], true, "socket.socket.__dict__.__contains__('__init__') == True (Python-level function; extra146 anchors __qualname__=='socket.__init__')"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('__slots__')
# socket.socket.__dict__.__len__()==28
# socket.__package__.__eq__('')
# socket.__loader__.__class__.__name__.__eq__('SourceFileLoader')
#
# Wave 319 theme: socket.socket dict __slots__, dict length, module package, and loader.
#
# socket.socket.__dict__ contains '__slots__' (a list of ['__weakref__', '_io_refs', '_closed']).
# The total dict length is 28. socket.__package__ is '' (empty string, top-level module).
# socket.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars).
# No prior socket spec anchors these together as a table under sockdict147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra147.socket_dict_slots_len_package_loader:
  description: "socket.socket.__dict__.__contains__('__slots__')==True / socket.__dict__.__len__()==28 / socket.__package__.__eq__('')==True / socket.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True — __slots__ is ['__weakref__','_io_refs','_closed'] (len 3); dict len 28 is between Struct(16) and UUID(37); __package__ '' for top-level module; SourceFileLoader (16 chars) for pure-Python Lib/socket.py; no prior socket spec anchors these under sockdict147"
  kind: python_call_eq
  category: identity
  id_prefix: sockdict147

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_slots,    socket.__dict__.__contains__,          ["__slots__"],         true, "socket.socket.__dict__.__contains__('__slots__') == True (list ['__weakref__','_io_refs','_closed'])"]
    - [dict_len_28,            socket.__dict__.__len__,               [],                    28,   "socket.socket.__dict__.__len__() is 28 (between Struct=16 and UUID=37 in class dict size ordering)"]
    - [pkg_empty,              __package__.__eq__,                    [""],                  true, "socket.__package__ == '' (empty string; standard for top-level stdlib modules)"]
    - [loader_SourceFileLoader, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"],  true, "socket.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; pure-Python Lib/socket.py)"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('sendfile')
# socket.socket.__dict__.__contains__('detach')
# socket.socket.__dict__.__contains__('dup')
# socket.socket.__dict__.__contains__('__repr__')
#
# Wave 319 theme: socket.socket __dict__ contains additional Python-level methods.
#
# sendfile, detach, dup, and __repr__ are additional Python-level functions defined
# in Lib/socket.py and stored in socket.socket.__dict__. sendfile provides efficient
# file-to-socket data transfer. detach and dup provide socket duplication/detachment.
# __repr__ formats the socket representation string. No prior socket spec anchors
# these __dict__.__contains__ checks as a table under sockdict147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra147.socket_dict_contains_additional_methods:
  description: "socket.socket.__dict__.__contains__('sendfile')==True / __dict__.__contains__('detach')==True / __dict__.__contains__('dup')==True / __dict__.__contains__('__repr__')==True — sendfile transfers file data efficiently to socket; detach returns the file descriptor and detaches from the socket; dup duplicates the socket; __repr__ formats the socket string representation; all are Python-level functions in Lib/socket.py; first sockdict147 anchor for these additional Python-level method checks"
  kind: python_call_eq
  category: identity
  id_prefix: sockdict147

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_sendfile, socket.__dict__.__contains__, ["sendfile"], true, "socket.socket.__dict__.__contains__('sendfile') == True (Python-level; efficient file-to-socket data transfer)"]
    - [dict_contains_detach,   socket.__dict__.__contains__, ["detach"],   true, "socket.socket.__dict__.__contains__('detach') == True (Python-level; returns fd and detaches from socket object)"]
    - [dict_contains_dup,      socket.__dict__.__contains__, ["dup"],      true, "socket.socket.__dict__.__contains__('dup') == True (Python-level; duplicates the socket)"]
    - [dict_contains_repr,     socket.__dict__.__contains__, ["__repr__"], true, "socket.socket.__dict__.__contains__('__repr__') == True (Python-level; formats socket string representation)"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('accept') — standalone
#
# socket.socket.__dict__.__contains__('accept') is True. The accept method is a
# Python-level function defined in Lib/socket.py. It wraps the C-level accept() call
# to return a (socket, address) tuple, where the socket is wrapped in a new
# socket.socket Python object. extra143 anchors accept/__class__.__name__=='function';
# extra97 anchors accept as one of the Python-level socket.socket methods; no prior
# socket spec anchors socket.socket.__dict__.__contains__('accept') as a standalone
# under sockdict147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra147.socket_dict_contains_accept:
  description: "socket.socket.__dict__.__contains__('accept') == True — Python-level function in Lib/socket.py; wraps C accept() to return (socket, address) with socket wrapped in socket.socket; extra143 anchors accept as 'function' class; extra97 anchors accept as Python-level method; no prior socket spec anchors this as a standalone; first standalone under sockdict147"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('makefile') — standalone
#
# socket.socket.__dict__.__contains__('makefile') is True. The makefile method is
# a Python-level function defined in Lib/socket.py. It creates a file-like object
# (SocketIO or BufferedReader/BufferedWriter) wrapping the socket, allowing it to
# be used with file-reading APIs. makefile is one of the key reasons socket.socket
# exists as a Python subclass of _socket.socket — the C-level _socket.socket does
# not have makefile. No prior socket spec anchors socket.socket.__dict__.__contains__
# ('makefile') as a standalone under sockdict147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra147.socket_dict_contains_makefile:
  description: "socket.socket.__dict__.__contains__('makefile') == True — Python-level function in Lib/socket.py; creates SocketIO/BufferedReader/BufferedWriter file-like wrapper; key reason socket.socket subclasses _socket.socket (C-level _socket.socket lacks makefile); no prior socket spec anchors this as a standalone; first standalone under sockdict147"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["makefile"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__len__()==28 — standalone
#
# socket.socket.__dict__.__len__() is 28. The 28 entries in socket.socket.__dict__
# reflect that socket.socket is a Python class (Lib/socket.py) that subclasses the
# C-level _socket.socket, adding Python-level methods and attributes. Comparing class
# dict sizes: struct.Struct (16) < socket.socket (28) << uuid.UUID (37). The 28
# entries include 16 Python-level method functions + 2 property descriptors (family,
# type) + 1 list (__slots__) + 9 metadata attributes (__doc__, __module__,
# __firstlineno__, __static_attributes__, __weakref__, _io_refs, _closed, and others).
# No prior socket spec anchors socket.socket.__dict__.__len__()==28 as a standalone
# under sockdict147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra147.socket_dict_len_28:
  description: "socket.socket.__dict__.__len__() == 28 — 28 entries: ~16 Python-level methods + 2 property descriptors (family, type) + __slots__ + metadata; ordering: Struct(16) < socket.socket(28) << UUID(37); reflects Python subclass of C extension with added Python methods; no prior socket spec anchors this as a standalone; first standalone under sockdict147"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__len__
  args: []
  expected: 28

# ---------------------------------------------------------------------------
# socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# socket.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars). The public
# socket module (Lib/socket.py) is loaded as Python source by SourceFileLoader.
# This is the same loader class as struct (struct_extra142) and uuid (uuid_extra138),
# which are also pure-Python wrappers around C extensions. The underlying C extension
# _socket uses ExtensionFileLoader (same pattern as hashlib/_hashlib in extra150).
# No prior socket spec anchors socket.__loader__.__class__.__name__ ==
# 'SourceFileLoader' as a standalone under sockdict147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra147.loader_SourceFileLoader:
  description: "socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — 'SourceFileLoader' (16 chars); pure-Python Lib/socket.py wrapper loaded as Python source; same loader class as struct (struct_extra142) and uuid (uuid_extra138); underlying _socket C extension uses ExtensionFileLoader; no prior socket spec anchors this as a standalone; first standalone under sockdict147"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__package__.__eq__('') — standalone
#
# socket.__package__ is '' (empty string). All four stdlib modules covered by
# this spec series have empty-string __package__: hashlib, uuid, struct, and socket.
# The empty string is the standard __package__ value for top-level stdlib modules
# not contained in a sub-package. This is distinct from the _socket C extension
# (which also has __package__ == '') versus sub-package modules like
# urllib.request (__package__ == 'urllib'). No prior socket spec anchors
# socket.__package__ == '' as a standalone under sockdict147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra147.package_empty:
  description: "socket.__package__.__eq__('') == True — empty string; standard __package__ for top-level stdlib modules; matches hashlib/uuid/struct (all ''); all four stdlib modules in the spec series are top-level (no sub-package); no prior socket spec anchors this as a standalone; first standalone under sockdict147"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

