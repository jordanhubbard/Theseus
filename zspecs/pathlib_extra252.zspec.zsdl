invariant pathlib_extra252.PurePath.with_suffix.name_eq:
  description: "pathlib.PurePath.with_suffix.__name__ == 'with_suffix' — the method name string; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: PurePath.with_suffix.__name__.__eq__
  args: ["with_suffix"]
