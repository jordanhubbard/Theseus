spec: pathlib_extra252
version: ">=3.4"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python 3 pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath component access, parent, parts, predicates, manipulation, joining, str"
    - "pathlib_extra.zspec.zsdl — covers Path.__name__, PurePosixPath.module, component/parent/truediv/parts/suffix/is_absolute"
  notes:
    - "This spec covers: pathlib.PurePath class identity (__name__, __module__, __bases__[0].__name__) and method identity contracts."
    - "pathlib.PurePath.__name__ == 'PurePath' — the class is named PurePath; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__module__ == 'pathlib' — PurePath is defined in the pathlib module; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath inherits directly from object; verified Python 3.14.3 macOS."
    - "PurePath.joinpath.__name__ == 'joinpath', __qualname__ == 'PurePath.joinpath'; verified Python 3.14.3 macOS."
    - "PurePath.with_name.__name__ == 'with_name', __qualname__ == 'PurePath.with_name'; verified Python 3.14.3 macOS."
    - "PurePath.with_suffix.__name__ == 'with_suffix', __qualname__ == 'PurePath.with_suffix'; verified Python 3.14.3 macOS."
    - "len('PurePath') == 8; len('pathlib') == 7; len('object') == 6; verified Python 3.14.3 macOS."
    - "len('joinpath') == 8; len('PurePath.joinpath') == 17; verified Python 3.14.3 macOS."
    - "len('with_name') == 9; len('PurePath.with_name') == 18; verified Python 3.14.3 macOS."
    - "len('with_suffix') == 11; len('PurePath.with_suffix') == 20; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePath class identity — __name__, __module__, __qualname__
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra252.PurePath_identity:
  description: "pathlib.PurePath class identity: __name__, __module__, __qualname__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathpure252

  columns: [id, function, args, expected]
  rows:
    - [name_eq,       PurePath.__name__.__eq__,      ["PurePath"], true ]
    - [name_not,      PurePath.__name__.__eq__,      ["Path"],     false]
    - [module_eq,     PurePath.__module__.__eq__,    ["pathlib"],  true ]
    - [module_not,    PurePath.__module__.__eq__,    ["os.path"],  false]
    - [qualname_eq,   PurePath.__qualname__.__eq__,  ["PurePath"], true ]

# ---------------------------------------------------------------------------
# PurePath class identity — string lengths
# __name__='PurePath' len=8, __module__='pathlib' len=7, __qualname__='PurePath' len=8
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra252.PurePath_identity_lengths:
  description: "pathlib.PurePath string lengths: __name__=8, __module__=7, __qualname__=8; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathpure252

  columns: [id, function, args, expected]
  rows:
    - [name_len,     PurePath.__name__.__len__,     [], 8]
    - [module_len,   PurePath.__module__.__len__,   [], 7]
    - [qualname_len, PurePath.__qualname__.__len__, [], 8]

# ---------------------------------------------------------------------------
# PurePath method __name__ and __qualname__ — joinpath, with_name, with_suffix
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra252.PurePath_method_names:
  description: "PurePath.joinpath/with_name/with_suffix __name__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathpurem252

  columns: [id, function, args, expected]
  rows:
    - [joinpath_name_eq,    PurePath.joinpath.__name__.__eq__,    ["joinpath"],   true]
    - [with_name_name_eq,   PurePath.with_name.__name__.__eq__,   ["with_name"],  true]
    - [with_suffix_name_eq, PurePath.with_suffix.__name__.__eq__, ["with_suffix"], true]
    - [joinpath_name_not,   PurePath.joinpath.__name__.__eq__,    ["with_name"],  false]
    - [with_name_name_not,  PurePath.with_name.__name__.__eq__,   ["with_suffix"], false]

# ---------------------------------------------------------------------------
# PurePath method __qualname__ — joinpath, with_name, with_suffix
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra252.PurePath_method_qualnames:
  description: "PurePath.joinpath/with_name/with_suffix __qualname__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathpurem252

  columns: [id, function, args, expected]
  rows:
    - [joinpath_qual_eq,    PurePath.joinpath.__qualname__.__eq__,    ["PurePath.joinpath"],   true]
    - [with_name_qual_eq,   PurePath.with_name.__qualname__.__eq__,   ["PurePath.with_name"],  true]
    - [with_suffix_qual_eq, PurePath.with_suffix.__qualname__.__eq__, ["PurePath.with_suffix"], true]
    - [joinpath_qual_len,   PurePath.joinpath.__qualname__.__len__,   [],                       17 ]
    - [with_suffix_qual_len, PurePath.with_suffix.__qualname__.__len__, [],                     20 ]

# ---------------------------------------------------------------------------
# Standalone invariants — PurePath class identity
# ---------------------------------------------------------------------------

invariant pathlib_extra252.PurePath.name_eq:
  description: "pathlib.PurePath.__name__ == 'PurePath' — the class name string; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra252.PurePath.module_eq:
  description: "pathlib.PurePath.__module__ == 'pathlib' — PurePath is defined in the pathlib module; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra252.PurePath.base_is_object:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath inherits directly from object; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pathlib_extra252.PurePath.class_is_type:
  description: "pathlib.PurePath.__class__.__name__ == 'type' — PurePath metaclass is plain type; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — PurePath method identity: joinpath
# ---------------------------------------------------------------------------

invariant pathlib_extra252.PurePath.joinpath.name_eq:
  description: "pathlib.PurePath.joinpath.__name__ == 'joinpath' — the method name string; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: PurePath.joinpath.__name__.__eq__
  args: ["joinpath"]
  expected: true

invariant pathlib_extra252.PurePath.joinpath.name_len:
  description: "len(pathlib.PurePath.joinpath.__name__) == 8 — 'joinpath' has 8 characters; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: PurePath.joinpath.__name__.__len__
  args: []
  expected: 8

invariant pathlib_extra252.PurePath.joinpath.qualname_eq:
  description: "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: PurePath.joinpath.__qualname__.__eq__
  args: ["PurePath.joinpath"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — PurePath method identity: with_name
# ---------------------------------------------------------------------------

invariant pathlib_extra252.PurePath.with_name.name_eq:
  description: "pathlib.PurePath.with_name.__name__ == 'with_name' — the method name string; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: PurePath.with_name.__name__.__eq__
  args: ["with_name"]
  expected: true

invariant pathlib_extra252.PurePath.with_name.name_len:
  description: "len(pathlib.PurePath.with_name.__name__) == 9 — 'with_name' has 9 characters; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: PurePath.with_name.__name__.__len__
  args: []
  expected: 9

invariant pathlib_extra252.PurePath.with_name.qualname_eq:
  description: "pathlib.PurePath.with_name.__qualname__ == 'PurePath.with_name'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: PurePath.with_name.__qualname__.__eq__
