spec: inspect_extra217
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.Parameter kind enum __name__ checks, inspect.Parameter.empty, Signature.empty, and CO_ flag constants (wave 383)."
    - "Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY', len==15, class==_ParameterKind. Verified with Python 3.14.3."
    - "Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD', len==21. Verified with Python 3.14.3."
    - "Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL', len==14. Verified with Python 3.14.3."
    - "Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY', len==12. Verified with Python 3.14.3."
    - "Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD', len==11. Verified with Python 3.14.3."
    - "Parameter.empty.__name__ == '_empty'; it is a class (isinstance(empty, type) == True). Verified with Python 3.14.3."
    - "Signature.empty is Parameter.empty == True. Verified with Python 3.14.3."
    - "CO_OPTIMIZED==1, CO_NEWLOCALS==2, CO_VARARGS==4, CO_VARKEYWORDS==8. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter kind .name attribute checks
#
# Each ParameterKind enum member has a .name string equal to the constant
# name as written in source code. These are stable across Python versions.
#
# Verified with Python 3.14.3:
#   Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY'
#   Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD'
#   Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL'
#   Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY'
#   Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD'
# ---------------------------------------------------------------------------

table inspect_extra217.parameter_kind_names:
  description: "inspect.Parameter kind enum .name attribute checks; wave 383; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra217kindnames

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_name_eq,
       Parameter.POSITIONAL_ONLY.name.__eq__,
       ["POSITIONAL_ONLY"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True — the .name attribute of a ParameterKind enum member is its symbolic name as a string; POSITIONAL_ONLY.name is 'POSITIONAL_ONLY'; str.__eq__ returns True; new to extra217"]
    - [positional_or_keyword_name_eq,
       Parameter.POSITIONAL_OR_KEYWORD.name.__eq__,
       ["POSITIONAL_OR_KEYWORD"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True — POSITIONAL_OR_KEYWORD marks the most common parameter kind (can pass by position or keyword); its .name is 'POSITIONAL_OR_KEYWORD'; str.__eq__ returns True; new to extra217"]
    - [var_positional_name_eq,
       Parameter.VAR_POSITIONAL.name.__eq__,
       ["VAR_POSITIONAL"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True — VAR_POSITIONAL marks *args parameters; its .name is 'VAR_POSITIONAL'; str.__eq__ returns True; new to extra217"]
    - [keyword_only_name_eq,
       Parameter.KEYWORD_ONLY.name.__eq__,
       ["KEYWORD_ONLY"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True — KEYWORD_ONLY marks parameters that appear after a bare * or *args in the signature; its .name is 'KEYWORD_ONLY'; str.__eq__ returns True; new to extra217"]
    - [var_keyword_name_eq,
       Parameter.VAR_KEYWORD.name.__eq__,
       ["VAR_KEYWORD"],
       true,
       "inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True — VAR_KEYWORD marks **kwargs parameters; its .name is 'VAR_KEYWORD'; str.__eq__ returns True; new to extra217"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter kind .name length checks
#
# The name lengths are fixed constants that reflect the API design.
#
# Verified with Python 3.14.3:
#   len(POSITIONAL_ONLY.name) == 15
#   len(POSITIONAL_OR_KEYWORD.name) == 21
#   len(VAR_POSITIONAL.name) == 14
#   len(KEYWORD_ONLY.name) == 12
#   len(VAR_KEYWORD.name) == 11
# ---------------------------------------------------------------------------

table inspect_extra217.parameter_kind_name_lengths:
  description: "inspect.Parameter kind enum .name length checks; wave 383; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra217kindnamelen

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_name_len_15,
       Parameter.POSITIONAL_ONLY.name.__len__,
       [],
       15,
       "inspect.Parameter.POSITIONAL_ONLY.name.__len__() == 15 — 'POSITIONAL_ONLY' has 15 characters; str.__len__() returns 15; new to extra217"]
    - [positional_or_keyword_name_len_21,
       Parameter.POSITIONAL_OR_KEYWORD.name.__len__,
       [],
       21,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__len__() == 21 — 'POSITIONAL_OR_KEYWORD' has 21 characters, making it the longest kind name; str.__len__() returns 21; new to extra217"]
    - [var_positional_name_len_14,
       Parameter.VAR_POSITIONAL.name.__len__,
       [],
       14,
       "inspect.Parameter.VAR_POSITIONAL.name.__len__() == 14 — 'VAR_POSITIONAL' has 14 characters; str.__len__() returns 14; new to extra217"]
    - [keyword_only_name_len_12,
       Parameter.KEYWORD_ONLY.name.__len__,
       [],
       12,
       "inspect.Parameter.KEYWORD_ONLY.name.__len__() == 12 — 'KEYWORD_ONLY' has 12 characters; str.__len__() returns 12; new to extra217"]
    - [var_keyword_name_len_11,
       Parameter.VAR_KEYWORD.name.__len__,
       [],
       11,
       "inspect.Parameter.VAR_KEYWORD.name.__len__() == 11 — 'VAR_KEYWORD' has 11 characters; str.__len__() returns 11; new to extra217"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter.empty — class identity checks
#
# inspect.Parameter.empty is a sentinel class (not an instance) used to
# indicate that a parameter has no default value and no annotation.
#
# Verified with Python 3.14.3:
#   Parameter.empty.__name__ == '_empty'
#   Parameter.empty.__class__.__name__ == 'type'  (it IS a class)
#   Signature.empty is Parameter.empty == True
# ---------------------------------------------------------------------------

table inspect_extra217.parameter_empty_checks:
  description: "inspect.Parameter.empty is a sentinel class with __name__=='_empty'; Signature.empty is the same object; wave 383; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra217empty

  columns: [id, function, args, expected, description]
  rows:
    - [empty_name_eq_empty,
       Parameter.empty.__name__.__eq__,
       ["_empty"],
       true,
       "inspect.Parameter.empty.__name__.__eq__('_empty') == True — Parameter.empty is a sentinel class whose __name__ is '_empty' (the private implementation name in Lib/inspect.py); str.__eq__('_empty') returns True; new to extra217"]
    - [empty_class_name_is_type,
       Parameter.empty.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is a class object (not an instance); its metaclass is 'type', so __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra217"]
    - [parameter_module_eq_inspect,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in the inspect module; its __module__ attribute is the string 'inspect'; str.__eq__('inspect') returns True; new to extra217"]
    - [signature_module_eq_inspect,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in the inspect module alongside Parameter; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra217"]

# ---------------------------------------------------------------------------
# Table 4: inspect CO_ flag constants
#
# inspect exposes code object flag constants from the CPython compiler.
# These are stable integer values used to test flags in code.__flags__.
#
# Verified with Python 3.14.3:
#   CO_OPTIMIZED == 1
#   CO_NEWLOCALS == 2
#   CO_VARARGS == 4
#   CO_VARKEYWORDS == 8
#   type(CO_OPTIMIZED).__name__ == 'int'
# ---------------------------------------------------------------------------

table inspect_extra217.co_flag_constants:
  description: "inspect CO_ flag constants: CO_OPTIMIZED=1, CO_NEWLOCALS=2, CO_VARARGS=4, CO_VARKEYWORDS=8; wave 383; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra217coflags

  columns: [id, function, args, expected, description]
  rows:
    - [co_optimized_eq_1,
       CO_OPTIMIZED.__eq__,
       [1],
       true,
       "inspect.CO_OPTIMIZED.__eq__(1) == True — CO_OPTIMIZED (value 1) is set on functions that use fast locals; most pure-Python functions have this flag; int.__eq__(1) returns True; new to extra217"]
    - [co_newlocals_eq_2,
       CO_NEWLOCALS.__eq__,
       [2],
       true,
       "inspect.CO_NEWLOCALS.__eq__(2) == True — CO_NEWLOCALS (value 2) is set on functions that create a new local namespace; combined with CO_OPTIMIZED for most functions; int.__eq__(2) returns True; new to extra217"]
    - [co_varargs_eq_4,
       CO_VARARGS.__eq__,
       [4],
       true,
       "inspect.CO_VARARGS.__eq__(4) == True — CO_VARARGS (value 4) is set on functions that accept *args (variable positional arguments); int.__eq__(4) returns True; new to extra217"]
    - [co_varkeywords_eq_8,
       CO_VARKEYWORDS.__eq__,
       [8],
       true,
       "inspect.CO_VARKEYWORDS.__eq__(8) == True — CO_VARKEYWORDS (value 8) is set on functions that accept **kwargs (variable keyword arguments); int.__eq__(8) returns True; new to extra217"]
    - [co_optimized_type_is_int,
       CO_OPTIMIZED.__class__.__name__.__eq__,
       ["int"],
       true,
       "inspect.CO_OPTIMIZED.__class__.__name__.__eq__('int') == True — CO_OPTIMIZED is a plain Python int constant; its class is 'int'; str.__eq__('int') returns True; new to extra217"]
    - [co_varargs_plus_varkeywords_eq_12,
       CO_VARARGS.__add__,
       [8],
       12,
       "inspect.CO_VARARGS.__add__(8) == 12 — CO_VARARGS (4) + CO_VARKEYWORDS (8) == 12; a function accepting both *args and **kwargs would have both flags set; int.__add__(8) returns 12; new to extra217"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra217
# ---------------------------------------------------------------------------

invariant inspect_extra217.positional_only_name:
  description: "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True; wave 383; new to extra217"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.name.__eq__
  args: ["POSITIONAL_ONLY"]
  expected: true

invariant inspect_extra217.positional_or_keyword_name:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True; wave 383; new to extra217"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.name.__eq__
  args: ["POSITIONAL_OR_KEYWORD"]
  expected: true

invariant inspect_extra217.var_keyword_name:
  description: "inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True; wave 383; new to extra217"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.name.__eq__
  args: ["VAR_KEYWORD"]
  expected: true

invariant inspect_extra217.positional_or_keyword_name_len:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__len__() == 21 — longest kind name; wave 383; new to extra217"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.name.__len__
  args: []
  expected: 21

invariant inspect_extra217.var_keyword_name_len:
  description: "inspect.Parameter.VAR_KEYWORD.name.__len__() == 11; wave 383; new to extra217"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.name.__len__
  args: []
  expected: 11

invariant inspect_extra217.empty_name:
  description: "inspect.Parameter.empty.__name__.__eq__('_empty') == True — sentinel class has private name; wave 383; new to extra217"
  kind: python_call_eq
  function: Parameter.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra217.parameter_module:
  description: "inspect.Parameter.__module__.__eq__('inspect') == True; wave 383; new to extra217"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra217.co_optimized:
  description: "inspect.CO_OPTIMIZED.__eq__(1) == True; wave 383; new to extra217"
  kind: python_call_eq
  function: CO_OPTIMIZED.__eq__
  args: [1]
  expected: true

invariant inspect_extra217.co_newlocals:
  description: "inspect.CO_NEWLOCALS.__eq__(2) == True; wave 383; new to extra217"
  kind: python_call_eq
  function: CO_NEWLOCALS.__eq__
  args: [2]
  expected: true

invariant inspect_extra217.co_varargs:
  description: "inspect.CO_VARARGS.__eq__(4) == True; wave 383; new to extra217"
  kind: python_call_eq
  function: CO_VARARGS.__eq__
  args: [4]
  expected: true

invariant inspect_extra217.co_varkeywords:
  description: "inspect.CO_VARKEYWORDS.__eq__(8) == True; wave 383; new to extra217"
  kind: python_call_eq
  function: CO_VARKEYWORDS.__eq__
  args: [8]
  expected: true

