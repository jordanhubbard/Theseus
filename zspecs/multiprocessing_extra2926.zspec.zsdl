spec: mp2926
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [multiprocessing source, Python docs, https://docs.python.org/3/library/multiprocessing.html]
  not_derived_from: [any external dataset, multiprocessing_extra2911.zspec.zsdl — covers __ilshift__/__irshift__/__ipow__ dict-presence, multiprocessing_extra2896.zspec.zsdl — covers __itruediv__/__ifloordiv__/__imod__ dict-presence, multiprocessing_extra2881.zspec.zsdl — covers __iadd__/__isub__/__imul__ dict-presence, multiprocessing_extra2866.zspec.zsdl — covers __rand__/__ror__/__rxor__ dict-presence]
  notes: [Wave 642 theme — __iand__/__ior__/__ixor__ dict-presence checks for multiprocessing types. In-place bitwise AND, OR, XOR operators. Process/Pool/AsyncResult/MapResult/SyncManager are process-management primitives lacking these dunders. managers.SetProxy defines __iand__/__ior__/__ixor__ because sets support in-place bitwise set operations (intersection-update, union-update, symmetric-difference-update). managers.DictProxy defines __ior__ (dict merge-update via |=) but NOT __iand__ or __ixor__. All other proxy and raw multiprocessing types lack these dunders. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table mp2926.iand:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["mp2926001", operator.contains, [multiprocessing.Process.__dict__, "__iand__"], false]
    - ["mp2926002", operator.contains, [multiprocessing.pool.Pool.__dict__, "__iand__"], false]
    - ["mp2926003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__, "__iand__"], false]
    - ["mp2926004", operator.contains, [multiprocessing.pool.MapResult.__dict__, "__iand__"], false]
    - ["mp2926005", operator.contains, [multiprocessing.managers.SyncManager.__dict__, "__iand__"], false]
    - ["mp2926006", operator.contains, [multiprocessing.managers.BaseProxy.__dict__, "__iand__"], false]

