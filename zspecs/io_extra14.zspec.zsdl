spec: io_extra14
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl through io_extra13.zspec.zsdl."
    - "io_extra13 covers: IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__; IncrementalNewlineDecoder __name__; UnsupportedOperation.__mro__[0].__name__; BytesIO getvalue seeded len, partial read; BytesIO/StringIO tell() at initial position; StringIO partial read; StringIO getvalue len; IOBase/RawIOBase is_type."
    - "io_extra12 covers: UnsupportedOperation.__mro__ len(6) and mro[1].__name__=='OSError'; BufferedRandom.__mro__ len(4); BytesIO/StringIO getvalue() on empty; BytesIO/StringIO .closed==False; BytesIO(b'hello').read()==b'hello'; StringIO('hello').read()=='hello'."
    - "io_extra11 covers: BufferedReader/Writer/Random/TextIOWrapper __bases__[0].__name__; BytesIO/StringIO readable/writable/seekable; DEFAULT_BUFFER_SIZE == 8192."
    - "Most io classes are implemented in the C extension _io; their __module__ is '_io'."
    - "UnsupportedOperation is the exception to the rule: it is defined in the pure-Python io module, so its __module__ is 'io'."
    - "io.IOBase.__module__ == '_io'."
    - "io.RawIOBase.__module__ == '_io'."
    - "io.BufferedIOBase.__module__ == '_io'."
    - "io.TextIOBase.__module__ == '_io'."
    - "io.FileIO.__module__ == '_io'."
    - "io.BytesIO.__module__ == '_io'."
    - "io.StringIO.__module__ == '_io'."
    - "io.BufferedReader.__module__ == '_io'."
    - "io.BufferedWriter.__module__ == '_io'."
    - "io.BufferedRandom.__module__ == '_io'."
    - "io.TextIOWrapper.__module__ == '_io'."
    - "io.IncrementalNewlineDecoder.__module__ == '_io'."
    - "io.UnsupportedOperation.__module__ == 'io' — defined in the pure-Python io wrapper, not in _io."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Abstract base class __module__ — IOBase, RawIOBase, BufferedIOBase, TextIOBase
#
# io_extra13 covers __name__ for these four abstract base classes.
# No prior spec covers their __module__ attributes.
# All four are implemented in the C extension _io, so __module__ == '_io'.
# ---------------------------------------------------------------------------

invariant io_extra14.IOBase.module:
  description: "io.IOBase.__module__ == '_io' — IOBase is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra14.RawIOBase.module:
  description: "io.RawIOBase.__module__ == '_io' — RawIOBase is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra14.BufferedIOBase.module:
  description: "io.BufferedIOBase.__module__ == '_io' — BufferedIOBase is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: BufferedIOBase.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra14.TextIOBase.module:
  description: "io.TextIOBase.__module__ == '_io' — TextIOBase is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: TextIOBase.__module__.__eq__
  args: ["_io"]
  expected: true

# ---------------------------------------------------------------------------
# Concrete class __module__ — FileIO, BytesIO, StringIO
#
# No prior spec covers __module__ for FileIO, BytesIO, or StringIO.
# All three are C-implemented classes exposed through the io namespace;
# their __module__ is '_io'.
# ---------------------------------------------------------------------------

invariant io_extra14.FileIO.module:
  description: "io.FileIO.__module__ == '_io' — FileIO is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra14.BytesIO.module:
  description: "io.BytesIO.__module__ == '_io' — BytesIO is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra14.StringIO.module:
  description: "io.StringIO.__module__ == '_io' — StringIO is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

# ---------------------------------------------------------------------------
# Buffered class __module__ — BufferedReader, BufferedWriter, BufferedRandom
#
# io_extra11 covers __bases__[0].__name__ for each of these classes.
# No prior spec covers their __module__ attributes.
# All three are C-implemented; __module__ == '_io'.
# ---------------------------------------------------------------------------

invariant io_extra14.BufferedReader.module:
  description: "io.BufferedReader.__module__ == '_io' — BufferedReader is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra14.BufferedWriter.module:
  description: "io.BufferedWriter.__module__ == '_io' — BufferedWriter is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: BufferedWriter.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra14.BufferedRandom.module:
  description: "io.BufferedRandom.__module__ == '_io' — BufferedRandom is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: BufferedRandom.__module__.__eq__
  args: ["_io"]
  expected: true

# ---------------------------------------------------------------------------
# TextIOWrapper and IncrementalNewlineDecoder __module__
#
# io_extra11 covers TextIOWrapper.__bases__[0].__name__.
# io_extra13 covers IncrementalNewlineDecoder.__name__.
# No prior spec covers __module__ for either class.
# Both are C-implemented; __module__ == '_io'.
# ---------------------------------------------------------------------------

invariant io_extra14.TextIOWrapper.module:
  description: "io.TextIOWrapper.__module__ == '_io' — TextIOWrapper is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra14.IncrementalNewlineDecoder.module:
  description: "io.IncrementalNewlineDecoder.__module__ == '_io' — IncrementalNewlineDecoder is implemented in the C extension _io"
  category: class_modules
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__module__.__eq__
  args: ["_io"]
  expected: true

# ---------------------------------------------------------------------------
# UnsupportedOperation — __module__ == 'io' (the pure-Python wrapper)
#
# UnsupportedOperation is the one io class defined in the pure-Python io module
# rather than in the C extension _io. Its __module__ is therefore 'io', not '_io'.
# No prior spec checks UnsupportedOperation.__module__.
# ---------------------------------------------------------------------------

invariant io_extra14.UnsupportedOperation.module:
  description: "io.UnsupportedOperation.__module__ == 'io' — defined in the pure-Python io wrapper, not in _io"
  category: class_modules
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true
