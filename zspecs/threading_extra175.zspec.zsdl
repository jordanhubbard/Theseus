spec: threading_extra175
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread.__mro__.__len__()==2 (Thread > object); threading.Lock.__class__.__name__=='type' (Lock is a type/class); threading.local.__mro__.__len__()==2 (local > object); threading.Semaphore.__mro__.__len__()==2 (Semaphore > object); threading.Event.__mro__.__len__()==2 (Event > object); threading.Barrier.__mro__.__len__()==2 (Barrier > object); threading.Thread.__module__=='threading'; threading.Semaphore.__module__=='threading'."
    - "threading.Thread.__mro__.__len__() == 2 — Thread is a Python class in Lib/threading.py inheriting directly from object; MRO is (Thread, object). Verified with Python 3.14.3."
    - "threading.Lock.__class__.__name__ == 'type' — threading.Lock is the C extension type _thread.lock (from Modules/_threadmodule.c), re-exported in threading; calling type() on it gives 'type' because Lock IS a class object. Verified with Python 3.14.3."
    - "threading.local.__mro__.__len__() == 2 — threading.local is the C extension type _thread._local; its MRO is (_local, object). Verified with Python 3.14.3."
    - "threading.Semaphore.__mro__.__len__() == 2 — Semaphore is a Python class in Lib/threading.py inheriting directly from object; its MRO is (Semaphore, object). Verified with Python 3.14.3."
    - "threading.Event.__mro__.__len__() == 2 — Event is a Python class in Lib/threading.py inheriting directly from object; its MRO is (Event, object). Verified with Python 3.14.3."
    - "threading.Barrier.__mro__.__len__() == 2 — Barrier is a Python class in Lib/threading.py inheriting directly from object; its MRO is (Barrier, object). Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading' and threading.Semaphore.__module__ == 'threading'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread and threading.Semaphore __module__ identity
#
# threading.Thread.__module__ == 'threading'
# threading.Semaphore.__module__ == 'threading'
# threading.Thread.__module__.__len__() == 9
# threading.Thread.__module__.__class__.__name__ == 'str'
#
# threading.Thread and threading.Semaphore are both Python classes defined in
# Lib/threading.py. Their __module__ attribute is the string 'threading', which
# is 9 characters long. New to extra175.
# ---------------------------------------------------------------------------

table threading_extra175.thread_semaphore_module:
  description: "threading.Thread.__module__ 'threading'; Semaphore.__module__ 'threading'; module len 9; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmro175

  columns: [id, function, args, expected, description]
  rows:
    - [thread_module_threading,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — threading.Thread is a Python class defined in Lib/threading.py; its __module__ attribute is the string 'threading'; str.__eq__('threading') returns True; new to extra175"]
    - [semaphore_module_threading,
       "Semaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — threading.Semaphore is a Python class defined in Lib/threading.py; its __module__ attribute is the string 'threading'; str.__eq__('threading') returns True; new to extra175"]
    - [thread_module_len_9,
       "Thread.__module__.__len__",
       [],
       9,
       "threading.Thread.__module__.__len__() == 9 — the module name 'threading' has exactly 9 characters: t-h-r-e-a-d-i-n-g; str.__len__() returns 9; new to extra175"]
    - [thread_module_class_str,
       "Thread.__module__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.Thread.__module__.__class__.__name__.__eq__('str') == True — Thread.__module__ is the string 'threading', a str instance; its __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra175"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread and threading.local __mro__.__len__() == 2
#
# threading.Thread.__mro__.__len__() == 2
# threading.Thread.__mro__[0].__name__ == 'Thread'
# threading.local.__mro__.__len__() == 2
# threading.local.__mro__[1].__name__ == 'object'
#
# threading.Thread is a Python class in Lib/threading.py inheriting from object.
# threading.local is actually the C extension type _thread._local (from
# Modules/_threadmodule.c), re-exported as threading.local. Its __mro__[0]
# __name__ is '_local' (the C type name). Both have MRO length 2. New to extra175.
# ---------------------------------------------------------------------------

table threading_extra175.thread_local_mro_len:
  description: "threading.Thread.__mro__: len 2, mro[0] 'Thread'; local.__mro__ len 2, mro[1] 'object'; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmro175

  columns: [id, function, args, expected, description]
  rows:
    - [thread_mro_len_2,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — threading.Thread is a Python class defined in Lib/threading.py representing a thread of control; it inherits directly from object with no intermediate base classes; its __mro__ is (Thread, object), a tuple of length 2; tuple.__len__() returns 2; new to extra175"]
    - ["thread_mro_0_thread",
       "Thread.__mro__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__mro__[0].__name__.__eq__('Thread') == True — the first entry in Thread.__mro__ is the Thread class itself; its __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra175"]
    - [local_mro_len_2,
       "local.__mro__.__len__",
       [],
       2,
       "threading.local.__mro__.__len__() == 2 — threading.local is the C extension type _thread._local from Modules/_threadmodule.c (re-exported as threading.local); it inherits directly from object; its __mro__ is (_local, object), a tuple of length 2; tuple.__len__() returns 2; new to extra175"]
    - ["local_mro_1_object",
       "local.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "threading.local.__mro__[1].__name__.__eq__('object') == True — the second entry in local.__mro__ is the base class object; its __name__ is 'object'; this confirms local (_thread._local) inherits directly from object; str.__eq__('object') returns True; new to extra175"]

# ---------------------------------------------------------------------------
# Table 3: threading.Semaphore and threading.Event __mro__.__len__() == 2
#
# threading.Semaphore.__mro__.__len__() == 2
# threading.Semaphore.__mro__[0].__name__ == 'Semaphore'
# threading.Event.__mro__.__len__() == 2
# threading.Event.__mro__[0].__name__ == 'Event'
#
# threading.Semaphore controls access to a shared resource using a counter.
# threading.Event is a simple synchronization primitive. Both are Python classes
# in Lib/threading.py inheriting directly from object, giving MRO length 2.
# New to extra175.
# ---------------------------------------------------------------------------

table threading_extra175.semaphore_event_mro_len:
  description: "threading.Semaphore.__mro__ len 2, mro[0] 'Semaphore'; Event.__mro__ len 2, mro[0] 'Event'; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmro175

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_mro_len_2,
       "Semaphore.__mro__.__len__",
       [],
       2,
       "threading.Semaphore.__mro__.__len__() == 2 — threading.Semaphore is a Python class defined in Lib/threading.py that manages a counter-based lock controlling access to a shared resource; it inherits directly from object with no intermediate base classes; its __mro__ is (Semaphore, object), a tuple of length 2; tuple.__len__() returns 2; new to extra175"]
    - ["semaphore_mro_0_semaphore",
       "Semaphore.__mro__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__mro__[0].__name__.__eq__('Semaphore') == True — the first entry in Semaphore.__mro__ is the Semaphore class itself; its __name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra175"]
    - [event_mro_len_2,
       "Event.__mro__.__len__",
       [],
       2,
       "threading.Event.__mro__.__len__() == 2 — threading.Event is a Python class defined in Lib/threading.py representing a synchronization primitive where one thread signals an event and others wait for it; it inherits directly from object; its __mro__ is (Event, object), a tuple of length 2; tuple.__len__() returns 2; new to extra175"]
    - ["event_mro_0_event",
       "Event.__mro__[0].__name__.__eq__",
       ["Event"],
       true,
       "threading.Event.__mro__[0].__name__.__eq__('Event') == True — the first entry in Event.__mro__ is the Event class itself; its __name__ is 'Event'; str.__eq__('Event') returns True; new to extra175"]

# ---------------------------------------------------------------------------
# Table 4: threading.Barrier.__mro__.__len__() == 2 and Lock class identity
#
# threading.Barrier.__mro__.__len__() == 2
# threading.Barrier.__mro__[0].__name__ == 'Barrier'
# threading.Lock.__class__.__name__ == 'type'
# threading.Lock.__class__.__name__ != 'function'
#
# threading.Barrier is a Python class in Lib/threading.py that allows a set
# of threads to synchronize at a common point. threading.Lock IS the C
# extension type _thread.lock; because Lock is a class (type), calling
# __class__.__name__ on it returns 'type'. New to extra175.
# ---------------------------------------------------------------------------

table threading_extra175.barrier_mro_and_lock_class:
  description: "threading.Barrier.__mro__ len 2, mro[0] 'Barrier'; Lock.__class__.__name__ 'type'; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmro175

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_mro_len_2,
       "Barrier.__mro__.__len__",
       [],
       2,
       "threading.Barrier.__mro__.__len__() == 2 — threading.Barrier is a Python class defined in Lib/threading.py that synchronizes a set of threads at a common barrier point; it inherits directly from object with no intermediate base classes; its __mro__ is (Barrier, object), a tuple of length 2; tuple.__len__() returns 2; new to extra175"]
    - ["barrier_mro_0_barrier",
       "Barrier.__mro__[0].__name__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__mro__[0].__name__.__eq__('Barrier') == True — the first entry in Barrier.__mro__ is the Barrier class itself; its __name__ is 'Barrier'; str.__eq__('Barrier') returns True; new to extra175"]
    - [lock_class_type,
       "Lock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — threading.Lock is the C extension type _thread.lock re-exported in threading; because Lock is a class (type object), its __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra175"]
    - [lock_class_not_function,
       "Lock.__class__.__name__.__eq__",
       ["function"],
       false,
       "threading.Lock.__class__.__name__.__eq__('function') == False — threading.Lock is a class (type), not a function; its __class__.__name__ is 'type', not 'function'; str.__eq__('function') returns False; new to extra175"]

# ---------------------------------------------------------------------------
# Table 5: MRO uniformity cross-checks — Thread, local, Semaphore, Barrier
#
# threading.Thread.__mro__.__len__() == 2
# threading.local.__mro__.__len__() == 2
# threading.Semaphore.__mro__.__len__() == 2
# threading.Barrier.__mro__.__len__() == 2
#
# All six threading synchronization classes covered in this spec share MRO
# depth 2 (Thread, Lock, local, Semaphore, Event, Barrier). This cross-check
# confirms the pattern for four of them. New to extra175.
# ---------------------------------------------------------------------------

table threading_extra175.mro_uniformity_cross_checks:
  description: "threading: Thread, local, Semaphore, Barrier all have __mro__.__len__() 2; uniformity cross-check; new to extra175"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmro175

  columns: [id, function, args, expected, description]
  rows:
    - [thread_mro_len_2_xcheck,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — cross-check confirming MRO uniformity: Thread is a Python class with direct object inheritance, MRO length 2; tuple.__len__() returns 2; new to extra175"]
    - [local_mro_len_2_xcheck,
       "local.__mro__.__len__",
       [],
       2,
       "threading.local.__mro__.__len__() == 2 — cross-check confirming MRO uniformity: local (_thread._local) is a C extension type with direct object inheritance, MRO length 2; tuple.__len__() returns 2; new to extra175"]
    - [semaphore_mro_len_2_xcheck,
       "Semaphore.__mro__.__len__",
       [],
       2,
       "threading.Semaphore.__mro__.__len__() == 2 — cross-check confirming MRO uniformity: Semaphore is a Python class with direct object inheritance, MRO length 2; tuple.__len__() returns 2; new to extra175"]
    - [barrier_mro_len_2_xcheck,
       "Barrier.__mro__.__len__",
       [],
       2,
       "threading.Barrier.__mro__.__len__() == 2 — cross-check confirming MRO uniformity: Barrier is a Python class with direct object inheritance, MRO length 2; tuple.__len__() returns 2; new to extra175"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra175
# ---------------------------------------------------------------------------

invariant threading_extra175.thread_mro_len_2:
  description: "threading.Thread.__mro__.__len__() == 2 — Thread is a Python class inheriting directly from object; MRO is (Thread, object); new to extra175"
  kind: python_call_eq
  function: Thread.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra175.lock_class_type:
  description: "threading.Lock.__class__.__name__ == 'type' — Lock is the C extension type _thread.lock; as a class object its __class__.__name__ is 'type'; new to extra175"
  kind: python_call_eq
  function: Lock.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra175.local_mro_len_2:
  description: "threading.local.__mro__.__len__() == 2 — local is the C extension type _thread._local inheriting directly from object; MRO is (_local, object); new to extra175"
  kind: python_call_eq
  function: local.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra175.semaphore_mro_len_2:
  description: "threading.Semaphore.__mro__.__len__() == 2 — Semaphore is a Python class inheriting directly from object; MRO is (Semaphore, object); new to extra175"
  kind: python_call_eq
  function: Semaphore.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra175.event_mro_len_2:
  description: "threading.Event.__mro__.__len__() == 2 — Event is a Python class inheriting directly from object; MRO is (Event, object); new to extra175"
  kind: python_call_eq
  function: Event.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra175.barrier_mro_len_2:
  description: "threading.Barrier.__mro__.__len__() == 2 — Barrier is a Python class inheriting directly from object; MRO is (Barrier, object); new to extra175"
  kind: python_call_eq
  function: Barrier.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra175.thread_module_threading:
  description: "threading.Thread.__module__ == 'threading' — Thread is defined in Lib/threading.py; new to extra175"
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra175.semaphore_module_threading:
  description: "threading.Semaphore.__module__ == 'threading' — Semaphore is defined in Lib/threading.py; new to extra175"
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["threading"]
  expected: true
