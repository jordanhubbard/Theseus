spec: abc_extra1441
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc: Abstract Base Classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py, Modules/_abc.c"
  notes:
    - "Wave 543 (_extra1441): focuses on __subclasshook__, __instancecheck__, and __subclasscheck__ for abc module classes."
    - "abc.ABCMeta defines __instancecheck__ and __subclasscheck__ in its own __dict__ (as plain Python functions)."
    - "abc.ABCMeta.__instancecheck__.__class__.__name__ == 'function' (defined in Lib/abc.py)."
    - "abc.ABCMeta.__subclasscheck__.__class__.__name__ == 'function' (defined in Lib/abc.py)."
    - "abc.ABCMeta.__subclasshook__ is inherited (not in ABCMeta.__dict__); its __class__.__name__ == 'builtin_function_or_method'."
    - "abc.ABC is an instance of ABCMeta, so abc.ABC.__instancecheck__ resolves to a bound method; __class__.__name__ == 'method'."
    - "abc.ABC.__subclasscheck__ similarly resolves to a bound method with __class__.__name__ == 'method'."
    - "abc.ABC does not define __instancecheck__, __subclasscheck__, or __subclasshook__ in its own __dict__."
    - "abc.abstractmethod is a plain function; it has no __instancecheck__; __subclasshook__ is inherited with __class__.__name__ == 'builtin_function_or_method'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra1441.abcmeta_instancecheck_subclasscheck_class_name:
  description: "abc.ABCMeta __instancecheck__ and __subclasscheck__ __class__.__name__ identity — both are plain Python functions defined in Lib/abc.py and present in ABCMeta.__dict__; __class__.__name__ == 'function' for both; __subclasshook__ is inherited with __class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"
  kind: python_call_eq
  category: instancecheck_class_name
  id_prefix: ab1441am
  columns: [id, function, args, expected]
  rows:
    - [ab1441am001, abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__,  ["function"],                  true]
    - [ab1441am002, abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__,  ["function"],                  true]
    - [ab1441am003, abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [ab1441am004, abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__,  ["function"],                  true]
    - [ab1441am005, abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__,  ["function"],                  true]
    - [ab1441am006, abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]

table abc_extra1441.abcmeta_dict_membership:
  description: "abc.ABCMeta __dict__ membership for __instancecheck__, __subclasscheck__, __subclasshook__ — ABCMeta defines __instancecheck__ and __subclasscheck__ in its own __dict__ (True), but __subclasshook__ is inherited and absent from ABCMeta.__dict__ (False); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ab1441dm
  columns: [id, function, args, expected]
  rows:
    - [ab1441dm001, abc.ABCMeta.__dict__.__contains__, ["__instancecheck__"],  true]
    - [ab1441dm002, abc.ABCMeta.__dict__.__contains__, ["__subclasscheck__"],  true]
    - [ab1441dm003, abc.ABCMeta.__dict__.__contains__, ["__subclasshook__"],   false]
    - [ab1441dm004, abc.ABC.__dict__.__contains__,     ["__instancecheck__"],  false]
    - [ab1441dm005, abc.ABC.__dict__.__contains__,     ["__subclasscheck__"],  false]
    - [ab1441dm006, abc.ABC.__dict__.__contains__,     ["__subclasshook__"],   false]

