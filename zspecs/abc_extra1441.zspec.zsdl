    - [ab1441ai002, abc.ABC.__subclasscheck__.__class__.__name__.__eq__,  ["method"],                    true]
    - [ab1441ai003, abc.ABC.__subclasshook__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [ab1441ai004, abc.ABC.__instancecheck__.__class__.__name__.__eq__,  ["method"],                    true]
    - [ab1441ai005, abc.ABC.__subclasscheck__.__class__.__name__.__eq__,  ["method"],                    true]
