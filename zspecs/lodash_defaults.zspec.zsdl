spec: lodash_defaults
version: ">=4.0.0"
backend: node(lodash.defaults)

docs: https://lodash.com/docs/#defaults

provenance:
  derived_from:
    - "lodash.defaults README — https://www.npmjs.com/package/lodash.defaults"
    - "Test vectors verified with lodash.defaults@4.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.defaults exports the _.defaults function directly as module.exports."
    - "defaults(object, ...sources) assigns default values for properties that resolve to undefined."
    - "Unlike merge, existing values are NOT overwritten — only undefined slots are filled."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns mutated object with defaults applied. No errors for object inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_defaults.defaults:
  kind: node_module_call_eq
  function: ~
  category: defaults
  id_prefix: ldefs

  columns: [id, args, expected]
  rows:
    - [fill_missing,  [{"a": 1}, {"a": 99, "b": 2}],   {"a": 1, "b": 2}]
    - [all_missing,   [{}, {"x": 1, "y": 2}],           {"x": 1, "y": 2}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:21:55Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
