spec: multiprocessing_extra67
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#exceptions — Python multiprocessing exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra66.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__len__() tables, Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type', Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins', Pool/__doc__/__class__/__module__=='builtins', Pool/__class__.__name__=='type', Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins'), Process/__init__.__class__.__name__.__eq__('function'), Process/Pool __repr__.__class__.__name__, Process __weakref__.__class__.__name__, ProcessError/AuthenticationError exception __repr__.__class__.__name__, mp.__all__.__class__.__name__.__eq__('list'), mp.__all__.__len__()==37, Process/ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor'), mp.__all__.__contains__ membership checks, mp.__package__.__eq__('multiprocessing'), Queue/Pool __doc__.__class__.__name__.__eq__('str'), __loader__/__spec__/__file__/__cached__ __class__.__name__, __spec__ attributes, Process method __qualname__ string equality, Process.__init__/__annotations__/__globals__ class identity, Process.__init__/__defaults__/__code__/__class__.__name__ checks, current_process/__defaults__/__code__/__class__.__name__ checks (extra61), Process.__init__/Process.start/current_process __code__.co_name equality and co_argcount values (extra62), Process.__init__/Process.start/current_process co_varnames/co_filename/co_flags attribute chains (extra63), Process.__init__/Process.start/current_process co_consts/co_nlocals/co_stacksize type identity (extra64), Process.__init__/__defaults__.__class__.__name__=='tuple', Process.__init__/__defaults__.__len__()==5, Process.start/__defaults__.__class__.__name__=='NoneType', current_process/__defaults__.__class__.__name__=='NoneType', Pool class identity, Pool MRO and base class checks (extra65), Process.__init__/__kwdefaults__.__class__.__name__=='dict', Process.__init__/__kwdefaults__.__len__()==1, Process.start/__kwdefaults__.__class__.__name__=='NoneType', current_process/__kwdefaults__.__class__.__name__=='NoneType', Pool/__name__/__module__/__qualname__, Process/__name__/__module__/__qualname__ (extra66)."
    - "This spec covers (mperror67 namespace): wave 235 theme — multiprocessing exception hierarchy identity. NEW in extra67: ProcessError.__name__.__eq__('ProcessError'); ProcessError.__bases__[0].__name__.__eq__('Exception') [quoted]; ProcessError.__mro__.__len__()==4; BufferTooShort/__bases__[0].__name__=='ProcessError' [quoted]; AuthenticationError/__bases__[0].__name__=='ProcessError' [quoted]; TimeoutError/__bases__[0].__name__=='ProcessError' [quoted]; BufferTooShort.__mro__.__len__()==5; TimeoutError.__mro__.__len__()==5; BufferTooShort.__name__.__eq__('BufferTooShort'); AuthenticationError.__name__.__eq__('AuthenticationError'); TimeoutError.__name__.__eq__('TimeoutError')."
    - "multiprocessing.ProcessError.__name__ == 'ProcessError'. ProcessError is the base exception for all multiprocessing errors, defined in Lib/multiprocessing/context.py. Its __name__ is the simple class name 'ProcessError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'. ProcessError inherits from Exception. ProcessError.__bases__ is (Exception,). Exception.__name__ is 'Exception'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__mro__.__len__() == 4. ProcessError's MRO is [ProcessError, Exception, BaseException, object], a four-element tuple. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'. BufferTooShort inherits from ProcessError. BufferTooShort.__bases__[0] is ProcessError. ProcessError.__name__ is 'ProcessError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'. AuthenticationError inherits from ProcessError. AuthenticationError.__bases__[0] is ProcessError. ProcessError.__name__ is 'ProcessError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'. multiprocessing.TimeoutError inherits from ProcessError (distinct from builtins.TimeoutError). TimeoutError.__bases__[0] is ProcessError. ProcessError.__name__ is 'ProcessError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__mro__.__len__() == 5. BufferTooShort's MRO is [BufferTooShort, ProcessError, Exception, BaseException, object], a five-element tuple. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__mro__.__len__() == 5. TimeoutError's MRO is [TimeoutError, ProcessError, Exception, BaseException, object], a five-element tuple. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort'. BufferTooShort is a subclass of ProcessError for when the connection sends data too large for a buffer. Its __name__ is the simple class name 'BufferTooShort'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError'. AuthenticationError is a subclass of ProcessError raised when there is an authentication error. Its __name__ is the simple class name 'AuthenticationError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__name__ == 'TimeoutError'. multiprocessing.TimeoutError is a subclass of ProcessError distinct from builtins.TimeoutError. Its __name__ is the simple class name 'TimeoutError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing ProcessError hierarchy checks — extra67
#
# Wave 235 theme: ProcessError base exception hierarchy.
#
# ProcessError.__name__ == 'ProcessError'
# ProcessError.__bases__[0].__name__ == 'Exception'  (quoting required: contains '[')
# ProcessError.__mro__.__len__() == 4
# ---------------------------------------------------------------------------

table multiprocessing_extra67.ProcessError_hierarchy:
  description: "multiprocessing ProcessError hierarchy checks in mperror67 namespace — wave 235 theme: ProcessError base exception hierarchy; ProcessError.__name__=='ProcessError'; ProcessError.__bases__[0].__name__=='Exception' (ProcessError inherits from Exception; function value containing '[' must be double-quoted); ProcessError.__mro__.__len__()==4 (MRO is [ProcessError, Exception, BaseException, object]); NEW in extra67: first hierarchy checks for ProcessError in the mperror67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mperror67

  columns: [id, function, args, expected, description]
  rows:
    - [processerror_name,      ProcessError.__name__.__eq__,             ["ProcessError"], true, "ProcessError.__name__ == 'ProcessError' — ProcessError is the base exception for all multiprocessing errors; defined in Lib/multiprocessing/context.py; its __name__ is the simple class name 'ProcessError'; NEW in extra67: first __name__.__eq__ check for ProcessError in the mperror67 namespace; verified with Python 3.14.3"]
    - ["processerror_bases_0", "ProcessError.__bases__[0].__name__.__eq__", ["Exception"],   true, "ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError inherits from Exception; ProcessError.__bases__ is (Exception,); ProcessError.__bases__[0] is Exception; Exception.__name__ is 'Exception'; function value containing '[' is double-quoted per ZSDL rules; NEW in extra67: first __bases__[0].__name__.__eq__('Exception') check for ProcessError in the mperror67 namespace; verified with Python 3.14.3"]
    - [processerror_mro_len,   ProcessError.__mro__.__len__,             [],               4,    "ProcessError.__mro__.__len__() == 4 — ProcessError's MRO is [ProcessError, Exception, BaseException, object], a four-element tuple; __mro__.__len__() returns 4; NEW in extra67: first __mro__.__len__() check for ProcessError in the mperror67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing ProcessError subclasses __bases__[0].__name__ — extra67
#
# Wave 235 theme: ProcessError subclass base identity.
#
# BufferTooShort.__bases__[0].__name__ == 'ProcessError'
# AuthenticationError.__bases__[0].__name__ == 'ProcessError'
# TimeoutError.__bases__[0].__name__ == 'ProcessError'
# All function values contain '[' and MUST be double-quoted.
# ---------------------------------------------------------------------------

table multiprocessing_extra67.ProcessError_subclasses:
  description: "multiprocessing BufferTooShort/AuthenticationError/TimeoutError __bases__[0].__name__.__eq__('ProcessError') checks in mperror67 namespace — wave 235 theme: ProcessError subclass base identity; all three directly inherit from ProcessError; function values containing '[' are double-quoted per ZSDL rules; NEW in extra67: first __bases__[0].__name__.__eq__('ProcessError') checks for BufferTooShort/AuthenticationError/TimeoutError in the mperror67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mperror67a

  columns: [id, function, args, expected, description]
  rows:
    - ["buffertoo_bases_0",  "BufferTooShort.__bases__[0].__name__.__eq__",     ["ProcessError"], true, "BufferTooShort.__bases__[0].__name__ == 'ProcessError' — BufferTooShort inherits from ProcessError; BufferTooShort.__bases__ is (ProcessError,); BufferTooShort.__bases__[0] is ProcessError; ProcessError.__name__ is 'ProcessError'; function value containing '[' is double-quoted per ZSDL rules; NEW in extra67: first __bases__[0].__name__.__eq__('ProcessError') check for BufferTooShort in the mperror67 namespace; verified with Python 3.14.3"]
    - ["autherror_bases_0",  "AuthenticationError.__bases__[0].__name__.__eq__", ["ProcessError"], true, "AuthenticationError.__bases__[0].__name__ == 'ProcessError' — AuthenticationError inherits from ProcessError; AuthenticationError.__bases__ is (ProcessError,); AuthenticationError.__bases__[0] is ProcessError; ProcessError.__name__ is 'ProcessError'; function value containing '[' is double-quoted per ZSDL rules; NEW in extra67: first __bases__[0].__name__.__eq__('ProcessError') check for AuthenticationError in the mperror67 namespace; verified with Python 3.14.3"]
    - ["timeout_bases_0",    "TimeoutError.__bases__[0].__name__.__eq__",        ["ProcessError"], true, "TimeoutError.__bases__[0].__name__ == 'ProcessError' — multiprocessing.TimeoutError inherits from ProcessError (distinct from builtins.TimeoutError); TimeoutError.__bases__[0] is ProcessError; ProcessError.__name__ is 'ProcessError'; function value containing '[' is double-quoted per ZSDL rules; NEW in extra67: first __bases__[0].__name__.__eq__('ProcessError') check for TimeoutError in the mperror67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing subclass MRO length checks — extra67
#
# Wave 235 theme: exception MRO depth.
#
# BufferTooShort.__mro__.__len__() == 5
# TimeoutError.__mro__.__len__() == 5
#
# MRO for each: [SubClass, ProcessError, Exception, BaseException, object]
# ---------------------------------------------------------------------------

table multiprocessing_extra67.subclass_mro_lengths:
  description: "multiprocessing BufferTooShort/__mro__.__len__() and TimeoutError/__mro__.__len__() checks in mperror67 namespace — wave 235 theme: exception MRO depth; BufferTooShort.__mro__.__len__()==5 (MRO is [BufferTooShort, ProcessError, Exception, BaseException, object]); TimeoutError.__mro__.__len__()==5 (MRO is [TimeoutError, ProcessError, Exception, BaseException, object]); NEW in extra67: first __mro__.__len__() checks for BufferTooShort and TimeoutError in the mperror67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mperror67b

  columns: [id, function, args, expected, description]
  rows:
    - [buffertoo_mro_len, BufferTooShort.__mro__.__len__, [], 5, "BufferTooShort.__mro__.__len__() == 5 — BufferTooShort's MRO is [BufferTooShort, ProcessError, Exception, BaseException, object], a five-element tuple; __mro__.__len__() returns 5; NEW in extra67: first __mro__.__len__() check for BufferTooShort in the mperror67 namespace; verified with Python 3.14.3"]
    - [timeout_mro_len,   TimeoutError.__mro__.__len__,  [], 5, "TimeoutError.__mro__.__len__() == 5 — multiprocessing.TimeoutError's MRO is [TimeoutError, ProcessError, Exception, BaseException, object], a five-element tuple; __mro__.__len__() returns 5; NEW in extra67: first __mro__.__len__() check for TimeoutError in the mperror67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing exception __name__ string equality — extra67
#
# Wave 235 theme: exception name identity.
#
# BufferTooShort.__name__ == 'BufferTooShort'
# AuthenticationError.__name__ == 'AuthenticationError'
# TimeoutError.__name__ == 'TimeoutError'
# ---------------------------------------------------------------------------

table multiprocessing_extra67.multiprocessing_error_names:
  description: "multiprocessing BufferTooShort/AuthenticationError/TimeoutError __name__.__eq__ checks in mperror67 namespace — wave 235 theme: exception name identity; BufferTooShort.__name__=='BufferTooShort'; AuthenticationError.__name__=='AuthenticationError'; TimeoutError.__name__=='TimeoutError'; NEW in extra67: first __name__.__eq__ string equality checks for these ProcessError subclasses in the mperror67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mperror67c

  columns: [id, function, args, expected, description]
  rows:
    - [buffertoo_name,  BufferTooShort.__name__.__eq__,     ["BufferTooShort"],     true, "BufferTooShort.__name__ == 'BufferTooShort' — BufferTooShort is a subclass of ProcessError raised when the connection sends data too large for a buffer; its __name__ is the simple class name 'BufferTooShort'; NEW in extra67: first __name__.__eq__ check for BufferTooShort in the mperror67 namespace; verified with Python 3.14.3"]
    - [autherror_name,  AuthenticationError.__name__.__eq__, ["AuthenticationError"], true, "AuthenticationError.__name__ == 'AuthenticationError' — AuthenticationError is a subclass of ProcessError raised when there is an authentication error; its __name__ is the simple class name 'AuthenticationError'; NEW in extra67: first __name__.__eq__ check for AuthenticationError in the mperror67 namespace; verified with Python 3.14.3"]
    - [timeout_name,    TimeoutError.__name__.__eq__,        ["TimeoutError"],        true, "TimeoutError.__name__ == 'TimeoutError' — multiprocessing.TimeoutError is a subclass of ProcessError distinct from builtins.TimeoutError; its __name__ is the simple class name 'TimeoutError'; NEW in extra67: first __name__.__eq__ check for TimeoutError in the mperror67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra67
# ---------------------------------------------------------------------------

invariant multiprocessing_extra67.ProcessError_name:
  description: "multiprocessing.ProcessError.__name__.__eq__('ProcessError') returns True — ProcessError is the base exception for all multiprocessing errors, defined in Lib/multiprocessing/context.py; its __name__ is the simple class name 'ProcessError'; NEW in extra67: first standalone __name__.__eq__('ProcessError') invariant for ProcessError in the mperror67 namespace; wave 235 first exception name identity invariant for ProcessError; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessError.__name__.__eq__
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra67.AuthenticationError_name:
  description: "multiprocessing.AuthenticationError.__name__.__eq__('AuthenticationError') returns True — AuthenticationError is a subclass of ProcessError raised when there is an authentication error; its __name__ is the simple class name 'AuthenticationError'; NEW in extra67: first standalone __name__.__eq__('AuthenticationError') invariant in the mperror67 namespace; wave 235 first name identity invariant for AuthenticationError; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AuthenticationError.__name__.__eq__
  args: ["AuthenticationError"]
  expected: true

invariant multiprocessing_extra67.ProcessError_mro_4:
  description: "multiprocessing.ProcessError.__mro__.__len__() == 4 — ProcessError's MRO is [ProcessError, Exception, BaseException, object], a four-element tuple; __mro__.__len__() returns 4; NEW in extra67: first standalone __mro__.__len__()==4 invariant for ProcessError in the mperror67 namespace; wave 235 first MRO length invariant for ProcessError; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessError.__mro__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra67.BufferTooShort_mro_5:
  description: "multiprocessing.BufferTooShort.__mro__.__len__() == 5 — BufferTooShort's MRO is [BufferTooShort, ProcessError, Exception, BaseException, object], a five-element tuple; __mro__.__len__() returns 5; NEW in extra67: first standalone __mro__.__len__()==5 invariant for BufferTooShort in the mperror67 namespace; wave 235 first MRO length invariant for BufferTooShort; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BufferTooShort.__mro__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra67.BufferTooShort_name:
  description: "multiprocessing.BufferTooShort.__name__.__eq__('BufferTooShort') returns True — BufferTooShort is a subclass of ProcessError; its __name__ is the simple class name 'BufferTooShort'; NEW in extra67: first standalone __name__.__eq__('BufferTooShort') invariant in the mperror67 namespace; wave 235 first name identity invariant for BufferTooShort; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BufferTooShort.__name__.__eq__
  args: ["BufferTooShort"]
  expected: true
