spec: re_extra2131
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match/error class names, flag constants"
    - "re_extra1771.zspec.zsdl — covers async protocol dict-presence for re types"
    - "re_extra1501.zspec.zsdl — covers __cause__/__context__ dict-presence for re types"
  notes:
    - "Wave 2131, theme: exception protocol dict-presence."
    - "Checks whether __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, and with_traceback appear in the __dict__ of re classes."
    - "re.error is an exception (subclasses Exception); re.Pattern and re.Match are C-extension types (not exceptions); re.RegexFlag is an IntFlag enum."
    - "__cause__, __context__, __traceback__, __suppress_context__ are CPython instance attributes on exception objects — never in a class __dict__."
    - "args is an instance-level tuple attribute of BaseException; not defined at class level."
    - "with_traceback is defined by the BaseException C type; re.error.__dict__ does not contain it."
    - "re.error.__dict__ contains: __init__, __str__, __doc__, __module__, __weakref__ — these are defined by re.error itself."
    - "re.Pattern and re.Match are C-extension types with no exception protocol methods in their __dict__."
    - "re.RegexFlag is an IntFlag subclass (enum); it defines no exception protocol members."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __cause__ dict-presence — re types
# __cause__ is the explicit exception cause; set on instances by 'raise X from Y'.
# re.error is an exception but still has no __cause__ in its class __dict__.
# ---------------------------------------------------------------------------

table re_extra2131.cause_protocol:
  description: "re type __dict__.__contains__('__cause__') — all False (instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2131

  columns: [id, function, args, expected]
  rows:
    - ["re2131001", "re.error.__dict__.__contains__",    ["__cause__"], false]
    - ["re2131002", "re.Pattern.__dict__.__contains__",  ["__cause__"], false]
    - ["re2131003", "re.Match.__dict__.__contains__",    ["__cause__"], false]
    - ["re2131004", "re.RegexFlag.__dict__.__contains__", ["__cause__"], false]

# ---------------------------------------------------------------------------
# __context__ dict-presence — re types
# __context__ is the implicit chained exception context; instance-level only.
# ---------------------------------------------------------------------------

table re_extra2131.context_protocol:
  description: "re type __dict__.__contains__('__context__') — all False (instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2131

  columns: [id, function, args, expected]
  rows:
    - ["re2131005", "re.error.__dict__.__contains__",    ["__context__"], false]
    - ["re2131006", "re.Pattern.__dict__.__contains__",  ["__context__"], false]
    - ["re2131007", "re.Match.__dict__.__contains__",    ["__context__"], false]
    - ["re2131008", "re.RegexFlag.__dict__.__contains__", ["__context__"], false]

# ---------------------------------------------------------------------------
# __traceback__ dict-presence — re types
# __traceback__ holds the traceback object on exception instances; instance-only.
# ---------------------------------------------------------------------------

table re_extra2131.traceback_protocol:
  description: "re type __dict__.__contains__('__traceback__') — all False (instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2131

  columns: [id, function, args, expected]
  rows:
    - ["re2131009", "re.error.__dict__.__contains__",    ["__traceback__"], false]
    - ["re2131010", "re.Pattern.__dict__.__contains__",  ["__traceback__"], false]
    - ["re2131011", "re.Match.__dict__.__contains__",    ["__traceback__"], false]
    - ["re2131012", "re.RegexFlag.__dict__.__contains__", ["__traceback__"], false]

# ---------------------------------------------------------------------------
# __suppress_context__ dict-presence — re types
# __suppress_context__ is a bool on exception instances; not in class __dict__.
# ---------------------------------------------------------------------------

table re_extra2131.suppress_context_protocol:
  description: "re type __dict__.__contains__('__suppress_context__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2131

  columns: [id, function, args, expected]
  rows:
    - ["re2131013", "re.error.__dict__.__contains__",    ["__suppress_context__"], false]
    - ["re2131014", "re.Pattern.__dict__.__contains__",  ["__suppress_context__"], false]
    - ["re2131015", "re.Match.__dict__.__contains__",    ["__suppress_context__"], false]
    - ["re2131016", "re.RegexFlag.__dict__.__contains__", ["__suppress_context__"], false]

# ---------------------------------------------------------------------------
# __notes__ dict-presence — re types
# __notes__ (PEP 678, Python 3.11+) is lazily created on exception instances.
# re.error does not define __notes__ at class level.
# ---------------------------------------------------------------------------

table re_extra2131.notes_protocol:
  description: "re type __dict__.__contains__('__notes__') — all False (PEP 678 instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2131

  columns: [id, function, args, expected]
  rows:
    - ["re2131017", "re.error.__dict__.__contains__",    ["__notes__"], false]
    - ["re2131018", "re.Pattern.__dict__.__contains__",  ["__notes__"], false]
    - ["re2131019", "re.Match.__dict__.__contains__",    ["__notes__"], false]
    - ["re2131020", "re.RegexFlag.__dict__.__contains__", ["__notes__"], false]

# ---------------------------------------------------------------------------
# args dict-presence — re types
# args is a tuple on BaseException instances (set in __init__); not class-level.
# Even though re.error overrides __init__, args is not added to class __dict__.
# ---------------------------------------------------------------------------

table re_extra2131.args_protocol:
  description: "re type __dict__.__contains__('args') — all False (instance attribute of BaseException)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2131

  columns: [id, function, args, expected]
  rows:
    - ["re2131021", "re.error.__dict__.__contains__",    ["args"], false]
    - ["re2131022", "re.Pattern.__dict__.__contains__",  ["args"], false]
    - ["re2131023", "re.Match.__dict__.__contains__",    ["args"], false]
    - ["re2131024", "re.RegexFlag.__dict__.__contains__", ["args"], false]

# ---------------------------------------------------------------------------
# with_traceback dict-presence — re types
# with_traceback is a method defined on the BaseException C type.
# re.error does not redefine or override with_traceback in its own __dict__.
# ---------------------------------------------------------------------------

table re_extra2131.with_traceback_protocol:
  description: "re type __dict__.__contains__('with_traceback') — all False (BaseException C-level method, not overridden)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2131

  columns: [id, function, args, expected]
  rows:
    - ["re2131025", "re.error.__dict__.__contains__",    ["with_traceback"], false]
    - ["re2131026", "re.Pattern.__dict__.__contains__",  ["with_traceback"], false]
    - ["re2131027", "re.Match.__dict__.__contains__",    ["with_traceback"], false]
    - ["re2131028", "re.RegexFlag.__dict__.__contains__", ["with_traceback"], false]
