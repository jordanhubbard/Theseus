spec: hmac_extra22
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "RFC 4231 — Identifiers and Test Vectors for HMAC-SHA-224, SHA-256, SHA-384, SHA-512"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "RFC 4231 — Identifiers and Test Vectors for HMAC-SHA-224, SHA-256, SHA-384, SHA-512, December 2005"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra21.zspec.zsdl — covers digest/compare_digest/new/HMAC __module__.__len__(); new(sha224/sha384) digest_size/block_size; callable_class_names table."
    - "hmac_extra19.zspec.zsdl — covers new(sha1) digest_size/block_size/hexdigest len; digest(sha256) len; new/digest __qualname__."
    - "hmac_extra17.zspec.zsdl — covers new/compare_digest/digest __name__/__module__; HMAC __qualname__/__module__/__bases__[0].__name__."
    - "hmac_extra14.zspec.zsdl — covers __qualname__ for new/digest/compare_digest/HMAC via table; HMAC __name__."
  notes:
    - "This spec extends hmac through hmac_extra21; it does NOT duplicate invariants present in those files."
    - "Focus: HMAC class MRO structure — MRO length, MRO member names, MRO member qualnames. hmac.HMAC has a two-entry MRO (HMAC, object). No prior spec groups all MRO invariants into a single table."
    - "hmac.HMAC.__mro__.__len__() == 2: HMAC inherits only from object; the MRO is [HMAC, object]. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__mro__[0].__name__ == 'HMAC': first MRO entry is the class itself. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__mro__[1].__name__ == 'object': second (and last) MRO entry is object. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__qualname__ == 'HMAC': plain top-level class; qualname equals name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__name__.__len__() == 4: len('HMAC') == 4. No prior spec verifies the length of the name string. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__qualname__.__len__() == 4: len('HMAC') == 4. No prior spec verifies the qualname length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__mro__[0].__qualname__ == 'HMAC': qualname of first MRO entry. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hmac.HMAC.__mro__[1].__qualname__ == 'object': qualname of second MRO entry. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hmac.HMAC MRO length
#
# hmac_extra17 covers HMAC.__bases__[0].__name__ == 'object'.
# No prior spec checks HMAC.__mro__.__len__() directly.
# hmac.HMAC has a flat hierarchy: HMAC -> object, giving a MRO of length 2.
# ---------------------------------------------------------------------------

invariant hmac_extra22.HMAC.mro_len:
  description: "hmac.HMAC.__mro__.__len__() == 2 — HMAC inherits only from object"
  category: class_hierarchy
  kind: python_call_eq
  function: HMAC.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# hmac.HMAC.__qualname__ and __name__ length
#
# hmac_extra14 covers HMAC.__qualname__ == 'HMAC' via a table row.
# No prior spec checks HMAC.__qualname__.__len__() or HMAC.__name__.__len__().
# Both equal 4 (len('HMAC') == 4).
# ---------------------------------------------------------------------------

invariant hmac_extra22.HMAC.qualname_len:
  description: "hmac.HMAC.__qualname__.__len__() == 4 — len('HMAC') == 4"
  category: class_metadata
  kind: python_call_eq
  function: HMAC.__qualname__.__len__
  args: []
  expected: 4

invariant hmac_extra22.HMAC.name_len:
  description: "hmac.HMAC.__name__.__len__() == 4 — len('HMAC') == 4"
  category: class_metadata
  kind: python_call_eq
  function: HMAC.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# hmac.HMAC.__qualname__.__eq__ as standalone invariant
#
# hmac_extra14 covers HMAC.__qualname__ via table row. This invariant anchors
# the same property from the extra22 namespace as a standalone __eq__ call,
# providing an independent execution path.
# ---------------------------------------------------------------------------

invariant hmac_extra22.HMAC.qualname_eq:
  description: "hmac.HMAC.__qualname__ == 'HMAC' — top-level class; qualname equals name"
  category: class_metadata
  kind: python_call_eq
  function: HMAC.__qualname__.__eq__
  args: ["HMAC"]
  expected: true

# ---------------------------------------------------------------------------
# hmac.HMAC MRO member __name__ and __qualname__ table
#
# hmac_extra17 covers HMAC.__bases__[0].__name__ == 'object' (not MRO).
# No prior spec checks MRO[0] or MRO[1] __name__/__qualname__ in table form.
# MRO[0] is HMAC itself; MRO[1] is object.
# ---------------------------------------------------------------------------

table hmac_extra22.HMAC.mro_member_names:
  description: "hmac.HMAC MRO entry __name__ and __qualname__ values"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: hmacmro22

  columns: [id, function, args, expected]
  rows:
    - ["mro0_name",     "HMAC.__mro__[0].__name__.__eq__",     ["HMAC"],   true]
    - ["mro1_name",     "HMAC.__mro__[1].__name__.__eq__",     ["object"], true]
    - ["mro0_qualname", "HMAC.__mro__[0].__qualname__.__eq__", ["HMAC"],   true]
    - ["mro1_qualname", "HMAC.__mro__[1].__qualname__.__eq__", ["object"], true]
