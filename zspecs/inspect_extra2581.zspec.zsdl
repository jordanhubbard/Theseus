spec: inspect_extra2581
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2581 (_extra2581): __call__ dict-presence checks — callable functor classification."
    - "inspect.attrgetter is actually operator.attrgetter (re-exported into inspect); it DOES define __call__ in its own __dict__ — it is a C extension callable functor."
    - "inspect.make_weakref is actually weakref.ReferenceType (re-exported into inspect); it DOES define __call__ in its own __dict__ — calling an existing weakref object returns its referent."
    - "inspect.Signature, inspect.Parameter, inspect.BoundArguments are pure-Python data classes; none define __call__ in their own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, inspect.FullArgSpec are namedtuple-based data containers; none define __call__."
    - "inspect.BlockFinder is a visitor helper class; inspect.EndOfBlock and inspect.ClassFoundException are exception classes — none define __call__."
    - "inspect.Format and inspect.BufferFlags are enum classes; inspect.ForwardRef is a typing helper — none define __call__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __call__ dict-presence — inspect types that ARE callable functors
#
# Only two names in the inspect namespace resolve to types that define
# __call__ in their own __dict__: inspect.attrgetter (operator.attrgetter,
# a C extension that fetches named attributes when called) and
# inspect.make_weakref (weakref.ReferenceType, whose instances are callable
# to retrieve the referent).  Both are re-exported aliases, not types
# defined in inspect itself.
# ---------------------------------------------------------------------------

table inspect_extra2581.call_present:
  description: "inspect namespace entries that define __call__ in their own __dict__ — wave 2581"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2581

  columns: [id, function, args, expected]
  rows:
    - ["in2581001", "inspect.attrgetter.__dict__.__contains__", ["__call__"], true]
    - ["in2581002", "inspect.make_weakref.__dict__.__contains__", ["__call__"], true]

# ---------------------------------------------------------------------------
# Table 2: __call__ dict-presence — inspect introspection data classes
#
# The core inspect data-holder types (Signature, Parameter, BoundArguments)
# represent parsed calling conventions but are not themselves callable
# functors.  None define __call__ in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2581.call_absent_data_classes:
  description: "inspect introspection data classes __call__ dict-presence — wave 2581"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2581

  columns: [id, function, args, expected]
  rows:
    - ["in2581003", "inspect.Signature.__dict__.__contains__", ["__call__"], false]
    - ["in2581004", "inspect.Parameter.__dict__.__contains__", ["__call__"], false]
    - ["in2581005", "inspect.BoundArguments.__dict__.__contains__", ["__call__"], false]
    - ["in2581006", "inspect.FrameInfo.__dict__.__contains__", ["__call__"], false]
    - ["in2581007", "inspect.ArgInfo.__dict__.__contains__", ["__call__"], false]
    - ["in2581008", "inspect.FullArgSpec.__dict__.__contains__", ["__call__"], false]
    - ["in2581009", "inspect.ClosureVars.__dict__.__contains__", ["__call__"], false]
    - ["in2581010", "inspect.Traceback.__dict__.__contains__", ["__call__"], false]
    - ["in2581011", "inspect.Arguments.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Table 3: __call__ dict-presence — inspect helper and exception types
#
# inspect.BlockFinder is a codeop-style visitor used by getsource() internals.
# inspect.EndOfBlock and inspect.ClassFoundException are sentinel exceptions.
# inspect.ForwardRef is a typing-system helper re-exported for use in
# annotation inspection.  inspect.Format and inspect.BufferFlags are enums.
# None define __call__ in their own __dict__.
# ---------------------------------------------------------------------------

table inspect_extra2581.call_absent_helpers:
  description: "inspect helper and exception types __call__ dict-presence — wave 2581"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2581

  columns: [id, function, args, expected]
  rows:
    - ["in2581012", "inspect.BlockFinder.__dict__.__contains__", ["__call__"], false]
    - ["in2581013", "inspect.EndOfBlock.__dict__.__contains__", ["__call__"], false]
    - ["in2581014", "inspect.ClassFoundException.__dict__.__contains__", ["__call__"], false]
    - ["in2581015", "inspect.ForwardRef.__dict__.__contains__", ["__call__"], false]
    - ["in2581016", "inspect.Format.__dict__.__contains__", ["__call__"], false]
    - ["in2581017", "inspect.BufferFlags.__dict__.__contains__", ["__call__"], false]
    - ["in2581018", "inspect.Attribute.__dict__.__contains__", ["__call__"], false]
