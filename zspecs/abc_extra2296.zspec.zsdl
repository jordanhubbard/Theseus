spec: abc_extra2296
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "abc.ABC, abc.ABCMeta, abc.abstractmethod all report __module__ as 'abc' (pure Python module)."
    - "abc.abstractclassmethod, abc.abstractstaticmethod, abc.abstractproperty are deprecated but still present; all report __module__ as 'abc'."
    - "abc.get_cache_token reports __module__ as '_abc' (C extension backing function)."
    - "All __qualname__ values match simple class/function names — no nesting."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2296.core_module:
  description: "abc.ABC, abc.ABCMeta, abc.abstractmethod __module__ and __qualname__"
  kind: python_call_eq
  category: module_identity
  id_prefix: ab2296

  columns: [id, function, args, expected]
  rows:
    - ["ab2296001", "abc.ABC.__module__", [], "abc"]
    - ["ab2296002", "abc.ABC.__qualname__", [], "ABC"]
    - ["ab2296003", "abc.ABCMeta.__module__", [], "abc"]
    - ["ab2296004", "abc.ABCMeta.__qualname__", [], "ABCMeta"]
    - ["ab2296005", "abc.abstractmethod.__module__", [], "abc"]
    - ["ab2296006", "abc.abstractmethod.__qualname__", [], "abstractmethod"]

table abc_extra2296.deprecated_module:
  description: "Deprecated abc classes __module__ and __qualname__ — still present in Python 3.14"
  kind: python_call_eq
  category: module_identity
  id_prefix: ab2296

  columns: [id, function, args, expected]
  rows:
    - ["ab2296007", "abc.abstractclassmethod.__module__", [], "abc"]
    - ["ab2296008", "abc.abstractclassmethod.__qualname__", [], "abstractclassmethod"]
    - ["ab2296009", "abc.abstractstaticmethod.__module__", [], "abc"]
    - ["ab2296010", "abc.abstractstaticmethod.__qualname__", [], "abstractstaticmethod"]
    - ["ab2296011", "abc.abstractproperty.__module__", [], "abc"]
    - ["ab2296012", "abc.abstractproperty.__qualname__", [], "abstractproperty"]

table abc_extra2296.name_checks:
  description: "abc class __name__ values match expected simple names"
  kind: python_call_eq
  category: module_identity
  id_prefix: ab2296

  columns: [id, function, args, expected]
  rows:
    - ["ab2296013", "abc.ABC.__name__", [], "ABC"]
    - ["ab2296014", "abc.ABCMeta.__name__", [], "ABCMeta"]
    - ["ab2296015", "abc.abstractmethod.__name__", [], "abstractmethod"]
    - ["ab2296016", "abc.abstractclassmethod.__name__", [], "abstractclassmethod"]
    - ["ab2296017", "abc.abstractstaticmethod.__name__", [], "abstractstaticmethod"]
    - ["ab2296018", "abc.abstractproperty.__name__", [], "abstractproperty"]

table abc_extra2296.get_cache_token_module:
  description: "abc.get_cache_token __module__ is '_abc' — backed by C extension"
  kind: python_call_eq
  category: module_identity
  id_prefix: ab2296

  columns: [id, function, args, expected]
  rows:
    - ["ab2296019", "abc.get_cache_token.__module__", [], "_abc"]
    - ["ab2296020", "abc.get_cache_token.__qualname__", [], "get_cache_token"]
