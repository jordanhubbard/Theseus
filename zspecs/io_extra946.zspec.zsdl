spec: io_extra946
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io module constants, open/open_code callables, and stream class name identities"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra946.constants_identity:
  description: "io module constant class identity"
  kind: python_call_eq
  category: constants_identity
  id_prefix: io946x
  columns: [id, function, args, expected]
  rows:
    - [io946x001, io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"],  true]
    - [io946x002, io.DEFAULT_BUFFER_SIZE.__class__.__eq__,          ["int"],  false]

table io_extra946.open_callable_identity:
  description: "io.open and io.open_code callable attribute identity"
  kind: python_call_eq
  category: callable_identity
  id_prefix: io946o
  columns: [id, function, args, expected]
  rows:
    - [io946o001, io.open.__module__.__eq__,      ["io"],          true]
    - [io946o002, io.open.__qualname__.__eq__,    ["open"],        true]
    - [io946o003, io.open_code.__module__.__eq__, ["io"],          true]
    - [io946o004, io.open.__name__.__eq__,        ["open"],        true]
    - [io946o005, io.open_code.__name__.__eq__,   ["open_code"],   true]

table io_extra946.stream_class_names:
  description: "io stream class __name__ identity"
  kind: python_call_eq
  category: class_names
  id_prefix: io946s
  columns: [id, function, args, expected]
  rows:
    - [io946s001, io.FileIO.__name__.__eq__,          ["FileIO"],          true]
    - [io946s002, io.BytesIO.__name__.__eq__,          ["BytesIO"],         true]
    - [io946s003, io.StringIO.__name__.__eq__,         ["StringIO"],        true]
    - [io946s004, io.BufferedReader.__name__.__eq__,   ["BufferedReader"],  true]
    - [io946s005, io.BufferedWriter.__name__.__eq__,   ["BufferedWriter"],  true]
    - [io946s006, io.TextIOWrapper.__name__.__eq__,    ["TextIOWrapper"],   true]
    - [io946s007, io.FileIO.__module__.__eq__,         ["io"],              true]
    - [io946s008, io.BytesIO.__module__.__eq__,        ["io"],              true]
    - [io946s009, io.StringIO.__module__.__eq__,       ["io"],              true]
    - [io946s010, io.BufferedReader.__module__.__eq__, ["io"],              true]
