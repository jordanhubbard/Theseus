spec: configparser_rust
version: ">=3.9"
backend: rust_module(configparser_rust)

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — Python configparser documentation"
  not_derived_from:
    - "CPython source: Lib/configparser.py"
  notes:
    - "Clean-room Rust reimplementation of Python configparser module, exposed via PyO3."
    - "ConfigParser() creates a new empty parser with no sections."
    - "ConfigParser().sections() == [] — no sections initially."
    - "ConfigParser().has_section('foo') == False — no sections present."
    - "ConfigParser().defaults() == {} — no defaults initially."
    - "ConfigParser().options(section) raises NoSectionError for non-existent section."
    - "DEFAULTSECT == 'DEFAULT' — the default section name constant."
    - "MAX_INTERPOLATION_DEPTH == 10 — the maximum interpolation recursion depth."
    - "read_string(s) parses an INI-format string into the parser."
    - "After read_string('[s1]\\nkey = val\\n'), sections() == ['s1']."
    - "After read_string, get('s1', 'key') == 'val'."
    - "All test vectors verified against Python 3.14.3 configparser module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# Module-level constants
table configparser_rust.constants:
  kind: python_call_eq
  category: constants
  id_prefix: const

  columns: [id, function, args, expected]
  rows:
    - [DEFAULTSECT,              DEFAULTSECT.__eq__,              ["DEFAULT"], true]
    - [MAX_INTERPOLATION_DEPTH,  MAX_INTERPOLATION_DEPTH.__eq__,  [10],        true]

# Empty ConfigParser — no sections
invariant configparser_rust.ConfigParser.empty_sections:
  description: "ConfigParser().sections() == []"
  category: ConfigParser
  kind: python_call_eq
  function: ConfigParser
  args: []
  method: sections
  method_args: []
  expected: []

invariant configparser_rust.ConfigParser.no_section:
  description: "ConfigParser().has_section('foo') == False"
  category: ConfigParser
  kind: python_call_eq
  function: ConfigParser
  args: []
  method: has_section
  method_args: ["foo"]
  expected: false

invariant configparser_rust.ConfigParser.empty_defaults:
  description: "ConfigParser().defaults() == {}"
  category: ConfigParser
  kind: python_call_eq
  function: ConfigParser
  args: []
  method: defaults
  method_args: []
  expected: {}

