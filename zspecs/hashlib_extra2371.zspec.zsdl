spec: hashlib_extra2371
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2371 (_extra2371): __class__.__name__ of module-level objects."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.blake2b and hashlib.blake2s are C-level type objects exposed directly."
    - "hashlib.md5, sha1, sha256, sha512, pbkdf2_hmac, scrypt are builtin_function_or_method (OpenSSL-backed C functions)."
    - "hashlib.new is a plain Python function (Lib/hashlib.py)."
    - "hashlib.algorithms_guaranteed and hashlib.algorithms_available are plain Python sets."
    - "hashlib.scrypt is available on OpenSSL-backed builds (macOS, Linux); verified present on Darwin 25.4.0."
  created_at: "2026-04-12"

table hashlib_extra2371.object_types:
  description: "hashlib module-level object type classification via __class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl2371
  columns: [id, function, args, expected]
  rows:
    - ["hl2371001", "hashlib.blake2b.__class__.__name__", [], "type"]
    - ["hl2371002", "hashlib.blake2s.__class__.__name__", [], "type"]
    - ["hl2371003", "hashlib.md5.__class__.__name__", [], "builtin_function_or_method"]
    - ["hl2371004", "hashlib.sha256.__class__.__name__", [], "builtin_function_or_method"]
    - ["hl2371005", "hashlib.sha512.__class__.__name__", [], "builtin_function_or_method"]
    - ["hl2371006", "hashlib.sha1.__class__.__name__", [], "builtin_function_or_method"]
    - ["hl2371007", "hashlib.new.__class__.__name__", [], "function"]
    - ["hl2371008", "hashlib.algorithms_guaranteed.__class__.__name__", [], "set"]
    - ["hl2371009", "hashlib.algorithms_available.__class__.__name__", [], "set"]
    - ["hl2371010", "hashlib.pbkdf2_hmac.__class__.__name__", [], "builtin_function_or_method"]
    - ["hl2371011", "hashlib.scrypt.__class__.__name__", [], "builtin_function_or_method"]

table hashlib_extra2371.class_types:
  description: "hashlib type-class objects: __class__.__name__ == 'type' confirms they are proper Python types"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl2371
  columns: [id, function, args, expected]
  rows:
    - ["hl2371012", "hashlib.blake2b.__class__.__name__.__eq__", ["type"], true]
    - ["hl2371013", "hashlib.blake2s.__class__.__name__.__eq__", ["type"], true]

