spec: re_extra161
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module-level function __code__.co_argcount values for compile, match, search, sub, split."
    - "re.compile.__code__.co_argcount == 2 (parameters: pattern, flags)."
    - "re.match.__code__.co_argcount == 3 (parameters: pattern, string, flags)."
    - "re.search.__code__.co_argcount == 3 (parameters: pattern, string, flags)."
    - "re.sub.__code__.co_argcount == 3 (parameters: pattern, repl, string; then count/flags are additional)."
    - "re.split.__code__.co_argcount == 2 (parameters: pattern, string; then maxsplit/flags are additional)."
    - "The co_argcount attribute counts only positional and positional-or-keyword parameters — it does NOT count *args or keyword-only arguments."
    - "Key pattern: compile and split both have co_argcount==2; match, search, and sub all have co_argcount==3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level function co_argcount values (group 1: compile, split)
# compile and split both have co_argcount==2.
# compile(pattern, flags); split(pattern, string, ...).
# The two-function tie at co_argcount=2 is the key pattern in this group.
# ---------------------------------------------------------------------------

table re_extra161.module_func_co_argcount_group1:
  description: "re module-level function co_argcount: compile=2 (pattern, flags), split=2 (pattern, string); compile and split are the only two-argument functions among the five"
  kind: python_call_eq
  category: identity
  id_prefix: recoargc161

  columns: [id, function, args, expected, description]
  rows:
    - [compile_argc,  re.compile.__code__.co_argcount.__eq__,  [2],  true, "re.compile.__code__.co_argcount == 2 — compile() takes 2 positional-or-keyword parameters: 'pattern' and 'flags'; co_argcount counts only positional and positional-or-keyword parameters (not *args or keyword-only); compile() differs from match/search/sub in that it takes no 'string' argument — it only compiles the pattern into a Pattern object; re.compile(pattern, flags=0) returns a Pattern; co_argcount=2 is the minimum for a useful re module function — one for the pattern and one for flags"]
    - [split_argc,    re.split.__code__.co_argcount.__eq__,    [2],  true, "re.split.__code__.co_argcount == 2 — split() has 2 counted positional-or-keyword parameters: 'pattern' and 'string'; additional parameters maxsplit and flags are present but not counted in co_argcount because they are captured via *args at the Python level in re's wrapper; re.split() splits the string at each non-overlapping match of pattern; the tie at co_argcount=2 with compile() reflects that both compile and split have fewer 'primary' positional params than match, search, and sub (co_argcount=3)"]
    - [compile_argc_val, re.compile.__code__.co_argcount.__eq__,  [2],  true, "re.compile.__code__.co_argcount == 2 (second check: verifying the equality holds; co_varnames[:2] for compile are ('pattern', 'flags') — these two parameters define the minimal re function signature: a pattern to compile and an optional flags bitmask; re.compile() is the core function of the re module, caching compiled patterns for reuse; functions with co_argcount=2 in the re module are compile() and split())"]
    - [split_argc_val,  re.split.__code__.co_argcount.__eq__,    [2],  true, "re.split.__code__.co_argcount == 2 (second check: verifying the equality holds; co_varnames[:2] for split are ('pattern', 'string') — the two core inputs that define what to split by and what to split; maxsplit and flags are not in co_argcount because they come through *args; re.split(pattern, string) returns a list of substrings; the pattern can contain capturing groups, in which case the captured text is included in the result list)"]

# ---------------------------------------------------------------------------
# re module-level function co_argcount values (group 2: match, search, sub)
# match, search, and sub all have co_argcount==3.
# match(pattern, string, flags); search(pattern, string, flags);
# sub(pattern, repl, string) — third param is 'repl', not 'flags' like match/search.
# ---------------------------------------------------------------------------

table re_extra161.module_func_co_argcount_group2:
  description: "re module-level function co_argcount: match=3 (pattern, string, flags), search=3 (pattern, string, flags), sub=3 (pattern, repl, string); match and search share the same 3 parameter names; sub's third parameter is 'repl' not 'flags'"
  kind: python_call_eq
  category: identity
  id_prefix: recoargc161

  columns: [id, function, args, expected, description]
  rows:
    - [match_argc,   re.match.__code__.co_argcount.__eq__,   [3],  true, "re.match.__code__.co_argcount == 3 — match() has 3 positional-or-keyword parameters: 'pattern', 'string', 'flags'; co_argcount=3 is the dominant count among re module-level functions (match, search, and sub all have 3); re.match() attempts to match pattern at the beginning of string; it is anchored to the start, equivalent to prepending '^' to the pattern; match()'s three parameters (pattern, string, flags) are identical in name to search()'s three parameters"]
    - [search_argc,  re.search.__code__.co_argcount.__eq__,  [3],  true, "re.search.__code__.co_argcount == 3 — search() has 3 positional-or-keyword parameters: 'pattern', 'string', 'flags'; re.search() scans through the string looking for the first position where the pattern produces a match; unlike match(), search() is not anchored to the start; search() and match() share identical co_argcount (3) and identical parameter names ('pattern', 'string', 'flags') — they differ only in whether the match is anchored at the start"]
    - [sub_argc,     re.sub.__code__.co_argcount.__eq__,     [3],  true, "re.sub.__code__.co_argcount == 3 — sub() has 3 positional-or-keyword parameters: 'pattern', 'repl', 'string'; note that sub()'s third parameter is 'repl' (replacement) rather than 'string' as in match() and search(); the 'string' is the THIRD argument to sub() vs the SECOND argument to match/search; this parameter order difference (pattern, repl, string for sub vs pattern, string, flags for match/search) reflects sub()'s need to specify a replacement before the target string; co_argcount=3 is shared with match and search"]
    - [match_argc_val, re.match.__code__.co_argcount.__eq__,  [3],  true, "re.match.__code__.co_argcount == 3 (second check: 3 is also the co_argcount for search and sub; the three-way tie at co_argcount=3 for match, search, sub reflects that all three functions need to name at least 3 core inputs; compile and split need only 2 named inputs; the re module's wrapper functions forward to the Pattern methods — re.match(p, s, f) calls re.compile(p, f).match(s); the co_argcount=3 group (match, search, sub) covers the most commonly used re module-level functions)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra161.compile_co_argcount_is_2:
  description: "re.compile.__code__.co_argcount == 2 — compile() takes 2 positional-or-keyword parameters (pattern, flags); co_argcount counts only non-*args, non-keyword-only parameters; compile() is the only re function in this spec that does not take a 'string' argument — it produces a Pattern object from the pattern; the two re functions with co_argcount=2 are compile and split; the three with co_argcount=3 are match, search, and sub; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant re_extra161.match_search_co_argcount_equal:
  description: "re.match.__code__.co_argcount == re.search.__code__.co_argcount == 3 — match() and search() are the two re functions with identical co_argcount (3) AND identical parameter names ('pattern', 'string', 'flags'); they differ only in whether the match is anchored; match() requires the pattern to match at the start of the string while search() scans the entire string; this identical signature is intentional — they are interchangeable in terms of calling convention; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.match.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra161.sub_co_argcount_is_3:
  description: "re.sub.__code__.co_argcount == 3 — sub()'s three positional-or-keyword parameters are 'pattern', 'repl', 'string'; this differs from match() and search() where the three params are 'pattern', 'string', 'flags'; sub()'s second parameter is 'repl' (the replacement), making sub()'s signature unique among the three co_argcount=3 functions; re.sub() replaces non-overlapping occurrences of the pattern; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.sub.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra161.split_co_argcount_is_2:
  description: "re.split.__code__.co_argcount == 2 — split() has 2 positional-or-keyword parameters ('pattern', 'string'); this ties with compile() at co_argcount=2; re.split() splits the string by occurrences of the pattern; additional parameters (maxsplit, flags) are not counted in co_argcount because they are passed through *args in the re wrapper; the two-function tie at co_argcount=2 (compile and split) vs the three-function tie at co_argcount=3 (match, search, sub) is the key structural fact about re module-level function signatures; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.split.__code__.co_argcount.__eq__
  args: [2]
  expected: true
