spec: fractions_extra3
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends prior fractions specs."
    - "Focus: Fraction arithmetic, comparison, and attribute access."
    - "Fraction(1, 3) + Fraction(1, 6) == Fraction(1, 2)."
    - "Fraction(3, 6) == Fraction(1, 2) — auto-reduces."
    - "Fraction(1, 2).numerator == 1; Fraction(1, 2).denominator == 2."
    - "Fraction(1, 2).__class__.__name__ == 'Fraction'."
    - "Fraction.__module__ == 'fractions'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

invariant fractions_extra3.Fraction.class_name:
  description: "fractions.Fraction.__name__ == 'Fraction'"
  category: class_names
  kind: python_call_eq
  function: Fraction.__name__.__eq__
  args: ["Fraction"]
  expected: true

invariant fractions_extra3.Fraction.module:
  description: "fractions.Fraction.__module__ == 'fractions'"
  category: module
  kind: python_call_eq
  function: Fraction.__module__.__eq__
  args: ["fractions"]
  expected: true

invariant fractions_extra3.Fraction.instance_class_name:
  description: "Fraction(1, 2).__class__.__name__ == 'Fraction'"
  category: class_names
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Fraction"]
  expected: true

invariant fractions_extra3.Fraction.numerator:
  description: "Fraction(1, 2).numerator == 1"
  category: attributes
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: numerator.__eq__
  method_args: [1]
  expected: true

invariant fractions_extra3.Fraction.denominator:
  description: "Fraction(1, 2).denominator == 2"
  category: attributes
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: denominator.__eq__
  method_args: [2]
  expected: true

invariant fractions_extra3.Fraction.auto_reduce_numerator:
  description: "Fraction(3, 6).numerator == 1 — auto-reduces to 1/2"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [3, 6]
  method: numerator.__eq__
  method_args: [1]
  expected: true

invariant fractions_extra3.Fraction.auto_reduce_denominator:
  description: "Fraction(3, 6).denominator == 2 — auto-reduces to 1/2"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [3, 6]
  method: denominator.__eq__
  method_args: [2]
  expected: true

invariant fractions_extra3.Fraction.from_string_half:
  description: "Fraction('1/2').numerator == 1"
  category: from_string
  kind: python_call_eq
  function: Fraction
  args: ["1/2"]
  method: numerator.__eq__
  method_args: [1]
  expected: true

invariant fractions_extra3.Fraction.from_string_denom:
  description: "Fraction('3/4').denominator == 4"
  category: from_string
  kind: python_call_eq
  function: Fraction
  args: ["3/4"]
  method: denominator.__eq__
  method_args: [4]
  expected: true

invariant fractions_extra3.Fraction.limit_denominator_name:
  description: "Fraction(1, 2).limit_denominator.__name__ == 'limit_denominator'"
  category: methods
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: limit_denominator.__func__.__name__.__eq__
  method_args: ["limit_denominator"]
  expected: true

invariant fractions_extra3.Fraction.base_class:
  description: "Fraction.__bases__[0].__name__ == 'Rational'"
  category: hierarchy
  kind: python_call_eq
  function: Fraction.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Rational"
