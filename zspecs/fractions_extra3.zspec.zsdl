spec: fractions_extra3
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and fractions_extra.zspec.zsdl, fractions_extra2.zspec.zsdl."
    - "Focus: Fraction class qualname and module; base class identity; behavioral instance attribute access."
    - "fractions.Fraction.__qualname__ == 'Fraction' — qualname at module level equals simple name."
    - "fractions.Fraction.__module__ == 'fractions' — Fraction is defined in the fractions module."
    - "fractions.Fraction.__bases__[0].__name__ == 'Rational' — Fraction inherits from numbers.Rational."
    - "fractions.Fraction(1, 3).__class__.__name__ == 'Fraction' — instance type check via method_chain."
    - "fractions.Fraction(1, 3).numerator == 1."
    - "fractions.Fraction(1, 3).denominator == 3."
    - "fractions.Fraction(2, 4).numerator == 1 — auto-reduces via GCD."
    - "fractions.Fraction(2, 4).denominator == 2 — auto-reduces via GCD."
    - "fractions.Fraction('3/5').numerator == 3 — construction from string."
    - "fractions.Fraction('3/5').denominator == 5 — construction from string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class metadata — __qualname__ and __module__
# ---------------------------------------------------------------------------

invariant fractions_extra3.Fraction.qualname:
  description: "fractions.Fraction.__qualname__ == 'Fraction'"
  category: class_metadata
  kind: python_call_eq
  function: Fraction.__qualname__.__eq__
  args: ["Fraction"]
  expected: true

invariant fractions_extra3.Fraction.module:
  description: "fractions.Fraction.__module__ == 'fractions'"
  category: class_metadata
  kind: python_call_eq
  function: Fraction.__module__.__eq__
  args: ["fractions"]
  expected: true

# ---------------------------------------------------------------------------
# Base class — Fraction inherits from numbers.Rational
# ---------------------------------------------------------------------------

invariant fractions_extra3.Fraction.base_class:
  description: "fractions.Fraction.__bases__[0].__name__ == 'Rational'"
  category: hierarchy
  kind: python_call_eq
  function: Fraction.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Rational"

# ---------------------------------------------------------------------------
# Fraction(1, 3) — instance class name and attributes
# ---------------------------------------------------------------------------

invariant fractions_extra3.Fraction_1_3.class_name:
  description: "fractions.Fraction(1, 3).__class__.__name__ == 'Fraction'"
  category: instance
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Fraction"]
  expected: true

invariant fractions_extra3.Fraction_1_3.numerator:
  description: "fractions.Fraction(1, 3).numerator == 1"
  category: instance
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: numerator.__eq__
  method_args: [1]
  expected: true

invariant fractions_extra3.Fraction_1_3.denominator:
  description: "fractions.Fraction(1, 3).denominator == 3"
  category: instance
  kind: python_call_eq
  function: Fraction
  args: [1, 3]
  method: denominator.__eq__
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# Fraction(2, 4) — auto-reduces to 1/2
# ---------------------------------------------------------------------------

invariant fractions_extra3.Fraction_2_4.numerator:
  description: "fractions.Fraction(2, 4).numerator == 1 — auto-reduces via GCD"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [2, 4]
  method: numerator.__eq__
  method_args: [1]
  expected: true

invariant fractions_extra3.Fraction_2_4.denominator:
  description: "fractions.Fraction(2, 4).denominator == 2 — auto-reduces via GCD"
  category: reduction
  kind: python_call_eq
  function: Fraction
  args: [2, 4]
  method: denominator.__eq__
  method_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# Fraction('3/5') — construction from string
# ---------------------------------------------------------------------------

invariant fractions_extra3.Fraction_from_string.numerator:
  description: "fractions.Fraction('3/5').numerator == 3"
  category: from_string
  kind: python_call_eq
  function: Fraction
  args: ["3/5"]
  method: numerator.__eq__
  method_args: [3]
  expected: true

invariant fractions_extra3.Fraction_from_string.denominator:
  description: "fractions.Fraction('3/5').denominator == 5"
  category: from_string
  kind: python_call_eq
  function: Fraction
  args: ["3/5"]
  method: denominator.__eq__
  method_args: [5]
  expected: true
