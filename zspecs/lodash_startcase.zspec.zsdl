spec: lodash_startcase
version: ">=4.0.0"
backend: node(lodash.startcase)

docs: https://lodash.com/docs/#startCase

provenance:
  derived_from:
    - "lodash.startcase README — https://www.npmjs.com/package/lodash.startcase"
    - "Test vectors verified with lodash.startcase@4.4.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.startcase exports the _.startCase function directly as module.exports."
    - "startCase(string) converts string to Start Case (each word capitalized)."
    - "Splits on whitespace, hyphens, underscores, and case transitions."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns Start Case string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_startcase.startcase:
  kind: node_module_call_eq
  function: ~
  category: startcase
  id_prefix: lsc

  columns: [id, args, expected]
  rows:
    - [spaces,    ["hello world"],  "Hello World"]
    - [camel,     ["fooBar"],       "Foo Bar"]
    - [snake,     ["foo_bar"],      "Foo Bar"]
    - [hyphen,    ["foo-bar"],      "Foo Bar"]
