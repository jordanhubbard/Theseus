spec: multiprocessing_extra1156
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing.__package__/__loader__ class name, multiprocessing.Process/__module__ identity (multiprocessing.process), multiprocessing.Queue/__module__ identity (multiprocessing.queues), multiprocessing.Pool/__module__ identity (multiprocessing.pool), multiprocessing.Lock/__module__ identity, multiprocessing.Manager/__module__ identity, multiprocessing.queues.Queue/JoinableQueue/SimpleQueue class method qualnames"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.__package__/__loader__ class name, multiprocessing.Process/__module__ (multiprocessing.process), multiprocessing.Queue/__module__ (multiprocessing.queues), multiprocessing.Pool/__module__ (multiprocessing.pool), multiprocessing.Lock/__module__, multiprocessing.Manager/__module__, multiprocessing.queues.Queue/JoinableQueue/SimpleQueue method qualnames — behaviors not covered by extra1126 or extra1141"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1156.package_loader_identity:
  description: "multiprocessing.__package__/__loader__ class name and top-level alias __module__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: mp1156pl
  columns: [id, function, args, expected]
  rows:
    - [mp1156pl001, multiprocessing.__package__.__class__.__name__.__eq__,   ["str"],               true]
    - [mp1156pl002, multiprocessing.__package__.__eq__,                       ["multiprocessing"],   true]
    - [mp1156pl003, multiprocessing.__loader__.__class__.__name__.__eq__,     ["SourceFileLoader"],  true]
    - [mp1156pl004, multiprocessing.__loader__.__name__.__eq__,               ["multiprocessing"],   true]
    - [mp1156pl005, multiprocessing.Process.__module__.__eq__,                ["multiprocessing.process"], true]
    - [mp1156pl006, multiprocessing.Queue.__module__.__eq__,                  ["multiprocessing.queues"],  true]
    - [mp1156pl007, multiprocessing.Pool.__module__.__eq__,                   ["multiprocessing.pool"],    true]
    - [mp1156pl008, multiprocessing.Lock.__module__.__eq__,                   ["multiprocessing"],         true]
    - [mp1156pl009, multiprocessing.Manager.__module__.__eq__,                ["multiprocessing"],         true]
    - [mp1156pl010, multiprocessing.Queue.__name__.__eq__,                    ["Queue"],                   true]
    - [mp1156pl011, multiprocessing.Queue.__qualname__.__eq__,                ["Queue"],                   true]
    - [mp1156pl012, multiprocessing.Queue.__class__.__name__.__eq__,          ["type"],                    true]

table multiprocessing_extra1156.process_class_identity:
  description: "multiprocessing.Process and multiprocessing.process.BaseProcess class module, qualname, name, and method qualname identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1156pc
  columns: [id, function, args, expected]
  rows:
    - [mp1156pc001, multiprocessing.Process.__qualname__.__eq__,               ["Process"],                     true]
    - [mp1156pc002, multiprocessing.Process.__name__.__eq__,                   ["Process"],                     true]
    - [mp1156pc003, multiprocessing.Process.__class__.__name__.__eq__,         ["type"],                        true]
    - [mp1156pc004, multiprocessing.Process.start.__qualname__.__eq__,         ["BaseProcess.start"],           true]
    - [mp1156pc005, multiprocessing.Process.start.__module__.__eq__,           ["multiprocessing.process"],     true]
    - [mp1156pc006, multiprocessing.Process.start.__name__.__eq__,             ["start"],                       true]
    - [mp1156pc007, multiprocessing.Process.join.__qualname__.__eq__,          ["BaseProcess.join"],            true]
    - [mp1156pc008, multiprocessing.Process.join.__name__.__eq__,              ["join"],                        true]
    - [mp1156pc009, multiprocessing.Process.terminate.__qualname__.__eq__,     ["BaseProcess.terminate"],       true]
    - [mp1156pc010, multiprocessing.Process.terminate.__name__.__eq__,         ["terminate"],                   true]
    - [mp1156pc011, multiprocessing.Process.run.__qualname__.__eq__,           ["BaseProcess.run"],             true]
    - [mp1156pc012, multiprocessing.Process.run.__name__.__eq__,               ["run"],                         true]
    - [mp1156pc013, multiprocessing.Process.is_alive.__qualname__.__eq__,      ["BaseProcess.is_alive"],        true]
    - [mp1156pc014, multiprocessing.Process.kill.__qualname__.__eq__,          ["BaseProcess.kill"],            true]

