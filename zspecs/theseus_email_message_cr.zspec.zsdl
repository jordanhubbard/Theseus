spec: theseus_email_message_cr
version: ">=3.0"
backend: python_cleanroom(theseus_email_message_cr)
blocks: email.message

docs: https://docs.python.org/3/library/email.message.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.message.html"
  not_derived_from:
    - "CPython source: Lib/email/message.py"
  notes:
    - "Clean-room email.message module. Do NOT import email.message."

error_model: python_exceptions

invariant theseus_email_message_cr.emailmsg2_create:
  description: "Message can be created and headers set"
  category: behavior
  kind: python_call_eq
  function: emailmsg2_create
  args: []
  expected: true

invariant theseus_email_message_cr.emailmsg2_payload:
  description: "Message payload can be set and retrieved"
  category: behavior
  kind: python_call_eq
  function: emailmsg2_payload
  args: []
  expected: true

invariant theseus_email_message_cr.emailmsg2_content_type:
  description: "get_content_type() returns content type string"
  category: behavior
  kind: python_call_eq
  function: emailmsg2_content_type
  args: []
  expected: true
