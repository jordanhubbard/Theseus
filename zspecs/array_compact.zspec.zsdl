spec: array_compact
version: ">=1.0.0"
backend: node(array-compact)

docs: https://www.npmjs.com/package/array-compact

provenance:
  derived_from:
    - "array-compact README — https://www.npmjs.com/package/array-compact"
    - "Test vectors verified with array-compact via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-compact source"
  notes:
    - "array-compact is an npm package. Install: npm install array-compact"
    - "Removes falsy values (null, undefined, false, 0, empty string) from an array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new array with falsy values removed."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_compact.compact:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: acomp

  columns: [id, args, expected]
  rows:
    - [mixed,   [[1, 0, 2, null, 3]],             [1, 2, 3]]
    - [falsy,   [[false, 1, 2, null]],             [1, 2]]
    - [empty,   [[]],                              []]
