spec: itertools_extra1711
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 561 (_extra1711): __init__ protocol dict-presence checks."
    - "All itertools types are C extension types that use __new__ for construction."
    - "NONE of them define __init__ in their own __dict__ — all results are False."
    - "They DO define __new__ in their __dict__ (confirmed by prior wave knowledge)."
    - "Cross-checks between __init__ and __new__ presence, and __init_subclass__ / __class_getitem__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __init__ dict-presence checks — all False for itertools C types
#
# Wave 561 theme: which itertools types define __init__ in their own __dict__.
#
# All itertools types are C extension types. They use __new__ (tp_new in C)
# for construction and do NOT expose a Python-level __init__ in their
# __dict__. Every check below returns False.
# ---------------------------------------------------------------------------

table itertools_extra1711.init_protocol:
  description: "itertools C types: __init__ NOT in own __dict__ (all False — C extension types use __new__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1711

  columns: [id, function, args, expected]
  rows:
    - ["it1711001", "itertools.chain.__dict__.__contains__", ["__init__"], false]
    - ["it1711002", "itertools.count.__dict__.__contains__", ["__init__"], false]
    - ["it1711003", "itertools.cycle.__dict__.__contains__", ["__init__"], false]
    - ["it1711004", "itertools.repeat.__dict__.__contains__", ["__init__"], false]
    - ["it1711005", "itertools.islice.__dict__.__contains__", ["__init__"], false]
    - ["it1711006", "itertools.product.__dict__.__contains__", ["__init__"], false]
    - ["it1711007", "itertools.permutations.__dict__.__contains__", ["__init__"], false]
    - ["it1711008", "itertools.combinations.__dict__.__contains__", ["__init__"], false]
    - ["it1711009", "itertools.accumulate.__dict__.__contains__", ["__init__"], false]
    - ["it1711010", "itertools.compress.__dict__.__contains__", ["__init__"], false]

# ---------------------------------------------------------------------------
# Table 2: __new__ dict-presence cross-checks — True for all itertools C types
#
# Wave 561 cross-check: C extension types that lack __init__ in their __dict__
# expose __new__ (tp_new) in their __dict__ instead.
# All itertools types are C extension types and define __new__ in their
# own __dict__.
# ---------------------------------------------------------------------------

table itertools_extra1711.new_protocol:
  description: "itertools C types: __new__ IS in own __dict__ (all True — C extension types define __new__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1711

  columns: [id, function, args, expected]
  rows:
    - ["it1711011", "itertools.chain.__dict__.__contains__", ["__new__"], true]
    - ["it1711012", "itertools.count.__dict__.__contains__", ["__new__"], true]
    - ["it1711013", "itertools.cycle.__dict__.__contains__", ["__new__"], true]
    - ["it1711014", "itertools.repeat.__dict__.__contains__", ["__new__"], true]
    - ["it1711015", "itertools.islice.__dict__.__contains__", ["__new__"], true]
    - ["it1711016", "itertools.product.__dict__.__contains__", ["__new__"], true]
    - ["it1711017", "itertools.permutations.__dict__.__contains__", ["__new__"], true]
    - ["it1711018", "itertools.combinations.__dict__.__contains__", ["__new__"], true]
    - ["it1711019", "itertools.accumulate.__dict__.__contains__", ["__new__"], true]
    - ["it1711020", "itertools.compress.__dict__.__contains__", ["__new__"], true]

# ---------------------------------------------------------------------------
# Table 3: related dunder protocol cross-checks
#
# Wave 561 extension: __init_subclass__ and __class_getitem__ are not expected
# in the own __dict__ of itertools C types. Neither attribute is overridden by
# any itertools type — they inherit from object.
# ---------------------------------------------------------------------------

table itertools_extra1711.related_dunder_protocol:
  description: "itertools C types: __init_subclass__ and __class_getitem__ not in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1711

  columns: [id, function, args, expected]
  rows:
    - ["it1711021", "itertools.chain.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it1711022", "itertools.count.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it1711023", "itertools.repeat.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it1711024", "itertools.product.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it1711025", "itertools.chain.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it1711026", "itertools.count.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it1711027", "itertools.repeat.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it1711028", "itertools.product.__dict__.__contains__", ["__class_getitem__"], false]
