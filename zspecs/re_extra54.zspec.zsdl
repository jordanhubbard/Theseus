spec: re_extra54
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra53.zspec.zsdl — covers re function __name__ equality and lengths for search/compile/sub/findall/fullmatch/match/split/subn/finditer."
    - "re_extra52.zspec.zsdl — covers __doc__.__class__.__name__/qualname for search/compile/sub/findall/fullmatch/match/split/subn/finditer/error/Pattern and module."
    - "re_extra51.zspec.zsdl — covers re RegexFlag member __class__.__module__.__eq__('re') for MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE."
    - "re_extra43.zspec.zsdl — covers search.__module__.__eq__('re') and findall.__module__.__eq__('re') as standalone invariants."
    - "re_extra41.zspec.zsdl — covers DOTALL/VERBOSE __class__.__module__.__eq__('re')."
    - "re_extra31.zspec.zsdl — covers split/findall/finditer/purge/escape __name__.__len__()."
    - "re_extra30.zspec.zsdl — covers compile/match/search/fullmatch/sub __name__.__len__()."
    - "re_extra29.zspec.zsdl — covers compile/__module__.__eq__('re') and match/__module__.__eq__('re')."
    - "re_extra28.zspec.zsdl — covers search/match/fullmatch/findall/finditer/subn/split __module__.__eq__('re')."
    - "re_extra27.zspec.zsdl — covers IGNORECASE/__class__/__module__/__eq__('re'); RegexFlag/__module__/__eq__('re'); compile/__module__/__eq__('re')."
    - "re_extra23.zspec.zsdl — covers compile/match/search/findall/sub/split/fullmatch/purge/escape/subn __module__.__eq__('re')."
    - "re_extra9.zspec.zsdl — covers Pattern/__module__.__eq__('re'); Match/__module__.__eq__('re'); error/__module__.__eq__('re')."
    - "re_extra6.zspec.zsdl — covers compile/match/search/findall/finditer/sub/subn/split __module__.__eq__('re')."
    - "re_extra4.zspec.zsdl — covers sub/subn/split/findall/finditer/match/search/fullmatch __module__.__eq__('re')."
  notes:
    - "This spec extends re_extra53.zspec.zsdl."
    - "Prior specs collectively covered: re.search/compile/sub/findall/fullmatch/match/split/subn/finditer __module__.__eq__('re') in many namespaces (re_extra4/re_extra6/re_extra23/re_extra28/re_extra29/re_extra43); re.error/__module__.__eq__('re') (re_extra9); re.Pattern/__module__/__eq__('re') (re_extra9/re_extra27/re_extra42); __name__.__len__() for compile/match/search/fullmatch/sub (re_extra30) and split/findall/finditer (re_extra31) and subn (re_extra53). NO prior re spec checks __module__.__len__() for any re function or for re.error as standalone invariants."
    - "This spec covers: re.search.__module__.__eq__('re') (namespace anchor in remod54; covered in re_extra4/re_extra6/re_extra23/re_extra28/re_extra43); re.compile.__module__.__eq__('re') (namespace anchor; covered in re_extra6/re_extra23/re_extra27/re_extra29); re.sub.__module__.__eq__('re') (namespace anchor; covered in re_extra4/re_extra6/re_extra23); re.findall.__module__.__eq__('re') (namespace anchor; covered in re_extra4/re_extra6/re_extra23/re_extra28/re_extra43); re.match.__module__.__eq__('re') (namespace anchor; covered in re_extra4/re_extra6/re_extra23/re_extra28/re_extra29); re.split.__module__.__eq__('re') (namespace anchor; covered in re_extra4/re_extra6/re_extra23/re_extra28); re.fullmatch.__module__.__eq__('re') (namespace anchor; covered in re_extra4/re_extra28); re.subn.__module__.__eq__('re') (namespace anchor; covered in re_extra4/re_extra6/re_extra23/re_extra28); re.finditer.__module__.__eq__('re') (namespace anchor; covered in re_extra4/re_extra6/re_extra28); re.error.__module__.__eq__('re') (namespace anchor; covered in re_extra9); re.search.__module__.__len__()==2 (NOVEL — no prior re spec checks __module__.__len__() for search; 're' has 2 characters; novel length anchor in remod54 namespace); re.compile.__module__.__len__()==2 (NOVEL — no prior re spec checks compile.__module__.__len__()); re.sub.__module__.__len__()==2 (NOVEL — no prior re spec checks sub.__module__.__len__()); re.error.__module__.__len__()==2 (NOVEL — no prior re spec checks error.__module__.__len__())."
    - "re.search.__module__ == 're'. The re module functions are defined in Lib/re/__init__.py. Their __module__ is 're'. Covered in many earlier namespaces. Namespace anchor in re_extra54. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.search.__module__.__len__() == 2. 're' has 2 characters. No prior re spec checks __module__.__len__() for any re public function as a standalone invariant. Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.compile.__module__.__len__() == 2. 're' has 2 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.sub.__module__.__len__() == 2. 're' has 2 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.error.__module__ == 're'. The error exception class is defined in the re module. re_extra9 covers this equality. Namespace anchor in re_extra54. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.error.__module__.__len__() == 2. 're' has 2 characters. No prior re spec checks error.__module__.__len__(). Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function __module__ equality (re_extra54 namespace anchors)
#
# Every public re module function and the re.error class have __module__
# equal to 're'. These equality values were established in many earlier
# namespaces (re_extra4/re_extra6/re_extra9/re_extra23/re_extra28/re_extra29/
# re_extra43). This table consolidates them as re_extra54 namespace anchors:
#
#   re.search.__module__    == 're'
#   re.compile.__module__   == 're'
#   re.sub.__module__       == 're'
#   re.findall.__module__   == 're'
#   re.match.__module__     == 're'
#   re.split.__module__     == 're'
#   re.fullmatch.__module__ == 're'
#   re.subn.__module__      == 're'
#   re.finditer.__module__  == 're'
#   re.error.__module__     == 're'
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra54.function_module_eq:
  description: "re module function __module__.__eq__('re') for search/compile/sub/findall/match/split/fullmatch/subn/finditer and re.error — all defined in the re module; earlier namespaces (re_extra4/6/9/23/28/29/43) cover these; consolidated re_extra54 namespace anchors; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: remod54eq

  columns: [id, function, args, expected]
  rows:
    - [search_module_eq,   search.__module__.__eq__,   ["re"], true]
    - [compile_module_eq,  compile.__module__.__eq__,  ["re"], true]
    - [sub_module_eq,      sub.__module__.__eq__,      ["re"], true]
    - [findall_module_eq,  findall.__module__.__eq__,  ["re"], true]
    - [match_module_eq,    match.__module__.__eq__,    ["re"], true]
    - [split_module_eq,    split.__module__.__eq__,    ["re"], true]
    - [fullmatch_module_eq, fullmatch.__module__.__eq__, ["re"], true]
    - [subn_module_eq,     subn.__module__.__eq__,     ["re"], true]
    - [finditer_module_eq, finditer.__module__.__eq__,  ["re"], true]
    - [error_module_eq,    error.__module__.__eq__,    ["re"], true]

# ---------------------------------------------------------------------------
# re module function __module__ lengths (novel — no prior re spec checks these)
#
# The __module__ attribute for all re public functions and re.error is 're'
# (2 characters). No prior re spec checks __module__.__len__() for any re
# public function as a standalone invariant.
#
#   re.search.__module__.__len__()  == 2   (NOVEL)
#   re.compile.__module__.__len__() == 2   (NOVEL)
#   re.sub.__module__.__len__()     == 2   (NOVEL)
#   re.error.__module__.__len__()   == 2   (NOVEL)
#
# All four length anchors are novel in the re_extra54 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra54.function_module_len:
  description: "re module function __module__.__len__() for search(2)/compile(2)/sub(2) and re.error(2) — 're' has 2 characters; no prior re spec checks __module__.__len__() for any re public function or re.error as standalone invariants; all four novel length anchors in remod54 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: string_length
  id_prefix: remod54len

  columns: [id, function, args, expected]
  rows:
    - [search_module_len,  search.__module__.__len__,  [], 2]
    - [compile_module_len, compile.__module__.__len__, [], 2]
    - [sub_module_len,     sub.__module__.__len__,     [], 2]
    - [error_module_len,   error.__module__.__len__,   [], 2]
