spec: fastest_levenshtein
version: ">=1.0.0"
backend: node(fastest-levenshtein)

docs: https://www.npmjs.com/package/fastest-levenshtein

provenance:
  derived_from:
    - "fastest-levenshtein README — https://www.npmjs.com/package/fastest-levenshtein"
    - "Test vectors verified with fastest-levenshtein via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "fastest-levenshtein source"
  notes:
    - "fastest-levenshtein is an npm package. Install: npm install fastest-levenshtein"
    - "distance(a, b) computes the Levenshtein edit distance between two strings."
    - "closest(str, arr) returns the string in arr with the smallest edit distance to str."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns edit distance (integer) or closest string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table fastest_levenshtein.distance:
  kind: node_module_call_eq
  function: distance
  category: distance
  id_prefix: fldist

  columns: [id, args, expected]
  rows:
    - [kitten_sitting, ["kitten", "sitting"], 3]
    - [empty_to_abc,   ["", "abc"],           3]
    - [identical,      ["abc", "abc"],        0]

table fastest_levenshtein.closest:
  kind: node_module_call_eq
  function: closest
  category: closest
  id_prefix: flcls

  columns: [id, args, expected]
  rows:
    - [basic, ["abc", ["abd", "xyz", "abcd"]], "abd"]
