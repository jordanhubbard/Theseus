spec: decimal_extra2611
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2596.zspec.zsdl — covers __get__/__set__/__delete__ dict-presence"
  notes:
    - "Wave 621 (decimal_extra2611) theme: __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks."
    - "None of the decimal classes define __init_subclass__, __subclasshook__, or __class_getitem__ in their own __dict__."
    - "decimal.Decimal is a C extension type implementing IEEE 754 decimal arithmetic; it does not support generic subscripting."
    - "decimal.Context is a rounding/precision configuration object; it is NOT a generic alias and does not override subclassing hooks."
    - "decimal.DecimalException and decimal.InvalidOperation are exception classes; none override __init_subclass__ or __subclasshook__."
    - "Unlike re.Pattern/re.Match (which gained __class_getitem__ in Python 3.9), decimal types were not updated with PEP 585 generic alias support."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __init_subclass__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2611.no_init_subclass_in_decimal_classes:
  description: "__init_subclass__ is absent from decimal.Decimal, decimal.Context, and decimal exception class __dict__s"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2611

  columns: [id, function, args, expected]
  rows:
    - ["dc2611001", "decimal.Decimal.__dict__.__contains__",          ["__init_subclass__"], false]
    - ["dc2611002", "decimal.Context.__dict__.__contains__",          ["__init_subclass__"], false]
    - ["dc2611003", "decimal.DecimalException.__dict__.__contains__", ["__init_subclass__"], false]
    - ["dc2611004", "decimal.InvalidOperation.__dict__.__contains__", ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# __subclasshook__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2611.no_subclasshook_in_decimal_classes:
  description: "__subclasshook__ is absent from decimal class __dict__s — decimal types do not customise ABC virtual subclass registration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2611

  columns: [id, function, args, expected]
  rows:
    - ["dc2611005", "decimal.Decimal.__dict__.__contains__",          ["__subclasshook__"], false]
    - ["dc2611006", "decimal.Context.__dict__.__contains__",          ["__subclasshook__"], false]
    - ["dc2611007", "decimal.DecimalException.__dict__.__contains__", ["__subclasshook__"], false]
    - ["dc2611008", "decimal.InvalidOperation.__dict__.__contains__", ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# __class_getitem__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2611.no_class_getitem_in_decimal_classes:
  description: "__class_getitem__ is absent from decimal class __dict__s — decimal types were not updated with PEP 585 generic alias support"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2611

  columns: [id, function, args, expected]
  rows:
    - ["dc2611009",  "decimal.Decimal.__dict__.__contains__",          ["__class_getitem__"], false]
    - ["dc2611010", "decimal.Context.__dict__.__contains__",          ["__class_getitem__"], false]
    - ["dc2611011", "decimal.DecimalException.__dict__.__contains__", ["__class_getitem__"], false]
    - ["dc2611012", "decimal.InvalidOperation.__dict__.__contains__", ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal HAS arithmetic operators but NOT subclassing protocol methods
# Confirms Decimal is a rich numeric type, not a subclassing customizer or generic alias
# ---------------------------------------------------------------------------

table decimal_extra2611.decimal_arithmetic_not_subclass_hooks:
  description: "decimal.Decimal defines __add__/__new__/real but NOT __init_subclass__/__subclasshook__/__class_getitem__; decimal.Context similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2611

  columns: [id, function, args, expected]
  rows:
    - ["dc2611013", "decimal.Decimal.__dict__.__contains__", ["__new__"],           true]
    - ["dc2611014", "decimal.Decimal.__dict__.__contains__", ["__add__"],           true]
    - ["dc2611015", "decimal.Decimal.__dict__.__contains__", ["real"],              true]
    - ["dc2611016", "decimal.Decimal.__dict__.__contains__", ["__init_subclass__"], false]
    - ["dc2611017", "decimal.Decimal.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["dc2611018", "decimal.Decimal.__dict__.__contains__", ["__class_getitem__"], false]
    - ["dc2611019", "decimal.Context.__dict__.__contains__", ["prec"],              true]
    - ["dc2611020", "decimal.Context.__dict__.__contains__", ["rounding"],          true]
    - ["dc2611021", "decimal.Context.__dict__.__contains__", ["__init_subclass__"], false]
    - ["dc2611022", "decimal.Context.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["dc2611023", "decimal.Context.__dict__.__contains__", ["__class_getitem__"], false]
