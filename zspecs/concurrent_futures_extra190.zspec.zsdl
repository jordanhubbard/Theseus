table concurrent_futures_extra190.cf_timeout_error_identity:
  description: "concurrent.futures.TimeoutError class identity checks in cfexceptions190 namespace â€” TimeoutError.__name__=='TimeoutError' (len=12: T(1)i(2)m(3)e(4)o(5)u(6)t(7)E(8)r(9)r(10)o(11)r(12); raised when a future does not complete within a given timeout); TimeoutError.__module__=='builtins' (len=8; since Python 3.11 concurrent.futures.TimeoutError IS the built-in TimeoutError, not a separate class); TimeoutError.__bases__[0].__name__=='OSError' (len=7; TimeoutError inherits from OSError in the built-in hierarchy); TimeoutError.__module__ (8) == len('builtins'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexceptions190

  columns: [id, function, args, expected, description]
  rows:
    - [te_name_eq,    concurrent.futures.TimeoutError.__name__.__eq__,    ["TimeoutError"],  true, "concurrent.futures.TimeoutError.__name__ == 'TimeoutError' (len=12; raised when future times out); verified Python 3.14.3"]
    - [te_name_len,   concurrent.futures.TimeoutError.__name__.__len__,   [],                12,   "concurrent.futures.TimeoutError.__name__.__len__() == 12 ('TimeoutError'=12: T=1+i=1+m=1+e=1+o=1+u=1+t=1+E=1+r=1+r=1+o=1+r=1=12); verified Python 3.14.3"]
    - [te_module_eq,  concurrent.futures.TimeoutError.__module__.__eq__,  ["builtins"],      true, "concurrent.futures.TimeoutError.__module__ == 'builtins' (len=8; is the built-in TimeoutError since Python 3.11); verified Python 3.14.3"]
    - [te_module_len, concurrent.futures.TimeoutError.__module__.__len__, [],                8,    "concurrent.futures.TimeoutError.__module__.__len__() == 8 ('builtins'=8: b=1+u=1+i=1+l=1+t=1+i=1+n=1+s=1=8); verified Python 3.14.3"]
    - ["te_base_eq",  "concurrent.futures.TimeoutError.__bases__[0].__name__.__eq__",        ["OSError"], true, "concurrent.futures.TimeoutError.__bases__[0].__name__ == 'OSError' (len=7; built-in timeout inherits from OSError); verified Python 3.14.3"]

