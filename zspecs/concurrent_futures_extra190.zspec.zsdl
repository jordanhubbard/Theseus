    - ["ce_base_eq",  "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__",                       ["Error"], true, "concurrent.futures.CancelledError.__bases__[0].__name__ == 'Error' (len=5; private Error base in concurrent.futures._base); verified Python 3.14.3"]

