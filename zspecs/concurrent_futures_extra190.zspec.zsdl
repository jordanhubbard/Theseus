  rows:
    - [be_name_eq,    concurrent.futures.BrokenExecutor.__name__.__eq__,    ["BrokenExecutor"],            true, "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor' (len=14; raised when executor is non-functional); verified Python 3.14.3"]
    - [be_name_len,   concurrent.futures.BrokenExecutor.__name__.__len__,   [],                            14,   "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 ('BrokenExecutor'=14: 'Broken'=6+'Executor'=8=14); verified Python 3.14.3"]
    - [be_module_eq,  concurrent.futures.BrokenExecutor.__module__.__eq__,  ["concurrent.futures._base"],  true, "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base' (len=24; same _base module as CancelledError); verified Python 3.14.3"]
    - [be_module_len, concurrent.futures.BrokenExecutor.__module__.__len__, [],                            24,   "concurrent.futures.BrokenExecutor.__module__.__len__() == 24 ('concurrent.futures._base'=24; BE.__module__==CE.__module__ both len 24); verified Python 3.14.3"]
    - ["be_base_eq",  "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__",                    ["RuntimeError"], true, "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' (len=12; inherits RuntimeError â€” executor cannot be recovered); verified Python 3.14.3"]

