table concurrent_futures_extra190.cf_broken_executor_identity:
  description: "concurrent.futures.BrokenExecutor class identity checks in cfexceptions190 namespace â€” BrokenExecutor.__name__=='BrokenExecutor' (len=14: 'Broken'=6+'Executor'=8=14; raised when an executor has become non-functional due to worker failure or crash); BrokenExecutor.__module__=='concurrent.futures._base' (len=24; defined alongside Future and Executor in the private _base submodule); BrokenExecutor.__bases__[0].__name__=='RuntimeError' (len=12; inherits from RuntimeError indicating an executor cannot be recovered); BrokenExecutor.__name__ (14) == CancelledError.__name__ (14) â€” same length despite different semantics; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexceptions190

