    - [ce_name_len,   concurrent.futures.CancelledError.__name__.__len__,   [],                               14,   "concurrent.futures.CancelledError.__name__.__len__() == 14 ('CancelledError'=14: 'Cancelled'=9+'Error'=5=14); verified Python 3.14.3"]
