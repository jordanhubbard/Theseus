    - "concurrent.futures.TimeoutError.__name__ == 'TimeoutError' (len=12: T(1)i(2)m(3)e(4)o(5)u(6)t(7)E(8)r(9)r(10)o(11)r(12))."
    - "concurrent.futures.TimeoutError.__module__ == 'builtins' (len=8) â€” since Python 3.11 concurrent.futures.TimeoutError is the built-in TimeoutError."
    - "concurrent.futures.TimeoutError.__bases__[0].__name__ == 'OSError' (len=7)."
    - "concurrent.futures.CancelledError.__name__ == 'CancelledError' (len=14: 'Cancelled'=9+'Error'=5=14)."
    - "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24)."
    - "concurrent.futures.CancelledError.__bases__[0].__name__ == 'Error' (len=5); the private Error base class in concurrent.futures._base."
    - "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor' (len=14: 'Broken'=6+'Executor'=8=14)."
    - "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base' (len=24)."
    - "Length ordering: OSError (7) < builtins (8) < Error (5) â€” note module lengths: builtins (8) < concurrent.futures._base (24)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

