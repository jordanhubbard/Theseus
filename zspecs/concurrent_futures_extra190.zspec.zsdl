invariant concurrent_futures_extra190.cf_TimeoutError_name_eq:
  description: "concurrent.futures.TimeoutError.__name__.__eq__('TimeoutError') returns True â€” concurrent.futures.TimeoutError.__name__=='TimeoutError' (len=12: T(1)i(2)m(3)e(4)o(5)u(6)t(7)E(8)r(9)r(10)o(11)r(12)); since Python 3.11, concurrent.futures.TimeoutError is the built-in TimeoutError â€” the separate exception class was removed and replaced with an alias to the built-in; TimeoutError is raised when a future passed to wait() or result() does not complete within the allotted time; TimeoutError.__name__ (12) == BrokenExecutor.__name__ (14)? No: TimeoutError (12) < BrokenExecutor (14) by 2; NEW in cfexceptions190: first standalone TimeoutError.__name__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant concurrent_futures_extra190.cf_TimeoutError_module_eq:
  description: "concurrent.futures.TimeoutError.__module__.__eq__('builtins') returns True â€” concurrent.futures.TimeoutError.__module__=='builtins' (len=8); since Python 3.11, concurrent.futures.TimeoutError was unified with the built-in TimeoutError (PEP 678 / bpo-29890); the module is 'builtins' confirming it is the exact same object as the built-in TimeoutError, not a subclass; TimeoutError.__module__ (8) << CancelledError.__module__ (24) â€” TimeoutError lives in builtins while CancelledError is defined in the private _base submodule; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra190.cf_TimeoutError_base_is_OSError:
  description: "concurrent.futures.TimeoutError.__bases__[0].__name__.__eq__('OSError') returns True â€” concurrent.futures.TimeoutError is the built-in TimeoutError which inherits from OSError (len=7: O(1)S(2)E(3)r(4)r(5)o(6)r(7)); the built-in TimeoutError hierarchy is: TimeoutError â†’ OSError â†’ Exception â†’ BaseException; this is distinct from CancelledError which inherits from concurrent.futures._base.Error; TimeoutError.__bases__[0].__name__=='OSError' (7) while BrokenExecutor.__bases__[0].__name__=='RuntimeError' (12); NEW in cfexceptions190: standalone TimeoutError base class invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.TimeoutError.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant concurrent_futures_extra190.cf_CancelledError_name_eq:
  description: "concurrent.futures.CancelledError.__name__.__eq__('CancelledError') returns True â€” concurrent.futures.CancelledError.__name__=='CancelledError' (len=14: 'Cancelled'=9+'Error'=5=14); CancelledError is raised when a future has been cancelled via Future.cancel(); unlike asyncio.CancelledError (which inherits from BaseException), concurrent.futures.CancelledError inherits from concurrent.futures._base.Error; CancelledError.__name__ (14) == BrokenExecutor.__name__ (14) â€” same length despite representing different failure modes; NEW in cfexceptions190: first standalone CancelledError.__name__ invariant in cfexceptions190 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.CancelledError.__name__.__eq__
  args: ["CancelledError"]
  expected: true

invariant concurrent_futures_extra190.cf_CancelledError_module_eq:
  description: "concurrent.futures.CancelledError.__module__.__eq__('concurrent.futures._base') returns True â€” CancelledError.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24); CancelledError is defined in the private _base module of concurrent.futures alongside Future, Executor, Error, and the wait functions; CancelledError.__module__ (24) == BrokenExecutor.__module__ (24) â€” both live in concurrent.futures._base; CancelledError.__module__ (24) >> TimeoutError.__module__ (8); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.CancelledError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra190.cf_CancelledError_base_is_Error:
  description: "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__('Error') returns True â€” CancelledError inherits from concurrent.futures._base.Error (len=5: E(1)r(2)r(3)o(4)r(5)); Error is a private exception base class in concurrent.futures._base that itself inherits from Exception; the hierarchy is: CancelledError â†’ Error â†’ Exception â†’ BaseException; CancelledError.__bases__[0].__name__=='Error' (5) is the shortest base name in this spec; compare BrokenExecutor base 'RuntimeError' (12); NEW in cfexceptions190: standalone CancelledError base class invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true

invariant concurrent_futures_extra190.cf_BrokenExecutor_name_eq:
  description: "concurrent.futures.BrokenExecutor.__name__.__eq__('BrokenExecutor') returns True â€” BrokenExecutor.__name__=='BrokenExecutor' (len=14: 'Broken'=6+'Executor'=8=14); BrokenExecutor is raised when an executor's worker processes or threads have terminated abnormally, making the executor permanently non-functional; subclasses include BrokenThreadPool and BrokenProcessPool; BrokenExecutor.__name__ (14) == CancelledError.__name__ (14) â€” identical lengths; BrokenExecutor.__name__ (14) > TimeoutError.__name__ (12) by 2; NEW in cfexceptions190: first standalone BrokenExecutor.__name__ invariant in cfexceptions190 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra190.cf_BrokenExecutor_module_eq:
  description: "concurrent.futures.BrokenExecutor.__module__.__eq__('concurrent.futures._base') returns True â€” BrokenExecutor.__module__=='concurrent.futures._base' (len=24); BrokenExecutor is defined in the private _base submodule alongside CancelledError, Future, and Executor; BrokenExecutor.__module__ (24) == CancelledError.__module__ (24) â€” both exceptions are package-local to concurrent.futures._base; this contrasts with TimeoutError whose __module__=='builtins' (8) â€” TimeoutError was promoted to a built-in while BrokenExecutor remains package-local; NEW in cfexceptions190: standalone BrokenExecutor.__module__ invariant completing 8-invariant coverage for concurrent.futures exception identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.BrokenExecutor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true
