spec: struct_extra931
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__.__class__.__name__ for struct functions, classes, and exceptions"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra931.struct_pack_functions_doc_class:
  description: "struct pack/unpack function __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: st931p
  columns: [id, function, args, expected]
  rows:
    - [st931p001, struct.pack.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [st931p002, struct.unpack.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [st931p003, struct.pack_into.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st931p004, struct.unpack_from.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st931p005, struct.iter_unpack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st931p006, struct.calcsize.__doc__.__class__.__name__.__eq__,  ["str"], true]

table struct_extra931.struct_class_doc_class:
  description: "struct.Struct and struct.error __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: st931c
  columns: [id, function, args, expected]
  rows:
    - [st931c001, struct.Struct.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st931c002, struct.error.__doc__.__class__.__name__.__eq__,  ["str"], true]

table struct_extra931.struct_doc_nonempty:
  description: "struct __doc__ strings are non-empty"
  kind: python_call_eq
  category: doc_nonempty
  id_prefix: st931n
  columns: [id, function, args, expected]
  rows:
    - [st931n001, struct.pack.__doc__.__len__.__gt__,        [0], true]
    - [st931n002, struct.unpack.__doc__.__len__.__gt__,      [0], true]
    - [st931n003, struct.pack_into.__doc__.__len__.__gt__,   [0], true]
    - [st931n004, struct.unpack_from.__doc__.__len__.__gt__, [0], true]
    - [st931n005, struct.iter_unpack.__doc__.__len__.__gt__, [0], true]
    - [st931n006, struct.calcsize.__doc__.__len__.__gt__,    [0], true]
    - [st931n007, struct.Struct.__doc__.__len__.__gt__,      [0], true]
    - [st931n008, struct.error.__doc__.__len__.__gt__,       [0], true]
