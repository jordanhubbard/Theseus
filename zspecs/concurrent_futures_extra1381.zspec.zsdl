spec: concurrent_futures_extra1381
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures: Launching parallel tasks"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ frozenset checks and __isabstractmethod__ boolean checks."
    - "In Python 3.14, concurrent.futures classes do NOT use ABCMeta; none have __abstractmethods__ in their __dict__."
    - "concurrent.futures.Executor, Future, ThreadPoolExecutor, ProcessPoolExecutor all lack __abstractmethods__."
    - "Despite Executor having a conceptual abstract-like role, it is NOT implemented with ABCMeta in CPython."
    - "The metaclass of all public concurrent.futures classes is the built-in 'type', not 'ABCMeta'."
    - "concurrent.futures.BrokenExecutor, InvalidStateError, InterpreterPoolExecutor also lack __abstractmethods__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1381.executor_future_abstractmethods_absent:
  description: "concurrent.futures executor and future classes lack __abstractmethods__ in their __dict__"
  kind: python_call_eq
  category: abstractmethods_dict_check
  id_prefix: cf1381ef
  columns: [id, function, args, expected]
  rows:
    - [cf1381ef001, concurrent.futures.Executor.__dict__.__contains__,             ["__abstractmethods__"], false]
    - [cf1381ef002, concurrent.futures.Future.__dict__.__contains__,               ["__abstractmethods__"], false]
    - [cf1381ef003, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,   ["__abstractmethods__"], false]
    - [cf1381ef004, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,  ["__abstractmethods__"], false]
    - [cf1381ef005, concurrent.futures.BrokenExecutor.__dict__.__contains__,       ["__abstractmethods__"], false]
    - [cf1381ef006, concurrent.futures.InvalidStateError.__dict__.__contains__,    ["__abstractmethods__"], false]

table concurrent_futures_extra1381.classes_metaclass_is_type_not_abcmeta:
  description: "concurrent.futures classes have plain 'type' as metaclass, not 'ABCMeta'"
  kind: python_call_eq
  category: metaclass_check
  id_prefix: cf1381mc
  columns: [id, function, args, expected]
  rows:
    - [cf1381mc001, concurrent.futures.Executor.__class__.__name__.__eq__,             ["type"], true]
    - [cf1381mc002, concurrent.futures.Future.__class__.__name__.__eq__,               ["type"], true]
    - [cf1381mc003, concurrent.futures.ThreadPoolExecutor.__class__.__name__.__eq__,   ["type"], true]
    - [cf1381mc004, concurrent.futures.ProcessPoolExecutor.__class__.__name__.__eq__,  ["type"], true]
    - [cf1381mc005, concurrent.futures.BrokenExecutor.__class__.__name__.__eq__,       ["type"], true]
    - [cf1381mc006, concurrent.futures.InterpreterPoolExecutor.__class__.__name__.__eq__, ["type"], true]

table concurrent_futures_extra1381.interpreter_pool_abstractmethods_and_name:
  description: "concurrent.futures.InterpreterPoolExecutor and exception classes lack __abstractmethods__"
  kind: python_call_eq
  category: abstractmethods_dict_check
  id_prefix: cf1381ip
  columns: [id, function, args, expected]
  rows:
    - [cf1381ip001, concurrent.futures.InterpreterPoolExecutor.__dict__.__contains__, ["__abstractmethods__"], false]
    - [cf1381ip002, concurrent.futures.InterpreterPoolExecutor.__name__.__eq__,       ["InterpreterPoolExecutor"],  true]
    - [cf1381ip003, concurrent.futures.Executor.__name__.__eq__,                      ["Executor"],                 true]
    - [cf1381ip004, concurrent.futures.BrokenExecutor.__name__.__eq__,                ["BrokenExecutor"],           true]
    - [cf1381ip005, concurrent.futures.InvalidStateError.__name__.__eq__,             ["InvalidStateError"],        true]
    - [cf1381ip006, concurrent.futures.Future.__name__.__eq__,                        ["Future"],                   true]
