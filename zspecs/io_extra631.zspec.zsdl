spec: io_extra631
version: ">=3.9"
backend: python_module(io)
docs: "Behavioral spec for io.BufferedWriter method qualnames and io.TextIOWrapper properties"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — BufferedWriter, BufferedReader, TextIOWrapper, StringIO, BytesIO"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "TextIOWrapper properties verified as property descriptors via __class__.__name__"
    - "BufferedWriter/BufferedReader qualnames verified via __qualname__ attribute"
  created_at: "2026-04-12T00:00:00Z"

table io_extra631.buffered_writer_qualnames:
  description: "Qualname checks for io.BufferedWriter methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: io631bw
  columns: [id, function, args, expected]
  rows:
    - [io631bw001, io.BufferedWriter.__init__.__qualname__.__eq__, ["BufferedWriter.__init__"], true]
    - [io631bw002, io.BufferedWriter.write.__qualname__.__eq__, ["BufferedWriter.write"], true]
    - [io631bw003, io.BufferedWriter.flush.__qualname__.__eq__, ["BufferedWriter.flush"], true]
    - [io631bw004, io.BufferedWriter.seek.__qualname__.__eq__, ["BufferedWriter.seek"], true]
    - [io631bw005, io.BufferedWriter.tell.__qualname__.__eq__, ["BufferedWriter.tell"], true]

table io_extra631.buffered_reader_qualnames:
  description: "Qualname checks for io.BufferedReader methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: io631br
  columns: [id, function, args, expected]
  rows:
    - [io631br001, io.BufferedReader.__init__.__qualname__.__eq__, ["BufferedReader.__init__"], true]

table io_extra631.textiowrapper_qualnames:
  description: "Qualname checks for io.TextIOWrapper methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: io631tw
  columns: [id, function, args, expected]
  rows:
    - [io631tw001, io.TextIOWrapper.__init__.__qualname__.__eq__, ["TextIOWrapper.__init__"], true]

table io_extra631.textiowrapper_properties:
  description: "Property descriptor checks for io.TextIOWrapper attributes"
  kind: python_call_eq
  category: properties
  id_prefix: io631tp
  columns: [id, function, args, expected]
  rows:
    - [io631tp001, io.TextIOWrapper.line_buffering.__class__.__name__.__eq__, ["property"], true]
    - [io631tp002, io.TextIOWrapper.write_through.__class__.__name__.__eq__, ["property"], true]
    - [io631tp003, io.TextIOWrapper.errors.__class__.__name__.__eq__, ["property"], true]
    - [io631tp004, io.TextIOWrapper.newlines.__class__.__name__.__eq__, ["property"], true]

table io_extra631.stringio_bytesio_qualnames:
  description: "Qualname checks for io.StringIO and io.BytesIO methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: io631sb
  columns: [id, function, args, expected]
  rows:
    - [io631sb001, io.StringIO.getvalue.__qualname__.__eq__, ["StringIO.getvalue"], true]
    - [io631sb002, io.BytesIO.getvalue.__qualname__.__eq__, ["BytesIO.getvalue"], true]
    - [io631sb003, io.BytesIO.getbuffer.__qualname__.__eq__, ["BytesIO.getbuffer"], true]
