spec: babel_rust
version: ">=3.9"
backend: rust_module(babel_rust)

docs: https://babel.pocoo.org/

provenance:
  derived_from:
    - "https://babel.pocoo.org/ — Babel internationalization library"
  notes:
    - "Babel provides i18n and l10n support."
    - "babel.Locale('en', 'US').language == 'en'."
    - "babel.numbers.format_number(1234567, locale='en_US') == '1,234,567'."
    - "babel.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant babel_rust.locale_language:
  description: "Locale('en', 'US').language == 'en'"
  category: locale
  kind: python_call_eq
  function: babel_locale_language
  args: ["en", "US"]
  expected: "en"

invariant babel_rust.has_locale_class:
  description: "babel.Locale is a class"
  category: presence
  kind: python_call_eq
  function: babel_has_locale_class
  args: []
  expected: true

invariant babel_rust.version_nonempty:
  description: "babel.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: babel_version_nonempty
  args: []
  expected: true

