spec: functools_extra2011
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 581 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "functools classes are not arithmetic types — none define arithmetic operators."
    - "functools.partial: C extension type — __add__, __radd__, __iadd__, __mul__, __rmul__, __imul__, __sub__, __rsub__, __isub__ absent from __dict__."
    - "functools.partialmethod: Python class — same arithmetic dunders absent from __dict__."
    - "functools.cached_property: Python descriptor class — same arithmetic dunders absent from __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __add__ / __radd__ / __iadd__ dict-presence for functools types
#
# functools.partial, functools.partialmethod, functools.cached_property are
# not numeric types and do not define any addition operators in their __dict__.
# All checks expected False.
# ---------------------------------------------------------------------------

table functools_extra2011.add_protocol:
  description: "functools types __add__/__radd__/__iadd__ dict-presence checks — all False — wave 581 _extra2011"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2011

  columns: [id, function, args, expected]
  rows:
    - ["ft2011001", "functools.partial.__dict__.__contains__", ["__add__"], false]
    - ["ft2011002", "functools.partial.__dict__.__contains__", ["__radd__"], false]
    - ["ft2011003", "functools.partial.__dict__.__contains__", ["__iadd__"], false]
    - ["ft2011004", "functools.partialmethod.__dict__.__contains__", ["__add__"], false]
    - ["ft2011005", "functools.partialmethod.__dict__.__contains__", ["__radd__"], false]
    - ["ft2011006", "functools.partialmethod.__dict__.__contains__", ["__iadd__"], false]
    - ["ft2011007", "functools.cached_property.__dict__.__contains__", ["__add__"], false]
    - ["ft2011008", "functools.cached_property.__dict__.__contains__", ["__radd__"], false]
    - ["ft2011009", "functools.cached_property.__dict__.__contains__", ["__iadd__"], false]

