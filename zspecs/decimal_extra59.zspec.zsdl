spec: decimal_extra59
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra58.zspec.zsdl — covers decimal.__doc__.__class__.__name__.__eq__('str') and __len__()==2546; Decimal.__doc__.__contains__('Decimal') and __contains__('value'); ROUND_UP/ROUND_DOWN __class__.__name__.__eq__('str') and __contains__('ROUND')."
    - "decimal_extra57.zspec.zsdl — covers Decimal.__lt__/__le__/__gt__/__ge__/__eq__/__ne__ __qualname__.__eq__(); Decimal.__floordiv__/__mod__/__pow__/__pos__/__int__/__float__ __qualname__.__eq__(); Context.exp/ln/log10/divmod/remainder/normalize/power __qualname__.__eq__()."
    - "decimal_extra56.zspec.zsdl — covers decimal.__loader__/__spec__ class identity checks."
    - "decimal_extra55.zspec.zsdl — covers decimal.__loader__/__file__/__cached__ class identity."
    - "decimal_extra29.zspec.zsdl — covers Context method __qualname__.__len__() values."
  notes:
    - "This spec extends decimal_extra58.zspec.zsdl."
    - "Wave 229 theme: __defaults__ and __code__ checks for Python functions + __doc__ content checks for additional classes."
    - "Decimal and Context are C extension types — no __defaults__ or __code__ on their methods. The module-level functions getcontext, setcontext, and localcontext are also C built-in functions (type builtin_function_or_method) in the accelerated C implementation (_decimal) — they do NOT have __defaults__ or __code__ attributes. Focus on __doc__.__contains__ content anchors."
    - "decimal.__doc__.__contains__('arithmetic') — decimal module docstring begins 'Decimal fixed-point and floating-point arithmetic.' The word 'arithmetic' appears. No prior decimal spec checks decimal.__doc__.__contains__('arithmetic') in deccode59 namespace. Novel module __doc__ content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__doc__.__contains__('floating') — same docstring also contains 'floating' (in 'floating-point'). Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Context.__doc__.__contains__('rounding') — Context.__doc__ begins 'The context affects almost all operations and controls rounding,...'. The word 'rounding' appears. No prior decimal spec checks Context.__doc__.__contains__('rounding') in deccode59 namespace. Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Context.__doc__.__contains__('operations') — same docstring also contains 'operations' (in 'almost all operations'). Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Context.__doc__.__contains__('Context') — same docstring shows a constructor example: 'c = Context(prec=28, ...)'. The word 'Context' appears. Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal module __doc__.__contains__ content checks
#
# decimal.__doc__ begins:
#   'Decimal fixed-point and floating-point arithmetic.\n\nThis is an
#    implementation of decimal floating-point arithmetic based on ...'
#
# The words 'arithmetic' and 'floating' both appear.
#
# No prior decimal spec checks decimal.__doc__.__contains__('arithmetic') or
# __contains__('floating') in the deccode59 namespace. Novel module-level
# __doc__ content anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra59.module_doc_contains:
  description: "decimal.__doc__.__contains__('arithmetic') and __contains__('floating') — decimal module __doc__ begins 'Decimal fixed-point and floating-point arithmetic.'; 'arithmetic' and 'floating' both appear; no prior decimal spec checks decimal.__doc__.__contains__('arithmetic') or __contains__('floating') in deccode59 namespace; novel module-level __doc__ content anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_doc_content
  id_prefix: deccode59moddoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_arithmetic, decimal.__doc__.__contains__, ["arithmetic"], true]
    - [doc_contains_floating,   decimal.__doc__.__contains__, ["floating"],   true]

# ---------------------------------------------------------------------------
# Context.__doc__.__contains__ content checks
#
# Context.__doc__ begins:
#   'The context affects almost all operations and controls rounding,
#    Over/Underflow, raising of exceptions and much more.  A new context
#    can be constructed as follows:\n\n    >>> c = Context(prec=28, ...'
#
# Context is a C extension type. Its docstring contains:
#   - 'rounding' (in 'controls rounding')
#   - 'operations' (in 'almost all operations')
#   - 'Context' (in the constructor example 'c = Context(prec=28, ...)')
#
# No prior decimal spec checks Context.__doc__.__contains__('rounding'),
# __contains__('operations'), or __contains__('Context') in the deccode59
# namespace. Novel C extension class __doc__ content anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra59.context_doc_contains:
  description: "Context.__doc__.__contains__('rounding') and __contains__('operations') and __contains__('Context') — Context is a C extension; __doc__ begins 'The context affects almost all operations and controls rounding,...' and shows constructor 'c = Context(prec=28, ...)'; 'rounding', 'operations', and 'Context' all appear; no prior decimal spec checks Context.__doc__.__contains__('rounding') or __contains__('operations') or __contains__('Context') in deccode59 namespace; novel __doc__ content anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: deccode59ctxdoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_rounding,    Context.__doc__.__contains__, ["rounding"],    true]
    - [doc_contains_operations,  Context.__doc__.__contains__, ["operations"],  true]
    - [doc_contains_context,     Context.__doc__.__contains__, ["Context"],     true]

# ---------------------------------------------------------------------------
# Decimal.__doc__.__class__.__name__.__eq__('str') and Context.__doc__.__class__.__name__.__eq__('str')
#
# Both Decimal and Context are C extension types. Their __doc__ attributes
# are string objects. __doc__.__class__.__name__ is 'str' for both.
#
# No prior decimal spec checks Decimal.__doc__.__class__.__name__.__eq__('str') or
# Context.__doc__.__class__.__name__.__eq__('str') in the deccode59 namespace.
# Novel __doc__ class identity anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra59.type_doc_class:
  description: "Decimal.__doc__.__class__.__name__.__eq__('str') and Context.__doc__.__class__.__name__.__eq__('str') — both are C extension types; their __doc__ attributes are str objects; __class__.__name__ is 'str'; no prior decimal spec checks Decimal.__doc__.__class__.__name__.__eq__('str') or Context.__doc__.__class__.__name__.__eq__('str') in deccode59 namespace; novel __doc__ class identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_identity
  id_prefix: deccode59dokcls

  columns: [id, function, args, expected]
  rows:
    - [decimal_doc_class_eq, Decimal.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [context_doc_class_eq, Context.__doc__.__class__.__name__.__eq__, ["str"], true]

invariant decimal_extra59.module_doc_contains_arithmetic:
  description: "decimal.__doc__.__contains__('arithmetic') == True — decimal module __doc__ begins 'Decimal fixed-point and floating-point arithmetic.'; 'arithmetic' appears; no prior decimal spec checks decimal.__doc__.__contains__('arithmetic') in deccode59 namespace; novel module-level __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_doc_content
  kind: python_call_eq
  function: decimal.__doc__.__contains__
  args: ["arithmetic"]
  expected: true

invariant decimal_extra59.module_doc_contains_floating:
  description: "decimal.__doc__.__contains__('floating') == True — decimal module __doc__ begins 'Decimal fixed-point and floating-point arithmetic.'; 'floating' appears (in 'floating-point'); no prior decimal spec checks decimal.__doc__.__contains__('floating') in deccode59 namespace; novel module-level __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_doc_content
  kind: python_call_eq
  function: decimal.__doc__.__contains__
  args: ["floating"]
  expected: true

invariant decimal_extra59.context_doc_contains_rounding:
  description: "Context.__doc__.__contains__('rounding') == True — Context is a C extension; __doc__ begins 'The context affects almost all operations and controls rounding,...'; 'rounding' appears; no prior decimal spec checks Context.__doc__.__contains__('rounding') in deccode59 namespace; novel C extension __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: Context.__doc__.__contains__
  args: ["rounding"]
  expected: true

invariant decimal_extra59.context_doc_contains_operations:
  description: "Context.__doc__.__contains__('operations') == True — Context.__doc__ begins 'The context affects almost all operations and controls rounding,...'; 'operations' appears; no prior decimal spec checks Context.__doc__.__contains__('operations') in deccode59 namespace; novel C extension __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: Context.__doc__.__contains__
  args: ["operations"]
  expected: true

invariant decimal_extra59.context_doc_contains_context:
  description: "Context.__doc__.__contains__('Context') == True — Context.__doc__ shows constructor example 'c = Context(prec=28, ...)'; 'Context' appears; no prior decimal spec checks Context.__doc__.__contains__('Context') in deccode59 namespace; novel C extension __doc__ content anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: Context.__doc__.__contains__
  args: ["Context"]
  expected: true

invariant decimal_extra59.decimal_doc_class_str:
  description: "Decimal.__doc__.__class__.__name__.__eq__('str') == True — Decimal is a C extension type; __doc__ is a str object; __class__.__name__ is 'str'; no prior decimal spec checks Decimal.__doc__.__class__.__name__.__eq__('str') in deccode59 namespace; novel __doc__ class identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_identity
  kind: python_call_eq
  function: Decimal.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra59.context_doc_class_str:
  description: "Context.__doc__.__class__.__name__.__eq__('str') == True — Context is a C extension type; __doc__ is a str object; __class__.__name__ is 'str'; no prior decimal spec checks Context.__doc__.__class__.__name__.__eq__('str') in deccode59 namespace; novel __doc__ class identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_identity
  kind: python_call_eq
  function: Context.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
