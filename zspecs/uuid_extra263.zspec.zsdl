spec: uuid_extra263
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra262.zspec.zsdl — covers uuid module __spec__/__loader__ identity and UUID.__slots__/__hash__ identity."
    - "uuid_extra261.zspec.zsdl — covers uuid module constants and SafeUUID enum identity."
  notes:
    - "uuid.UUID.__init__.__class__.__name__ == 'function' — UUID.__init__ is a pure-Python method. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__slots__.__class__.__name__ == 'tuple' — UUID.__slots__ is a tuple of slot names. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "len(uuid.UUID.__slots__) == 3 — UUID defines exactly 3 slots. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' — qualified name reflects class nesting. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__le__.__qualname__ == 'UUID.__le__' — qualified name reflects class nesting. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__' — qualified name reflects class nesting. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__' — qualified name reflects class nesting. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID(int=0) produces '00000000-0000-0000-0000-000000000000' — all-zero UUID from int=0. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID __slots__ and __init__ identity
# UUID defines 3 slots: ('int', 'is_safe', '__weakref__').
# UUID.__init__ is a pure-Python function (class 'function').
# ---------------------------------------------------------------------------

table uuid_extra263.UUID_slots_init_identity:
  description: "uuid.UUID __slots__ and __init__ identity — __slots__ is a tuple of length 3; __init__.__class__.__name__/'function'; comparison operators __lt__/__le__ have qualnames 'UUID.__lt__'/'UUID.__le__'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidslots263

  columns: [id, function, args, expected, description]
  rows:
    - [slots_type,     UUID.__slots__.__class__.__name__.__eq__,   ["tuple"],      true, "type(uuid.UUID.__slots__).__name__ == 'tuple' — UUID.__slots__ is a tuple of slot name strings"]
    - [slots_len,      UUID.__slots__.__len__,                     [],             3,    "len(uuid.UUID.__slots__) == 3 — UUID defines exactly 3 slots"]
    - [init_cls,       UUID.__init__.__class__.__name__.__eq__,    ["function"],   true, "uuid.UUID.__init__.__class__.__name__ == 'function' — UUID.__init__ is a pure-Python method"]
    - [lt_qualname,    UUID.__lt__.__qualname__.__eq__,            ["UUID.__lt__"], true, "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' — qualified name reflects class nesting"]
    - [le_qualname,    UUID.__le__.__qualname__.__eq__,            ["UUID.__le__"], true, "uuid.UUID.__le__.__qualname__ == 'UUID.__le__' — qualified name reflects class nesting"]

# ---------------------------------------------------------------------------
# uuid.UUID comparison operator qualnames — __gt__ and __ge__
# UUID defines all four rich comparison operators as pure-Python methods.
# Each qualname follows the pattern 'UUID.<op>'.
# ---------------------------------------------------------------------------

table uuid_extra263.UUID_comparison_op_identity:
  description: "uuid.UUID comparison operator identity — __gt__/__qualname__/'UUID.__gt__'; __ge__/__qualname__/'UUID.__ge__'; __lt__/__class__.__name__/'function'; __gt__/__class__.__name__/'function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidcmp263

  columns: [id, function, args, expected, description]
  rows:
    - [gt_qualname,  UUID.__gt__.__qualname__.__eq__,           ["UUID.__gt__"], true, "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__' — qualified name reflects class nesting"]
    - [ge_qualname,  UUID.__ge__.__qualname__.__eq__,           ["UUID.__ge__"], true, "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__' — qualified name reflects class nesting"]
    - [lt_cls,       UUID.__lt__.__class__.__name__.__eq__,     ["function"],    true, "uuid.UUID.__lt__.__class__.__name__ == 'function' — __lt__ is a pure-Python method"]
    - [gt_cls,       UUID.__gt__.__class__.__name__.__eq__,     ["function"],    true, "uuid.UUID.__gt__.__class__.__name__ == 'function' — __gt__ is a pure-Python method"]
    - [ge_cls,       UUID.__ge__.__class__.__name__.__eq__,     ["function"],    true, "uuid.UUID.__ge__.__class__.__name__ == 'function' — __ge__ is a pure-Python method"]

# ---------------------------------------------------------------------------
# Standalone invariants — UUID slots, comparison operators, error case
# ---------------------------------------------------------------------------

invariant uuid_extra263.UUID_slots_type_eq:
  description: "type(uuid.UUID.__slots__).__name__ == 'tuple' — UUID.__slots__ is a tuple of slot name strings defined in Lib/uuid.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__slots__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant uuid_extra263.UUID_slots_len_eq:
  description: "len(uuid.UUID.__slots__) == 3 — UUID defines exactly 3 slots in Lib/uuid.py: 'int', 'is_safe', '__weakref__'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__slots__.__len__
  args: []
  expected: 3

invariant uuid_extra263.UUID_init_class_eq:
  description: "uuid.UUID.__init__.__class__.__name__ == 'function' — UUID.__init__ is a pure-Python method defined in Lib/uuid.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant uuid_extra263.UUID_lt_qualname_eq:
  description: "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__' — qualified name of a comparison method on a top-level class is ClassName.method_name; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__lt__.__qualname__.__eq__
  args: ["UUID.__lt__"]
  expected: true

invariant uuid_extra263.UUID_le_qualname_eq:
  description: "uuid.UUID.__le__.__qualname__ == 'UUID.__le__' — qualified name of the less-than-or-equal comparison method; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__le__.__qualname__.__eq__
  args: ["UUID.__le__"]
  expected: true

invariant uuid_extra263.UUID_gt_qualname_eq:
  description: "uuid.UUID.__gt__.__qualname__ == 'UUID.__gt__' — qualified name of the greater-than comparison method; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__gt__.__qualname__.__eq__
  args: ["UUID.__gt__"]
  expected: true

invariant uuid_extra263.UUID_ge_qualname_eq:
  description: "uuid.UUID.__ge__.__qualname__ == 'UUID.__ge__' — qualified name of the greater-than-or-equal comparison method; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__ge__.__qualname__.__eq__
  args: ["UUID.__ge__"]
  expected: true

invariant uuid_extra263.UUID_invalid_string_raises:
  description: "uuid.UUID('not-a-uuid') raises ValueError — invalid UUID string is rejected immediately with ValueError; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: UUID
  args: ["not-a-uuid"]
  raises: ValueError

invariant uuid_extra263.UUID_slots_class_name_eq:
  description: "uuid.UUID.__slots__.__class__.__name__ == 'tuple' — the __slots__ attribute is a plain Python tuple; confirmed by checking its class name; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: UUID.__slots__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
