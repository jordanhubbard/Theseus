spec: string
version: ">=3.0"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified by running Python 3.14.3 string module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "Module-level constants (ascii_lowercase, ascii_uppercase, etc.) are tested via __len__ and __contains__ to avoid hard-coding the full strings."
    - "ascii_letters is the concatenation of ascii_lowercase + ascii_uppercase, giving 52 characters."
    - "hexdigits includes lowercase a-f and uppercase A-F, giving 22 characters (10 digits + 12 letters)."
    - "whitespace includes space, tab, newline, carriage return, vertical tab, and form feed — 6 characters."
    - "printable is digits + ascii_letters + punctuation + whitespace = 100 characters."
    - "capwords(s) splits on whitespace, capitalizes each word, and rejoins with a single space. Leading/trailing whitespace is stripped."
    - "Template substitution is not tested here as Template instances are not JSON-serializable."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module constants — lengths
#
# Each constant is a module-level string. __len__ counts its characters.
# ---------------------------------------------------------------------------

table string.constants.lengths:
  kind: python_call_eq
  category: constants
  id_prefix: const_len

  columns: [id, function, args, expected]
  rows:
    - [ascii_lowercase_len,  ascii_lowercase.__len__,  [], 26]
    - [ascii_uppercase_len,  ascii_uppercase.__len__,  [], 26]
    - [ascii_letters_len,    ascii_letters.__len__,    [], 52]
    - [digits_len,           digits.__len__,           [], 10]
    - [hexdigits_len,        hexdigits.__len__,        [], 22]
    - [octdigits_len,        octdigits.__len__,        [], 8]
    - [punctuation_len,      punctuation.__len__,      [], 32]
    - [whitespace_len,       whitespace.__len__,       [], 6]
    - [printable_len,        printable.__len__,        [], 100]

# ---------------------------------------------------------------------------
# Module constants — membership tests via __contains__
# ---------------------------------------------------------------------------

table string.constants.contains:
  kind: python_call_eq
  category: constants
  id_prefix: const_contains

  columns: [id, function, args, expected]
  rows:
    - [lowercase_has_a,         ascii_lowercase.__contains__,  ["a"],  true]
    - [lowercase_not_A,         ascii_lowercase.__contains__,  ["A"],  false]
    - [uppercase_has_A,         ascii_uppercase.__contains__,  ["A"],  true]
    - [uppercase_not_a,         ascii_uppercase.__contains__,  ["a"],  false]
    - [digits_has_0,            digits.__contains__,           ["0"],  true]
    - [digits_has_9,            digits.__contains__,           ["9"],  true]
    - [hexdigits_has_a,         hexdigits.__contains__,        ["a"],  true]
    - [hexdigits_has_F,         hexdigits.__contains__,        ["F"],  true]
    - [hexdigits_not_g,         hexdigits.__contains__,        ["g"],  false]
    - [octdigits_has_7,         octdigits.__contains__,        ["7"],  true]
    - [octdigits_not_8,         octdigits.__contains__,        ["8"],  false]

# ---------------------------------------------------------------------------
# string.capwords — capitalize each word, collapse whitespace
# ---------------------------------------------------------------------------

table string.capwords.basic:
  kind: python_call_eq
  category: capwords
  id_prefix: capwords
  function: capwords

  columns: [id, args, expected]
  rows:
    - [simple,         ["hello world"],        "Hello World"]
    - [already_upper,  ["HELLO WORLD"],        "Hello World"]
    - [three_words,    ["one two three"],      "One Two Three"]
    - [extra_spaces,   ["  hello  world  "],   "Hello World"]
    - [single_word,    ["hello"],              "Hello"]
    - [mixed_case,     ["hElLo WoRlD"],        "Hello World"]

# ---------------------------------------------------------------------------
# string.capwords — with separator argument
# ---------------------------------------------------------------------------

table string.capwords.sep:
  kind: python_call_eq
  category: capwords
  id_prefix: capwords_sep
  function: capwords

  columns: [id, args, expected]
  rows:
    - [hyphen_sep,    ["hello-world", "-"],    "Hello-World"]
    - [comma_sep,     ["one,two,three", ","],  "One,Two,Three"]

