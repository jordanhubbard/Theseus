spec: multiprocessing_extra272
version: ">=3.9"
backend: python_module(multiprocessing.heap)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.shared_memory.html — shared memory documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/heap.py"
    - "multiprocessing_extra28.zspec.zsdl — covers Pool/Process method qualname lengths, exception hierarchy"
    - "multiprocessing_extra27.zspec.zsdl — covers context-bound class qualname lengths, Process method qualname lengths"
    - "multiprocessing_extra.zspec.zsdl — covers Process/__module__/__name__/__bases__, factory function names, AuthenticationError identity"
  notes:
    - "This spec covers the multiprocessing.heap internal submodule: module identity (__name__, __spec__.name, __package__, __loader__.__class__.__name__, __all__); Arena class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()); Heap class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()); BufferWrapper class identity; heap utility function qualnames (rebuild_arena, reduce_arena)."
    - "multiprocessing.heap is an internal implementation module (not part of the public API). It provides shared-memory arena management for multiprocessing. Its __all__ == ['BufferWrapper'] (list, len=1). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.heap.__name__ == 'multiprocessing.heap' (len=20); __package__ == 'multiprocessing' (len=15); __loader__.__class__.__name__ == 'SourceFileLoader'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Arena.__name__ == 'Arena' (len=5); Arena.__module__ == 'multiprocessing.heap'; Arena.__bases__[0].__name__ == 'object'; Arena.__mro__.__len__() == 2 ([Arena, object]). Arena is a flat class with no non-trivial base. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Heap.__name__ == 'Heap' (len=4); Heap.__module__ == 'multiprocessing.heap'; Heap.__bases__[0].__name__ == 'object'; Heap.__mro__.__len__() == 2 ([Heap, object]). Heap is also a flat class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "BufferWrapper.__name__ == 'BufferWrapper' (len=13); BufferWrapper.__bases__[0].__name__ == 'object'; BufferWrapper.__mro__.__len__() == 2. Like Arena and Heap, BufferWrapper is a flat direct object subclass. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "rebuild_arena.__qualname__ == 'rebuild_arena' (len=13); reduce_arena.__qualname__ == 'reduce_arena' (len=12). Both are module-level functions in multiprocessing.heap used for pickling/unpickling Arena objects. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.heap module identity — extra272
#
# multiprocessing.heap.__name__             == 'multiprocessing.heap'  (len=20)
# multiprocessing.heap.__spec__.name        == 'multiprocessing.heap'
# multiprocessing.heap.__package__          == 'multiprocessing'       (len=15)
# multiprocessing.heap.__loader__.__class__.__name__ == 'SourceFileLoader'
# multiprocessing.heap.__all__.__class__.__name__    == 'list'
# multiprocessing.heap.__all__.__len__()             == 1
# ---------------------------------------------------------------------------

table multiprocessing_extra272.heap_module_identity:
  description: "multiprocessing.heap module identity checks in extra272 namespace — internal implementation module; __name__=='multiprocessing.heap' (len=20); __package__=='multiprocessing' (len=15); __all__ is a list with 1 member ('BufferWrapper'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: heapmod272

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,   multiprocessing.heap.__name__.__eq__,                      ["multiprocessing.heap"], true,  "multiprocessing.heap.__name__ == 'multiprocessing.heap'; verified with Python 3.14.3"]
    - [mod_spec_eq,   multiprocessing.heap.__spec__.name.__eq__,                 ["multiprocessing.heap"], true,  "multiprocessing.heap.__spec__.name == 'multiprocessing.heap'; verified with Python 3.14.3"]
    - [mod_name_len,  multiprocessing.heap.__name__.__len__,                     [],                       20,    "multiprocessing.heap.__name__.__len__() == 20 ('multiprocessing.heap'=20); verified with Python 3.14.3"]
    - [mod_pkg_eq,    multiprocessing.heap.__package__.__eq__,                   ["multiprocessing"],      true,  "multiprocessing.heap.__package__ == 'multiprocessing'; verified with Python 3.14.3"]
    - [mod_pkg_len,   multiprocessing.heap.__package__.__len__,                  [],                       15,    "multiprocessing.heap.__package__.__len__() == 15 ('multiprocessing'=15); verified with Python 3.14.3"]
    - [mod_loader_eq, multiprocessing.heap.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"],     true,  "multiprocessing.heap.__loader__.__class__.__name__ == 'SourceFileLoader'; verified with Python 3.14.3"]
    - [all_class_eq,  multiprocessing.heap.__all__.__class__.__name__.__eq__,    ["list"],                 true,  "multiprocessing.heap.__all__.__class__.__name__ == 'list' (not a tuple); verified with Python 3.14.3"]
    - [all_len,       multiprocessing.heap.__all__.__len__,                      [],                       1,     "multiprocessing.heap.__all__.__len__() == 1 — only 'BufferWrapper' is exported; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Arena, Heap, BufferWrapper class identity table — extra272
#
# All three classes in multiprocessing.heap are direct subclasses of object
# (MRO length == 2). All share the same __module__ == 'multiprocessing.heap'.
# Name lengths differ: Arena=5, Heap=4, BufferWrapper=13.
# Arena.__bases__[0].__name__ == 'object'
# Heap.__bases__[0].__name__  == 'object'
# BufferWrapper.__bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

table multiprocessing_extra272.heap_class_identities:
  description: "multiprocessing.heap Arena/Heap/BufferWrapper class identity checks in extra272 namespace — all three are flat direct-object subclasses (MRO len=2); all share __module__=='multiprocessing.heap' (len=20); name lengths: Arena=5, Heap=4, BufferWrapper=13; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: heapclass272

  columns: [id, function, args, expected, description]
  rows:
    - [arena_name_eq,     multiprocessing.heap.Arena.__name__.__eq__,              ["Arena"],             true,  "Arena.__name__ == 'Arena'; verified with Python 3.14.3"]
    - [arena_module_eq,   multiprocessing.heap.Arena.__module__.__eq__,            ["multiprocessing.heap"], true, "Arena.__module__ == 'multiprocessing.heap'; verified with Python 3.14.3"]
    - [arena_base_eq,     "multiprocessing.heap.Arena.__bases__[0].__name__.__eq__", ["object"],          true,  "Arena.__bases__[0].__name__ == 'object' (direct object subclass); verified with Python 3.14.3"]
    - [arena_mro_len,     multiprocessing.heap.Arena.__mro__.__len__,              [],                    2,     "Arena.__mro__.__len__() == 2 ([Arena, object]); verified with Python 3.14.3"]
    - [heap_name_eq,      multiprocessing.heap.Heap.__name__.__eq__,               ["Heap"],              true,  "Heap.__name__ == 'Heap'; verified with Python 3.14.3"]
    - [heap_module_eq,    multiprocessing.heap.Heap.__module__.__eq__,             ["multiprocessing.heap"], true, "Heap.__module__ == 'multiprocessing.heap'; verified with Python 3.14.3"]
    - [heap_base_eq,      "multiprocessing.heap.Heap.__bases__[0].__name__.__eq__",  ["object"],          true,  "Heap.__bases__[0].__name__ == 'object' (direct object subclass); verified with Python 3.14.3"]
    - [heap_mro_len,      multiprocessing.heap.Heap.__mro__.__len__,               [],                    2,     "Heap.__mro__.__len__() == 2 ([Heap, object]); verified with Python 3.14.3"]
    - [bw_name_eq,        multiprocessing.heap.BufferWrapper.__name__.__eq__,      ["BufferWrapper"],     true,  "BufferWrapper.__name__ == 'BufferWrapper'; verified with Python 3.14.3"]
    - [bw_module_eq,      multiprocessing.heap.BufferWrapper.__module__.__eq__,    ["multiprocessing.heap"], true, "BufferWrapper.__module__ == 'multiprocessing.heap'; verified with Python 3.14.3"]
    - [bw_base_eq,        "multiprocessing.heap.BufferWrapper.__bases__[0].__name__.__eq__", ["object"],  true,  "BufferWrapper.__bases__[0].__name__ == 'object'; verified with Python 3.14.3"]
    - [bw_mro_len,        multiprocessing.heap.BufferWrapper.__mro__.__len__,      [],                    2,     "BufferWrapper.__mro__.__len__() == 2 ([BufferWrapper, object]); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Arena and Heap __name__.__len__() standalone invariants — extra272
# ---------------------------------------------------------------------------

invariant multiprocessing_extra272.Arena.name_len:
  description: "multiprocessing.heap.Arena.__name__.__len__() == 5 — 'Arena' is 5 characters"
  category: identity
  kind: python_call_eq
  function: multiprocessing.heap.Arena.__name__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra272.Heap.name_len:
  description: "multiprocessing.heap.Heap.__name__.__len__() == 4 — 'Heap' is 4 characters; the shortest class name in multiprocessing.heap"
  category: identity
  kind: python_call_eq
  function: multiprocessing.heap.Heap.__name__.__len__
  args: []
  expected: 4

invariant multiprocessing_extra272.BufferWrapper.name_len:
  description: "multiprocessing.heap.BufferWrapper.__name__.__len__() == 13 — 'BufferWrapper' is 13 characters; the longest class name in multiprocessing.heap"
  category: identity
  kind: python_call_eq
  function: multiprocessing.heap.BufferWrapper.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# rebuild_arena and reduce_arena function qualnames — extra272
#
# These two module-level functions in multiprocessing.heap are used for
# pickle serialisation of Arena objects (reduce_arena produces a tuple for
# pickling; rebuild_arena reconstructs the Arena from it).
# rebuild_arena.__qualname__ == 'rebuild_arena' (len=13)
# reduce_arena.__qualname__  == 'reduce_arena'  (len=12)
# Both are module-level functions, so __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra272.rebuild_arena.qualname_eq:
  description: "multiprocessing.heap.rebuild_arena.__qualname__ == 'rebuild_arena' — module-level function for Arena pickle reconstruction (len=13)"
  category: functions
  kind: python_call_eq
  function: multiprocessing.heap.rebuild_arena.__qualname__.__eq__
  args: ["rebuild_arena"]
  expected: true

invariant multiprocessing_extra272.reduce_arena.qualname_eq:
  description: "multiprocessing.heap.reduce_arena.__qualname__ == 'reduce_arena' — module-level function for Arena pickle reduction (len=12)"
  category: functions
  kind: python_call_eq
  function: multiprocessing.heap.reduce_arena.__qualname__.__eq__
  args: ["reduce_arena"]
  expected: true

invariant multiprocessing_extra272.rebuild_arena.qualname_len:
  description: "multiprocessing.heap.rebuild_arena.__qualname__.__len__() == 13 — 'rebuild_arena' is 13 characters; one more than 'reduce_arena' (12)"
  category: functions
  kind: python_call_eq
  function: multiprocessing.heap.rebuild_arena.__qualname__.__len__
  args: []
  expected: 13

invariant multiprocessing_extra272.reduce_arena.qualname_len:
  description: "multiprocessing.heap.reduce_arena.__qualname__.__len__() == 12 — 'reduce_arena' is 12 characters; one less than 'rebuild_arena' (13)"
  category: functions
  kind: python_call_eq
  function: multiprocessing.heap.reduce_arena.__qualname__.__len__
  args: []
  expected: 12

invariant multiprocessing_extra272.heap_all_single_entry:
  description: "multiprocessing.heap.__all__.__len__() == 1 — only 'BufferWrapper' is in __all__; Arena and Heap are not exported via __all__"
  category: identity
  kind: python_call_eq
  function: multiprocessing.heap.__all__.__len__
  args: []
  expected: 1
