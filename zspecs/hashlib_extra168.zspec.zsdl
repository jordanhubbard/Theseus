spec: hashlib_extra168
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra167.zspec.zsdl — covers hashlib.__spec__.name/__class__.__name__/__spec__.origin (table + invariants)."
    - "hashlib_extra166.zspec.zsdl — covers hashlib.new.__name__/__qualname__/__module__/__class__.__name__ / new.__code__.co_argcount / new.__code__.co_name / co_varnames.__len__()==3 (table + invariants)."
    - "hashlib_extra165.zspec.zsdl — covers hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method') / md5.__class__.__name__ / sha512.__class__.__name__ / sha256.__doc__ / md5.__doc__ (table + invariants)."
    - "hashlib_extra164.zspec.zsdl — covers hashlib.algorithms_available and hashlib.algorithms_guaranteed set membership and lengths (table + invariants)."
    - "hashlib_extra160.zspec.zsdl — covers hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra167."
    - "Wave 347 theme: hashlib constructor __name__ and __module__ identity — sha256.__name__=='openssl_sha256' / sha256.__module__=='_hashlib' / md5.__name__=='openssl_md5' / md5.__module__=='_hashlib' / sha512.__name__=='openssl_sha512' / sha512.__module__=='_hashlib' / algorithms_available.__class__.__name__=='set' / algorithms_guaranteed.__class__.__name__=='set'. On macOS/Darwin with OpenSSL-backed CPython, hash constructors are OpenSSL wrappers whose __name__ carries the 'openssl_' prefix. hashlib_extra165 anchors sha256.__class__.__name__=='builtin_function_or_method'; hashlib_extra164 anchors algorithms_guaranteed.__class__.__name__=='set'; this spec anchors the __name__ and __module__ strings of the three hash constructors as the primary novel content."
    - "hashlib.sha256.__name__ == 'openssl_sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__name__ == 'openssl_md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__name__ == 'openssl_sha512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.sha256.__name__ == 'openssl_sha256' (14 chars = 'openssl_'=8 + 'sha256'=6). On CPython builds linked against OpenSSL, the hash constructor functions exposed in the hashlib namespace are OpenSSL-backed builtin_function_or_method objects whose __name__ carries the 'openssl_' prefix. The public name 'sha256' in hashlib.sha256 is an alias; the function's own __name__ reveals the underlying OpenSSL implementation. 'openssl_sha256' (14 chars) = 'openssl_'=8 + 'sha256'=6. Same length as 'openssl_sha512' (also 14 chars)."
    - "Note: hashlib.sha256.__module__ == '_hashlib' (8 chars). The hash constructor functions come from the _hashlib C extension module (Modules/_hashlib.c), not from the public hashlib Python module. '_hashlib' (8 chars) has a leading underscore (private C extension convention) and is 1 char longer than 'hashlib' (7 chars). All three constructors sha256/md5/sha512 share the same __module__ == '_hashlib'."
    - "Note: hashlib.md5.__name__ == 'openssl_md5' (11 chars = 'openssl_'=8 + 'md5'=3). md5 has the shortest __name__ among the three because 'md5' (3 chars) is shorter than 'sha256'/'sha512' (both 6 chars). 'openssl_md5'(11) < 'openssl_sha256'(14) == 'openssl_sha512'(14) in length."
    - "Note: hashlib.algorithms_available.__class__.__name__ == 'set' (3 chars). hashlib.algorithms_available is a Python set containing the names of all hash algorithms available to hashlib (including OpenSSL-backed ones). hashlib_extra164 anchors algorithms_guaranteed.__class__.__name__=='set' as a table row; this spec anchors algorithms_available.__class__.__name__ as a primary novel invariant alongside algorithms_guaranteed.__class__.__name__ for completeness."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__.__eq__('openssl_sha256')
# hashlib.sha256.__module__.__eq__('_hashlib')
# hashlib.md5.__name__.__eq__('openssl_md5')
# hashlib.md5.__module__.__eq__('_hashlib')
#
# Wave 347 theme: hashlib hash constructor __name__ and __module__ identity.
#
# sha256.__name__ == 'openssl_sha256' (14 chars; OpenSSL-backed prefix).
# sha256.__module__ == '_hashlib' (8 chars; private C extension).
# md5.__name__ == 'openssl_md5' (11 chars; shorter because 'md5'=3 vs 'sha256'=6).
# md5.__module__ == '_hashlib' (8 chars; same C extension module).
# hashlib_extra165 anchors sha256.__class__.__name__=='builtin_function_or_method'; no prior
# spec anchors sha256.__name__ or sha256.__module__ as a table under hashlibctor168.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra168.sha256_md5_name_and_module:
  description: "hashlib.sha256.__name__.__eq__('openssl_sha256')==True / sha256.__module__.__eq__('_hashlib')==True / md5.__name__.__eq__('openssl_md5')==True / md5.__module__.__eq__('_hashlib')==True — sha256.__name__ is 'openssl_sha256' (14 chars = 'openssl_'=8 + 'sha256'=6; OpenSSL-backed CPython exposes hash constructors with 'openssl_' prefix in __name__; the public alias 'sha256' in hashlib is separate from the function's own __name__; hashlib_extra165 anchors sha256.__class__.__name__=='builtin_function_or_method'); sha256.__module__ is '_hashlib' (8 chars = '_'=1 + 'hashlib'=7; private C extension module; leading underscore marks private; 1 char longer than 'hashlib' (7 chars) by the leading underscore); md5.__name__ is 'openssl_md5' (11 chars = 'openssl_'=8 + 'md5'=3; 'md5'=3 chars is shorter than 'sha256'/'sha512'=6 chars; openssl_md5(11) < openssl_sha256/openssl_sha512(14) in length); md5.__module__ is '_hashlib' (8 chars; same C extension as sha256; all three hash constructors share the same __module__); first hashlibctor168 anchor for sha256/__md5 __name__ and __module__"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibctor168

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name_openssl,    "sha256.__name__.__eq__",   ["openssl_sha256"], true, "hashlib.sha256.__name__ == 'openssl_sha256' (14 chars; OpenSSL-backed; 'openssl_'=8 + 'sha256'=6; public alias 'sha256' is separate from function's own __name__)"]
    - [sha256_module_hashlib,  "sha256.__module__.__eq__", ["_hashlib"],       true, "hashlib.sha256.__module__ == '_hashlib' (8 chars; private C extension; leading underscore marks private; 1 char longer than 'hashlib'=7)"]
    - [md5_name_openssl,       "md5.__name__.__eq__",      ["openssl_md5"],    true, "hashlib.md5.__name__ == 'openssl_md5' (11 chars; OpenSSL-backed; 'openssl_'=8 + 'md5'=3; shortest of the three: 11 < 14)"]
    - [md5_module_hashlib,     "md5.__module__.__eq__",    ["_hashlib"],       true, "hashlib.md5.__module__ == '_hashlib' (8 chars; same C extension module as sha256 and sha512)"]

# ---------------------------------------------------------------------------
# hashlib.sha512.__name__.__eq__('openssl_sha512')
# hashlib.sha512.__module__.__eq__('_hashlib')
# hashlib.sha256.__name__.__len__()==14
# hashlib.md5.__name__.__len__()==11
#
# Wave 347 theme: sha512 identity and name lengths.
#
# sha512.__name__ == 'openssl_sha512' (14 chars; same length as sha256's 'openssl_sha256').
# sha512.__module__ == '_hashlib' (8 chars; same C extension as sha256 and md5).
# sha256.__name__.__len__() == 14 ('openssl_sha256' = 'openssl_'=8 + 'sha256'=6).
# md5.__name__.__len__() == 11 ('openssl_md5' = 'openssl_'=8 + 'md5'=3).
# No prior hashlib spec anchors sha512.__name__ or name lengths as a table under hashlibctor168.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra168.sha512_name_module_and_lengths:
  description: "hashlib.sha512.__name__.__eq__('openssl_sha512')==True / sha512.__module__.__eq__('_hashlib')==True / sha256.__name__.__len__()==14 / md5.__name__.__len__()==11 — sha512.__name__ is 'openssl_sha512' (14 chars = 'openssl_'=8 + 'sha512'=6; same length as sha256's 'openssl_sha256' because 'sha256'=6 chars == 'sha512'=6 chars; both 14 chars); sha512.__module__ is '_hashlib' (8 chars; same C extension as sha256 and md5; all three share __module__=='_hashlib'); sha256.__name__.__len__() is 14 ('openssl_sha256' = 'openssl_'=8 + 'sha256'=6 = 14; same as sha512; 14 > 11 by 3 chars — the difference between 'sha256'/'sha512' (6 chars) and 'md5' (3 chars)); md5.__name__.__len__() is 11 ('openssl_md5' = 'openssl_'=8 + 'md5'=3 = 11; shortest of the three because 'md5'=3 is shortest algorithm name); length ordering: md5.__name__(11) < sha256.__name__(14) == sha512.__name__(14); first hashlibctor168 anchor for sha512 name/module and name lengths"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibctor168

  columns: [id, function, args, expected, description]
  rows:
    - [sha512_name_openssl,    "sha512.__name__.__eq__",   ["openssl_sha512"], true, "hashlib.sha512.__name__ == 'openssl_sha512' (14 chars = 'openssl_'=8 + 'sha512'=6; same length as sha256's 'openssl_sha256')"]
    - [sha512_module_hashlib,  "sha512.__module__.__eq__", ["_hashlib"],       true, "hashlib.sha512.__module__ == '_hashlib' (8 chars; same C extension as sha256 and md5; all three share __module__)"]
    - [sha256_name_len_14,     "sha256.__name__.__len__",  [],                 14,  "hashlib.sha256.__name__.__len__() is 14 ('openssl_sha256' = 'openssl_'=8 + 'sha256'=6 = 14; same length as sha512)"]
    - [md5_name_len_11,        "md5.__name__.__len__",     [],                 11,  "hashlib.md5.__name__.__len__() is 11 ('openssl_md5' = 'openssl_'=8 + 'md5'=3 = 11; shortest because 'md5'=3 chars vs 'sha256'/'sha512'=6 chars)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__ and algorithms_guaranteed
#
# Wave 347 theme: algorithms_available and algorithms_guaranteed are both sets.
#
# algorithms_available.__class__.__name__ == 'set' (3 chars).
# algorithms_guaranteed.__class__.__name__ == 'set' (3 chars).
# sha256.__module__.__eq__('_hashlib') (confirmed; 8 chars).
# sha512.__name__.__len__() == 14 (confirmed).
# hashlib_extra164 anchors algorithms_guaranteed.__class__.__name__=='set' and membership;
# no prior spec anchors algorithms_available.__class__.__name__ as a table under hashlibctor168.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra168.algorithms_set_class_names:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set')==True / algorithms_guaranteed.__class__.__name__.__eq__('set')==True / sha256.__module__.__eq__('_hashlib')==True / sha512.__name__.__len__()==14 — algorithms_available.__class__.__name__ is 'set' (3 chars; hashlib.algorithms_available is a Python set containing the names of all hash algorithms available via hashlib, including OpenSSL-backed ones that vary by platform; 'set' is the built-in Python set type; hashlib_extra164 does not anchor algorithms_available.__class__.__name__ as a table row — that spec anchors membership and len; this spec anchors __class__.__name__ as the primary novel invariant); algorithms_guaranteed.__class__.__name__ is 'set' (3 chars; hashlib.algorithms_guaranteed is a Python set containing the names of hash algorithms guaranteed to be available on all Python implementations; subset of algorithms_available; hashlib_extra160 anchors this as a table row; confirmed here with algorithms_available as parallel); sha256.__module__ is '_hashlib' (confirmed; 8 chars; C extension module); sha512.__name__.__len__() is 14 (confirmed; 'openssl_sha512' = 14 chars; same as sha256's 14 chars); first hashlibctor168 anchor for algorithms_available.__class__.__name__ as a table"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibctor168

  columns: [id, function, args, expected, description]
  rows:
    - [alg_avail_class_set,   "algorithms_available.__class__.__name__.__eq__",   ["set"], true, "hashlib.algorithms_available.__class__.__name__ == 'set' (3 chars; set of all available algorithm names; platform-dependent; includes OpenSSL variants)"]
    - [alg_guar_class_set,    "algorithms_guaranteed.__class__.__name__.__eq__",  ["set"], true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' (3 chars; set of guaranteed algorithm names; subset of algorithms_available; hashlib_extra160 anchors)"]
    - [sha256_module_b,       "sha256.__module__.__eq__",                         ["_hashlib"], true, "hashlib.sha256.__module__ == '_hashlib' (confirmed; 8 chars; private C extension; all three hash constructors share this __module__)"]
    - [sha512_name_len_14,    "sha512.__name__.__len__",                          [], 14,        "hashlib.sha512.__name__.__len__() is 14 ('openssl_sha512' = 'openssl_'=8 + 'sha512'=6 = 14; same length as sha256.__name__)"]

# ---------------------------------------------------------------------------
# hashlib.__module__ lengths
#
# Wave 347 theme: module string lengths for hash constructors.
#
# sha256.__module__.__len__() == 8 ('_hashlib' = 8 chars).
# md5.__module__.__len__() == 8 ('_hashlib' = 8 chars; same).
# sha512.__module__.__len__() == 8 ('_hashlib' = 8 chars; same).
# algorithms_available.__class__.__name__.__len__() == 3 ('set' = 3 chars).
# No prior hashlib spec anchors the __module__ lengths of the hash constructors as a table
# under hashlibctor168. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra168.hashlib_constructor_module_lengths:
  description: "hashlib.sha256.__module__.__len__()==8 / md5.__module__.__len__()==8 / sha512.__module__.__len__()==8 / algorithms_available.__class__.__name__.__len__()==3 — sha256.__module__.__len__() is 8 ('_hashlib' = '_'=1 + 'hashlib'=7 = 8 chars; 1 char longer than 'hashlib'=7 by the leading underscore; the underscore convention marks the private C extension); md5.__module__.__len__() is 8 ('_hashlib' = 8 chars; same module as sha256; md5 and sha256 and sha512 all come from the same C extension); sha512.__module__.__len__() is 8 ('_hashlib' = 8 chars; same; all three hash constructors share __module__=='_hashlib' with length 8); algorithms_available.__class__.__name__.__len__() is 3 ('set' = 3 chars; 'set' is the shortest type name in this spec: 'set'(3) << '_hashlib'(8) < 'openssl_md5'(11) < 'openssl_sha256'/'openssl_sha512'(14)); length ordering: 'set'(3) < '_hashlib'(8) < 'openssl_md5'(11) < 'openssl_sha256/sha512'(14); first hashlibctor168 anchor for __module__ lengths as a table"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibctor168

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_module_len_8, "sha256.__module__.__len__",                      [], 8, "hashlib.sha256.__module__.__len__() is 8 ('_hashlib' = '_'=1 + 'hashlib'=7 = 8; underscore prefix makes it 1 char longer than 'hashlib'=7)"]
    - [md5_module_len_8,    "md5.__module__.__len__",                         [], 8, "hashlib.md5.__module__.__len__() is 8 ('_hashlib' = 8 chars; same module as sha256 and sha512)"]
    - [sha512_module_len_8, "sha512.__module__.__len__",                      [], 8, "hashlib.sha512.__module__.__len__() is 8 ('_hashlib' = 8 chars; all three hash constructors share __module__ with length 8)"]
    - [alg_avail_cls_len_3, "algorithms_available.__class__.__name__.__len__", [], 3, "hashlib.algorithms_available.__class__.__name__.__len__() is 3 ('set' = 3 chars; shortest type name in this spec; Python built-in set type)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__.__eq__('openssl_sha256') — standalone
#
# hashlib.sha256.__name__ is 'openssl_sha256' (14 chars = 'openssl_'=8 + 'sha256'=6).
# On macOS/Darwin CPython linked against OpenSSL, the hash constructors exposed in hashlib
# are OpenSSL-backed C functions from the _hashlib extension module. The public name 'sha256'
# in the hashlib namespace is an alias pointing to a builtin_function_or_method whose own
# __name__ is 'openssl_sha256'. This reveals the OpenSSL implementation behind the public API.
# hashlib_extra165 anchors sha256.__class__.__name__=='builtin_function_or_method' as a table
# row, but not sha256.__name__. No prior hashlib spec anchors sha256.__name__ as a standalone
# under hashlibctor168. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra168.sha256_name_openssl_sha256:
  description: "hashlib.sha256.__name__.__eq__('openssl_sha256') == True — 'openssl_sha256' (14 chars = 'openssl_'=8 + 'sha256'=6); OpenSSL-backed CPython exposes hash constructors with 'openssl_' prefix in __name__; public alias 'sha256' in hashlib.sha256 differs from function's own __name__; sha256.__module__=='_hashlib' (8 chars; C extension); hashlib_extra165 anchors sha256.__class__.__name__=='builtin_function_or_method' but not __name__; 'openssl_sha256'(14) == 'openssl_sha512'(14) > 'openssl_md5'(11) in length; first hashlibctor168 standalone for sha256.__name__"
  category: identity
  kind: python_call_eq
  function: sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5.__name__.__eq__('openssl_md5') — standalone
#
# hashlib.md5.__name__ is 'openssl_md5' (11 chars = 'openssl_'=8 + 'md5'=3). MD5 has the
# shortest __name__ among the three hash constructors because 'md5' (3 chars) is shorter
# than 'sha256' and 'sha512' (both 6 chars). 'openssl_md5' (11 chars) is 3 chars shorter
# than 'openssl_sha256' and 'openssl_sha512' (both 14 chars). The MD5 algorithm is
# considered cryptographically broken for security purposes but remains available in hashlib
# for non-security uses (file checksums, etc.). No prior hashlib spec anchors md5.__name__
# as a standalone under hashlibctor168. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra168.md5_name_openssl_md5:
  description: "hashlib.md5.__name__.__eq__('openssl_md5') == True — 'openssl_md5' (11 chars = 'openssl_'=8 + 'md5'=3); 'md5'=3 chars is the shortest algorithm name (vs 'sha256'/'sha512'=6 chars each); openssl_md5(11) is 3 chars shorter than openssl_sha256/openssl_sha512(14 each); md5.__module__=='_hashlib' (8 chars; same C extension as sha256 and sha512); md5.__class__.__name__=='builtin_function_or_method' (hashlib_extra165 anchors); first hashlibctor168 standalone for md5.__name__"
  category: identity
  kind: python_call_eq
  function: md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha512.__name__.__eq__('openssl_sha512') — standalone
#
# hashlib.sha512.__name__ is 'openssl_sha512' (14 chars = 'openssl_'=8 + 'sha512'=6).
# sha512's __name__ has the same length as sha256's __name__ ('openssl_sha256' = 14 chars)
# because 'sha512' and 'sha256' are both 6-character algorithm name suffixes. SHA-512
# produces a 512-bit (64-byte) digest, versus SHA-256's 256-bit (32-byte) digest.
# Both are in hashlib.algorithms_guaranteed (guaranteed on all Python implementations).
# No prior hashlib spec anchors sha512.__name__ as a standalone under hashlibctor168.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra168.sha512_name_openssl_sha512:
  description: "hashlib.sha512.__name__.__eq__('openssl_sha512') == True — 'openssl_sha512' (14 chars = 'openssl_'=8 + 'sha512'=6); same length as sha256.__name__=='openssl_sha256' (both 14 chars) because 'sha256'/'sha512' are both 6 chars; sha512.__module__=='_hashlib' (8 chars; same C extension); sha512 produces 512-bit (64-byte) digest vs sha256's 256-bit (32-byte) digest; both in algorithms_guaranteed; first hashlibctor168 standalone for sha512.__name__"
  category: identity
  kind: python_call_eq
  function: sha512.__name__.__eq__
  args: ["openssl_sha512"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_available.__class__.__name__ is 'set' (3 chars). algorithms_available
# is a Python set containing the names of all hash algorithms available to hashlib on the
# current platform. On OpenSSL-backed CPython, this includes all OpenSSL algorithms (which
# may vary by OpenSSL version and platform configuration). The set is larger than
# algorithms_guaranteed (which lists only algorithms available on all Python implementations).
# hashlib_extra164 anchors algorithms_available membership checks and lengths as table rows
# and standalones, but does NOT anchor algorithms_available.__class__.__name__ as a standalone.
# No prior hashlib spec anchors algorithms_available.__class__.__name__ as a standalone under
# hashlibctor168. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra168.algorithms_available_class_set:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — 'set' (3 chars; Python built-in set type; shortest type name in this spec); algorithms_available is a set of all hash algorithm names available on this platform (platform-dependent; includes OpenSSL variants); algorithms_guaranteed is a subset; algorithms_available.__class__.__name__=='set'(3) same as algorithms_guaranteed.__class__.__name__=='set'(3); hashlib_extra164 anchors membership/len but not __class__.__name__ standalone; first hashlibctor168 standalone for algorithms_available.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_guaranteed.__class__.__name__ is 'set' (3 chars). algorithms_guaranteed
# is a Python set containing the names of hash algorithms that are guaranteed to be available
# on all Python implementations (not just CPython). The guaranteed set is a subset of
# algorithms_available. The guaranteed algorithms include: sha1, sha224, sha256, sha384,
# sha512, sha3_224, sha3_256, sha3_384, sha3_512, shake_128, shake_256, blake2b, blake2s, md5
# (14 algorithms total — hashlib_extra164 anchors __len__()==14 as a table row).
# hashlib_extra160 anchors algorithms_guaranteed.__class__.__name__.__eq__('set') as a table
# row; this standalone provides a dedicated invariant under hashlibctor168.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra168.algorithms_guaranteed_class_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — 'set' (3 chars; Python built-in set type); algorithms_guaranteed is the set of hash algorithm names guaranteed on all Python implementations; subset of algorithms_available; hashlib_extra164 anchors __len__()==14 as a row; hashlib_extra160 anchors __class__.__name__=='set' as a table row; this standalone provides a dedicated invariant under hashlibctor168 alongside algorithms_available for completeness; 'set'(3) < '_hashlib'(8) < 'openssl_md5'(11) < 'openssl_sha256'(14) in length ordering; first hashlibctor168 standalone for algorithms_guaranteed.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__module__.__eq__('_hashlib') — standalone
#
# hashlib.sha256.__module__ is '_hashlib' (8 chars). The '_hashlib' module is the private
# C extension (Modules/_hashlib.c) that provides OpenSSL-backed hash implementations.
# '_hashlib' (8 chars) = '_'=1 + 'hashlib'=7. The leading underscore follows the Python
# convention for private C extension modules that are not intended to be imported directly
# by users. The public API is through 'hashlib' (7 chars, no underscore). All three hash
# constructors sha256, md5, and sha512 share __module__ == '_hashlib'.
# hashlib_extra166 notes that new.__module__ == 'hashlib' (7 chars, no underscore) contrasts
# with sha256.__module__ == '_hashlib' (8 chars, with underscore). No prior hashlib spec
# anchors sha256.__module__ as a standalone under hashlibctor168.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra168.sha256_module_hashlib_private:
  description: "hashlib.sha256.__module__.__eq__('_hashlib') == True — '_hashlib' (8 chars = '_'=1 + 'hashlib'=7); private C extension module (Modules/_hashlib.c); leading underscore marks private (not for direct import); 'hashlib'(7 chars; public API module) vs '_hashlib'(8 chars; private C extension): differ by 1 char (the leading underscore); all three constructors sha256/md5/sha512 share __module__=='_hashlib'; new.__module__=='hashlib' (7 chars; Python function from public module — hashlib_extra166 anchors); sha256.__name__=='openssl_sha256' (14 chars); first hashlibctor168 standalone for sha256.__module__"
  category: identity
