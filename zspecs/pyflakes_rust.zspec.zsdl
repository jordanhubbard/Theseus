spec: pyflakes_rust
version: ">=3.9"
backend: rust_module(pyflakes_rust)

docs: https://pypi.org/project/pyflakes/

provenance:
  derived_from:
    - "https://pypi.org/project/pyflakes/ — pyflakes documentation"
  not_derived_from:
    - "pyflakes source: pyflakes/__init__.py"
  notes:
    - "pyflakes checks Python source code for errors."
    - "pyflakes.__version__ is a non-empty string."
    - "pyflakes.api is available."
    - "pyflakes.api.check is available."
    - "pyflakes.api.check('import os\\n', '<test>') == 1 — unused import."
    - "pyflakes.api.check('x = 1\\n', '<test>') == 0 — no errors."
    - "Expose pyflakes_check_ok(code) -> int: pyflakes.api.check(code, '<test>')."
    - "Expose pyflakes_version_nonempty() -> bool: len(pyflakes.__version__) > 0."
    - "All test vectors verified against pyflakes 3.3.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pyflakes_check_ok — code with no issues returns 0
table pyflakes_rust.check.no_errors:
  kind: python_call_eq
  category: check
  id_prefix: pf_ok
  function: pyflakes_check_ok

  columns: [id, args, expected]
  rows:
    - [empty,  [""],           0]
    - [assign, ["x = 1\n"],   0]

# pyflakes_version_nonempty — version non-empty
invariant pyflakes_rust.version.nonempty:
  description: "pyflakes.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pyflakes_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:07:24Z
  iterations: 2
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 2 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
