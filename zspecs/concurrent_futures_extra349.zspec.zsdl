spec: concurrent_futures_extra349
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "ThreadPoolExecutor is in module concurrent.futures.thread and derives from Executor"
    - "ProcessPoolExecutor is in module concurrent.futures.process and derives from Executor"
    - "Future and Executor are both in module concurrent.futures._base"
    - "Future and Executor both derive directly from object"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra349.class_names:
  description: "Verify __name__ attribute of concurrent.futures executor and future classes"
  kind: python_call_eq
  category: identity
  id_prefix: cf349n

  columns: [id, function, args, expected]
  rows:
    - [cf349n001, concurrent.futures.ThreadPoolExecutor.__name__.__eq__, ["ThreadPoolExecutor"], true]
    - [cf349n002, concurrent.futures.ProcessPoolExecutor.__name__.__eq__, ["ProcessPoolExecutor"], true]
    - [cf349n003, concurrent.futures.Future.__name__.__eq__, ["Future"], true]
    - [cf349n004, concurrent.futures.Executor.__name__.__eq__, ["Executor"], true]

table concurrent_futures_extra349.class_modules:
  description: "Verify __module__ attribute of concurrent.futures executor and future classes"
  kind: python_call_eq
  category: identity
  id_prefix: cf349m

  columns: [id, function, args, expected]
  rows:
    - [cf349m001, concurrent.futures.ThreadPoolExecutor.__module__.__eq__, ["concurrent.futures.thread"], true]
    - [cf349m002, concurrent.futures.ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"], true]
    - [cf349m003, concurrent.futures.Future.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf349m004, concurrent.futures.Executor.__module__.__eq__, ["concurrent.futures._base"], true]

table concurrent_futures_extra349.class_bases:
  description: "Verify __bases__[0].__name__ (immediate base class name) of concurrent.futures classes"
  kind: python_call_eq
  category: identity
  id_prefix: cf349b

  columns: [id, function, args, expected]
  rows:
    - [cf349b001, "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true]
    - [cf349b002, "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true]
    - [cf349b003, "concurrent.futures.Future.__bases__[0].__name__.__eq__", ["object"], true]
    - [cf349b004, "concurrent.futures.Executor.__bases__[0].__name__.__eq__", ["object"], true]
