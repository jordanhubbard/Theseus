spec: threading_extra2056
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "threading.Thread, threading.Event, threading.Lock, threading.Condition, threading.Semaphore, threading.Barrier do not define sequence/mapping or attribute access protocol methods."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table threading_extra2056.getitem_protocol:
  description: "threading types __getitem__/__setitem__/__delitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2056
  columns: [id, function, args, expected]
  rows:
    - ["th2056001", "threading.Thread.__dict__.__contains__",    ["__getitem__"], false]
    - ["th2056002", "threading.Event.__dict__.__contains__",     ["__getitem__"], false]
    - ["th2056003", "threading.Lock.__dict__.__contains__",      ["__getitem__"], false]
    - ["th2056004", "threading.Thread.__dict__.__contains__",    ["__setitem__"], false]
    - ["th2056005", "threading.Event.__dict__.__contains__",     ["__setitem__"], false]
    - ["th2056006", "threading.Lock.__dict__.__contains__",      ["__setitem__"], false]
    - ["th2056007", "threading.Thread.__dict__.__contains__",    ["__delitem__"], false]
    - ["th2056008", "threading.Event.__dict__.__contains__",     ["__delitem__"], false]
    - ["th2056009", "threading.Lock.__dict__.__contains__",      ["__delitem__"], false]

