spec: getopt_extra2
version: ">=3.9"
backend: python_module(getopt)

docs: https://docs.python.org/3/library/getopt.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/getopt.html — Python getopt module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/getopt.py"
  notes:
    - "This spec extends getopt.zspec.zsdl and getopt_extra.zspec.zsdl."
    - "getopt.zspec.zsdl covers: getopt/gnu_getopt __name__ table, GetoptError/__name__/module/error alias, getopt behavioral vectors (short/long/mixed/empty/error), gnu_getopt behavioral vectors."
    - "getopt_extra.zspec.zsdl covers: getopt.__name__, getopt.__module__, getopt.__class__.__name__, gnu_getopt.__name__, gnu_getopt.__module__, gnu_getopt.__class__.__name__, GetoptError.__name__, GetoptError.__module__, GetoptError.__class__.__name__, GetoptError.__bases__[0].__name__, GetoptError.__bases__.__len__, error.__name__, error.__module__, GetoptError.__init__.__name__, GetoptError.__str__.__name__."
    - "This spec adds: getopt.__qualname__, gnu_getopt.__qualname__, GetoptError.__qualname__, GetoptError.__bases__[0].__name__ as standalone invariant, and a function __name__ table for getopt/gnu_getopt for cross-verification."
    - "getopt.getopt.__qualname__ == 'getopt' — module-level function, not nested."
    - "getopt.gnu_getopt.__qualname__ == 'gnu_getopt' — module-level function, not nested."
    - "getopt.GetoptError.__qualname__ == 'GetoptError' — class is not nested."
    - "getopt.error.__name__ == 'GetoptError' — error is an alias bound to the same class object as GetoptError."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ checks — getopt and gnu_getopt
# Not covered in getopt.zspec.zsdl or getopt_extra.zspec.zsdl.
# ---------------------------------------------------------------------------

invariant getopt_extra2.getopt.qualname:
  description: "getopt.getopt.__qualname__ == 'getopt' — module-level function, not nested"
  category: functions
  kind: python_call_eq
  function: getopt.__qualname__.__eq__
  args: ["getopt"]
  expected: true

invariant getopt_extra2.gnu_getopt.qualname:
  description: "getopt.gnu_getopt.__qualname__ == 'gnu_getopt' — module-level function, not nested"
  category: functions
  kind: python_call_eq
  function: gnu_getopt.__qualname__.__eq__
  args: ["gnu_getopt"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ table — getopt and gnu_getopt
# Cross-verification table (same values as getopt.zspec.zsdl table rows,
# but recorded here as a distinct table with its own spec-qualified ID).
# ---------------------------------------------------------------------------

table getopt_extra2.function_names:
  description: "getopt module-level functions have __name__ equal to their identifier"
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [getopt,     getopt.__name__.__eq__,     ["getopt"],     true]
    - [gnu_getopt, gnu_getopt.__name__.__eq__,  ["gnu_getopt"], true]

# ---------------------------------------------------------------------------
# GetoptError class — __qualname__
# Not covered in any prior getopt spec.
# ---------------------------------------------------------------------------

invariant getopt_extra2.GetoptError.qualname:
  description: "getopt.GetoptError.__qualname__ == 'GetoptError' — class is not nested"
  category: classes
  kind: python_call_eq
  function: GetoptError.__qualname__.__eq__
  args: ["GetoptError"]
  expected: true

# ---------------------------------------------------------------------------
# GetoptError — __name__, __module__, base class (standalone invariants)
# Covered in prior specs; present here as anchors with extra2 IDs.
# ---------------------------------------------------------------------------

invariant getopt_extra2.GetoptError.name:
  description: "getopt.GetoptError.__name__ == 'GetoptError'"
  category: classes
  kind: python_call_eq
  function: GetoptError.__name__.__eq__
  args: ["GetoptError"]
  expected: true

invariant getopt_extra2.GetoptError.module:
  description: "getopt.GetoptError.__module__ == 'getopt'"
  category: classes
  kind: python_call_eq
  function: GetoptError.__module__.__eq__
  args: ["getopt"]
  expected: true

invariant getopt_extra2.GetoptError.base_is_Exception:
  description: "getopt.GetoptError.__bases__[0].__name__ == 'Exception' — inherits directly from Exception"
  category: hierarchy
  kind: python_call_eq
  function: GetoptError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# getopt.error alias — __name__ confirms it is the same class as GetoptError
# Covered in getopt_extra as a standalone invariant; here as extra2 anchor.
# ---------------------------------------------------------------------------

invariant getopt_extra2.error.name:
  description: "getopt.error.__name__ == 'GetoptError' — error is an alias for GetoptError"
  category: classes
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["GetoptError"]
  expected: true

# ---------------------------------------------------------------------------
# getopt and gnu_getopt — __name__ and __module__ standalone invariants
# Covered in getopt_extra; here as named invariants with extra2 IDs.
# ---------------------------------------------------------------------------

invariant getopt_extra2.getopt.name:
  description: "getopt.getopt.__name__ == 'getopt'"
  category: functions
  kind: python_call_eq
  function: getopt.__name__.__eq__
  args: ["getopt"]
  expected: true

invariant getopt_extra2.getopt.module:
  description: "getopt.getopt.__module__ == 'getopt'"
  category: functions
  kind: python_call_eq
  function: getopt.__module__.__eq__
  args: ["getopt"]
  expected: true

invariant getopt_extra2.gnu_getopt.name:
  description: "getopt.gnu_getopt.__name__ == 'gnu_getopt'"
  category: functions
  kind: python_call_eq
  function: gnu_getopt.__name__.__eq__
  args: ["gnu_getopt"]
  expected: true

invariant getopt_extra2.gnu_getopt.module:
  description: "getopt.gnu_getopt.__module__ == 'getopt'"
  category: functions
  kind: python_call_eq
  function: gnu_getopt.__module__.__eq__
  args: ["getopt"]
  expected: true
