spec: json_extra22
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra21.zspec.zsdl."
    - "json_extra21 covers: loads/__qualname__; dumps/__qualname__; load/__name__; load/__qualname__; dump/__name__; dump/__qualname__; load/__module__; dump/__module__; JSONDecodeError/__init__/__qualname__; JSONDecodeError/__init__/__module__."
    - "json_extra19 covers: JSONEncoder/__init__/__qualname__; JSONDecoder/__init__/__qualname__; JSONEncoder/__init__/__module__; JSONDecoder/__init__/__module__."
    - "json_extra5 covers: loads/__name__; dumps/__name__."
    - "json_extra4 covers: load/__name__; dump/__name__ (verified in earlier table)."
    - "Focus: __name__ attribute of JSONDecoder.__init__, JSONEncoder.__init__, and JSONDecodeError.__init__; __name__ type axes (str) for those three dunder __name__ strings; loads/__name__ and dumps/__name__ type axes."
    - "No prior json spec checks JSONDecoder.__init__.__name__."
    - "No prior json spec checks JSONEncoder.__init__.__name__."
    - "No prior json spec checks JSONDecodeError.__init__.__name__."
    - "No prior json spec checks JSONDecoder.__init__.__name__.__class__.__name__ (type axis)."
    - "No prior json spec checks JSONEncoder.__init__.__name__.__class__.__name__ (type axis)."
    - "No prior json spec checks JSONDecodeError.__init__.__name__.__class__.__name__ (type axis)."
    - "No prior json spec checks loads.__qualname__.__class__.__name__ (type axis)."
    - "No prior json spec checks dumps.__qualname__.__class__.__name__ (type axis)."
    - "json.JSONDecoder.__init__.__name__ == '__init__' — dunder method __name__ is always the bare dunder string."
    - "json.JSONEncoder.__init__.__name__ == '__init__' — dunder method __name__ is always the bare dunder string."
    - "json.JSONDecodeError.__init__.__name__ == '__init__' — dunder method __name__ is always the bare dunder string."
    - "json.JSONDecoder.__init__.__name__.__class__.__name__ == 'str' — __name__ attribute is a plain string."
    - "json.JSONEncoder.__init__.__name__.__class__.__name__ == 'str' — __name__ attribute is a plain string."
    - "json.JSONDecodeError.__init__.__name__.__class__.__name__ == 'str' — __name__ attribute is a plain string."
    - "json.loads.__qualname__.__class__.__name__ == 'str' — __qualname__ attribute is a plain string."
    - "json.dumps.__qualname__.__class__.__name__ == 'str' — __qualname__ attribute is a plain string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# JSONDecoder.__init__, JSONEncoder.__init__, JSONDecodeError.__init__ — __name__
#
# json_extra19 checks __qualname__ and __module__ for JSONEncoder.__init__ and
# JSONDecoder.__init__.  json_extra21 checks __qualname__ and __module__ for
# JSONDecodeError.__init__.  No prior json spec checks the bare __name__ of any
# of these three __init__ methods.  For every Python function or method,
# __name__ is always the plain identifier without qualification, so all three
# return '__init__'.
# ---------------------------------------------------------------------------

invariant json_extra22.JSONDecoder.__init__.name:
  description: "json.JSONDecoder.__init__.__name__ == '__init__' — bare method name without class prefix"
  category: method_attrs
  kind: python_call_eq
  function: "JSONDecoder.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

invariant json_extra22.JSONEncoder.__init__.name:
  description: "json.JSONEncoder.__init__.__name__ == '__init__' — bare method name without class prefix"
  category: method_attrs
  kind: python_call_eq
  function: "JSONEncoder.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

invariant json_extra22.JSONDecodeError.__init__.name:
  description: "json.JSONDecodeError.__init__.__name__ == '__init__' — bare method name without class prefix"
  category: method_attrs
  kind: python_call_eq
  function: "JSONDecodeError.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Type axis: __name__ of JSONDecoder, JSONEncoder, JSONDecodeError __init__
#
# Verifies that the __name__ attribute on each dunder method is itself a
# plain str instance.  This is the type axis for the three __name__ checks
# above.
# ---------------------------------------------------------------------------

invariant json_extra22.JSONDecoder.__init__.name.class_name:
  description: "json.JSONDecoder.__init__.__name__.__class__.__name__ == 'str' — __name__ is a plain string"
  category: type_attrs
  kind: python_call_eq
  function: "JSONDecoder.__init__.__name__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

invariant json_extra22.JSONEncoder.__init__.name.class_name:
  description: "json.JSONEncoder.__init__.__name__.__class__.__name__ == 'str' — __name__ is a plain string"
  category: type_attrs
  kind: python_call_eq
  function: "JSONEncoder.__init__.__name__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

invariant json_extra22.JSONDecodeError.__init__.name.class_name:
  description: "json.JSONDecodeError.__init__.__name__.__class__.__name__ == 'str' — __name__ is a plain string"
  category: type_attrs
  kind: python_call_eq
  function: "JSONDecodeError.__init__.__name__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Type axis: __qualname__ of loads and dumps
#
# json_extra21 checks the value of loads.__qualname__ and dumps.__qualname__.
# No prior json spec checks the type (__class__.__name__) of those __qualname__
# attributes.  A function's __qualname__ is always a plain str instance.
# ---------------------------------------------------------------------------

invariant json_extra22.loads.qualname.class_name:
  description: "json.loads.__qualname__.__class__.__name__ == 'str' — __qualname__ is a plain string"
  category: type_attrs
  kind: python_call_eq
  function: loads.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant json_extra22.dumps.qualname.class_name:
  description: "json.dumps.__qualname__.__class__.__name__ == 'str' — __qualname__ is a plain string"
  category: type_attrs
  kind: python_call_eq
  function: dumps.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all eight new invariants
#
# All eight are first covered in this spec (json_extra22).
# ---------------------------------------------------------------------------

table json_extra22.init_names_and_type_axes:
  description: "json JSONDecoder/JSONEncoder/JSONDecodeError __init__.__name__ and type axes for __name__/__qualname__"
  kind: python_call_eq
  category: method_attrs
  id_prefix: jfa22

  columns: [id, function, args, expected]
  rows:
    - [decoder_init_name,      "JSONDecoder.__init__.__name__.__eq__",                    ["__init__"], true]
    - [encoder_init_name,      "JSONEncoder.__init__.__name__.__eq__",                    ["__init__"], true]
    - [decodeerr_init_name,    "JSONDecodeError.__init__.__name__.__eq__",                ["__init__"], true]
    - [decoder_init_name_type, "JSONDecoder.__init__.__name__.__class__.__name__.__eq__", ["str"],      true]
    - [encoder_init_name_type, "JSONEncoder.__init__.__name__.__class__.__name__.__eq__", ["str"],      true]
    - [decodeerr_init_name_type, "JSONDecodeError.__init__.__name__.__class__.__name__.__eq__", ["str"], true]
    - [loads_qn_type,          loads.__qualname__.__class__.__name__.__eq__,              ["str"],      true]
    - [dumps_qn_type,          dumps.__qualname__.__class__.__name__.__eq__,              ["str"],      true]
