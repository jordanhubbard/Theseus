spec: concurrent_futures_extra11
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra10.zspec.zsdl."
    - "extra10 covers: Future method __qualname__ (cancel/result/done/cancelled/running/exception); ThreadPoolExecutor.submit/__qualname__; ThreadPoolExecutor.shutdown/__qualname__; ProcessPoolExecutor.submit/__qualname__; Executor.submit/__qualname__."
    - "extra9 covers: Future additional method __name__ (cancelled/running/done/exception/set_result); InvalidStateError.__qualname__/__module__/__bases__[0].__name__; ThreadPoolExecutor/__class__.__name__=='type'; ProcessPoolExecutor/__class__.__name__=='type'; ThreadPoolExecutor/ProcessPoolExecutor __mro__[2].__name__=='object'."
    - "extra6 covers: __qualname__ for ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor/CancelledError/TimeoutError/BrokenExecutor/as_completed/wait."
    - "extra4 covers: __bases__[0] for ThreadPoolExecutor/ProcessPoolExecutor/BrokenExecutor/Future; __mro__[1] for ThreadPoolExecutor/ProcessPoolExecutor/BrokenExecutor/Future."
    - "extra3 covers: BrokenExecutor/__name__/__module__/__bases__[0]; CancelledError/__name__/__module__; TimeoutError/__name__/__module__; InvalidStateError/__name__/__module__; Executor.submit/__name__; Executor.map/__name__; Executor.shutdown/__name__."
    - "base spec covers: Future.cancel/__name__; Future.result/__name__; Future.add_done_callback/__name__."
    - "NOT yet covered in any prior spec: Future.add_done_callback.__qualname__ == 'Future.add_done_callback'."
    - "NOT yet covered: Future.set_result.__qualname__ == 'Future.set_result'."
    - "NOT yet covered: Future.set_exception.__qualname__ == 'Future.set_exception'."
    - "NOT yet covered: Executor.map.__qualname__ == 'Executor.map'."
    - "NOT yet covered: Executor.shutdown.__qualname__ == 'Executor.shutdown'."
    - "NOT yet covered: ProcessPoolExecutor.map.__qualname__ — inherits Executor.map override."
    - "NOT yet covered: ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown'."
    - "NOT yet covered: BrokenExecutor.__mro__[2].__name__ == 'Exception' — index-2 MRO check."
    - "NOT yet covered: BrokenExecutor.__class__.__name__ == 'type' — metaclass check."
    - "NOT yet covered: CancelledError.__class__.__name__ == 'type' — metaclass check."
    - "NOT yet covered: TimeoutError.__class__.__name__ == 'type' — metaclass check."
    - "concurrent.futures.Future.add_done_callback.__qualname__ == 'Future.add_done_callback'."
    - "concurrent.futures.Future.set_result.__qualname__ == 'Future.set_result'."
    - "concurrent.futures.Future.set_exception.__qualname__ == 'Future.set_exception'."
    - "concurrent.futures.Executor.map.__qualname__ == 'Executor.map'."
    - "concurrent.futures.Executor.shutdown.__qualname__ == 'Executor.shutdown'."
    - "concurrent.futures.ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map'."
    - "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown'."
    - "concurrent.futures.BrokenExecutor.__mro__[2].__name__ == 'Exception'."
    - "concurrent.futures.BrokenExecutor.__class__.__name__ == 'type'."
    - "concurrent.futures.CancelledError.__class__.__name__ == 'type'."
    - "concurrent.futures.TimeoutError.__class__.__name__ == 'type'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Additional Future method __qualname__ checks
#
# extra10 covers Future.cancel/result/done/cancelled/running/exception
# __qualname__. The base spec covers add_done_callback/__name__, and
# extra9 covers set_result/__name__. No prior spec checks __qualname__
# for add_done_callback, set_result, or set_exception.
# ---------------------------------------------------------------------------

table concurrent_futures_extra11.Future_extra_method_qualnames:
  description: "concurrent.futures.Future additional methods have correct __qualname__"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: futexqname

  columns: [id, function, args, expected]
  rows:
    - [add_done_callback, Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"], true]
    - [set_result,        Future.set_result.__qualname__.__eq__,        ["Future.set_result"],        true]
    - [set_exception,     Future.set_exception.__qualname__.__eq__,     ["Future.set_exception"],     true]

# ---------------------------------------------------------------------------
# Executor and ProcessPoolExecutor method __qualname__
#
# extra3 covers Executor.map/__name__ and Executor.shutdown/__name__.
# extra10 covers ProcessPoolExecutor.submit/__qualname__ and
# ThreadPoolExecutor.shutdown/__qualname__. No prior spec checks
# Executor.map/__qualname__, Executor.shutdown/__qualname__,
# ProcessPoolExecutor.map/__qualname__, or
# ProcessPoolExecutor.shutdown/__qualname__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra11.Executor_method_qualnames:
  description: "Executor and ProcessPoolExecutor methods have correct __qualname__"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: execmqname

  columns: [id, function, args, expected]
  rows:
    - [executor_map,              Executor.map.__qualname__.__eq__,                    ["Executor.map"],                    true]
    - [executor_shutdown,         Executor.shutdown.__qualname__.__eq__,               ["Executor.shutdown"],               true]
    - [processpoolexec_map,       ProcessPoolExecutor.map.__qualname__.__eq__,         ["ProcessPoolExecutor.map"],         true]
    - [processpoolexec_shutdown,  ProcessPoolExecutor.shutdown.__qualname__.__eq__,    ["ProcessPoolExecutor.shutdown"],    true]

# ---------------------------------------------------------------------------
# BrokenExecutor MRO depth check
#
# extra4 covers BrokenExecutor.__mro__[1].__name__ == 'RuntimeError'. No
# prior spec checks __mro__[2] for BrokenExecutor. BrokenExecutor's MRO
# is [BrokenExecutor, RuntimeError, Exception, BaseException, object], so
# index 2 is Exception.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra11.BrokenExecutor.mro_index2:
  description: "concurrent.futures.BrokenExecutor.__mro__[2].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: BrokenExecutor.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# Class-level __class__.__name__ — metaclass checks
#
# extra9 covers ThreadPoolExecutor/__class__.__name__ and
# ProcessPoolExecutor/__class__.__name__. No prior spec checks the metaclass
# for BrokenExecutor, CancelledError, or TimeoutError. All three are plain
# Python classes with __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra11.class_metaclass_names:
  description: "BrokenExecutor/CancelledError/TimeoutError have __class__.__name__ == 'type'"
  kind: python_call_eq
  category: class_types
  id_prefix: cfcmeta

  columns: [id, function, args, expected]
  rows:
    - [BrokenExecutor,  BrokenExecutor.__class__.__name__.__eq__,  ["type"], true]
    - [CancelledError,  CancelledError.__class__.__name__.__eq__,  ["type"], true]
    - [TimeoutError,    TimeoutError.__class__.__name__.__eq__,    ["type"], true]
