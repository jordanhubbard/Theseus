spec: uuid_extra135
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra134.zspec.zsdl — covers uuid.UUID.__init__/__str__/__repr__/__hash__/__eq__/__lt__ __qualname__ lengths (13/12/13/13/11/11) / __qualname__ equality strings / __slots__ class name/length / UUID.__bases__[0].__name__=='object' (table + invariants)."
    - "uuid_extra133.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5/UUID __doc__.__class__.__name__=='str' / uuid3 vs uuid5 __doc__ inequality and gap (2) / uuid1 vs uuid4 gap (235) / UUID class vs __init__ doc gap (1367)."
    - "uuid_extra132.zspec.zsdl — covers uuid1/uuid4/uuid3/uuid5/getnode __code__.co_consts lengths / co_varnames lengths / UUID.__init__.__code__ attribute counts."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID method qualname equality and length."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants __class__.__name__, hex values, str() values, version attributes."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant / type(UUID.hex).__name__=='property'."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ / SafeUUID.__bases__[0].__name__=='Enum'."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra134."
    - "Wave 299 theme: uuid.UUID property descriptor __class__.__name__ == 'property' for hex/urn/variant/version/bytes/fields / UUID.int.__class__.__name__ == 'member_descriptor' / property fget __qualname__ lengths for hex/urn (both 8) / variant/version (both 12) / fields (11) / node/time (both 9)."
    - "uuid.UUID.hex.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.int.__class__.__name__ == 'member_descriptor' (not 'property'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.fget.__qualname__ == 'UUID.urn' (len 8). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__qualname__ == 'UUID.version' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__qualname__ == 'UUID.fields' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__qualname__ == 'UUID.node' (len 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__qualname__ == 'UUID.time' (len 9). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.int is a member_descriptor (slot descriptor), not a property. The 'int' slot directly stores the 128-bit integer in the UUID's __slots__ memory. By contrast, hex/urn/variant/version/bytes/fields/node/time/clock_seq are all property objects with fget functions that compute their values from the 'int' slot on demand."
    - "Note: uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' (8 chars = 5-char 'UUID.' + 3-char 'hex'). uuid.UUID.urn.fget.__qualname__ == 'UUID.urn' (8 chars = 5-char 'UUID.' + 3-char 'urn'). hex and urn tie at 8 chars because both property names are 3 chars."
    - "Note: uuid.UUID.variant.fget.__qualname__ == 'UUID.variant' (12 chars = 5-char 'UUID.' + 7-char 'variant'). uuid.UUID.version.fget.__qualname__ == 'UUID.version' (12 chars = 5-char 'UUID.' + 7-char 'version'). variant and version tie at 12 chars because both property names are 7 chars."
    - "Note: The 'property' class name is 8 chars — the same as the string 'property' itself. All computed UUID attributes (hex/bytes/bytes_le/fields/urn/variant/version/node/time/clock_seq) are property objects. Only 'int' and 'is_safe' are member_descriptor slots."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.hex.__class__.__name__.__eq__('property')
# uuid.UUID.urn.__class__.__name__.__eq__('property')
# uuid.UUID.variant.__class__.__name__.__eq__('property')
# uuid.UUID.version.__class__.__name__.__eq__('property')
# uuid.UUID.bytes.__class__.__name__.__eq__('property')
# uuid.UUID.fields.__class__.__name__.__eq__('property')
#
# Wave 299 theme: UUID property descriptor __class__.__name__ == 'property'.
#
# Six UUID computed attributes are Python property objects. extra97 anchors
# type(UUID.hex).__name__=='property' using a different path (via type()); this
# table anchors __class__.__name__ on the descriptor itself directly under
# uuidprop135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra135.UUID_property_class_names:
  description: "uuid.UUID.hex/__class__.__name__.__eq__('property')==True / urn/__class__.__name__.__eq__('property')==True / variant/__class__.__name__.__eq__('property')==True / version/__class__.__name__.__eq__('property')==True / bytes/__class__.__name__.__eq__('property')==True / fields/__class__.__name__.__eq__('property')==True — six UUID computed attributes are property descriptors; extra97 anchors type(UUID.hex).__name__; this table uses __class__.__name__ on the descriptor directly; first uuidprop135 anchor"
  kind: python_call_eq
  category: identity
  id_prefix: uuidprop135

  columns: [id, function, args, expected, description]
  rows:
    - [hex_class_property,     UUID.hex.__class__.__name__.__eq__,     ["property"], true, "uuid.UUID.hex.__class__.__name__ == 'property' (computed from int slot on demand)"]
    - [urn_class_property,     UUID.urn.__class__.__name__.__eq__,     ["property"], true, "uuid.UUID.urn.__class__.__name__ == 'property' (RFC 4122 URN form computed from hex)"]
    - [variant_class_property, UUID.variant.__class__.__name__.__eq__, ["property"], true, "uuid.UUID.variant.__class__.__name__ == 'property' (UUID variant bits computed from int)"]
    - [version_class_property, UUID.version.__class__.__name__.__eq__, ["property"], true, "uuid.UUID.version.__class__.__name__ == 'property' (UUID version computed from int; may be None)"]
    - [bytes_class_property,   UUID.bytes.__class__.__name__.__eq__,   ["property"], true, "uuid.UUID.bytes.__class__.__name__ == 'property' (16-byte big-endian form computed from int)"]
    - [fields_class_property,  UUID.fields.__class__.__name__.__eq__,  ["property"], true, "uuid.UUID.fields.__class__.__name__ == 'property' (tuple of 6 UUID field values computed from int)"]

# ---------------------------------------------------------------------------
# uuid.UUID.int.__class__.__name__.__eq__('member_descriptor')
# uuid.UUID.hex.__class__.__name__.__eq__('property') contrasting with int
# uuid.UUID.int.__qualname__.__eq__('UUID.int')
# uuid.UUID.int.__qualname__.__len__()==8
#
# Wave 299 theme: UUID.int is a member_descriptor, not a property.
#
# UUID.int stores the 128-bit integer directly in the __slots__ memory layout.
# All other UUID computed attributes (hex, bytes, urn, variant, version, etc.)
# are property objects that compute their values from UUID.int. extra94 anchors
# UUID.__slots__ contents; no prior uuid spec anchors UUID.int.__class__.__name__
# == 'member_descriptor' as a table under uuidprop135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra135.UUID_int_member_descriptor:
  description: "uuid.UUID.int/__class__.__name__.__eq__('member_descriptor')==True / uuid.UUID.int/__qualname__.__eq__('UUID.int')==True / __qualname__.__len__()==8 — UUID.int is a slot descriptor (not a property); directly stores 128-bit integer in __slots__ memory; all other UUID attributes compute from this slot; extra94 anchors __slots__ contents; first uuidprop135 anchor for int descriptor class name and qualname"
  kind: python_call_eq
  category: identity
  id_prefix: uuidprop135

  columns: [id, function, args, expected, description]
  rows:
    - [int_class_member,      UUID.int.__class__.__name__.__eq__, ["member_descriptor"], true, "uuid.UUID.int.__class__.__name__ == 'member_descriptor' (slot, not property; directly stored in __slots__)"]
    - [int_qualname_eq,       UUID.int.__qualname__.__eq__,       ["UUID.int"],          true, "uuid.UUID.int.__qualname__ == 'UUID.int' (8 chars = 5-char 'UUID.' + 3-char 'int')"]
    - [int_qualname_len,      UUID.int.__qualname__.__len__,      [],                   8,    "uuid.UUID.int.__qualname__.__len__() is 8 ('UUID.int' = 5-char prefix + 3-char 'int')"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__len__()==8
# uuid.UUID.urn.fget.__qualname__.__len__()==8
# uuid.UUID.variant.fget.__qualname__.__len__()==12
# uuid.UUID.version.fget.__qualname__.__len__()==12
# uuid.UUID.fields.fget.__qualname__.__len__()==11
# uuid.UUID.node.fget.__qualname__.__len__()==9
# uuid.UUID.time.fget.__qualname__.__len__()==9
#
# Wave 299 theme: UUID property fget __qualname__ lengths.
#
# All property fget qualnames follow the 'UUID.<property>' pattern with the 5-char
# 'UUID.' prefix. hex/urn (3-char names) tie at 8; node/time (4-char names) tie at
# 9; fields (6-char) is 11; variant/version (7-char names) tie at 12. extra97 anchors
# fget qualname string equality; no prior uuid spec anchors these fget qualname
# lengths as a table under uuidprop135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra135.UUID_property_fget_qualname_lengths:
  description: "uuid.UUID.hex.fget/__qualname__/__len__()==8 / urn.fget/__qualname__/__len__()==8 / variant.fget/__qualname__/__len__()==12 / version.fget/__qualname__/__len__()==12 / fields.fget/__qualname__/__len__()==11 / node.fget/__qualname__/__len__()==9 / time.fget/__qualname__/__len__()==9 — all follow 'UUID.<property>' pattern (5-char prefix); hex/urn tie at 8 (3-char names); node/time tie at 9 (4-char names); fields is 11 (6-char name); variant/version tie at 12 (7-char names); extra97 anchors equality strings; first uuidprop135 anchor for fget lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidprop135

  columns: [id, function, args, expected, description]
  rows:
    - [hex_fget_qn_len,     UUID.hex.fget.__qualname__.__len__,     [], 8,  "uuid.UUID.hex.fget.__qualname__.__len__() is 8 ('UUID.hex' = 5 + 3 chars)"]
    - [urn_fget_qn_len,     UUID.urn.fget.__qualname__.__len__,     [], 8,  "uuid.UUID.urn.fget.__qualname__.__len__() is 8 ('UUID.urn' = 5 + 3 chars; ties with hex)"]
    - [node_fget_qn_len,    UUID.node.fget.__qualname__.__len__,    [], 9,  "uuid.UUID.node.fget.__qualname__.__len__() is 9 ('UUID.node' = 5 + 4 chars)"]
    - [time_fget_qn_len,    UUID.time.fget.__qualname__.__len__,    [], 9,  "uuid.UUID.time.fget.__qualname__.__len__() is 9 ('UUID.time' = 5 + 4 chars; ties with node)"]
    - [fields_fget_qn_len,  UUID.fields.fget.__qualname__.__len__,  [], 11, "uuid.UUID.fields.fget.__qualname__.__len__() is 11 ('UUID.fields' = 5 + 6 chars)"]
    - [variant_fget_qn_len, UUID.variant.fget.__qualname__.__len__, [], 12, "uuid.UUID.variant.fget.__qualname__.__len__() is 12 ('UUID.variant' = 5 + 7 chars)"]
    - [version_fget_qn_len, UUID.version.fget.__qualname__.__len__, [], 12, "uuid.UUID.version.fget.__qualname__.__len__() is 12 ('UUID.version' = 5 + 7 chars; ties with variant)"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.__class__.__name__.__eq__('property') — standalone
#
# uuid.UUID.hex.__class__.__name__ == 'property'. The hex attribute returns the
# UUID as a 32-character hexadecimal string (with no hyphens), computed from the
# 128-bit integer stored in the int slot. extra97 anchors type(UUID.hex).__name__
# using type(); this standalone uses __class__.__name__ on the descriptor directly,
# which is an equivalent but different access path. No prior uuid spec anchors this
# specific path as a standalone under uuidprop135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra135.UUID_hex_class_property:
  description: "uuid.UUID.hex.__class__.__name__.__eq__('property') == True — UUID.hex is a property (returns 32-char hex string without hyphens, computed from int slot); extra97 anchors type(UUID.hex).__name__; this uses __class__.__name__ directly on the descriptor; first standalone under uuidprop135"
  category: identity
  kind: python_call_eq
  function: UUID.hex.__class__.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.variant.__class__.__name__.__eq__('property') — standalone
#
# uuid.UUID.variant.__class__.__name__ == 'property'. UUID.variant returns one of
# the variant constants (RESERVED_NCS, RFC_4122, RESERVED_MICROSOFT, RESERVED_FUTURE)
# determined by examining specific bits of the UUID integer. It is a computed property,
# not a stored slot. extra97 anchors variant as a property via type(); this standalone
# anchors the same fact via __class__.__name__ under uuidprop135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra135.UUID_variant_class_property:
  description: "uuid.UUID.variant.__class__.__name__.__eq__('property') == True — UUID.variant is a property (returns one of RESERVED_NCS/RFC_4122/RESERVED_MICROSOFT/RESERVED_FUTURE from UUID bit pattern); extra97 anchors via type(); this uses __class__.__name__; first standalone under uuidprop135"
  category: identity
  kind: python_call_eq
  function: UUID.variant.__class__.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.int.__class__.__name__.__eq__('member_descriptor') — standalone
#
# uuid.UUID.int.__class__.__name__ == 'member_descriptor'. UUID.int is the only
# fundamental storage slot among all UUID's numeric attributes. It stores the
# full 128-bit integer value directly in the __slots__ memory layout. All other
# UUID computed attributes (hex, bytes, urn, variant, etc.) are property objects
# that compute their values by reading and manipulating this single int value.
# No prior uuid spec anchors UUID.int.__class__.__name__ == 'member_descriptor'
# as a standalone under uuidprop135. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra135.UUID_int_class_member_descriptor:
  description: "uuid.UUID.int.__class__.__name__.__eq__('member_descriptor') == True — UUID.int is a slot descriptor (not a property); fundamental storage for the 128-bit UUID integer; all other computed attributes (hex/bytes/urn/variant/etc.) derive from this slot; no prior uuid spec anchors this as a standalone; first standalone under uuidprop135"
  category: identity
  kind: python_call_eq
  function: UUID.int.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__qualname__.__len__()==8 — standalone
#
# uuid.UUID.hex.fget.__qualname__.__len__() is 8. The fget qualname 'UUID.hex'
# consists of the 5-char 'UUID.' prefix plus the 3-char 'hex'. At 8 chars it
# ties with uuid.UUID.urn.fget.__qualname__ (also 8 chars) because 'urn' is
# also 3 chars. The 'hex' property returns the UUID without hyphens; the 'urn'
# property returns the full 'urn:uuid:...' form. No prior uuid spec anchors
# uuid.UUID.hex.fget.__qualname__.__len__()==8 as a standalone under uuidprop135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra135.UUID_hex_fget_qualname_len_8:
  description: "uuid.UUID.hex.fget.__qualname__.__len__() == 8 — 'UUID.hex' (8 chars = 5-char 'UUID.' + 3-char 'hex'); ties with UUID.urn.fget.__qualname__ (also 8 chars, both 3-char property names); hex returns 32-char string without hyphens; no prior uuid spec anchors this as a standalone; first standalone under uuidprop135"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.hex.fget.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__qualname__.__len__()==12 — standalone
#
# uuid.UUID.variant.fget.__qualname__.__len__() is 12. The fget qualname
# 'UUID.variant' consists of the 5-char 'UUID.' prefix plus the 7-char 'variant'.
# At 12 chars it ties with uuid.UUID.version.fget.__qualname__ (also 12 chars)
# because 'version' is also 7 chars. variant and version are the two longest
# property names examined in this spec. No prior uuid spec anchors
# uuid.UUID.variant.fget.__qualname__.__len__()==12 as a standalone under uuidprop135.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra135.UUID_variant_fget_qualname_len_12:
  description: "uuid.UUID.variant.fget.__qualname__.__len__() == 12 — 'UUID.variant' (12 chars = 5-char 'UUID.' + 7-char 'variant'); ties with UUID.version.fget.__qualname__ (also 12 chars; 'version' is also 7 chars); longest fget qualname in this spec; no prior uuid spec anchors this as a standalone; first standalone under uuidprop135"
  category: qualname_lengths
  kind: python_call_eq
  function: UUID.variant.fget.__qualname__.__len__
  args: []
  expected: 12
