spec: pathlib_extra270
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib.__name__ == 'pathlib' — the module name."
    - "pathlib.__package__ == 'pathlib' — pathlib is itself its own package (it's a package directory)."
    - "pathlib.__spec__.__class__.__name__ == 'ModuleSpec'."
    - "pathlib.__spec__.name == 'pathlib'."
    - "pathlib.__all__ is a list of 7 entries: ['UnsupportedOperation', 'PurePath', 'PurePosixPath', 'PureWindowsPath', 'Path', 'PosixPath', 'WindowsPath']."
    - "pathlib.__all__[0] == 'UnsupportedOperation' — first public name in __all__."
    - "'Path', 'PurePath', 'PurePosixPath', 'PureWindowsPath' are all present in pathlib.__all__."
    - "type(pathlib.Path.home()).__name__ == 'PosixPath' on macOS/POSIX — Path.home() returns a platform-specific concrete subclass."
    - "type(pathlib.Path.cwd()).__name__ == 'PosixPath' on macOS/POSIX — Path.cwd() returns the same concrete subclass."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib module identity — __name__, __package__, __spec__
# ---------------------------------------------------------------------------

invariant pathlib_extra270.module.name:
  description: "pathlib.__name__ == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra270.module.package:
  description: "pathlib.__package__ == 'pathlib' — pathlib is its own package"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra270.module.spec_class:
  description: "pathlib.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant pathlib_extra270.module.spec_name:
  description: "pathlib.__spec__.name == 'pathlib'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.__all__ — type, length, and membership
# ---------------------------------------------------------------------------

invariant pathlib_extra270.all.type_name:
  description: "type(pathlib.__all__).__name__ == 'list'"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant pathlib_extra270.all.length:
  description: "len(pathlib.__all__) == 7"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 7

invariant pathlib_extra270.all.first_entry:
  description: "pathlib.__all__[0] == 'UnsupportedOperation'"
  category: identity
  kind: python_call_eq
  function: "__all__[0].__eq__"
  args: ["UnsupportedOperation"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.__all__ membership checks — key public names
# ---------------------------------------------------------------------------

table pathlib_extra270.all_membership:
  description: "Key public names present in pathlib.__all__"
  kind: python_call_eq
  category: identity
  id_prefix: allmember

  columns: [id, function, args, expected, description]
  rows:
    - [path,            "__all__.__contains__",  ["Path"],           true, "'Path' is in pathlib.__all__"]
    - [purepath,        "__all__.__contains__",  ["PurePath"],       true, "'PurePath' is in pathlib.__all__"]
    - [pureposixpath,   "__all__.__contains__",  ["PurePosixPath"],  true, "'PurePosixPath' is in pathlib.__all__"]
    - [purewinpath,     "__all__.__contains__",  ["PureWindowsPath"], true, "'PureWindowsPath' is in pathlib.__all__"]

# ---------------------------------------------------------------------------
# pathlib.Path.home() and Path.cwd() — return PosixPath on macOS/POSIX
# ---------------------------------------------------------------------------

invariant pathlib_extra270.Path.home_type:
  description: "type(pathlib.Path.home()).__name__ == 'PosixPath' on macOS/POSIX"
  category: identity
  kind: python_call_eq
  function: Path.home
  args: []
  method: __class__.__name__.__eq__
  method_args: ["PosixPath"]
  expected: true

invariant pathlib_extra270.Path.cwd_type:
  description: "type(pathlib.Path.cwd()).__name__ == 'PosixPath' on macOS/POSIX"
  category: identity
  kind: python_call_eq
  function: Path.cwd
  args: []
  method: __class__.__name__.__eq__
  method_args: ["PosixPath"]
  expected: true
