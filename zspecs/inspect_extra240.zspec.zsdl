spec: inspect_extra240
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra239.zspec.zsdl — covers prior inspect identity specs"
  notes:
    - "This spec covers inspect.FrameInfo, inspect.Traceback, and inspect.ArgInfo named tuple identity contracts."
    - "inspect.FrameInfo.__name__ == 'FrameInfo' (len=9) — FrameInfo is a named tuple class in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__module__ == 'inspect' (len=7) — FrameInfo is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo' — FrameInfo inherits from _FrameInfo (a private named tuple base). Verified with Python 3.14.3."
    - "inspect.FrameInfo.__class__.__name__ == 'type' — FrameInfo is a class; its metaclass is type. Verified with Python 3.14.3."
    - "inspect.FrameInfo.__qualname__ == 'FrameInfo' (len=9) — same as __name__ for top-level class. Verified with Python 3.14.3."
    - "inspect.Traceback.__name__ == 'Traceback' (len=9) — Traceback is a named tuple class in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Traceback.__module__ == 'inspect' (len=7) — Traceback is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.Traceback.__bases__[0].__name__ == '_Traceback' — Traceback inherits from _Traceback. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__name__ == 'ArgInfo' (len=7) — ArgInfo is a named tuple in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__module__ == 'inspect' (len=7) — ArgInfo is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — ArgInfo inherits from tuple (a plain namedtuple). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.FrameInfo identity contracts
#
# inspect.FrameInfo.__name__ == 'FrameInfo' (len=9)
# inspect.FrameInfo.__module__ == 'inspect' (len=7)
# inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo'
# inspect.FrameInfo.__class__.__name__ == 'type'
# inspect.FrameInfo.__qualname__ == 'FrameInfo' (len=9)
#
# FrameInfo is a named tuple class in Lib/inspect.py. New to extra240.
# ---------------------------------------------------------------------------

table inspect_extra240.inspframe240_identity:
  description: "inspect.FrameInfo identity: name, module, bases, class, qualname; new to extra240"
  kind: python_call_eq
  category: identity
  id_prefix: inspframe240

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_name_eq,
       FrameInfo.__name__.__eq__,
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__name__.__eq__('FrameInfo') == True — FrameInfo is a named tuple class in Lib/inspect.py; __name__ is 'FrameInfo' (len=9); new to extra240"]
    - [frameinfo_name_len_9,
       FrameInfo.__name__.__len__,
       [],
       9,
       "inspect.FrameInfo.__name__.__len__() == 9 — 'FrameInfo' has exactly 9 characters; str.__len__() returns 9; new to extra240"]
    - [frameinfo_module_eq,
       FrameInfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__eq__('inspect') == True — FrameInfo is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra240"]
    - [frameinfo_module_len_7,
       FrameInfo.__module__.__len__,
       [],
       7,
       "inspect.FrameInfo.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; str.__len__() returns 7; new to extra240"]
    - [frameinfo_bases_0_is_frameinfo,
       "FrameInfo.__bases__[0].__name__.__eq__",
       ["_FrameInfo"],
       true,
       "inspect.FrameInfo.__bases__[0].__name__.__eq__('_FrameInfo') == True — FrameInfo inherits from _FrameInfo (private named tuple base); new to extra240"]

# ---------------------------------------------------------------------------
# Table 2: inspect.FrameInfo class and qualname contracts
#
# inspect.FrameInfo.__class__.__name__ == 'type'
# inspect.FrameInfo.__qualname__ == 'FrameInfo' (len=9)
# inspect.FrameInfo.__bases__[0].__module__ == 'inspect'
#
# New to extra240.
# ---------------------------------------------------------------------------

table inspect_extra240.inspframe240_class:
  description: "inspect.FrameInfo class, qualname, base module checks; new to extra240"
  kind: python_call_eq
  category: identity
  id_prefix: inspframe240cls

  columns: [id, function, args, expected, description]
  rows:
    - [frameinfo_class_is_type,
       FrameInfo.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.FrameInfo.__class__.__name__.__eq__('type') == True — FrameInfo is a class; its metaclass is the built-in type; new to extra240"]
    - [frameinfo_qualname_eq,
       FrameInfo.__qualname__.__eq__,
       ["FrameInfo"],
       true,
       "inspect.FrameInfo.__qualname__.__eq__('FrameInfo') == True — __qualname__ is 'FrameInfo' (len=9); same as __name__ for top-level class; new to extra240"]
    - [frameinfo_qualname_len_9,
       FrameInfo.__qualname__.__len__,
       [],
       9,
       "inspect.FrameInfo.__qualname__.__len__() == 9 — 'FrameInfo' has exactly 9 characters; str.__len__() returns 9; new to extra240"]
    - [frameinfo_base_module_eq,
       "FrameInfo.__bases__[0].__module__.__eq__",
       ["inspect"],
       true,
       "inspect.FrameInfo.__bases__[0].__module__.__eq__('inspect') == True — _FrameInfo base is also defined in Lib/inspect.py; new to extra240"]
    - [frameinfo_module_contains_inspect,
       FrameInfo.__module__.__contains__,
       ["inspect"],
       true,
       "inspect.FrameInfo.__module__.__contains__('inspect') == True — 'inspect' contains the substring 'inspect'; new to extra240"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Traceback identity contracts
#
# inspect.Traceback.__name__ == 'Traceback' (len=9)
# inspect.Traceback.__module__ == 'inspect' (len=7)
# inspect.Traceback.__bases__[0].__name__ == '_Traceback'
# inspect.Traceback.__class__.__name__ == 'type'
# inspect.Traceback.__qualname__ == 'Traceback' (len=9)
#
# Traceback is a named tuple class in Lib/inspect.py. New to extra240.
# ---------------------------------------------------------------------------

table inspect_extra240.insptb240_identity:
  description: "inspect.Traceback identity: name, module, bases, class, qualname; new to extra240"
  kind: python_call_eq
  category: identity
  id_prefix: insptb240

  columns: [id, function, args, expected, description]
  rows:
    - [tb_name_eq,
       Traceback.__name__.__eq__,
       ["Traceback"],
       true,
       "inspect.Traceback.__name__.__eq__('Traceback') == True — Traceback is a named tuple class in Lib/inspect.py; __name__ is 'Traceback' (len=9); new to extra240"]
    - [tb_name_len_9,
       Traceback.__name__.__len__,
       [],
       9,
       "inspect.Traceback.__name__.__len__() == 9 — 'Traceback' has exactly 9 characters; str.__len__() returns 9; new to extra240"]
    - [tb_module_eq,
       Traceback.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Traceback.__module__.__eq__('inspect') == True — Traceback is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra240"]
    - [tb_module_len_7,
       Traceback.__module__.__len__,
       [],
       7,
       "inspect.Traceback.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; str.__len__() returns 7; new to extra240"]
    - [tb_bases_0_is_traceback,
       "Traceback.__bases__[0].__name__.__eq__",
       ["_Traceback"],
       true,
       "inspect.Traceback.__bases__[0].__name__.__eq__('_Traceback') == True — Traceback inherits from _Traceback (private named tuple base); new to extra240"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra240
# ---------------------------------------------------------------------------

invariant inspect_extra240.frameinfo_name_eq:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo' (len=9); new to extra240"
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra240.frameinfo_name_len_9:
  description: "inspect.FrameInfo.__name__.__len__() == 9 — 'FrameInfo' has 9 characters; new to extra240"
  kind: python_call_eq
  function: FrameInfo.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra240.frameinfo_module_eq:
  description: "inspect.FrameInfo.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra240"
  kind: python_call_eq
  function: FrameInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra240.frameinfo_module_len_7:
  description: "inspect.FrameInfo.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra240"
  kind: python_call_eq
  function: FrameInfo.__module__.__len__
  args: []
  expected: 7

invariant inspect_extra240.frameinfo_bases_0_is_frameinfo:
  description: "inspect.FrameInfo.__bases__[0].__name__ == '_FrameInfo'; new to extra240"
  kind: python_call_eq
  function: "FrameInfo.__bases__[0].__name__.__eq__"
  args: ["_FrameInfo"]
  expected: true

invariant inspect_extra240.frameinfo_class_is_type:
  description: "inspect.FrameInfo.__class__.__name__ == 'type'; new to extra240"
  kind: python_call_eq
  function: FrameInfo.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra240.frameinfo_qualname_eq:
  description: "inspect.FrameInfo.__qualname__ == 'FrameInfo' (len=9); new to extra240"
  kind: python_call_eq
  function: FrameInfo.__qualname__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra240.tb_name_eq:
  description: "inspect.Traceback.__name__ == 'Traceback' (len=9); new to extra240"
  kind: python_call_eq
  function: Traceback.__name__.__eq__
  args: ["Traceback"]
  expected: true

invariant inspect_extra240.tb_name_len_9:
  description: "inspect.Traceback.__name__.__len__() == 9 — 'Traceback' has 9 characters; new to extra240"
  kind: python_call_eq
  function: Traceback.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra240.tb_module_eq:
  description: "inspect.Traceback.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra240"
  kind: python_call_eq
  function: Traceback.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra240.tb_module_len_7:
  description: "inspect.Traceback.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra240"
  kind: python_call_eq
  function: Traceback.__module__.__len__
  args: []
  expected: 7

invariant inspect_extra240.tb_bases_0_is_traceback:
  description: "inspect.Traceback.__bases__[0].__name__ == '_Traceback'; new to extra240"
  kind: python_call_eq
  function: "Traceback.__bases__[0].__name__.__eq__"
  args: ["_Traceback"]
  expected: true

invariant inspect_extra240.tb_class_is_type:
  description: "inspect.Traceback.__class__.__name__ == 'type'; new to extra240"
  kind: python_call_eq
  function: Traceback.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra240.tb_qualname_eq:
  description: "inspect.Traceback.__qualname__ == 'Traceback' (len=9); new to extra240"
  kind: python_call_eq
  function: Traceback.__qualname__.__eq__
  args: ["Traceback"]
  expected: true

invariant inspect_extra240.arginfo_name_eq:
  description: "inspect.ArgInfo.__name__ == 'ArgInfo' (len=7); new to extra240"
  kind: python_call_eq
  function: ArgInfo.__name__.__eq__
  args: ["ArgInfo"]
  expected: true

invariant inspect_extra240.arginfo_module_eq:
  description: "inspect.ArgInfo.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra240"
  kind: python_call_eq
  function: ArgInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra240.arginfo_bases_0_is_tuple:
  description: "inspect.ArgInfo.__bases__[0].__name__ == 'tuple' — ArgInfo is a plain namedtuple; new to extra240"
  kind: python_call_eq
  function: "ArgInfo.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true
