spec: concurrent_futures_extra2746
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 630 (_extra2746): __round__, __divmod__, __pow__ dict-presence checks."
    - "concurrent.futures types (Future, ThreadPoolExecutor, ProcessPoolExecutor) are concurrency primitives, not numeric types."
    - "None of these types define rounding, divmod, or power protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __round__ dict-presence checks
#
# Wave 630 theme: concurrent.futures executor and future types do not
# implement the round operator. __round__ does not appear in any of
# these classes' own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2746.round_protocol:
  description: "concurrent.futures types __round__ dict-presence checks — none define rounding in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2746

  columns: [id, function, args, expected]
  rows:
    - ["cf2746001", "concurrent.futures.Future.__dict__.__contains__",              ["__round__"], false]
    - ["cf2746002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__round__"], false]
    - ["cf2746003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__round__"], false]

