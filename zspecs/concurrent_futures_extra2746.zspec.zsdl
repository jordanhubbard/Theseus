  id_prefix: cf2746

  columns: [id, function, args, expected]
  rows:
    - ["cf2746010", "concurrent.futures.Executor.__dict__.__contains__", ["__round__"],  false]
    - ["cf2746011", "concurrent.futures.Executor.__dict__.__contains__", ["__divmod__"], false]
    - ["cf2746012", "concurrent.futures.Executor.__dict__.__contains__", ["__pow__"],    false]
