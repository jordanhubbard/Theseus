# ---------------------------------------------------------------------------
# Table 4: Executor base class __round__/__divmod__/__pow__ checks
#
# Wave 630 theme: concurrent.futures.Executor is the abstract base class for
# ThreadPoolExecutor and ProcessPoolExecutor. It also does not define any
# rounding, divmod, or power operator protocol in its own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2746.executor_base_arithmetic:
  description: "concurrent.futures.Executor __round__/__divmod__/__pow__ dict-presence checks — abstract base class also defines none"
  kind: python_call_eq
