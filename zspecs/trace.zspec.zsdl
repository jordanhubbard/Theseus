spec: trace
version: ">=3.3"
backend: python_module(trace)

docs: https://docs.python.org/3/library/trace.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/trace.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "trace source: Lib/trace.py (PSF; source inspection permitted)"
  not_derived_from:
    - "trace source: sys.settrace internals"
  notes:
    - "trace provides code coverage tracking and execution tracing for Python programs."
    - "Trace is the primary class; it accepts count, trace, countfuncs, countcallers kwargs."
    - "Trace.__bases__[0].__name__ == 'object' — Trace inherits directly from object."
    - "CoverageResults holds coverage data returned by Trace.results()."
    - "CoverageResults.__bases__[0].__name__ == 'object' — inherits directly from object."
    - "Trace methods: run, runfunc, runctx, results."
    - "CoverageResults methods: update, write_results."
    - "trace.__name__ == 'trace'."
    - "All expected values verified by running Python 3.12 trace module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Trace raises ValueError on invalid constructor arguments. CoverageResults.write_results() raises IOError if the output file cannot be written."
  stderr: "null"
  stickiness: "N/A — Trace instances are independent."
  codes: {}

# ---------------------------------------------------------------------------
# module name
# ---------------------------------------------------------------------------

invariant trace.module_name:
  description: "trace.__name__ == 'trace'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["trace"]
  expected: true

# ---------------------------------------------------------------------------
# class names
# ---------------------------------------------------------------------------

table trace.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [Trace,           Trace.__name__.__eq__,           ["Trace"],           true]
    - [CoverageResults, CoverageResults.__name__.__eq__, ["CoverageResults"], true]

# ---------------------------------------------------------------------------
# class modules
# ---------------------------------------------------------------------------

table trace.class_modules:
  kind: python_call_eq
  category: classes
  id_prefix: class_module

  columns: [id, function, args, expected]
  rows:
    - [Trace,           Trace.__module__.__eq__,           ["trace"], true]
    - [CoverageResults, CoverageResults.__module__.__eq__, ["trace"], true]

# ---------------------------------------------------------------------------
# class hierarchy
# ---------------------------------------------------------------------------

invariant trace.hierarchy.Trace_base:
  description: "Trace.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Trace.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant trace.hierarchy.CoverageResults_base:
  description: "CoverageResults.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: CoverageResults.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Trace methods — presence checks via __name__
# ---------------------------------------------------------------------------

table trace.Trace_methods:
  kind: python_call_eq
  category: methods
  id_prefix: Trace_method

  columns: [id, function, args, expected]
  rows:
    - [run,     Trace.run.__name__.__eq__,     ["run"],     true]
    - [runfunc, Trace.runfunc.__name__.__eq__, ["runfunc"], true]
    - [runctx, Trace.runctx.__name__.__eq__,  ["runctx"],  true]
    - [results, Trace.results.__name__.__eq__, ["results"], true]

# ---------------------------------------------------------------------------
# CoverageResults methods — presence checks via __name__
# ---------------------------------------------------------------------------

table trace.CoverageResults_methods:
  kind: python_call_eq
  category: methods
  id_prefix: CoverageResults_method

  columns: [id, function, args, expected]
  rows:
    - [update,       CoverageResults.update.__name__.__eq__,       ["update"],       true]
    - [write_results, CoverageResults.write_results.__name__.__eq__, ["write_results"], true]
