    - [file_class_name_eq_str,
       "__file__.__class__.__name__.__eq__",
       ["str"],
       true,
       "asyncio.__file__.__class__.__name__.__eq__('str') == True — __file__ holds the path to asyncio/__init__.py as a plain Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra199"]
    - [task_name_len_eq_4,
       "Task.__name__.__len__",
       [],
       4,
       "asyncio.Task.__name__.__len__() == 4 — 'Task' has 4 characters; int.__eq__(4) is True; new to extra199"]
    - [future_name_len_eq_6,
       "Future.__name__.__len__",
       [],
       6,
       "asyncio.Future.__name__.__len__() == 6 — 'Future' has 6 characters; int.__eq__(6) is True; new to extra199"]

# ---------------------------------------------------------------------------
