spec: asyncio_extra199
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec covers: asyncio module-level attributes — __name__, __package__, __spec__.name, __file__.__class__.__name__, and __name__.__len__() for Task, Future, Queue, Lock."
    - "asyncio.__name__ == 'asyncio' — the module is registered under the name 'asyncio'. Verified with Python 3.14.3."
    - "asyncio.__package__ == 'asyncio' — asyncio is a package (directory with __init__.py); __package__ equals 'asyncio'. Verified with Python 3.14.3."
    - "asyncio.__spec__.name == 'asyncio' — the ModuleSpec name matches the import name 'asyncio'. Verified with Python 3.14.3."
    - "asyncio.__file__.__class__.__name__ == 'str' — __file__ is a plain Python str holding the path to __init__.py. Verified with Python 3.14.3."
    - "asyncio.Task.__name__.__len__() == 4 — 'Task' has 4 characters. Verified with Python 3.14.3."
    - "asyncio.Future.__name__.__len__() == 6 — 'Future' has 6 characters. Verified with Python 3.14.3."
    - "asyncio.Queue.__name__.__len__() == 5 — 'Queue' has 5 characters. Verified with Python 3.14.3."
    - "asyncio.Lock.__name__.__len__() == 4 — 'Lock' has 4 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio module identity — __name__, __package__, __spec__.name
#
# asyncio.__name__.__eq__('asyncio') == True
# asyncio.__package__.__eq__('asyncio') == True
# asyncio.__spec__.name.__eq__('asyncio') == True
#
# asyncio is a standard-library package. Its __name__, __package__, and
# __spec__.name are all 'asyncio'. New to extra199.
# ---------------------------------------------------------------------------

table asyncio_extra199.module_identity:
  description: "asyncio __name__, __package__, __spec__.name all equal 'asyncio'; asyncio is a stdlib package; new to extra199"
  kind: python_call_eq
  category: string_identity
  id_prefix: asynciomodule199

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq_asyncio,
       __name__.__eq__,
       ["asyncio"],
       true,
       "asyncio.__name__.__eq__('asyncio') == True — the module is registered under the name 'asyncio'; str.__eq__('asyncio') returns True; new to extra199"]
    - [module_package_eq_asyncio,
       __package__.__eq__,
       ["asyncio"],
       true,
       "asyncio.__package__.__eq__('asyncio') == True — asyncio is a package (directory with __init__.py); __package__ equals 'asyncio'; str.__eq__('asyncio') returns True; new to extra199"]
    - [module_spec_name_eq_asyncio,
       __spec__.name.__eq__,
       ["asyncio"],
       true,
       "asyncio.__spec__.name.__eq__('asyncio') == True — the ModuleSpec name matches the import name 'asyncio'; str.__eq__('asyncio') returns True; new to extra199"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.__file__ class and asyncio.Task / asyncio.Future name lengths
#
# asyncio.__file__.__class__.__name__.__eq__('str') == True
# asyncio.Task.__name__.__len__() == 4
# asyncio.Future.__name__.__len__() == 6
#
# __file__ is a plain Python str. Task and Future are public asyncio classes.
# New to extra199.
# ---------------------------------------------------------------------------

table asyncio_extra199.file_class_and_task_future_lens:
  description: "asyncio.__file__.__class__.__name__=='str'; Task.__name__ len==4; Future.__name__ len==6; new to extra199"
