spec: ft2911
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 641 (ft2911): __ilshift__, __irshift__, __ipow__ dict-presence checks for functools types."
    - "functools classes are not numeric types — none define in-place left-shift, right-shift, or power operators."
    - "Verified types: functools.partial, functools.partialmethod, functools.cached_property, functools._lru_cache_wrapper, functools._CacheInfo, functools.singledispatch."
    - "functools._lru_cache_wrapper is the C-level wrapper type produced by functools.lru_cache()."
    - "functools._CacheInfo is the namedtuple class for lru_cache statistics."
    - "functools.singledispatch is the dispatch decorator function; its __dict__ is empty."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft2911.ilshift:
  description: "functools types __ilshift__ dict-presence checks; wave 641"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2911
  columns: [id, function, args, expected]
  rows:
    - ["ft2911001", operator.contains, [functools.partial.__dict__,              "__ilshift__"], false]
    - ["ft2911002", operator.contains, [functools.partialmethod.__dict__,        "__ilshift__"], false]
    - ["ft2911003", operator.contains, [functools.cached_property.__dict__,      "__ilshift__"], false]
    - ["ft2911004", operator.contains, [functools._lru_cache_wrapper.__dict__,   "__ilshift__"], false]
    - ["ft2911005", operator.contains, [functools._CacheInfo.__dict__,           "__ilshift__"], false]
    - ["ft2911006", operator.contains, [functools.singledispatch.__dict__,       "__ilshift__"], false]

