spec: functools_extra147
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.update_wrapper (Python function), functools.wraps (Python function), functools.__all__ (list), functools.reduce (C builtin) — doc string len, __qualname__, __module__, co_argcount, co_varnames len, __all__ class and len (Wave 270)."
    - "functools.update_wrapper.__qualname__ == 'update_wrapper'; co_argcount == 4; co_varnames len == 6; doc len == 458. Verified with Python 3.14.3."
    - "functools.wraps.__qualname__ == 'wraps'; co_argcount == 3; co_varnames len == 3; doc len == 356. Verified with Python 3.14.3."
    - "functools.__all__.__class__.__name__ == 'list'; len(functools.__all__) == 15. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method'; __qualname__ == 'reduce'; __module__ == '_functools'; doc len == 389. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.update_wrapper — Python function qualname, doc, argcount
#
# Wave 270 theme: functools.update_wrapper — pure Python helper that copies
# attributes from wrapped to wrapper functions.
#
# functools.update_wrapper.__class__.__name__ == 'function'
# functools.update_wrapper.__qualname__ == 'update_wrapper' (len 14)
# functools.update_wrapper.__module__ == 'functools' (len 9)
# len(functools.update_wrapper.__doc__) == 458
# functools.update_wrapper.__code__.co_argcount == 4
# len(functools.update_wrapper.__code__.co_varnames) == 6
#
# update_wrapper takes: wrapper, wrapped, assigned, updated.
# co_varnames is ('wrapper', 'wrapped', 'assigned', 'updated', 'attr', 'value').
# New to extra147.
# ---------------------------------------------------------------------------

table functools_extra147.update_wrapper_attrs:
  description: "functools.update_wrapper: Python function, __qualname__ len 14, __module__ len 9, __doc__ len 458, co_argcount 4, co_varnames len 6; wave 270; new to extra147"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsupdatewrapper147

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_class_eq_function,
       "update_wrapper.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.update_wrapper.__class__.__name__.__eq__('function') == True — update_wrapper is a Python function defined in Lib/functools.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra147"]
    - [update_wrapper_qualname_eq,
       "update_wrapper.__qualname__.__eq__",
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__.__eq__('update_wrapper') == True — the function's __qualname__ is 'update_wrapper'; str.__eq__('update_wrapper') returns True; new to extra147"]
    - [update_wrapper_qualname_len_eq_14,
       "update_wrapper.__qualname__.__len__",
       [],
       14,
       "functools.update_wrapper.__qualname__.__len__() == 14 — __qualname__ is 'update_wrapper' which has 14 characters; len('update_wrapper') == 14; new to extra147"]
    - [update_wrapper_module_eq_functools,
       "update_wrapper.__module__.__eq__",
       ["functools"],
       true,
       "functools.update_wrapper.__module__.__eq__('functools') == True — update_wrapper is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra147"]
    - [update_wrapper_doc_len_eq_458,
       "update_wrapper.__doc__.__len__",
       [],
       458,
       "functools.update_wrapper.__doc__.__len__() == 458 — the update_wrapper docstring has 458 characters; len(__doc__) == 458; verified with Python 3.14.3; new to extra147"]
    - [update_wrapper_co_argcount_eq_4,
       "update_wrapper.__code__.co_argcount.__eq__",
       [4],
       true,
       "functools.update_wrapper.__code__.co_argcount.__eq__(4) == True — update_wrapper takes 4 positional-or-keyword arguments: wrapper, wrapped, assigned, updated; co_argcount is 4; int.__eq__(4) returns True; new to extra147"]
    - [update_wrapper_co_varnames_len_eq_6,
       "update_wrapper.__code__.co_varnames.__len__",
       [],
       6,
       "functools.update_wrapper.__code__.co_varnames.__len__() == 6 — co_varnames is ('wrapper', 'wrapped', 'assigned', 'updated', 'attr', 'value'); len == 6; verified with Python 3.14.3; new to extra147"]

# ---------------------------------------------------------------------------
# Table 2: functools.wraps — Python function qualname, doc, argcount
#
# Wave 270 theme: functools.wraps — the decorator form of update_wrapper.
#
# functools.wraps.__class__.__name__ == 'function'
# functools.wraps.__qualname__ == 'wraps' (len 5)
# functools.wraps.__module__ == 'functools' (len 9)
# len(functools.wraps.__doc__) == 356
# functools.wraps.__code__.co_argcount == 3
# len(functools.wraps.__code__.co_varnames) == 3
#
# wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES)
# returns a decorator that applies update_wrapper. New to extra147.
# ---------------------------------------------------------------------------

table functools_extra147.wraps_attrs:
  description: "functools.wraps: Python function, __qualname__ len 5, __module__ len 9, __doc__ len 356, co_argcount 3, co_varnames len 3; wave 270; new to extra147"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswraps147

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_class_eq_function,
       "wraps.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.wraps.__class__.__name__.__eq__('function') == True — wraps is a Python function defined in Lib/functools.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra147"]
    - [wraps_qualname_eq,
       "wraps.__qualname__.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — the function's __qualname__ is 'wraps'; str.__eq__('wraps') returns True; new to extra147"]
    - [wraps_qualname_len_eq_5,
       "wraps.__qualname__.__len__",
       [],
       5,
       "functools.wraps.__qualname__.__len__() == 5 — __qualname__ is 'wraps' which has 5 characters; len('wraps') == 5; new to extra147"]
    - [wraps_module_eq_functools,
       "wraps.__module__.__eq__",
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra147"]
    - [wraps_doc_len_eq_356,
       "wraps.__doc__.__len__",
       [],
       356,
       "functools.wraps.__doc__.__len__() == 356 — the wraps docstring has 356 characters; len(__doc__) == 356; verified with Python 3.14.3; new to extra147"]
    - [wraps_co_argcount_eq_3,
       "wraps.__code__.co_argcount.__eq__",
       [3],
       true,
       "functools.wraps.__code__.co_argcount.__eq__(3) == True — wraps takes 3 positional-or-keyword arguments: wrapped, assigned, updated; co_argcount is 3; int.__eq__(3) returns True; new to extra147"]
    - [wraps_co_varnames_len_eq_3,
       "wraps.__code__.co_varnames.__len__",
       [],
       3,
       "functools.wraps.__code__.co_varnames.__len__() == 3 — co_varnames is ('wrapped', 'assigned', 'updated'); len == 3; verified with Python 3.14.3; new to extra147"]

# ---------------------------------------------------------------------------
# Table 3: functools.__all__ — list identity and length
#
# Wave 270 theme: functools.__all__ — the module's public API list.
#
# functools.__all__.__class__.__name__ == 'list'
# len(functools.__all__) == 15
#
# __all__ controls what is exported by 'from functools import *'.
# It has 15 entries in Python 3.14. New to extra147.
# ---------------------------------------------------------------------------

table functools_extra147.all_list_attrs:
  description: "functools.__all__: list, len 15; wave 270; new to extra147"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsall147

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_eq_list,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "functools.__all__.__class__.__name__.__eq__('list') == True — __all__ is a Python list defined in Lib/functools.py; __class__.__name__ is 'list'; str.__eq__('list') returns True; new to extra147"]
    - [all_len_eq_15,
       "__all__.__len__",
       [],
       15,
       "functools.__all__.__len__() == 15 — functools.__all__ has 15 entries in Python 3.14; len(__all__) == 15; verified with Python 3.14.3; new to extra147"]

# ---------------------------------------------------------------------------
# Table 4: functools.reduce — C builtin identity, qualname, module, doc
#
# Wave 270 theme: functools.reduce — the C builtin reduce function.
#
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__qualname__ == 'reduce' (len 6)
# functools.reduce.__module__ == '_functools' (len 10)
# len(functools.reduce.__doc__) == 389
#
# reduce is implemented in _functoolsmodule.c alongside cmp_to_key.
# It applies a function of two arguments cumulatively to items of a sequence.
# New to extra147.
# ---------------------------------------------------------------------------

table functools_extra147.reduce_attrs:
  description: "functools.reduce: C builtin_function_or_method, __qualname__ len 6, __module__ '_functools' len 10, __doc__ len 389; wave 270; new to extra147"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsreduce147

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_class_eq_builtin,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin from _functoolsmodule.c; __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra147"]
    - [reduce_qualname_eq,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — the C builtin's __qualname__ is 'reduce'; str.__eq__('reduce') returns True; new to extra147"]
    - [reduce_qualname_len_eq_6,
       "reduce.__qualname__.__len__",
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — __qualname__ is 'reduce' which has 6 characters; len('reduce') == 6; new to extra147"]
    - [reduce_module_eq__functools,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is defined in _functoolsmodule.c; __module__ is '_functools'; str.__eq__('_functools') returns True; new to extra147"]
    - [reduce_module_len_eq_10,
       "reduce.__module__.__len__",
       [],
       10,
       "functools.reduce.__module__.__len__() == 10 — __module__ is '_functools' which has 10 characters; len('_functools') == 10; new to extra147"]
    - [reduce_doc_class_eq_str,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — the reduce docstring is a plain Python str; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra147"]
    - [reduce_doc_len_eq_389,
       "reduce.__doc__.__len__",
       [],
       389,
       "functools.reduce.__doc__.__len__() == 389 — the reduce docstring has 389 characters; len(__doc__) == 389; verified with Python 3.14.3; new to extra147"]

