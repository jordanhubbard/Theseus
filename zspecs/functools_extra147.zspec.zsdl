# Standalone invariants — extra147
# ---------------------------------------------------------------------------

invariant functools_extra147.update_wrapper_qualname_len:
  description: "len(functools.update_wrapper.__qualname__) == 14 — __qualname__ is 'update_wrapper'; wave 270; new to extra147"
  kind: python_call_eq
  function: update_wrapper.__qualname__.__len__
  args: []
  expected: 14

