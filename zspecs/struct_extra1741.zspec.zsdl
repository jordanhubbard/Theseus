spec: struct_extra1741
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol dict-presence checks."
    - "struct.Struct is not a descriptor — it defines no __get__, __set__, __delete__, or __set_name__ in its own __dict__."
    - "struct.Struct.__dict__.__contains__('__get__') is False — Struct is a compiled format object, not a descriptor."
    - "struct.Struct.__dict__.__contains__('__set__') is False — Struct defines no __set__."
    - "struct.Struct.__dict__.__contains__('__delete__') is False — Struct defines no __delete__."
    - "struct.Struct.__dict__.__contains__('__set_name__') is False — Struct does not participate in class creation hooks."
    - "struct.error is a subclass of Exception — also not a descriptor; all four checks are False."
    - "Complementary checks: struct.Struct.__dict__ contains 'pack', 'unpack', 'pack_into', 'unpack_from', 'iter_unpack', 'size', 'format'."
    - "struct.Struct.__dict__.__contains__('pack') is True — Struct exposes the pack() method."
    - "struct.Struct.__dict__.__contains__('unpack') is True — Struct exposes the unpack() method."
    - "struct.Struct.__dict__.__contains__('pack_into') is True — Struct exposes pack_into()."
    - "struct.Struct.__dict__.__contains__('unpack_from') is True — Struct exposes unpack_from()."
    - "struct.Struct.__dict__.__contains__('iter_unpack') is True — Struct exposes iter_unpack()."
    - "struct.Struct.__dict__.__contains__('size') is True — Struct exposes the size property."
    - "struct.Struct.__dict__.__contains__('format') is True — Struct exposes the format property."
    - "struct.error.__dict__.__contains__('__get__') is False — error is an Exception subclass, not a descriptor."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: descriptor protocol dict-presence checks for struct types
#
# Wave 563 theme: which struct types define __get__, __set__, __delete__,
# __set_name__ in their own __dict__.
#
# struct.Struct: C extension compiled format object — no descriptor protocol.
#   __get__: False, __set__: False, __delete__: False, __set_name__: False.
# struct.error: Exception subclass — also no descriptor protocol.
#   __get__: False, __set__: False, __delete__: False, __set_name__: False.
# ---------------------------------------------------------------------------

table struct_extra1741.descriptor_protocol:
  description: "struct types descriptor protocol dict-presence checks — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1741

  columns: [id, function, args, expected]
  rows:
    - ["st1741001", "struct.Struct.__dict__.__contains__", ["__get__"],      false]
    - ["st1741002", "struct.Struct.__dict__.__contains__", ["__set__"],      false]
    - ["st1741003", "struct.Struct.__dict__.__contains__", ["__delete__"],   false]
    - ["st1741004", "struct.Struct.__dict__.__contains__", ["__set_name__"], false]
    - ["st1741005", "struct.error.__dict__.__contains__",  ["__get__"],      false]
    - ["st1741006", "struct.error.__dict__.__contains__",  ["__set__"],      false]
    - ["st1741007", "struct.error.__dict__.__contains__",  ["__delete__"],   false]
    - ["st1741008", "struct.error.__dict__.__contains__",  ["__set_name__"], false]

# ---------------------------------------------------------------------------
# Table 2: struct.Struct __dict__ method and attribute presence
#
# struct.Struct is a C extension type exposing pack/unpack methods and
# size/format attributes. These are present in Struct's own __dict__.
#
# struct.Struct.__dict__.__contains__('pack') is True.
# struct.Struct.__dict__.__contains__('unpack') is True.
# struct.Struct.__dict__.__contains__('pack_into') is True.
# struct.Struct.__dict__.__contains__('unpack_from') is True.
# struct.Struct.__dict__.__contains__('iter_unpack') is True.
# struct.Struct.__dict__.__contains__('size') is True.
# struct.Struct.__dict__.__contains__('format') is True.
# struct.Struct.__dict__.__contains__('__doc__') is True.
# struct.Struct.__dict__.__contains__('__sizeof__') is True.
# ---------------------------------------------------------------------------

table struct_extra1741.struct_dict_presence:
  description: "struct.Struct __dict__ method and attribute presence checks — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1741

  columns: [id, function, args, expected]
  rows:
    - ["st1741009", "struct.Struct.__dict__.__contains__", ["pack"],        true]
    - ["st1741010", "struct.Struct.__dict__.__contains__", ["unpack"],      true]
    - ["st1741011", "struct.Struct.__dict__.__contains__", ["pack_into"],   true]
    - ["st1741012", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1741013", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st1741014", "struct.Struct.__dict__.__contains__", ["size"],        true]
    - ["st1741015", "struct.Struct.__dict__.__contains__", ["format"],      true]
    - ["st1741016", "struct.Struct.__dict__.__contains__", ["__doc__"],     true]
    - ["st1741017", "struct.Struct.__dict__.__contains__", ["__sizeof__"],  true]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct class name identity
#
# struct.Struct.__name__ == 'Struct' (len=6).
# struct.Struct.__module__ == 'struct'.
# struct.Struct.__class__.__name__ == 'type'.
# struct.error.__name__ == 'error' (len=5).
# struct.error.__bases__[0].__name__ == 'Exception'.
# ---------------------------------------------------------------------------

table struct_extra1741.struct_class_identity:
  description: "struct.Struct and struct.error class identity checks — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1741

  columns: [id, function, args, expected]
  rows:
    - ["st1741018", "struct.Struct.__name__.__eq__",                  ["Struct"],    true]
    - ["st1741019", "struct.Struct.__module__.__eq__",                ["struct"],    true]
    - ["st1741020", "struct.Struct.__name__.__len__",                 [],            6]
    - ["st1741021", "struct.error.__name__.__eq__",                   ["error"],     true]
    - ["st1741022", "struct.error.__name__.__len__",                  [],            5]
    - ["st1741023", "struct.error.__bases__[0].__name__.__eq__",      ["Exception"], true]
