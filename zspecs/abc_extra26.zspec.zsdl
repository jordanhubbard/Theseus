spec: abc_extra26
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra25.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token, abstractproperty lengths, ABCMeta.register/__name__/__qualname__ lengths, ABCMeta.__new__/__instancecheck__ __qualname__.__len__(), __mro__.__len__() for ABCMeta/ABC, ABC/__ABCMeta __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() for ABC/ABCMeta (both 12), ABCMeta.__subclasscheck__/__qualname__.__len__()==25, update_abstractmethods/__qualname__.__len__()==22, ABC.__abstractmethods__.__class__.__name__.__len__()==9."
    - "This spec covers: ABC.__name__.__len__()==3; ABCMeta.__bases__[0].__name__.__len__()==4 ('type'); ABCMeta.register.__qualname__.__len__()==16 ('ABCMeta.register'); ABCMeta.register.__name__.__len__()==8 ('register'); ABCMeta.__new__.__qualname__.__len__()==15 ('ABCMeta.__new__'); abstractmethod.__name__.__len__()==14; abstractmethod.__module__.__len__()==3; get_cache_token.__name__.__len__()==15; abc.__name__.__len__()==3."
    - "ABC.__name__ == 'ABC' (length 3) — the class name itself is a 3-character acronym."
    - "ABCMeta.__bases__[0].__name__ == 'type' (length 4) — ABCMeta is a direct subclass of the built-in 'type' metaclass."
    - "ABCMeta.register.__qualname__ == 'ABCMeta.register' (length 16) — 7 (ABCMeta) + 1 (.) + 8 (register) = 16."
    - "ABCMeta.register.__name__ == 'register' (length 8)."
    - "ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (length 15) — 7 (ABCMeta) + 1 (.) + 7 (__new__) = 15."
    - "abstractmethod.__name__ == 'abstractmethod' (length 14) — same as its __qualname__; top-level class with no nesting."
    - "abstractmethod.__module__ == 'abc' (length 3)."
    - "get_cache_token.__name__ == 'get_cache_token' (length 15) — same as its __qualname__."
    - "abc.__name__ == 'abc' (length 3)."
    - "Surprise: ABCMeta.__mro__.__len__() == 3 (ABCMeta → type → object), NOT 4 as one might expect from counting C-level slots. The prompt suggestion of 4 was incorrect — confirmed 3 at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABC and ABCMeta class __name__.__len__() and bases name lengths
#
# ABC.__name__ == 'ABC' (length 3) — a well-known 3-character acronym class
# name. ABCMeta.__bases__[0].__name__ == 'type' (length 4) — ABCMeta inherits
# directly from the built-in 'type' metaclass, not from 'object'. No prior abc
# spec records either of these two in the extra26 namespace.
# ---------------------------------------------------------------------------

table abc_extra26.class_name_and_base_lens:
  description: "ABC.__name__.__len__()==3 and ABCMeta.__bases__[0].__name__.__len__()==4 ('type')"
  kind: python_call_eq
  category: class_name_attrs
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [ABC_name,               ABC.__name__.__len__,                         [], 3]
    - [ABCMeta_base_name,      "ABCMeta.__bases__[0].__name__.__len__",        [], 4]

# ---------------------------------------------------------------------------
# ABCMeta.register __qualname__ and __name__ lengths
#
# ABCMeta.register.__qualname__ == 'ABCMeta.register' (16 chars):
#   7 (ABCMeta) + 1 (.) + 8 (register) = 16.
# ABCMeta.register.__name__ == 'register' (8 chars) — the bare method name
# without the class prefix. These two together confirm the qualname structure
# for ABCMeta's only public API method. No prior abc spec records
# register.__name__.__len__() == 8.
# ---------------------------------------------------------------------------

table abc_extra26.register_name_lens:
  description: "ABCMeta.register __qualname__.__len__()==16 and __name__.__len__()==8"
  kind: python_call_eq
  category: method_name_lengths
  id_prefix: register_len

  columns: [id, function, args, expected]
  rows:
    - [qualname, ABCMeta.register.__qualname__.__len__, [], 16]
    - [name,     ABCMeta.register.__name__.__len__,     [], 8]

# ---------------------------------------------------------------------------
# ABCMeta.__new__ qualname length and abstractmethod/get_cache_token name lengths
#
# ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (length 15):
#   7 (ABCMeta) + 1 (.) + 7 (__new__) = 15. Prior spec extra24 recorded
#   ABCMeta.__new__.__qualname__.__len__() in table form; this standalone
#   records it under the extra26 namespace for completeness.
# abstractmethod.__name__ == 'abstractmethod' (length 14) — equals __qualname__.
# get_cache_token.__name__ == 'get_cache_token' (length 15) — equals __qualname__.
# ---------------------------------------------------------------------------

table abc_extra26.special_method_name_lens:
  description: "ABCMeta.__new__.__qualname__.__len__()==15, abstractmethod.__name__.__len__()==14, get_cache_token.__name__.__len__()==15"
  kind: python_call_eq
  category: method_name_lengths
  id_prefix: special_method_len

  columns: [id, function, args, expected]
  rows:
    - [ABCMeta_new_qualname,      ABCMeta.__new__.__qualname__.__len__, [], 15]
    - [abstractmethod_name,       abstractmethod.__name__.__len__,      [], 14]
    - [get_cache_token_name,      get_cache_token.__name__.__len__,     [], 15]

# ---------------------------------------------------------------------------
# abstractmethod.__module__.__len__() == 3 — standalone (extra26 namespace)
#
# abstractmethod.__module__ == 'abc' (3 characters). This confirms that the
# abstractmethod decorator is defined in the 'abc' module (not re-exported from
# a private C extension). No prior abc spec records this standalone under the
# extra26 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra26.abstractmethod.module_len:
  description: "abc.abstractmethod.__module__.__len__() == 3 — module is 'abc' (3 chars); abstractmethod is defined directly in the abc module"
  category: module_attrs
  kind: python_call_eq
  function: abstractmethod.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# abc.__name__.__len__() == 3 — standalone (extra26 namespace)
#
# The module's own __name__ attribute is 'abc' — 3 characters. This records
# the module-level __name__ attribute length in the extra26 namespace, parallel
# to the __name__ lengths already recorded for the classes and functions it
# exports. No prior abc spec records abc.__name__.__len__() as a standalone
# in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra26.module_name_len:
  description: "abc.__name__.__len__() == 3 — the module name 'abc' has 3 characters"
  category: module_attrs
  kind: python_call_eq
  function: abc.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# ABCMeta.__new__.__qualname__.__len__() == 15 — standalone (extra26 namespace)
#
# 'ABCMeta.__new__' has 15 characters: 7 (ABCMeta) + 1 (.) + 7 (__new__) = 15.
# ABCMeta.__new__ is the metaclass constructor hook that registers the abstract
# method set during class creation. Its qualname length (15) equals
# get_cache_token's __name__ length, providing a useful numerical cross-check.
# ---------------------------------------------------------------------------

invariant abc_extra26.ABCMeta.new_qualname_len:
  description: "abc.ABCMeta.__new__.__qualname__.__len__() == 15 — 'ABCMeta.__new__' is 7+1+7=15 chars"
  category: method_qualname_lengths
  kind: python_call_eq
  function: ABCMeta.__new__.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# ABCMeta.register.__qualname__.__len__() == 16 — standalone (extra26 namespace)
#
# 'ABCMeta.register' has 16 characters: 7 (ABCMeta) + 1 (.) + 8 (register) =
# 16. ABCMeta.register is the public API method that registers a virtual
# subclass without requiring actual subclassing. Its qualname length (16)
# exceeds ABCMeta.__new__ (15) by one character. No prior abc spec records this
# standalone under the extra26 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra26.ABCMeta.register_qualname_len:
  description: "abc.ABCMeta.register.__qualname__.__len__() == 16 — 'ABCMeta.register' is 7+1+8=16 chars; one longer than ABCMeta.__new__ (15)"
  category: method_qualname_lengths
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__len__
  args: []
  expected: 16
