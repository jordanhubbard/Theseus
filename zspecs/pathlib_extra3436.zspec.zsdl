spec: pp3436
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 676 (pp3436): __le__, __gt__, __ge__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __le__/__gt__/__ge__ dict-presence (x<=y, x>y, x>=y)."
    - "pathlib.PurePath defines __le__, __gt__, __ge__ (all true): PurePath supports full path ordering."
    - "PurePosixPath, PureWindowsPath, Path, PosixPath all inherit these from PurePath and do not define them in their own __dict__ (false)."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __le__ dict-presence — operator.contains(Cls.__dict__, '__le__')
#
# pathlib.PurePath DOES define __le__ in its own __dict__: true.
# PurePath objects support <= comparison for path ordering.
# All subclasses (PurePosixPath, PureWindowsPath, Path, PosixPath) inherit
# __le__ from PurePath and do not define it in their own __dict__: false.
# ---------------------------------------------------------------------------

table pp3436.le:
  description: "pathlib types __le__ dict-presence checks; wave 676"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3436

  columns: [id, function, args, expected]
  rows:
    - ["pp3436001", operator.contains, [pathlib.PurePath.__dict__,         "__le__"], true]
    - ["pp3436002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__le__"], false]
    - ["pp3436003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__le__"], false]
    - ["pp3436004", operator.contains, [pathlib.Path.__dict__,             "__le__"], false]
    - ["pp3436005", operator.contains, [pathlib.PosixPath.__dict__,        "__le__"], false]

