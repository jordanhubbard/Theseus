spec: mailcap_extra
version: ">=3.9,<3.13"
backend: python_module(mailcap)

docs: https://docs.python.org/3/library/mailcap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mailcap.html — Python mailcap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/mailcap.py"
  notes:
    - "The mailcap module was deprecated in Python 3.11 and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "mailcap.findmatch is the primary lookup function; __name__ == 'findmatch', __module__ == 'mailcap'."
    - "mailcap.getcaps reads and returns the system mailcap database; __name__ == 'getcaps', __module__ == 'mailcap'."
    - "mailcap.lookup is an internal helper not part of the public API; it may or may not be exported."
    - "mailcap.findmatch returns a (command, entry) tuple or (None, None) if no match is found."
    - "mailcap.getcaps returns a dict mapping MIME types to lists of mailcap entries."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# findmatch — function name and module affiliation
# ---------------------------------------------------------------------------

invariant mailcap_extra.findmatch.name:
  description: "mailcap.findmatch.__name__ == 'findmatch'"
  category: functions
  kind: python_call_eq
  function: findmatch.__name__.__eq__
  args: ["findmatch"]
  expected: true

invariant mailcap_extra.findmatch.module:
  description: "mailcap.findmatch.__module__ == 'mailcap'"
  category: functions
  kind: python_call_eq
  function: findmatch.__module__.__eq__
  args: ["mailcap"]
  expected: true

invariant mailcap_extra.findmatch.is_function:
  description: "mailcap.findmatch is a plain Python function"
  category: functions
  kind: python_call_eq
  function: findmatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# getcaps — function name and module affiliation
# ---------------------------------------------------------------------------

invariant mailcap_extra.getcaps.name:
  description: "mailcap.getcaps.__name__ == 'getcaps'"
  category: functions
  kind: python_call_eq
  function: getcaps.__name__.__eq__
  args: ["getcaps"]
  expected: true

invariant mailcap_extra.getcaps.module:
  description: "mailcap.getcaps.__module__ == 'mailcap'"
  category: functions
  kind: python_call_eq
  function: getcaps.__module__.__eq__
  args: ["mailcap"]
  expected: true

invariant mailcap_extra.getcaps.is_function:
  description: "mailcap.getcaps is a plain Python function"
  category: functions
  kind: python_call_eq
  function: getcaps.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# getcaps() return type — must return a dict
# ---------------------------------------------------------------------------

invariant mailcap_extra.getcaps.return_is_dict:
  description: "mailcap.getcaps() returns a dict"
  category: return_types
  kind: python_call_eq
  function: getcaps
  args: []
  method: __class__.__name__.__eq__
  method_args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# findmatch() no-match return type — returns a tuple when no caps found
#
# With an empty caps dict, findmatch returns (None, None).
# We verify the return value is a tuple and has length 2.
# ---------------------------------------------------------------------------

invariant mailcap_extra.findmatch.return_is_tuple:
  description: "mailcap.findmatch({}, 'text/plain') returns a tuple"
  category: return_types
  kind: python_call_eq
  function: findmatch
  args: [{}, "text/plain"]
  method: __class__.__name__.__eq__
  method_args: ["tuple"]
  expected: true

invariant mailcap_extra.findmatch.return_len_two:
  description: "mailcap.findmatch({}, 'text/plain') returns a 2-tuple"
  category: return_types
  kind: python_call_eq
  function: findmatch
  args: [{}, "text/plain"]
  method: __len__
  method_args: []
  expected: 2

invariant mailcap_extra.findmatch.no_match_first_none:
  description: "mailcap.findmatch({}, 'text/plain')[0] is None when no caps"
  category: return_types
  kind: python_call_eq
  function: findmatch
  args: [{}, "text/plain"]
  method: __getitem__
  method_args: [0]
  expected: null

# ---------------------------------------------------------------------------
# lookup — internal helper (present in CPython <3.13 mailcap implementation)
# ---------------------------------------------------------------------------

invariant mailcap_extra.lookup.name:
  description: "mailcap.lookup.__name__ == 'lookup' (internal helper function)"
  category: functions
  kind: python_call_eq
  function: lookup.__name__.__eq__
  args: ["lookup"]
  expected: true

invariant mailcap_extra.lookup.module:
  description: "mailcap.lookup.__module__ == 'mailcap'"
  category: functions
  kind: python_call_eq
  function: lookup.__module__.__eq__
  args: ["mailcap"]
  expected: true
