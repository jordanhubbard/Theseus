spec: re_extra243
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra95.zspec.zsdl — covers subn and escape __qualname__ equality and lengths"
    - "re_extra99.zspec.zsdl — covers function __code__.co_name and co_argcount"
  notes:
    - "This spec covers: re.subn and re.escape function identity and behavioral contracts."
    - "re.subn.__name__ == 'subn' — length 4; verified Python 3.14.3 macOS."
    - "re.subn.__module__ == 're' — length 2; verified Python 3.14.3 macOS."
    - "re.subn.__qualname__ == 'subn' — length 4; verified Python 3.14.3 macOS."
    - "re.escape.__name__ == 'escape' — length 6; verified Python 3.14.3 macOS."
    - "re.escape.__module__ == 're' — length 2; verified Python 3.14.3 macOS."
    - "re.escape.__qualname__ == 'escape' — length 6; verified Python 3.14.3 macOS."
    - "re.subn(r'\\d', 'X', 'a1b2') == ('aXbX', 2) — subn returns a 2-tuple of (new_string, count); verified Python 3.14.3 macOS."
    - "re.escape('a.b') == 'a\\.b' — escape adds a backslash before the dot; length 4; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.subn function identity: __name__, __module__, __qualname__
# subn.__name__ == 'subn' (len=4), __module__ == 're' (len=2), __qualname__ == 'subn' (len=4).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra243.subn_identity:
  description: "re.subn function identity: __name__, __module__, __qualname__ equality; verified Python 3.14.3"
  kind: python_call_eq
  category: func_identity
  id_prefix: resubn243

  columns: [id, function, args, expected]
  rows:
    - [subn_name_eq,      subn.__name__.__eq__,      ["subn"], true]
    - [subn_name_not_sub, subn.__name__.__eq__,      ["sub"],  false]
    - [subn_module_eq,    subn.__module__.__eq__,    ["re"],   true]
    - [subn_module_not,   subn.__module__.__eq__,    ["sre"],  false]
    - [subn_qualname_eq,  subn.__qualname__.__eq__,  ["subn"], true]

# ---------------------------------------------------------------------------
# re.escape function identity: __name__, __module__, __qualname__
# escape.__name__ == 'escape' (len=6), __module__ == 're' (len=2), __qualname__ == 'escape' (len=6).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra243.escape_identity:
  description: "re.escape function identity: __name__, __module__, __qualname__ equality; verified Python 3.14.3"
  kind: python_call_eq
  category: func_identity
  id_prefix: reescape243

  columns: [id, function, args, expected]
  rows:
    - [escape_name_eq,     escape.__name__.__eq__,     ["escape"], true]
    - [escape_name_not,    escape.__name__.__eq__,     ["subn"],   false]
    - [escape_module_eq,   escape.__module__.__eq__,   ["re"],     true]
    - [escape_module_not,  escape.__module__.__eq__,   ["sre"],    false]
    - [escape_qualname_eq, escape.__qualname__.__eq__, ["escape"], true]

# ---------------------------------------------------------------------------
# re.subn and re.escape __name__ and __qualname__ string lengths
# subn: __name__ len=4, __qualname__ len=4; escape: __name__ len=6, __qualname__ len=6.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra243.subn_escape_name_lengths:
  description: "re.subn and re.escape __name__ and __qualname__ string lengths; verified Python 3.14.3"
  kind: python_call_eq
  category: func_identity
  id_prefix: resubn243

  columns: [id, function, args, expected]
  rows:
    - [subn_name_len,     subn.__name__.__len__,     [], 4]
    - [subn_qualname_len, subn.__qualname__.__len__,  [], 4]
    - [subn_module_len,   subn.__module__.__len__,   [], 2]
    - [escape_name_len,   escape.__name__.__len__,   [], 6]
    - [escape_qname_len,  escape.__qualname__.__len__, [], 6]
    - [escape_module_len, escape.__module__.__len__,  [], 2]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra243.subn.name_eq:
  description: "re.subn.__name__ == 'subn' — the function's __name__ attribute; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: subn.__name__.__eq__
  args: ["subn"]
  expected: true

invariant re_extra243.subn.module_is_re:
  description: "re.subn.__module__ == 're' — subn is defined in the re module; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: subn.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra243.subn.qualname_eq:
  description: "re.subn.__qualname__ == 'subn' — subn is a module-level function so __qualname__ equals __name__; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: subn.__qualname__.__eq__
  args: ["subn"]
  expected: true

invariant re_extra243.escape.name_eq:
  description: "re.escape.__name__ == 'escape' — the function's __name__ attribute; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: escape.__name__.__eq__
  args: ["escape"]
  expected: true

invariant re_extra243.escape.module_is_re:
  description: "re.escape.__module__ == 're' — escape is defined in the re module; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: escape.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra243.escape.qualname_eq:
  description: "re.escape.__qualname__ == 'escape' — escape is a module-level function so __qualname__ equals __name__; verified Python 3.14.3 macOS"
  category: func_identity
  kind: python_call_eq
  function: escape.__qualname__.__eq__
  args: ["escape"]
  expected: true

invariant re_extra243.subn.result_count:
  description: "re.subn(r'\\d', 'X', 'a1b2')[1] == 2 — subn replaces each digit; 'a1b2' has 2 digits so count is 2; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: subn.__call__
  args: ["\\d", "X", "a1b2"]
  method: __getitem__
  method_args: [1]
  expected: 2

invariant re_extra243.escape.result_len:
  description: "len(re.escape('a.b')) == 4 — escape turns 'a.b' into 'a\\.b' which has 4 characters; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: escape.__call__
  args: ["a.b"]
  method: __len__
  method_args: []
  expected: 4
