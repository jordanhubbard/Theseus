spec: abc_extra80
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra79.zspec.zsdl."
    - "This spec covers: wave 246 theme — abc abstractmethod/abstractproperty/abstractclassmethod/abstractstaticmethod __dict__ lengths and ABCMeta __new__/register/register code attributes. NOTE: ABCMeta.__init__ is a wrapper_descriptor (from type.__init__) and has no __code__; use ABCMeta.__new__ instead (which IS defined directly on ABCMeta with __code__). NEW in extra80: abstractmethod.__dict__.__len__()==0; abstractproperty.__dict__.__len__()==7; abstractclassmethod.__dict__.__len__()==7; abstractstaticmethod.__dict__.__len__()==7; ABCMeta.__new__.__code__.co_name=='__new__'; ABCMeta.__new__.__code__.co_argcount==4 (mcls, name, bases, namespace); ABCMeta.__new__.__code__.co_varnames.__len__()==6; ABCMeta.__new__.__qualname__=='ABCMeta.__new__'; ABCMeta.__new__.__qualname__.__len__()==15; ABCMeta.register.__code__.co_name=='register'; ABCMeta._dump_registry.__code__.co_name=='_dump_registry'; update_abstractmethods.__code__.co_varnames.__len__()==5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__dict__.__len__() == 0. abstractmethod is a decorator function with an empty class __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__dict__.__len__() == 7. abstractproperty defines 7 entries: __module__, __firstlineno__, __doc__, __isabstractmethod__, __static_attributes__, __dict__, __weakref__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__dict__.__len__() == 7. abstractclassmethod defines 7 entries: __module__, __firstlineno__, __doc__, __isabstractmethod__, __init__, __static_attributes__, __weakref__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__dict__.__len__() == 7. abstractstaticmethod defines 7 entries: __module__, __firstlineno__, __doc__, __isabstractmethod__, __init__, __static_attributes__, __weakref__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__code__.co_name == '__new__'. __new__ is defined directly on ABCMeta (unlike __init__ which is inherited from type). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__code__.co_argcount == 4. __new__ takes 4 positional args: mcls, name, bases, namespace. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__code__.co_varnames.__len__() == 6. co_varnames includes (mcls, name, bases, namespace, kwargs, cls). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__'. Qualified name includes the enclosing class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__qualname__.__len__() == 15. 'ABCMeta.__new__' has 15 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_name == 'register'. register is defined directly on ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta._dump_registry.__code__.co_name == '_dump_registry'. _dump_registry is defined directly on ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_varnames.__len__() == 5. co_varnames includes (cls, abstracts, scls, name, value). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc abstract decorator __dict__.__len__() checks — extra80
#
# Wave 246 theme: abc abstractmethod/abstractproperty/abstractclassmethod/abstractstaticmethod
# __dict__ lengths and ABCMeta __new__ code attributes.
#
# abstractmethod.__dict__.__len__() == 0
# abstractproperty.__dict__.__len__() == 7
# abstractclassmethod.__dict__.__len__() == 7
# abstractstaticmethod.__dict__.__len__() == 7
# ---------------------------------------------------------------------------

table abc_extra80.abstract_decorator_dict_lengths:
  description: "abc abstract decorator __dict__.__len__() checks in abcextra80 namespace — wave 246 theme: abc abstractmethod/abstractproperty/abstractclassmethod/abstractstaticmethod __dict__ lengths; abstractmethod.__dict__.__len__()==0 (abstractmethod is a decorator function with empty class dict); abstractproperty.__dict__.__len__()==7 (defines __module__, __firstlineno__, __doc__, __isabstractmethod__, __static_attributes__, __dict__, __weakref__); abstractclassmethod.__dict__.__len__()==7; abstractstaticmethod.__dict__.__len__()==7; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra80

  columns: [id, function, args, expected, description]
  rows:
    - [am_dict_len,    "abstractmethod.__dict__.__len__",      [], 0, "abstractmethod.__dict__.__len__() == 0 — abstractmethod has an empty class dict; verified with Python 3.14.3"]
    - [ap_dict_len,    "abstractproperty.__dict__.__len__",    [], 7, "abstractproperty.__dict__.__len__() == 7 — abstractproperty defines 7 entries including __isabstractmethod__; verified with Python 3.14.3"]
    - [acm_dict_len,   "abstractclassmethod.__dict__.__len__", [], 7, "abstractclassmethod.__dict__.__len__() == 7 — abstractclassmethod defines 7 entries including __isabstractmethod__ and __init__; verified with Python 3.14.3"]
    - [asm_dict_len,   "abstractstaticmethod.__dict__.__len__", [], 7, "abstractstaticmethod.__dict__.__len__() == 7 — abstractstaticmethod defines 7 entries including __isabstractmethod__ and __init__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta.__new__ code attributes — extra80
#
# ABCMeta.__new__.__code__.co_name == '__new__'
# ABCMeta.__new__.__code__.co_argcount == 4
# ABCMeta.__new__.__code__.co_varnames.__len__() == 6
# ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__'
# ABCMeta.__new__.__qualname__.__len__() == 15
# ---------------------------------------------------------------------------

table abc_extra80.ABCMeta_new_code_attrs:
  description: "abc ABCMeta.__new__ code attribute checks in abcextra80 namespace — wave 246 theme: abc ABCMeta __new__ code attributes; ABCMeta.__new__.__code__.co_name=='__new__' (co_name is the function name as string); ABCMeta.__new__.__code__.co_argcount==4 (__new__ takes mcls, name, bases, namespace as positional args); ABCMeta.__new__.__code__.co_varnames.__len__()==6 (co_varnames includes mcls, name, bases, namespace, kwargs, cls); ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (qualified name includes enclosing class); ABCMeta.__new__.__qualname__.__len__()==15 ('ABCMeta.__new__' is 15 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra80a

  columns: [id, function, args, expected, description]
  rows:
    - [new_co_name,       ABCMeta.__new__.__code__.co_name.__eq__,           ["__new__"],         true, "ABCMeta.__new__.__code__.co_name == '__new__' — code object function name; verified with Python 3.14.3"]
    - [new_co_argcount,   "ABCMeta.__new__.__code__.co_argcount.__eq__",     [4],                 true, "ABCMeta.__new__.__code__.co_argcount == 4 — mcls, name, bases, namespace are positional args; verified with Python 3.14.3"]
    - [new_co_varnames_len, "ABCMeta.__new__.__code__.co_varnames.__len__",  [],                  6,    "ABCMeta.__new__.__code__.co_varnames.__len__() == 6 — includes mcls, name, bases, namespace, kwargs, cls; verified with Python 3.14.3"]
    - [new_qualname,       ABCMeta.__new__.__qualname__.__eq__,              ["ABCMeta.__new__"], true, "ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' — qualified name includes enclosing class; verified with Python 3.14.3"]
    - [new_qualname_len,   "ABCMeta.__new__.__qualname__.__len__",           [],                  15,   "ABCMeta.__new__.__qualname__.__len__() == 15 — 'ABCMeta.__new__' has 15 characters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta.register and _dump_registry code attributes — extra80
#
# ABCMeta.register.__code__.co_name == 'register'
# ABCMeta._dump_registry.__code__.co_name == '_dump_registry'
# ABCMeta._dump_registry.__code__.co_varnames.__len__() == 6
# ABCMeta.register.__qualname__ == 'ABCMeta.register'
# ---------------------------------------------------------------------------

table abc_extra80.ABCMeta_register_and_dump_code_attrs:
  description: "abc ABCMeta.register and _dump_registry code attribute checks in abcextra80 namespace — wave 246 theme: abc ABCMeta method code attributes; ABCMeta.register.__code__.co_name=='register' (register is defined directly on ABCMeta); ABCMeta._dump_registry.__code__.co_name=='_dump_registry' (_dump_registry is defined directly on ABCMeta); ABCMeta._dump_registry.__code__.co_varnames.__len__()==6 (includes cls, file, _abc_registry, _abc_cache, _abc_negative_cache, _abc_negative_cache_version); ABCMeta.register.__qualname__=='ABCMeta.register'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra80b

  columns: [id, function, args, expected, description]
  rows:
    - [reg_co_name,       ABCMeta.register.__code__.co_name.__eq__,          ["register"],        true, "ABCMeta.register.__code__.co_name == 'register' — register is defined directly on ABCMeta; verified with Python 3.14.3"]
    - [dump_co_name,      ABCMeta._dump_registry.__code__.co_name.__eq__,    ["_dump_registry"],  true, "ABCMeta._dump_registry.__code__.co_name == '_dump_registry' — _dump_registry is defined directly on ABCMeta; verified with Python 3.14.3"]
    - [dump_varnames_len, "ABCMeta._dump_registry.__code__.co_varnames.__len__", [],              6,    "ABCMeta._dump_registry.__code__.co_varnames.__len__() == 6 — includes cls, file, _abc_registry, _abc_cache, _abc_negative_cache, _abc_negative_cache_version; verified with Python 3.14.3"]
    - [reg_qualname,      ABCMeta.register.__qualname__.__eq__,              ["ABCMeta.register"], true, "ABCMeta.register.__qualname__ == 'ABCMeta.register' — qualified name includes enclosing class; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc update_abstractmethods and cross-check — extra80
#
# update_abstractmethods.__code__.co_varnames.__len__() == 5
# update_abstractmethods.__code__.co_name == 'update_abstractmethods'
# abstractmethod.__dict__.__len__() == 0 (cross-check)
# abstractproperty.__dict__.__len__() == 7 (cross-check)
# ---------------------------------------------------------------------------

table abc_extra80.update_abstractmethods_and_cross_checks:
  description: "abc update_abstractmethods code attribute checks and cross-checks in abcextra80 namespace — wave 246 theme: abc ABCMeta code attributes; update_abstractmethods.__code__.co_varnames.__len__()==5 (co_varnames includes cls, abstracts, scls, name, value); update_abstractmethods.__code__.co_name=='update_abstractmethods'; abstractmethod.__dict__.__len__()==0 (cross-check); abstractproperty.__dict__.__len__()==7 (cross-check); ABCMeta.__new__.__code__.co_name=='__new__' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra80c

  columns: [id, function, args, expected, description]
  rows:
    - [uam_varnames_len,  "update_abstractmethods.__code__.co_varnames.__len__", [], 5, "update_abstractmethods.__code__.co_varnames.__len__() == 5 — includes cls, abstracts, scls, name, value; verified with Python 3.14.3"]
    - [uam_co_name,       update_abstractmethods.__code__.co_name.__eq__,        ["update_abstractmethods"], true, "update_abstractmethods.__code__.co_name == 'update_abstractmethods' — code object function name; verified with Python 3.14.3"]
    - [am_dict_cross,     "abstractmethod.__dict__.__len__",                      [],                        0,    "abstractmethod.__dict__.__len__() == 0 — cross-check; verified with Python 3.14.3"]
    - [ap_dict_cross,     "abstractproperty.__dict__.__len__",                    [],                        7,    "abstractproperty.__dict__.__len__() == 7 — cross-check; verified with Python 3.14.3"]
    - [new_co_name_cross, ABCMeta.__new__.__code__.co_name.__eq__,               ["__new__"],               true, "ABCMeta.__new__.__code__.co_name == '__new__' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra80
# ---------------------------------------------------------------------------

invariant abc_extra80.abstractmethod_dict_len:
  description: "abc.abstractmethod.__dict__.__len__() == 0 — abstractmethod is a decorator function with an empty class __dict__; it uses slots or stores instance attributes directly rather than class-level attributes; NEW in extra80: first standalone __dict__.__len__ invariant for abstractmethod in abcextra80 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__dict__.__len__
  args: []
  expected: 0

invariant abc_extra80.abstractproperty_dict_len:
  description: "abc.abstractproperty.__dict__.__len__() == 7 — abstractproperty defines 7 entries in its class dict including __module__, __firstlineno__, __doc__, __isabstractmethod__, __static_attributes__, __dict__, __weakref__; NEW in extra80: first standalone __dict__.__len__ invariant for abstractproperty in abcextra80 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abstractproperty.__dict__.__len__
  args: []
  expected: 7

invariant abc_extra80.ABCMeta_new_co_name:
  description: "abc.ABCMeta.__new__.__code__.co_name.__eq__('__new__') returns True — ABCMeta.__new__ is defined directly on ABCMeta (unlike __init__ which is a wrapper_descriptor from type); its co_name is '__new__'; NEW in extra80: first standalone co_name invariant for ABCMeta.__new__ in abcextra80 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__new__.__code__.co_name.__eq__
  args: ["__new__"]
  expected: true

invariant abc_extra80.ABCMeta_new_qualname:
  description: "abc.ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__') returns True — ABCMeta.__new__ is qualified with the enclosing ABCMeta class name; NEW in extra80: first standalone __qualname__ invariant for ABCMeta.__new__ in abcextra80 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__new__.__qualname__.__eq__
  args: ["ABCMeta.__new__"]
  expected: true

invariant abc_extra80.update_abstractmethods_varnames_len:
  description: "abc.update_abstractmethods.__code__.co_varnames.__len__() == 5 — update_abstractmethods has 5 local variables: cls, abstracts, scls, name, value; NEW in extra80: first standalone co_varnames.__len__ invariant for update_abstractmethods in abcextra80 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: update_abstractmethods.__code__.co_varnames.__len__
  args: []
  expected: 5
