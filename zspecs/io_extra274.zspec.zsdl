spec: io_extra274
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io.BytesIO is a C-extension class; its methods are method_descriptor objects."
    - "BytesIO methods: read, write, readline, seek, tell, getvalue, getbuffer, truncate all have __class__.__name__ == 'method_descriptor'."
    - "BytesIO method qualnames follow 'BytesIO.<method_name>' pattern."
    - "io.FileIO is also C-backed; its read, readall, write methods are method_descriptor objects."
    - "FileIO method qualnames follow 'FileIO.<method_name>' pattern."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: BytesIO method __name__ identity
# ---------------------------------------------------------------------------

table io_extra274.bytesio_method_names:
  description: "io.BytesIO method __name__ for read, write, readline, seek, tell, getvalue, getbuffer, truncate"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [read_name,      BytesIO.read.__name__.__eq__,      ["read"],      true, "io.BytesIO.read.__name__ == 'read'"]
    - [write_name,     BytesIO.write.__name__.__eq__,     ["write"],     true, "io.BytesIO.write.__name__ == 'write'"]
    - [readline_name,  BytesIO.readline.__name__.__eq__,  ["readline"],  true, "io.BytesIO.readline.__name__ == 'readline'"]
    - [seek_name,      BytesIO.seek.__name__.__eq__,      ["seek"],      true, "io.BytesIO.seek.__name__ == 'seek'"]
    - [tell_name,      BytesIO.tell.__name__.__eq__,      ["tell"],      true, "io.BytesIO.tell.__name__ == 'tell'"]
    - [getvalue_name,  BytesIO.getvalue.__name__.__eq__,  ["getvalue"],  true, "io.BytesIO.getvalue.__name__ == 'getvalue'"]
    - [getbuffer_name, BytesIO.getbuffer.__name__.__eq__, ["getbuffer"], true, "io.BytesIO.getbuffer.__name__ == 'getbuffer'"]
    - [truncate_name,  BytesIO.truncate.__name__.__eq__,  ["truncate"],  true, "io.BytesIO.truncate.__name__ == 'truncate'"]

# ---------------------------------------------------------------------------
# Table: BytesIO method __class__.__name__ (all method_descriptor)
# ---------------------------------------------------------------------------

table io_extra274.bytesio_method_classes:
  description: "io.BytesIO method __class__.__name__ for read, write, readline, seek, tell, getvalue, getbuffer, truncate"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [read_class,      BytesIO.read.__class__.__name__.__eq__,      ["method_descriptor"], true, "io.BytesIO.read.__class__.__name__ == 'method_descriptor'"]
    - [write_class,     BytesIO.write.__class__.__name__.__eq__,     ["method_descriptor"], true, "io.BytesIO.write.__class__.__name__ == 'method_descriptor'"]
    - [readline_class,  BytesIO.readline.__class__.__name__.__eq__,  ["method_descriptor"], true, "io.BytesIO.readline.__class__.__name__ == 'method_descriptor'"]
    - [seek_class,      BytesIO.seek.__class__.__name__.__eq__,      ["method_descriptor"], true, "io.BytesIO.seek.__class__.__name__ == 'method_descriptor'"]
    - [tell_class,      BytesIO.tell.__class__.__name__.__eq__,      ["method_descriptor"], true, "io.BytesIO.tell.__class__.__name__ == 'method_descriptor'"]
    - [getvalue_class,  BytesIO.getvalue.__class__.__name__.__eq__,  ["method_descriptor"], true, "io.BytesIO.getvalue.__class__.__name__ == 'method_descriptor'"]
    - [getbuffer_class, BytesIO.getbuffer.__class__.__name__.__eq__, ["method_descriptor"], true, "io.BytesIO.getbuffer.__class__.__name__ == 'method_descriptor'"]
    - [truncate_class,  BytesIO.truncate.__class__.__name__.__eq__,  ["method_descriptor"], true, "io.BytesIO.truncate.__class__.__name__ == 'method_descriptor'"]

# ---------------------------------------------------------------------------
# Standalone invariants: BytesIO qualnames and FileIO identity
# ---------------------------------------------------------------------------

invariant io_extra274.BytesIO.read.qualname:
  description: "io.BytesIO.read.__qualname__ == 'BytesIO.read'"
  category: identity
  kind: python_call_eq
  function: BytesIO.read.__qualname__.__eq__
  args: ["BytesIO.read"]
  expected: true

invariant io_extra274.BytesIO.write.qualname:
  description: "io.BytesIO.write.__qualname__ == 'BytesIO.write'"
  category: identity
  kind: python_call_eq
  function: BytesIO.write.__qualname__.__eq__
  args: ["BytesIO.write"]
  expected: true

invariant io_extra274.FileIO.read.name:
  description: "io.FileIO.read.__name__ == 'read'"
  category: identity
  kind: python_call_eq
  function: FileIO.read.__name__.__eq__
  args: ["read"]
  expected: true

invariant io_extra274.FileIO.readall.name:
  description: "io.FileIO.readall.__name__ == 'readall'"
  category: identity
  kind: python_call_eq
  function: FileIO.readall.__name__.__eq__
  args: ["readall"]
  expected: true

invariant io_extra274.FileIO.write.name:
  description: "io.FileIO.write.__name__ == 'write'"
  category: identity
  kind: python_call_eq
  function: FileIO.write.__name__.__eq__
  args: ["write"]
  expected: true

invariant io_extra274.FileIO.read.is_method_descriptor:
  description: "io.FileIO.read is a method_descriptor (C-extension method)"
  category: identity
  kind: python_call_eq
  function: FileIO.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
