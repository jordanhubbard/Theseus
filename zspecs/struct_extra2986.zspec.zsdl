spec: st2986
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct: Interpret bytes as packed binary data"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (st2986): __len__, __length_hint__, __contains__ dict-presence checks for struct types."
    - "struct.Struct is a C extension type for packing/unpacking binary data; struct.error is an exception subclass — neither is a container or sequence type."
    - "None of the struct types define __len__, __length_hint__, or __contains__ in their own __dict__."
    - "Verified types: struct.Struct, struct.error."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

