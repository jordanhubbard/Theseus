spec: lodash_reject
version: ">=4.0.0"
backend: node(lodash.reject)

docs: https://lodash.com/docs/#reject

provenance:
  derived_from:
    - "lodash.reject README — https://www.npmjs.com/package/lodash.reject"
    - "Test vectors verified with lodash.reject@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.reject exports the _.reject function directly as module.exports."
    - "reject(collection, predicate) returns elements NOT matching the predicate."
    - "Complement of _.filter. Supports object and string predicates."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of non-matching elements."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_reject.reject:
  kind: node_module_call_eq
  function: ~
  category: reject
  id_prefix: lrjt

  columns: [id, args, expected]
  rows:
    - [by_obj,   [[{"n": 1, "x": "a"}, {"n": 2, "x": "b"}, {"n": 1, "x": "c"}], {"n": 1}],
       [{"n": 2, "x": "b"}]]
    - [by_prop,  [[{"active": true, "n": "a"}, {"active": false, "n": "b"}], "active"],
       [{"active": false, "n": "b"}]]

