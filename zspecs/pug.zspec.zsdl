spec: pug
version: ">=3.0.0"
backend: node(pug)

docs: https://pugjs.org/api/reference.html

provenance:
  derived_from:
    - "Pug API reference — https://pugjs.org/api/reference.html"
    - "Test vectors verified with pug via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "pug source"
  notes:
    - "Templating engine — successor to Jade."
    - "Install: npm install pug"
    - "v3 CJS; module exposes render / renderFile / compile / compileFile."
    - "render(source, locals) is synchronous and pure for in-memory strings."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Throws on syntax errors with file/line in message."
  stderr: "null"
  stickiness: "N/A — each render independent."
  codes: {}

# Plain HTML rendering — no interpolation
invariant pug.render_simple_paragraph:
  description: "render('p hello') produces '<p>hello</p>'"
  category: render
  kind: node_chain_eq
  entry: named
  function: render
  entry_args: ["p hello"]
  chain: []
  expected: "<p>hello</p>"

# Locals interpolation via #{var}
invariant pug.render_with_locals:
  description: "render('p Hello, #{name}', {name: 'World'}) interpolates the local"
  category: render
  kind: node_chain_eq
  entry: named
  function: render
  entry_args: ["p Hello, #{name}", {name: "World"}]
  chain: []
  expected: "<p>Hello, World</p>"

# Code-buffered output: =expr
invariant pug.render_buffered_code:
  description: "render('p= name', {name: 'Alice'}) escapes & outputs"
  category: render
  kind: node_chain_eq
  entry: named
  function: render
  entry_args: ["p= name", {name: "Alice"}]
  chain: []
  expected: "<p>Alice</p>"

# HTML escaping in #{}
invariant pug.render_escapes_html_special_chars:
  description: "render('p #{x}', {x: '<>&'}) escapes special chars"
  category: render
  kind: node_chain_eq
  entry: named
  function: render
  entry_args: ["p #{x}", {x: "<>&"}]
  chain: []
  expected: "<p>&lt;&gt;&amp;</p>"

# Attributes
invariant pug.render_attributes:
  description: "render('a(href=\"/foo\") link') emits an anchor with href"
  category: render
  kind: node_chain_eq
  entry: named
  function: render
  entry_args: ["a(href=\"/foo\") link"]
  chain: []
  expected: "<a href=\"/foo\">link</a>"

# Nested elements
invariant pug.render_nested:
  description: "Indented children render as nested elements"
  category: render
  kind: node_chain_eq
  entry: named
  function: render
  entry_args: ["div\n  span hi"]
  chain: []
  expected: "<div><span>hi</span></div>"

# Class shortcut
invariant pug.render_class_shortcut:
  description: "render('p.greet hi') renders class attribute"
  category: render
  kind: node_chain_eq
  entry: named
  function: render
  entry_args: ["p.greet hi"]
  chain: []
  expected: "<p class=\"greet\">hi</p>"

# ID shortcut
invariant pug.render_id_shortcut:
  description: "render('p#main hi') renders id attribute"
  category: render
  kind: node_chain_eq
  entry: named
  function: render
  entry_args: ["p#main hi"]
  chain: []
  expected: "<p id=\"main\">hi</p>"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:05:39Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
