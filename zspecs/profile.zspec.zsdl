spec: profile
version: ">=3.3"
backend: python_module(profile)

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "profile source: Lib/profile.py (PSF; source inspection permitted)"
  not_derived_from:
    - "profile source: sys.setprofile internals"
  notes:
    - "profile is the pure-Python deterministic profiler; cProfile is the C-accelerated alternative."
    - "Profile is the only public class; it is instantiable with no arguments."
    - "Profile.__bases__[0].__name__ == 'object' — Profile inherits directly from object."
    - "Profile methods: run, runcall, runctx, print_stats, dump_stats."
    - "Profile().__class__.__name__ == 'Profile' — instantiation with no args yields a Profile instance."
    - "profile.__name__ == 'profile'."
    - "All expected values verified by running Python 3.12 profile module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Profile.dump_stats() raises OSError if the file cannot be written. print_stats() requires that profiling has been run first."
  stderr: "null"
  stickiness: "N/A — each Profile instance is independent."
  codes: {}

# ---------------------------------------------------------------------------
# module name
# ---------------------------------------------------------------------------

invariant profile.module_name:
  description: "profile.__name__ == 'profile'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["profile"]
  expected: true

# ---------------------------------------------------------------------------
# class name and module
# ---------------------------------------------------------------------------

invariant profile.Profile_name:
  description: "Profile.__name__ == 'Profile'"
  category: classes
  kind: python_call_eq
  function: Profile.__name__.__eq__
  args: ["Profile"]
  expected: true

invariant profile.Profile_module:
  description: "Profile.__module__ == 'profile'"
  category: classes
  kind: python_call_eq
  function: Profile.__module__.__eq__
  args: ["profile"]
  expected: true

# ---------------------------------------------------------------------------
# class hierarchy
# ---------------------------------------------------------------------------

invariant profile.hierarchy.Profile_base:
  description: "Profile.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Profile.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Profile methods — presence checks via __name__
# ---------------------------------------------------------------------------

table profile.Profile_methods:
  kind: python_call_eq
  category: methods
  id_prefix: Profile_method

  columns: [id, function, args, expected]
  rows:
    - [run,        Profile.run.__name__.__eq__,        ["run"],        true]
    - [runcall,    Profile.runcall.__name__.__eq__,    ["runcall"],    true]
    - [runctx,     Profile.runctx.__name__.__eq__,     ["runctx"],     true]
    - [print_stats, Profile.print_stats.__name__.__eq__, ["print_stats"], true]
    - [dump_stats, Profile.dump_stats.__name__.__eq__, ["dump_stats"], true]

# ---------------------------------------------------------------------------
# instantiation — Profile() yields a Profile instance
# ---------------------------------------------------------------------------

invariant profile.Profile_instantiable:
  description: "Profile().__class__.__name__ == 'Profile' — Profile is instantiable with no args"
  category: instantiation
  kind: python_call_eq
  function: Profile
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Profile"]
  expected: true
