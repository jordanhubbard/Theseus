spec: decimal_extra130
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Context class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__) and method descriptor identity (__class__.__name__ and __qualname__) for quantize, sqrt, exp, ln, log10, add, subtract, multiply, divide, power, compare, abs, minus, plus, normalize, remainder."
    - "decimal.Context.__name__ == 'Context' (length 7)."
    - "decimal.Context.__module__ == 'decimal' (length 7) — Context is a C extension type that reports 'decimal' as its module."
    - "decimal.Context.__qualname__ == 'Context' (length 7)."
    - "decimal.Context.__bases__[0].__name__ == 'object' (length 6) — Context has no intermediate base class."
    - "decimal.Context.__mro__.__len__() == 2 — MRO is [Context, object]."
    - "decimal.Context.__class__.__name__ == 'type' — Context is a C extension type, and its metaclass is the built-in 'type'."
    - "decimal.Context.quantize.__class__.__name__ == 'method_descriptor' — all Context math/arithmetic methods are C method_descriptors."
    - "decimal.Context.quantize.__qualname__ == 'Context.quantize' (length 16)."
    - "decimal.Context.sqrt.__qualname__ == 'Context.sqrt' (length 12)."
    - "decimal.Context.add.__qualname__ == 'Context.add' (length 11)."
    - "decimal.Context.subtract.__qualname__ == 'Context.subtract' (length 16)."
    - "decimal.Context.multiply.__qualname__ == 'Context.multiply' (length 16)."
    - "decimal.Context.divide.__qualname__ == 'Context.divide' (length 14)."
    - "decimal.Context.power.__qualname__ == 'Context.power' (length 13)."
    - "decimal.Context.compare.__qualname__ == 'Context.compare' (length 15)."
    - "decimal.Context.remainder.__qualname__ == 'Context.remainder' (length 17)."
    - "decimal.Context.normalize.__qualname__ == 'Context.normalize' (length 17)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context class identity
# Context is a C extension type from _decimal. __name__ == 'Context' (7),
# __module__ == 'decimal' (7), __qualname__ == 'Context' (7).
# __bases__[0].__name__ == 'object' (6). MRO length == 2.
# __class__.__name__ == 'type' (Context's metaclass is the built-in type).
# ---------------------------------------------------------------------------

table decimal_extra130.Context_class_identity:
  description: "decimal.Context class identity: __name__='Context' (7), __module__='decimal' (7), __qualname__='Context' (7), __bases__[0].__name__='object', __mro__.__len__()==2, __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: decctx130

  columns: [id, function, args, expected]
  rows:
    - [ctx_name_eq,      Context.__name__.__eq__,                    ["Context"],  true]
    - [ctx_name_len,     Context.__name__.__len__,                   [],           7]
    - [ctx_module_eq,    Context.__module__.__eq__,                  ["decimal"],  true]
    - [ctx_module_not,   Context.__module__.__eq__,                  ["_decimal"], false]
    - [ctx_module_len,   Context.__module__.__len__,                 [],           7]
    - [ctx_qualname_eq,  Context.__qualname__.__eq__,                ["Context"],  true]
    - [ctx_qualname_len, Context.__qualname__.__len__,               [],           7]
    - [ctx_base_eq,      "Context.__bases__[0].__name__.__eq__",     ["object"],   true]
    - [ctx_base_len,     "Context.__bases__[0].__name__.__len__",    [],           6]
    - [ctx_mro_len,      Context.__mro__.__len__,                    [],           2]
    - [ctx_cls_eq,       Context.__class__.__name__.__eq__,          ["type"],     true]
    - [ctx_name_not_dec, Context.__name__.__eq__,                    ["Decimal"],  false]

# ---------------------------------------------------------------------------
# decimal.Context method descriptor __class__.__name__
# All arithmetic and math methods (quantize, sqrt, exp, ln, log10, add,
# subtract, multiply, divide, power, compare) are method_descriptor instances.
# ---------------------------------------------------------------------------

table decimal_extra130.Context_method_descriptor_classes:
  description: "decimal.Context method descriptor __class__.__name__ == 'method_descriptor' for quantize, sqrt, exp, ln, log10, add, subtract, multiply, divide, power, compare"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: decctx130

  columns: [id, function, args, expected]
  rows:
    - [quantize_cls_eq,  Context.quantize.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [sqrt_cls_eq,      Context.sqrt.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [exp_cls_eq,       Context.exp.__class__.__name__.__eq__,       ["method_descriptor"], true]
    - [ln_cls_eq,        Context.ln.__class__.__name__.__eq__,        ["method_descriptor"], true]
    - [log10_cls_eq,     Context.log10.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [add_cls_eq,       Context.add.__class__.__name__.__eq__,       ["method_descriptor"], true]
    - [subtract_cls_eq,  Context.subtract.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [multiply_cls_eq,  Context.multiply.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [divide_cls_eq,    Context.divide.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [power_cls_eq,     Context.power.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [compare_cls_eq,   Context.compare.__class__.__name__.__eq__,   ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# decimal.Context method __qualname__ equality and lengths (math operations)
# quantize (16), sqrt (12), exp (11), ln (10), log10 (13), normalize (17),
# remainder (17).
# ---------------------------------------------------------------------------

table decimal_extra130.Context_math_method_qualnames:
  description: "decimal.Context math method __qualname__ equality and lengths: quantize=16, sqrt=12, exp=11, ln=10, log10=13, normalize=17, remainder=17"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: decctx130

  columns: [id, function, args, expected]
  rows:
    - [quantize_qn_eq,   Context.quantize.__qualname__.__eq__,   ["Context.quantize"],   true]
    - [quantize_qn_len,  Context.quantize.__qualname__.__len__,  [],                     16]
    - [sqrt_qn_eq,       Context.sqrt.__qualname__.__eq__,       ["Context.sqrt"],       true]
    - [sqrt_qn_len,      Context.sqrt.__qualname__.__len__,      [],                     12]
    - [exp_qn_eq,        Context.exp.__qualname__.__eq__,        ["Context.exp"],        true]
    - [exp_qn_len,       Context.exp.__qualname__.__len__,       [],                     11]
    - [ln_qn_eq,         Context.ln.__qualname__.__eq__,         ["Context.ln"],         true]
    - [ln_qn_len,        Context.ln.__qualname__.__len__,        [],                     10]
    - [log10_qn_eq,      Context.log10.__qualname__.__eq__,      ["Context.log10"],      true]
    - [log10_qn_len,     Context.log10.__qualname__.__len__,     [],                     13]
    - [normalize_qn_eq,  Context.normalize.__qualname__.__eq__,  ["Context.normalize"],  true]
    - [normalize_qn_len, Context.normalize.__qualname__.__len__, [],                     17]
    - [remainder_qn_eq,  Context.remainder.__qualname__.__eq__,  ["Context.remainder"],  true]
    - [remainder_qn_len, Context.remainder.__qualname__.__len__, [],                     17]

# ---------------------------------------------------------------------------
# decimal.Context method __qualname__ equality and lengths (arithmetic ops)
# add (11), subtract (16), multiply (16), divide (14), power (13),
# compare (15), abs (11), minus (13), plus (12).
# ---------------------------------------------------------------------------

table decimal_extra130.Context_arithmetic_method_qualnames:
  description: "decimal.Context arithmetic method __qualname__ equality and lengths: add=11, subtract=16, multiply=16, divide=14, power=13, compare=15, abs=11, minus=13, plus=12"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: decctx130

  columns: [id, function, args, expected]
  rows:
    - [add_qn_eq,       Context.add.__qualname__.__eq__,       ["Context.add"],       true]
    - [add_qn_len,      Context.add.__qualname__.__len__,      [],                    11]
    - [sub_qn_eq,       Context.subtract.__qualname__.__eq__,  ["Context.subtract"],  true]
    - [sub_qn_len,      Context.subtract.__qualname__.__len__, [],                    16]
    - [mul_qn_eq,       Context.multiply.__qualname__.__eq__,  ["Context.multiply"],  true]
    - [mul_qn_len,      Context.multiply.__qualname__.__len__, [],                    16]
    - [div_qn_eq,       Context.divide.__qualname__.__eq__,    ["Context.divide"],    true]
    - [div_qn_len,      Context.divide.__qualname__.__len__,   [],                    14]
    - [pow_qn_eq,       Context.power.__qualname__.__eq__,     ["Context.power"],     true]
    - [pow_qn_len,      Context.power.__qualname__.__len__,    [],                    13]
    - [cmp_qn_eq,       Context.compare.__qualname__.__eq__,   ["Context.compare"],   true]
    - [cmp_qn_len,      Context.compare.__qualname__.__len__,  [],                    15]
    - [abs_qn_eq,       Context.abs.__qualname__.__eq__,       ["Context.abs"],       true]
    - [abs_qn_len,      Context.abs.__qualname__.__len__,      [],                    11]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra130.Context.name_is_Context:
  description: "decimal.Context.__name__ == 'Context' (length 7; the class name as defined in the C extension; __module__ is 'decimal', not '_decimal')"
  category: class_identity
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra130.Context.module_is_decimal:
  description: "decimal.Context.__module__ == 'decimal' (length 7; the C-accelerated Context reports 'decimal' as its module, not '_decimal')"
  category: class_identity
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra130.Context.mro_len_2:
  description: "decimal.Context.__mro__.__len__() == 2 (MRO is [Context, object]; Context has no intermediate base class)"
  category: class_identity
  kind: python_call_eq
  function: Context.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra130.Context.class_name_is_type:
  description: "decimal.Context.__class__.__name__ == 'type' (Context is a C extension type whose metaclass is the built-in 'type', distinguishing it from instances)"
  category: class_identity
  kind: python_call_eq
  function: Context.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra130.Context.quantize_qualname_len_16:
  description: "decimal.Context.quantize.__qualname__.__len__() == 16 ('Context.quantize' is 16 chars: 'Context' (7) + '.' (1) + 'quantize' (8))"
  category: method_descriptor
  kind: python_call_eq
  function: Context.quantize.__qualname__.__len__
  args: []
  expected: 16
