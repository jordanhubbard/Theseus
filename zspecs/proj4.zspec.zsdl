spec: proj4
version: ">=2.9.0"
backend: node(proj4)

docs: https://github.com/proj4js/proj4js#readme

provenance:
  derived_from:
    - "proj4js README — https://github.com/proj4js/proj4js#readme"
    - "PROJ project documentation — https://proj.org/"
    - "Test vectors verified with proj4 via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "proj4 source"
  notes:
    - "JavaScript port of the canonical PROJ cartographic projections library."
    - "Install: npm install proj4"
    - "Module export IS the conversion function: proj4(fromProj, toProj, [x, y]) → [x', y']."
    - "Test vectors round-trip via fixed proj4 strings to avoid EPSG-name ambiguity."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Throws on un-parseable proj strings; pure conversion otherwise."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# WGS-84 longlat -> UTM zone 33 (Berlin)
invariant proj4.berlin_utm_33_x:
  description: "Berlin (13.4°E, 52.5°N) projected to UTM zone 33 — easting ~391,391 m"
  category: utm
  kind: node_chain_eq
  entry: module
  entry_args: ["+proj=longlat +datum=WGS84 +no_defs",
               "+proj=utm +zone=33 +datum=WGS84 +units=m +no_defs",
               [13.4, 52.5]]
  chain:
    - {method: at, args: [0]}
    - {method: toFixed, args: [0]}
  expected: "391391"

invariant proj4.berlin_utm_33_y:
  description: "Berlin (13.4°E, 52.5°N) projected to UTM zone 33 — northing ~5,817,855 m"
  category: utm
  kind: node_chain_eq
  entry: module
  entry_args: ["+proj=longlat +datum=WGS84 +no_defs",
               "+proj=utm +zone=33 +datum=WGS84 +units=m +no_defs",
               [13.4, 52.5]]
  chain:
    - {method: at, args: [1]}
    - {method: toFixed, args: [0]}
  expected: "5817855"

# Round-trip identity: WGS-84 -> UTM -> WGS-84 returns ~original
invariant proj4.utm_to_wgs84_roundtrip_x:
  description: "UTM 33 northing/easting round-trips back to ~13.4°E"
  category: roundtrip
  kind: node_chain_eq
  entry: module
  entry_args: ["+proj=utm +zone=33 +datum=WGS84 +units=m +no_defs",
               "+proj=longlat +datum=WGS84 +no_defs",
               [391391, 5817855]]
  chain:
    - {method: at, args: [0]}
    - {method: toFixed, args: [4]}
  expected: "13.4000"

invariant proj4.utm_to_wgs84_roundtrip_y:
  description: "UTM 33 round-trips back to ~52.5°N"
  category: roundtrip
  kind: node_chain_eq
  entry: module
  entry_args: ["+proj=utm +zone=33 +datum=WGS84 +units=m +no_defs",
               "+proj=longlat +datum=WGS84 +no_defs",
               [391391, 5817855]]
  chain:
    - {method: at, args: [1]}
    - {method: toFixed, args: [4]}
  expected: "52.5000"

# Identity transform: same projection both directions returns input unchanged
invariant proj4.identity_x:
  description: "Same-source same-target projection returns input x to ~14 decimals"
  category: identity
  kind: node_chain_eq
  entry: module
  entry_args: ["+proj=longlat +datum=WGS84 +no_defs",
               "+proj=longlat +datum=WGS84 +no_defs",
               [13.4, 52.5]]
  chain:
    - {method: at, args: [0]}
    - {method: toFixed, args: [1]}
  expected: "13.4"

invariant proj4.identity_y:
  description: "Same-source same-target projection returns input y to ~14 decimals"
  category: identity
  kind: node_chain_eq
  entry: module
  entry_args: ["+proj=longlat +datum=WGS84 +no_defs",
               "+proj=longlat +datum=WGS84 +no_defs",
               [13.4, 52.5]]
  chain:
    - {method: at, args: [1]}
    - {method: toFixed, args: [1]}
  expected: "52.5"
