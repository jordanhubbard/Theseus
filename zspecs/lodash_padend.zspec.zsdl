spec: lodash_padend
version: ">=4.0.0"
backend: node(lodash.padend)

docs: https://lodash.com/docs/#padEnd

provenance:
  derived_from:
    - "lodash.padend README — https://www.npmjs.com/package/lodash.padend"
    - "Test vectors verified with lodash.padend@4.6.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.padend exports the _.padEnd function directly as module.exports."
    - "padEnd(string, length, chars) pads string at the end."
    - "Pads with spaces by default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a right-padded string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_padend.padend:
  kind: node_module_call_eq
  function: ~
  category: padend
  id_prefix: lpade

  columns: [id, args, expected]
  rows:
    - [zero_pad,    ["5", 3, "0"],    "500"]
    - [space_pad,   ["abc", 6],       "abc   "]
    - [no_padding,  ["hello", 3],     "hello"]
    - [multi_char,  ["1", 5, "xo"],   "1xoxo"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:36:05Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
