spec: theseus_sys_utils
version: ">=3.9"
backend: python_cleanroom(theseus_sys_utils)
blocks: sys

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html"
  notes:
    - "Clean-room sys module utilities. Do NOT import sys."
    - "Provide constants and utilities that mirror sys module attributes."
    - "SYS_MAXSIZE: maximum int size on this platform (2^63-1 on 64-bit)."
    - "byteorder: 'little' or 'big' endian string for this platform."
    - "version_info-like tuple: major, minor, micro."
    - "sys_maxsize_positive(): SYS_MAXSIZE > 0."
    - "sys_byteorder_valid(): byteorder in ('little', 'big')."
    - "sys_int_info_bits(): integer bit size >= 30."
    - "Export: MAXSIZE int constant, BYTEORDER str constant."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_sys_utils.maxsize_positive:
  description: "SYS_MAXSIZE > 0"
  category: constants
  kind: python_call_eq
  function: sys_maxsize_positive
  args: []
  expected: true

invariant theseus_sys_utils.byteorder_valid:
  description: "byteorder in ('little', 'big')"
  category: constants
  kind: python_call_eq
  function: sys_byteorder_valid
  args: []
  expected: true

invariant theseus_sys_utils.maxsize_value:
  description: "SYS_MAXSIZE == 2**63 - 1 on 64-bit"
  category: constants
  kind: python_call_eq
  function: sys_maxsize_value
  args: []
  expected: 9223372036854775807
