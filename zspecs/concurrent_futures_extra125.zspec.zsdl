spec: concurrent_futures_extra125
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec covers: wave 256 theme — concurrent.futures.ThreadPoolExecutor method co_varnames. NEW in extra125: ThreadPoolExecutor.submit.__code__.co_varnames[0]=='self'; ThreadPoolExecutor.submit.__code__.co_argcount==2 (self, fn); ThreadPoolExecutor.submit.__code__.co_varnames[1]=='fn'; ThreadPoolExecutor.submit.__code__.co_varnames.__len__()==7; ThreadPoolExecutor.map.__code__.co_varnames[0]=='self'; ThreadPoolExecutor.map.__code__.co_argcount==2; ThreadPoolExecutor.map.__qualname__=='Executor.map' (len=12, inherited from Executor); ThreadPoolExecutor.shutdown.__code__.co_varnames[0]=='self'; ThreadPoolExecutor.shutdown.__code__.co_argcount==2 (self, wait); ThreadPoolExecutor.shutdown.__code__.co_varnames[1]=='wait'; ThreadPoolExecutor.__init__.__code__.co_argcount==5 (self, max_workers, thread_name_prefix, initializer, initargs); ThreadPoolExecutor.__init__.__code__.co_varnames[1]=='max_workers'; ThreadPoolExecutor.__init__.__code__.co_varnames.__len__()==6. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.map.__qualname__ == 'Executor.map'. ThreadPoolExecutor does not override map — it inherits the implementation from the base Executor class defined in concurrent/futures/_base.py; thus map.__qualname__ uses 'Executor.' prefix (len=12: 'Executor.'=9+'map'=3=12) rather than 'ThreadPoolExecutor.'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__len__() == 7. submit's co_varnames are ('self', 'fn', 'args', 'kwargs', 'f', 'task', 'w'): 2 positional params (self, fn) plus *args and **kwargs plus 3 local variables (f=Future, task=_WorkItem, w=worker). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5. __init__ is defined as '__init__(self, max_workers=None, thread_name_prefix='', initializer=None, initargs=())' — 5 positional params (note: ctxkwargs is a local variable added to co_varnames but not a positional param, making co_argcount=5 and co_varnames.__len__()==6). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor.submit co_varnames — extra125
#
# Wave 256 theme: concurrent.futures.ThreadPoolExecutor method co_varnames.
#
# ThreadPoolExecutor.submit.__code__.co_varnames[0]    == 'self'
# ThreadPoolExecutor.submit.__code__.co_varnames[1]    == 'fn'
# ThreadPoolExecutor.submit.__code__.co_argcount       == 2
# ThreadPoolExecutor.submit.__code__.co_varnames.__len__() == 7
# ThreadPoolExecutor.submit.__qualname__               == 'ThreadPoolExecutor.submit'  (len=25)
# ---------------------------------------------------------------------------

table concurrent_futures_extra125.tpe_submit_varnames:
  description: "concurrent.futures.ThreadPoolExecutor.submit __code__.co_varnames checks in tpevarnames125 namespace — wave 256 theme: concurrent.futures.ThreadPoolExecutor.submit is defined as 'def submit(self, fn, /, *args, **kwargs)'; co_argcount==2 counts only positional parameters before *args (self and fn); co_varnames contains 7 entries ('self', 'fn', 'args', 'kwargs', 'f', 'task', 'w') where 'f' is the Future object, 'task' is the _WorkItem, and 'w' is the thread worker; concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__getitem__(0).__eq__('self')==True; concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__getitem__(1).__eq__('fn')==True (fn is the callable to run in the thread pool); concurrent.futures.ThreadPoolExecutor.submit.__code__.co_argcount.__eq__(2)==True (self and fn as positional params before /); concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__len__()==7 (2 positional + 2 variadic + 3 local variables); concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__('ThreadPoolExecutor.submit')==True (len=25: 'ThreadPoolExecutor.'=19+'submit'=6=25); concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__()==25; concurrent.futures.ThreadPoolExecutor.submit.__class__.__name__.__eq__('function')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: tpevarnames125

  columns: [id, function, args, expected, description]
  rows:
    - [sub_var0,    "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__getitem__", [0],   "self", "ThreadPoolExecutor.submit.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [sub_var1,    "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__getitem__", [1],   "fn",   "ThreadPoolExecutor.submit.__code__.co_varnames[1] == 'fn' (the callable to submit); verified with Python 3.14.3"]
    - [sub_argc,    "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_argcount.__eq__",      [2],   true,   "ThreadPoolExecutor.submit.__code__.co_argcount == 2 (self, fn as positional before /); verified with Python 3.14.3"]
    - [sub_varlen,  "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__len__",     [],    7,      "ThreadPoolExecutor.submit.__code__.co_varnames.__len__() == 7 (self, fn, args, kwargs, f, task, w); verified with Python 3.14.3"]
    - [sub_qn_eq,   "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__",              ["ThreadPoolExecutor.submit"], true, "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25); verified with Python 3.14.3"]
    - [sub_qn_len,  "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__",             [],    25,     "ThreadPoolExecutor.submit.__qualname__.__len__() == 25 ('ThreadPoolExecutor.'=19+'submit'=6=25); verified with Python 3.14.3"]
    - [sub_cls,     "concurrent.futures.ThreadPoolExecutor.submit.__class__.__name__.__eq__",        ["function"], true, "ThreadPoolExecutor.submit.__class__.__name__ == 'function' (Python-defined); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor.map and shutdown co_varnames — extra125
#
# ThreadPoolExecutor.map.__code__.co_varnames[0]     == 'self'
# ThreadPoolExecutor.map.__code__.co_argcount        == 2
# ThreadPoolExecutor.map.__qualname__                == 'Executor.map'   (len=12, inherited)
# ThreadPoolExecutor.map.__code__.co_varnames.__len__() == 8
# ThreadPoolExecutor.shutdown.__code__.co_varnames[0] == 'self'
# ThreadPoolExecutor.shutdown.__code__.co_varnames[1] == 'wait'
# ThreadPoolExecutor.shutdown.__code__.co_argcount   == 2
# ThreadPoolExecutor.shutdown.__qualname__           == 'ThreadPoolExecutor.shutdown'  (len=27)
# ---------------------------------------------------------------------------

table concurrent_futures_extra125.tpe_map_shutdown_varnames:
  description: "concurrent.futures.ThreadPoolExecutor.map and shutdown __code__.co_varnames checks in tpevarnames125 namespace — wave 256 theme: concurrent.futures.ThreadPoolExecutor.map is inherited from the Executor base class (Lib/concurrent/futures/_base.py); map.__qualname__.__eq__('Executor.map')==True (len=12: 'Executor.'=9+'map'=3=12; qualname uses defining class 'Executor', not 'ThreadPoolExecutor'); map.__code__.co_varnames.__getitem__(0).__eq__('self')==True; map.__code__.co_argcount.__eq__(2)==True (self and fn); map.__code__.co_varnames.__len__()==8 (8 co_varnames: 'self', 'fn', 'timeout', 'chunksize', 'buffersize', 'iterables', 'args', 'result_iterator'); map.__code__.co_varnames.__getitem__(1).__eq__('fn')==True; ThreadPoolExecutor.shutdown.__code__.co_varnames.__getitem__(0).__eq__('self')==True; ThreadPoolExecutor.shutdown.__code__.co_varnames.__getitem__(1).__eq__('wait')==True (second param is 'wait', the wait-for-completion flag); ThreadPoolExecutor.shutdown.__code__.co_argcount.__eq__(2)==True (self, wait); ThreadPoolExecutor.shutdown.__qualname__.__eq__('ThreadPoolExecutor.shutdown')==True (len=27: 'ThreadPoolExecutor.'=19+'shutdown'=8=27, two more than submit's 25); ThreadPoolExecutor.shutdown.__qualname__.__len__()==27; shutdown.__code__.co_varnames.__len__()==5 (self, wait, cancel_futures, work_item, t); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: tpevarnames125a

  columns: [id, function, args, expected, description]
  rows:
    - [map_var0,    "concurrent.futures.ThreadPoolExecutor.map.__code__.co_varnames.__getitem__",      [0],   "self",         "ThreadPoolExecutor.map.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [map_var1,    "concurrent.futures.ThreadPoolExecutor.map.__code__.co_varnames.__getitem__",      [1],   "fn",           "ThreadPoolExecutor.map.__code__.co_varnames[1] == 'fn' (first function param); verified with Python 3.14.3"]
    - [map_argc,    "concurrent.futures.ThreadPoolExecutor.map.__code__.co_argcount.__eq__",           [2],   true,           "ThreadPoolExecutor.map.__code__.co_argcount == 2 (self, fn); verified with Python 3.14.3"]
    - [map_varlen,  "concurrent.futures.ThreadPoolExecutor.map.__code__.co_varnames.__len__",          [],    8,              "ThreadPoolExecutor.map.__code__.co_varnames.__len__() == 8 (self, fn, timeout, chunksize, buffersize, iterables, args, result_iterator); verified with Python 3.14.3"]
    - [map_qn_eq,   "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__",                   ["Executor.map"],    true, "ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (len=12, inherited — qualname uses defining class 'Executor'); verified with Python 3.14.3"]
    - [map_qn_len,  "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__len__",                  [],    12,             "ThreadPoolExecutor.map.__qualname__.__len__() == 12 ('Executor.'=9+'map'=3=12, inherited); verified with Python 3.14.3"]
    - [sdn_var0,    "concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_varnames.__getitem__",  [0],   "self",         "ThreadPoolExecutor.shutdown.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [sdn_var1,    "concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_varnames.__getitem__",  [1],   "wait",         "ThreadPoolExecutor.shutdown.__code__.co_varnames[1] == 'wait' (the wait-for-completion flag); verified with Python 3.14.3"]
    - [sdn_argc,    "concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_argcount.__eq__",       [2],   true,           "ThreadPoolExecutor.shutdown.__code__.co_argcount == 2 (self, wait); verified with Python 3.14.3"]
    - [sdn_varlen,  "concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_varnames.__len__",      [],    5,              "ThreadPoolExecutor.shutdown.__code__.co_varnames.__len__() == 5 (self, wait, cancel_futures, work_item, t); verified with Python 3.14.3"]
    - [sdn_qn_len,  "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__len__",              [],    27,             "ThreadPoolExecutor.shutdown.__qualname__.__len__() == 27 ('ThreadPoolExecutor.'=19+'shutdown'=8=27); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor.__init__ co_varnames — extra125
#
# ThreadPoolExecutor.__init__.__code__.co_argcount       == 5
# ThreadPoolExecutor.__init__.__code__.co_varnames[0]    == 'self'
# ThreadPoolExecutor.__init__.__code__.co_varnames[1]    == 'max_workers'
# ThreadPoolExecutor.__init__.__code__.co_varnames[2]    == 'thread_name_prefix'
# ThreadPoolExecutor.__init__.__code__.co_varnames.__len__() == 6
# ThreadPoolExecutor.__init__.__qualname__               == 'ThreadPoolExecutor.__init__'  (len=27)
# ThreadPoolExecutor.__name__                            == 'ThreadPoolExecutor'  (len=18)
# ---------------------------------------------------------------------------

table concurrent_futures_extra125.tpe_init_varnames:
  description: "concurrent.futures.ThreadPoolExecutor.__init__ __code__.co_varnames and class identity checks in tpevarnames125 namespace — wave 256 theme: concurrent.futures.ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py; ThreadPoolExecutor.__init__.__code__.co_varnames.__getitem__(0).__eq__('self')==True; ThreadPoolExecutor.__init__.__code__.co_varnames.__getitem__(1).__eq__('max_workers')==True (first config param: maximum number of threads in the pool); ThreadPoolExecutor.__init__.__code__.co_varnames.__getitem__(2).__eq__('thread_name_prefix')==True (second config param: prefix for thread names); ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__(5)==True (5 positional params: self, max_workers, thread_name_prefix, initializer, initargs); ThreadPoolExecutor.__init__.__code__.co_varnames.__len__()==6 (6 total co_varnames: 5 positional params plus 'ctxkwargs' local variable); ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__')==True (len=27: 'ThreadPoolExecutor.'=19+'__init__'=8=27; tied with shutdown at 27); ThreadPoolExecutor.__init__.__qualname__.__len__()==27; ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor')==True (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18); ThreadPoolExecutor.__name__.__len__()==18; ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (inherits from Executor base class); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: tpevarnames125b

  columns: [id, function, args, expected, description]
  rows:
    - [init_var0,    "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__getitem__", [0],   "self",              "ThreadPoolExecutor.__init__.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [init_var1,    "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__getitem__", [1],   "max_workers",       "ThreadPoolExecutor.__init__.__code__.co_varnames[1] == 'max_workers' (max thread count); verified with Python 3.14.3"]
    - [init_var2,    "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__getitem__", [2],   "thread_name_prefix","ThreadPoolExecutor.__init__.__code__.co_varnames[2] == 'thread_name_prefix'; verified with Python 3.14.3"]
    - [init_argc,    "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__",      [5],   true,                "ThreadPoolExecutor.__init__.__code__.co_argcount == 5 (self, max_workers, thread_name_prefix, initializer, initargs); verified with Python 3.14.3"]
    - [init_varlen,  "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__len__",     [],    6,                   "ThreadPoolExecutor.__init__.__code__.co_varnames.__len__() == 6 (5 positional + ctxkwargs local); verified with Python 3.14.3"]
    - [init_qn_len,  "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__",             [],    27,                  "ThreadPoolExecutor.__init__.__qualname__.__len__() == 27 ('ThreadPoolExecutor.'=19+'__init__'=8=27); verified with Python 3.14.3"]
    - [tpe_name_eq,  "concurrent.futures.ThreadPoolExecutor.__name__.__eq__",                           ["ThreadPoolExecutor"], true, "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor' (len=18); verified with Python 3.14.3"]
    - [tpe_name_len, "concurrent.futures.ThreadPoolExecutor.__name__.__len__",                          [],    18,                  "ThreadPoolExecutor.__name__.__len__() == 18 ('Thread'=6+'Pool'=4+'Executor'=8=18); verified with Python 3.14.3"]
    - [tpe_base0,    "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__",              ["Executor"], true,         "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' (inherits from Executor base class); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra125
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra125.submit_varnames_len_7:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__len__() == 7 — submit's co_varnames are ('self', 'fn', 'args', 'kwargs', 'f', 'task', 'w'); the 7 entries consist of: 2 positional params (self, fn where fn is the callable to submit), 2 variadic collection params (args as tuple, kwargs as dict from *args/**kwargs), and 3 internal local variables (f=the Future object created, task=the _WorkItem wrapping the callable, w=the thread worker object); submit.__code__.co_argcount is 2 (only self and fn are positional, before the / separator); compare co_varnames lengths: shutdown=5 (shorter), submit=7, map=8 (longest: more params and locals); submit.__qualname__ is 'ThreadPoolExecutor.submit' (len=25); NEW in extra125: first standalone ThreadPoolExecutor.submit co_varnames length invariant in tpevarnames125 namespace; wave 256; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__len__"
  args: []
  expected: 7

invariant concurrent_futures_extra125.map_qualname_is_Executor_map:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__('Executor.map') returns True — ThreadPoolExecutor does not define its own map method; it inherits map from the Executor base class (Lib/concurrent/futures/_base.py); Python's qualname mechanism records the defining class, so map.__qualname__ is 'Executor.map' (len=12: 'Executor.'=9+'map'=3=12) rather than 'ThreadPoolExecutor.map' (which would be len=22); this contrasts with submit and shutdown whose qualnames use 'ThreadPoolExecutor.' (len=19+method) because those methods ARE defined in ThreadPoolExecutor; map.__code__.co_argcount is 2 (self, fn); map.__code__.co_varnames.__len__() is 8; NEW in extra125: first standalone ThreadPoolExecutor.map qualname prefix invariant in tpevarnames125 namespace; wave 256; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__"
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra125.shutdown_qualname_len_27:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__len__() == 27 — concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ is 'ThreadPoolExecutor.shutdown' (27 chars: 'ThreadPoolExecutor.'=19 + 'shutdown'=8 = 27); this is tied with __init__ at len=27; compare qualname lengths: map=12 (inherited, uses 'Executor.' prefix), submit=25, shutdown=27 (tied), __init__=27 (tied); shutdown is 8 chars (two more than submit=6), explaining the +2 chars versus submit's 25; shutdown.__code__.co_argcount is 2 (self, wait); shutdown.__code__.co_varnames[1] is 'wait' (wait-for-completion flag); concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_varnames.__len__() is 5; NEW in extra125: first standalone ThreadPoolExecutor.shutdown qualname length invariant in tpevarnames125 namespace; wave 256; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__len__"
  args: []
  expected: 27

invariant concurrent_futures_extra125.init_argcount_5:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5 — ThreadPoolExecutor.__init__ is defined as '__init__(self, max_workers=None, thread_name_prefix='', initializer=None, initargs=())': 5 positional parameters; co_argcount==5 counts only positional params (self, max_workers, thread_name_prefix, initializer, initargs); co_varnames.__len__()==6 because 'ctxkwargs' is a local variable added to co_varnames beyond the 5 positional params; compare co_argcount values: submit=2 (self, fn), map=2 (self, fn), shutdown=2 (self, wait), __init__=5 (most params in spec); __init__.__qualname__ is 'ThreadPoolExecutor.__init__' (len=27); NEW in extra125: first standalone ThreadPoolExecutor.__init__ co_argcount invariant in tpevarnames125 namespace; wave 256; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__"
  args: [5]
  expected: true

invariant concurrent_futures_extra125.tpe_name_len_18:
  description: "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18 — concurrent.futures.ThreadPoolExecutor.__name__ is 'ThreadPoolExecutor' (18 chars: 'Thread'=6+'Pool'=4+'Executor'=8=18); ThreadPoolExecutor.__bases__[0].__name__ is 'Executor' (len=8, the base class); ThreadPoolExecutor.__mro__.__len__() is 3 ([ThreadPoolExecutor, Executor, object]); ThreadPoolExecutor.__module__ is 'concurrent.futures.thread' (defined in Lib/concurrent/futures/thread.py); the 18-char class name 'ThreadPoolExecutor' is composed of three words: 'Thread' (the execution model), 'Pool' (the resource pool pattern), 'Executor' (the base class concept); NEW in extra125: first standalone ThreadPoolExecutor name length invariant in tpevarnames125 namespace; wave 256; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__name__.__len__"
  args: []
  expected: 18
