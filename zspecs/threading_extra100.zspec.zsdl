spec: threading_extra100
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra99

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra99.zspec.zsdl."
    - "This spec covers: threading.TIMEOUT_MAX constant identity; threading C-level builtins (get_ident, get_native_id, excepthook) module identity; threading pure-Python utility functions (settrace, setprofile, current_thread, main_thread, active_count, enumerate) co_argcount; threading.Thread class identity (Wave 256)."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX == 9223372036.0 — the maximum timeout value on macOS/Darwin 25.4.0. Verified with Python 3.14.3."
    - "threading.excepthook.__class__.__name__ == 'builtin_function_or_method' — excepthook is a C builtin from _thread. Verified with Python 3.14.3."
    - "threading.excepthook.__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading.get_ident.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "threading.get_ident.__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading.get_native_id.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "threading.get_native_id.__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading.settrace.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.settrace.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "threading.setprofile.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.setprofile.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "threading.current_thread.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.current_thread.__code__.co_argcount == 0. Verified with Python 3.14.3."
    - "threading.main_thread.__code__.co_argcount == 0. Verified with Python 3.14.3."
    - "threading.active_count.__code__.co_argcount == 0. Verified with Python 3.14.3."
    - "threading.enumerate.__code__.co_argcount == 0. Verified with Python 3.14.3."
    - "threading.Thread.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "threading.Thread.__module__ == 'threading'. Verified with Python 3.14.3."
    - "len(threading.Thread.__mro__) == 2 — Thread inherits from object only. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.TIMEOUT_MAX constant identity
#
# Wave 256 theme: threading module-level constant TIMEOUT_MAX.
#
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.TIMEOUT_MAX.__eq__(9223372036.0) == True
#
# TIMEOUT_MAX is the maximum value that may be passed as a timeout parameter
# to blocking calls such as Lock.acquire(). It is a float constant derived
# from the platform's maximum signed 64-bit nanosecond value divided by 1e9.
# New to extra100.
# ---------------------------------------------------------------------------

table threading_extra100.timeout_max_identity:
  description: "threading.TIMEOUT_MAX is a float constant; __class__.__name__=='float'; value==9223372036.0 on Darwin 25.4.0; wave 256; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtimeout100

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_class_name_eq_float,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — TIMEOUT_MAX is a module-level constant of type float defined in Lib/threading.py; it represents the maximum timeout (in seconds) accepted by blocking primitives; __class__.__name__ is 'float'; str.__eq__('float') returns True; new to extra100"]
    - [timeout_max_value_eq,
       "TIMEOUT_MAX.__eq__",
       [9223372036.0],
       true,
       "threading.TIMEOUT_MAX.__eq__(9223372036.0) == True — TIMEOUT_MAX is computed as TIMEOUT_MAX = _time.CLOCK_REALTIME; on Darwin 25.4.0 the value is 9223372036.0 seconds (approx. 292 years), derived from the maximum signed 64-bit nanosecond value divided by 1e9; float.__eq__(9223372036.0) returns True; new to extra100"]

# ---------------------------------------------------------------------------
# Table 2: threading C-level builtins (get_ident, get_native_id, excepthook)
#
# Wave 256 theme: threading C-level builtin functions from _thread.
#
# threading.get_ident.__class__.__name__ == 'builtin_function_or_method'
# threading.get_ident.__module__ == '_thread'
# threading.get_native_id.__class__.__name__ == 'builtin_function_or_method'
# threading.get_native_id.__module__ == '_thread'
# threading.excepthook.__class__.__name__ == 'builtin_function_or_method'
# threading.excepthook.__module__ == '_thread'
#
# get_ident, get_native_id, and excepthook are all C-level builtins
# imported from the _thread C extension module into threading. New to extra100.
# ---------------------------------------------------------------------------

table threading_extra100.c_builtins_identity:
  description: "threading.get_ident/get_native_id/excepthook are C builtins from _thread; __class__.__name__=='builtin_function_or_method'; __module__=='_thread'; wave 256; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtimeout100

  columns: [id, function, args, expected, description]
  rows:
    - [get_ident_class_name_eq_builtin,
       "get_ident.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.get_ident.__class__.__name__.__eq__('builtin_function_or_method') == True — get_ident is a C-level builtin function from Modules/_threadmodule.c; it returns the 'thread identifier' (a non-zero integer); __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra100"]
    - [get_ident_module_eq_thread,
       "get_ident.__module__.__eq__",
       ["_thread"],
       true,
       "threading.get_ident.__module__.__eq__('_thread') == True — get_ident is implemented in and imported from the C extension module _thread (Modules/_threadmodule.c); __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra100"]
    - [get_native_id_class_name_eq_builtin,
       "get_native_id.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.get_native_id.__class__.__name__.__eq__('builtin_function_or_method') == True — get_native_id is a C-level builtin added in Python 3.8 that returns the native OS thread ID; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra100"]
    - [get_native_id_module_eq_thread,
       "get_native_id.__module__.__eq__",
       ["_thread"],
       true,
       "threading.get_native_id.__module__.__eq__('_thread') == True — get_native_id is implemented in the C extension module _thread; __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra100"]
    - [excepthook_class_name_eq_builtin,
       "excepthook.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.excepthook.__class__.__name__.__eq__('builtin_function_or_method') == True — threading.excepthook is a C-level builtin function from _thread; it is called when a thread raises an uncaught exception; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra100"]
    - [excepthook_module_eq_thread,
       "excepthook.__module__.__eq__",
       ["_thread"],
       true,
       "threading.excepthook.__module__.__eq__('_thread') == True — excepthook is implemented in and imported from _thread; __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra100"]

# ---------------------------------------------------------------------------
# Table 3: threading pure-Python utility functions co_argcount
#
# Wave 256 theme: threading pure-Python utility function co_argcount values.
#
# threading.settrace.__class__.__name__ == 'function'
# threading.settrace.__code__.co_argcount == 1
# threading.setprofile.__class__.__name__ == 'function'
# threading.setprofile.__code__.co_argcount == 1
# threading.current_thread.__class__.__name__ == 'function'
# threading.current_thread.__code__.co_argcount == 0
# threading.main_thread.__code__.co_argcount == 0
# threading.active_count.__code__.co_argcount == 0
# threading.enumerate.__code__.co_argcount == 0
#
# settrace(fn) and setprofile(fn) each take one argument.
# current_thread(), main_thread(), active_count(), enumerate() take none.
# New to extra100.
# ---------------------------------------------------------------------------

table threading_extra100.utility_function_argcounts:
  description: "threading utility functions: settrace/setprofile co_argcount==1; current_thread/main_thread/active_count/enumerate co_argcount==0; all are pure-Python; wave 256; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtimeout100

  columns: [id, function, args, expected, description]
  rows:
    - [settrace_class_name_eq_function,
       "settrace.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.settrace.__class__.__name__.__eq__('function') == True — settrace is a pure-Python function defined in Lib/threading.py; it installs a trace function for all threads started from this point; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra100"]
    - [settrace_co_argcount_eq_1,
       "settrace.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.settrace.__code__.co_argcount.__eq__(1) == True — settrace(func) takes a single positional argument (the trace function to install); co_argcount is 1; int.__eq__(1) returns True; new to extra100"]
    - [setprofile_class_name_eq_function,
       "setprofile.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.setprofile.__class__.__name__.__eq__('function') == True — setprofile is a pure-Python function defined in Lib/threading.py; it installs a profile function for all threads; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra100"]
    - [setprofile_co_argcount_eq_1,
       "setprofile.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.setprofile.__code__.co_argcount.__eq__(1) == True — setprofile(func) takes one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra100"]
    - [current_thread_class_name_eq_function,
       "current_thread.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.current_thread.__class__.__name__.__eq__('function') == True — current_thread is a pure-Python function defined in Lib/threading.py; it returns the Thread instance corresponding to the caller's thread of control; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra100"]
    - [current_thread_co_argcount_eq_0,
       "current_thread.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.current_thread.__code__.co_argcount.__eq__(0) == True — current_thread() takes no positional arguments; co_argcount is 0; int.__eq__(0) returns True; new to extra100"]
    - [main_thread_co_argcount_eq_0,
       "main_thread.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.main_thread.__code__.co_argcount.__eq__(0) == True — main_thread() takes no arguments; it returns the main Thread object; co_argcount is 0; int.__eq__(0) returns True; new to extra100"]
    - [active_count_co_argcount_eq_0,
       "active_count.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.active_count.__code__.co_argcount.__eq__(0) == True — active_count() takes no positional arguments; it returns the number of Thread objects currently alive; co_argcount is 0; int.__eq__(0) returns True; new to extra100"]
    - [enumerate_co_argcount_eq_0,
       "enumerate.__code__.co_argcount.__eq__",
       [0],
       true,
       "threading.enumerate.__code__.co_argcount.__eq__(0) == True — threading.enumerate() takes no positional arguments; it returns a list of all Thread objects currently alive; co_argcount is 0; int.__eq__(0) returns True; new to extra100"]

# ---------------------------------------------------------------------------
# Table 4: threading.Thread class identity
#
# Wave 256 theme: threading.Thread base class identity.
#
# threading.Thread.__class__.__name__ == 'type'
# threading.Thread.__module__ == 'threading'
# threading.Thread.__bases__[0].__name__ == 'object'
# len(threading.Thread.__mro__) == 2
# threading.Thread.__qualname__ == 'Thread'
#
# Thread is a pure-Python class defined in Lib/threading.py; it inherits
# directly from object. New to extra100.
# ---------------------------------------------------------------------------

table threading_extra100.thread_class_identity:
  description: "threading.Thread class identity: __class__.__name__=='type', __module__=='threading', __bases__[0]=='object', MRO len==2, __qualname__=='Thread'; wave 256; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtimeout100

  columns: [id, function, args, expected, description]
  rows:
    - [thread_class_name_eq_type,
       "Thread.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Thread.__class__.__name__.__eq__('type') == True — Thread is a Python class defined with 'class Thread:' in Lib/threading.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra100"]
    - [thread_module_eq_threading,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra100"]
    - [thread_bases_first_eq_object,
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — Thread is defined as 'class Thread:' with no explicit base; it therefore inherits only from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra100"]
    - [thread_mro_len_eq_2,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — Thread inherits directly from object with no intermediate base classes; MRO is [Thread, object]; len(__mro__) is 2; new to extra100"]
    - [thread_qualname_eq_Thread,
       "Thread.__qualname__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__qualname__.__eq__('Thread') == True — Thread is defined at module scope in Lib/threading.py; __qualname__ is the simple class name 'Thread'; str.__eq__('Thread') returns True; new to extra100"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra100
# ---------------------------------------------------------------------------

invariant threading_extra100.timeout_max_class_name:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — module-level float constant for maximum timeout; wave 256; new to extra100"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra100.get_ident_module:
  description: "threading.get_ident.__module__ == '_thread' — get_ident is a C builtin from the _thread extension; wave 256; new to extra100"
  kind: python_call_eq
  function: get_ident.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra100.get_native_id_class_name:
  description: "threading.get_native_id.__class__.__name__ == 'builtin_function_or_method' — C builtin returning native OS thread ID; wave 256; new to extra100"
  kind: python_call_eq
  function: get_native_id.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra100.settrace_co_argcount:
  description: "threading.settrace.__code__.co_argcount == 1 — settrace(func) takes one argument; wave 256; new to extra100"
  kind: python_call_eq
  function: settrace.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant threading_extra100.current_thread_co_argcount:
  description: "threading.current_thread.__code__.co_argcount == 0 — current_thread() takes no arguments; wave 256; new to extra100"
  kind: python_call_eq
  function: current_thread.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant threading_extra100.thread_mro_len:
  description: "len(threading.Thread.__mro__) == 2 — Thread inherits directly from object; wave 256; new to extra100"
  kind: python_call_eq
  function: Thread.__mro__.__len__
  args: []
  expected: 2
