spec: ssl_extra26
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra25.zspec.zsdl — covers Purpose/AlertDescription __qualname__/__module__; enum metaclass __class__.__name__; SSLCertVerificationError/CertificateError __bases__[0].__name__."
    - "ssl_extra24.zspec.zsdl — covers SSLContext.verify_mode.__class__.__name__; SSLError.__bases__[0] re-anchor; CertificateError.__qualname__; SSLWantRead/WriteError qualnames; SSLObject.__qualname__ re-anchor."
    - "ssl_extra23.zspec.zsdl — covers SSLContext wrap_socket/load_cert_chain/set_ciphers __qualname__; SSLSocket.read.__qualname__; SSLError.__module__; PROTOCOL_TLS_CLIENT class name."
    - "ssl_extra22.zspec.zsdl — covers VerifyMode enum member __class__.__qualname__; PROTOCOL_TLS_CLIENT.__class__.__qualname__; VerifyMode.__qualname__.__len__; SSLCertVerificationError.__qualname__ standalone."
    - "ssl_extra21.zspec.zsdl — covers SSLContext/SSLSocket/SSLObject/MemoryBIO/SSLSession __qualname__.__len__; create_default_context __qualname__/__len__; SSLContext.__qualname__.__eq__ as standalone."
    - "ssl_extra9.zspec.zsdl — covers SSLWantReadError/__qualname__; SSLWantWriteError/__qualname__; SSLObject/__qualname__."
    - "ssl_extra8.zspec.zsdl — covers SSLContext/SSLSocket/SSLError/create_default_context __qualname__ table; SSLCertVerificationError/__qualname__; SSLZeroReturnError/__qualname__."
    - "ssl.zspec.zsdl — covers SSLError.__bases__[0].__name__ == 'OSError'; SSLError/__module__; class names."
  notes:
    - "This spec extends ssl through ssl_extra25; it does NOT duplicate invariants present in those files."
    - "Focus: SSLContext/__module__ (novel — no prior spec covers SSLContext.__module__.__eq__); SSLContext.__bases__[0].__name__ (novel — '_SSLContext' C extension base, no prior spec covers this); SSLSocket/__module__ (novel); SSLSocket.__bases__[0].__name__ == 'socket' (novel); SSLObject/__module__ (novel); SSLObject.__bases__[0].__name__ == 'object' (novel); OP_ALL.__class__.__name__ == 'Options' (novel — ssl.OP_ALL is an Options enum member, no prior spec checks this)."
    - "ssl.SSLContext.__module__ == 'ssl': SSLContext is defined in ssl.py. No prior spec covers SSLContext.__module__.__eq__ as a standalone invariant. ssl_extra8/21 cover __qualname__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.__bases__[0].__name__ == '_SSLContext': SSLContext inherits from the C-level _SSLContext type in _ssl.c. No prior spec checks __bases__[0].__name__ for SSLContext. The C base name reveals the implementation layer. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.__module__ == 'ssl': SSLSocket is a Python class defined in ssl.py. No prior spec covers SSLSocket.__module__.__eq__. ssl_extra8 covers __qualname__ only. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.__bases__[0].__name__ == 'socket': SSLSocket inherits from socket.socket. No prior spec checks __bases__[0].__name__ for SSLSocket. ssl.zspec/extra8 do not check this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLObject.__module__ == 'ssl': SSLObject is defined in ssl.py. No prior spec covers SSLObject.__module__.__eq__. ssl_extra9/24 cover __qualname__ only. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLObject.__bases__[0].__name__ == 'object': SSLObject directly subclasses object (it wraps an _ssl._SSLObject C object but does not inherit from it). No prior spec checks __bases__[0].__name__ for SSLObject. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.OP_ALL.__class__.__name__ == 'Options': ssl.OP_ALL is a member of the ssl.Options IntFlag enum. No prior spec checks OP_ALL.__class__.__name__. ssl_extra25 covers VerifyMode/Purpose/AlertDescription metaclass names (EnumType) but not Options members. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SSLContext.__module__ and __bases__[0].__name__
#
# ssl_extra8 covers SSLContext.__qualname__ (via table); ssl_extra21 covers
# SSLContext.__qualname__.__eq__ as standalone. No prior spec covers
# SSLContext.__module__ or SSLContext.__bases__[0].__name__.
# SSLContext inherits from the C-level _SSLContext; its __module__ is 'ssl'.
# ---------------------------------------------------------------------------

invariant ssl_extra26.SSLContext.module:
  description: "ssl.SSLContext.__module__ == 'ssl' — defined in the ssl module"
  category: module_metadata
  kind: python_call_eq
  function: SSLContext.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra26.SSLContext.base_name:
  description: "ssl.SSLContext.__bases__[0].__name__ == '_SSLContext' — C extension base class"
  category: type_metadata
  kind: python_call_eq
  function: "SSLContext.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["_SSLContext"]
  expected: true

# ---------------------------------------------------------------------------
# SSLSocket.__module__ and __bases__[0].__name__
#
# ssl_extra8 covers SSLSocket.__qualname__ (via table). No prior spec covers
# SSLSocket.__module__ or SSLSocket.__bases__[0].__name__.
# SSLSocket inherits from socket.socket and adds TLS wrapping.
# ---------------------------------------------------------------------------

invariant ssl_extra26.SSLSocket.module:
  description: "ssl.SSLSocket.__module__ == 'ssl' — TLS-wrapped socket class defined in ssl module"
  category: module_metadata
  kind: python_call_eq
  function: SSLSocket.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra26.SSLSocket.base_name:
  description: "ssl.SSLSocket.__bases__[0].__name__ == 'socket' — SSLSocket inherits from socket.socket"
  category: type_metadata
  kind: python_call_eq
  function: "SSLSocket.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# SSLObject.__module__ and __bases__[0].__name__
#
# ssl_extra9 and ssl_extra24 cover SSLObject.__qualname__. No prior spec
# covers SSLObject.__module__ or SSLObject.__bases__[0].__name__.
# SSLObject is a lightweight wrapper around _ssl._SSLObject but directly
# subclasses object at the Python level.
# ---------------------------------------------------------------------------

invariant ssl_extra26.SSLObject.module:
  description: "ssl.SSLObject.__module__ == 'ssl' — lightweight TLS object wrapper defined in ssl module"
  category: module_metadata
  kind: python_call_eq
  function: SSLObject.__module__.__eq__
  args: ["ssl"]
  expected: true

invariant ssl_extra26.SSLObject.base_name:
  description: "ssl.SSLObject.__bases__[0].__name__ == 'object' — SSLObject directly subclasses object"
  category: type_metadata
  kind: python_call_eq
  function: "SSLObject.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# ssl.OP_ALL — enum member class name
#
# ssl.OP_ALL is a member of the ssl.Options IntFlag enum.
# ssl_extra25 covers VerifyMode/Purpose/AlertDescription __class__.__name__
# (EnumType — metaclass). ssl.OP_ALL is an enum instance (member), so its
# __class__.__name__ is 'Options' (the enum class name), not 'EnumType'.
# No prior spec checks OP_ALL.__class__.__name__. This confirms OP_ALL
# is an Options enum member at runtime.
# ---------------------------------------------------------------------------

invariant ssl_extra26.OP_ALL.class_name:
  description: "ssl.OP_ALL.__class__.__name__ == 'Options' — OP_ALL is an Options IntFlag enum member"
  category: type_metadata
  kind: python_call_eq
  function: OP_ALL.__class__.__name__.__eq__
  args: ["Options"]
  expected: true
