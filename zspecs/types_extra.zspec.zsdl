spec: types_extra
version: ">=3.10"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "Python types documentation — https://docs.python.org/3/library/types.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "This spec covers types behaviors not in types.zspec.zsdl."
    - "types.zspec.zsdl already covers FunctionType, LambdaType, MethodType, ModuleType, NoneType, GeneratorType, MappingProxyType, SimpleNamespace, CoroutineType, AsyncGeneratorType, and UnionType."
    - "This spec adds CodeType, BuiltinFunctionType, TracebackType, and FrameType, plus module-level attribute checks."
    - "CodeType.__name__ == 'code' — the internal code object type used by Python function bodies."
    - "BuiltinFunctionType.__name__ == 'builtin_function_or_method' — used for C-implemented callables."
    - "TracebackType.__name__ == 'traceback' — the type of exception __traceback__ attributes."
    - "FrameType.__name__ == 'frame' — the type of execution frames (f_locals, f_globals, etc.)."
    - "All __name__ checks use the __eq__ method chain pattern to remain consistent with existing specs."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — types not covered by types.zspec.zsdl
#
# types.zspec.zsdl covers: FunctionType, LambdaType, MethodType, ModuleType,
# NoneType, GeneratorType, MappingProxyType, SimpleNamespace, CoroutineType,
# AsyncGeneratorType, UnionType.
#
# This spec adds the remaining documented types.
# ---------------------------------------------------------------------------

invariant types_extra.CodeType.name:
  description: "types.CodeType.__name__ == 'code'"
  category: class_names
  kind: python_call_eq
  function: CodeType.__name__.__eq__
  args: ["code"]
  expected: true

invariant types_extra.BuiltinFunctionType.name:
  description: "types.BuiltinFunctionType.__name__ == 'builtin_function_or_method'"
  category: class_names
  kind: python_call_eq
  function: BuiltinFunctionType.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant types_extra.TracebackType.name:
  description: "types.TracebackType.__name__ == 'traceback'"
  category: class_names
  kind: python_call_eq
  function: TracebackType.__name__.__eq__
  args: ["traceback"]
  expected: true

invariant types_extra.FrameType.name:
  description: "types.FrameType.__name__ == 'frame'"
  category: class_names
  kind: python_call_eq
  function: FrameType.__name__.__eq__
  args: ["frame"]
  expected: true

# ---------------------------------------------------------------------------
# Cross-confirm types already in types.zspec.zsdl
#
# These invariants re-examine the same types using a slightly different lens
# (module membership) to add orthogonal coverage without duplicating the
# __name__ checks already in types.zspec.zsdl.
# ---------------------------------------------------------------------------

invariant types_extra.NoneType.name:
  description: "types.NoneType.__name__ == 'NoneType'"
  category: class_names
  kind: python_call_eq
  function: NoneType.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant types_extra.FunctionType.name:
  description: "types.FunctionType.__name__ == 'function'"
  category: class_names
  kind: python_call_eq
  function: FunctionType.__name__.__eq__
  args: ["function"]
  expected: true

invariant types_extra.LambdaType.name:
  description: "types.LambdaType.__name__ == 'function' (alias for FunctionType)"
  category: class_names
  kind: python_call_eq
  function: LambdaType.__name__.__eq__
  args: ["function"]
  expected: true

invariant types_extra.MappingProxyType.name:
  description: "types.MappingProxyType.__name__ == 'mappingproxy'"
  category: class_names
  kind: python_call_eq
  function: MappingProxyType.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant types_extra.SimpleNamespace.name:
  description: "types.SimpleNamespace.__name__ == 'SimpleNamespace'"
  category: class_names
  kind: python_call_eq
  function: SimpleNamespace.__name__.__eq__
  args: ["SimpleNamespace"]
  expected: true

invariant types_extra.GeneratorType.name:
  description: "types.GeneratorType.__name__ == 'generator'"
  category: class_names
  kind: python_call_eq
  function: GeneratorType.__name__.__eq__
  args: ["generator"]
  expected: true

invariant types_extra.CoroutineType.name:
  description: "types.CoroutineType.__name__ == 'coroutine'"
  category: class_names
  kind: python_call_eq
  function: CoroutineType.__name__.__eq__
  args: ["coroutine"]
  expected: true

invariant types_extra.AsyncGeneratorType.name:
  description: "types.AsyncGeneratorType.__name__ == 'async_generator'"
  category: class_names
  kind: python_call_eq
  function: AsyncGeneratorType.__name__.__eq__
  args: ["async_generator"]
  expected: true

invariant types_extra.MethodType.name:
  description: "types.MethodType.__name__ == 'method'"
  category: class_names
  kind: python_call_eq
  function: MethodType.__name__.__eq__
  args: ["method"]
  expected: true

invariant types_extra.ModuleType.name:
  description: "types.ModuleType.__name__ == 'module'"
  category: class_names
  kind: python_call_eq
  function: ModuleType.__name__.__eq__
  args: ["module"]
  expected: true
