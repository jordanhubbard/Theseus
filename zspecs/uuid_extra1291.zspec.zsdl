spec: uuid_extra1291
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra129.zspec.zsdl — covers UUID.__lt__/__int__/__setattr__ __name__ / co_name / __setattr__ co_argcount and co_varnames.__len__() / __int__ co_varnames.__len__() (table + invariants)."
    - "uuid_extra128.zspec.zsdl — covers UUID.__le__/__gt__/__ge__ qualname/name/class/module/co_argcount / UUID.__repr__/__hash__ co_name and co_varnames.__len__() (table + invariants)."
    - "uuid_extra127.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__/__hash__ __name__ equality / UUID dunder __class__.__name__=='function' and __module__=='uuid' / UUID.__init__ co_argcount==7 and co_varnames.__len__()==15 / UUID.__new__ identity (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ co_name/co_argcount/__qualname__ / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier uuid spec files."
    - "Wave 533 theme: __init__ and __new__ method presence and qualname checks for uuid."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__init__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__new__.__qualname__ == 'object.__new__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__new__') == False (UUID does not override __new__). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__init__.__qualname__ == 'object.__init__'. SafeUUID does not define __init__ — it inherits from object via Enum. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__init__.__class__.__name__ == 'wrapper_descriptor'. The inherited object.__init__ is a C-level wrapper_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__dict__.__contains__('__init__') == False (SafeUUID does not define __init__ explicitly). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__class__.__name__ == 'type' (UUID is a regular Python class whose metaclass is type). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID.__init__ is a pure-Python function ('function') defined in Lib/uuid.py — it validates and normalizes the various ways a UUID can be specified. It explicitly overrides __init__ in the class body."
    - "Note: UUID does NOT override __new__ — it relies on object.__new__ to allocate the instance. Thus UUID.__new__ resolves to object.__new__ (a builtin_function_or_method)."
    - "Note: SafeUUID is an IntFlag/Enum subclass. Its metaclass is EnumType. It inherits __init__ from object — SafeUUID.__init__.__qualname__ is 'object.__init__' (a C-level wrapper_descriptor)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__')
# uuid.UUID.__init__.__class__.__name__.__eq__('function')
# uuid.UUID.__dict__.__contains__('__init__') == True
# uuid.UUID.__new__.__qualname__.__eq__('object.__new__')
# uuid.UUID.__new__.__class__.__name__.__eq__('builtin_function_or_method')
# uuid.UUID.__dict__.__contains__('__new__') == False
#
# Wave 533 theme: UUID.__init__ and __new__ identity checks.
#
# UUID explicitly defines __init__ in Lib/uuid.py to validate UUID arguments.
# UUID does NOT override __new__ — it inherits object.__new__. This is a
# common pattern for immutable-ish value objects that prefer __init__ over
# __new__. The dict containment checks distinguish between explicit definition
# (True for __init__) and inherited resolution (False for __new__).
# uuid_extra99 anchors UUID.__init__.__qualname__ via co_name equality;
# uuid_extra127 anchors UUID.__init__.__name__ equality and co_argcount.
# No prior uuid spec anchors __init__.__qualname__.__eq__ or __dict__.__contains__
# for both __init__ and __new__ under uuinit1291. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table uuid_extra1291.UUID_init_and_new_identity:
  description: "uuid.UUID/__init__/__qualname__.__eq__('UUID.__init__')==True / __init__/__class__/__name__.__eq__('function')==True / __dict__/__contains__('__init__')==True / __new__/__qualname__.__eq__('object.__new__')==True / __new__/__class__/__name__.__eq__('builtin_function_or_method')==True / __dict__/__contains__('__new__')==False — UUID defines __init__ explicitly; inherits object.__new__; dict containment distinguishes explicit vs inherited; first uuinit1291 anchor"
  kind: python_call_eq
  category: init_new_identity
  id_prefix: uuinit1291

  columns: [id, function, args, expected, description]
  rows:
    - [uu1291in001, UUID.__init__.__qualname__.__eq__,            ["UUID.__init__"],                true,  "UUID.__init__.__qualname__ is 'UUID.__init__' (defined explicitly in Lib/uuid.py class body)"]
    - [uu1291in002, UUID.__init__.__class__.__name__.__eq__,      ["function"],                     true,  "UUID.__init__.__class__.__name__ is 'function' (pure-Python method, not a C descriptor)"]
    - [uu1291in003, UUID.__dict__.__contains__,                   ["__init__"],                     true,  "UUID.__dict__.__contains__('__init__') is True — UUID explicitly overrides __init__"]
    - [uu1291in004, UUID.__new__.__qualname__.__eq__,             ["object.__new__"],                true,  "UUID.__new__.__qualname__ is 'object.__new__' — UUID does not override __new__; inherits from object"]
    - [uu1291in005, UUID.__new__.__class__.__name__.__eq__,       ["builtin_function_or_method"],    true,  "UUID.__new__.__class__.__name__ is 'builtin_function_or_method' (C-level object.__new__)"]
    - [uu1291in006, UUID.__dict__.__contains__,                   ["__new__"],                      false, "UUID.__dict__.__contains__('__new__') is False — UUID does not override __new__"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__init__.__qualname__.__eq__('object.__init__')
# uuid.SafeUUID.__init__.__class__.__name__.__eq__('wrapper_descriptor')
# uuid.SafeUUID.__dict__.__contains__('__init__') == False
# uuid.UUID.__class__.__name__.__eq__('type')
# uuid.SafeUUID.__class__.__name__.__eq__('EnumType')
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') (cross-check)
#
# Wave 533 theme: SafeUUID __init__ inheritance and class metaclass checks.
#
# SafeUUID is an Enum subclass (IntFlag/Enum). Its metaclass is EnumType, not
# the plain 'type'. SafeUUID does NOT define __init__ — it inherits object.__init__
# through the Enum MRO. object.__init__ is a C-level wrapper_descriptor, not a
# Python function. This contrasts with UUID.__init__ which is a pure-Python
# function. UUID's own metaclass is the plain 'type' (not EnumType or any
# custom metaclass). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra1291.SafeUUID_init_and_metaclass:
  description: "uuid.SafeUUID/__init__/__qualname__.__eq__('object.__init__')==True / __init__/__class__/__name__.__eq__('wrapper_descriptor')==True / __dict__/__contains__('__init__')==False / UUID/__class__/__name__.__eq__('type')==True / SafeUUID/__class__/__name__.__eq__('EnumType')==True / UUID/__init__/__qualname__.__eq__('UUID.__init__')==True — SafeUUID inherits object.__init__; UUID is a plain type; SafeUUID metaclass is EnumType; first uusa1291 anchor"
  kind: python_call_eq
  category: safeuuid_metaclass
  id_prefix: uusa1291

  columns: [id, function, args, expected, description]
  rows:
    - [uu1291sa001, SafeUUID.__init__.__qualname__.__eq__,        ["object.__init__"],    true,  "SafeUUID.__init__.__qualname__ is 'object.__init__' — SafeUUID inherits __init__ from object via Enum MRO"]
    - [uu1291sa002, SafeUUID.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"],  true,  "SafeUUID.__init__.__class__.__name__ is 'wrapper_descriptor' (C-level slot wrapper for object.__init__)"]
    - [uu1291sa003, SafeUUID.__dict__.__contains__,               ["__init__"],            false, "SafeUUID.__dict__.__contains__('__init__') is False — SafeUUID does not define __init__ explicitly"]
    - [uu1291sa004, UUID.__class__.__name__.__eq__,               ["type"],                true,  "UUID.__class__.__name__ is 'type' — UUID's metaclass is the standard 'type' (no custom metaclass)"]
    - [uu1291sa005, SafeUUID.__class__.__name__.__eq__,           ["EnumType"],            true,  "SafeUUID.__class__.__name__ is 'EnumType' — Enum subclasses use EnumType as their metaclass"]
    - [uu1291sa006, UUID.__init__.__qualname__.__eq__,            ["UUID.__init__"],       true,  "UUID.__init__.__qualname__ cross-check in SafeUUID context: 'UUID.__init__' (defined in Lib/uuid.py)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') — standalone
# uuid.UUID.__dict__.__contains__('__init__') == True — standalone
# uuid.UUID.__new__.__qualname__.__eq__('object.__new__') — standalone
# uuid.SafeUUID.__init__.__qualname__.__eq__('object.__init__') — standalone
# uuid.UUID.__class__.__name__.__eq__('type') — standalone
#
# Wave 533 theme: standalone confirmations for wave 533 init/new identity theme.
#
# These standalones provide individual anchors for the most important
# invariants in this wave. uuid_extra99 and uuid_extra127 cover related
# aspects of UUID.__init__ via co_name, co_argcount, and __name__. This spec
# (wave 533) is the first to anchor __qualname__.__eq__ and __dict__.__contains__
# as explicit standalone invariants under uusc1291. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table uuid_extra1291.UUID_wave533_standalones:
  description: "uuid.UUID/__init__/__qualname__.__eq__('UUID.__init__')==True / __dict__/__contains__('__init__')==True / __new__/__qualname__.__eq__('object.__new__')==True / SafeUUID/__init__/__qualname__.__eq__('object.__init__')==True / UUID/__class__/__name__.__eq__('type')==True / SafeUUID/__dict__/__contains__('__init__')==False — standalone wave-533 anchor confirmations; first uusc1291 anchor"
  kind: python_call_eq
  category: wave533_standalones
  id_prefix: uusc1291

  columns: [id, function, args, expected, description]
  rows:
    - [uu1291sc001, UUID.__init__.__qualname__.__eq__,            ["UUID.__init__"],       true,  "UUID.__init__.__qualname__ is 'UUID.__init__' — primary wave 533 invariant for uuid"]
    - [uu1291sc002, UUID.__dict__.__contains__,                   ["__init__"],            true,  "UUID explicitly defines __init__ (in class body); dict containment confirms this"]
    - [uu1291sc003, UUID.__new__.__qualname__.__eq__,             ["object.__new__"],      true,  "UUID.__new__ resolves to object.__new__ (inherited; not overridden by UUID)"]
    - [uu1291sc004, SafeUUID.__init__.__qualname__.__eq__,        ["object.__init__"],     true,  "SafeUUID.__init__ resolves to object.__init__ (inherited via Enum MRO)"]
    - [uu1291sc005, UUID.__class__.__name__.__eq__,               ["type"],                true,  "UUID's metaclass is 'type'; SafeUUID's metaclass is 'EnumType' (contrast)"]
    - [uu1291sc006, SafeUUID.__dict__.__contains__,               ["__init__"],            false, "SafeUUID does not define __init__ in its own __dict__ (inherited from object via Enum)"]
