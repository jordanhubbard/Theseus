spec: io2911
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/io_extra2896.zspec.zsdl — wave 640 predecessor (covered __itruediv__, __ifloordiv__, __imod__)"
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "Wave 641 theme: __ilshift__, __irshift__, __ipow__ dict-presence checks (in-place left-shift, right-shift, power operators)."
    - "io classes are I/O stream objects with no numeric, bitwise, or power semantics — none define __ilshift__, __irshift__, or __ipow__."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase are abstract base classes that also omit all three in-place shift/power operators."
    - "io.BytesIO, io.StringIO, io.FileIO do NOT define any of these operators — they are byte/string/file streams, not integers."
    - "io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper also absent for all three operators."
    - "The non-inplace counterparts (__lshift__, __rshift__, __pow__) are also absent from all io classes — absence is total."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __ilshift__ dict-presence — absent from all io ABC and concrete classes
# ---------------------------------------------------------------------------

table io2911.ilshift:
  description: "__ilshift__ is absent from all io class __dict__s — io streams have no bitwise left-shift semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2911

  columns: [id, function, args, expected]
  rows:
    - ["io2911001", "io.IOBase.__dict__.__contains__",              ["__ilshift__"], false]
    - ["io2911002", "io.RawIOBase.__dict__.__contains__",           ["__ilshift__"], false]
    - ["io2911003", "io.BufferedIOBase.__dict__.__contains__",      ["__ilshift__"], false]
    - ["io2911004", "io.TextIOBase.__dict__.__contains__",          ["__ilshift__"], false]
    - ["io2911005", "io.BytesIO.__dict__.__contains__",             ["__ilshift__"], false]
    - ["io2911006", "io.StringIO.__dict__.__contains__",            ["__ilshift__"], false]
    - ["io2911007", "io.FileIO.__dict__.__contains__",              ["__ilshift__"], false]
    - ["io2911008", "io.BufferedReader.__dict__.__contains__",      ["__ilshift__"], false]
    - ["io2911009", "io.BufferedWriter.__dict__.__contains__",      ["__ilshift__"], false]
    - ["io2911010", "io.BufferedRandom.__dict__.__contains__",      ["__ilshift__"], false]
    - ["io2911011", "io.TextIOWrapper.__dict__.__contains__",       ["__ilshift__"], false]
    - ["io2911012", "io.IncrementalNewlineDecoder.__dict__.__contains__", ["__ilshift__"], false]

