# ---------------------------------------------------------------------------
# Table: ABC-layer combined — all three in-place shift/power ops absent from ABCs
# Confirms absence is established at the ABC level, not per-concrete-class
# ---------------------------------------------------------------------------

table io2911.combined:
  description: "In-place lshift/rshift/pow ops absent from all four io ABC layers — io streams have no numeric or bitwise semantics at any level"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2911

  columns: [id, function, args, expected]
  rows:
    - ["io2911037", "io.IOBase.__dict__.__contains__",         ["__ilshift__"], false]
    - ["io2911038", "io.IOBase.__dict__.__contains__",         ["__irshift__"], false]
    - ["io2911039", "io.IOBase.__dict__.__contains__",         ["__ipow__"],    false]
    - ["io2911040", "io.RawIOBase.__dict__.__contains__",      ["__ilshift__"], false]
    - ["io2911041", "io.RawIOBase.__dict__.__contains__",      ["__irshift__"], false]
    - ["io2911042", "io.RawIOBase.__dict__.__contains__",      ["__ipow__"],    false]
    - ["io2911043", "io.BufferedIOBase.__dict__.__contains__", ["__ilshift__"], false]
    - ["io2911044", "io.BufferedIOBase.__dict__.__contains__", ["__irshift__"], false]
    - ["io2911045", "io.BufferedIOBase.__dict__.__contains__", ["__ipow__"],    false]
    - ["io2911046", "io.TextIOBase.__dict__.__contains__",     ["__ilshift__"], false]
    - ["io2911047", "io.TextIOBase.__dict__.__contains__",     ["__irshift__"], false]
    - ["io2911048", "io.TextIOBase.__dict__.__contains__",     ["__ipow__"],    false]
