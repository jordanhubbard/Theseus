spec: struct_extra219
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.pack.__class__.__name__ == 'method_descriptor' — pack is a C-level method descriptor."
    - "struct.Struct.unpack.__class__.__name__ == 'method_descriptor' — unpack is a C-level method descriptor."
    - "struct.Struct.pack_into.__class__.__name__ == 'method_descriptor' — pack_into is a C-level method descriptor."
    - "struct.Struct.unpack_from.__class__.__name__ == 'method_descriptor' — unpack_from is a C-level method descriptor."
    - "struct.Struct.iter_unpack.__class__.__name__ == 'method_descriptor' — iter_unpack is a C-level method descriptor."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor' — size is a C-level getset descriptor."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor' — format is a C-level getset descriptor."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method' — module-level pack is C-level builtin."
    - "struct.unpack.__class__.__name__ == 'builtin_function_or_method' — module-level unpack is C-level builtin."
    - "struct.calcsize.__class__.__name__ == 'builtin_function_or_method' — module-level calcsize is C-level builtin."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct Struct method and attribute __class__ type contracts
#
# struct.Struct.pack.__class__.__name__        == 'method_descriptor'
# struct.Struct.unpack.__class__.__name__      == 'method_descriptor'
# struct.Struct.pack_into.__class__.__name__   == 'method_descriptor'
# struct.Struct.unpack_from.__class__.__name__ == 'method_descriptor'
# struct.Struct.iter_unpack.__class__.__name__ == 'method_descriptor'
# struct.Struct.size.__class__.__name__        == 'getset_descriptor'
# struct.Struct.format.__class__.__name__      == 'getset_descriptor'
# ---------------------------------------------------------------------------

table struct_extra219.Struct_method_type_contracts:
  description: "struct Struct method and attribute __class__ type contracts in struct219 namespace — wave 219 theme: Struct.pack/unpack/pack_into/unpack_from/iter_unpack are all method_descriptor (C-level bound methods); Struct.size and Struct.format are getset_descriptor (C-level computed attributes); module-level pack/unpack/calcsize are builtin_function_or_method; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: struct219

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_pack_class,        struct.Struct.pack.__class__.__name__.__eq__,        ["method_descriptor"], true, "struct.Struct.pack.__class__.__name__ == 'method_descriptor' — pack is a C-level method descriptor on Struct"]
    - [Struct_unpack_class,      struct.Struct.unpack.__class__.__name__.__eq__,      ["method_descriptor"], true, "struct.Struct.unpack.__class__.__name__ == 'method_descriptor' — unpack is a C-level method descriptor on Struct"]
    - [Struct_pack_into_class,   struct.Struct.pack_into.__class__.__name__.__eq__,   ["method_descriptor"], true, "struct.Struct.pack_into.__class__.__name__ == 'method_descriptor' — pack_into is a C-level method descriptor on Struct"]
    - [Struct_unpack_from_class, struct.Struct.unpack_from.__class__.__name__.__eq__, ["method_descriptor"], true, "struct.Struct.unpack_from.__class__.__name__ == 'method_descriptor' — unpack_from is a C-level method descriptor on Struct"]
    - [Struct_iter_unpack_class, struct.Struct.iter_unpack.__class__.__name__.__eq__, ["method_descriptor"], true, "struct.Struct.iter_unpack.__class__.__name__ == 'method_descriptor' — iter_unpack is a C-level method descriptor on Struct"]
    - [Struct_size_class,        struct.Struct.size.__class__.__name__.__eq__,        ["getset_descriptor"], true, "struct.Struct.size.__class__.__name__ == 'getset_descriptor' — size is a C-level getset descriptor (read-only computed attribute)"]
    - [Struct_format_class,      struct.Struct.format.__class__.__name__.__eq__,      ["getset_descriptor"], true, "struct.Struct.format.__class__.__name__ == 'getset_descriptor' — format is a C-level getset descriptor (read-only computed attribute)"]

# ---------------------------------------------------------------------------
# struct module-level function type contracts
#
# struct.pack.__class__.__name__     == 'builtin_function_or_method'
# struct.unpack.__class__.__name__   == 'builtin_function_or_method'
# struct.calcsize.__class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table struct_extra219.struct_module_function_types:
  description: "struct module-level function type contracts in struct219a namespace — wave 219 theme: module-level pack/unpack/calcsize are all builtin_function_or_method; these are convenience wrappers around Struct methods exposed directly on the module; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: struct219a

  columns: [id, function, args, expected, description]
  rows:
    - [pack_class,     struct.pack.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "struct.pack.__class__.__name__ == 'builtin_function_or_method' — module-level pack is a C-level builtin"]
    - [unpack_class,   struct.unpack.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "struct.unpack.__class__.__name__ == 'builtin_function_or_method' — module-level unpack is a C-level builtin"]
    - [calcsize_class, struct.calcsize.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "struct.calcsize.__class__.__name__ == 'builtin_function_or_method' — calcsize is a C-level builtin returning packed size for a format string"]

# ---------------------------------------------------------------------------
# Standalone invariants for Struct method type contracts
# ---------------------------------------------------------------------------

invariant struct_extra219.Struct_pack_method_descriptor_eq:
  description: "struct.Struct.pack.__class__.__name__.__eq__('method_descriptor') == True — Struct.pack is a C-level method descriptor; calling it on a Struct instance creates a bound method; defined in Modules/_struct.c; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: struct.Struct.pack.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant struct_extra219.Struct_size_getset_descriptor_eq:
  description: "struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') == True — Struct.size is a C-level getset_descriptor; it computes the size of the packed struct format at the C level; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: struct.Struct.size.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true
