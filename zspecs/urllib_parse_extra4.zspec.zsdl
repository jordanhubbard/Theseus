spec: urllib_parse_extra4
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
  notes:
    - "This spec extends urllib_parse.zspec.zsdl, urllib_parse_extra.zspec.zsdl, urllib_parse_extra2.zspec.zsdl, urllib_parse_extra3.zspec.zsdl."
    - "Focus: __qualname__ attributes for urllib.parse functions and classes, plus quote/unquote value correctness."
    - "urllib.parse.quote(' ') == '%20' — space is always percent-encoded."
    - "urllib.parse.quote('/', safe='') == '%2F' — slash is encoded only when safe='' is passed explicitly."
    - "urllib.parse.unquote('%20') == ' ' — %20 decodes to space."
    - "ParseResult, SplitResult, DefragResult are named-tuple subclasses defined in urllib.parse."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Named result type qualnames — ParseResult, SplitResult, DefragResult
# ---------------------------------------------------------------------------

invariant urllib_parse_extra4.ParseResult.qualname:
  description: "urllib.parse.ParseResult.__qualname__ == 'ParseResult'"
  category: qualnames
  kind: python_call_eq
  function: ParseResult.__qualname__.__eq__
  args: ["ParseResult"]
  expected: true

invariant urllib_parse_extra4.SplitResult.qualname:
  description: "urllib.parse.SplitResult.__qualname__ == 'SplitResult'"
  category: qualnames
  kind: python_call_eq
  function: SplitResult.__qualname__.__eq__
  args: ["SplitResult"]
  expected: true

invariant urllib_parse_extra4.DefragResult.qualname:
  description: "urllib.parse.DefragResult.__qualname__ == 'DefragResult'"
  category: qualnames
  kind: python_call_eq
  function: DefragResult.__qualname__.__eq__
  args: ["DefragResult"]
  expected: true

# ---------------------------------------------------------------------------
# urldefrag qualname — individual invariant (not in table below)
# ---------------------------------------------------------------------------

invariant urllib_parse_extra4.urldefrag.qualname:
  description: "urllib.parse.urldefrag.__qualname__ == 'urldefrag'"
  category: qualnames
  kind: python_call_eq
  function: urldefrag.__qualname__.__eq__
  args: ["urldefrag"]
  expected: true

# ---------------------------------------------------------------------------
# Table: qualname checks for common urllib.parse functions
# ---------------------------------------------------------------------------

table urllib_parse_extra4.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [urlparse,   urlparse.__qualname__.__eq__,   ["urlparse"],   true]
    - [urlsplit,   urlsplit.__qualname__.__eq__,   ["urlsplit"],   true]
    - [urljoin,    urljoin.__qualname__.__eq__,    ["urljoin"],    true]
    - [urlencode,  urlencode.__qualname__.__eq__,  ["urlencode"],  true]
    - [quote,      quote.__qualname__.__eq__,      ["quote"],      true]
    - [unquote,    unquote.__qualname__.__eq__,    ["unquote"],    true]

# ---------------------------------------------------------------------------
# quote() — value correctness
# space → %20 (safe=' ' is the default but space is still encoded)
# slash with safe='' → %2F
# ---------------------------------------------------------------------------

invariant urllib_parse_extra4.quote.space_to_pct20:
  description: "urllib.parse.quote(' ') == '%20' — space is always percent-encoded"
  category: quote_values
  kind: python_call_eq
  function: quote
  args: [" "]
  expected: "%20"

invariant urllib_parse_extra4.quote.slash_safe_empty:
  description: "urllib.parse.quote('/', safe='') == '%2F' — slash encoded when safe=''"
  category: quote_values
  kind: python_call_eq
  function: quote
  args: ["/", ""]
  expected: "%2F"

# ---------------------------------------------------------------------------
# unquote() — value correctness
# ---------------------------------------------------------------------------

invariant urllib_parse_extra4.unquote.pct20_to_space:
  description: "urllib.parse.unquote('%20') == ' ' — %20 decodes to space"
  category: unquote_values
  kind: python_call_eq
  function: unquote
  args: ["%20"]
  expected: " "
