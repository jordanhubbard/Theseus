spec: pathlib_extra19
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "This spec extends pathlib.zspec.zsdl through pathlib_extra18.zspec.zsdl."
    - "pathlib_extra18 covers PurePath/PosixPath/PurePosixPath MRO[1].__name__; PurePosixPath root parts, two-component parts, name with extension, root/anchor of '/'."
    - "pathlib_extra17 covers PurePath method __name__/__qualname__ and behavioral vectors for with_name/with_suffix/relative_to/is_relative_to."
    - "pathlib_extra16 covers MRO lengths for all six public classes; PureWindowsPath.__name__ standalone."
    - "pathlib_extra6 covers __qualname__ for all six classes."
    - "pathlib_extra4 covers Path.open/stat/mkdir/exists __name__ attributes."
    - "NOT yet covered: Path.home.__qualname__ == 'Path.home' — class method qualname."
    - "NOT yet covered: Path.cwd.__qualname__ == 'Path.cwd' — class method qualname."
    - "NOT yet covered: Path.stat.__qualname__ == 'Path.stat' — method qualname."
    - "NOT yet covered: Path.open.__qualname__ == 'Path.open' — method qualname."
    - "NOT yet covered: Path.mkdir.__qualname__ == 'Path.mkdir' — method qualname."
    - "NOT yet covered: Path.exists.__qualname__ == 'Path.exists' — method qualname."
    - "NOT yet covered: PurePath.__qualname__ == 'PurePath' as a standalone invariant (pathlib_extra6 uses a table row)."
    - "NOT yet covered: PurePosixPath.__qualname__ == 'PurePosixPath' as a standalone invariant."
    - "Path.home.__qualname__ == 'Path.home' — class method, qualname includes class prefix."
    - "Path.cwd.__qualname__ == 'Path.cwd' — class method, qualname includes class prefix."
    - "Path.stat.__qualname__ == 'Path.stat' — instance method qualname."
    - "Path.open.__qualname__ == 'Path.open' — instance method qualname."
    - "Path.mkdir.__qualname__ == 'Path.mkdir' — instance method qualname."
    - "Path.exists.__qualname__ == 'Path.exists' — instance method qualname."
    - "PurePath.__qualname__ == 'PurePath' — standalone (not table) invariant."
    - "PurePosixPath.__qualname__ == 'PurePosixPath' — standalone invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path class method __qualname__ attributes: home and cwd
#
# pathlib_extra4 covers Path.open/stat/mkdir/exists __name__ attributes.
# pathlib_extra6 covers __qualname__ for the six public *classes* but NOT
# for their methods. Path.home and Path.cwd are class methods; their
# qualname is 'Path.home' and 'Path.cwd' respectively.
# ---------------------------------------------------------------------------

invariant pathlib_extra19.Path.home.qualname:
  description: "Path.home.__qualname__ == 'Path.home' — class method qualname includes class prefix"
  category: method_identity
  kind: python_call_eq
  function: Path.home.__qualname__.__eq__
  args: ["Path.home"]
  expected: true

invariant pathlib_extra19.Path.cwd.qualname:
  description: "Path.cwd.__qualname__ == 'Path.cwd' — class method qualname includes class prefix"
  category: method_identity
  kind: python_call_eq
  function: Path.cwd.__qualname__.__eq__
  args: ["Path.cwd"]
  expected: true

# ---------------------------------------------------------------------------
# Path instance method __qualname__ attributes
#
# pathlib_extra4 records __name__ for open/stat/mkdir/exists.
# No prior spec records __qualname__ for any of these instance methods.
# For instance methods on a class, __qualname__ == 'ClassName.method_name'.
# ---------------------------------------------------------------------------

table pathlib_extra19.path_method_qualnames:
  description: "Path instance method __qualname__ attributes"
  kind: python_call_eq
  category: method_identity
  id_prefix: pmqn

  columns: [id, function, args, expected]
  rows:
    - [stat,   Path.stat.__qualname__.__eq__,   ["Path.stat"],   true]
    - [open,   Path.open.__qualname__.__eq__,   ["Path.open"],   true]
    - [mkdir,  Path.mkdir.__qualname__.__eq__,  ["Path.mkdir"],  true]
    - [exists, Path.exists.__qualname__.__eq__, ["Path.exists"], true]

# ---------------------------------------------------------------------------
# PurePath.__qualname__ — standalone invariant
#
# pathlib_extra6 covers PurePath.__qualname__ == 'PurePath' in a table row.
# This standalone invariant provides direct lookup in the pathlib_extra19
# namespace without requiring table context.
# ---------------------------------------------------------------------------

invariant pathlib_extra19.PurePath.qualname_standalone:
  description: "pathlib.PurePath.__qualname__ == 'PurePath' — standalone invariant"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__qualname__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra19.PurePosixPath.qualname_standalone:
  description: "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath' — standalone invariant"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__qualname__.__eq__
  args: ["PurePosixPath"]
  expected: true

# ---------------------------------------------------------------------------
# PurePath.__module__ — standalone invariant
#
# pathlib_extra15 covers PurePath.__module__ in a table.
# No prior spec has a standalone invariant for PurePath.__module__ == 'pathlib'.
# ---------------------------------------------------------------------------

invariant pathlib_extra19.PurePath.module_standalone:
  description: "pathlib.PurePath.__module__ == 'pathlib' — standalone invariant"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra19.PurePosixPath.module_standalone:
  description: "pathlib.PurePosixPath.__module__ == 'pathlib' — standalone invariant"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra19.PosixPath.module_standalone:
  description: "pathlib.PosixPath.__module__ == 'pathlib' — standalone invariant"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra19.PureWindowsPath.module_standalone:
  description: "pathlib.PureWindowsPath.__module__ == 'pathlib' — standalone invariant"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true
