spec: node_os
version: ">=12.0.0"
backend: node(os)

docs: https://nodejs.org/api/os.html

provenance:
  derived_from:
    - "Node.js os module documentation — https://nodejs.org/api/os.html"
    - "Test vectors verified with Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "Node.js source"
  notes:
    - "os is a Node.js built-in module. No npm install required."
    - "Tests use only deterministic values that are constant in Docker/Linux environments."
    - "os.platform() → 'linux' in Docker. os.endianness() → 'LE' on x86/ARM."
    - "os.type() → 'Linux' in Docker."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns OS information strings."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table node_os.platform:
  kind: node_module_call_eq
  function: platform
  category: platform
  id_prefix: osplat

  columns: [id, args, expected]
  rows:
    - [linux, [], "linux"]

table node_os.type:
  kind: node_module_call_eq
  function: type
  category: type
  id_prefix: ostype

  columns: [id, args, expected]
  rows:
    - [linux, [], "Linux"]

table node_os.endianness:
  kind: node_module_call_eq
  function: endianness
  category: endianness
  id_prefix: osend

  columns: [id, args, expected]
  rows:
    - [little_endian, [], "LE"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:49:07Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
