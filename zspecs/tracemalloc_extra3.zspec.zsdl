spec: tracemalloc_extra3
version: ">=3.9"
backend: python_module(tracemalloc)

docs: https://docs.python.org/3/library/tracemalloc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tracemalloc.html — Python tracemalloc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tracemalloc.py"
    - "CPython source: Modules/_tracemalloc.c"
    - "tracemalloc.zspec.zsdl — covers function __name__ table, class __name__ table, Snapshot.__module__, is_tracing, get_traceback_limit"
    - "tracemalloc_extra.zspec.zsdl — covers class __name__ table, Snapshot.__module__, function __name__ table"
    - "tracemalloc_extra2.zspec.zsdl — covers individual class __name__ invariants and class __module__ table for all classes"
  notes:
    - "This spec extends tracemalloc_extra2.zspec.zsdl."
    - "Focus: class hierarchy (__bases__) and __qualname__ for tracemalloc classes."
    - "Snapshot.__bases__[0].__name__ == 'object' — Snapshot inherits directly from object."
    - "Filter.__bases__[0].__name__ == 'object' — Filter inherits directly from object."
    - "StatisticDiff.__bases__[0].__name__ == 'object' — StatisticDiff inherits directly from object."
    - "Statistic.__bases__[0].__name__ == 'object' — Statistic inherits directly from object."
    - "Traceback.__bases__[0].__name__ == 'Sequence' — Traceback inherits from collections.abc.Sequence."
    - "Frame.__bases__[0].__name__ == 'object' — Frame inherits directly from object."
    - "Class __qualname__ == __name__ for all top-level classes in tracemalloc."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __bases__ — hierarchy checks
# Not covered by tracemalloc.zspec.zsdl, tracemalloc_extra.zspec.zsdl, or tracemalloc_extra2.zspec.zsdl
# ---------------------------------------------------------------------------

invariant tracemalloc_extra3.Snapshot.base_name:
  description: "tracemalloc.Snapshot.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Snapshot.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant tracemalloc_extra3.Filter.base_name:
  description: "tracemalloc.Filter.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Filter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant tracemalloc_extra3.StatisticDiff.base_name:
  description: "tracemalloc.StatisticDiff.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: StatisticDiff.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant tracemalloc_extra3.Statistic.base_name:
  description: "tracemalloc.Statistic.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Statistic.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant tracemalloc_extra3.Frame.base_name:
  description: "tracemalloc.Frame.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Frame.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Class __qualname__ checks — not covered by any prior tracemalloc spec
# For top-level classes, __qualname__ == __name__
# ---------------------------------------------------------------------------

table tracemalloc_extra3.class_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Snapshot,      Snapshot.__qualname__.__eq__,      ["Snapshot"],      true]
    - [Filter,        Filter.__qualname__.__eq__,        ["Filter"],        true]
    - [StatisticDiff, StatisticDiff.__qualname__.__eq__, ["StatisticDiff"], true]
    - [Statistic,     Statistic.__qualname__.__eq__,     ["Statistic"],     true]
    - [Traceback,     Traceback.__qualname__.__eq__,     ["Traceback"],     true]
    - [Frame,         Frame.__qualname__.__eq__,         ["Frame"],         true]
