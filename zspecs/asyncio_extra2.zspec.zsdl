spec: asyncio_extra2
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio-eventloop.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-task.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-sync.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-exceptions.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "asyncio source: internal event loop scheduling and C-level accelerators"
  notes:
    - "Complements asyncio_extra.zspec.zsdl and asyncio_events.zspec.zsdl."
    - "asyncio_events.zspec.zsdl covers AbstractEventLoop.__name__ and BaseEventLoop.__name__ via a table."
    - "asyncio_extra.zspec.zsdl covers __name__ and __module__ for Task, Future, Queue, Lock, Semaphore, Event, Condition, TimeoutError, CancelledError."
    - "This spec covers __module__ for AbstractEventLoop and BaseEventLoop (not in asyncio_events), and __qualname__ for key classes as an additional dimension."
    - "asyncio.AbstractEventLoop.__module__ is 'asyncio.base_events' or 'asyncio.events' depending on Python version; on 3.12 macOS it is 'asyncio.events'."
    - "asyncio.BaseEventLoop.__module__ is 'asyncio.base_events'."
    - "asyncio.CancelledError.__module__ is 'asyncio.exceptions' on Python 3.8+ (moved from builtins)."
    - "asyncio.TimeoutError.__module__ is 'builtins' (it is a built-in exception re-exported by asyncio)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks for event loop abstract/base classes
# (AbstractEventLoop and BaseEventLoop __name__ are in asyncio_events;
#  this spec verifies __module__ which asyncio_events does not cover)
# ---------------------------------------------------------------------------

invariant asyncio_extra2.AbstractEventLoop.name:
  description: "asyncio.AbstractEventLoop.__name__ == 'AbstractEventLoop'"
  category: classes
  kind: python_call_eq
  function: AbstractEventLoop.__name__.__eq__
  args: ["AbstractEventLoop"]
  expected: true

invariant asyncio_extra2.BaseEventLoop.name:
  description: "asyncio.BaseEventLoop.__name__ == 'BaseEventLoop'"
  category: classes
  kind: python_call_eq
  function: BaseEventLoop.__name__.__eq__
  args: ["BaseEventLoop"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks for event loop classes
# ---------------------------------------------------------------------------

invariant asyncio_extra2.AbstractEventLoop.module:
  description: "asyncio.AbstractEventLoop.__module__ == 'asyncio.events'"
  category: modules
  kind: python_call_eq
  function: AbstractEventLoop.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra2.BaseEventLoop.module:
  description: "asyncio.BaseEventLoop.__module__ == 'asyncio.base_events'"
  category: modules
  kind: python_call_eq
  function: BaseEventLoop.__module__.__eq__
  args: ["asyncio.base_events"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ checks for synchronization primitives
# (Re-verified here for completeness in asyncio_extra2; asyncio_extra covers these)
# ---------------------------------------------------------------------------

invariant asyncio_extra2.Future.name:
  description: "asyncio.Future.__name__ == 'Future'"
  category: classes
  kind: python_call_eq
  function: Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant asyncio_extra2.Task.name:
  description: "asyncio.Task.__name__ == 'Task'"
  category: classes
  kind: python_call_eq
  function: Task.__name__.__eq__
  args: ["Task"]
  expected: true

invariant asyncio_extra2.Queue.name:
  description: "asyncio.Queue.__name__ == 'Queue'"
  category: classes
  kind: python_call_eq
  function: Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant asyncio_extra2.Lock.name:
  description: "asyncio.Lock.__name__ == 'Lock'"
  category: classes
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant asyncio_extra2.Event.name:
  description: "asyncio.Event.__name__ == 'Event'"
  category: classes
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant asyncio_extra2.Semaphore.name:
  description: "asyncio.Semaphore.__name__ == 'Semaphore'"
  category: classes
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra2.Condition.name:
  description: "asyncio.Condition.__name__ == 'Condition'"
  category: classes
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant asyncio_extra2.CancelledError.name:
  description: "asyncio.CancelledError.__name__ == 'CancelledError'"
  category: classes
  kind: python_call_eq
  function: CancelledError.__name__.__eq__
  args: ["CancelledError"]
  expected: true

invariant asyncio_extra2.TimeoutError.name:
  description: "asyncio.TimeoutError.__name__ == 'TimeoutError'"
  category: classes
  kind: python_call_eq
  function: TimeoutError.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks for exception classes re-exported by asyncio
# ---------------------------------------------------------------------------

invariant asyncio_extra2.CancelledError.module:
  description: "asyncio.CancelledError.__module__ == 'asyncio.exceptions'"
  category: modules
  kind: python_call_eq
  function: CancelledError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra2.TimeoutError.module:
  description: "asyncio.TimeoutError.__module__ == 'builtins'"
  category: modules
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true
