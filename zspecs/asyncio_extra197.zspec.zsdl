table asyncio_extra197.asyncio_Future_method_qualnames:
  description: "asyncio.Future method qualname checks in asynciofuture197 namespace — Future.result.__qualname__=='Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13; result() returns the result set by set_result(), raising InvalidStateError if not done or CancelledError if cancelled); Future.done.__qualname__=='Future.done' (len=11: 'Future'=6+'.'=1+'done'=4=11; done() returns True when the Future is complete, cancelled, or has an exception); Future.exception.__qualname__=='Future.exception' (len=16: 'Future'=6+'.'=1+'exception'=9=16; exception() returns the exception set by set_exception(), or None); exception.__qualname__ (16) > result.__qualname__ (13) > done.__qualname__ (11) — length ordering; verified with Python 3.14.3"
  kind: python_call_eq
  category: methods
  id_prefix: asynciofuture197

  columns: [id, function, args, expected, description]
  rows:
    - [future_result_qn_eq,     asyncio.Future.result.__qualname__.__eq__,      ["Future.result"],     true, "asyncio.Future.result.__qualname__ == 'Future.result' (len=13; returns result or raises stored exception); verified Python 3.14.3"]
    - [future_result_qn_len,    asyncio.Future.result.__qualname__.__len__,     [],                    13,   "asyncio.Future.result.__qualname__.__len__() == 13 ('Future.result'=13: 'Future'=6+'.'=1+'result'=6=13); verified Python 3.14.3"]
    - [future_done_qn_eq,       asyncio.Future.done.__qualname__.__eq__,        ["Future.done"],       true, "asyncio.Future.done.__qualname__ == 'Future.done' (len=11; returns True when Future is complete/cancelled/excepted); verified Python 3.14.3"]
    - [future_exception_qn_eq,  asyncio.Future.exception.__qualname__.__eq__,   ["Future.exception"],  true, "asyncio.Future.exception.__qualname__ == 'Future.exception' (len=16; returns the stored exception or None); verified Python 3.14.3"]
    - [future_exception_qn_len, asyncio.Future.exception.__qualname__.__len__,  [],                    16,   "asyncio.Future.exception.__qualname__.__len__() == 16 ('Future.exception'=16: 'Future'=6+'.'=1+'exception'=9=16); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra197
# ---------------------------------------------------------------------------

invariant asyncio_extra197.asyncio_Future_name_eq:
  description: "asyncio.Future.__name__.__eq__('Future') returns True — Future.__name__=='Future' (len=6: F(1)u(2)t(3)u(4)r(5)e(6)); asyncio.Future is the low-level awaitable object that represents an eventual result of an asynchronous operation; it is the base class for asyncio.Task; Futures are set by calling set_result() or set_exception() and awaited by coroutines; Future.__name__ (6) == Future.__bases__[0].__name__ (6: 'object') — coincidentally the same length; Future.__name__ (6) < Future.__module__ (8) by 2; NEW in asynciofuture197: first standalone Future.__name__.__eq__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant asyncio_extra197.asyncio_Future_module_eq:
  description: "asyncio.Future.__module__.__eq__('_asyncio') returns True — Future.__module__=='_asyncio' (len=8: '_asyncio'=8: '_'=1+'asyncio'=7=8); Future is implemented in the C extension _asyncio for performance; the leading underscore marks it as a private C implementation detail; Future.__module__ (8) == asyncio.Task.__module__ (8: '_asyncio') — both Future and Task are implemented in the same C extension; Future.__module__ (8) < asyncio.Queue.__module__ (14: 'asyncio.queues') — C extension name is shorter than pure-Python submodule names; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra197.asyncio_Future_base_name_eq:
  description: "asyncio.Future.__bases__[0].__name__.__eq__('object') returns True — Future.__bases__[0].__name__=='object' (len=6: o(1)b(2)j(3)e(4)c(5)t(6)); Future inherits directly from object — it is a top-level class that does not extend any asyncio-specific base; this contrasts with asyncio.Task, whose base is Future itself; Future.__bases__[0].__name__ (6: 'object') == Future.__name__ (6: 'Future') — the base class name and the class name are coincidentally the same length; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra197.asyncio_Future_class_name_eq:
  description: "asyncio.Future.__class__.__name__.__eq__('type') returns True — Future.__class__.__name__=='type' (len=4); Future is a regular Python class, not a metaclass or descriptor; its metaclass is the built-in type (same as most Python classes); Future.__class__.__name__ (4: 'type') < Future.__name__ (6: 'Future') by 2 — metaclass name shorter than the class name; Future.__class__.__name__ (4) < Future.__module__ (8) by 4; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra197.asyncio_Future_result_qualname_eq:
  description: "asyncio.Future.result.__qualname__.__eq__('Future.result') returns True — Future.result.__qualname__=='Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13); result() returns the result value set by set_result(); if the Future is not done it raises InvalidStateError; if the Future was cancelled it raises CancelledError; if the Future was set with an exception it re-raises it; Future.result.__qualname__ (13) == Future.cancel.__qualname__ (13) — identical qualname lengths; Future.result.__qualname__ (13) > Future.done.__qualname__ (11) by 2; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: methods
  kind: python_call_eq
  function: asyncio.Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant asyncio_extra197.asyncio_Future_cancel_qualname_eq:
  description: "asyncio.Future.cancel.__qualname__.__eq__('Future.cancel') returns True — Future.cancel.__qualname__=='Future.cancel' (len=13: 'Future'=6+'.'=1+'cancel'=6=13); cancel() changes the Future's state to cancelled if it is not already done and schedules all callbacks; cancel() returns True if the Future was successfully cancelled, False if it was already done; Future.cancel.__qualname__ (13) == Future.result.__qualname__ (13) — cancel and result are both 6-char method names giving the same qualname length; Future.cancel.__qualname__ (13) < Future.exception.__qualname__ (16) by 3; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: methods
  kind: python_call_eq
  function: asyncio.Future.cancel.__qualname__.__eq__
  args: ["Future.cancel"]
  expected: true

invariant asyncio_extra197.asyncio_Future_done_qualname_eq:
  description: "asyncio.Future.done.__qualname__.__eq__('Future.done') returns True — Future.done.__qualname__=='Future.done' (len=11: 'Future'=6+'.'=1+'done'=4=11); done() returns True if the Future is finished — either set_result() or set_exception() was called, or it was cancelled; Future.done.__qualname__ (11) is the shortest method qualname in this spec; Future.done.__qualname__ (11) < Future.cancel.__qualname__ (13) by 2; Future.done.__qualname__ (11) < Future.exception.__qualname__ (16) by 5; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: methods
  kind: python_call_eq
  function: asyncio.Future.done.__qualname__.__eq__
  args: ["Future.done"]
  expected: true

invariant asyncio_extra197.asyncio_Future_exception_qualname_eq:
  description: "asyncio.Future.exception.__qualname__.__eq__('Future.exception') returns True — Future.exception.__qualname__=='Future.exception' (len=16: 'Future'=6+'.'=1+'exception'=9=16); exception() returns the exception that was set by set_exception(), or None if no exception was set; if the Future is not done it raises InvalidStateError; if the Future was cancelled it raises CancelledError; Future.exception.__qualname__ (16) is the longest method qualname in this spec; Future.exception.__qualname__ (16) > Future.result.__qualname__ (13) by 3; NEW in asynciofuture197: completing 8-invariant coverage for asyncio.Future class identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: methods
  kind: python_call_eq
  function: asyncio.Future.exception.__qualname__.__eq__
  args: ["Future.exception"]
  expected: true
