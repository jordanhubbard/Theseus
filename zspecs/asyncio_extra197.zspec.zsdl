table asyncio_extra197.asyncio_Future_type_and_cancel:
  description: "asyncio.Future metaclass and cancel method identity in asynciofuture197 namespace — Future.__class__.__name__=='type' (len=4; Future is a regular Python class; its metaclass is the built-in type); Future.__bases__[0].__name__.__len__()==6 (confirming 'object'=6 as the direct base class); Future.cancel.__qualname__=='Future.cancel' (len=13: 'Future'=6+'.'=1+'cancel'=6=13; cancel() sets the Future's state to cancelled and schedules callbacks); Future.cancel.__qualname__ (13) == Future.result.__qualname__ (13) — both method qualnames share the same length; Future.__class__.__name__ (4) < Future.__module__ (8) by 4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciofuture197

  columns: [id, function, args, expected, description]
  rows:
    - [future_class_eq,       asyncio.Future.__class__.__name__.__eq__,             ["type"],          true, "asyncio.Future.__class__.__name__ == 'type' (len=4; Future is a regular class, metaclass is type); verified Python 3.14.3"]
    - [future_class_len,      asyncio.Future.__class__.__name__.__len__,            [],                4,    "asyncio.Future.__class__.__name__.__len__() == 4 ('type'=4: t(1)y(2)p(3)e(4)); verified Python 3.14.3"]
    - ["future_base_len",     "asyncio.Future.__bases__[0].__name__.__len__",       [],                6,    "asyncio.Future.__bases__[0].__name__.__len__() == 6 ('object'=6: o(1)b(2)j(3)e(4)c(5)t(6)); verified Python 3.14.3"]
    - [future_cancel_qn_eq,   asyncio.Future.cancel.__qualname__.__eq__,            ["Future.cancel"], true, "asyncio.Future.cancel.__qualname__ == 'Future.cancel' (len=13; qualname includes the class prefix); verified Python 3.14.3"]
    - [future_cancel_qn_len,  asyncio.Future.cancel.__qualname__.__len__,           [],                13,   "asyncio.Future.cancel.__qualname__.__len__() == 13 ('Future.cancel'=13: 'Future'=6+'.'=1+'cancel'=6=13); verified Python 3.14.3"]

