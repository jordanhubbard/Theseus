spec: asyncio_extra197
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-future.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-future.html — Python asyncio Future class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
    - "CPython source: Lib/asyncio/futures.py"
  notes:
    - "asyncio.Future.__name__ == 'Future' (len=6: F(1)u(2)t(3)u(4)r(5)e(6)); the low-level awaitable object that represents an eventual result of an asynchronous operation."
    - "asyncio.Future.__module__ == '_asyncio' (len=8); Future is implemented in the C extension _asyncio, not pure Python asyncio.futures."
    - "asyncio.Future.__bases__[0].__name__ == 'object' (len=6); Future inherits directly from object (unlike Task which inherits from Future)."
    - "asyncio.Future.__class__.__name__ == 'type' (len=4); Future is a regular Python class whose metaclass is the built-in type."
    - "asyncio.Future.result.__qualname__ == 'Future.result' (len=13: 'Future'=6+'.'=1+'result'=6=13); returns the result set by set_result()."
    - "asyncio.Future.cancel.__qualname__ == 'Future.cancel' (len=13: 'Future'=6+'.'=1+'cancel'=6=13); requests cancellation of the Future."
    - "asyncio.Future.done.__qualname__ == 'Future.done' (len=11: 'Future'=6+'.'=1+'done'=4=11); returns True if the Future is complete."
    - "asyncio.Future.exception.__qualname__ == 'Future.exception' (len=16: 'Future'=6+'.'=1+'exception'=9=16); returns the exception set by set_exception()."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Future class identity — __name__, __module__, __bases__
#
# Future.__name__ == 'Future' (len=6)
# Future.__module__ == '_asyncio' (len=8)
# Future.__bases__[0].__name__ == 'object' (len=6)
# ---------------------------------------------------------------------------

table asyncio_extra197.asyncio_Future_class_identity:
  description: "asyncio.Future class identity checks in asynciofuture197 namespace — Future.__name__=='Future' (len=6: F(1)u(2)t(3)u(4)r(5)e(6); the low-level awaitable representing an eventual async result); Future.__module__=='_asyncio' (len=8: '_asyncio'=8: '_'=1+'asyncio'=7=8; implemented in the C extension for performance); Future.__bases__[0].__name__=='object' (len=6: o(1)b(2)j(3)e(4)c(5)t(6); Future inherits directly from object, unlike Task which inherits from Future); Future.__name__ (6) == Future.__bases__[0].__name__ (6) — coincidentally the same length; Future.__module__ (8) > Future.__name__ (6) by 2; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciofuture197

  columns: [id, function, args, expected, description]
  rows:
    - [future_name_eq,    asyncio.Future.__name__.__eq__,                    ["Future"],    true, "asyncio.Future.__name__ == 'Future' (len=6; low-level awaitable for eventual async result); verified Python 3.14.3"]
    - [future_name_len,   asyncio.Future.__name__.__len__,                   [],            6,    "asyncio.Future.__name__.__len__() == 6 ('Future'=6: F(1)u(2)t(3)u(4)r(5)e(6)); verified Python 3.14.3"]
    - [future_module_eq,  asyncio.Future.__module__.__eq__,                  ["_asyncio"],  true, "asyncio.Future.__module__ == '_asyncio' (len=8; C extension implementation, not pure-Python asyncio.futures); verified Python 3.14.3"]
    - [future_module_len, asyncio.Future.__module__.__len__,                 [],            8,    "asyncio.Future.__module__.__len__() == 8 ('_asyncio'=8: '_'=1+'asyncio'=7=8); verified Python 3.14.3"]
    - ["future_base_eq",  "asyncio.Future.__bases__[0].__name__.__eq__",     ["object"],    true, "asyncio.Future.__bases__[0].__name__ == 'object' (len=6; Future inherits directly from object); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
