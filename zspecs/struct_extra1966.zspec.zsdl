spec: struct_extra1966
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
    - "CPython source: Modules/_struct.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 1966 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "struct.Struct does not define __enter__ or __exit__ (not a context manager)."
    - "struct.error is a subclass of Exception and does not define context manager protocol."
    - "Neither struct.Struct nor struct.error define __del__, __aenter__, or __aexit__."
    - "struct.error.__dict__ contains only: __module__, __weakref__, __doc__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra1966.struct_context_manager_protocol:
  description: "struct.Struct __enter__/__exit__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1966

  columns: [id, function, args, expected]
  rows:
    - ["st1966001", "struct.Struct.__dict__.__contains__", ["__enter__"], false]
    - ["st1966002", "struct.Struct.__dict__.__contains__", ["__exit__"], false]
    - ["st1966003", "struct.Struct.__dict__.__contains__", ["__aenter__"], false]
    - ["st1966004", "struct.Struct.__dict__.__contains__", ["__aexit__"], false]
    - ["st1966005", "struct.Struct.__dict__.__contains__", ["__del__"], false]

table struct_extra1966.struct_error_context_manager_protocol:
  description: "struct.error __enter__/__exit__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1966

  columns: [id, function, args, expected]
  rows:
    - ["st1966006", "struct.error.__dict__.__contains__", ["__enter__"], false]
    - ["st1966007", "struct.error.__dict__.__contains__", ["__exit__"], false]
    - ["st1966008", "struct.error.__dict__.__contains__", ["__aenter__"], false]
    - ["st1966009", "struct.error.__dict__.__contains__", ["__aexit__"], false]
    - ["st1966010", "struct.error.__dict__.__contains__", ["__del__"], false]

table struct_extra1966.struct_async_context_manager_protocol:
  description: "struct types async context manager protocol absence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1966

  columns: [id, function, args, expected]
  rows:
    - ["st1966011", "struct.Struct.__dict__.__contains__", ["__aenter__"], false]
    - ["st1966012", "struct.Struct.__dict__.__contains__", ["__aexit__"], false]
    - ["st1966013", "struct.error.__dict__.__contains__", ["__aenter__"], false]
    - ["st1966014", "struct.error.__dict__.__contains__", ["__aexit__"], false]

table struct_extra1966.struct_finalizer_checks:
  description: "struct types __del__ finalizer absence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1966

  columns: [id, function, args, expected]
  rows:
    - ["st1966015", "struct.Struct.__dict__.__contains__", ["__del__"], false]
    - ["st1966016", "struct.error.__dict__.__contains__", ["__del__"], false]

table struct_extra1966.struct_negative_protocol_matrix:
  description: "struct.Struct and struct.error full negative protocol matrix"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1966

  columns: [id, function, args, expected]
  rows:
    - ["st1966017", "struct.Struct.__dict__.__contains__", ["__enter__"], false]
    - ["st1966018", "struct.Struct.__dict__.__contains__", ["__exit__"], false]
    - ["st1966019", "struct.Struct.__dict__.__contains__", ["__aenter__"], false]
    - ["st1966020", "struct.Struct.__dict__.__contains__", ["__aexit__"], false]
    - ["st1966021", "struct.Struct.__dict__.__contains__", ["__del__"], false]
    - ["st1966022", "struct.error.__dict__.__contains__", ["__enter__"], false]
    - ["st1966023", "struct.error.__dict__.__contains__", ["__exit__"], false]
    - ["st1966024", "struct.error.__dict__.__contains__", ["__aenter__"], false]
    - ["st1966025", "struct.error.__dict__.__contains__", ["__aexit__"], false]
