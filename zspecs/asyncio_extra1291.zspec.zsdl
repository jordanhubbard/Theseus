spec: asyncio_extra1291
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "asyncio standard library documentation — https://docs.python.org/3/library/asyncio.html"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "Test vectors verified with Python 3.13 on macOS Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any third-party asyncio wrapper or extension library"
  notes:
    - "Wave 533 (_extra1291): focus on __init__ and __new__ method presence and qualname checks."
    - "Queue, Lock, Event, Semaphore, BoundedSemaphore, Condition all define __init__ directly in their own __dict__."
    - "Task.__init__ and Future.__init__ are wrapper_descriptor (C-level) but present in __dict__."
    - "BoundedSemaphore.__init__.__qualname__ is 'BoundedSemaphore.__init__' — it overrides Semaphore.__init__."
    - "All __init__.__class__.__name__ values verified: 'function' for pure-Python classes, 'wrapper_descriptor' for C classes."
    - "All expected values verified by running Python 3.13 on macOS Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra1291.init_qualnames:
  description: "asyncio synchronization primitive __init__ qualname identity"
  kind: python_call_eq
  category: init_qualname
  id_prefix: as1291
  columns: [id, function, args, expected]
  rows:
    - ["as1291qi001", "asyncio.Queue.__init__.__qualname__.__eq__", ["Queue.__init__"], true]
    - ["as1291qi002", "asyncio.Lock.__init__.__qualname__.__eq__", ["Lock.__init__"], true]
    - ["as1291qi003", "asyncio.Event.__init__.__qualname__.__eq__", ["Event.__init__"], true]
    - ["as1291qi004", "asyncio.Semaphore.__init__.__qualname__.__eq__", ["Semaphore.__init__"], true]
    - ["as1291qi005", "asyncio.BoundedSemaphore.__init__.__qualname__.__eq__", ["BoundedSemaphore.__init__"], true]
    - ["as1291qi006", "asyncio.Condition.__init__.__qualname__.__eq__", ["Condition.__init__"], true]
    - ["as1291qi007", "asyncio.Task.__init__.__qualname__.__eq__", ["Task.__init__"], true]
    - ["as1291qi008", "asyncio.Future.__init__.__qualname__.__eq__", ["Future.__init__"], true]

table asyncio_extra1291.init_class_names:
  description: "asyncio __init__ method type identity via __class__.__name__"
  kind: python_call_eq
  category: init_class
  id_prefix: as1291
  columns: [id, function, args, expected]
  rows:
    - ["as1291ic001", "asyncio.Queue.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["as1291ic002", "asyncio.Lock.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["as1291ic003", "asyncio.Event.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["as1291ic004", "asyncio.Semaphore.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["as1291ic005", "asyncio.BoundedSemaphore.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["as1291ic006", "asyncio.Condition.__init__.__class__.__name__.__eq__", ["function"], true]
    - ["as1291ic007", "asyncio.Task.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["as1291ic008", "asyncio.Future.__init__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table asyncio_extra1291.dict_contains_init:
  description: "asyncio classes with __init__ explicitly in their own __dict__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: as1291
  columns: [id, function, args, expected]
  rows:
    - ["as1291dc001", "asyncio.Queue.__dict__.__contains__", ["__init__"], true]
    - ["as1291dc002", "asyncio.Lock.__dict__.__contains__", ["__init__"], true]
    - ["as1291dc003", "asyncio.Event.__dict__.__contains__", ["__init__"], true]
    - ["as1291dc004", "asyncio.Semaphore.__dict__.__contains__", ["__init__"], true]
    - ["as1291dc005", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__init__"], true]
    - ["as1291dc006", "asyncio.Condition.__dict__.__contains__", ["__init__"], true]
    - ["as1291dc007", "asyncio.Task.__dict__.__contains__", ["__init__"], true]
    - ["as1291dc008", "asyncio.Future.__dict__.__contains__", ["__init__"], true]
