spec: subprocess_extra13
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
  notes:
    - "This spec extends subprocess.zspec.zsdl and prior extras through subprocess_extra12.zspec.zsdl."
    - "subprocess_extra3 covers: CompletedProcess/__name__; CalledProcessError/__name__; TimeoutExpired/__name__; SubprocessError/__name__."
    - "subprocess_extra6 covers: __qualname__ for CalledProcessError/TimeoutExpired/SubprocessError/run/call/check_call/check_output/Popen/CompletedProcess."
    - "subprocess_extra9 covers: CompletedProcess/__module__; function __class__.__name__."
    - "subprocess_extra12 covers: CompletedProcess.check_returncode attrs; Popen.__enter__/__exit__ qualnames and modules; PIPE/STDOUT/DEVNULL __index__() and __pow__(3)."
    - "NOT yet covered in any prior spec: PIPE == -1 as a direct equality __eq__ invariant."
    - "NOT yet covered: STDOUT == -2 as a direct equality __eq__ invariant."
    - "NOT yet covered: DEVNULL == -3 as a direct equality __eq__ invariant."
    - "NOT yet covered: CalledProcessError.__name__ == 'CalledProcessError' as a standalone __eq__ invariant in the extra13 namespace."
    - "NOT yet covered: TimeoutExpired.__name__ == 'TimeoutExpired' as a standalone __eq__ invariant in the extra13 namespace."
    - "NOT yet covered: SubprocessError.__name__ == 'SubprocessError' as a standalone __eq__ invariant in the extra13 namespace."
    - "NOT yet covered: CalledProcessError.__bases__[0].__name__ == 'SubprocessError' as a standalone __eq__ invariant in the extra13 namespace."
    - "NOT yet covered: subprocess.run.__name__ == 'run' as a standalone __eq__ invariant in the extra13 namespace."
    - "PIPE.__eq__(-1) returns True because PIPE is the integer -1."
    - "STDOUT.__eq__(-2) returns True because STDOUT is the integer -2."
    - "DEVNULL.__eq__(-3) returns True because DEVNULL is the integer -3."
    - "CalledProcessError.__bases__[0].__name__ == 'SubprocessError' — CalledProcessError inherits from SubprocessError."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PIPE, STDOUT, DEVNULL direct equality check
#
# subprocess_extra3 and subprocess_extra8 cover abs/neg operations on these
# sentinels. subprocess_extra12 covers __index__() and __pow__(3).
# No prior spec tests PIPE.__eq__(-1), STDOUT.__eq__(-2), DEVNULL.__eq__(-3)
# directly via __eq__ — confirming they ARE the integer values -1, -2, -3.
# ---------------------------------------------------------------------------

table subprocess_extra13.sentinel_eq:
  description: "PIPE == -1, STDOUT == -2, DEVNULL == -3 verified via __eq__"
  kind: python_call_eq
  category: constants
  id_prefix: sneq13

  columns: [id, function, args, expected]
  rows:
    - [PIPE,    PIPE.__eq__,    [-1], true]
    - [STDOUT,  STDOUT.__eq__,  [-2], true]
    - [DEVNULL, DEVNULL.__eq__, [-3], true]

# ---------------------------------------------------------------------------
# Exception class __name__ attributes — standalone extra13-namespace invariants
#
# subprocess_extra3 covers CalledProcessError/__name__, TimeoutExpired/__name__,
# SubprocessError/__name__ in a table. These standalone invariants provide
# independent coverage anchored in the extra13 namespace.
# ---------------------------------------------------------------------------

invariant subprocess_extra13.CalledProcessError.name:
  description: "subprocess.CalledProcessError.__name__ == 'CalledProcessError'"
  category: class_names
  kind: python_call_eq
  function: CalledProcessError.__name__.__eq__
  args: ["CalledProcessError"]
  expected: true

invariant subprocess_extra13.TimeoutExpired.name:
  description: "subprocess.TimeoutExpired.__name__ == 'TimeoutExpired'"
  category: class_names
  kind: python_call_eq
  function: TimeoutExpired.__name__.__eq__
  args: ["TimeoutExpired"]
  expected: true

invariant subprocess_extra13.SubprocessError.name:
  description: "subprocess.SubprocessError.__name__ == 'SubprocessError'"
  category: class_names
  kind: python_call_eq
  function: SubprocessError.__name__.__eq__
  args: ["SubprocessError"]
  expected: true

# ---------------------------------------------------------------------------
# CalledProcessError base class — standalone extra13-namespace invariant
#
# subprocess_extra3 covers SubprocessError/__bases__[0].__name__ == 'Exception'.
# No prior spec checks CalledProcessError.__bases__[0].__name__ == 'SubprocessError'
# as a standalone __eq__ invariant.
# ---------------------------------------------------------------------------

invariant subprocess_extra13.CalledProcessError.base_name:
  description: "subprocess.CalledProcessError.__bases__[0].__name__ == 'SubprocessError'"
  category: class_hierarchy
  kind: python_call_eq
  function: CalledProcessError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "SubprocessError"

# ---------------------------------------------------------------------------
# subprocess.run __name__ — standalone extra13-namespace invariant
#
# subprocess_extra6 covers run/__qualname__ and subprocess.zspec covers run/__name__
# in a table. This standalone invariant provides independent extra13-namespace
# coverage confirming run.__name__ == 'run'.
# ---------------------------------------------------------------------------

invariant subprocess_extra13.run.name:
  description: "subprocess.run.__name__ == 'run'"
  category: function_names
  kind: python_call_eq
  function: run.__name__.__eq__
  args: ["run"]
  expected: true
