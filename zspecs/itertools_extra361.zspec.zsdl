  description: "itertools.compress.__name__ == 'compress' — C extension type; selects elements where selector is true; new to extra361"
  kind: python_call_eq
  function: compress.__name__.__eq__
  args: ["compress"]
  expected: true

invariant itertools_extra361.compress_module:
  description: "itertools.compress.__module__ == 'itertools' — C extension type with module 'itertools'; new to extra361"
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra361.filterfalse_name:
  description: "itertools.filterfalse.__name__ == 'filterfalse' — C extension type; yields elements where predicate is false; new to extra361"
  kind: python_call_eq
  function: filterfalse.__name__.__eq__
  args: ["filterfalse"]
  expected: true

invariant itertools_extra361.filterfalse_module:
  description: "itertools.filterfalse.__module__ == 'itertools' — C extension type with module 'itertools'; new to extra361"
  kind: python_call_eq
