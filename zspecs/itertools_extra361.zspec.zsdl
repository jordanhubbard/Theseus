spec: itertools_extra361
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.islice.__name__ == 'islice' — C extension type in _itertoolsmodule.c; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.takewhile.__name__ == 'takewhile' — C extension type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__name__ == 'dropwhile' — C extension type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.compress.__name__ == 'compress' — C extension type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__name__ == 'filterfalse' — C extension type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.starmap.__name__ == 'starmap' — C extension type; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools filtering/slicing C type identity — islice, takewhile, dropwhile
#
# itertools.islice.__name__ == 'islice'
# itertools.islice.__module__ == 'itertools'
# itertools.takewhile.__name__ == 'takewhile'
# itertools.takewhile.__module__ == 'itertools'
# itertools.dropwhile.__name__ == 'dropwhile'
# itertools.dropwhile.__module__ == 'itertools'
#
# These are C extension types defined in Modules/_itertoolsmodule.c.
# Accessing the type object directly (not an instance) gives __name__
# and __module__ of the type itself.
# ---------------------------------------------------------------------------

table itertools_extra361.slice_filter_type_identity:
  description: "itertools.islice, takewhile, dropwhile C type __name__ and __module__ identity; all are C extension types with __module__=='itertools'; new to extra361"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolssfd361

  columns: [id, function, args, expected, description]
  rows:
    - [islice_name_eq,
       "islice.__name__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — islice is a C extension type in Modules/_itertoolsmodule.c that returns selected elements from an iterable using start/stop/step indices; its type __name__ is 'islice'; str.__eq__('islice') returns True; new to extra361"]
    - [islice_module_eq,
       "islice.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — islice is a C extension type whose __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra361"]
    - [takewhile_name_eq,
       "takewhile.__name__.__eq__",
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — takewhile is a C extension type in Modules/_itertoolsmodule.c that yields elements from an iterable as long as a predicate is true; its type __name__ is 'takewhile'; str.__eq__('takewhile') returns True; new to extra361"]
    - [takewhile_module_eq,
       "takewhile.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.takewhile.__module__.__eq__('itertools') == True — takewhile is a C extension type whose __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra361"]
    - [dropwhile_name_eq,
       "dropwhile.__name__.__eq__",
       ["dropwhile"],
       true,
       "itertools.dropwhile.__name__.__eq__('dropwhile') == True — dropwhile is a C extension type in Modules/_itertoolsmodule.c that skips elements while a predicate is true then yields the rest; its type __name__ is 'dropwhile'; str.__eq__('dropwhile') returns True; new to extra361"]
    - [dropwhile_module_eq,
       "dropwhile.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.dropwhile.__module__.__eq__('itertools') == True — dropwhile is a C extension type whose __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra361"]

# ---------------------------------------------------------------------------
# Table 2: itertools functional C type identity — compress, filterfalse, starmap
#
# itertools.compress.__name__ == 'compress'
# itertools.compress.__module__ == 'itertools'
# itertools.filterfalse.__name__ == 'filterfalse'
# itertools.filterfalse.__module__ == 'itertools'
# itertools.starmap.__name__ == 'starmap'
# itertools.starmap.__module__ == 'itertools'
#
# compress selects elements using a boolean selector iterable.
# filterfalse yields elements for which a predicate is false.
# starmap maps a function using argument tuples from an iterable.
# All three are C extension types.
# ---------------------------------------------------------------------------

table itertools_extra361.functional_type_identity:
  description: "itertools.compress, filterfalse, starmap C type __name__ and __module__ identity; all C extension types with __module__=='itertools'; new to extra361"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscfs361

  columns: [id, function, args, expected, description]
  rows:
    - [compress_name_eq,
       "compress.__name__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — compress is a C extension type in Modules/_itertoolsmodule.c that selects elements from data where the corresponding selector is true; its type __name__ is 'compress'; str.__eq__('compress') returns True; new to extra361"]
    - [compress_module_eq,
       "compress.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.compress.__module__.__eq__('itertools') == True — compress is a C extension type whose __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra361"]
    - [filterfalse_name_eq,
       "filterfalse.__name__.__eq__",
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__.__eq__('filterfalse') == True — filterfalse is a C extension type in Modules/_itertoolsmodule.c that yields elements for which predicate(element) is false; its type __name__ is 'filterfalse'; str.__eq__('filterfalse') returns True; new to extra361"]
    - [filterfalse_module_eq,
       "filterfalse.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.filterfalse.__module__.__eq__('itertools') == True — filterfalse is a C extension type whose __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra361"]
    - [starmap_name_eq,
       "starmap.__name__.__eq__",
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — starmap is a C extension type in Modules/_itertoolsmodule.c that maps a function using argument tuples unpacked from an iterable; its type __name__ is 'starmap'; str.__eq__('starmap') returns True; new to extra361"]
    - [starmap_module_eq,
       "starmap.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.starmap.__module__.__eq__('itertools') == True — starmap is a C extension type whose __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra361"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra361
# ---------------------------------------------------------------------------

invariant itertools_extra361.islice_name:
  description: "itertools.islice.__name__ == 'islice' — C extension type for index-based slicing; new to extra361"
  kind: python_call_eq
  function: islice.__name__.__eq__
  args: ["islice"]
  expected: true

invariant itertools_extra361.islice_module:
  description: "itertools.islice.__module__ == 'itertools' — C extension type with module 'itertools'; new to extra361"
  kind: python_call_eq
  function: islice.__module__.__eq__
  args: ["itertools"]
  expected: true

