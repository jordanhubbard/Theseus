spec: itsdangerous_rust
version: ">=3.9"
backend: rust_module(itsdangerous_rust)

docs: https://itsdangerous.palletsprojects.com/

provenance:
  derived_from:
    - "https://itsdangerous.palletsprojects.com/ — itsdangerous"
  notes:
    - "itsdangerous provides secure data signing."
    - "itsdangerous.URLSafeSerializer('secret').dumps({'id': 1}) returns a string."
    - "itsdangerous.URLSafeSerializer is a class."
    - "itsdangerous.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant itsdangerous_rust.dumps_is_string:
  description: "URLSafeSerializer('secret').dumps({'id':1}) returns str"
  category: serde
  kind: python_call_eq
  function: itsdangerous_dumps_is_string
  args: []
  expected: true

invariant itsdangerous_rust.has_url_safe_serializer:
  description: "itsdangerous.URLSafeSerializer is a class"
  category: presence
  kind: python_call_eq
  function: itsdangerous_has_url_safe_serializer
  args: []
  expected: true

invariant itsdangerous_rust.version_nonempty:
  description: "itsdangerous.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: itsdangerous_version_nonempty
  args: []
  expected: true

