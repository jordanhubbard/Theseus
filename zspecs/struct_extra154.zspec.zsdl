# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack') — standalone
#
# struct.Struct.pack.__qualname__ is 'Struct.pack' (11 chars = 'Struct.'=7 + 'pack'=4).
# Struct.pack is a method_descriptor — the C extension method type used for methods
# defined in C extension types (distinct from builtin_function_or_method used for
# module-level functions). Struct.pack(v1, v2, ...) packs the provided values into a
# bytes object according to the format string with which the Struct was compiled.
# The qualname 'Struct.pack' uses 'Struct.' as the class prefix (7 chars; 1 more than
# 'HASH.' from hashlib hash objects). extra148 anchors Struct.pack.__qualname__ as a
# table row; no prior struct spec anchors this as a standalone under structmq154.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra154.Struct_pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — 11 chars = 'Struct.'=7 + 'pack'=4; Struct.pack is a method_descriptor (C extension method slot; contrasts with module-level struct.pack which is builtin_function_or_method); Struct.pack(v1, v2, ...) packs values to bytes per format; class prefix 'Struct.'=7 chars (vs 'HASH.'=5 for hashlib); extra148 anchors this as a table row; no prior struct spec anchors this as a standalone under structmq154"
  category: identity
  kind: python_call_eq
  function: Struct.pack.__qualname__.__eq__
  args: ["Struct.pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack.__class__.__name__.__eq__('method_descriptor') — standalone
#
# struct.Struct.pack.__class__.__name__ is 'method_descriptor' (17 chars). The
# method_descriptor type is used for C extension methods of built-in C types. It is
# the same type as list.append, str.join, dict.get, etc. This contrasts with:
# - builtin_function_or_method: module-level C functions (struct.pack, struct.unpack, etc.)
# - wrapper_descriptor: slot methods like __init__, __len__ (struct.Struct.__init__)
# - function: pure Python methods (uuid.UUID.__str__, etc.)
# All five Struct instance methods (pack, unpack, pack_into, unpack_from, iter_unpack)
# are method_descriptor objects. 'method_descriptor' = 17 chars. No prior struct spec
# anchors Struct.pack.__class__.__name__ as a standalone under structmq154.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra154.Struct_pack_class_method_descriptor:
  description: "struct.Struct.pack.__class__.__name__.__eq__('method_descriptor') == True — 17 chars; C extension method slot type; same as list.append/str.join/dict.get; contrasts with: builtin_function_or_method (26 chars; module-level struct.pack), wrapper_descriptor (18 chars; Struct.__init__), function (8 chars; pure Python methods); all five Struct instance methods (pack/unpack/pack_into/unpack_from/iter_unpack) are method_descriptor; no prior struct spec anchors this as a standalone; first standalone under structmq154"
  category: identity
  kind: python_call_eq
  function: Struct.pack.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') — standalone
#
# struct.Struct.unpack_from.__qualname__ is 'Struct.unpack_from' (18 chars = 'Struct.'=7 +
# 'unpack_from'=11). unpack_from() unpacks values from a buffer (bytes, bytearray,
# memoryview, etc.) starting at a specified byte offset (default 0), without requiring
# the buffer to be exactly the right size. This is useful for extracting structured data
# from larger byte sequences. 'Struct.unpack_from' ties 'Struct.iter_unpack' at 18 chars
# (the longest Struct method qualnames). extra149 anchors unpack_from.__qualname__ as a
# table row; no prior struct spec anchors this as a standalone under structmq154.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra154.Struct_unpack_from_qualname_eq:
  description: "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — 18 chars = 'Struct.'=7 + 'unpack_from'=11; unpack_from(buffer, offset=0) unpacks from buffer at given offset without size constraint; method_descriptor type; 'unpack_from'=11 chars (longest Struct method name); ties 'Struct.iter_unpack' at 18 chars; extra149 anchors this as a table row; no prior struct spec anchors this as a standalone under structmq154"
  category: identity
  kind: python_call_eq
  function: Struct.unpack_from.__qualname__.__eq__
  args: ["Struct.unpack_from"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__qualname__.__len__()==18 — standalone
#
# struct.Struct.iter_unpack.__qualname__.__len__() is 18. 'Struct.iter_unpack' =
# 'Struct.'=7 + 'iter_unpack'=11 = 18 chars. iter_unpack() yields successive tuples
# by unpacking from a buffer repeatedly using the Struct's format. The buffer must be
# a multiple of the struct size. Struct.iter_unpack is a method_descriptor (same as
# pack, unpack, pack_into, unpack_from). The qualname length 18 ties Struct.unpack_from.
# These are the longest Struct method qualnames. The length ordering across all five
# methods: pack(11) < unpack(13) < pack_into(16) < unpack_from==iter_unpack(18).
# No prior struct spec anchors Struct.iter_unpack.__qualname__.__len__() as a standalone
# under structmq154. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra154.Struct_iter_unpack_qualname_len:
  description: "struct.Struct.iter_unpack.__qualname__.__len__() == 18 — 'Struct.iter_unpack' = 'Struct.'=7 + 'iter_unpack'=11 = 18 chars; ties unpack_from at 18 (longest Struct method qualnames); iter_unpack yields successive tuples from buffer (buffer must be multiple of struct size); method_descriptor type; length ordering: pack(11) < unpack(13) < pack_into(16) < unpack_from==iter_unpack(18); extra149 anchors iter_unpack qualname string value; no prior struct spec anchors __len__() as a standalone; first standalone under structmq154"
  category: identity
  kind: python_call_eq
  function: Struct.iter_unpack.__qualname__.__len__
  args: []
  expected: 18

