spec: functools_extra179
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.reduce.__doc__ string properties — class 'str', non-empty (len 389), contains 'function'; functools.WRAPPER_ASSIGNMENTS class 'tuple', len 6 (Python 3.14: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__); functools.WRAPPER_UPDATES class 'tuple', len 1 ('__dict__')."
    - "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce is a C-level built-in with a docstring; its __doc__ is a str instance. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__len__() == 389 — the reduce docstring has 389 characters on Python 3.14.3. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__contains__('function') == True — the reduce docstring begins 'Apply a function of two arguments cumulatively...'; 'function' is present. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a module-level tuple constant. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — on Python 3.14: ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'). Note: Python 3.11 and earlier have 5 entries (__annotations__ instead of __annotate__/__type_params__). Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is the 1-tuple ('__dict__',) on all Python versions. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce.__doc__ string class and emptiness
#
# functools.reduce.__doc__.__class__.__name__ == 'str'
# functools.reduce.__doc__.__class__.__name__ != 'NoneType'
# functools.reduce.__doc__.__len__() == 389
# functools.reduce.__doc__.__len__() > 0  (non-empty)
#
# reduce is a C-level builtin_function_or_method with a docstring. The __doc__
# attribute is a str instance. On Python 3.14.3 the docstring is 389 characters
# long, beginning "Apply a function of two arguments cumulatively...". New to
# extra179.
# ---------------------------------------------------------------------------

table functools_extra179.reduce_doc_class_and_len:
  description: "functools.reduce.__doc__ class 'str', not NoneType; len 389; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: funcwrapattr179

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_class_str,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — reduce is a C-level builtin with a docstring; its __doc__ is a str instance; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra179"]
    - [reduce_doc_class_not_nonetype,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["NoneType"],
       false,
       "functools.reduce.__doc__.__class__.__name__.__eq__('NoneType') == False — reduce.__doc__ is a non-None str (reduce has a real docstring); its __class__.__name__ is 'str', not 'NoneType'; str.__eq__('NoneType') returns False; new to extra179"]
    - [reduce_doc_len_389,
       "reduce.__doc__.__len__",
       [],
       389,
       "functools.reduce.__doc__.__len__() == 389 — the reduce docstring ('Apply a function of two arguments cumulatively to the items of an iterable, from left to right...') has exactly 389 characters on Python 3.14.3; str.__len__() returns 389; new to extra179"]
    - [reduce_doc_len_gt_zero,
       "reduce.__doc__.__len__",
       [],
       389,
       "functools.reduce.__doc__.__len__() > 0 — reduce.__doc__ is a non-empty docstring; the string has 389 characters, confirming it is not empty; str.__len__() returns 389; new to extra179"]

# ---------------------------------------------------------------------------
# Table 2: functools.reduce.__doc__ keyword presence
#
# functools.reduce.__doc__.__contains__('function') == True
# functools.reduce.__doc__.__contains__('reduce') == True
# functools.reduce.__doc__.__contains__('NoneType') == False
#
# The reduce docstring begins "Apply a function of two arguments cumulatively
# to the items of an iterable, from left to right." Both 'function' and
# 'reduce' appear in the text. New to extra179.
# ---------------------------------------------------------------------------

table functools_extra179.reduce_doc_keywords:
  description: "functools.reduce.__doc__ contains 'function' True; contains 'reduce' True; contains 'NoneType' False; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: funcwrapattr179

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_doc_contains_function,
       "reduce.__doc__.__contains__",
       ["function"],
       true,
       "functools.reduce.__doc__.__contains__('function') == True — the reduce docstring begins 'Apply a function of two arguments cumulatively...'; the word 'function' appears in the docstring; str.__contains__('function') returns True; new to extra179"]
    - [reduce_doc_contains_reduce,
       "reduce.__doc__.__contains__",
       ["reduce"],
       true,
       "functools.reduce.__doc__.__contains__('reduce') == True — the reduce docstring references 'reduce' (the function name appears in its own documentation); str.__contains__('reduce') returns True; new to extra179"]
    - [reduce_doc_not_contains_nonetype,
       "reduce.__doc__.__contains__",
       ["NoneType"],
       false,
       "functools.reduce.__doc__.__contains__('NoneType') == False — 'NoneType' does not appear anywhere in the reduce docstring; str.__contains__('NoneType') returns False; new to extra179"]
    - [reduce_doc_not_contains_empty,
       "reduce.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — cross-check confirming reduce.__doc__ is a str (not NoneType or bytes); the docstring is present and well-typed; str.__eq__('str') returns True; new to extra179"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_ASSIGNMENTS class and length
#
# WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# WRAPPER_ASSIGNMENTS.__len__() == 6  (Python 3.14)
# WRAPPER_ASSIGNMENTS.__contains__('__module__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__name__') == True
#
# On Python 3.14 WRAPPER_ASSIGNMENTS is a 6-tuple:
# ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__').
# Note: Python <= 3.11 has 5 entries with '__annotations__' instead of
# '__annotate__' and '__type_params__'. New to extra179.
# ---------------------------------------------------------------------------

table functools_extra179.wrapper_assignments_class_len:
  description: "functools.WRAPPER_ASSIGNMENTS: class 'tuple', len 6 (Python 3.14), contains __module__ and __name__; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: funcwrapattr179

  columns: [id, function, args, expected, description]
  rows:
    - [wrapasn_class_tuple,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant listing attribute names copied by @wraps; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra179"]
    - [wrapasn_len_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — on Python 3.14: ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'); 6 wrapper assignments in total; tuple.__len__() returns 6; new to extra179"]
    - [wrapasn_contains_module,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is the first element of WRAPPER_ASSIGNMENTS; @wraps copies the module attribute from wrapped to wrapper; tuple.__contains__('__module__') returns True; new to extra179"]
    - [wrapasn_contains_name,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is the second element of WRAPPER_ASSIGNMENTS; @wraps copies the function name from wrapped to wrapper; tuple.__contains__('__name__') returns True; new to extra179"]

# ---------------------------------------------------------------------------
# Table 4: functools.WRAPPER_ASSIGNMENTS further membership and WRAPPER_UPDATES
#
# WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True
# WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True
# WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# WRAPPER_UPDATES.__len__() == 1
#
# WRAPPER_UPDATES on all Python versions is the 1-tuple ('__dict__',). The
# __dict__ attribute is merged (updated) rather than replaced. New to extra179.
# ---------------------------------------------------------------------------

table functools_extra179.wrapper_updates_and_more_assignments:
  description: "WRAPPER_ASSIGNMENTS contains __qualname__ and __doc__; WRAPPER_UPDATES class 'tuple', len 1; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: funcwrapattr179

  columns: [id, function, args, expected, description]
  rows:
    - [wrapasn_contains_qualname,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is the third element of WRAPPER_ASSIGNMENTS; @wraps copies the qualified name (e.g., 'MyClass.my_method') from wrapped to wrapper; tuple.__contains__('__qualname__') returns True; new to extra179"]
    - [wrapasn_contains_doc,
       "WRAPPER_ASSIGNMENTS.__contains__",
       ["__doc__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is the fourth element of WRAPPER_ASSIGNMENTS; @wraps copies the docstring from wrapped to wrapper so help() shows the original docs; tuple.__contains__('__doc__') returns True; new to extra179"]
    - [wrapupd_class_tuple,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level tuple constant listing attributes merged (not replaced) by @wraps; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra179"]
    - [wrapupd_len_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is the 1-tuple ('__dict__',) on all Python versions; only __dict__ is merged (updated) by @wraps, not replaced; tuple.__len__() returns 1; new to extra179"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra179
# ---------------------------------------------------------------------------

invariant functools_extra179.reduce_doc_class_str:
  description: "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce is a C-level builtin with a non-None docstring; __doc__ is a str instance; new to extra179"
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra179.reduce_doc_len_389:
  description: "functools.reduce.__doc__.__len__() == 389 — reduce docstring is 389 characters on Python 3.14.3; non-empty; new to extra179"
  kind: python_call_eq
  function: reduce.__doc__.__len__
  args: []
  expected: 389

invariant functools_extra179.reduce_doc_contains_function:
  description: "functools.reduce.__doc__.__contains__('function') == True — 'function' appears in the reduce docstring ('Apply a function of two arguments...'); new to extra179"
  kind: python_call_eq
  function: reduce.__doc__.__contains__
  args: ["function"]
  expected: true

invariant functools_extra179.wrapper_assignments_class_tuple:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a tuple of attribute names copied by @wraps; new to extra179"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra179.wrapper_assignments_len_6:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — on Python 3.14: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; new to extra179"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra179.wrapper_updates_len_1:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is the 1-tuple ('__dict__',) on all Python versions; new to extra179"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra179.wrapper_updates_contains_dict:
  description: "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — only '__dict__' is merged (not replaced) by @wraps; new to extra179"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true

