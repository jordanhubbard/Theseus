spec: re_extra130
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module exception class identity — re.error (alias for re.PatternError in Python 3.14)."
    - "re.error.__name__ = 'PatternError' (len=12) — in Python 3.14, re.error was renamed to re.PatternError; re.error is a backward-compatible alias."
    - "re.error.__module__ = 're' (len=2)."
    - "re.error.__qualname__ = 'PatternError' (len=12)."
    - "re.error.__bases__[0].__name__ = 'Exception' (len=9) — re.error directly extends Exception."
    - "re.error.__mro__.__len__() = 4 — MRO is [PatternError, Exception, BaseException, object]."
    - "re.error.__class__.__name__ = 'type' (len=4) — re.error is itself a class (type)."
    - "re.PatternError is re.error — they are the same object; both have __name__=='PatternError'."
    - "re.error.__mro__.__len__() == re.PatternError.__mro__.__len__() — confirming they are the same class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.error class identity
# re.error.__name__ == 'PatternError' (len 12) in Python 3.14.
# re.error.__module__ == 're' (len 2).
# re.error.__qualname__ == 'PatternError' (len 12).
# re.error.__class__.__name__ == 'type' (len 4).
# ---------------------------------------------------------------------------

table re_extra130.error_class_identity:
  description: "re.error class identity: __name__=='PatternError'(12), __module__=='re'(2), __qualname__=='PatternError'(12), __class__.__name__=='type'(4)"
  kind: python_call_eq
  category: class_identity
  id_prefix: reerror130

  columns: [id, function, args, expected]
  rows:
    - [err_name_eq,      error.__name__.__eq__,                  ["PatternError"],  true]
    - [err_name_len,     error.__name__.__len__,                 [],               12]
    - [err_module_eq,    error.__module__.__eq__,                ["re"],            true]
    - [err_module_len,   error.__module__.__len__,               [],                2]
    - [err_qualname_eq,  error.__qualname__.__eq__,              ["PatternError"],  true]
    - [err_qualname_len, error.__qualname__.__len__,             [],               12]
    - [err_cls_eq,       error.__class__.__name__.__eq__,        ["type"],          true]
    - [err_cls_len,      error.__class__.__name__.__len__,       [],                4]
    - [err_name_not_old, error.__name__.__eq__,                  ["error"],         false]

# ---------------------------------------------------------------------------
# re.error.__bases__[0].__name__ and MRO
# re.error.__bases__[0].__name__ == 'Exception' (len 9).
# re.error.__mro__.__len__() == 4 (PatternError, Exception, BaseException, object).
# ---------------------------------------------------------------------------

table re_extra130.error_bases_and_mro:
  description: "re.error bases and MRO: __bases__[0].__name__=='Exception'(9), __mro__.__len__()==4"
  kind: python_call_eq
  category: class_identity
  id_prefix: reerror130

  columns: [id, function, args, expected]
  rows:
    - [err_base_eq,      "error.__bases__[0].__name__.__eq__",   ["Exception"],    true]
    - [err_base_len,     "error.__bases__[0].__name__.__len__",  [],                9]
    - [err_mro_len,      error.__mro__.__len__,                  [],                4]
    - [err_base_not_be,  "error.__bases__[0].__name__.__eq__",   ["BaseException"], false]
    - [err_base_not_re,  "error.__bases__[0].__name__.__eq__",   ["re"],            false]
    - [err_mro_not_3,    error.__mro__.__len__,                  [],                4]

# ---------------------------------------------------------------------------
# re.PatternError alias: re.error is re.PatternError
# PatternError.__name__ == 'PatternError' (same as error.__name__).
# PatternError.__mro__.__len__() == 4 (same as error; same class).
# Both error.__name__ and PatternError.__name__ resolve to 'PatternError'.
# ---------------------------------------------------------------------------

table re_extra130.PatternError_alias_identity:
  description: "re.PatternError is an alias for re.error: both have __name__=='PatternError' and __mro__.__len__()==4"
  kind: python_call_eq
  category: class_identity
  id_prefix: reerror130

  columns: [id, function, args, expected]
  rows:
    - [pe_name_eq,       PatternError.__name__.__eq__,           ["PatternError"],  true]
    - [pe_name_len,      PatternError.__name__.__len__,          [],               12]
    - [pe_module_eq,     PatternError.__module__.__eq__,         ["re"],            true]
    - [pe_qualname_eq,   PatternError.__qualname__.__eq__,       ["PatternError"],  true]
    - [pe_mro_len,       PatternError.__mro__.__len__,           [],                4]
    - [pe_base_eq,       "PatternError.__bases__[0].__name__.__eq__", ["Exception"], true]
    - [pe_cls_eq,        PatternError.__class__.__name__.__eq__, ["type"],          true]
    - [err_pe_mro_same,  error.__mro__.__len__,                  [],                4]
    - [pe_not_exc_name,  PatternError.__name__.__eq__,           ["Exception"],     false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra130.error.name_is_PatternError:
  description: "re.error.__name__ == 'PatternError' (in Python 3.14 the exception was renamed from 'error' to 'PatternError'; re.error is now a backward-compatible alias; the canonical __name__ reflects the new name)"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra130.error.module_is_re:
  description: "re.error.__module__ == 're' (re.PatternError / re.error is defined in the re module; __module__ is the short name 're', len=2)"
  category: class_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra130.error.base_is_Exception:
  description: "re.error.__bases__[0].__name__ == 'Exception' (re.error / re.PatternError directly extends the built-in Exception class; it does not inherit from ValueError or any other built-in subclass)"
  category: class_identity
  kind: python_call_eq
  function: error.__bases__[0].__name__.__eq__
  args: ["Exception"]
  expected: true

invariant re_extra130.error.mro_len_4:
  description: "re.error.__mro__.__len__() == 4 (MRO is [PatternError, Exception, BaseException, object]; four entries because there is one intermediate class Exception between PatternError and object)"
  category: class_identity
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

invariant re_extra130.PatternError.name_eq_error_name:
  description: "re.PatternError.__name__ == 'PatternError' and re.error.__name__ == 'PatternError' — re.error is re.PatternError (the same class object), so both name lookups return the same canonical name"
  category: class_identity
  kind: python_call_eq
  function: PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true
