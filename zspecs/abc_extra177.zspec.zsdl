spec: abc_extra177
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc.ABC class identity and deprecated abstract decorators — ABC.__name__=='ABC' (len=3); ABC.__module__=='abc'; ABC.__qualname__=='ABC'; ABC.__bases__[0].__name__=='object'; ABC.__class__.__name__=='ABCMeta' (ABC's metaclass is ABCMeta); abstractclassmethod.__name__=='abstractclassmethod' (len=19, deprecated); abstractstaticmethod.__name__=='abstractstaticmethod' (len=20, deprecated); abstractproperty.__name__=='abstractproperty' (len=16, deprecated)."
    - "abc.ABC.__class__.__name__ == 'ABCMeta'. ABC is an instance of ABCMeta (its metaclass); this is how ABCMeta is applied — ABC itself is a class whose metaclass is ABCMeta, so ABC.__class__ is ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractclassmethod, abc.abstractstaticmethod, abc.abstractproperty are deprecated since Python 3.3 but remain present in Python 3.14. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__bases__[0].__name__ == 'object'. ABC is defined as 'class ABC(metaclass=ABCMeta): pass' — it has no explicit superclass other than object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABC class identity — __name__, __module__, __qualname__
#
# abc.ABC.__name__ == 'ABC' (len=3)
# abc.ABC.__module__ == 'abc'
# abc.ABC.__qualname__ == 'ABC'
#
# ABC is the abstract base class helper — a convenience class whose metaclass
# is ABCMeta, allowing subclasses to define abstract methods without
# explicitly setting metaclass=ABCMeta.
# ---------------------------------------------------------------------------

table abc_extra177.abc_class_identity:
  description: "abc.ABC class identity: __name__=='ABC'(len=3), __module__=='abc', __qualname__=='ABC'; ABC helper class with ABCMeta metaclass; new to abc_extra177"
  kind: python_call_eq
  category: identity
  id_prefix: abcabc177

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,
       ABC.__name__.__eq__,
       ["ABC"],
       true,
       "abc.ABC.__name__.__eq__('ABC') == True — ABC is the convenience abstract base class helper; subclass it instead of specifying metaclass=ABCMeta; __name__ is 'ABC' (3 chars: A-B-C); str.__eq__('ABC') returns True; new to abc_extra177"]
    - [abc_name_len_3,
       ABC.__name__.__len__,
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters: A-B-C; NAME LENGTHS: ABC=3 < abstractproperty=16 < abstractclassmethod=19 < abstractstaticmethod=20; one of the shortest class names in the abc module; str.__len__() returns 3; new to abc_extra177"]
    - [abc_module_eq,
       ABC.__module__.__eq__,
       ["abc"],
       true,
       "abc.ABC.__module__.__eq__('abc') == True — ABC is defined and exported from the 'abc' module; __module__ is 'abc'; str.__eq__('abc') returns True; new to abc_extra177"]
    - [abc_qualname_eq,
       ABC.__qualname__.__eq__,
       ["ABC"],
       true,
       "abc.ABC.__qualname__.__eq__('ABC') == True — ABC is a top-level class in the abc module so its __qualname__ equals its __name__; str.__eq__('ABC') returns True; new to abc_extra177"]
    - [abc_module_len_3,
       ABC.__module__.__len__,
       [],
       3,
       "abc.ABC.__module__.__len__() == 3 — 'abc' has 3 characters: a-b-c; same as ABC.__name__.__len__(); str.__len__() returns 3; new to abc_extra177"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABC metaclass and base class identity
#
# abc.ABC.__bases__[0].__name__ == 'object'
# abc.ABC.__class__.__name__ == 'ABCMeta'
#
# ABC is defined as: class ABC(metaclass=ABCMeta): pass
# Its only base is object; its metaclass is ABCMeta.
# ---------------------------------------------------------------------------

table abc_extra177.abc_bases_and_metaclass:
  description: "abc.ABC.__bases__[0].__name__=='object'; abc.ABC.__class__.__name__=='ABCMeta'; ABC's metaclass is ABCMeta; new to abc_extra177"
  kind: python_call_eq
  category: identity
  id_prefix: abcabc177

  columns: [id, function, args, expected, description]
  rows:
    - [abc_base0_name_eq,
       "ABC.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "abc.ABC.__bases__[0].__name__.__eq__('object') == True — ABC is defined as 'class ABC(metaclass=ABCMeta): pass' with no explicit superclass; its only base is object; str.__eq__('object') returns True; new to abc_extra177"]
    - [abc_bases_len_1,
       "ABC.__bases__.__len__",
       [],
       1,
       "abc.ABC.__bases__.__len__() == 1 — ABC has exactly one direct base class: object; tuple.__len__() returns 1; new to abc_extra177"]
    - [abc_class_name_eq,
       "ABC.__class__.__name__.__eq__",
       ["ABCMeta"],
       true,
       "abc.ABC.__class__.__name__.__eq__('ABCMeta') == True — ABC's metaclass is ABCMeta; ABC.__class__ is ABCMeta since ABCMeta is passed as the metaclass when defining ABC; str.__eq__('ABCMeta') returns True; new to abc_extra177"]
    - [abc_class_name_len_7,
       "ABC.__class__.__name__.__len__",
       [],
       7,
       "abc.ABC.__class__.__name__.__len__() == 7 — 'ABCMeta' has 7 characters: A-B-C-M-e-t-a; str.__len__() returns 7; new to abc_extra177"]
    - [abc_base0_name_len_6,
       "ABC.__bases__[0].__name__.__len__",
       [],
       6,
       "abc.ABC.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters: o-b-j-e-c-t; str.__len__() returns 6; new to abc_extra177"]

# ---------------------------------------------------------------------------
# Table 3: abc deprecated abstract decorators — __name__ lengths
#
# abc.abstractclassmethod.__name__ == 'abstractclassmethod' (len=19)
# abc.abstractstaticmethod.__name__ == 'abstractstaticmethod' (len=20)
# abc.abstractproperty.__name__ == 'abstractproperty' (len=16)
#
# These are deprecated since Python 3.3 but remain in Python 3.14.
# ---------------------------------------------------------------------------

table abc_extra177.deprecated_decorators_identity:
  description: "abc deprecated decorators: abstractclassmethod(len=19), abstractstaticmethod(len=20), abstractproperty(len=16); deprecated since Python 3.3 but present in Python 3.14; new to abc_extra177"
  kind: python_call_eq
  category: identity
  id_prefix: abcabc177

  columns: [id, function, args, expected, description]
  rows:
    - [absproperty_name_eq,
       abstractproperty.__name__.__eq__,
       ["abstractproperty"],
       true,
       "abc.abstractproperty.__name__.__eq__('abstractproperty') == True — deprecated since Python 3.3; use property with abstractmethod instead; __name__ is 'abstractproperty' (16 chars); str.__eq__('abstractproperty') returns True; new to abc_extra177"]
    - [absproperty_name_len_16,
       abstractproperty.__name__.__len__,
       [],
       16,
       "abc.abstractproperty.__name__.__len__() == 16 — 'abstractproperty' has 16 characters: a-b-s-t-r-a-c-t-p-r-o-p-e-r-t-y; shortest deprecated decorator name; str.__len__() returns 16; new to abc_extra177"]
    - [abscm_name_eq,
       abstractclassmethod.__name__.__eq__,
       ["abstractclassmethod"],
       true,
       "abc.abstractclassmethod.__name__.__eq__('abstractclassmethod') == True — deprecated since Python 3.3; use classmethod with abstractmethod instead; __name__ is 'abstractclassmethod' (19 chars); str.__eq__('abstractclassmethod') returns True; new to abc_extra177"]
    - [abscm_name_len_19,
       abstractclassmethod.__name__.__len__,
       [],
       19,
       "abc.abstractclassmethod.__name__.__len__() == 19 — 'abstractclassmethod' has 19 characters: a-b-s-t-r-a-c-t-c-l-a-s-s-m-e-t-h-o-d; str.__len__() returns 19; new to abc_extra177"]
    - [abssm_name_eq,
       abstractstaticmethod.__name__.__eq__,
       ["abstractstaticmethod"],
       true,
       "abc.abstractstaticmethod.__name__.__eq__('abstractstaticmethod') == True — deprecated since Python 3.3; use staticmethod with abstractmethod instead; __name__ is 'abstractstaticmethod' (20 chars); longest deprecated decorator name; str.__eq__('abstractstaticmethod') returns True; new to abc_extra177"]
    - [abssm_name_len_20,
       abstractstaticmethod.__name__.__len__,
       [],
       20,
       "abc.abstractstaticmethod.__name__.__len__() == 20 — 'abstractstaticmethod' has 20 characters: a-b-s-t-r-a-c-t-s-t-a-t-i-c-m-e-t-h-o-d; longest name in spec; NAME LENGTHS: abstractproperty=16 < abstractclassmethod=19 < abstractstaticmethod=20; str.__len__() returns 20; new to abc_extra177"]

