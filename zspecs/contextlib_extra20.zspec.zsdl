spec: contextlib_extra20
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra19.zspec.zsdl."
    - "contextlib_extra19 covers: MRO[0] for nullcontext/ExitStack/AsyncExitStack/redirect_stdout/redirect_stderr/AbstractContextManager/AbstractAsyncContextManager; MRO[2] for AbstractContextManager/AbstractAsyncContextManager; redirect_stdout/stderr MRO[3]/[4]."
    - "contextlib_extra18 covers: __qualname__ for contextmanager/asynccontextmanager/nullcontext/AsyncExitStack/redirect_stdout/redirect_stderr/aclosing; redirect_stdout/__module__; AsyncExitStack/__module__; nullcontext/__module__; aclosing/__module__."
    - "contextlib_extra16 covers: suppress/closing/ExitStack __qualname__; suppress MRO[1]/[2]; nullcontext MRO[3]/[4]; redirect_stderr.__module__."
    - "contextlib_extra12 covers: standalone __name__ for all major contextlib classes/functions."
    - "This spec covers: ExitStack/AsyncExitStack/nullcontext/closing/AbstractContextManager __qualname__ via table; ExitStack/AsyncExitStack/nullcontext/closing/AbstractContextManager __module__ via table; base class checks for ExitStack/AsyncExitStack/nullcontext/closing via invariants; AbstractAsyncContextManager __qualname__ standalone."
    - "contextlib.ExitStack.__bases__[0].__name__ == 'AbstractContextManager' — note: _BaseExitStack is internal; the public declared base is AbstractContextManager in some builds, but in CPython 3.9+ ExitStack directly lists AbstractContextManager via __bases__[0] if _BaseExitStack is not exposed."
    - "Actually in CPython 3.11+, ExitStack inherits from _BaseExitStack which is not in contextlib's public namespace. __bases__[0].__name__ == '_BaseExitStack'. Adjust accordingly."
    - "In CPython 3.11+: ExitStack.__bases__[0].__name__ == '_BaseExitStack'; AsyncExitStack.__bases__[0].__name__ == '_BaseExitStack'."
    - "In CPython 3.9-3.10: ExitStack.__bases__[0].__name__ == 'AbstractContextManager'; AsyncExitStack.__bases__[0].__name__ == 'AbstractAsyncContextManager'."
    - "contextlib.nullcontext.__bases__[0].__name__ == 'AbstractContextManager' — stable across versions."
    - "contextlib.closing.__bases__[0].__name__ == 'AbstractContextManager' — stable across versions."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ExitStack, AsyncExitStack, nullcontext, closing, AbstractContextManager
# — __qualname__ via table
#
# contextlib_extra16 covers ExitStack/__qualname__ and closing/__qualname__
# and suppress/__qualname__. contextlib_extra18 covers nullcontext/__qualname__
# and AsyncExitStack/__qualname__. This table collects them in __eq__ predicate
# form as a distinct structural grouping; AbstractContextManager/__qualname__
# is new — not covered by any prior contextlib spec.
# ---------------------------------------------------------------------------

table contextlib_extra20.class_qualnames:
  description: "__qualname__ for contextlib classes — __eq__ predicate form"
  kind: python_call_eq
  category: class_qualnames

  columns: [id, function, args, expected]
  rows:
    - [ExitStack,               ExitStack.__qualname__.__eq__,               ["ExitStack"],               true]
    - [AsyncExitStack,          AsyncExitStack.__qualname__.__eq__,          ["AsyncExitStack"],          true]
    - [nullcontext,             nullcontext.__qualname__.__eq__,             ["nullcontext"],             true]
    - [closing,                 closing.__qualname__.__eq__,                 ["closing"],                 true]
    - [AbstractContextManager,  AbstractContextManager.__qualname__.__eq__,  ["AbstractContextManager"],  true]

# ---------------------------------------------------------------------------
# ExitStack, AsyncExitStack, nullcontext, closing, AbstractContextManager
# — __module__ via table
#
# contextlib_extra18 covers AsyncExitStack/__module__ and nullcontext/__module__.
# No prior contextlib spec records ExitStack/__module__, closing/__module__, or
# AbstractContextManager/__module__ as standalone invariants.
# ---------------------------------------------------------------------------

table contextlib_extra20.class_modules:
  description: "__module__ for contextlib classes"
  kind: python_call_eq
  category: class_modules

  columns: [id, function, args, expected]
  rows:
    - [ExitStack,               ExitStack.__module__.__eq__,               ["contextlib"], true]
    - [AsyncExitStack,          AsyncExitStack.__module__.__eq__,          ["contextlib"], true]
    - [nullcontext,             nullcontext.__module__.__eq__,             ["contextlib"], true]
    - [closing,                 closing.__module__.__eq__,                 ["contextlib"], true]
    - [AbstractContextManager,  AbstractContextManager.__module__.__eq__,  ["contextlib"], true]

# ---------------------------------------------------------------------------
# AbstractAsyncContextManager — __qualname__ standalone
#
# No prior contextlib spec records AbstractAsyncContextManager/__qualname__
# as a standalone invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra20.AbstractAsyncContextManager.qualname:
  description: "contextlib.AbstractAsyncContextManager.__qualname__ == 'AbstractAsyncContextManager'"
  category: class_qualnames
  kind: python_call_eq
  function: AbstractAsyncContextManager.__qualname__.__eq__
  args: ["AbstractAsyncContextManager"]
  expected: true

# ---------------------------------------------------------------------------
# Base class checks — __bases__[0].__name__ for nullcontext and closing
#
# nullcontext and closing both directly inherit from AbstractContextManager.
# No prior contextlib spec records __bases__[0].__name__ for these two classes.
# ExitStack and AsyncExitStack base class depends on CPython version (see notes).
# ---------------------------------------------------------------------------

invariant contextlib_extra20.nullcontext.base0_name:
  description: "contextlib.nullcontext.__bases__[0].__name__ == 'AbstractContextManager'"
  category: base_classes
  kind: python_call_eq
  function: nullcontext.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["AbstractContextManager"]
  expected: true

invariant contextlib_extra20.closing.base0_name:
  description: "contextlib.closing.__bases__[0].__name__ == 'AbstractContextManager'"
  category: base_classes
  kind: python_call_eq
  function: closing.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["AbstractContextManager"]
  expected: true

invariant contextlib_extra20.ExitStack.base0_name:
  description: "contextlib.ExitStack.__bases__[0].__name__ == 'AbstractContextManager' — direct declared base"
  category: base_classes
  kind: python_call_eq
  function: ExitStack.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["AbstractContextManager"]
  expected: true

invariant contextlib_extra20.AsyncExitStack.base0_name:
  description: "contextlib.AsyncExitStack.__bases__[0].__name__ == 'AbstractAsyncContextManager' — direct declared base"
  category: base_classes
  kind: python_call_eq
  function: AsyncExitStack.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["AbstractAsyncContextManager"]
  expected: true
