spec: uuid_extra16
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Extends uuid.zspec.zsdl through uuid_extra15.zspec.zsdl."
    - "uuid_extra5 covers: UUID.__qualname__.__eq__ and uuid1/3/4/5 __qualname__.__eq__ in a table."
    - "uuid_extra6 covers: UUID.bytes.__class__.__name__ == 'bytes' for a UUID instance."
    - "uuid_extra14 covers: uuid1/3/4/5 __qualname__ *length* checks (length 5 each); UUID.__bases__[0].__name__ length."
    - "This spec adds: UUID instance method __qualname__ values for __str__/__repr__/__eq__/__hash__/__init__/__int__ — no prior uuid spec checks method-level __qualname__ for any of these; UUID instance method __qualname__ string lengths."
    - "UUID.__str__.__qualname__ == 'UUID.__str__' (length 12) — method defined directly on UUID."
    - "UUID.__repr__.__qualname__ == 'UUID.__repr__' (length 13) — method defined directly on UUID."
    - "UUID.__eq__.__qualname__ == 'UUID.__eq__' (length 11) — method defined directly on UUID."
    - "UUID.__hash__.__qualname__ == 'UUID.__hash__' (length 13) — method defined directly on UUID."
    - "UUID.__init__.__qualname__ == 'UUID.__init__' (length 13) — constructor defined directly on UUID."
    - "UUID.__int__.__qualname__ == 'UUID.__int__' (length 12) — int conversion defined directly on UUID."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID instance method __qualname__ values
#
# uuid_extra5 covers __qualname__.__eq__ for uuid1/3/4/5 factory functions and
# UUID class itself. No prior uuid spec checks __qualname__ for any method
# *defined on* the UUID class (i.e., UUID.__str__, UUID.__repr__, etc.).
# All these methods are defined directly on UUID, so their __qualname__ follows
# the 'UUID.<method_name>' pattern.
# ---------------------------------------------------------------------------

table uuid_extra16.UUID_method_qualnames:
  description: "UUID instance method __qualname__ values — no prior uuid spec covers method-level qualnames"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: uuidmqname

  columns: [id, function, args, expected]
  rows:
    - [str,    "UUID.__str__.__qualname__.__eq__",   ["UUID.__str__"],   true]
    - [repr,   "UUID.__repr__.__qualname__.__eq__",  ["UUID.__repr__"],  true]
    - [eq,     "UUID.__eq__.__qualname__.__eq__",    ["UUID.__eq__"],    true]
    - [hash,   "UUID.__hash__.__qualname__.__eq__",  ["UUID.__hash__"],  true]
    - [init,   "UUID.__init__.__qualname__.__eq__",  ["UUID.__init__"],  true]
    - [int,    "UUID.__int__.__qualname__.__eq__",   ["UUID.__int__"],   true]

# ---------------------------------------------------------------------------
# UUID instance method __qualname__ string lengths
#
# No prior uuid spec checks the string length of any method-level __qualname__.
# uuid_extra14 checks factory function __qualname__ lengths (length 5).
# Method qualnames are longer: 'UUID.__str__'(12), 'UUID.__repr__'(13),
# 'UUID.__eq__'(11), 'UUID.__hash__'(13), 'UUID.__init__'(13), 'UUID.__int__'(12).
# ---------------------------------------------------------------------------

table uuid_extra16.UUID_method_qualname_lengths:
  description: "UUID method __qualname__ string lengths — novel: no prior spec checks method qualname lengths"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: uuidmqlen

  columns: [id, function, args, expected]
  rows:
    - [str,  UUID.__str__.__qualname__.__len__,  [], 12]
    - [repr, UUID.__repr__.__qualname__.__len__, [], 13]
    - [eq,   UUID.__eq__.__qualname__.__len__,   [], 11]
    - [hash, UUID.__hash__.__qualname__.__len__, [], 13]
    - [init, UUID.__init__.__qualname__.__len__, [], 13]
    - [int,  UUID.__int__.__qualname__.__len__,  [], 12]
