spec: bisect_extra13
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect.zspec.zsdl and prior extras through bisect_extra12.zspec.zsdl."
    - "Prior specs cover: __name__/__module__/__qualname__ for bisect_left/bisect_right/insort_left/insort_right/bisect/insort; behavioral vectors on many sorted lists."
    - "This spec adds NEW behavioral vectors not yet covered by any prior bisect spec:"
    - "  (1) bisect_left([1,2,3,4,5], 3) == 2 — target present, left insertion point is index 2."
    - "  (2) bisect_right([1,2,3,4,5], 3) == 3 — target present, right insertion point is one past."
    - "  (3) bisect_left([1,1,1,1], 1) == 0 — all equal, leftmost insertion point is 0."
    - "  (4) bisect_right([1,1,1,1], 1) == 4 — all equal, rightmost insertion point is 4 (past end)."
    - "  (5) bisect_left([], 1) == 0 — empty list always returns 0."
    - "  (6) bisect_right([], 1) == 0 — empty list always returns 0."
    - "  (7) bisect_left([1,2,3,4,5], 0) == 0 — target less than all elements."
    - "  (8) bisect_right([1,2,3,4,5], 6) == 5 — target greater than all elements."
    - "bisect.bisect_left([1,2,3,4,5], 3) == 2 — verified Python 3.12 macOS."
    - "bisect.bisect_right([1,2,3,4,5], 3) == 3 — verified Python 3.12 macOS."
    - "bisect.bisect_left([1,1,1,1], 1) == 0 — verified Python 3.12 macOS."
    - "bisect.bisect_right([1,1,1,1], 1) == 4 — verified Python 3.12 macOS."
    - "bisect.bisect_left([], 1) == 0 — verified Python 3.12 macOS."
    - "bisect.bisect_right([], 1) == 0 — verified Python 3.12 macOS."
    - "bisect.bisect_left([1,2,3,4,5], 0) == 0 — verified Python 3.12 macOS."
    - "bisect.bisect_right([1,2,3,4,5], 6) == 5 — verified Python 3.12 macOS."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# bisect_left behavioral invariants
#
# bisect_left returns the leftmost index where the value can be inserted to
# keep the list sorted. When the value is present, this is the index of the
# leftmost occurrence.
# ---------------------------------------------------------------------------

invariant bisect_extra13.bisect_left.five_elem_target_3:
  description: "bisect_left([1,2,3,4,5], 3) == 2 — target at index 2; left insertion point is 2"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[1, 2, 3, 4, 5], 3]
  expected: 2

invariant bisect_extra13.bisect_left.all_equal_target_1:
  description: "bisect_left([1,1,1,1], 1) == 0 — all equal; leftmost insertion point is 0"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[1, 1, 1, 1], 1]
  expected: 0

invariant bisect_extra13.bisect_left.empty_list:
  description: "bisect_left([], 1) == 0 — empty list always returns 0"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[], 1]
  expected: 0

invariant bisect_extra13.bisect_left.target_below_all:
  description: "bisect_left([1,2,3,4,5], 0) == 0 — target smaller than all elements"
  category: behavior
  kind: python_call_eq
  function: bisect_left
  args: [[1, 2, 3, 4, 5], 0]
  expected: 0

# ---------------------------------------------------------------------------
# bisect_right behavioral invariants
#
# bisect_right returns the rightmost index where the value can be inserted to
# keep the list sorted. When the value is present, this is one past the index
# of the rightmost occurrence.
# ---------------------------------------------------------------------------

invariant bisect_extra13.bisect_right.five_elem_target_3:
  description: "bisect_right([1,2,3,4,5], 3) == 3 — target at index 2; right insertion point is 3"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[1, 2, 3, 4, 5], 3]
  expected: 3

invariant bisect_extra13.bisect_right.all_equal_target_1:
  description: "bisect_right([1,1,1,1], 1) == 4 — all equal; rightmost insertion point is 4"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[1, 1, 1, 1], 1]
  expected: 4

invariant bisect_extra13.bisect_right.empty_list:
  description: "bisect_right([], 1) == 0 — empty list always returns 0"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[], 1]
  expected: 0

invariant bisect_extra13.bisect_right.target_above_all:
  description: "bisect_right([1,2,3,4,5], 6) == 5 — target larger than all elements"
  category: behavior
  kind: python_call_eq
  function: bisect_right
  args: [[1, 2, 3, 4, 5], 6]
  expected: 5

# ---------------------------------------------------------------------------
# Behavioral table — bisect_left and bisect_right vectors side by side
#
# Compact reference table with fresh id_prefix bisect13 for all 8 vectors.
# ---------------------------------------------------------------------------

table bisect_extra13.bisect_vectors:
  description: "bisect_left and bisect_right behavioral vectors"
  kind: python_call_eq
  category: behavior
  id_prefix: bisect13

  columns: [id, function, args, expected]
  rows:
    - [left_5elem_t3,   bisect_left,  [[1, 2, 3, 4, 5], 3],    2]
    - [right_5elem_t3,  bisect_right, [[1, 2, 3, 4, 5], 3],    3]
    - [left_all_eq,     bisect_left,  [[1, 1, 1, 1], 1],        0]
    - [right_all_eq,    bisect_right, [[1, 1, 1, 1], 1],        4]
    - [left_empty,      bisect_left,  [[], 1],                  0]
    - [right_empty,     bisect_right, [[], 1],                  0]
    - [left_below_all,  bisect_left,  [[1, 2, 3, 4, 5], 0],    0]
    - [right_above_all, bisect_right, [[1, 2, 3, 4, 5], 6],    5]
