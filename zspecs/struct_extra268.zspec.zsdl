spec: struct_extra268
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/struct.py"
    - "struct_extra267.zspec.zsdl — covers struct.error MRO length and struct.__all__ identity."
    - "struct_extra266.zspec.zsdl — covers struct module __spec__/__loader__ identity and _struct C extension identity."
    - "struct_extra263.zspec.zsdl — covers struct.error class identity and pack/unpack error cases."
  notes:
    - "struct.Struct.__name__ == 'Struct' — the Struct class name is 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.__module__ == '_struct' — Struct is implemented in the _struct C extension, not in the pure-Python struct module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits directly from object. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!H', 256) == b'\\x01\\x00' — big-endian unsigned short 256 packs to bytes [1, 0]. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.pack('!I', 1) == b'\\x00\\x00\\x00\\x01' — big-endian unsigned int 1 packs to bytes [0, 0, 0, 1]. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!H') == 2 — network-byte-order unsigned short is 2 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!I') == 4 — network-byte-order unsigned int is 4 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.calcsize('!Q') == 8 — network-byte-order unsigned long long is 8 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.__name__ == 'struct' — the module name attribute. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct class identity
# Struct is a C extension type defined in _struct (not the pure-Python struct
# module). Its __module__ is '_struct' and it inherits directly from object.
# struct.__name__ is 'struct' (the pure-Python wrapper module).
# ---------------------------------------------------------------------------

table struct_extra268.Struct_class_identity:
  description: "struct.Struct class identity — Struct.__name__/'Struct'; Struct.__module__/'_struct'; Struct.__bases__[0].__name__/'object'; struct.__name__/'struct'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structcls268

  columns: [id, function, args, expected, description]
  rows:
    - [struct_name,    Struct.__name__.__eq__,                  ["Struct"],   true, "struct.Struct.__name__ == 'Struct' — the C extension type name"]
    - [struct_module,  Struct.__module__.__eq__,                ["_struct"],  true, "struct.Struct.__module__ == '_struct' — Struct is implemented in the _struct C extension"]
    - [struct_bases0,  "Struct.__bases__[0].__name__.__eq__",   ["object"],   true, "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits directly from object"]
    - [mod_name,       __name__.__eq__,                         ["struct"],   true, "struct.__name__ == 'struct' — the pure-Python wrapper module name"]
    - [mod_package,    __package__.__eq__,                      [""],         true, "struct.__package__ == '' — struct is a top-level module with empty package string"]

# ---------------------------------------------------------------------------
# struct.pack and struct.calcsize behavior for network byte-order formats
# '!' means network byte order (big-endian). H=unsigned short (2B),
# I=unsigned int (4B), Q=unsigned long long (8B).
# pack('!H', 256) == b'\x01\x00' because 256 == 0x0100 in big-endian.
# pack('!I', 1) == b'\x00\x00\x00\x01' because 1 in 4-byte big-endian.
# ---------------------------------------------------------------------------

table struct_extra268.pack_and_calcsize_network_order:
  description: "struct.pack and calcsize for network byte-order formats — pack('!H',256)==b'\\x01\\x00'; pack('!I',1)==b'\\x00\\x00\\x00\\x01'; calcsize('!H')==2; calcsize('!I')==4; calcsize('!Q')==8; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: structpack268

  columns: [id, function, args, expected, description]
  rows:
    - [calc_H,  calcsize_excl_H.__eq__,   [2], true, "struct.calcsize('!H') == 2 — network-order unsigned short is 2 bytes"]
    - [calc_I,  calcsize_excl_I.__eq__,   [4], true, "struct.calcsize('!I') == 4 — network-order unsigned int is 4 bytes"]
    - [calc_Q,  calcsize_excl_Q.__eq__,   [8], true, "struct.calcsize('!Q') == 8 — network-order unsigned long long is 8 bytes"]
    - [pack_H,  pack_excl_H_256.__eq__,   ["b'\\x01\\x00'"], true, "struct.pack('!H', 256) == b'\\x01\\x00' — 256 as big-endian 2-byte unsigned short"]
    - [pack_I,  pack_excl_I_1.__eq__,     ["b'\\x00\\x00\\x00\\x01'"], true, "struct.pack('!I', 1) == b'\\x00\\x00\\x00\\x01' — 1 as big-endian 4-byte unsigned int"]

# ---------------------------------------------------------------------------
# Standalone invariants — Struct class identity and pack/calcsize behavior
# ---------------------------------------------------------------------------

invariant struct_extra268.Struct_name_eq:
  description: "struct.Struct.__name__ == 'Struct' — the class name of the Struct type defined in the _struct C extension; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra268.Struct_module_eq:
  description: "struct.Struct.__module__ == '_struct' — Struct is a C extension type implemented in _struct, not the pure-Python struct wrapper; contrasts with struct.__name__ == 'struct'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra268.Struct_bases0_name_eq:
  description: "struct.Struct.__bases__[0].__name__ == 'object' — Struct has no intermediate base class; inherits directly from object; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: "Struct.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant struct_extra268.module_name_eq:
  description: "struct.__name__ == 'struct' — the pure-Python wrapper module's __name__ attribute; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra268.calcsize_H_eq:
  description: "struct.calcsize('!H') == 2 — network-byte-order (big-endian) unsigned short requires 2 bytes; '!' prefix means network order; 'H' means unsigned short; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: calcsize_excl_H.__eq__
  args: [2]
  expected: true

invariant struct_extra268.calcsize_I_eq:
  description: "struct.calcsize('!I') == 4 — network-byte-order unsigned int requires 4 bytes; 'I' means unsigned int; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: calcsize_excl_I.__eq__
  args: [4]
  expected: true

invariant struct_extra268.calcsize_Q_eq:
  description: "struct.calcsize('!Q') == 8 — network-byte-order unsigned long long requires 8 bytes; 'Q' means unsigned long long; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: calcsize_excl_Q.__eq__
  args: [8]
  expected: true

invariant struct_extra268.pack_invalid_char_raises:
  description: "struct.pack('z', 1) raises struct.error — 'z' is not a valid struct format character; struct.error is raised for unrecognized format characters; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: pack
  args: ["z", 1]
  raises: error
