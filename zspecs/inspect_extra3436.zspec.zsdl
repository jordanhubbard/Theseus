spec: in3436
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 676 (in3436): __le__, __gt__, __ge__ dict-presence checks for inspect types."
    - "Theme: __le__/__gt__/__ge__ dict-presence (x<=y, x>y, x>=y)."
    - "All values False — inspect introspection types have no custom le/gt/ge comparison in their own __dict__."
    - "None of the inspect types define __le__, __gt__, or __ge__ in their own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "None of these types implement le, gt, or ge comparison protocols directly in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3436.le:
  description: "inspect types __le__ dict-presence checks; wave 676"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3436
  columns: [id, function, args, expected]
  rows:
    - ["in3436001", operator.contains, [inspect.Parameter.__dict__,           "__le__"], false]
    - ["in3436002", operator.contains, [inspect.Signature.__dict__,           "__le__"], false]
    - ["in3436003", operator.contains, [inspect.BoundArguments.__dict__,      "__le__"], false]
