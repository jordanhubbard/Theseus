spec: email_policy
version: ">=3.3"
backend: python_module(email.policy)

docs: https://docs.python.org/3/library/email.policy.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.policy.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "email.policy source: Lib/email/policy.py (PSF; source inspection permitted)"
  not_derived_from:
    - "email.policy source: internal header encoding machinery"
  notes:
    - "Policy is the abstract base class for all email policies; it defines the API but is not used directly."
    - "EmailPolicy (Python 3.6+) is the modern policy class; it inherits from Policy."
    - "Compat32 is the legacy policy class maintaining compatibility with the old email package; it inherits from Policy."
    - "email.policy.default is a module-level EmailPolicy instance (max_line_length=78, utf8=False)."
    - "email.policy.strict is a module-level EmailPolicy instance with raise_on_defect=True."
    - "email.policy.SMTP is a module-level EmailPolicy instance pre-configured for SMTP (linesep='\\r\\n')."
    - "email.policy.SMTPUTF8 is a module-level EmailPolicy instance with utf8=True and linesep='\\r\\n'."
    - "email.policy.HTTP is a module-level EmailPolicy instance with linesep='\\r\\n' and max_line_length=None."
    - "email.policy.compat32 is a module-level Compat32 instance (the legacy default policy)."
    - "All expected values verified by running Python 3.12 email.policy module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table email_policy.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [Policy,       Policy.__name__.__eq__,       ["Policy"],       true]
    - [EmailPolicy,  EmailPolicy.__name__.__eq__,   ["EmailPolicy"],  true]
    - [Compat32,     Compat32.__name__.__eq__,      ["Compat32"],     true]

# ---------------------------------------------------------------------------
# Module checks
# ---------------------------------------------------------------------------

table email_policy.module_checks:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Policy,      Policy.__module__.__eq__,      ["email.policy"], true]
    - [EmailPolicy, EmailPolicy.__module__.__eq__,  ["email.policy"], true]
    - [Compat32,    Compat32.__module__.__eq__,     ["email.policy"], true]

# ---------------------------------------------------------------------------
# Inheritance
# ---------------------------------------------------------------------------

invariant email_policy.emailpolicy_base:
  description: "EmailPolicy.__bases__[0].__name__ == 'Policy' — EmailPolicy inherits from Policy"
  category: inheritance
  kind: python_call_eq
  function: EmailPolicy.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Policy"

invariant email_policy.compat32_base:
  description: "Compat32.__bases__[0].__name__ == 'Policy' — Compat32 inherits from Policy"
  category: inheritance
  kind: python_call_eq
  function: Compat32.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Policy"

# ---------------------------------------------------------------------------
# Module-level policy instances — class identity
#
# email.policy.default, SMTP, SMTPUTF8, HTTP are EmailPolicy instances.
# email.policy.compat32 is a Compat32 instance.
# These are accessed as module attributes (non-callable), so we use
# function: ATTR.__class__.__name__.__eq__ with args: ["ClassName"].
# ---------------------------------------------------------------------------

invariant email_policy.default_is_emailpolicy:
  description: "email.policy.default.__class__.__name__ == 'EmailPolicy'"
  category: instances
  kind: python_call_eq
  function: default.__class__.__name__.__eq__
  args: ["EmailPolicy"]
  expected: true

invariant email_policy.strict_is_emailpolicy:
  description: "email.policy.strict.__class__.__name__ == 'EmailPolicy'"
  category: instances
  kind: python_call_eq
  function: strict.__class__.__name__.__eq__
  args: ["EmailPolicy"]
  expected: true

invariant email_policy.SMTP_is_emailpolicy:
  description: "email.policy.SMTP.__class__.__name__ == 'EmailPolicy'"
  category: instances
  kind: python_call_eq
  function: SMTP.__class__.__name__.__eq__
  args: ["EmailPolicy"]
  expected: true

invariant email_policy.SMTPUTF8_is_emailpolicy:
  description: "email.policy.SMTPUTF8.__class__.__name__ == 'EmailPolicy'"
  category: instances
  kind: python_call_eq
  function: SMTPUTF8.__class__.__name__.__eq__
  args: ["EmailPolicy"]
  expected: true

invariant email_policy.HTTP_is_emailpolicy:
  description: "email.policy.HTTP.__class__.__name__ == 'EmailPolicy'"
  category: instances
  kind: python_call_eq
  function: HTTP.__class__.__name__.__eq__
  args: ["EmailPolicy"]
  expected: true

invariant email_policy.compat32_is_compat32:
  description: "email.policy.compat32.__class__.__name__ == 'Compat32'"
  category: instances
  kind: python_call_eq
  function: compat32.__class__.__name__.__eq__
  args: ["Compat32"]
  expected: true

# ---------------------------------------------------------------------------
# SMTP instance — linesep attribute
# ---------------------------------------------------------------------------

invariant email_policy.SMTP_linesep:
  description: "email.policy.SMTP.linesep == '\\r\\n' — SMTP policy uses CRLF line endings"
  category: instance_attrs
  kind: python_call_eq
  function: SMTP.linesep.__eq__
  args: ["\r\n"]
  expected: true

invariant email_policy.SMTPUTF8_utf8:
  description: "email.policy.SMTPUTF8.utf8 == True — SMTPUTF8 policy enables UTF-8 headers"
  category: instance_attrs
  kind: python_call_eq
  function: SMTPUTF8.utf8.__eq__
  args: [true]
  expected: true
