spec: itertools_extra37
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra36.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 ('object') for all major types; __dict__.__class__.__name__.__len__()==12 ('mappingproxy') for all major types; chain.from_iterable.__name__.__len__()==13; chain.__doc__.__len__()==190; count.__doc__.__len__()==205; repeat.__doc__.__len__()==154; cycle.__doc__.__len__()==95; dropwhile.__doc__.__len__()==126; takewhile.__doc__.__len__()==101; compress.__doc__.__len__()==164; accumulate.__doc__.__len__()==69; filterfalse.__doc__.__len__()==120; starmap.__doc__.__len__()==126; pairwise.__doc__.__len__()==112."
    - "This spec covers: combinations_with_replacement.__doc__.__len__() (234 — longest docstring in the combinatorial trio); permutations.__doc__.__len__() (140); combinations.__doc__.__len__() (134); product.__doc__.__len__() (681 — the longest docstring in all of itertools); islice.__doc__.__len__() (453); zip_longest.__doc__.__len__() (427); groupby.__doc__.__len__() (323)."
    - "Key findings: itertools.product.__doc__ is 681 chars — the longest docstring in all of itertools, because product's behavior (Cartesian product with repeat parameter) requires extensive description and examples. itertools.islice.__doc__ is 453 chars and itertools.zip_longest.__doc__ is 427 chars — the second and third longest, because both have complex semantics (slicing vs. padding to longest). itertools.groupby.__doc__ is 323 chars. itertools.combinations_with_replacement.__doc__ is 234 chars — the longest of the pure combinatorial trio (combinations_with_replacement/permutations/combinations). itertools.permutations.__doc__ is 140 chars. itertools.combinations.__doc__ is 134 chars — shorter than permutations by 6 chars."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Combinatorial C-type docstring lengths — extra37 namespace
#
# itertools.combinations_with_replacement.__doc__ is 234 chars — the longest
# docstring among the pure combinatorial types, because it must describe
# both the with-replacement semantics and the sorted order guarantee.
# itertools.permutations.__doc__ is 140 chars. itertools.combinations.__doc__
# is 134 chars — 6 chars shorter than permutations (combinations need not
# explain order of selection). No prior itertools spec records __doc__.__len__()
# for combinations_with_replacement, permutations, or combinations. These three
# values are recorded together for the first time in the extra37 namespace.
# ---------------------------------------------------------------------------

table itertools_extra37.combinatorial_type_docstring_lengths:
  description: "itertools combinatorial C-type __doc__.__len__(): combinations_with_replacement(234), permutations(140), combinations(134)"
  kind: python_call_eq
  category: string_properties
  id_prefix: combinedoclen37

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_with_replacement,
       combinations_with_replacement.__doc__.__len__,
       [],
       234,
       "len(itertools.combinations_with_replacement.__doc__) == 234 — longest combinatorial docstring; describes with-replacement semantics and sorted-order guarantee"]
    - [permutations,
       permutations.__doc__.__len__,
       [],
       140,
       "len(itertools.permutations.__doc__) == 140 — describes ordered arrangements; 6 chars longer than combinations"]
    - [combinations,
       combinations.__doc__.__len__,
       [],
       134,
       "len(itertools.combinations.__doc__) == 134 — shortest of the combinatorial trio; unordered selection needs less explanation"]

# ---------------------------------------------------------------------------
# Sequence-control C-type docstring lengths — extra37 namespace
#
# itertools.product.__doc__ is 681 chars — the single longest docstring in all
# of itertools, because product requires explanation of both the basic
# Cartesian-product semantics and the 'repeat' keyword parameter. itertools.
# islice.__doc__ is 453 chars — second longest, because islice has four
# distinct call forms (0/1/2/3 non-None arguments). itertools.zip_longest.
# __doc__ is 427 chars — third longest, because zip_longest must explain the
# 'fillvalue' parameter and the padding-to-longest contract. itertools.groupby.
# __doc__ is 323 chars. No prior itertools spec records __doc__.__len__() for
# product, islice, zip_longest, or groupby. These four values are recorded
# together for the first time in the extra37 namespace.
# ---------------------------------------------------------------------------

table itertools_extra37.sequence_control_type_docstring_lengths:
  description: "itertools sequence-control C-type __doc__.__len__(): product(681), islice(453), zip_longest(427), groupby(323)"
  kind: python_call_eq
  category: string_properties
  id_prefix: seqdoclen37

  columns: [id, function, args, expected, description]
  rows:
    - [product,
       product.__doc__.__len__,
       [],
       681,
       "len(itertools.product.__doc__) == 681 — the single longest docstring in all of itertools; Cartesian product with 'repeat' parameter requires extensive description"]
    - [islice,
       islice.__doc__.__len__,
       [],
       453,
       "len(itertools.islice.__doc__) == 453 — second longest; four distinct call forms (0/1/2/3 non-None arguments) require detailed documentation"]
    - [zip_longest,
       zip_longest.__doc__.__len__,
       [],
       427,
       "len(itertools.zip_longest.__doc__) == 427 — third longest; must explain 'fillvalue' parameter and padding-to-longest contract"]
    - [groupby,
       groupby.__doc__.__len__,
       [],
       323,
       "len(itertools.groupby.__doc__) == 323 — describes key-function grouping with consecutive-key semantics"]

# ---------------------------------------------------------------------------
# itertools.combinations_with_replacement.__doc__ longest-in-module flag
#
# itertools.combinations_with_replacement.__doc__ (234 chars) is the longest
# docstring among the three pure combinatorial types (combinations_with_
# replacement, permutations, combinations). However, itertools.product.__doc__
# (681 chars) is the longest in all of itertools. This invariant records the
# fact that the combinatorial trio leader (234) is less than the full-module
# leader (681): combinations_with_replacement.__doc__.__len__() < product.
# __doc__.__len__(). We confirm this relationship with __lt__ on the length.
# ---------------------------------------------------------------------------

invariant itertools_extra37.cwr_doc_len_lt_product:
  description: "itertools.combinations_with_replacement.__doc__.__len__() < itertools.product.__doc__.__len__() — product(681) has the longest docstring in itertools; combinations_with_replacement(234) leads the combinatorial trio but not the module"
  category: string_properties
  kind: python_call_eq
  function: combinations_with_replacement.__doc__.__len__
  args: []
  method: __lt__
  method_args: [681]
  expected: true
