table asyncio_extra111.asyncio_condition_class_hierarchy:
  description: "asyncio.Condition class hierarchy and method qualname length comparison in asynciocond111 namespace — wave 254 theme: asyncio.Condition.__name__.__eq__('Condition')==True (len=9); asyncio.Condition.__qualname__.__eq__('Condition')==True (len=9, qualname equals name for top-level class); asyncio.Condition.__module__.__eq__('asyncio.locks')==True; asyncio.Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (Condition inherits from _ContextManagerMixin); asyncio.Condition.__mro__.__len__()==4 (MRO=[Condition, _ContextManagerMixin, _LoopBoundMixin, object]); compare Condition method qualname lengths (all start with 'Condition.'=10 prefix): Condition.wait=14 (shortest in spec) < Condition.notify=16 < Condition.wait_for=18 < Condition.notify_all=20 (longest in spec); compare co_argcount values: notify_all=1 == wait=1 (self only) < notify=2 == wait_for=2 (self plus one extra arg); Condition.notify takes n (count of waiters to notify) while Condition.wait_for takes predicate (callable that returns True/False); asyncio.Condition.__name__.__len__()==9 (same as Condition.__qualname__.__len__()==9); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: asynciocond111b

  columns: [id, function, args, expected, description]
