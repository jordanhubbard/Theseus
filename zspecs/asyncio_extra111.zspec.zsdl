# ---------------------------------------------------------------------------
# Standalone invariants — extra111
# ---------------------------------------------------------------------------

invariant asyncio_extra111.Condition_notify_co_argcount_2:
  description: "asyncio.Condition.notify.__code__.co_argcount == 2 — notify takes self and n (n is the number of waiting coroutines to wake, defaults to 1); Condition.notify.__qualname__=='Condition.notify' (len=16); type(asyncio.Condition.notify).__name__=='function' (Python-defined method); compare: notify co_argcount=2 (takes n) vs notify_all co_argcount=1 (self only — wakes all waiters without an n parameter); Condition.wait co_argcount=1 (self only — suspends coroutine until notify is called); Condition.wait_for co_argcount=2 (self and predicate — also takes one extra arg like notify); Condition.notify must be called within the lock (Condition is a reentrant condition variable); asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin' (mro len=4); asyncio.Condition.__module__=='asyncio.locks'; NEW in extra111: first standalone Condition.notify argcount invariant in asynciocond111 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Condition.notify.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant asyncio_extra111.Condition_notify_all_qualname_len_20:
  description: "asyncio.Condition.notify_all.__qualname__.__len__() == 20 — 'Condition.notify_all' = 'Condition.'=10 + 'notify_all'=10 = 20; this is the longest method qualname in this spec; compare: Condition.wait=14 (shortest) < Condition.notify=16 < Condition.wait_for=18 < Condition.notify_all=20 (longest); notify_all is longer than notify by 4 chars ('notify_all'=10 vs 'notify'=6); Condition.notify_all.__code__.co_argcount==1 (self only — despite the longer name, notify_all takes only self); asyncio.Condition.__mro__.__len__()==4 ([Condition, _ContextManagerMixin, _LoopBoundMixin, object]); asyncio.Condition.__module__=='asyncio.locks'; NEW in extra111: first standalone Condition.notify_all qualname length invariant in asynciocond111 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Condition.notify_all.__qualname__.__len__
  args: []
  expected: 20

invariant asyncio_extra111.Condition_wait_for_co_argcount_2:
  description: "asyncio.Condition.wait_for.__code__.co_argcount == 2 — wait_for takes self and predicate (the predicate callable is called repeatedly until it returns True); Condition.wait_for.__qualname__=='Condition.wait_for' (len=18); type(asyncio.Condition.wait_for).__name__=='function' (Python-defined coroutine); compare co_argcount: wait_for=2 == notify=2 (both take one extra positional arg beyond self) > wait=notify_all=1 (self only); Condition.wait_for waits until predicate() returns a true value, internally calling wait() in a loop; Condition.wait co_argcount=1 (simpler: wait until any notify); asyncio.Condition.__mro__.__len__()==4; asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin'; NEW in extra111: first standalone Condition.wait_for argcount invariant in asynciocond111 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Condition.wait_for.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant asyncio_extra111.Condition_wait_qualname_len_14:
  description: "asyncio.Condition.wait.__qualname__.__len__() == 14 — 'Condition.wait' = 'Condition.'=10 + 'wait'=4 = 14; this is the shortest method qualname in this spec; compare all method qualname lengths: Condition.wait=14 (shortest) < Condition.notify=16 < Condition.wait_for=18 < Condition.notify_all=20 (longest); Condition.wait.__code__.co_argcount==1 (self only); Condition.wait suspends the calling coroutine until notify() or notify_all() releases it; asyncio.Condition.__qualname__.__len__()==9 (class qualname is shorter than all method qualnames in spec); asyncio.Condition.__module__=='asyncio.locks'; asyncio.Condition.__mro__.__len__()==4; NEW in extra111: first standalone Condition.wait qualname length invariant in asynciocond111 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: asyncio.Condition.wait.__qualname__.__len__
  args: []
  expected: 14

invariant asyncio_extra111.Condition_mro_len_4:
  description: "asyncio.Condition.__mro__.__len__() == 4 — Condition's MRO is [Condition, _ContextManagerMixin, _LoopBoundMixin, object] (length=4); asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin' (direct parent); asyncio.Condition.__name__=='Condition' (len=9); asyncio.Condition.__qualname__=='Condition' (len=9, same as __name__); asyncio.Condition.__module__=='asyncio.locks'; compare MRO structure: Condition (len=4) is deeper than asyncio.Lock (mro len=4) and asyncio.Semaphore (mro len=4) from prior specs — all synchronization primitives use _ContextManagerMixin; asyncio.Event has mro len=3 (shorter, uses _LoopBoundMixin as direct base); asyncio.BoundedSemaphore has mro len=5 (longer, adds Semaphore layer); Condition's unique MRO path: _ContextManagerMixin then _LoopBoundMixin then object; the 4-level MRO reflects Condition's role as a complex synchronization primitive; NEW in extra111: first standalone Condition MRO length invariant in asynciocond111 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: asyncio.Condition.__mro__.__len__
  args: []
  expected: 4
