    - [cond_mro_len2,     asyncio.Condition.__mro__.__len__,                            [],                       4,    "Condition.__mro__.__len__() == 4 ([Condition, _ContextManagerMixin, _LoopBoundMixin, object]); verified with Python 3.14.3"]
