    - [nall_qn_eq,        asyncio.Condition.notify_all.__qualname__.__eq__,             ["Condition.notify_all"], true, "Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20); verified with Python 3.14.3"]
    - [nall_qn_len,       asyncio.Condition.notify_all.__qualname__.__len__,            [],                       20,   "Condition.notify_all.__qualname__.__len__() == 20 ('Condition.notify_all'=20); verified with Python 3.14.3"]
    - [nall_type_eq,      type(asyncio.Condition.notify_all).__name__.__eq__,           ["function"],             true, "type(Condition.notify_all).__name__ == 'function' (Python-defined); verified with Python 3.14.3"]
    - [nall_argc,         asyncio.Condition.notify_all.__code__.co_argcount.__eq__,     [1],                      true, "Condition.notify_all.__code__.co_argcount == 1 (self only — notifies all waiters); verified with Python 3.14.3"]
