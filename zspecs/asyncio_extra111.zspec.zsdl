spec: asyncio_extra111
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra110.zspec.zsdl."
    - "This spec covers: wave 254 theme — asyncio.Condition method qualnames and co_argcounts: notify, notify_all, wait, wait_for. NEW in extra111: asyncio.Condition.notify.__qualname__=='Condition.notify' (len=16, co_argcount=2: self and n); asyncio.Condition.notify_all.__qualname__=='Condition.notify_all' (len=20, co_argcount=1: self only); asyncio.Condition.wait.__qualname__=='Condition.wait' (len=14, co_argcount=1: self only); asyncio.Condition.wait_for.__qualname__=='Condition.wait_for' (len=18, co_argcount=2: self and predicate); asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin', __mro__.__len__()==4; asyncio.Condition.__module__=='asyncio.locks'; asyncio.Condition.__qualname__=='Condition' (len=9); asyncio.Condition.__name__=='Condition' (len=9). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.notify.__qualname__ == 'Condition.notify' (len=16). co_argcount=2 (self and n — n is the number of waiters to notify, defaults to 1). asyncio.Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20, co_argcount=1: self only — notifies all waiters). asyncio.Condition.__module__=='asyncio.locks'. asyncio.Condition.__bases__[0].__name__=='_ContextManagerMixin' (MRO=[Condition, _ContextManagerMixin, _LoopBoundMixin, object], length=4). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.wait.__qualname__ == 'Condition.wait' (len=14, co_argcount=1: self only — wait() suspends until notified). asyncio.Condition.wait_for.__qualname__ == 'Condition.wait_for' (len=18, co_argcount=2: self and predicate — wait_for waits until predicate returns True). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Condition.notify and notify_all method code attributes — extra111
#
# Wave 254 theme: Condition notify methods qualnames and co_argcounts.
#
# asyncio.Condition.notify.__qualname__     == 'Condition.notify'     (len=16, co_argcount=2)
# asyncio.Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20, co_argcount=1)
# ---------------------------------------------------------------------------

table asyncio_extra111.asyncio_condition_notify_attrs:
  description: "asyncio.Condition.notify and notify_all method code attribute checks in asynciocond111 namespace — wave 254 theme: asyncio.Condition.notify.__qualname__.__eq__('Condition.notify')==True (len=16: 'Condition.'=10+'notify'=6=16); type(asyncio.Condition.notify).__name__.__eq__('function')==True (Python-defined method); asyncio.Condition.notify.__code__.co_argcount==2 (self and n — n is the number of waiters to wake, defaults to 1); asyncio.Condition.notify_all.__qualname__.__eq__('Condition.notify_all')==True (len=20: 'Condition.'=10+'notify_all'=10=20; longest qualname in this table); type(asyncio.Condition.notify_all).__name__.__eq__('function')==True; asyncio.Condition.notify_all.__code__.co_argcount==1 (self only — notify_all wakes all waiters, takes no n argument); compare co_argcount: notify=2 (takes n) vs notify_all=1 (self only); notify_all qualname len=20 > notify qualname len=16 (notify_all is longer by 4 chars: 'notify_all'=10 vs 'notify'=6); asyncio.Condition.__name__.__eq__('Condition')==True (len=9); asyncio.Condition.__module__.__eq__('asyncio.locks')==True; asyncio.Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True; asyncio.Condition.__mro__.__len__()==4; verified with Python 3.14.3"
