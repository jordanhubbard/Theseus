spec: mp3526
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 682 (mp3526): __set_name__, __init_subclass__, __class_getitem__ dict-presence checks for multiprocessing types."
    - "All values false — multiprocessing types do not implement class creation hooks or generic parameterization."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __set_name__ dict-presence — operator.contains(Cls.__dict__, '__set_name__')
# ---------------------------------------------------------------------------

table mp3526.set_name:
  description: "multiprocessing types __set_name__ dict-presence checks; wave 682"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3526
  columns: [id, function, args, expected]
  rows:
    - ["mp3526001", operator.contains, [multiprocessing.Process.__dict__,                 "__set_name__"], false]
    - ["mp3526002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__set_name__"], false]
    - ["mp3526003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__set_name__"], false]
    - ["mp3526004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__set_name__"], false]
    - ["mp3526005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__set_name__"], false]

