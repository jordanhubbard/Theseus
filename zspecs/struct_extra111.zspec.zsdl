spec: struct_extra111
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra110.zspec.zsdl — covers iter_unpack/unpack_from __name__/__module__ equality / module function type identity (builtin_function_or_method) / Struct instance method __name__ equality / error __qualname__/__module__ equality (table + invariants)."
    - "struct_extra109.zspec.zsdl — covers Struct method_descriptor __objclass__.__name__ equality / module-level function __name__ equality (pack/unpack/calcsize/pack_into) / Struct class __module__/__qualname__ equality (table + invariants)."
    - "struct_extra108.zspec.zsdl — covers module-level function __name__ lengths / struct.error __name__/__module__/__qualname__ equality and lengths / struct.Struct.__name__ equality / struct.error MRO structure (table + invariants)."
    - "struct_extra107.zspec.zsdl — covers Struct.size/format getset_descriptor qualname equality and __objclass__.__name__ / module-level calcsize/pack/unpack qualname equality / Struct.__doc__ type (table + invariants)."
    - "struct_extra106.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack qualname equality / Struct.__init__ qualname and wrapper_descriptor type / all five methods are method_descriptor (table + invariants)."
    - "struct_extra105.zspec.zsdl — covers struct.__spec__ attributes (name, class, has_location) / struct.__name__ and __package__ equality and lengths / struct.error method qualnames (table + invariants)."
    - "struct_extra104.zspec.zsdl — covers Struct.size/format getset_descriptor qualnames and __objclass__ / module-level function qualname equality for all six functions (table + invariants)."
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths / Struct class-level method_descriptor type names (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers module-level function __doc__ lengths / Struct.size/__format__ __doc__ equality (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers Struct.__qualname__.__len__()==6 / module-level function __module__.__eq__('_struct') (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra110; it does NOT duplicate invariants present in those files."
    - "Wave 275 theme: struct module __spec__ and __loader__ class attributes not yet covered — struct_extra105 anchors __spec__.name, __spec__.__class__.__name__ ('ModuleSpec'), and __spec__.has_location; NOT YET covered: __spec__.__class__.__module__ ('_frozen_importlib'), __loader__.__class__.__name__ ('SourceFileLoader'), __loader__.__class__.__module__ ('_frozen_importlib_external'), __loader__.__class__.__qualname__, and class name/module lengths."
    - "struct.__spec__.__class__.__module__ == '_frozen_importlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.__class__.__qualname__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__module__ == '_frozen_importlib_external'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__qualname__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.__class__.__name__.__len__() == 10 (len('ModuleSpec')). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.__class__.__module__.__len__() == 17 (len('_frozen_importlib')). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__name__.__len__() == 16 (len('SourceFileLoader')). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__module__.__len__() == 26 (len('_frozen_importlib_external')). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct_extra105 anchors __spec__.__class__.__name__=='ModuleSpec', __spec__.name=='struct', and __spec__.has_location==True. This spec anchors __spec__.__class__.__module__ ('_frozen_importlib' — the frozen bootstrap importer) and the __loader__ class identity (SourceFileLoader from _frozen_importlib_external). The struct module on CPython 3.14.3 macOS uses a SourceFileLoader because struct.py is a Python source file (the C implementation is in _struct.c but the public struct module is a thin Python wrapper)."
    - "Note: '_frozen_importlib' is the module name for the importlib._bootstrap module as it appears in the frozen importer. '_frozen_importlib_external' is the module name for importlib._bootstrap_external. These are CPython implementation details; the leading underscore and 'frozen' prefix indicate they are internal bootstrap components not intended for direct use. 'SourceFileLoader' loads Python source (.py) files."
    - "Note: struct.__loader__.__class__.__module__.__len__() == 26 is the longest module name length in this spec. '_frozen_importlib_external' = '_frozen_importlib' (17) + '_external' (9) = 26 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__module__.__eq__('_frozen_importlib')
# struct.__spec__.__class__.__qualname__.__eq__('ModuleSpec')
# struct.__spec__.__class__.__name__.__len__() == 10
# struct.__spec__.__class__.__module__.__len__() == 17
# struct.__loader__.__class__.__name__.__eq__('SourceFileLoader')
#
# Wave 275 theme: struct.__spec__ class module identity and lengths.
#
# struct.__spec__ is a ModuleSpec from the _frozen_importlib module. The class
# module '_frozen_importlib' is CPython's internal frozen bootstrap importer.
# struct_extra105 anchors __spec__.__class__.__name__=='ModuleSpec' and
# __spec__.name=='struct'. This spec anchors __spec__.__class__.__module__
# equality and the class name/module lengths for the first time.
# Also anchors __loader__.__class__.__name__=='SourceFileLoader'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra111.spec_class_module_and_loader_identity:
  description: "__spec__.__class__.__module__.__eq__('_frozen_importlib')==True / __spec__.__class__.__qualname__.__eq__('ModuleSpec')==True / __spec__.__class__.__name__.__len__()==10 / __spec__.__class__.__module__.__len__()==17 / __loader__.__class__.__name__.__eq__('SourceFileLoader')==True — __spec__ class module is '_frozen_importlib' (CPython bootstrap importer; 17 chars); __spec__ class qualname is 'ModuleSpec' (same as __name__; top-level class); ModuleSpec name is 10 chars; SourceFileLoader loads .py source files; extra105 anchors __spec__ class name and spec.name; first structspec111 anchor"
  kind: python_call_eq
  category: module_identity
  id_prefix: structspec111

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_module_eq,    "__spec__.__class__.__module__.__eq__",   ["_frozen_importlib"], true, "__spec__.__class__.__module__ is '_frozen_importlib' (CPython's frozen bootstrap importer module; 17 chars)"]
    - [spec_class_qualname_eq,  "__spec__.__class__.__qualname__.__eq__", ["ModuleSpec"],        true, "__spec__.__class__.__qualname__ is 'ModuleSpec' (same as __name__; top-level class with no enclosing scope)"]
    - [spec_class_name_len,     "__spec__.__class__.__name__.__len__",    [],                    10,   "__spec__.__class__.__name__.__len__() is 10 (len('ModuleSpec')==10)"]
    - [spec_class_module_len,   "__spec__.__class__.__module__.__len__",  [],                    17,   "__spec__.__class__.__module__.__len__() is 17 (len('_frozen_importlib')==17)"]
    - [loader_class_name_eq,    "__loader__.__class__.__name__.__eq__",   ["SourceFileLoader"],  true, "__loader__.__class__.__name__ is 'SourceFileLoader' (loads .py source files; 16 chars)"]

# ---------------------------------------------------------------------------
# struct.__loader__.__class__.__module__.__eq__('_frozen_importlib_external')
# struct.__loader__.__class__.__qualname__.__eq__('SourceFileLoader')
# struct.__loader__.__class__.__name__.__len__() == 16
# struct.__loader__.__class__.__module__.__len__() == 26
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec')
#
# Wave 275 theme: struct.__loader__ class module and qualname identity.
#
# struct.__loader__ is a SourceFileLoader from _frozen_importlib_external.
# '_frozen_importlib_external' is CPython's frozen external bootstrap module
# (handles file-based loading: source files, bytecode, etc.). The class qualname
# 'SourceFileLoader' matches the class name (top-level class). The module name
# '_frozen_importlib_external' is 26 chars — the longest module name in this spec.
# No prior struct spec anchors __loader__.__class__.__module__ as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra111.loader_class_module_and_qualname:
  description: "__loader__.__class__.__module__.__eq__('_frozen_importlib_external')==True / __loader__.__class__.__qualname__.__eq__('SourceFileLoader')==True / __loader__.__class__.__name__.__len__()==16 / __loader__.__class__.__module__.__len__()==26 / __spec__.__class__.__name__.__eq__('ModuleSpec')==True — loader class module is '_frozen_importlib_external' (handles file-based loading; 26 chars; longest in spec); loader qualname=='SourceFileLoader' (top-level class; no class prefix); loader name is 16 chars; extra105 anchors __spec__ class name; first structspec111 anchor for loader module/qualname"
  kind: python_call_eq
  category: module_identity
  id_prefix: structspec111

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_module_eq,   "__loader__.__class__.__module__.__eq__",   ["_frozen_importlib_external"], true, "__loader__.__class__.__module__ is '_frozen_importlib_external' (CPython frozen external bootstrap; handles .py/.pyc loading; 26 chars)"]
    - [loader_class_qualname_eq, "__loader__.__class__.__qualname__.__eq__", ["SourceFileLoader"],           true, "__loader__.__class__.__qualname__ is 'SourceFileLoader' (same as __name__; top-level class; no enclosing scope)"]
    - [loader_class_name_len,    "__loader__.__class__.__name__.__len__",    [],                            16,   "__loader__.__class__.__name__.__len__() is 16 (len('SourceFileLoader')==16)"]
    - [loader_class_module_len,  "__loader__.__class__.__module__.__len__",  [],                            26,   "__loader__.__class__.__module__.__len__() is 26 (len('_frozen_importlib_external')==26; longest in this spec)"]
    - [spec_class_name_eq,       "__spec__.__class__.__name__.__eq__",       ["ModuleSpec"],                true, "__spec__.__class__.__name__ is 'ModuleSpec' (10 chars; extra105 anchors this; repeated here as cross-check)"]

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__module__.__len__() == 17
# struct.__loader__.__class__.__module__.__len__() == 26
# struct.__spec__.__class__.__name__.__len__() == 10
# struct.__loader__.__class__.__name__.__len__() == 16
# struct.__loader__.__class__.__qualname__.__eq__('SourceFileLoader')
#
# Wave 275 theme: spec and loader class name/module length comparison.
#
# ModuleSpec class name is 10 chars; SourceFileLoader class name is 16 chars.
# _frozen_importlib module is 17 chars; _frozen_importlib_external is 26 chars.
# These length relationships summarize the CPython import machinery name patterns:
# the external loader module name is 9 chars longer than the base bootstrap module
# (adding '_external' suffix). The loader class name is 6 chars longer than the
# spec class name. No prior struct spec anchors these length comparisons as a group.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra111.spec_and_loader_class_name_length_comparison:
  description: "__spec__.__class__.__module__.__len__()==17 / __loader__.__class__.__module__.__len__()==26 / __spec__.__class__.__name__.__len__()==10 / __loader__.__class__.__name__.__len__()==16 / __loader__.__class__.__qualname__.__eq__('SourceFileLoader')==True — _frozen_importlib is 17 chars; _frozen_importlib_external is 26 chars (9 more, adding '_external'); ModuleSpec is 10 chars; SourceFileLoader is 16 chars (6 more); loader qualname matches class name; no prior spec anchors these lengths; first structspec111 anchor for length comparison"
  kind: python_call_eq
  category: module_identity
  id_prefix: structspec111

  columns: [id, function, args, expected, description]
  rows:
    - [spec_module_len_17,       "__spec__.__class__.__module__.__len__",    [], 17, "__spec__.__class__.__module__.__len__() is 17 ('_frozen_importlib': 17 chars)"]
    - [loader_module_len_26,     "__loader__.__class__.__module__.__len__",  [], 26, "__loader__.__class__.__module__.__len__() is 26 ('_frozen_importlib_external': 26 chars; 9 more than _frozen_importlib)"]
    - [spec_name_len_10,         "__spec__.__class__.__name__.__len__",      [], 10, "__spec__.__class__.__name__.__len__() is 10 ('ModuleSpec': 10 chars)"]
    - [loader_name_len_16,       "__loader__.__class__.__name__.__len__",    [], 16, "__loader__.__class__.__name__.__len__() is 16 ('SourceFileLoader': 16 chars; 6 more than 'ModuleSpec')"]
    - [loader_qualname_eq,       "__loader__.__class__.__qualname__.__eq__", ["SourceFileLoader"], true, "__loader__.__class__.__qualname__ is 'SourceFileLoader' (same as __name__; top-level class in _frozen_importlib_external)"]

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__module__.__eq__('_frozen_importlib') — standalone
#
# struct.__spec__.__class__.__module__ is '_frozen_importlib'. The ModuleSpec
# class is defined in importlib._bootstrap, which is compiled into CPython as
# a frozen module (embedded in the interpreter at startup) named '_frozen_importlib'.
# The 'frozen' status means it is loaded before the file system is accessible.
# struct_extra105 anchors __spec__.__class__.__name__=='ModuleSpec'; no prior
# struct spec anchors the __spec__ class module equality as a standalone under
# structspec111. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra111.spec_class_module_frozen_importlib:
  description: "struct.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True — ModuleSpec class is from '_frozen_importlib' (17 chars; CPython frozen bootstrap; compiled into interpreter at startup; same module regardless of Python version); extra105 anchors __spec__ class name; first standalone for __spec__ class module under structspec111"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__module__.__eq__"
  args: ["_frozen_importlib"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# struct.__loader__.__class__.__name__ is 'SourceFileLoader'. The SourceFileLoader
# class handles loading Python source files (.py). Despite struct having a C
# extension implementation (_struct.c), the public 'struct' module on CPython
# 3.14.3 macOS is a Python source file (struct.py) that imports from _struct.
# The loader identifies the module type: SourceFileLoader for .py files,
# ExtensionFileLoader for .so/.pyd files. No prior struct spec anchors
# __loader__.__class__.__name__ as a standalone under structspec111.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra111.loader_class_name_source_file_loader:
  description: "struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — loader is SourceFileLoader (16 chars; loads .py source files); struct on macOS 3.14.3 is a Python source file (struct.py wrapping _struct C extension); contrasts with ExtensionFileLoader for .so files; no prior struct spec anchors loader class name as standalone; first standalone under structspec111"
  category: module_identity
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__eq__"
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__loader__.__class__.__module__.__eq__('_frozen_importlib_external') — standalone
#
# struct.__loader__.__class__.__module__ is '_frozen_importlib_external' (26 chars).
# SourceFileLoader is defined in importlib._bootstrap_external, which is compiled
# into CPython as a frozen module named '_frozen_importlib_external'. The
# '_external' suffix distinguishes it from '_frozen_importlib' (which handles
# the core bootstrap) — the external module handles file-system-based loading
# (source files, bytecode files, namespace packages). No prior struct spec anchors
# __loader__.__class__.__module__ as a standalone under structspec111.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra111.loader_class_module_frozen_external:
  description: "struct.__loader__.__class__.__module__.__eq__('_frozen_importlib_external') == True — SourceFileLoader class is from '_frozen_importlib_external' (26 chars; CPython frozen external bootstrap; handles .py/.pyc file loading; '_external' suffix distinguishes from core bootstrap '_frozen_importlib'=17 chars); no prior struct spec anchors loader class module as standalone; first standalone under structspec111"
  category: module_identity
  kind: python_call_eq
  function: "__loader__.__class__.__module__.__eq__"
  args: ["_frozen_importlib_external"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__name__.__len__() == 10 — standalone
#
# struct.__spec__.__class__.__name__.__len__() is 10. 'ModuleSpec' has 10 chars:
# 'M','o','d','u','l','e','S','p','e','c'. The ModuleSpec class represents the
# import specification for a module (PEP 451), containing all information needed
# to load a module: name, loader, origin, submodule_search_locations, etc.
# struct_extra105 anchors __spec__.__class__.__name__=='ModuleSpec' in a table
# but not the __len__() as a standalone. No prior struct spec anchors
# __spec__.__class__.__name__.__len__() as a standalone under structspec111.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra111.spec_class_name_len_10:
  description: "struct.__spec__.__class__.__name__.__len__() == 10 — len('ModuleSpec')==10 (PEP 451 module specification class; contains name/loader/origin/has_location); extra105 anchors __spec__ class name equality; no prior spec anchors ModuleSpec name length as standalone; first standalone under structspec111"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# struct.__loader__.__class__.__name__.__len__() == 16 — standalone
#
# struct.__loader__.__class__.__name__.__len__() is 16. 'SourceFileLoader' has
# 16 chars: 'Source'(6) + 'File'(4) + 'Loader'(6) = 16. The SourceFileLoader
# is the most commonly encountered loader for Python source files. It is 6 chars
# longer than 'ModuleSpec' (10 chars). The corresponding ExtensionFileLoader
# for C extensions also has 19 chars. struct_extra111.spec_class_name_len_10
# anchors the ModuleSpec name length; no prior struct spec anchors SourceFileLoader
# name length as a standalone under structspec111.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra111.loader_class_name_len_16:
  description: "struct.__loader__.__class__.__name__.__len__() == 16 — len('SourceFileLoader')==16 ('Source'=6+'File'=4+'Loader'=6=16); 6 chars longer than 'ModuleSpec' (10); loads .py source files; most common Python loader; no prior struct spec anchors SourceFileLoader name length as standalone; first standalone under structspec111"
  category: module_identity
  kind: python_call_eq
  function: "__loader__.__class__.__name__.__len__"
  args: []
  expected: 16
