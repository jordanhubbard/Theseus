spec: sk2956
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket: Low-level networking interface"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 644 (sk2956): __invert__, __round__, __trunc__ dict-presence checks for socket types."
    - "socket.AddressInfo and socket.MsgFlag are IntFlag subclasses that define __invert__ in their own __dict__ (bitwise complement is valid for flags); socket.AddressFamily and socket.SocketKind do not."
    - "socket.socket is a networking file descriptor wrapper; socket.error, socket.herror, socket.gaierror, and socket.timeout are exception classes — none are numeric types."
    - "No socket type defines __round__ or __trunc__ in its own __dict__."
    - "Verified types: socket.socket, socket.AddressFamily, socket.SocketKind, socket.AddressInfo, socket.MsgFlag, socket.error, socket.herror, socket.gaierror, socket.timeout."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk2956.invert:
  description: "socket types __invert__ dict-presence checks; wave 644"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2956
  columns: [id, function, args, expected]
  rows:
    - ["sk2956001", operator.contains, [socket.socket.__dict__,        "__invert__"], false]
    - ["sk2956002", operator.contains, [socket.AddressFamily.__dict__, "__invert__"], false]
    - ["sk2956003", operator.contains, [socket.SocketKind.__dict__,    "__invert__"], false]
    - ["sk2956004", operator.contains, [socket.AddressInfo.__dict__,   "__invert__"], true]
    - ["sk2956005", operator.contains, [socket.MsgFlag.__dict__,       "__invert__"], true]
    - ["sk2956006", operator.contains, [socket.error.__dict__,         "__invert__"], false]
    - ["sk2956007", operator.contains, [socket.herror.__dict__,        "__invert__"], false]
    - ["sk2956008", operator.contains, [socket.gaierror.__dict__,      "__invert__"], false]

