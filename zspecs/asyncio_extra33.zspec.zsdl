spec: asyncio_extra33
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "https://docs.python.org/3/library/asyncio-timeouts.html — asyncio Timeouts (3.11+)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/timeouts.py"
    - "CPython source: Lib/asyncio/taskgroups.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra32.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__() (C extension), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__() == 95, class __dict__.__class__.__name__.__len__() for Event/Semaphore/Condition/AbstractEventLoop/BaseEventLoop/Task/Lock/Queue/PriorityQueue/LifoQueue/QueueEmpty/QueueFull/BoundedSemaphore, Event/Semaphore/Condition method __qualname__.__len__(), create_task/run_coroutine_threadsafe __qualname__.__len__(), Queue/__mro__.__len__() == 3, BoundedSemaphore/__mro__.__len__() == 5, Queue method __qualname__.__len__() for put/get/put_nowait/get_nowait/empty/full/qsize."
    - "This spec covers: wait_for/__name__.__len__()==8, wait_for/__qualname__.__len__()==8, wait_for/__module__.__len__()==13; shield/__name__.__len__()==6, shield/__qualname__.__len__()==6, shield/__module__.__len__()==13; timeout/__name__.__len__()==7, timeout/__qualname__.__len__()==7, timeout/__module__.__len__()==16 ('asyncio.timeouts'); TaskGroup/__name__.__len__()==9, TaskGroup/__qualname__.__len__()==9, TaskGroup/__module__.__len__()==18 ('asyncio.taskgroups'), TaskGroup/__mro__.__len__()==2; Task/__mro__.__len__()==3, Future/__mro__.__len__()==2; Task/__bases__[0].__name__.__len__()==6 ('Future'), Future/__bases__[0].__name__.__len__()==6 ('object')."
    - "wait_for, shield and sleep all live in asyncio.tasks — __module__ == 'asyncio.tasks' (13 chars)."
    - "timeout lives in asyncio.timeouts — __module__ == 'asyncio.timeouts' (16 chars), longer than asyncio.tasks."
    - "TaskGroup is defined in asyncio.taskgroups — __module__ == 'asyncio.taskgroups' (18 chars), the longest submodule path in this spec."
    - "TaskGroup.__mro__.__len__() == 2 — direct object subclass, no intermediate base."
    - "asyncio.Task extends asyncio.Future: Task.__mro__ == (Task, Future, object), length 3."
    - "asyncio.Future has flat hierarchy: Future.__mro__ == (Future, object), length 2."
    - "Task.__bases__[0].__name__ == 'Future' (6 chars); Future.__bases__[0].__name__ == 'object' (6 chars) — both base name lengths are the same despite different base classes."
    - "timeout.__name__ == 'timeout' (7 chars) — the class name matches the public API function name used as a context manager."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio task coroutine helper __name__ and __qualname__ lengths — extra33
#
# wait_for, shield and sleep are coroutine helpers defined in asyncio.tasks.
# Their __name__ and __qualname__ strings are identical (no class prefix):
#   wait_for: 'wait_for' (8 chars)
#   shield:   'shield'   (6 chars)
#   sleep:    'sleep'    (5 chars) — covered in prior spec but included for
#             contrast with the __module__ angle below
# All three share __module__ == 'asyncio.tasks' (13 chars).
# No prior spec has measured __name__.__len__() or __module__.__len__() for
# wait_for or shield.
# ---------------------------------------------------------------------------

table asyncio_extra33.coroutine_helper_name_lengths:
  description: "asyncio coroutine helper __name__.__len__() for wait_for/shield in extra33 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: corohelpname33

  columns: [id, function, args, expected]
  rows:
    - [wait_for, wait_for.__name__.__len__, [], 8]
    - [shield,   shield.__name__.__len__,   [], 6]

table asyncio_extra33.coroutine_helper_module_lengths:
  description: "asyncio coroutine helper __module__.__len__() for wait_for/shield/sleep — all 'asyncio.tasks' (13) in extra33 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: corohelpmodlen33

  columns: [id, function, args, expected]
  rows:
    - [wait_for, wait_for.__module__.__len__, [], 13]
    - [shield,   shield.__module__.__len__,   [], 13]
    - [sleep,    sleep.__module__.__len__,     [], 13]

# ---------------------------------------------------------------------------
# asyncio.timeout class identity — extra33 namespace
#
# asyncio.timeout (added in Python 3.11) is a class used as a context
# manager. Its canonical attributes:
#   timeout.__name__.__len__()     == 7 ('timeout')
#   timeout.__qualname__.__len__() == 7 ('timeout')
#   timeout.__module__.__len__()   == 16 ('asyncio.timeouts')
# The submodule name 'asyncio.timeouts' (16 chars) is distinct from the
# coroutine helpers which live in 'asyncio.tasks' (13 chars).
# No prior asyncio spec has measured the timeout class name or module lengths.
# ---------------------------------------------------------------------------

table asyncio_extra33.timeout_class_identity:
  description: "asyncio.timeout class __name__, __qualname__, and __module__ lengths in extra33 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: timeoutident33

  columns: [id, function, args, expected]
  rows:
    - [name_len,     timeout.__name__.__len__,     [], 7]
    - [qualname_len, timeout.__qualname__.__len__,  [], 7]
    - [module_len,   timeout.__module__.__len__,    [], 16]

# ---------------------------------------------------------------------------
# asyncio.TaskGroup class identity — extra33 namespace
#
# asyncio.TaskGroup (added in Python 3.11) provides structured concurrency.
# Its class attributes:
#   TaskGroup.__name__.__len__()     == 9 ('TaskGroup')
#   TaskGroup.__qualname__.__len__() == 9 ('TaskGroup')
#   TaskGroup.__module__.__len__()   == 18 ('asyncio.taskgroups')
#   TaskGroup.__mro__.__len__()      == 2 — direct subclass of object
# The submodule 'asyncio.taskgroups' (18 chars) is the longest submodule path
# encountered in asyncio specs. No prior spec measured TaskGroup name or
# module lengths (the __module__.__len__() for TaskGroup appeared only
# as a narrative note in extra31; it was not a table row or invariant).
# ---------------------------------------------------------------------------

table asyncio_extra33.taskgroup_class_identity:
  description: "asyncio.TaskGroup class identity lengths in extra33 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: taskgroupident33

  columns: [id, function, args, expected]
  rows:
    - [name_len,     TaskGroup.__name__.__len__,     [], 9]
    - [qualname_len, TaskGroup.__qualname__.__len__,  [], 9]
    - [module_len,   TaskGroup.__module__.__len__,    [], 18]

# ---------------------------------------------------------------------------
# asyncio Task and Future MRO depths — extra33 namespace
#
# asyncio.Task and asyncio.Future are C-extension types (_asyncio module):
#   Task.__mro__.__len__()   == 3 — [Task, Future, object] — Task subclasses Future
#   Future.__mro__.__len__() == 2 — [Future, object] — flat C-extension hierarchy
# Task.__bases__[0].__name__ == 'Future' (6 chars) — confirms Task directly extends Future.
# Future.__bases__[0].__name__ == 'object' (6 chars) — confirms Future is a root class.
# Both base class names happen to have the same length (6) despite being different classes.
# No prior spec has measured __mro__.__len__() for Task or Future in an explicit table.
# ---------------------------------------------------------------------------

table asyncio_extra33.task_future_mro_lengths:
  description: "asyncio Task and Future __mro__.__len__() and __bases__[0].__name__.__len__() in extra33 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: taskfutmrolen33

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [Task_mro,   Task.__mro__,   [], !ascii "", __len__, [], "Task.__mro__.__len__() == 3 — (Task, Future, object)"]
    - [Future_mro, Future.__mro__, [], !ascii "", __len__, [], "Future.__mro__.__len__() == 2 — (Future, object)"]

table asyncio_extra33.task_future_base_name_lengths:
  description: "asyncio Task and Future __bases__[0].__name__.__len__() in extra33 namespace — both equal 6"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: taskfutbaselen33

  columns: [id, function, args, expected]
  rows:
    - [Task,   "Task.__bases__[0].__name__.__len__",   [], 6]
    - [Future, "Future.__bases__[0].__name__.__len__", [], 6]

# ---------------------------------------------------------------------------
# asyncio.TaskGroup MRO depth standalone invariant — extra33
# ---------------------------------------------------------------------------

invariant asyncio_extra33.TaskGroup_mro_len:
  description: "asyncio.TaskGroup.__mro__.__len__() == 2 — TaskGroup is a direct subclass of object"
  category: class_hierarchy
  kind: python_call_eq
  function: TaskGroup.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra33.timeout_module_len:
  description: "asyncio.timeout.__module__.__len__() == 16 — 'asyncio.timeouts' is 16 characters, longer than 'asyncio.tasks'"
  category: function_names
  kind: python_call_eq
  function: timeout.__module__.__len__
  args: []
  expected: 16

invariant asyncio_extra33.Task_extends_Future:
  description: "asyncio.Task.__bases__[0].__name__.__len__() == 6 — Task's direct base is Future (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "Task.__bases__[0].__name__.__len__"
  args: []
  expected: 6
