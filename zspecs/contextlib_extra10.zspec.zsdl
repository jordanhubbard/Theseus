spec: contextlib_extra10
version: ">=3.10"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra9.zspec.zsdl and contextlib_suppress.zspec.zsdl."
    - "contextlib_extra9 covers: ExitStack/__bases__.__len__ == 2; ExitStack/__bases__[1].__name__ == 'AbstractContextManager'; nullcontext/__bases__.__len__ == 2; nullcontext/__bases__[1].__name__ == 'AbstractAsyncContextManager'; abstractmethods.__len__ for AbstractContextManager/AbstractAsyncContextManager/ExitStack."
    - "NOT yet covered: MRO length for suppress, closing, ExitStack, AsyncExitStack, nullcontext, redirect_stdout."
    - "NOT yet covered: AsyncExitStack/__abstractmethods__.__len__ == 0; suppress/__abstractmethods__.__len__ == 0; closing/__abstractmethods__.__len__ == 0."
    - "NOT yet covered: aclosing/__name__/__module__/__qualname__/__bases__; aclosing is an async context manager for generators."
    - "NOT yet covered: AsyncContextDecorator/__name__/__module__/__bases__/__bases__.__len__; ContextDecorator/__mro__/__len__."
    - "contextlib.suppress.__mro__.__len__() == 4 — [suppress, AbstractContextManager, ABC, object]."
    - "contextlib.closing.__mro__.__len__() == 4 — [closing, AbstractContextManager, ABC, object]."
    - "contextlib.ExitStack.__mro__.__len__() == 5 — [ExitStack, _BaseExitStack, AbstractContextManager, ABC, object]."
    - "contextlib.AsyncExitStack.__mro__.__len__() == 5 — [AsyncExitStack, _BaseExitStack, AbstractAsyncContextManager, ABC, object]."
    - "contextlib.AsyncExitStack.__abstractmethods__.__len__() == 0 — fully concrete class."
    - "contextlib.aclosing.__name__ == 'aclosing' (Python 3.10+)."
    - "contextlib.aclosing.__module__ == 'contextlib' (Python 3.10+)."
    - "contextlib.aclosing.__qualname__ == 'aclosing' (Python 3.10+)."
    - "contextlib.aclosing.__bases__[0].__name__ == 'AbstractAsyncContextManager' (Python 3.10+)."
    - "contextlib.AsyncContextDecorator.__name__ == 'AsyncContextDecorator' (Python 3.10+)."
    - "contextlib.AsyncContextDecorator.__bases__[0].__name__ == 'object' (Python 3.10+)."
    - "contextlib.ContextDecorator.__mro__.__len__() == 2 — [ContextDecorator, object]."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO length checks for core contextlib classes
#
# contextlib_extra7/extra8/extra9 verified __bases__ and __bases__.__len__
# for most classes but no spec has tested the __mro__ length for these classes.
# suppress, closing: [cls, AbstractContextManager, ABC, object] = length 4
# ---------------------------------------------------------------------------

invariant contextlib_extra10.suppress.mro_len:
  description: "contextlib.suppress.__mro__.__len__() == 4 — [suppress, AbstractContextManager, ABC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: suppress.__mro__.__len__
  args: []
  expected: 4

invariant contextlib_extra10.closing.mro_len:
  description: "contextlib.closing.__mro__.__len__() == 4 — [closing, AbstractContextManager, ABC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: closing.__mro__.__len__
  args: []
  expected: 4

invariant contextlib_extra10.ExitStack.mro_len:
  description: "contextlib.ExitStack.__mro__.__len__() == 5 — [ExitStack, _BaseExitStack, AbstractContextManager, ABC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: ExitStack.__mro__.__len__
  args: []
  expected: 5

invariant contextlib_extra10.AsyncExitStack.mro_len:
  description: "contextlib.AsyncExitStack.__mro__.__len__() == 5 — [AsyncExitStack, _BaseExitStack, AbstractAsyncContextManager, ABC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: AsyncExitStack.__mro__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# AsyncExitStack.__abstractmethods__ is empty (fully concrete)
#
# contextlib_extra9 verified ExitStack.__abstractmethods__.__len__() == 0.
# Not yet verified: AsyncExitStack.__abstractmethods__.__len__() == 0.
# ---------------------------------------------------------------------------

invariant contextlib_extra10.AsyncExitStack.abstractmethods_len:
  description: "contextlib.AsyncExitStack.__abstractmethods__ is empty — AsyncExitStack is fully concrete"
  category: abstract_methods
  kind: python_call_eq
  function: AsyncExitStack.__abstractmethods__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# aclosing — name, module, qualname, and base class (Python 3.10+)
#
# contextlib.aclosing is an async context manager for async generators, added
# in Python 3.10. contextlib_extra3 covered aclosing.__qualname__ but no prior
# spec covers aclosing.__module__, aclosing.__name__, or aclosing.__bases__.
# ---------------------------------------------------------------------------

invariant contextlib_extra10.aclosing.name:
  description: "contextlib.aclosing.__name__ == 'aclosing' (Python 3.10+)"
  category: aclosing
  kind: python_call_eq
  function: aclosing.__name__.__eq__
  args: ["aclosing"]
  expected: true

invariant contextlib_extra10.aclosing.module:
  description: "contextlib.aclosing.__module__ == 'contextlib' (Python 3.10+)"
  category: aclosing
  kind: python_call_eq
  function: aclosing.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra10.aclosing.base_name:
  description: "contextlib.aclosing.__bases__[0].__name__ == 'AbstractAsyncContextManager' (Python 3.10+)"
  category: aclosing
  kind: python_call_eq
  function: aclosing.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "AbstractAsyncContextManager"

# ---------------------------------------------------------------------------
# AsyncContextDecorator — name, module, and base class (Python 3.10+)
#
# contextlib_extra3 covered AsyncContextDecorator.__qualname__. No prior spec
# covers AsyncContextDecorator.__name__, __module__, or __bases__. It is a
# simple mixin class (no ABC) whose sole base is object.
# ---------------------------------------------------------------------------

invariant contextlib_extra10.AsyncContextDecorator.name:
  description: "contextlib.AsyncContextDecorator.__name__ == 'AsyncContextDecorator' (Python 3.10+)"
  category: AsyncContextDecorator
  kind: python_call_eq
  function: AsyncContextDecorator.__name__.__eq__
  args: ["AsyncContextDecorator"]
  expected: true

invariant contextlib_extra10.AsyncContextDecorator.module:
  description: "contextlib.AsyncContextDecorator.__module__ == 'contextlib' (Python 3.10+)"
  category: AsyncContextDecorator
  kind: python_call_eq
  function: AsyncContextDecorator.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra10.AsyncContextDecorator.base_name:
  description: "contextlib.AsyncContextDecorator.__bases__[0].__name__ == 'object' — simple mixin with no ABC base (Python 3.10+)"
  category: AsyncContextDecorator
  kind: python_call_eq
  function: AsyncContextDecorator.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# ContextDecorator.__mro__ length
#
# contextlib_extra8 covers ContextDecorator.__bases__[0].__name__ == 'object'.
# contextlib_extra7 covers ContextDecorator.__name__/__qualname__/__module__.
# Not yet verified: ContextDecorator.__mro__.__len__() == 2.
# ---------------------------------------------------------------------------

invariant contextlib_extra10.ContextDecorator.mro_len:
  description: "contextlib.ContextDecorator.__mro__.__len__() == 2 — [ContextDecorator, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: ContextDecorator.__mro__.__len__
  args: []
  expected: 2
