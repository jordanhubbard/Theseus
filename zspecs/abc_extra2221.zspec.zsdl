  columns: [id, function, args, expected]
  rows:
    - ["ab2221019", "abc.ABCMeta.__dict__.__contains__", ["__name__"], false]
    - ["ab2221020", "abc.ABC.__dict__.__contains__", ["__name__"], false]
    - ["ab2221021", "abc.abstractmethod.__dict__.__contains__", ["__name__"], false]

# ---------------------------------------------------------------------------
# Table 8: Cross-check — ABCMeta defines metaclass protocol, not display protocol
#
# ABCMeta DOES define __instancecheck__ and __subclasscheck__ in its __dict__
# (the metaclass hook methods). It does NOT define display protocol methods
# (__repr__, __str__, __hash__). This table cross-checks known-present keys
# alongside known-absent display-protocol keys, confirming the separation.
# ---------------------------------------------------------------------------

table abc_extra2221.abcmeta_protocol_cross_check:
  description: "abc.ABCMeta: __instancecheck__/__subclasscheck__ True; __repr__/__str__/__hash__ False — metaclass vs display protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2221

  columns: [id, function, args, expected]
  rows:
    - ["ab2221022", "abc.ABCMeta.__dict__.__contains__", ["__instancecheck__"], true]
    - ["ab2221023", "abc.ABCMeta.__dict__.__contains__", ["__subclasscheck__"], true]
    - ["ab2221024", "abc.ABCMeta.__dict__.__contains__", ["__repr__"], false]
    - ["ab2221025", "abc.ABCMeta.__dict__.__contains__", ["__str__"], false]
    - ["ab2221026", "abc.ABCMeta.__dict__.__contains__", ["__hash__"], false]
    - ["ab2221027", "abc.ABC.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["ab2221028", "abc.ABC.__dict__.__contains__", ["__slots__"], true]
