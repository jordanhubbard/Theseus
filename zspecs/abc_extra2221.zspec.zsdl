spec: abc_extra2221
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c — C accelerator for ABCMeta"
    - "abc_extra2056.zspec.zsdl — covers __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__, __contains__, __iter__/__next__/__reversed__ dict-presence for ABCMeta/ABC/abstractmethod"
  notes:
    - "Wave 2221 (_extra2221): identity/display protocol dict-presence — __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__ checks for abc.ABCMeta, abc.ABC, abc.abstractmethod."
    - "abc.ABCMeta is a metaclass (type subclass); its __module__ == 'abc'."
    - "abc.ABC is a helper base class; its __module__ == 'abc'."
    - "abc.abstractmethod is a plain Python function (class function decorator); it is NOT a class. Its __doc__, __module__, __qualname__ are function attributes stored as slots, NOT in __dict__. abstractmethod.__dict__ is empty."
    - "__hash__ is NOT in __dict__ for any of the 3 — ABCMeta/ABC do not suppress or define __hash__; abstractmethod is a function with an empty __dict__."
    - "__repr__ is NOT in __dict__ for any of the 3 — ABCMeta does not define a custom __repr__; ABC does not define one; abstractmethod is a function with empty __dict__."
    - "__str__ is NOT in __dict__ for any of the 3."
    - "__doc__ IS in __dict__ for ABCMeta (True) and ABC (True). For abstractmethod (False) — abstractmethod is a function; __doc__ is stored as a function slot attribute, not in __dict__."
    - "__module__ IS in __dict__ for ABCMeta (True) and ABC (True). For abstractmethod (False) — same reason as __doc__: function slot, not __dict__."
    - "__qualname__ is NOT in __dict__ for any of the 3."
    - "__name__ is NOT in __dict__ for any of the 3."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __hash__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __hash__ is NOT in the __dict__ of any abc construct. ABCMeta and ABC do
# not explicitly define or suppress __hash__ in their class body.
# abstractmethod is a function; its __dict__ is empty. All 3 return False.
# ---------------------------------------------------------------------------

table abc_extra2221.hash_dict_presence:
  description: "__hash__ dict-presence for abc.ABCMeta/ABC/abstractmethod — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2221

  columns: [id, function, args, expected]
  rows:
    - ["ab2221001", "abc.ABCMeta.__dict__.__contains__", ["__hash__"], false]
    - ["ab2221002", "abc.ABC.__dict__.__contains__", ["__hash__"], false]
    - ["ab2221003", "abc.abstractmethod.__dict__.__contains__", ["__hash__"], false]

# ---------------------------------------------------------------------------
# Table 2: __repr__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __repr__ is NOT in the __dict__ of any abc construct. ABCMeta does not
# define a custom __repr__ (it inherits from type). ABC does not define one.
# abstractmethod is a function with an empty __dict__. All 3 return False.
# ---------------------------------------------------------------------------

table abc_extra2221.repr_dict_presence:
  description: "__repr__ dict-presence for abc.ABCMeta/ABC/abstractmethod — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2221

  columns: [id, function, args, expected]
  rows:
    - ["ab2221004", "abc.ABCMeta.__dict__.__contains__", ["__repr__"], false]
    - ["ab2221005", "abc.ABC.__dict__.__contains__", ["__repr__"], false]
    - ["ab2221006", "abc.abstractmethod.__dict__.__contains__", ["__repr__"], false]

# ---------------------------------------------------------------------------
# Table 3: __str__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __str__ is NOT in the __dict__ of any abc construct. None of ABCMeta, ABC,
# or abstractmethod define a custom __str__ in their own namespace.
# All 3 return False.
# ---------------------------------------------------------------------------

table abc_extra2221.str_dict_presence:
  description: "__str__ dict-presence for abc.ABCMeta/ABC/abstractmethod — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2221

  columns: [id, function, args, expected]
  rows:
    - ["ab2221007", "abc.ABCMeta.__dict__.__contains__", ["__str__"], false]
    - ["ab2221008", "abc.ABC.__dict__.__contains__", ["__str__"], false]
    - ["ab2221009", "abc.abstractmethod.__dict__.__contains__", ["__str__"], false]

# ---------------------------------------------------------------------------
# Table 4: __doc__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __doc__ IS in the __dict__ of ABCMeta and ABC — both are classes with
# docstrings stored in their class __dict__. For abstractmethod (a function),
# __doc__ is a function slot attribute, NOT a key in __dict__; abstractmethod.
# __dict__ is empty, so '__doc__' in abstractmethod.__dict__ == False.
# ABCMeta=True, ABC=True, abstractmethod=False.
# ---------------------------------------------------------------------------

table abc_extra2221.doc_dict_presence:
  description: "__doc__ dict-presence for abc.ABCMeta/ABC/abstractmethod — ABCMeta and ABC True, abstractmethod False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2221

  columns: [id, function, args, expected]
  rows:
    - ["ab2221010", "abc.ABCMeta.__dict__.__contains__", ["__doc__"], true]
    - ["ab2221011", "abc.ABC.__dict__.__contains__", ["__doc__"], true]
    - ["ab2221012", "abc.abstractmethod.__dict__.__contains__", ["__doc__"], false]

# ---------------------------------------------------------------------------
# Table 5: __module__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __module__ IS in the __dict__ of ABCMeta and ABC — both classes store
# __module__ == 'abc' in their class __dict__. For abstractmethod (a
# function), __module__ is a function slot attribute stored outside __dict__;
# abstractmethod.__dict__ is empty, so '__module__' in abstractmethod.__dict__
# == False. ABCMeta=True, ABC=True, abstractmethod=False.
# ---------------------------------------------------------------------------

table abc_extra2221.module_dict_presence:
  description: "__module__ dict-presence for abc.ABCMeta/ABC/abstractmethod — ABCMeta and ABC True, abstractmethod False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2221

  columns: [id, function, args, expected]
  rows:
    - ["ab2221013", "abc.ABCMeta.__dict__.__contains__", ["__module__"], true]
    - ["ab2221014", "abc.ABC.__dict__.__contains__", ["__module__"], true]
    - ["ab2221015", "abc.abstractmethod.__dict__.__contains__", ["__module__"], false]

# ---------------------------------------------------------------------------
# Table 6: __qualname__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __qualname__ is NOT in the __dict__ of any abc construct. For ABCMeta and
