    - ["ab2221017", "abc.ABC.__dict__.__contains__", ["__qualname__"], false]
    - ["ab2221018", "abc.abstractmethod.__dict__.__contains__", ["__qualname__"], false]

# ---------------------------------------------------------------------------
# Table 7: __name__ dict-presence — ABCMeta, ABC, abstractmethod
#
# __name__ is NOT in the __dict__ of any abc construct. For ABCMeta and ABC,
# __name__ is exposed via type machinery but not stored in class __dict__.
# For abstractmethod (a function), __name__ is a function slot, not in
# __dict__. All 3 return False.
# ---------------------------------------------------------------------------

table abc_extra2221.name_dict_presence:
  description: "__name__ dict-presence for abc.ABCMeta/ABC/abstractmethod — all False"
