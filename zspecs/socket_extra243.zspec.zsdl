spec: socket_extra243
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl, socket_extra.zspec.zsdl, socket_extra2.zspec.zsdl, and _socket_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket.socket instance methods have __qualname__ of the form 'socket.<method>' (not 'SocketType.<method>')."
    - "The qualname prefix is 'socket' (the class __name__ is 'socket'), not 'SocketType' or 'socket.socket'."
    - "socket.socket.connect.__qualname__ == 'socket.connect' — verified on Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__ == 'socket.bind', socket.socket.listen.__qualname__ == 'socket.listen'."
    - "socket.socket.accept.__qualname__ == 'socket.accept', socket.socket.close.__qualname__ == 'socket.close'."
    - "socket.socket.recv.__qualname__ == 'socket.recv', socket.socket.send.__qualname__ == 'socket.send'."
    - "socket.socket.sendall.__qualname__ == 'socket.sendall', socket.socket.settimeout.__qualname__ == 'socket.settimeout'."
    - "socket.socket.gettimeout.__qualname__ == 'socket.gettimeout', socket.socket.fileno.__qualname__ == 'socket.fileno'."
    - "socket.socket.shutdown.__qualname__ == 'socket.shutdown', socket.socket.setblocking.__qualname__ == 'socket.setblocking'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "socket raises OSError (and subclasses) for I/O failures. __qualname__ attribute accesses are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are class-level attribute accesses."
  codes: {}

# ---------------------------------------------------------------------------
# socket.socket instance method __qualname__ — primary 7 methods
# All qualnames use the 'socket.<method>' pattern (not 'SocketType.<method>')
# ---------------------------------------------------------------------------

table socksockq243.method_qualnames.primary:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: socksockq243

  columns: [id, function, args, expected]
  rows:
    - [connect_qualname,  socket.connect.__qualname__.__eq__,  ["socket.connect"],  true]
    - [bind_qualname,     socket.bind.__qualname__.__eq__,     ["socket.bind"],     true]
    - [listen_qualname,   socket.listen.__qualname__.__eq__,   ["socket.listen"],   true]
    - [accept_qualname,   socket.accept.__qualname__.__eq__,   ["socket.accept"],   true]
    - [close_qualname,    socket.close.__qualname__.__eq__,    ["socket.close"],    true]
    - [recv_qualname,     socket.recv.__qualname__.__eq__,     ["socket.recv"],     true]
    - [send_qualname,     socket.send.__qualname__.__eq__,     ["socket.send"],     true]

# ---------------------------------------------------------------------------
# socket.socket instance method __qualname__ — additional methods
# sendall, settimeout, gettimeout, fileno, shutdown, setblocking
# ---------------------------------------------------------------------------

table socksockq243.method_qualnames.extended:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: socksockq243

  columns: [id, function, args, expected]
  rows:
    - [sendall_qualname,    socket.sendall.__qualname__.__eq__,    ["socket.sendall"],    true]
    - [settimeout_qualname, socket.settimeout.__qualname__.__eq__, ["socket.settimeout"], true]
    - [gettimeout_qualname, socket.gettimeout.__qualname__.__eq__, ["socket.gettimeout"], true]
    - [fileno_qualname,     socket.fileno.__qualname__.__eq__,     ["socket.fileno"],     true]
    - [shutdown_qualname,   socket.shutdown.__qualname__.__eq__,   ["socket.shutdown"],   true]
    - [setblocking_qualname,socket.setblocking.__qualname__.__eq__,["socket.setblocking"],true]

# ---------------------------------------------------------------------------
# Standalone invariants: verify qualnames are NOT the SocketType prefix form
# On Python 3.14.3 macOS, socket.socket methods use 'socket.' prefix, not 'SocketType.'
# ---------------------------------------------------------------------------

invariant socksockq243.connect.not_sockettype_prefix:
  description: "socket.socket.connect.__qualname__ is NOT 'SocketType.connect' — prefix is 'socket.' on Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: socket.connect.__qualname__.__eq__
  args: ["SocketType.connect"]
  expected: false

invariant socksockq243.bind.not_sockettype_prefix:
  description: "socket.socket.bind.__qualname__ is NOT 'SocketType.bind' — prefix is 'socket.' on Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: socket.bind.__qualname__.__eq__
  args: ["SocketType.bind"]
  expected: false

# ---------------------------------------------------------------------------
# Qualname prefix — all method qualnames begin with 'socket.'
# ---------------------------------------------------------------------------

invariant socksockq243.connect.qualname_startswith:
  description: "socket.socket.connect.__qualname__.startswith('socket.') == True"
  category: method_qualnames
  kind: python_call_eq
  function: socket.connect.__qualname__.startswith
  args: ["socket."]
  expected: true

invariant socksockq243.recv.qualname_startswith:
  description: "socket.socket.recv.__qualname__.startswith('socket.') == True"
  category: method_qualnames
  kind: python_call_eq
  function: socket.recv.__qualname__.startswith
  args: ["socket."]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket — getsockname, getpeername, setsockopt qualnames
# ---------------------------------------------------------------------------

invariant socksockq243.getsockname.qualname:
  description: "socket.socket.getsockname.__qualname__ == 'socket.getsockname'"
  category: method_qualnames
  kind: python_call_eq
  function: socket.getsockname.__qualname__.__eq__
  args: ["socket.getsockname"]
  expected: true

invariant socksockq243.getpeername.qualname:
  description: "socket.socket.getpeername.__qualname__ == 'socket.getpeername'"
  category: method_qualnames
  kind: python_call_eq
  function: socket.getpeername.__qualname__.__eq__
  args: ["socket.getpeername"]
  expected: true

invariant socksockq243.setsockopt.qualname:
  description: "socket.socket.setsockopt.__qualname__ == 'socket.setsockopt'"
  category: method_qualnames
  kind: python_call_eq
  function: socket.setsockopt.__qualname__.__eq__
  args: ["socket.setsockopt"]
  expected: true
