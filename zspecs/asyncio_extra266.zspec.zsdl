spec: asyncio_extra266
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio exception documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
    - "CPython source: Lib/asyncio/exceptions.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "asyncio.CancelledError.__module__ == 'asyncio.exceptions' (defined in the exceptions submodule)."
    - "asyncio.TimeoutError is the builtin TimeoutError: __module__ == 'builtins', base is OSError."
    - "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions'; base is Exception."
    - "asyncio.QueueEmpty.__module__ == 'asyncio.queues'; base is Exception."
    - "asyncio.QueueFull.__module__ == 'asyncio.queues'; base is Exception."
    - "asyncio.CancelledError.__bases__[0] is BaseException (not Exception)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class __name__ and __module__ — table
#
# Five asyncio exception classes: CancelledError, TimeoutError,
# InvalidStateError, QueueEmpty, QueueFull. TimeoutError is the builtin
# OSError subclass re-exported from asyncio; the rest are defined in
# asyncio submodules.
# ---------------------------------------------------------------------------

table asyncio_extra266.exception_names:
  description: "asyncio exception classes report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: excname

  columns: [id, function, args, expected, description]
  rows:
    - [CancelledError,    CancelledError.__name__.__eq__,    ["CancelledError"],    true, "asyncio.CancelledError.__name__ == 'CancelledError'"]
    - [TimeoutError,      TimeoutError.__name__.__eq__,      ["TimeoutError"],      true, "asyncio.TimeoutError.__name__ == 'TimeoutError'"]
    - [InvalidStateError, InvalidStateError.__name__.__eq__, ["InvalidStateError"], true, "asyncio.InvalidStateError.__name__ == 'InvalidStateError'"]
    - [QueueEmpty,        QueueEmpty.__name__.__eq__,        ["QueueEmpty"],        true, "asyncio.QueueEmpty.__name__ == 'QueueEmpty'"]
    - [QueueFull,         QueueFull.__name__.__eq__,         ["QueueFull"],         true, "asyncio.QueueFull.__name__ == 'QueueFull'"]

table asyncio_extra266.exception_modules:
  description: "asyncio exception classes report the expected __module__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: excmod

  columns: [id, function, args, expected, description]
  rows:
    - [CancelledError,    CancelledError.__module__.__eq__,    ["asyncio.exceptions"], true, "asyncio.CancelledError.__module__ == 'asyncio.exceptions'"]
    - [TimeoutError,      TimeoutError.__module__.__eq__,      ["builtins"],           true, "asyncio.TimeoutError.__module__ == 'builtins' — it is the builtin TimeoutError"]
    - [InvalidStateError, InvalidStateError.__module__.__eq__, ["asyncio.exceptions"], true, "asyncio.InvalidStateError.__module__ == 'asyncio.exceptions'"]
    - [QueueEmpty,        QueueEmpty.__module__.__eq__,        ["asyncio.queues"],     true, "asyncio.QueueEmpty.__module__ == 'asyncio.queues'"]
    - [QueueFull,         QueueFull.__module__.__eq__,         ["asyncio.queues"],     true, "asyncio.QueueFull.__module__ == 'asyncio.queues'"]

# ---------------------------------------------------------------------------
# Exception base classes — standalone invariants
#
# CancelledError derives from BaseException (not Exception) — a Python 3.8+
# change that allows it to propagate through broad except Exception clauses.
# TimeoutError derives from OSError (it is the builtin).
# InvalidStateError, QueueEmpty, QueueFull all derive from Exception.
# ---------------------------------------------------------------------------

invariant asyncio_extra266.CancelledError.base:
  description: "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException'"
  category: identity
  kind: python_call_eq
  function: CancelledError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseException"

invariant asyncio_extra266.TimeoutError.base:
  description: "asyncio.TimeoutError.__bases__[0].__name__ == 'OSError' — it is the builtin TimeoutError subclassing OSError"
  category: identity
  kind: python_call_eq
  function: TimeoutError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

invariant asyncio_extra266.InvalidStateError.base:
  description: "asyncio.InvalidStateError.__bases__[0].__name__ == 'Exception'"
  category: identity
  kind: python_call_eq
  function: InvalidStateError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant asyncio_extra266.QueueEmpty.base:
  description: "asyncio.QueueEmpty.__bases__[0].__name__ == 'Exception'"
  category: identity
  kind: python_call_eq
  function: QueueEmpty.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant asyncio_extra266.QueueFull.base:
  description: "asyncio.QueueFull.__bases__[0].__name__ == 'Exception'"
  category: identity
  kind: python_call_eq
  function: QueueFull.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant asyncio_extra266.CancelledError.qualname:
  description: "asyncio.CancelledError.__qualname__ == 'CancelledError'"
  category: identity
  kind: python_call_eq
  function: CancelledError.__qualname__.__eq__
  args: ["CancelledError"]
  expected: true

invariant asyncio_extra266.QueueEmpty.qualname:
  description: "asyncio.QueueEmpty.__qualname__ == 'QueueEmpty'"
  category: identity
  kind: python_call_eq
  function: QueueEmpty.__qualname__.__eq__
  args: ["QueueEmpty"]
  expected: true

invariant asyncio_extra266.QueueFull.qualname:
  description: "asyncio.QueueFull.__qualname__ == 'QueueFull'"
  category: identity
  kind: python_call_eq
  function: QueueFull.__qualname__.__eq__
  args: ["QueueFull"]
  expected: true
