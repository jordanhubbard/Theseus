provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABCMeta, abc.ABC, abc.abstractmethod, abc.abstractproperty __dict__ for __and__, __or__, __xor__ presence (all false)"]
  created_at: "2026-04-13"
error_model: python_exceptions

table abc_extra2686.abcmeta_dict_presence:
  description: "abc.ABCMeta __dict__ does not contain __and__, __or__, __xor__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ab2686md
  columns: [id, function, args, expected]
  rows:
    - ["ab2686md001", abc.ABCMeta.__dict__.__contains__, ["__and__"], false]
    - ["ab2686md002", abc.ABCMeta.__dict__.__contains__, ["__or__"], false]
    - ["ab2686md003", abc.ABCMeta.__dict__.__contains__, ["__xor__"], false]

