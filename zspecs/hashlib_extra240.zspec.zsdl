spec: hashlib_extra240
version: ">=3.6"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "RFC 7693 — The BLAKE2 Cryptographic Hash and MAC"

provenance:
  derived_from:
    - "RFC 7693 — The BLAKE2 Cryptographic Hash and MAC"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_blake2module.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra239.zspec.zsdl — covers sha3_256/sha3_512 hexdigest vectors and length contracts"
    - "hashlib_extra238.zspec.zsdl — covers sha512/sha384 hexdigest vectors and length contracts"
    - "hashlib_extra237.zspec.zsdl — covers sha256/md5/sha1 hexdigest vectors and hexdigest length contracts"
    - "_hashlib.zspec.zsdl — covers _hashlib C extension identity"
    - "hashlib_extra.zspec.zsdl — covers sha256 __name__/__qualname__ and algorithms_available"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.blake2b.__module__ == '_blake2' — BLAKE2b is implemented in the _blake2 C extension on this platform."
    - "hashlib.blake2s.__module__ == '_blake2' — BLAKE2s is implemented in the _blake2 C extension on this platform."
    - "hashlib.blake2b(b'').hexdigest() == '786a02f742015903c6c6fd852552d272912f4740e15847618a86e217f71f5419d25e1031afee585313896444934eb04b903a685b1448b755d56f701afe9be2ce' — RFC 7693 BLAKE2b-512 known test vector for empty input."
    - "hashlib.blake2s(b'').hexdigest() == '69217a3079908094e11121d042354a7c1f55b6482ca1a51e1b250dfd1ed0eef9' — RFC 7693 BLAKE2s-256 known test vector for empty input."
    - "hashlib.blake2b().digest_size == 64 — BLAKE2b default digest is 64 bytes (512 bits)."
    - "hashlib.blake2s().digest_size == 32 — BLAKE2s default digest is 32 bytes (256 bits)."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BLAKE2b class identity contracts
#
# hashlib.blake2b.__name__     == 'blake2b'
# hashlib.blake2b.__module__   == '_blake2'
# hashlib.blake2b.__qualname__ == 'blake2b'
#
# On macOS/Darwin with Python 3.14.3, blake2b is implemented in the _blake2
# C extension module. The class is exposed through hashlib as hashlib.blake2b.
# Novel to hashlib_extra240: no prior hashlib spec anchors blake2b identity.
# ---------------------------------------------------------------------------

table hashlib_extra240.blake2b_identity_contracts:
  description: "blake2b.__name__=='blake2b'; blake2b.__module__=='_blake2'; blake2b.__qualname__=='blake2b'; blake2b class identity contracts; new to hashlib_extra240"
  kind: python_call_eq
  category: class_identity
  id_prefix: hl240b2b

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_name_eq,
       blake2b.__name__.__eq__,
       ["blake2b"],
       true,
       "hashlib.blake2b.__name__.__eq__('blake2b') == True — the BLAKE2b type __name__ attribute is 'blake2b'; this is the type name as defined in the _blake2 C extension; novel blake2b __name__ identity anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]
    - [blake2b_module_eq,
       blake2b.__module__.__eq__,
       ["_blake2"],
       true,
       "hashlib.blake2b.__module__.__eq__('_blake2') == True — the BLAKE2b type is implemented in the _blake2 C extension on macOS/Darwin; __module__ is '_blake2' (not 'hashlib'); novel blake2b __module__ identity anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]
    - [blake2b_qualname_eq,
       blake2b.__qualname__.__eq__,
       ["blake2b"],
       true,
       "hashlib.blake2b.__qualname__.__eq__('blake2b') == True — the BLAKE2b type __qualname__ is 'blake2b'; for a top-level class in a C extension, qualname equals name; novel blake2b __qualname__ identity anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# BLAKE2s class identity contracts
#
# hashlib.blake2s.__name__   == 'blake2s'
# hashlib.blake2s.__module__ == '_blake2'
#
# Similarly to blake2b, blake2s is implemented in the _blake2 C extension.
# BLAKE2s is the 32-bit variant targeting smaller architectures; default
# digest is 32 bytes (256 bits). Novel to hashlib_extra240.
# ---------------------------------------------------------------------------

table hashlib_extra240.blake2s_identity_contracts:
  description: "blake2s.__name__=='blake2s'; blake2s.__module__=='_blake2'; blake2s class identity contracts; new to hashlib_extra240"
  kind: python_call_eq
  category: class_identity
  id_prefix: hl240b2s

  columns: [id, function, args, expected, description]
  rows:
    - [blake2s_name_eq,
       blake2s.__name__.__eq__,
       ["blake2s"],
       true,
       "hashlib.blake2s.__name__.__eq__('blake2s') == True — the BLAKE2s type __name__ attribute is 'blake2s'; this is the type name as defined in the _blake2 C extension; novel blake2s __name__ identity anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]
    - [blake2s_module_eq,
       blake2s.__module__.__eq__,
       ["_blake2"],
       true,
       "hashlib.blake2s.__module__.__eq__('_blake2') == True — the BLAKE2s type is implemented in the _blake2 C extension on macOS/Darwin; __module__ is '_blake2' (not 'hashlib'); novel blake2s __module__ identity anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]
    - [blake2s_qualname_eq,
       blake2s.__qualname__.__eq__,
       ["blake2s"],
       true,
       "hashlib.blake2s.__qualname__.__eq__('blake2s') == True — the BLAKE2s type __qualname__ is 'blake2s'; for a top-level class in a C extension, qualname equals name; novel blake2s __qualname__ identity anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# BLAKE2 test vector contracts — RFC 7693 known-answer tests
#
# hashlib.blake2b(b'').hexdigest() ==
#   '786a02f742015903c6c6fd852552d272912f4740e15847618a86e217f71f5419d25e1031afee585313896444934eb04b903a685b1448b755d56f701afe9be2ce'
#
# hashlib.blake2s(b'').hexdigest() ==
#   '69217a3079908094e11121d042354a7c1f55b6482ca1a51e1b250dfd1ed0eef9'
#
# These are the RFC 7693 known-answer test vectors for empty input.
# BLAKE2b-512 produces a 64-byte (512-bit) digest (128 hex chars).
# BLAKE2s-256 produces a 32-byte (256-bit) digest (64 hex chars).
# Novel to hashlib_extra240: no prior spec anchors these blake2b/blake2s vectors.
# ---------------------------------------------------------------------------

table hashlib_extra240.blake2_hexdigest_vectors:
  description: "blake2b(b'').hexdigest()==RFC7693 empty vector; blake2s(b'').hexdigest()==RFC7693 empty vector; BLAKE2 known test vector contracts; new to hashlib_extra240"
  kind: python_call_eq
  category: hash_vectors
  id_prefix: hl240vecs

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_empty_hexdigest,
       "blake2b(b'').hexdigest.__eq__",
       ["786a02f742015903c6c6fd852552d272912f4740e15847618a86e217f71f5419d25e1031afee585313896444934eb04b903a685b1448b755d56f701afe9be2ce"],
       true,
       "hashlib.blake2b(b'').hexdigest().__eq__('786a02f742015903c6c6fd852552d272912f4740e15847618a86e217f71f5419d25e1031afee585313896444934eb04b903a685b1448b755d56f701afe9be2ce') == True — RFC 7693 BLAKE2b-512 known test vector for empty input; 128 hex characters representing 64 bytes (512 bits); novel blake2b empty hexdigest anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]
    - [blake2s_empty_hexdigest,
       "blake2s(b'').hexdigest.__eq__",
       ["69217a3079908094e11121d042354a7c1f55b6482ca1a51e1b250dfd1ed0eef9"],
       true,
       "hashlib.blake2s(b'').hexdigest().__eq__('69217a3079908094e11121d042354a7c1f55b6482ca1a51e1b250dfd1ed0eef9') == True — RFC 7693 BLAKE2s-256 known test vector for empty input; 64 hex characters representing 32 bytes (256 bits); novel blake2s empty hexdigest anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# BLAKE2 hexdigest length contracts
#
# blake2b hexdigest has 128 hex characters (digest_size=64, 64*2=128).
# blake2s hexdigest has 64 hex characters (digest_size=32, 32*2=64).
# Novel to hashlib_extra240.
# ---------------------------------------------------------------------------

table hashlib_extra240.blake2_hexdigest_lengths:
  description: "blake2b(b'').hexdigest().__len__()==128; blake2s(b'').hexdigest().__len__()==64; BLAKE2 hexdigest length contracts; new to hashlib_extra240"
  kind: python_call_eq
  category: hash_lengths
  id_prefix: hl240len

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_hexdigest_len,
       "blake2b(b'').hexdigest().__len__",
       [],
       128,
       "hashlib.blake2b(b'').hexdigest().__len__() == 128 — BLAKE2b default digest_size is 64 bytes; hexdigest encodes as 2 hex chars per byte giving 128 characters; novel blake2b hexdigest length anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]
    - [blake2s_hexdigest_len,
       "blake2s(b'').hexdigest().__len__",
       [],
       64,
       "hashlib.blake2s(b'').hexdigest().__len__() == 64 — BLAKE2s default digest_size is 32 bytes; hexdigest encodes as 2 hex chars per byte giving 64 characters; novel blake2s hexdigest length anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]
    - [blake2b_digest_size_eq,
       "blake2b().digest_size.__eq__",
       [64],
       true,
       "hashlib.blake2b().digest_size.__eq__(64) == True — BLAKE2b default digest_size is 64 bytes (512 bits); this is the maximum digest length for BLAKE2b; novel blake2b digest_size anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]
    - [blake2s_digest_size_eq,
       "blake2s().digest_size.__eq__",
       [32],
       true,
       "hashlib.blake2s().digest_size.__eq__(32) == True — BLAKE2s default digest_size is 32 bytes (256 bits); this is the maximum digest length for BLAKE2s; novel blake2s digest_size anchor; new to hashlib_extra240 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra240.blake2b_name_eq:
  description: "hashlib.blake2b.__name__.__eq__('blake2b') == True — the BLAKE2b type is exposed in the hashlib module as hashlib.blake2b; its __name__ attribute is 'blake2b' as defined in the _blake2 C extension; BLAKE2b is the 64-bit optimized variant of BLAKE2 defined in RFC 7693; it produces digests up to 64 bytes (512 bits); no prior hashlib spec anchors blake2b.__name__; hashlib_extra240 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

invariant hashlib_extra240.blake2b_module_eq:
  description: "hashlib.blake2b.__module__.__eq__('_blake2') == True — the BLAKE2b type is implemented in the _blake2 C extension module on macOS/Darwin with Python 3.14.3; __module__ is '_blake2' not 'hashlib'; this distinguishes it from pure-Python implementations; the _blake2 module is the authoritative source of the blake2b class; no prior hashlib spec anchors blake2b.__module__; hashlib_extra240 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

invariant hashlib_extra240.blake2s_name_eq:
  description: "hashlib.blake2s.__name__.__eq__('blake2s') == True — the BLAKE2s type is exposed in the hashlib module as hashlib.blake2s; its __name__ attribute is 'blake2s' as defined in the _blake2 C extension; BLAKE2s is the 32-bit optimized variant of BLAKE2 defined in RFC 7693; it produces digests up to 32 bytes (256 bits); no prior hashlib spec anchors blake2s.__name__; hashlib_extra240 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: blake2s.__name__.__eq__
  args: ["blake2s"]
  expected: true

invariant hashlib_extra240.blake2s_module_eq:
  description: "hashlib.blake2s.__module__.__eq__('_blake2') == True — the BLAKE2s type is implemented in the _blake2 C extension module on macOS/Darwin with Python 3.14.3; __module__ is '_blake2' not 'hashlib'; BLAKE2s is optimized for 8- to 32-bit platforms; no prior hashlib spec anchors blake2s.__module__; hashlib_extra240 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: class_identity
  kind: python_call_eq
  function: blake2s.__module__.__eq__
  args: ["_blake2"]
  expected: true

invariant hashlib_extra240.blake2b_empty_hexdigest_eq:
  description: "hashlib.blake2b(b'').hexdigest().__eq__('786a02f742015903c6c6fd852552d272912f4740e15847618a86e217f71f5419d25e1031afee585313896444934eb04b903a685b1448b755d56f701afe9be2ce') == True — RFC 7693 BLAKE2b-512 known-answer test vector for the empty byte string; the 128-character hex string represents 64 bytes (512 bits); BLAKE2b is faster than SHA-3 while providing equivalent security on 64-bit platforms; no prior hashlib spec anchors any blake2b hexdigest output; hashlib_extra240 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_vectors
  kind: python_call_eq
  function: "blake2b(b'').hexdigest.__eq__"
  args: ["786a02f742015903c6c6fd852552d272912f4740e15847618a86e217f71f5419d25e1031afee585313896444934eb04b903a685b1448b755d56f701afe9be2ce"]
  expected: true

invariant hashlib_extra240.blake2s_empty_hexdigest_eq:
  description: "hashlib.blake2s(b'').hexdigest().__eq__('69217a3079908094e11121d042354a7c1f55b6482ca1a51e1b250dfd1ed0eef9') == True — RFC 7693 BLAKE2s-256 known-answer test vector for the empty byte string; the 64-character hex string represents 32 bytes (256 bits); BLAKE2s is optimized for short messages and constrained devices; no prior hashlib spec anchors any blake2s hexdigest output; hashlib_extra240 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_vectors
  kind: python_call_eq
  function: "blake2s(b'').hexdigest.__eq__"
  args: ["69217a3079908094e11121d042354a7c1f55b6482ca1a51e1b250dfd1ed0eef9"]
  expected: true

invariant hashlib_extra240.blake2b_hexdigest_len_128:
  description: "hashlib.blake2b(b'').hexdigest().__len__() == 128 — BLAKE2b default digest_size is 64 bytes; hexdigest() encodes each byte as exactly 2 lowercase hex characters giving 128 characters total; 128 == 64 * 2; this length is constant for all BLAKE2b inputs when using the default 512-bit output length; no prior spec anchors blake2b hexdigest length; hashlib_extra240 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_lengths
  kind: python_call_eq
  function: "blake2b(b'').hexdigest().__len__"
  args: []
  expected: 128

invariant hashlib_extra240.blake2s_hexdigest_len_64:
  description: "hashlib.blake2s(b'').hexdigest().__len__() == 64 — BLAKE2s default digest_size is 32 bytes; hexdigest() encodes each byte as exactly 2 lowercase hex characters giving 64 characters total; 64 == 32 * 2; this length is constant for all BLAKE2s inputs when using the default 256-bit output length; no prior spec anchors blake2s hexdigest length; hashlib_extra240 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: hash_lengths
  kind: python_call_eq
  function: "blake2s(b'').hexdigest().__len__"
  args: []
  expected: 64
