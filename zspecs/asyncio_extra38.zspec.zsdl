spec: asyncio_extra38
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio Event Loop"
    - "https://docs.python.org/3/library/asyncio-protocol.html — asyncio Protocols"
    - "https://docs.python.org/3/library/asyncio-stream.html — asyncio Streams"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
    - "CPython source: Lib/asyncio/base_events.py"
    - "CPython source: Lib/asyncio/protocols.py"
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "This spec extends asyncio_extra37.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, timeout_at/__name__/__qualname__.__len__()==10, create_task/__name__.__len__()==11, ensure_future/__name__.__len__()==13, Runner/__name__.__len__()==6, AbstractEventLoop/__mro__.__len__()==2, AbstractEventLoop/__bases__[0].__name__.__len__()==6, AbstractEventLoop/__dict__.__class__.__name__.__len__()==12, MRO depths for all queue/lock/sync classes."
    - "This spec covers: AbstractEventLoop/__name__.__len__()==17; BaseEventLoop/__name__.__len__()==13; Handle/__name__.__len__()==6; TimerHandle/__name__.__len__()==11; Protocol/__name__.__len__()==8; StreamReader/__name__.__len__()==12; AbstractEventLoop/__module__.__len__()==14 ('asyncio.events'); BaseEventLoop/__module__.__len__()==19 ('asyncio.base_events'); Handle/__module__.__len__()==14 ('asyncio.events'); TimerHandle/__module__.__len__()==14 ('asyncio.events'); Protocol/__module__.__len__()==17 ('asyncio.protocols'); StreamReader/__module__.__len__()==15 ('asyncio.streams')."
    - "AbstractEventLoop.__name__ == 'AbstractEventLoop' (17 chars); BaseEventLoop.__name__ == 'BaseEventLoop' (13 chars). The 'Abstract' prefix (8 chars) makes AbstractEventLoop.__name__ 4 chars longer than BaseEventLoop.__name__ (17 - 13 = 4). Prior specs (extra2, extra7) captured __name__.__eq__ and __qualname__.__eq__ as boolean equality checks, but NOT __name__.__len__() as integer invariants."
    - "Handle.__name__ == 'Handle' (6 chars); TimerHandle.__name__ == 'TimerHandle' (11 chars). 'Timer' prefix (5 chars) distinguishes TimerHandle from Handle, making TimerHandle.__name__.__len__() exactly 5 longer (11 - 6 = 5). Both Handle and TimerHandle live in asyncio.events (module len 14)."
    - "Protocol.__name__ == 'Protocol' (8 chars); StreamReader.__name__ == 'StreamReader' (12 chars). Protocol is in asyncio.protocols (len 17); StreamReader is in asyncio.streams (len 15). These are different submodules, with asyncio.protocols being 2 chars longer than asyncio.streams."
    - "AbstractEventLoop.__module__ == 'asyncio.events' (14 chars); BaseEventLoop.__module__ == 'asyncio.base_events' (19 chars). BaseEventLoop lives in asyncio.base_events (the longer submodule name, 5 chars more than asyncio.events). Handle and TimerHandle also live in asyncio.events (14 chars each)."
    - "For top-level classes, __qualname__ equals __name__, so AbstractEventLoop/__qualname__.__len__()==17 and BaseEventLoop/__qualname__.__len__()==13. These are novel integer measurements."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio event loop class __name__.__len__() — extra38 namespace
#
# The core event loop classes have these __name__ lengths:
#   AbstractEventLoop.__name__ == 'AbstractEventLoop' (17 chars)
#   BaseEventLoop.__name__     == 'BaseEventLoop'     (13 chars)
# The 'Abstract' prefix (8 chars) differentiates them; the shared 'EventLoop'
# suffix (9 chars) is the structural unit. AbstractEventLoop is 4 chars longer
# than BaseEventLoop (17 - 13 = 4, matching 'Abstract' minus 'Base' = 8 - 4 = 4).
# Prior specs (extra2) captured __name__.__eq__ as boolean; extra7 captured
# __qualname__.__eq__ as boolean. Neither captured __len__() as integer.
# ---------------------------------------------------------------------------

table asyncio_extra38.event_loop_class_name_lengths:
  description: "asyncio event loop class __name__.__len__() in extra38 namespace — AbstractEventLoop and BaseEventLoop"
  kind: python_call_eq
  category: class_names
  id_prefix: elclassnamelen38

  columns: [id, function, args, expected, description]
  rows:
    - [AbstractEventLoop, AbstractEventLoop.__name__.__len__, [], 17, "'AbstractEventLoop' is 17 characters — 4 longer than BaseEventLoop"]
    - [BaseEventLoop,     BaseEventLoop.__name__.__len__,     [], 13, "'BaseEventLoop' is 13 characters — 4 shorter than AbstractEventLoop"]

# ---------------------------------------------------------------------------
# asyncio Handle and TimerHandle __name__.__len__() — extra38 namespace
#
# Handle and TimerHandle live in asyncio.events and represent scheduled
# callbacks:
#   Handle.__name__     == 'Handle'     ( 6 chars)
#   TimerHandle.__name__ == 'TimerHandle' (11 chars)
# The 'Timer' prefix (5 chars) makes TimerHandle exactly 5 chars longer than
# Handle. Both are top-level classes so __qualname__ == __name__.
# No prior asyncio spec has measured Handle/__name__.__len__() or
# TimerHandle/__name__.__len__() as integer invariants.
# ---------------------------------------------------------------------------

table asyncio_extra38.handle_class_name_lengths:
  description: "asyncio Handle and TimerHandle __name__.__len__() in extra38 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: handleclassnamelen38

  columns: [id, function, args, expected, description]
  rows:
    - [Handle,      Handle.__name__.__len__,      [], 6,  "'Handle' is 6 characters — the base callback handle"]
    - [TimerHandle, TimerHandle.__name__.__len__,  [], 11, "'TimerHandle' is 11 characters — 5 longer than Handle due to 'Timer' prefix"]

# ---------------------------------------------------------------------------
# asyncio Protocol and StreamReader __name__.__len__() — extra38 namespace
#
# Protocol and StreamReader represent the protocol and streaming API:
#   Protocol.__name__    == 'Protocol'    ( 8 chars)
#   StreamReader.__name__ == 'StreamReader' (12 chars)
# Prior specs (asyncio_extra) captured StreamReader/__name__.__eq__ as boolean
# and asyncio_extra13 captured StreamReader/__qualname__.__eq__ as boolean.
# Neither spec measured __name__.__len__() as an integer. Protocol's
# __name__.__len__() has not been measured in any prior spec.
# ---------------------------------------------------------------------------

table asyncio_extra38.protocol_stream_name_lengths:
  description: "asyncio Protocol and StreamReader __name__.__len__() in extra38 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: protonamelen38

  columns: [id, function, args, expected, description]
  rows:
    - [Protocol,    Protocol.__name__.__len__,    [], 8,  "'Protocol' is 8 characters"]
    - [StreamReader, StreamReader.__name__.__len__, [], 12, "'StreamReader' is 12 characters — 4 longer than Protocol"]

# ---------------------------------------------------------------------------
# asyncio class __module__.__len__() — extra38 namespace
#
# These classes are spread across multiple asyncio submodules. Their module
# string lengths reveal the internal structure:
#   AbstractEventLoop.__module__ == 'asyncio.events'     (14 chars)
#   Handle.__module__            == 'asyncio.events'     (14 chars)
#   TimerHandle.__module__       == 'asyncio.events'     (14 chars)
#   BaseEventLoop.__module__     == 'asyncio.base_events' (19 chars)
#   StreamReader.__module__      == 'asyncio.streams'    (15 chars)
#   Protocol.__module__          == 'asyncio.protocols'  (17 chars)
# AbstractEventLoop, Handle, and TimerHandle all share module length 14.
# BaseEventLoop stands out at 19 because 'base_events' is a longer submodule
# name. No prior asyncio spec has measured any of these __module__.__len__()
# values as integer invariants.
# ---------------------------------------------------------------------------

table asyncio_extra38.class_module_lengths:
  description: "asyncio class __module__.__len__() in extra38 namespace — reveals internal submodule structure"
  kind: python_call_eq
  category: module_names
  id_prefix: classmoudlelen38

  columns: [id, function, args, expected, description]
  rows:
    - [AbstractEventLoop, AbstractEventLoop.__module__.__len__, [], 14, "'asyncio.events' is 14 characters — shared by AbstractEventLoop/Handle/TimerHandle"]
    - [Handle,             Handle.__module__.__len__,            [], 14, "'asyncio.events' is 14 characters — same submodule as AbstractEventLoop"]
    - [TimerHandle,        TimerHandle.__module__.__len__,       [], 14, "'asyncio.events' is 14 characters — same submodule as Handle"]
    - [BaseEventLoop,      BaseEventLoop.__module__.__len__,     [], 19, "'asyncio.base_events' is 19 characters — 5 longer than asyncio.events"]
    - [StreamReader,       StreamReader.__module__.__len__,      [], 15, "'asyncio.streams' is 15 characters"]
    - [Protocol,           Protocol.__module__.__len__,          [], 17, "'asyncio.protocols' is 17 characters — 2 longer than asyncio.streams"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra38
# ---------------------------------------------------------------------------

invariant asyncio_extra38.AbstractEventLoop_name_len:
  description: "asyncio.AbstractEventLoop.__name__.__len__() == 17 — 'AbstractEventLoop' has 17 characters; 4 longer than BaseEventLoop (13)"
  category: class_names
  kind: python_call_eq
  function: AbstractEventLoop.__name__.__len__
  args: []
  expected: 17

invariant asyncio_extra38.BaseEventLoop_module_len:
  description: "asyncio.BaseEventLoop.__module__.__len__() == 19 — 'asyncio.base_events' has 19 characters; the longest event-loop submodule name in this spec"
  category: module_names
  kind: python_call_eq
  function: BaseEventLoop.__module__.__len__
  args: []
  expected: 19

invariant asyncio_extra38.TimerHandle_name_len:
  description: "asyncio.TimerHandle.__name__.__len__() == 11 — 'TimerHandle' has 11 characters; 5 longer than Handle (6) due to the 'Timer' prefix"
  category: class_names
  kind: python_call_eq
  function: TimerHandle.__name__.__len__
  args: []
  expected: 11

invariant asyncio_extra38.Protocol_module_len:
  description: "asyncio.Protocol.__module__.__len__() == 17 — 'asyncio.protocols' has 17 characters; 2 longer than asyncio.streams (15)"
  category: module_names
  kind: python_call_eq
  function: Protocol.__module__.__len__
  args: []
  expected: 17
