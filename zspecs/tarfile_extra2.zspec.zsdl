spec: tarfile_extra2
version: ">=3.9"
backend: python_module(tarfile)

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tarfile.html — Python tarfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tarfile.py"
  notes:
    - "Extends tarfile.zspec.zsdl and tarfile_extra.zspec.zsdl."
    - "tarfile.zspec.zsdl covers: USTAR/GNU/PAX/DEFAULT_FORMAT, BLOCKSIZE, RECORDSIZE, ENCODING value, type flag bytes, TarInfo construction, class __name__ for TarFile/TarInfo/TarError/ReadError, ReadError and TarError base classes, is_tarfile false on bad bytes."
    - "tarfile_extra.zspec.zsdl covers: class __name__ table for TarFile/TarInfo/TarError/ReadError/CompressionError, open/__name__, is_tarfile/__name__, TarError base, ENCODING class name."
    - "This spec adds: TarFile.__module__, TarInfo.__module__, CompressionError.__bases__[0] == TarError, REGULAR_TYPES and SUPPORTED_TYPES as frozenset, open.__name__ (individual invariant), additional module/type checks."
    - "tarfile.TarFile.__module__ == 'tarfile'."
    - "tarfile.CompressionError.__bases__[0].__name__ == 'TarError' — distinct from TarError itself."
    - "tarfile.REGULAR_TYPES.__class__.__name__ == 'frozenset' — frozenset of regular-file type flags."
    - "tarfile.SUPPORTED_TYPES.__class__.__name__ == 'frozenset' — frozenset of all supported type flags."
    - "tarfile.ENCODING.__class__.__name__ == 'str' — ENCODING is a plain Python str."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — TarFile, TarInfo, CompressionError
# ---------------------------------------------------------------------------

invariant tarfile_extra2.TarFile.name:
  description: "tarfile.TarFile.__name__ == 'TarFile'"
  category: class_names
  kind: python_call_eq
  function: TarFile.__name__.__eq__
  args: ["TarFile"]
  expected: true

invariant tarfile_extra2.TarInfo.name:
  description: "tarfile.TarInfo.__name__ == 'TarInfo'"
  category: class_names
  kind: python_call_eq
  function: TarInfo.__name__.__eq__
  args: ["TarInfo"]
  expected: true

invariant tarfile_extra2.CompressionError.name:
  description: "tarfile.CompressionError.__name__ == 'CompressionError'"
  category: class_names
  kind: python_call_eq
  function: CompressionError.__name__.__eq__
  args: ["CompressionError"]
  expected: true

# ---------------------------------------------------------------------------
# Module checks — TarFile and TarInfo live in the tarfile module
# ---------------------------------------------------------------------------

invariant tarfile_extra2.TarFile.module:
  description: "tarfile.TarFile.__module__ == 'tarfile'"
  category: modules
  kind: python_call_eq
  function: TarFile.__module__.__eq__
  args: ["tarfile"]
  expected: true

invariant tarfile_extra2.TarInfo.module:
  description: "tarfile.TarInfo.__module__ == 'tarfile'"
  category: modules
  kind: python_call_eq
  function: TarInfo.__module__.__eq__
  args: ["tarfile"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — CompressionError inherits from TarError
# ---------------------------------------------------------------------------

invariant tarfile_extra2.CompressionError.base_is_TarError:
  description: "tarfile.CompressionError.__bases__[0].__name__ == 'TarError'"
  category: hierarchy
  kind: python_call_eq
  function: CompressionError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "TarError"

# ---------------------------------------------------------------------------
# ENCODING constant — type check (str)
# ---------------------------------------------------------------------------

invariant tarfile_extra2.ENCODING.class_name:
  description: "tarfile.ENCODING.__class__.__name__ == 'str' — ENCODING is a plain str"
  category: constants
  kind: python_call_eq
  function: ENCODING.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# REGULAR_TYPES — frozenset of regular-file type flags
# ---------------------------------------------------------------------------

invariant tarfile_extra2.REGULAR_TYPES.class_name:
  description: "tarfile.REGULAR_TYPES.__class__.__name__ == 'frozenset'"
  category: constants
  kind: python_call_eq
  function: REGULAR_TYPES.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

# ---------------------------------------------------------------------------
# SUPPORTED_TYPES — frozenset of all supported member type flags
# ---------------------------------------------------------------------------

invariant tarfile_extra2.SUPPORTED_TYPES.class_name:
  description: "tarfile.SUPPORTED_TYPES.__class__.__name__ == 'frozenset'"
  category: constants
  kind: python_call_eq
  function: SUPPORTED_TYPES.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

# ---------------------------------------------------------------------------
# Function name check — open factory function
# ---------------------------------------------------------------------------

invariant tarfile_extra2.open.name:
  description: "tarfile.open.__name__ == 'open'"
  category: function_names
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# Type identity checks — TarFile and TarInfo are proper types (classes)
# ---------------------------------------------------------------------------

invariant tarfile_extra2.TarFile.is_type:
  description: "tarfile.TarFile.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: TarFile.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant tarfile_extra2.TarInfo.is_type:
  description: "tarfile.TarInfo.__class__.__name__ == 'type'"
  category: type_identity
  kind: python_call_eq
  function: TarInfo.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# SUPPORTED_TYPES contains REGULAR_TYPES members (membership cross-check)
# REGTYPE == b'0' is in both REGULAR_TYPES and SUPPORTED_TYPES
# ---------------------------------------------------------------------------

invariant tarfile_extra2.REGULAR_TYPES.contains_REGTYPE:
  description: "tarfile.REGTYPE in tarfile.REGULAR_TYPES — regular file flag is in REGULAR_TYPES"
  category: constants
  kind: python_call_eq
  function: REGULAR_TYPES.__contains__
  args: [{type: bytes_ascii, value: "0"}]
  expected: true

invariant tarfile_extra2.SUPPORTED_TYPES.contains_DIRTYPE:
  description: "tarfile.DIRTYPE in tarfile.SUPPORTED_TYPES — directory flag is in SUPPORTED_TYPES"
  category: constants
  kind: python_call_eq
  function: SUPPORTED_TYPES.__contains__
  args: [{type: bytes_ascii, value: "5"}]
  expected: true
