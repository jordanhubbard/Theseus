spec: functools_extra180
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.lru_cache function identity — functools.lru_cache.__name__=='lru_cache' (len=9); functools.lru_cache.__module__=='functools'; functools.cache.__name__=='cache' (len=5); functools.cache.__module__=='functools'; functools.cached_property.__name__=='cached_property' (len=15); functools.cached_property.__module__=='functools'; functools.cached_property.__mro__.__len__()==2 (cached_property > object — Python class); functools.total_ordering.__name__=='total_ordering' (len=14)."
    - "functools.lru_cache.__name__ == 'lru_cache' — lru_cache is a Python function defined in Lib/functools.py; its __name__ is 'lru_cache', 9 characters long. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools' — lru_cache is defined in Lib/functools.py; its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.cache.__name__ == 'cache' — cache is a Python function defined in Lib/functools.py (added in 3.9); its __name__ is 'cache', 5 characters long. Verified with Python 3.14.3."
    - "functools.cache.__module__ == 'functools' — cache is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cached_property.__name__ == 'cached_property' — cached_property is a Python class defined in Lib/functools.py; its __name__ is 'cached_property', 15 characters long. Verified with Python 3.14.3."
    - "functools.cached_property.__module__ == 'functools' — cached_property is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cached_property.__mro__.__len__() == 2 — cached_property is a Python class inheriting directly from object; its MRO is (cached_property, object). Verified with Python 3.14.3."
    - "functools.total_ordering.__name__ == 'total_ordering' — total_ordering is a Python function defined in Lib/functools.py; its __name__ is 'total_ordering', 14 characters long. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache and functools.cache __name__ and __module__
#
# functools.lru_cache.__name__ == 'lru_cache'
# functools.lru_cache.__name__.__len__() == 9
# functools.lru_cache.__module__ == 'functools'
# functools.cache.__name__ == 'cache'
#
# functools.lru_cache is a Python function/decorator in Lib/functools.py that
# wraps a callable with a least-recently-used cache of bounded size.
# functools.cache (added in Python 3.9) is an unbounded variant equivalent to
# lru_cache(maxsize=None). Both are defined in functools and have their
# respective __name__ values. New to extra180.
# ---------------------------------------------------------------------------

table functools_extra180.lru_cache_and_cache_name_module:
  description: "functools.lru_cache.__name__ 'lru_cache' len 9; cache.__name__ 'cache' len 5; lru_cache.__module__ 'functools'; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: funclrucache180

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_name_eq,
       "lru_cache.__name__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache is a Python function/decorator in Lib/functools.py that wraps callables with a bounded least-recently-used cache; its __name__ is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra180"]
    - [lru_cache_name_len_9,
       "lru_cache.__name__.__len__",
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — the name 'lru_cache' has exactly 9 characters: l-r-u-_-c-a-c-h-e; str.__len__() returns 9; new to extra180"]
    - [lru_cache_module_functools,
       "lru_cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in Lib/functools.py; its __module__ attribute is the string 'functools'; str.__eq__('functools') returns True; new to extra180"]
    - [cache_name_eq,
       "cache.__name__.__eq__",
       ["cache"],
       true,
       "functools.cache.__name__.__eq__('cache') == True — functools.cache (added in Python 3.9) is an unbounded memoization decorator equivalent to lru_cache(maxsize=None); its __name__ is 'cache'; str.__eq__('cache') returns True; new to extra180"]

# ---------------------------------------------------------------------------
# Table 2: functools.cache __name__.__len__ and __module__, functools.total_ordering
#
# functools.cache.__name__.__len__() == 5
# functools.cache.__module__ == 'functools'
# functools.total_ordering.__name__ == 'total_ordering'
# functools.total_ordering.__name__.__len__() == 15
#
# functools.cache.__name__ is 'cache' (5 chars). functools.total_ordering is a
# class decorator that fills in missing comparison methods given __eq__ and one
# of __lt__, __le__, __gt__, __ge__. Its __name__ is 'total_ordering' (15 chars,
# same length as 'cached_property'). New to extra180.
# ---------------------------------------------------------------------------

table functools_extra180.cache_module_and_total_ordering_name:
  description: "functools.cache.__name__ len 5; cache.__module__ 'functools'; total_ordering.__name__ 'total_ordering' len 15; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: funclrucache180

  columns: [id, function, args, expected, description]
  rows:
    - [cache_name_len_5,
       "cache.__name__.__len__",
       [],
       5,
       "functools.cache.__name__.__len__() == 5 — the name 'cache' has exactly 5 characters: c-a-c-h-e; str.__len__() returns 5; new to extra180"]
    - [cache_module_functools,
       "cache.__module__.__eq__",
       ["functools"],
       true,
       "functools.cache.__module__.__eq__('functools') == True — functools.cache is defined in Lib/functools.py; its __module__ is the string 'functools'; str.__eq__('functools') returns True; new to extra180"]
    - [total_ordering_name_eq,
       "total_ordering.__name__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — total_ordering is a class decorator in Lib/functools.py that fills in missing rich comparison methods; its __name__ is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra180"]
    - [total_ordering_name_len_14,
       "total_ordering.__name__.__len__",
       [],
       14,
       "functools.total_ordering.__name__.__len__() == 14 — the name 'total_ordering' has exactly 14 characters: t-o-t-a-l-_-o-r-d-e-r-i-n-g; str.__len__() returns 14; new to extra180"]

# ---------------------------------------------------------------------------
# Table 3: functools.cached_property class __name__, __module__, __mro__
#
# functools.cached_property.__name__ == 'cached_property'
# functools.cached_property.__name__.__len__() == 15
# functools.cached_property.__module__ == 'functools'
# functools.cached_property.__mro__.__len__() == 2
#
# functools.cached_property is a Python class (a non-data descriptor) defined
# in Lib/functools.py. It computes a class attribute once and caches it as an
# instance attribute. Its __name__ is 'cached_property' (15 chars), and it
# inherits directly from object so its MRO length is 2. New to extra180.
# ---------------------------------------------------------------------------

table functools_extra180.cached_property_name_module_mro:
  description: "functools.cached_property.__name__ 'cached_property' len 15; __module__ 'functools'; __mro__ len 2; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: funclrucache180

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_name_eq,
       "cached_property.__name__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property is a Python descriptor class in Lib/functools.py that computes a value once and stores it as an instance attribute; its __name__ is 'cached_property'; str.__eq__('cached_property') returns True; new to extra180"]
    - [cached_property_name_len_15,
       "cached_property.__name__.__len__",
       [],
       15,
       "functools.cached_property.__name__.__len__() == 15 — the name 'cached_property' has exactly 15 characters: c-a-c-h-e-d-_-p-r-o-p-e-r-t-y; str.__len__() returns 15; new to extra180"]
    - [cached_property_module_functools,
       "cached_property.__module__.__eq__",
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — cached_property is a Python class defined in Lib/functools.py; its __module__ is the string 'functools'; str.__eq__('functools') returns True; new to extra180"]
    - [cached_property_mro_len_2,
       "cached_property.__mro__.__len__",
       [],
       2,
       "functools.cached_property.__mro__.__len__() == 2 — cached_property is a Python class defined in Lib/functools.py that inherits directly from object with no intermediate base classes; its __mro__ is (cached_property, object), a tuple of length 2; tuple.__len__() returns 2; new to extra180"]

# ---------------------------------------------------------------------------
# Table 4: functools.cached_property __mro__ entries and total_ordering module
#
# functools.cached_property.__mro__[0].__name__ == 'cached_property'
# functools.cached_property.__mro__[1].__name__ == 'object'
# functools.total_ordering.__module__ == 'functools'
# functools.lru_cache.__module__.__len__() == 9
#
# Cross-checks confirming cached_property's MRO entries and total_ordering's
# module. The module name 'functools' is 9 characters long. New to extra180.
# ---------------------------------------------------------------------------

table functools_extra180.cached_property_mro_entries_and_total_ordering_module:
  description: "cached_property.__mro__[0] 'cached_property'; mro[1] 'object'; total_ordering.__module__ 'functools'; lru_cache module len 9; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: funclrucache180

  columns: [id, function, args, expected, description]
  rows:
    - ["cached_property_mro_0_name",
       "cached_property.__mro__[0].__name__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__mro__[0].__name__.__eq__('cached_property') == True — the first entry in cached_property.__mro__ is the cached_property class itself; its __name__ is 'cached_property'; str.__eq__('cached_property') returns True; new to extra180"]
    - ["cached_property_mro_1_object",
       "cached_property.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__mro__[1].__name__.__eq__('object') == True — the second and final entry in cached_property.__mro__ is the base class object; its __name__ is 'object'; this confirms cached_property inherits directly from object; str.__eq__('object') returns True; new to extra180"]
    - [total_ordering_module_functools,
       "total_ordering.__module__.__eq__",
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in Lib/functools.py; its __module__ is the string 'functools'; str.__eq__('functools') returns True; new to extra180"]
    - [lru_cache_module_len_9,
       "lru_cache.__module__.__len__",
       [],
       9,
       "functools.lru_cache.__module__.__len__() == 9 — the module name 'functools' has exactly 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; new to extra180"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra180
# ---------------------------------------------------------------------------

invariant functools_extra180.lru_cache_name_lru_cache:
  description: "functools.lru_cache.__name__ == 'lru_cache' — lru_cache is a decorator in Lib/functools.py with __name__ 'lru_cache' (9 chars); new to extra180"
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra180.lru_cache_name_len_9:
  description: "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' is 9 characters long; new to extra180"
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9

invariant functools_extra180.lru_cache_module_functools:
  description: "functools.lru_cache.__module__ == 'functools' — lru_cache is defined in Lib/functools.py; new to extra180"
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra180.cache_name_cache:
  description: "functools.cache.__name__ == 'cache' — functools.cache (Python 3.9+) is an unbounded memoizer with __name__ 'cache' (5 chars); new to extra180"
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra180.cache_name_len_5:
  description: "functools.cache.__name__.__len__() == 5 — 'cache' is 5 characters long; new to extra180"
  kind: python_call_eq
  function: cache.__name__.__len__
  args: []
  expected: 5

invariant functools_extra180.cached_property_name_cached_property:
  description: "functools.cached_property.__name__ == 'cached_property' — cached_property is a Python descriptor class with __name__ 'cached_property' (15 chars); new to extra180"
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra180.cached_property_mro_len_2:
  description: "functools.cached_property.__mro__.__len__() == 2 — cached_property inherits directly from object; MRO is (cached_property, object); new to extra180"
  kind: python_call_eq
  function: cached_property.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra180.total_ordering_name_total_ordering:
  description: "functools.total_ordering.__name__ == 'total_ordering' — total_ordering is a class decorator with __name__ 'total_ordering' (14 chars); new to extra180"
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true
