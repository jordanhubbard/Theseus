spec: abc_extra274
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Python collections.abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
    - "abc_extra273.zspec.zsdl — covers collections.abc.Buffer and collections.abc.ByteString class identity"
  notes:
    - "This spec covers: collections.abc.ItemsView, collections.abc.KeysView, and collections.abc.ValuesView class identity. NEW in extra274: collections.abc.ItemsView.__name__=='ItemsView'; collections.abc.ItemsView.__module__=='collections.abc'; collections.abc.ItemsView.__bases__[0].__name__=='MappingView'; collections.abc.ItemsView.__mro__.__len__()==8 ([ItemsView, MappingView, Set, Collection, Sized, Iterable, Container, object]); collections.abc.KeysView.__name__=='KeysView'; collections.abc.KeysView.__module__=='collections.abc'; collections.abc.KeysView.__bases__[0].__name__=='MappingView'; collections.abc.KeysView.__mro__.__len__()==8 ([KeysView, MappingView, Set, Collection, Sized, Iterable, Container, object]); collections.abc.ValuesView.__name__=='ValuesView'; collections.abc.ValuesView.__module__=='collections.abc'; collections.abc.ValuesView.__bases__[0].__name__=='MappingView'; collections.abc.ValuesView.__mro__.__len__()==7 ([ValuesView, MappingView, Collection, Sized, Iterable, Container, object]); collections.abc.MappingView.__name__=='MappingView'; collections.abc.MappingView.__module__=='collections.abc'; collections.abc.MappingView.__bases__[0].__name__=='Sized'; collections.abc.MappingView.__mro__.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.ItemsView and KeysView both have MRO length 8: [ItemsView/KeysView, MappingView, Set, Collection, Sized, Iterable, Container, object]. Both inherit from MappingView and Set (two direct bases); MappingView contributes [MappingView, Sized]; Set contributes [Set, Collection, Sized, Iterable, Container]; C3 linearisation merges these into the length-8 MRO. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.ValuesView has MRO length 7: [ValuesView, MappingView, Collection, Sized, Iterable, Container, object]. ValuesView inherits from MappingView and Collection (two direct bases) but NOT from Set, so its MRO is one element shorter than ItemsView and KeysView. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "collections.abc.MappingView.__bases__[0].__name__ == 'Sized'. MappingView is the shared base of ItemsView, KeysView, and ValuesView; MappingView inherits from Sized (not from object directly); MappingView.__mro__.__len__() == 3 ([MappingView, Sized, object]). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections.abc.ItemsView and KeysView class identity — extra274
#
# collections.abc.ItemsView.__name__                  == 'ItemsView'
# collections.abc.ItemsView.__module__                == 'collections.abc'
# collections.abc.ItemsView.__bases__[0].__name__     == 'MappingView'
# collections.abc.ItemsView.__mro__.__len__()         == 8
# collections.abc.ItemsView.__qualname__              == 'ItemsView'
# collections.abc.KeysView.__name__                   == 'KeysView'
# collections.abc.KeysView.__module__                 == 'collections.abc'
# collections.abc.KeysView.__bases__[0].__name__      == 'MappingView'
# collections.abc.KeysView.__mro__.__len__()          == 8
# collections.abc.KeysView.__qualname__               == 'KeysView'
# ---------------------------------------------------------------------------

table abc_extra274.cabc_items_keys_view_identity:
  description: "collections.abc.ItemsView and KeysView class identity checks in cabcview274 namespace — ItemsView and KeysView are both defined in Lib/_collections_abc.py; both inherit from MappingView and Set (two direct bases each); ItemsView.__name__.__eq__('ItemsView')==True; ItemsView.__module__.__eq__('collections.abc')==True (len=15: 'collections'=11+'.abc'=4); ItemsView.__bases__[0].__name__.__eq__('MappingView')==True (first base); ItemsView.__mro__.__len__()==8 ([ItemsView, MappingView, Set, Collection, Sized, Iterable, Container, object]); ItemsView.__qualname__.__eq__('ItemsView')==True; ItemsView.__name__.__len__()==9 ('ItemsView'=9); KeysView.__name__.__eq__('KeysView')==True; KeysView.__module__.__eq__('collections.abc')==True (same module); KeysView.__bases__[0].__name__.__eq__('MappingView')==True; KeysView.__mro__.__len__()==8 ([KeysView, MappingView, Set, Collection, Sized, Iterable, Container, object]); same MRO length as ItemsView; KeysView.__qualname__.__eq__('KeysView')==True; KeysView.__name__.__len__()==8 ('KeysView'=8, shorter than ItemsView by 1); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cabcview274

  columns: [id, function, args, expected, description]
  rows:
    - [iv_name_eq,    collections.abc.ItemsView.__name__.__eq__,                    ["ItemsView"],        true, "collections.abc.ItemsView.__name__ == 'ItemsView'; verified with Python 3.14.3"]
    - [iv_mod_eq,     collections.abc.ItemsView.__module__.__eq__,                  ["collections.abc"],  true, "collections.abc.ItemsView.__module__ == 'collections.abc' (len=15); verified with Python 3.14.3"]
    - [iv_base0_eq,   "collections.abc.ItemsView.__bases__[0].__name__.__eq__",     ["MappingView"],      true, "collections.abc.ItemsView.__bases__[0].__name__ == 'MappingView'; verified with Python 3.14.3"]
    - [iv_mro_len,    collections.abc.ItemsView.__mro__.__len__,                    [],                   8,    "collections.abc.ItemsView.__mro__.__len__() == 8 — [ItemsView, MappingView, Set, Collection, Sized, Iterable, Container, object]; verified with Python 3.14.3"]
    - [iv_qn_eq,      collections.abc.ItemsView.__qualname__.__eq__,                ["ItemsView"],        true, "collections.abc.ItemsView.__qualname__ == 'ItemsView' (module-level class); verified with Python 3.14.3"]
    - [iv_name_len,   collections.abc.ItemsView.__name__.__len__,                   [],                   9,    "collections.abc.ItemsView.__name__.__len__() == 9 ('ItemsView'=9); verified with Python 3.14.3"]
    - [kv_name_eq,    collections.abc.KeysView.__name__.__eq__,                     ["KeysView"],         true, "collections.abc.KeysView.__name__ == 'KeysView'; verified with Python 3.14.3"]
    - [kv_mod_eq,     collections.abc.KeysView.__module__.__eq__,                   ["collections.abc"],  true, "collections.abc.KeysView.__module__ == 'collections.abc' (same as ItemsView); verified with Python 3.14.3"]
    - [kv_base0_eq,   "collections.abc.KeysView.__bases__[0].__name__.__eq__",      ["MappingView"],      true, "collections.abc.KeysView.__bases__[0].__name__ == 'MappingView'; verified with Python 3.14.3"]
    - [kv_mro_len,    collections.abc.KeysView.__mro__.__len__,                     [],                   8,    "collections.abc.KeysView.__mro__.__len__() == 8 — [KeysView, MappingView, Set, Collection, Sized, Iterable, Container, object]; verified with Python 3.14.3"]
    - [kv_qn_eq,      collections.abc.KeysView.__qualname__.__eq__,                 ["KeysView"],         true, "collections.abc.KeysView.__qualname__ == 'KeysView' (module-level class); verified with Python 3.14.3"]
    - [kv_name_len,   collections.abc.KeysView.__name__.__len__,                    [],                   8,    "collections.abc.KeysView.__name__.__len__() == 8 ('KeysView'=8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# collections.abc.ValuesView and MappingView class identity — extra274
#
# collections.abc.ValuesView.__name__                  == 'ValuesView'
# collections.abc.ValuesView.__module__                == 'collections.abc'
# collections.abc.ValuesView.__bases__[0].__name__     == 'MappingView'
# collections.abc.ValuesView.__mro__.__len__()         == 7
# collections.abc.MappingView.__name__                 == 'MappingView'
# collections.abc.MappingView.__module__               == 'collections.abc'
# collections.abc.MappingView.__bases__[0].__name__    == 'Sized'
# collections.abc.MappingView.__mro__.__len__()        == 3
# ---------------------------------------------------------------------------

table abc_extra274.cabc_values_mapping_view_identity:
  description: "collections.abc.ValuesView and MappingView class identity checks in cabcview274a namespace — ValuesView inherits from MappingView and Collection (unlike ItemsView and KeysView which inherit from MappingView and Set); ValuesView.__name__.__eq__('ValuesView')==True; ValuesView.__module__.__eq__('collections.abc')==True (len=15, shared with ItemsView and KeysView); ValuesView.__bases__[0].__name__.__eq__('MappingView')==True; ValuesView.__mro__.__len__()==7 ([ValuesView, MappingView, Collection, Sized, Iterable, Container, object], one element shorter than ItemsView and KeysView because ValuesView does not include Set in its MRO); ValuesView.__qualname__.__eq__('ValuesView')==True; ValuesView.__name__.__len__()==10 ('ValuesView'=10, longer than ItemsView=9 and KeysView=8); MappingView is the common base for all three view classes; MappingView.__name__.__eq__('MappingView')==True; MappingView.__module__.__eq__('collections.abc')==True; MappingView.__bases__[0].__name__.__eq__('Sized')==True (MappingView inherits from Sized, not from object directly); MappingView.__mro__.__len__()==3 ([MappingView, Sized, object]); MappingView.__qualname__.__eq__('MappingView')==True; MappingView.__name__.__len__()==11 ('MappingView'=11, longest class name in spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cabcview274a

  columns: [id, function, args, expected, description]
  rows:
    - [vv_name_eq,    collections.abc.ValuesView.__name__.__eq__,                   ["ValuesView"],       true, "collections.abc.ValuesView.__name__ == 'ValuesView'; verified with Python 3.14.3"]
    - [vv_mod_eq,     collections.abc.ValuesView.__module__.__eq__,                 ["collections.abc"],  true, "collections.abc.ValuesView.__module__ == 'collections.abc' (len=15); verified with Python 3.14.3"]
    - [vv_base0_eq,   "collections.abc.ValuesView.__bases__[0].__name__.__eq__",    ["MappingView"],      true, "collections.abc.ValuesView.__bases__[0].__name__ == 'MappingView'; verified with Python 3.14.3"]
    - [vv_mro_len,    collections.abc.ValuesView.__mro__.__len__,                   [],                   7,    "collections.abc.ValuesView.__mro__.__len__() == 7 — [ValuesView, MappingView, Collection, Sized, Iterable, Container, object]; verified with Python 3.14.3"]
    - [vv_qn_eq,      collections.abc.ValuesView.__qualname__.__eq__,               ["ValuesView"],       true, "collections.abc.ValuesView.__qualname__ == 'ValuesView'; verified with Python 3.14.3"]
    - [vv_name_len,   collections.abc.ValuesView.__name__.__len__,                  [],                   10,   "collections.abc.ValuesView.__name__.__len__() == 10 ('ValuesView'=10, longest view name in spec); verified with Python 3.14.3"]
    - [mv_name_eq,    collections.abc.MappingView.__name__.__eq__,                  ["MappingView"],      true, "collections.abc.MappingView.__name__ == 'MappingView'; verified with Python 3.14.3"]
    - [mv_mod_eq,     collections.abc.MappingView.__module__.__eq__,                ["collections.abc"],  true, "collections.abc.MappingView.__module__ == 'collections.abc' (shared base of all three view classes); verified with Python 3.14.3"]
    - [mv_base0_eq,   "collections.abc.MappingView.__bases__[0].__name__.__eq__",   ["Sized"],            true, "collections.abc.MappingView.__bases__[0].__name__ == 'Sized' (MappingView inherits from Sized, not object directly); verified with Python 3.14.3"]
    - [mv_mro_len,    collections.abc.MappingView.__mro__.__len__,                  [],                   3,    "collections.abc.MappingView.__mro__.__len__() == 3 — [MappingView, Sized, object]; verified with Python 3.14.3"]
    - [mv_qn_eq,      collections.abc.MappingView.__qualname__.__eq__,              ["MappingView"],      true, "collections.abc.MappingView.__qualname__ == 'MappingView' (module-level class); verified with Python 3.14.3"]
    - [mv_name_len,   collections.abc.MappingView.__name__.__len__,                 [],                   11,   "collections.abc.MappingView.__name__.__len__() == 11 ('MappingView'=11, longest class name in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra274
# ---------------------------------------------------------------------------

invariant abc_extra274.ItemsView_module_is_collections_abc:
  description: "collections.abc.ItemsView.__module__.__eq__('collections.abc') returns True — ItemsView is defined in Lib/_collections_abc.py and exposed as collections.abc.ItemsView; its __module__ is 'collections.abc' (len=15: 'collections'=11+'.abc'=4); ItemsView inherits from both MappingView and Set (two direct bases); ItemsView.__mro__.__len__() is 8 ([ItemsView, MappingView, Set, Collection, Sized, Iterable, Container, object]); the dual inheritance from MappingView and Set reflects that dict items support set-like operations (e.g., set intersection with other views); ItemsView.__name__.__len__() is 9 ('ItemsView'=9); NEW in extra274: first standalone ItemsView.__module__ invariant in cabcview274 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.ItemsView.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra274.ItemsView_mro_len_is_8:
  description: "collections.abc.ItemsView.__mro__.__len__() == 8 — ItemsView's MRO is [ItemsView, MappingView, Set, Collection, Sized, Iterable, Container, object] (length=8); ItemsView and KeysView share the same 8-element MRO structure (both inherit from MappingView and Set); ValuesView's MRO length is 7 (no Set in its chain); the length-8 MRO arises from inheriting both MappingView ([MappingView, Sized]) and Set ([Set, Collection, Sized, Iterable, Container]); C3 linearisation merges the shared Sized and object tails; ItemsView.__bases__[0].__name__ is 'MappingView'; ItemsView.__module__ is 'collections.abc'; NEW in extra274: first standalone ItemsView MRO length invariant in cabcview274 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.ItemsView.__mro__.__len__
  args: []
  expected: 8

invariant abc_extra274.KeysView_mro_len_is_8:
  description: "collections.abc.KeysView.__mro__.__len__() == 8 — KeysView's MRO is [KeysView, MappingView, Set, Collection, Sized, Iterable, Container, object] (length=8); KeysView and ItemsView share the same MRO length and structure (both inherit from MappingView and Set); this reflects that both key views and item views support set operations, while value views do not (ValuesView MRO length=7); KeysView.__bases__[0].__name__ is 'MappingView'; KeysView.__module__ is 'collections.abc'; KeysView.__name__.__len__() is 8 ('KeysView'=8); NEW in extra274: first standalone KeysView MRO length invariant in cabcview274 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.KeysView.__mro__.__len__
  args: []
  expected: 8

invariant abc_extra274.ValuesView_mro_len_is_7:
  description: "collections.abc.ValuesView.__mro__.__len__() == 7 — ValuesView's MRO is [ValuesView, MappingView, Collection, Sized, Iterable, Container, object] (length=7); ValuesView's MRO is one element shorter than ItemsView and KeysView (both length=8) because ValuesView does not inherit from Set (dict values do not support set operations like intersection or difference); ValuesView inherits from MappingView and Collection (not Set); ValuesView.__bases__[0].__name__ is 'MappingView'; ValuesView.__module__ is 'collections.abc'; ValuesView.__name__.__len__() is 10 ('ValuesView'=10, the longest view name in this spec); NEW in extra274: first standalone ValuesView MRO length invariant in cabcview274 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.ValuesView.__mro__.__len__
  args: []
  expected: 7

invariant abc_extra274.MappingView_base_is_Sized:
  description: "collections.abc.MappingView.__bases__[0].__name__.__eq__('Sized') returns True — MappingView inherits from Sized as its sole direct base; Sized is in collections.abc (Sized.__module__ == 'collections.abc'); MappingView's MRO is [MappingView, Sized, object] (length=3); MappingView is the common shared base of all three view classes (ItemsView, KeysView, ValuesView); MappingView.__module__ is 'collections.abc'; MappingView.__name__.__len__() is 11 ('MappingView'=11, the longest class name in this spec); the Sized base reflects that mapping views always support __len__(); NEW in extra274: first standalone MappingView base class invariant in cabcview274 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "collections.abc.MappingView.__bases__[0].__name__.__eq__"
  args: ["Sized"]
  expected: true

invariant abc_extra274.MappingView_mro_len_is_3:
  description: "collections.abc.MappingView.__mro__.__len__() == 3 — MappingView's MRO is [MappingView, Sized, object] (length=3); this is the shortest MRO among all classes in this spec; compare MRO depths: MappingView=3, ValuesView=7, ItemsView=8, KeysView=8; MappingView is the base of all three view classes but itself has a simple 3-element chain; MappingView.__bases__[0].__name__ is 'Sized'; MappingView.__module__ is 'collections.abc'; MappingView.__qualname__ is 'MappingView'; NEW in extra274: first standalone MappingView MRO length invariant in cabcview274 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: collections.abc.MappingView.__mro__.__len__
  args: []
  expected: 3
