spec: threading_extra179
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread method names — threading.Thread.start.__name__=='start' (len=5); threading.Thread.run.__name__=='run' (len=3); threading.Thread.join.__name__=='join' (len=4); threading.Thread.is_alive.__name__=='is_alive' (len=8); threading.Thread.getName.__name__=='getName' (len=7); threading.Thread.setName.__name__=='setName' (len=7; same as getName); threading.Thread.isDaemon.__name__=='isDaemon' (len=8; same as is_alive); threading.Thread.setDaemon.__name__=='setDaemon' (len=9)."
    - "threading.Thread.start.__name__ == 'start' — start is a Python method on threading.Thread in Lib/threading.py that starts the thread's activity by arranging for the thread's run() method to be invoked; its __name__ is 'start', 5 characters. Verified with Python 3.14.3."
    - "threading.Thread.run.__name__ == 'run' — run is a Python method on threading.Thread in Lib/threading.py that represents the thread's activity; it may be overridden in a subclass; its __name__ is 'run', 3 characters, the shortest Thread method name. Verified with Python 3.14.3."
    - "threading.Thread.join.__name__ == 'join' — join is a Python method on threading.Thread in Lib/threading.py that waits until the thread terminates; its __name__ is 'join', 4 characters. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__name__ == 'is_alive' — is_alive is a Python method on threading.Thread in Lib/threading.py returning True if the thread is alive; its __name__ is 'is_alive', 8 characters. Verified with Python 3.14.3."
    - "threading.Thread.getName.__name__ == 'getName' — getName is a deprecated Python method on threading.Thread in Lib/threading.py returning the thread name (use .name instead); its __name__ is 'getName', 7 characters. Verified with Python 3.14.3."
    - "threading.Thread.setName.__name__ == 'setName' — setName is a deprecated Python method on threading.Thread in Lib/threading.py setting the thread name (use .name instead); its __name__ is 'setName', 7 characters, same length as 'getName'. Verified with Python 3.14.3."
    - "threading.Thread.isDaemon.__name__ == 'isDaemon' — isDaemon is a deprecated Python method on threading.Thread in Lib/threading.py returning whether the thread is a daemon thread (use .daemon instead); its __name__ is 'isDaemon', 8 characters, same length as 'is_alive'. Verified with Python 3.14.3."
    - "threading.Thread.setDaemon.__name__ == 'setDaemon' — setDaemon is a deprecated Python method on threading.Thread in Lib/threading.py setting whether the thread is a daemon thread (use .daemon instead); its __name__ is 'setDaemon', 9 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread.start, .run, and .join __name__
#
# threading.Thread.start.__name__ == 'start'
# threading.Thread.start.__name__.__len__() == 5
# threading.Thread.run.__name__ == 'run'
# threading.Thread.run.__name__.__len__() == 3
# threading.Thread.join.__name__ == 'join'
#
# start initiates the thread's activity (5 chars). run is the thread body
# method that may be overridden (3 chars — the shortest Thread method name).
# join blocks until the thread finishes (4 chars). New to extra179.
# ---------------------------------------------------------------------------

table threading_extra179.thread_start_run_join_name:
  description: "threading.Thread.start.__name__ 'start' len 5; run.__name__ 'run' len 3 (shortest); join.__name__ 'join' len 4; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: threadingthread179

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_name_eq,
       "Thread.start.__name__.__eq__",
       ["start"],
       true,
       "threading.Thread.start.__name__.__eq__('start') == True — threading.Thread.start is a Python method in Lib/threading.py that starts the thread's activity by arranging for the thread's run() method to be invoked in a separate thread of control; its __name__ is 'start'; str.__eq__('start') returns True; new to extra179"]
    - [thread_start_name_len_5,
       "Thread.start.__name__.__len__",
       [],
       5,
       "threading.Thread.start.__name__.__len__() == 5 — the name 'start' has exactly 5 characters: s-t-a-r-t; str.__len__() returns 5; new to extra179"]
    - [thread_run_name_eq,
       "Thread.run.__name__.__eq__",
       ["run"],
       true,
       "threading.Thread.run.__name__.__eq__('run') == True — threading.Thread.run is a Python method in Lib/threading.py representing the thread's activity; it invokes the callable passed as the target argument or may be overridden in a subclass; its __name__ is 'run'; str.__eq__('run') returns True; new to extra179"]
    - [thread_join_name_eq,
       "Thread.join.__name__.__eq__",
       ["join"],
       true,
       "threading.Thread.join.__name__.__eq__('join') == True — threading.Thread.join is a Python method in Lib/threading.py that blocks the calling thread until the thread on which it is called terminates or the optional timeout expires; its __name__ is 'join'; str.__eq__('join') returns True; new to extra179"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.run name length, .join name length, and .is_alive __name__
#
# threading.Thread.run.__name__.__len__() == 3
# threading.Thread.join.__name__.__len__() == 4
# threading.Thread.is_alive.__name__ == 'is_alive'
# threading.Thread.is_alive.__name__.__len__() == 8
#
# run has __name__ 'run' (3 chars — shortest). join has __name__ 'join' (4
# chars). is_alive has __name__ 'is_alive' (8 chars). New to extra179.
# ---------------------------------------------------------------------------

table threading_extra179.thread_run_len_join_len_is_alive_name:
  description: "threading.Thread.run.__name__ len 3 (shortest); join.__name__ len 4; is_alive.__name__ 'is_alive' len 8; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: threadingthread179

  columns: [id, function, args, expected, description]
  rows:
    - [thread_run_name_len_3,
       "Thread.run.__name__.__len__",
       [],
       3,
       "threading.Thread.run.__name__.__len__() == 3 — the name 'run' has exactly 3 characters: r-u-n; this is the shortest name among the threading.Thread methods covered in this spec; str.__len__() returns 3; new to extra179"]
    - [thread_join_name_len_4,
       "Thread.join.__name__.__len__",
       [],
       4,
       "threading.Thread.join.__name__.__len__() == 4 — the name 'join' has exactly 4 characters: j-o-i-n; str.__len__() returns 4; new to extra179"]
    - [thread_is_alive_name_eq,
       "Thread.is_alive.__name__.__eq__",
       ["is_alive"],
       true,
       "threading.Thread.is_alive.__name__.__eq__('is_alive') == True — threading.Thread.is_alive is a Python method in Lib/threading.py that returns True if the thread is alive (i.e., has been started and has not yet terminated); its __name__ is 'is_alive'; str.__eq__('is_alive') returns True; new to extra179"]
    - [thread_is_alive_name_len_8,
       "Thread.is_alive.__name__.__len__",
       [],
       8,
       "threading.Thread.is_alive.__name__.__len__() == 8 — the name 'is_alive' has exactly 8 characters: i-s-_-a-l-i-v-e; str.__len__() returns 8; new to extra179"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread.getName and .setName __name__
#
# threading.Thread.getName.__name__ == 'getName'
# threading.Thread.getName.__name__.__len__() == 7
# threading.Thread.setName.__name__ == 'setName'
# threading.Thread.setName.__name__.__len__() == 7
#
# getName is a deprecated method returning the thread name; its __name__ is
# 'getName' (7 chars). setName is a deprecated method setting the thread name;
# its __name__ is 'setName' (7 chars — same length as 'getName'). New to extra179.
# ---------------------------------------------------------------------------

table threading_extra179.thread_getname_and_setname_name:
  description: "threading.Thread.getName.__name__ 'getName' len 7; setName.__name__ 'setName' len 7 (same); new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: threadingthread179

  columns: [id, function, args, expected, description]
  rows:
    - [thread_getname_name_eq,
       "Thread.getName.__name__.__eq__",
       ["getName"],
       true,
       "threading.Thread.getName.__name__.__eq__('getName') == True — threading.Thread.getName is a deprecated Python method in Lib/threading.py that returns the thread's name (the .name property is preferred); its __name__ is 'getName'; str.__eq__('getName') returns True; new to extra179"]
    - [thread_getname_name_len_7,
       "Thread.getName.__name__.__len__",
       [],
       7,
       "threading.Thread.getName.__name__.__len__() == 7 — the name 'getName' has exactly 7 characters: g-e-t-N-a-m-e; str.__len__() returns 7; new to extra179"]
    - [thread_setname_name_eq,
       "Thread.setName.__name__.__eq__",
       ["setName"],
       true,
       "threading.Thread.setName.__name__.__eq__('setName') == True — threading.Thread.setName is a deprecated Python method in Lib/threading.py that sets the thread's name (the .name property is preferred); its __name__ is 'setName'; str.__eq__('setName') returns True; new to extra179"]
    - [thread_setname_name_len_7,
       "Thread.setName.__name__.__len__",
       [],
       7,
       "threading.Thread.setName.__name__.__len__() == 7 — the name 'setName' has exactly 7 characters: s-e-t-N-a-m-e; same length as 'getName' (7); str.__len__() returns 7; new to extra179"]

# ---------------------------------------------------------------------------
# Table 4: threading.Thread.isDaemon and .setDaemon __name__
#
# threading.Thread.isDaemon.__name__ == 'isDaemon'
# threading.Thread.isDaemon.__name__.__len__() == 8
# threading.Thread.setDaemon.__name__ == 'setDaemon'
# threading.Thread.setDaemon.__name__.__len__() == 9
#
# isDaemon is a deprecated method returning whether the thread is a daemon
# thread; its __name__ is 'isDaemon' (8 chars — same length as 'is_alive').
# setDaemon is a deprecated method setting daemon status; its __name__ is
# 'setDaemon' (9 chars). New to extra179.
# ---------------------------------------------------------------------------

table threading_extra179.thread_isdaemon_and_setdaemon_name:
  description: "threading.Thread.isDaemon.__name__ 'isDaemon' len 8 (same as is_alive); setDaemon.__name__ 'setDaemon' len 9; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: threadingthread179

  columns: [id, function, args, expected, description]
  rows:
    - [thread_isdaemon_name_eq,
       "Thread.isDaemon.__name__.__eq__",
       ["isDaemon"],
       true,
       "threading.Thread.isDaemon.__name__.__eq__('isDaemon') == True — threading.Thread.isDaemon is a deprecated Python method in Lib/threading.py that returns True if the thread is a daemon thread (the .daemon property is preferred); its __name__ is 'isDaemon'; str.__eq__('isDaemon') returns True; new to extra179"]
    - [thread_isdaemon_name_len_8,
       "Thread.isDaemon.__name__.__len__",
       [],
       8,
       "threading.Thread.isDaemon.__name__.__len__() == 8 — the name 'isDaemon' has exactly 8 characters: i-s-D-a-e-m-o-n; same length as 'is_alive' (8); str.__len__() returns 8; new to extra179"]
    - [thread_setdaemon_name_eq,
       "Thread.setDaemon.__name__.__eq__",
       ["setDaemon"],
       true,
       "threading.Thread.setDaemon.__name__.__eq__('setDaemon') == True — threading.Thread.setDaemon is a deprecated Python method in Lib/threading.py that sets whether the thread is a daemon thread (the .daemon property is preferred); its __name__ is 'setDaemon'; str.__eq__('setDaemon') returns True; new to extra179"]
    - [thread_setdaemon_name_len_9,
       "Thread.setDaemon.__name__.__len__",
       [],
       9,
       "threading.Thread.setDaemon.__name__.__len__() == 9 — the name 'setDaemon' has exactly 9 characters: s-e-t-D-a-e-m-o-n; str.__len__() returns 9; new to extra179"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra179
# ---------------------------------------------------------------------------

invariant threading_extra179.thread_start_name_start:
  description: "threading.Thread.start.__name__ == 'start' — Python method in Lib/threading.py with __name__ 'start' (5 chars); new to extra179"
  kind: python_call_eq
  function: Thread.start.__name__.__eq__
  args: ["start"]
  expected: true

invariant threading_extra179.thread_run_name_run:
  description: "threading.Thread.run.__name__ == 'run' — Python method in Lib/threading.py with __name__ 'run' (3 chars, shortest Thread method name); new to extra179"
  kind: python_call_eq
  function: Thread.run.__name__.__eq__
  args: ["run"]
  expected: true

invariant threading_extra179.thread_run_name_len_3:
  description: "threading.Thread.run.__name__.__len__() == 3 — 'run' is 3 characters long; new to extra179"
  kind: python_call_eq
  function: Thread.run.__name__.__len__
  args: []
  expected: 3

invariant threading_extra179.thread_join_name_join:
  description: "threading.Thread.join.__name__ == 'join' — Python method in Lib/threading.py with __name__ 'join' (4 chars); new to extra179"
  kind: python_call_eq
  function: Thread.join.__name__.__eq__
  args: ["join"]
  expected: true

invariant threading_extra179.thread_is_alive_name_is_alive:
  description: "threading.Thread.is_alive.__name__ == 'is_alive' — Python method in Lib/threading.py with __name__ 'is_alive' (8 chars); new to extra179"
  kind: python_call_eq
  function: Thread.is_alive.__name__.__eq__
  args: ["is_alive"]
  expected: true

invariant threading_extra179.thread_getname_name_getname:
  description: "threading.Thread.getName.__name__ == 'getName' — deprecated Python method in Lib/threading.py with __name__ 'getName' (7 chars); new to extra179"
  kind: python_call_eq
  function: Thread.getName.__name__.__eq__
  args: ["getName"]
  expected: true

invariant threading_extra179.thread_setname_name_setname:
  description: "threading.Thread.setName.__name__ == 'setName' — deprecated Python method in Lib/threading.py with __name__ 'setName' (7 chars, same as getName); new to extra179"
  kind: python_call_eq
  function: Thread.setName.__name__.__eq__
  args: ["setName"]
  expected: true

invariant threading_extra179.thread_isdaemon_name_isdaemon:
  description: "threading.Thread.isDaemon.__name__ == 'isDaemon' — deprecated Python method in Lib/threading.py with __name__ 'isDaemon' (8 chars, same as is_alive); new to extra179"
  kind: python_call_eq
  function: Thread.isDaemon.__name__.__eq__
  args: ["isDaemon"]
  expected: true

invariant threading_extra179.thread_setdaemon_name_setdaemon:
  description: "threading.Thread.setDaemon.__name__ == 'setDaemon' — deprecated Python method in Lib/threading.py with __name__ 'setDaemon' (9 chars); new to extra179"
  kind: python_call_eq
  function: Thread.setDaemon.__name__.__eq__
  args: ["setDaemon"]
  expected: true

invariant threading_extra179.thread_setdaemon_name_len_9:
  description: "threading.Thread.setDaemon.__name__.__len__() == 9 — 'setDaemon' is 9 characters long; new to extra179"
  kind: python_call_eq
  function: Thread.setDaemon.__name__.__len__
  args: []
  expected: 9
