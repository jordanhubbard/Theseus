spec: re_extra191
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "re.error.__name__ == 'PatternError' (len=12); re.error is aliased to re.PatternError in Python 3.13+."
    - "re.error.__module__ == 're'."
    - "re.error.__qualname__ == 'PatternError'."
    - "re.error.__bases__[0].__name__ == 'Exception'; single base class."
    - "re.PatternError.__name__ == 'PatternError' (len=12); re.error is re.PatternError is True."
    - "re.PatternError.__module__ == 're'."
    - "re.PatternError.__bases__[0].__name__ == 'Exception'."
    - "re.PatternError.__qualname__ == 'PatternError'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.error class identity — name, module, qualname
# re.error is aliased to re.PatternError in Python 3.13+
# ---------------------------------------------------------------------------

table re_extra191.re_error_identity:
  description: "re.error class identity: __name__='PatternError'(12), __module__='re', __qualname__='PatternError'; re.error is re.PatternError in Python 3.13+"
  kind: python_call_eq
  category: identity
  id_prefix: repaerror191

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,     re.error.__name__.__eq__,     ["PatternError"], true, "re.error.__name__ == 'PatternError'; alias to PatternError in Python 3.13+; confirmed Python 3.14.3 macOS"]
    - [error_name_len,    re.error.__name__.__len__,    [],               12,   "re.error.__name__.__len__() == 12 — P(1)a(2)t(3)t(4)e(5)r(6)n(7)E(8)r(9)r(10)o(11)r(12); confirmed Python 3.14.3 macOS"]
    - [error_module_eq,   re.error.__module__.__eq__,   ["re"],           true, "re.error.__module__ == 're'; confirmed Python 3.14.3 macOS"]
    - [error_qualname_eq, re.error.__qualname__.__eq__, ["PatternError"], true, "re.error.__qualname__ == 'PatternError'; confirmed Python 3.14.3 macOS"]
    - [error_base_eq,     "re.error.__bases__[0].__name__.__eq__",        ["Exception"], true, "re.error.__bases__[0].__name__ == 'Exception'; single direct base; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.PatternError class identity — name, module, qualname
# re.PatternError is the canonical name; re.error is re.PatternError
# ---------------------------------------------------------------------------

table re_extra191.re_patternerror_identity:
  description: "re.PatternError class identity: __name__='PatternError'(12), __module__='re', __qualname__='PatternError'; canonical name since Python 3.13"
  kind: python_call_eq
  category: identity
  id_prefix: repaerror191

  columns: [id, function, args, expected, description]
  rows:
    - [pe_name_eq,     re.PatternError.__name__.__eq__,     ["PatternError"], true, "re.PatternError.__name__ == 'PatternError'; confirmed Python 3.14.3 macOS"]
    - [pe_name_len,    re.PatternError.__name__.__len__,    [],               12,   "re.PatternError.__name__.__len__() == 12; matches re.error.__name__.__len__(); confirmed Python 3.14.3 macOS"]
    - [pe_module_eq,   re.PatternError.__module__.__eq__,   ["re"],           true, "re.PatternError.__module__ == 're'; confirmed Python 3.14.3 macOS"]
    - [pe_qualname_eq, re.PatternError.__qualname__.__eq__, ["PatternError"], true, "re.PatternError.__qualname__ == 'PatternError'; confirmed Python 3.14.3 macOS"]
    - [pe_base_eq,     "re.PatternError.__bases__[0].__name__.__eq__",        ["Exception"], true, "re.PatternError.__bases__[0].__name__ == 'Exception'; single direct base; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.error vs re.PatternError length cross-check
# Both have __name__ len=12; module name 're' has len=2
# ---------------------------------------------------------------------------

table re_extra191.re_error_lengths:
  description: "re.error and re.PatternError name length cross-check: both __name__ len=12; __module__ 're' len=2; __qualname__ len=12"
  kind: python_call_eq
  category: identity
  id_prefix: repaerror191

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_len2,    re.error.__name__.__len__,           [], 12, "re.error.__name__.__len__() == 12; cross-check with re.PatternError; confirmed Python 3.14.3 macOS"]
    - [pe_name_len2,       re.PatternError.__name__.__len__,    [], 12, "re.PatternError.__name__.__len__() == 12; identical to re.error; confirmed Python 3.14.3 macOS"]
    - [error_module_len,   re.error.__module__.__len__,         [], 2,  "re.error.__module__.__len__() == 2 — r(1)e(2); module name 're'; confirmed Python 3.14.3 macOS"]
    - [error_qualname_len, re.error.__qualname__.__len__,       [], 12, "re.error.__qualname__.__len__() == 12; qualname matches __name__; confirmed Python 3.14.3 macOS"]
    - [pe_module_len,      re.PatternError.__module__.__len__,  [], 2,  "re.PatternError.__module__.__len__() == 2 — 're'; same as re.error.__module__; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra191.error_name_eq:
  description: "re.error.__name__ == 'PatternError' — re.error is aliased to PatternError in Python 3.13+, length 12; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra191.error_module_eq:
  description: "re.error.__module__ == 're' — error class lives in the re module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra191.error_qualname_eq:
  description: "re.error.__qualname__ == 'PatternError' — qualname equals canonical class name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__qualname__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra191.error_base_eq:
  description: "re.error.__bases__[0].__name__ == 'Exception' — re.error has a single direct base class Exception; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant re_extra191.patternerror_name_eq:
  description: "re.PatternError.__name__ == 'PatternError' — canonical exception class name since Python 3.13, length 12; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra191.patternerror_module_eq:
  description: "re.PatternError.__module__ == 're' — PatternError lives in the re module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.PatternError.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra191.patternerror_base_eq:
  description: "re.PatternError.__bases__[0].__name__ == 'Exception' — PatternError has a single direct base class Exception; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.PatternError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant re_extra191.patternerror_qualname_eq:
  description: "re.PatternError.__qualname__ == 'PatternError' — qualname matches __name__ for top-level class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.PatternError.__qualname__.__eq__
  args: ["PatternError"]
  expected: true
