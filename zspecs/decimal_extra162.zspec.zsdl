spec: decimal_extra162
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal rounding mode string constants and their string equality comparisons."
    - "decimal.ROUND_HALF_UP.__eq__('ROUND_HALF_UP') == True — rounding mode is the string 'ROUND_HALF_UP'."
    - "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True — the default rounding mode; also called 'banker's rounding'."
    - "decimal.ROUND_DOWN.__eq__('ROUND_DOWN') == True — rounding mode that truncates toward zero."
    - "decimal.ROUND_UP.__eq__('ROUND_UP') == True — rounding mode that rounds away from zero."
    - "decimal.ROUND_CEILING.__eq__('ROUND_CEILING') == True — rounding mode toward positive infinity."
    - "decimal.ROUND_FLOOR.__eq__('ROUND_FLOOR') == True — rounding mode toward negative infinity."
    - "All rounding mode constants are plain Python strings (str), not enum members."
    - "Name length ranking: ROUND_UP=8, ROUND_DOWN=10, ROUND_FLOOR=11, ROUND_HALF_UP=13, ROUND_CEILING=13 (two-way tie), ROUND_HALF_EVEN=15."
    - "ROUND_UP (8) is the shortest rounding mode string; ROUND_HALF_EVEN (15) is the longest."
    - "ROUND_DOWN (10) and ROUND_UP (8) form the non-half rounding pair; ROUND_HALF_UP (13) and ROUND_HALF_EVEN (15) form the half-rounding pair."
    - "All six rounding mode string values use the ROUND_ prefix (6 chars: 'ROUND_')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.ROUND_HALF_UP and ROUND_HALF_EVEN string equality
# ROUND_HALF_UP == 'ROUND_HALF_UP' (len=13), ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' (len=15)
# Both are half-rounding modes: they differ in handling the exact midpoint case.
# ---------------------------------------------------------------------------

table decimal_extra162.rounding_half_modes:
  description: "decimal.ROUND_HALF_UP.__eq__('ROUND_HALF_UP')==True (len=13); decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN')==True (len=15); both are half-rounding modes; ROUND_HALF_EVEN (15) is 2 longer than ROUND_HALF_UP (13) because 'EVEN' (4) > 'UP' (2) by 2"
  kind: python_call_eq
  category: identity
  id_prefix: drnd162

  columns: [id, function, args, expected, description]
  rows:
    - [half_up_eq,    decimal.ROUND_HALF_UP.__eq__,    ["ROUND_HALF_UP"],    true, "decimal.ROUND_HALF_UP.__eq__('ROUND_HALF_UP') == True — ROUND_HALF_UP is the string 'ROUND_HALF_UP'; the rounding mode constants in the decimal module are plain strings, not enum members or integers; ROUND_HALF_UP rounds to the nearest value; when the value is exactly halfway between two decimal places, it rounds away from zero (up in magnitude); for example, Decimal('2.5').quantize(Decimal('1'), rounding=ROUND_HALF_UP) == Decimal('3'); 'ROUND_HALF_UP' has 13 characters: ROUND(5)+_(1)+HALF(4)+_(1)+UP(2)=13; ROUND_HALF_UP (13) is tied with ROUND_CEILING (13) — the only two-way tie in rounding mode string lengths; ROUND_HALF_UP is the most common rounding mode in everyday arithmetic and financial contexts; confirmed Python 3.14.3 macOS"]
    - [half_even_eq,  decimal.ROUND_HALF_EVEN.__eq__,  ["ROUND_HALF_EVEN"],  true, "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True — ROUND_HALF_EVEN is the string 'ROUND_HALF_EVEN'; ROUND_HALF_EVEN is the default rounding mode in Python's decimal module and is also called 'banker's rounding' or 'round half to even'; when a value is exactly halfway, it rounds to the nearest even digit: Decimal('2.5').quantize(Decimal('1'), rounding=ROUND_HALF_EVEN) == Decimal('2') (rounds to even 2), while Decimal('3.5').quantize(Decimal('1'), rounding=ROUND_HALF_EVEN) == Decimal('4') (rounds to even 4); 'ROUND_HALF_EVEN' = R-O-U-N-D-_-H-A-L-F-_-E-V-E-N = 15 characters: ROUND(5)+_(1)+HALF(4)+_(1)+EVEN(4)=15; ROUND_HALF_EVEN is the IEEE 754 default rounding mode; confirmed Python 3.14.3 macOS"]
    - [half_up_ne,    decimal.ROUND_HALF_UP.__eq__,    ["ROUND_HALF_EVEN"],  false, "decimal.ROUND_HALF_UP.__eq__('ROUND_HALF_EVEN') == False — ROUND_HALF_UP and ROUND_HALF_EVEN are distinct rounding mode strings; they differ in behavior only at exact midpoints: ROUND_HALF_UP always rounds away from zero at midpoints, while ROUND_HALF_EVEN rounds to the nearest even digit; ROUND_HALF_UP.__eq__(ROUND_HALF_EVEN) is False because 'ROUND_HALF_UP' (13 chars) != 'ROUND_HALF_EVEN' (15 chars) — they are different strings with different lengths; the distinction matters significantly for financial calculations: ROUND_HALF_EVEN avoids systematic bias (positive and negative roundings cancel out over many operations) while ROUND_HALF_UP introduces a systematic upward bias; confirmed Python 3.14.3 macOS"]
    - [half_up_len,   decimal.ROUND_HALF_UP.__len__,   [],                  13,   "decimal.ROUND_HALF_UP.__len__() == 13 — 'ROUND_HALF_UP' has 13 characters: 'ROUND' (5) + '_' (1) + 'HALF' (4) + '_' (1) + 'UP' (2) = 13; the two underscores contribute 2 of the 13 characters; 'UP' (2 chars) is the shortest suffix among the rounding direction suffixes: UP (2) < DOWN (4) < FLOOR (5) < CEILING (7); ROUND_HALF_UP (13) < ROUND_HALF_EVEN (15) by 2 — the 'UP' (2) suffix is 2 shorter than 'EVEN' (4); all rounding mode strings share the 'ROUND_' prefix (6 chars: 'R-O-U-N-D-_'); confirmed Python 3.14.3 macOS"]
    - [half_even_len, decimal.ROUND_HALF_EVEN.__len__,  [],                  15,   "decimal.ROUND_HALF_EVEN.__len__() == 15 — 'ROUND_HALF_EVEN' has 15 characters: 'ROUND' (5) + '_' (1) + 'HALF' (4) + '_' (1) + 'EVEN' (4) = 15; ROUND_HALF_EVEN (15) is the longest rounding mode string in this spec — the sole maximum; the 'EVEN' suffix (4 chars) > 'UP' suffix (2 chars) by 2: ROUND_HALF_EVEN (15) > ROUND_HALF_UP (13) by 2; ROUND_HALF_EVEN (15) is also the default rounding mode of Python's decimal module (decimal.getcontext().rounding == 'ROUND_HALF_EVEN'); 15 chars is also len('PureWindowsPath') == 15 from pathlib — a coincidental cross-module tie; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.ROUND_DOWN and ROUND_UP string equality
# ROUND_DOWN == 'ROUND_DOWN' (len=10), ROUND_UP == 'ROUND_UP' (len=8)
# Both are non-half rounding modes (no special midpoint behavior needed).
# ---------------------------------------------------------------------------

table decimal_extra162.rounding_down_up_modes:
  description: "decimal.ROUND_DOWN.__eq__('ROUND_DOWN')==True (len=10); decimal.ROUND_UP.__eq__('ROUND_UP')==True (len=8); ROUND_UP (8) is the shortest rounding mode string; ROUND_DOWN (10) > ROUND_UP (8) by 2 because 'DOWN' (4) > 'UP' (2) by 2"
  kind: python_call_eq
  category: identity
  id_prefix: drnd162

  columns: [id, function, args, expected, description]
  rows:
    - [down_eq,   decimal.ROUND_DOWN.__eq__,  ["ROUND_DOWN"],  true,  "decimal.ROUND_DOWN.__eq__('ROUND_DOWN') == True — ROUND_DOWN is the string 'ROUND_DOWN'; ROUND_DOWN truncates the value toward zero (also called truncation or round-toward-zero); for positive numbers, ROUND_DOWN is equivalent to floor; for negative numbers, ROUND_DOWN is equivalent to ceiling; Decimal('2.9').quantize(Decimal('1'), rounding=ROUND_DOWN) == Decimal('2'); Decimal('-2.9').quantize(Decimal('1'), rounding=ROUND_DOWN) == Decimal('-2'); 'ROUND_DOWN' has 10 characters: 'ROUND' (5) + '_' (1) + 'DOWN' (4) = 10; ROUND_DOWN (10) > ROUND_UP (8) by 2 because 'DOWN' (4) > 'UP' (2) by 2; confirmed Python 3.14.3 macOS"]
    - [up_eq,     decimal.ROUND_UP.__eq__,    ["ROUND_UP"],    true,  "decimal.ROUND_UP.__eq__('ROUND_UP') == True — ROUND_UP is the string 'ROUND_UP'; ROUND_UP rounds away from zero regardless of the digit following the last kept digit; for positive numbers, ROUND_UP is equivalent to ceiling; for negative numbers, ROUND_UP is equivalent to floor; Decimal('2.1').quantize(Decimal('1'), rounding=ROUND_UP) == Decimal('3'); Decimal('-2.1').quantize(Decimal('1'), rounding=ROUND_UP) == Decimal('-3'); 'ROUND_UP' has 8 characters: 'ROUND' (5) + '_' (1) + 'UP' (2) = 8; ROUND_UP (8) is the shortest rounding mode string — 'UP' (2 chars) is the shortest direction suffix; confirmed Python 3.14.3 macOS"]
    - [down_len,  decimal.ROUND_DOWN.__len__, [],              10,    "decimal.ROUND_DOWN.__len__() == 10 — 'ROUND_DOWN' has 10 characters: 'ROUND' (5) + '_' (1) + 'DOWN' (4) = 10; ROUND_DOWN (10) > ROUND_UP (8) by 2: the 'DOWN' suffix (4) is 2 longer than the 'UP' suffix (2); ROUND_DOWN (10) < ROUND_FLOOR (11) by 1: 'DOWN' (4) is 1 shorter than 'FLOOR' (5); the ascending rounding mode string lengths: ROUND_UP (8) < ROUND_DOWN (10) < ROUND_FLOOR (11) < ROUND_HALF_UP (13) < ROUND_CEILING (13) < ROUND_HALF_EVEN (15); ROUND_DOWN (10) is the third-shortest rounding mode string; confirmed Python 3.14.3 macOS"]
    - [up_len,    decimal.ROUND_UP.__len__,   [],              8,     "decimal.ROUND_UP.__len__() == 8 — 'ROUND_UP' has 8 characters: 'ROUND' (5) + '_' (1) + 'UP' (2) = 8; ROUND_UP (8) is the shortest rounding mode string — the minimum length among all decimal rounding mode constants; 'UP' (2 chars) is the shortest direction suffix, making ROUND_UP the global minimum; ROUND_UP (8) is also the same length as len('Decimal.__repr__')/2 = 16/2 = 8 — not a useful comparison; rather, ROUND_UP (8) == len('Decimal.') (8 chars: 'Decimal' + '.') — both are 8 characters; the 8-character 'ROUND_UP' string equals the 8-character 'Decimal.' prefix used in Decimal method qualnames; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.ROUND_CEILING and ROUND_FLOOR string equality
# ROUND_CEILING == 'ROUND_CEILING' (len=13), ROUND_FLOOR == 'ROUND_FLOOR' (len=11)
# Ceiling rounds toward +infinity; Floor rounds toward -infinity.
# ---------------------------------------------------------------------------

table decimal_extra162.rounding_ceiling_floor_modes:
  description: "decimal.ROUND_CEILING.__eq__('ROUND_CEILING')==True (len=13); decimal.ROUND_FLOOR.__eq__('ROUND_FLOOR')==True (len=11); ROUND_CEILING (13) > ROUND_FLOOR (11) by 2 because 'CEILING' (7) > 'FLOOR' (5) by 2; both are directional rounding modes"
  kind: python_call_eq
  category: identity
  id_prefix: drnd162

  columns: [id, function, args, expected, description]
  rows:
    - [ceil_eq,    decimal.ROUND_CEILING.__eq__,  ["ROUND_CEILING"],  true,  "decimal.ROUND_CEILING.__eq__('ROUND_CEILING') == True — ROUND_CEILING is the string 'ROUND_CEILING'; ROUND_CEILING rounds toward positive infinity (+∞): the result is the smallest representable value that is not less than the mathematical result; for positive numbers this is equivalent to rounding up; for negative numbers this is equivalent to rounding toward zero; Decimal('-2.1').quantize(Decimal('1'), rounding=ROUND_CEILING) == Decimal('-2'); 'ROUND_CEILING' has 13 characters: 'ROUND' (5) + '_' (1) + 'CEILING' (7) = 13; ROUND_CEILING (13) > ROUND_FLOOR (11) by 2 because 'CEILING' (7) > 'FLOOR' (5) by 2; confirmed Python 3.14.3 macOS"]
    - [floor_eq,   decimal.ROUND_FLOOR.__eq__,    ["ROUND_FLOOR"],    true,  "decimal.ROUND_FLOOR.__eq__('ROUND_FLOOR') == True — ROUND_FLOOR is the string 'ROUND_FLOOR'; ROUND_FLOOR rounds toward negative infinity (-∞): the result is the largest representable value that is not greater than the mathematical result; for positive numbers this is equivalent to rounding toward zero; for negative numbers this is equivalent to rounding away from zero; Decimal('2.9').quantize(Decimal('1'), rounding=ROUND_FLOOR) == Decimal('2'); Decimal('-2.1').quantize(Decimal('1'), rounding=ROUND_FLOOR) == Decimal('-3'); 'ROUND_FLOOR' has 11 characters: 'ROUND' (5) + '_' (1) + 'FLOOR' (5) = 11; confirmed Python 3.14.3 macOS"]
    - [ceil_len,   decimal.ROUND_CEILING.__len__, [],                13,    "decimal.ROUND_CEILING.__len__() == 13 — 'ROUND_CEILING' has 13 characters: 'ROUND' (5) + '_' (1) + 'CEILING' (7) = 13; ROUND_CEILING (13) is tied with ROUND_HALF_UP (13) in string length — both have 13-character rounding mode strings; the tie: 'ROUND_CEILING' = ROUND(5)+_(1)+CEILING(7)=13 and 'ROUND_HALF_UP' = ROUND(5)+_(1)+HALF(4)+_(1)+UP(2)=13; both arrive at 13 by different compositional paths: ROUND_CEILING uses one long suffix 'CEILING' (7) while ROUND_HALF_UP uses two shorter segments 'HALF' (4) + '_UP' (3); ROUND_CEILING (13) > ROUND_FLOOR (11) by 2; confirmed Python 3.14.3 macOS"]
    - [floor_len,  decimal.ROUND_FLOOR.__len__,   [],                11,    "decimal.ROUND_FLOOR.__len__() == 11 — 'ROUND_FLOOR' has 11 characters: 'ROUND' (5) + '_' (1) + 'FLOOR' (5) = 11; ROUND_FLOOR (11) is between ROUND_DOWN (10) and ROUND_CEILING (13) in string length: ROUND_DOWN (10) < ROUND_FLOOR (11) < ROUND_CEILING (13); ROUND_FLOOR (11) - ROUND_DOWN (10) == 1: 'FLOOR' (5) is 1 longer than 'DOWN' (4); ROUND_FLOOR (11) < ROUND_CEILING (13) by 2: 'CEILING' (7) is 2 longer than 'FLOOR' (5); ROUND_CEILING (13) and ROUND_FLOOR (11) are the directional-toward-infinity pair; the 2-character gap between them mirrors the 2-character gap between ROUND_DOWN (10) and ROUND_UP (8); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Rounding mode string class identity (all are plain str, not enum)
# And string length ordering across all six rounding modes.
# ---------------------------------------------------------------------------

table decimal_extra162.rounding_mode_string_type_and_ordering:
  description: "All rounding modes are plain str: ROUND_UP.__class__.__name__=='str'; string length ordering: ROUND_UP(8) < ROUND_DOWN(10) < ROUND_FLOOR(11) < ROUND_HALF_UP(13)=ROUND_CEILING(13) < ROUND_HALF_EVEN(15); two-way tie at 13 for ROUND_CEILING and ROUND_HALF_UP"
  kind: python_call_eq
  category: identity
  id_prefix: drnd162

  columns: [id, function, args, expected, description]
  rows:
    - [up_cls,       decimal.ROUND_UP.__class__.__name__.__eq__,      ["str"],  true,  "decimal.ROUND_UP.__class__.__name__ == 'str' — ROUND_UP is a plain Python string, not an enum member or integer; the decimal module rounding mode constants are bare strings, unlike io.SEEK_* which are plain ints or re.IGNORECASE which is a RegexFlag IntFlag member; 'str' has 3 characters; ROUND_UP.__class__.__name__ == 'str' (3) confirms type(ROUND_UP) is str; all six rounding mode constants (ROUND_UP, ROUND_DOWN, ROUND_FLOOR, ROUND_CEILING, ROUND_HALF_UP, ROUND_HALF_EVEN) share __class__.__name__ == 'str' — they are type-uniform plain strings; the plain string type means the rounding mode can be compared with == to a string literal; confirmed Python 3.14.3 macOS"]
    - [half_up_cls,  decimal.ROUND_HALF_UP.__class__.__name__.__eq__, ["str"],  true,  "decimal.ROUND_HALF_UP.__class__.__name__ == 'str' — ROUND_HALF_UP is a plain Python string; all decimal rounding mode constants are str, making them interchangeable with any code that uses string literals like context.rounding = 'ROUND_HALF_UP'; ROUND_HALF_UP.__class__.__name__ == 'str' (3 chars) is the same for all rounding mode constants; the string type means rounding modes can be stored in JSON (unlike enum members), sorted lexicographically, and concatenated; context.rounding = ROUND_HALF_UP is equivalent to context.rounding = 'ROUND_HALF_UP' because they are the same string object (CPython interns short strings); confirmed Python 3.14.3 macOS"]
    - [up_lt_down,   decimal.ROUND_UP.__len__,                         [],      8,     "decimal.ROUND_UP.__len__() == 8 — ROUND_UP (8) is the minimum string length among the six rounding mode constants; the ascending rounding mode string length sequence: ROUND_UP(8) < ROUND_DOWN(10) < ROUND_FLOOR(11) < ROUND_HALF_UP(13)=ROUND_CEILING(13) < ROUND_HALF_EVEN(15); the minimum is ROUND_UP (8) and the maximum is ROUND_HALF_EVEN (15); the range is 15 - 8 = 7 characters; ROUND_UP (8) stands alone at the minimum length — the 'UP' (2-char) suffix is uniquely short; all rounding mode strings share the 'ROUND_' prefix (6 chars); confirmed Python 3.14.3 macOS"]
    - [even_gt_ceil, decimal.ROUND_HALF_EVEN.__len__,                  [],      15,    "decimal.ROUND_HALF_EVEN.__len__() == 15 — ROUND_HALF_EVEN (15) is the maximum string length among the six rounding mode constants; the ascending sequence: ROUND_UP(8), ROUND_DOWN(10), ROUND_FLOOR(11), ROUND_HALF_UP(13)=ROUND_CEILING(13), ROUND_HALF_EVEN(15); ROUND_HALF_EVEN (15) stands alone at the maximum — 2 longer than the two-way tie at 13 (ROUND_HALF_UP and ROUND_CEILING); ROUND_HALF_EVEN (15) is the default rounding mode in Python's decimal module (Context().rounding == 'ROUND_HALF_EVEN'); the 'EVEN' suffix (4 chars) makes ROUND_HALF_EVEN longer than ROUND_HALF_UP ('UP' 2 chars) by 2 and introduces the only 4-character suffix after HALF; confirmed Python 3.14.3 macOS"]
    - [tie_at_13,    decimal.ROUND_CEILING.__len__,                    [],      13,    "decimal.ROUND_CEILING.__len__() == 13 — ROUND_CEILING (13) is tied with ROUND_HALF_UP (13) at length 13; this is the only tie in the six rounding mode string lengths; ROUND_CEILING = 'ROUND'(5)+'_'(1)+'CEILING'(7) = 13; ROUND_HALF_UP = 'ROUND'(5)+'_'(1)+'HALF'(4)+'_'(1)+'UP'(2) = 13; both reach length 13 via different structures: ROUND_CEILING uses a single long suffix 'CEILING' (7 chars) while ROUND_HALF_UP uses a compound suffix 'HALF_UP' (7 chars total: HALF(4)+_(1)+UP(2)=7); coincidentally both suffixes after 'ROUND_' are exactly 7 characters: 'CEILING' (7) and 'HALF_UP' (7); this makes the two-way tie at 13 a deep structural coincidence; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra162.ROUND_HALF_UP_is_string:
  description: "decimal.ROUND_HALF_UP.__eq__('ROUND_HALF_UP') == True — ROUND_HALF_UP is the plain string 'ROUND_HALF_UP' (13 characters: ROUND(5)+_(1)+HALF(4)+_(1)+UP(2)=13); ROUND_HALF_UP rounds to nearest, with ties going away from zero (upward in magnitude); this is the most common rounding mode in everyday arithmetic; decimal rounding mode constants are plain str objects — not enums, not integers; ROUND_HALF_UP (13 chars) is tied with ROUND_CEILING (13 chars) in string length — the only tie among the six rounding modes; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra162.ROUND_HALF_EVEN_is_string:
  description: "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True — ROUND_HALF_EVEN is the plain string 'ROUND_HALF_EVEN' (15 characters: ROUND(5)+_(1)+HALF(4)+_(1)+EVEN(4)=15); ROUND_HALF_EVEN is the default rounding mode of Python's decimal module and IEEE 754; it rounds to nearest with ties going to the nearest even digit — also called banker's rounding; ROUND_HALF_EVEN (15) is the longest rounding mode string and the sole maximum; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra162.ROUND_DOWN_is_string:
  description: "decimal.ROUND_DOWN.__eq__('ROUND_DOWN') == True — ROUND_DOWN is the plain string 'ROUND_DOWN' (10 characters: ROUND(5)+_(1)+DOWN(4)=10); ROUND_DOWN truncates toward zero regardless of the following digits; ROUND_DOWN (10) > ROUND_UP (8) by 2 because 'DOWN' (4) > 'UP' (2) by 2; ROUND_DOWN (10) < ROUND_FLOOR (11) by 1 because 'DOWN' (4) < 'FLOOR' (5) by 1; ROUND_DOWN and ROUND_UP are the non-half rounding modes: they do not have special midpoint behavior; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_DOWN.__eq__
  args: ["ROUND_DOWN"]
  expected: true

invariant decimal_extra162.ROUND_UP_is_string:
  description: "decimal.ROUND_UP.__eq__('ROUND_UP') == True — ROUND_UP is the plain string 'ROUND_UP' (8 characters: ROUND(5)+_(1)+UP(2)=8); ROUND_UP rounds away from zero regardless of the following digits; ROUND_UP (8) is the shortest rounding mode string — the minimum length among all six rounding mode constants; 'UP' (2 chars) is the shortest direction suffix; ROUND_UP.__class__.__name__ == 'str' — plain string; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra162.ROUND_CEILING_is_string:
  description: "decimal.ROUND_CEILING.__eq__('ROUND_CEILING') == True — ROUND_CEILING is the plain string 'ROUND_CEILING' (13 characters: ROUND(5)+_(1)+CEILING(7)=13); ROUND_CEILING rounds toward positive infinity (+∞): always rounds up for positive numbers, rounds toward zero for negative numbers; ROUND_CEILING (13) is tied with ROUND_HALF_UP (13) — the only two-way tie in the six rounding mode string lengths; the tie is a structural coincidence: 'CEILING' suffix (7 chars) equals 'HALF_UP' total suffix (4+1+2=7 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_CEILING.__eq__
  args: ["ROUND_CEILING"]
  expected: true

invariant decimal_extra162.ROUND_FLOOR_is_string:
  description: "decimal.ROUND_FLOOR.__eq__('ROUND_FLOOR') == True — ROUND_FLOOR is the plain string 'ROUND_FLOOR' (11 characters: ROUND(5)+_(1)+FLOOR(5)=11); ROUND_FLOOR rounds toward negative infinity (-∞): always rounds down for positive numbers, rounds away from zero for negative numbers; ROUND_FLOOR (11) is the complement of ROUND_CEILING (13) just as mathematical floor is the complement of ceiling; ROUND_FLOOR (11) < ROUND_CEILING (13) by 2 because 'FLOOR' (5) < 'CEILING' (7) by 2; the ascending sequence: ROUND_UP(8) < ROUND_DOWN(10) < ROUND_FLOOR(11) < ROUND_CEILING(13)=ROUND_HALF_UP(13) < ROUND_HALF_EVEN(15); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_FLOOR.__eq__
  args: ["ROUND_FLOOR"]
  expected: true

invariant decimal_extra162.ROUND_UP_is_shortest_at_8:
  description: "decimal.ROUND_UP.__len__() == 8 — ROUND_UP (8 chars) is the shortest rounding mode string; the minimum rounding mode string length is 8 (ROUND_UP) and the maximum is 15 (ROUND_HALF_EVEN); the range is 15 - 8 = 7 characters; all six rounding mode strings share the 'ROUND_' prefix (6 chars = 'ROUND' (5) + '_' (1)); the minimum suffix length is 'UP' (2 chars), making ROUND_UP (6+2=8) the minimum total; the direction suffixes in ascending length: UP(2), DOWN(4), FLOOR(5), HALF_UP(7 total suffix after ROUND_), CEILING(7), HALF_EVEN(9 total); ROUND_CEILING and ROUND_HALF_UP tie at total length 13 because both have 7-character suffixes after 'ROUND_'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_UP.__len__
  args: []
  expected: 8

