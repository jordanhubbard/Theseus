spec: io_extra296
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — FileIO class method identity and attribute descriptors"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/fileio.c, Lib/io.py"
  notes:
    - "FileIO method __qualname__ attributes verified via interactive Python session"
    - "Attribute descriptors (name, mode, closefd) are getset_descriptor on CPython"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table io_extra296.fileio_method_qualnames:
  description: "FileIO method __qualname__ values"
  kind: python_call_eq
  category: identity
  id_prefix: iox296

  columns: [id, function, args, expected, description]
  rows:
    - [iox296_001, io.FileIO.read.__qualname__.__eq__, ["FileIO.read"], true, "FileIO.read qualname"]
    - [iox296_002, io.FileIO.readall.__qualname__.__eq__, ["FileIO.readall"], true, "FileIO.readall qualname"]
    - [iox296_003, io.FileIO.readinto.__qualname__.__eq__, ["FileIO.readinto"], true, "FileIO.readinto qualname"]
    - [iox296_004, io.FileIO.write.__qualname__.__eq__, ["FileIO.write"], true, "FileIO.write qualname"]
    - [iox296_005, io.FileIO.seek.__qualname__.__eq__, ["FileIO.seek"], true, "FileIO.seek qualname"]
    - [iox296_006, io.FileIO.tell.__qualname__.__eq__, ["FileIO.tell"], true, "FileIO.tell qualname"]
    - [iox296_007, io.FileIO.close.__qualname__.__eq__, ["FileIO.close"], true, "FileIO.close qualname"]
    - [iox296_008, io.FileIO.flush.__qualname__.__eq__, ["FileIO.flush"], true, "FileIO.flush qualname"]
    - [iox296_009, io.FileIO.readable.__qualname__.__eq__, ["FileIO.readable"], true, "FileIO.readable qualname"]
    - [iox296_010, io.FileIO.writable.__qualname__.__eq__, ["FileIO.writable"], true, "FileIO.writable qualname"]
    - [iox296_011, io.FileIO.seekable.__qualname__.__eq__, ["FileIO.seekable"], true, "FileIO.seekable qualname"]

table io_extra296.fileio_attr_descriptor_classes:
  description: "FileIO attribute descriptor __class__.__name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: iox296d

  columns: [id, function, args, expected, description]
  rows:
    - [iox296d_001, io.FileIO.name.__class__.__name__.__eq__, ["getset_descriptor"], true, "FileIO.name descriptor class"]
    - [iox296d_002, io.FileIO.mode.__class__.__name__.__eq__, ["getset_descriptor"], true, "FileIO.mode descriptor class"]
    - [iox296d_003, io.FileIO.closefd.__class__.__name__.__eq__, ["getset_descriptor"], true, "FileIO.closefd descriptor class"]

invariant io_extra296.inv_read_qualname:
  description: "FileIO.read __qualname__ is 'FileIO.read'"
  category: identity
  kind: python_call_eq
  function: io.FileIO.read.__qualname__.__eq__
  args: ["FileIO.read"]
  expected: true

invariant io_extra296.inv_write_qualname:
  description: "FileIO.write __qualname__ is 'FileIO.write'"
  category: identity
  kind: python_call_eq
  function: io.FileIO.write.__qualname__.__eq__
  args: ["FileIO.write"]
  expected: true

invariant io_extra296.inv_seekable_qualname:
  description: "FileIO.seekable __qualname__ is 'FileIO.seekable'"
  category: identity
  kind: python_call_eq
  function: io.FileIO.seekable.__qualname__.__eq__
  args: ["FileIO.seekable"]
  expected: true
