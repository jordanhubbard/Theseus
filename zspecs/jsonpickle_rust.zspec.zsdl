spec: jsonpickle_rust
version: ">=3.9"
backend: rust_module(jsonpickle_rust)

docs: https://jsonpickle.readthedocs.io/

provenance:
  derived_from:
    - "https://jsonpickle.readthedocs.io/ — jsonpickle documentation"
  not_derived_from:
    - "jsonpickle source: jsonpickle/pickler.py"
  notes:
    - "jsonpickle serializes Python objects to JSON and back."
    - "jsonpickle.encode({'a': 1}) == '{\"a\": 1}'."
    - "jsonpickle.decode('{\"a\": 1}') == {'a': 1}."
    - "jsonpickle.encode([1, 2, 3]) == '[1, 2, 3]'."
    - "jsonpickle.decode('[1, 2, 3]') == [1, 2, 3]."
    - "Expose jsonpickle_roundtrip_dict(d) -> dict: decode(encode(d))."
    - "Expose jsonpickle_roundtrip_list(lst) -> list: decode(encode(lst))."
    - "Expose jsonpickle_roundtrip_int(n) -> int: decode(encode(n))."
    - "Expose jsonpickle_encode_type(obj) -> str: type(encode(obj)).__name__ == 'str'."
    - "All test vectors verified against jsonpickle 3.4.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# jsonpickle_roundtrip_dict — dict encode/decode roundtrip
table jsonpickle_rust.roundtrip.dict:
  kind: python_call_eq
  category: dict
  id_prefix: jp_dict
  function: jsonpickle_roundtrip_dict

  columns: [id, args, expected]
  rows:
    - [simple,  [{"a": 1}],             {"a": 1}]
    - [multi,   [{"x": 1, "y": 2}],    {"x": 1, "y": 2}]
    - [empty,   [{}],                   {}]
    - [nested,  [{"a": {"b": 1}}],     {"a": {"b": 1}}]

# jsonpickle_roundtrip_list — list encode/decode roundtrip
table jsonpickle_rust.roundtrip.list:
  kind: python_call_eq
  category: list
  id_prefix: jp_list
  function: jsonpickle_roundtrip_list

  columns: [id, args, expected]
  rows:
    - [three,  [[1, 2, 3]],  [1, 2, 3]]
    - [empty,  [[]],         []]

# jsonpickle_encode_type — encoded result is a string
invariant jsonpickle_rust.encode.type_is_str:
  description: "jsonpickle.encode({'a': 1}) returns str"
  category: type
  kind: python_call_eq
  function: jsonpickle_encode_type
  args: [{"a": 1}]
  expected: "str"

