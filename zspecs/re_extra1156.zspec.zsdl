spec: re_extra1156
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module __package__.__class__.__name__, __loader__.__class__.__name__, __all__.__class__.__name__, re.error.__module__, re.Pattern.__module__, re.Match.__module__, re.RegexFlag.__module__, re.compile.__module__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.__package__.__class__.__name__, re.__loader__.__class__.__name__, re.__all__.__class__.__name__, re.error.__module__ (not covered in _extra1141 as a separate attr-chain from __qualname__ focus), re.compile.__module__, re.sub.__module__, re.search.__module__, re.fullmatch.__module__; __package__/__loader__/__all__ class names not covered in _extra1126 or _extra1141"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1156.module_dunder_class_names:
  description: "re module __package__, __loader__, and __all__ __class__.__name__ checks"
  kind: python_call_eq
  category: module_dunder_class_names
  id_prefix: re1156mc
  columns: [id, function, args, expected]
  rows:
    - [re1156mc001, re.__package__.__class__.__name__.__eq__,  ["str"],   true]
    - [re1156mc002, re.__loader__.__class__.__name__.__eq__,   ["SourceFileLoader"], true]
    - [re1156mc003, re.__all__.__class__.__name__.__eq__,      ["list"],  true]
    - [re1156mc004, re.__package__.__class__.__name__.__eq__,  ["bytes"], false]
    - [re1156mc005, re.__package__.__class__.__name__.__eq__,  ["NoneType"], false]
    - [re1156mc006, re.__all__.__class__.__name__.__eq__,      ["tuple"], false]
    - [re1156mc007, re.__package__.__eq__,                     ["re"],    true]
    - [re1156mc008, re.__package__.__class__.__name__.__eq__,  ["str"],   true]

table re_extra1156.function_modules:
  description: "re module-level function __module__ checks — compile, sub, search, fullmatch, findall, split"
  kind: python_call_eq
  category: function_modules
  id_prefix: re1156fm
  columns: [id, function, args, expected]
  rows:
    - [re1156fm001, re.compile.__module__.__eq__,   ["re"],    true]
    - [re1156fm002, re.sub.__module__.__eq__,       ["re"],    true]
    - [re1156fm003, re.search.__module__.__eq__,    ["re"],    true]
    - [re1156fm004, re.fullmatch.__module__.__eq__, ["re"],    true]
    - [re1156fm005, re.findall.__module__.__eq__,   ["re"],    true]
    - [re1156fm006, re.split.__module__.__eq__,     ["re"],    true]
    - [re1156fm007, re.compile.__module__.__eq__,   ["_sre"],  false]
    - [re1156fm008, re.sub.__module__.__eq__,       ["builtins"], false]
    - [re1156fm009, re.compile.__module__.__class__.__name__.__eq__, ["str"], true]
    - [re1156fm010, re.search.__module__.__class__.__name__.__eq__,  ["str"], true]

table re_extra1156.pattern_match_regexflag_modules:
  description: "re.Pattern, re.Match, and re.RegexFlag __module__ cross-checks not previously covered in this combination"
  kind: python_call_eq
  category: pattern_match_regexflag_modules
  id_prefix: re1156pr
  columns: [id, function, args, expected]
  rows:
    - [re1156pr001, re.Pattern.__module__.__eq__,         ["re"],  true]
    - [re1156pr002, re.Match.__module__.__eq__,           ["re"],  true]
    - [re1156pr003, re.RegexFlag.__module__.__eq__,       ["re"],  true]
    - [re1156pr004, re.error.__module__.__eq__,           ["re"],  true]
    - [re1156pr005, re.Pattern.__module__.__eq__,         ["_sre"], false]
    - [re1156pr006, re.Match.__module__.__eq__,           ["_sre"], false]
    - [re1156pr007, re.RegexFlag.__module__.__eq__,       ["builtins"], false]
    - [re1156pr008, re.error.__module__.__eq__,           ["builtins"], false]
    - [re1156pr009, re.Pattern.__module__.__class__.__name__.__eq__,   ["str"], true]
    - [re1156pr010, re.RegexFlag.__module__.__class__.__name__.__eq__, ["str"], true]
