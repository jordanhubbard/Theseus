spec: enum_extra14
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra13.zspec.zsdl and enum_flags.zspec.zsdl."
    - "enum_extra13 covers IntEnum/StrEnum/IntFlag MRO length and key entries; auto MRO length and MRO[1].__name__; unique.__qualname__/__module__; ReprEnum.__bases__[0].__name__; EnumMeta.__mro__[2].__name__."
    - "enum_extra12 covers EnumMeta MRO length/MRO[1]; Flag MRO length/MRO[1]; ReprEnum __qualname__/__bases__.__len__; nonmember/member __module__/__qualname__; global_enum/show_flag_values __qualname__."
    - "NOT yet covered: enum.IntFlag.__name__ == 'IntFlag' as a standalone invariant."
    - "NOT yet covered: enum.StrEnum.__name__ == 'StrEnum' as a standalone invariant (Python 3.11+)."
    - "NOT yet covered: enum.ReprEnum.__name__ == 'ReprEnum' as a standalone invariant (Python 3.11+)."
    - "NOT yet covered: enum.EnumType.__name__ — EnumType is an alias for EnumMeta (Python 3.11+)."
    - "NOT yet covered: enum.IntEnum.__name__ == 'IntEnum' as a standalone invariant."
    - "NOT yet covered: enum.Flag.__name__ == 'Flag' as a standalone invariant."
    - "NOT yet covered: enum.EnumMeta.__name__ == 'EnumMeta' as a standalone invariant."
    - "NOT yet covered: enum.auto.__name__ == 'auto' as a standalone invariant."
    - "NOT yet covered: enum.unique.__name__ == 'unique' as a standalone invariant."
    - "NOT yet covered: enum.IntEnum.__bases__[0].__name__ == 'int' as a standalone invariant."
    - "NOT yet covered: enum.auto().__class__.__name__ == 'auto' — instance class identity."
    - "NOT yet covered: enum.IntFlag.__bases__[0].__name__ == 'int'."
    - "enum.IntFlag.__name__ == 'IntFlag'."
    - "enum.StrEnum.__name__ == 'StrEnum' (Python 3.11+)."
    - "enum.ReprEnum.__name__ == 'ReprEnum' (Python 3.11+)."
    - "enum.EnumType.__name__ == 'EnumMeta' — EnumType is an alias, __name__ still 'EnumMeta' (Python 3.11+)."
    - "enum.IntEnum.__name__ == 'IntEnum'."
    - "enum.Flag.__name__ == 'Flag'."
    - "enum.EnumMeta.__name__ == 'EnumMeta'."
    - "enum.auto.__name__ == 'auto'."
    - "enum.unique.__name__ == 'unique'."
    - "enum.IntEnum.__bases__[0].__name__ == 'int'."
    - "enum.auto().__class__.__name__ == 'auto'."
    - "enum.IntFlag.__bases__[0].__name__ == 'int'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ — standalone invariants for all stable enum classes
#
# Prior specs cover __name__ for these classes in combined tables or as part
# of larger attribute sweeps. These add each __name__ as its own standalone
# invariant using the dotted-eq pattern for maximum machine-readability.
# ---------------------------------------------------------------------------

invariant enum_extra14.IntFlag.name:
  description: "enum.IntFlag.__name__ == 'IntFlag'"
  category: class_names
  kind: python_call_eq
  function: IntFlag.__name__.__eq__
  args: ["IntFlag"]
  expected: true

invariant enum_extra14.IntEnum.name:
  description: "enum.IntEnum.__name__ == 'IntEnum'"
  category: class_names
  kind: python_call_eq
  function: IntEnum.__name__.__eq__
  args: ["IntEnum"]
  expected: true

invariant enum_extra14.Flag.name:
  description: "enum.Flag.__name__ == 'Flag'"
  category: class_names
  kind: python_call_eq
  function: Flag.__name__.__eq__
  args: ["Flag"]
  expected: true

invariant enum_extra14.EnumMeta.name:
  description: "enum.EnumMeta.__name__ == 'EnumMeta'"
  category: class_names
  kind: python_call_eq
  function: EnumMeta.__name__.__eq__
  args: ["EnumMeta"]
  expected: true

invariant enum_extra14.auto.name:
  description: "enum.auto.__name__ == 'auto'"
  category: class_names
  kind: python_call_eq
  function: auto.__name__.__eq__
  args: ["auto"]
  expected: true

invariant enum_extra14.unique.name:
  description: "enum.unique.__name__ == 'unique'"
  category: function_names
  kind: python_call_eq
  function: unique.__name__.__eq__
  args: ["unique"]
  expected: true

# ---------------------------------------------------------------------------
# Python 3.11+ class __name__ — StrEnum, ReprEnum, EnumType
#
# StrEnum, ReprEnum, and EnumType were added in Python 3.11. These add their
# __name__ attributes as standalone invariants, version-gated to >=3.11.
# EnumType is an alias for EnumMeta; its __name__ remains 'EnumMeta'.
# ---------------------------------------------------------------------------

invariant enum_extra14.StrEnum.name:
  description: "enum.StrEnum.__name__ == 'StrEnum' (Python 3.11+)"
  category: class_names
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__name__.__eq__
  args: ["StrEnum"]
  expected: true

invariant enum_extra14.ReprEnum.name:
  description: "enum.ReprEnum.__name__ == 'ReprEnum' (Python 3.11+)"
  category: class_names
  version: ">=3.11"
  kind: python_call_eq
  function: ReprEnum.__name__.__eq__
  args: ["ReprEnum"]
  expected: true

invariant enum_extra14.EnumType.name:
  description: "enum.EnumType.__name__ == 'EnumMeta' — EnumType is an alias for EnumMeta (Python 3.11+)"
  category: class_names
  version: ">=3.11"
  kind: python_call_eq
  function: EnumType.__name__.__eq__
  args: ["EnumMeta"]
  expected: true

# ---------------------------------------------------------------------------
# IntEnum.__bases__[0].__name__ — first direct base is int
#
# enum_extra11 verified IntEnum.__bases__.__len__() == 2. enum_extra13 verified
# IntEnum.__mro__[1].__name__ == 'int'. No prior spec isolates the first base
# class name via __bases__[0].__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant enum_extra14.IntEnum.base0_is_int:
  description: "enum.IntEnum.__bases__[0].__name__ == 'int' — first direct base of IntEnum is int"
  category: class_hierarchy
  kind: python_call_eq
  function: IntEnum.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "int"

# ---------------------------------------------------------------------------
# IntFlag.__bases__[0].__name__ — first direct base is int
#
# enum_extra11 verified IntFlag.__bases__.__len__() == 2.
# No prior spec checks which class is first in IntFlag.__bases__. On Python
# 3.11+ the MRO shows int as the first mixin, which means __bases__[0] is int.
# ---------------------------------------------------------------------------

invariant enum_extra14.IntFlag.base0_is_int:
  description: "enum.IntFlag.__bases__[0].__name__ == 'int' — first direct base of IntFlag is int"
  category: class_hierarchy
  kind: python_call_eq
  function: IntFlag.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "int"

# ---------------------------------------------------------------------------
# auto() instance — __class__.__name__
#
# enum_extra10 verified auto.__bases__[0].__name__ == 'int' (older check) and
# enum_extra13 verified auto.__mro__[1].__name__ == 'object'.
# No prior spec calls auto() (instantiates it) and checks the class name of
# the returned instance. auto() returns an auto instance; its class name is 'auto'.
# ---------------------------------------------------------------------------

invariant enum_extra14.auto.instance_class_name:
  description: "enum.auto().__class__.__name__ == 'auto' — auto() returns an instance of class auto"
  category: class_identity
  kind: python_call_eq
  function: auto
  args: []
  method: __class__.__name__.__eq__
  method_args: ["auto"]
  expected: true
