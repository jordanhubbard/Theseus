# Barrier.__bases__[0].__name__ == 'Barrier'  (threading.Barrier)
# ---------------------------------------------------------------------------

table multiprocessing_extra245.event_condition_barrier_identity:
  description: "multiprocessing.synchronize Event(len=5), Condition(len=9), and Barrier(len=7) class identity — Event and Condition inherit from object directly; Barrier inherits from threading.Barrier (also named 'Barrier'); all in multiprocessing.synchronize(len=27); verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: mp245ecb

  columns: [id, function, args, expected, description]
  rows:
    - [ev_name_eq,    synchronize.Event.__name__.__eq__,                        ["Event"],                           true, "multiprocessing.synchronize.Event.__name__ == 'Event'; verified with Python 3.14.4"]
    - [ev_name_len,   synchronize.Event.__name__.__len__,                       [],                                   5,    "multiprocessing.synchronize.Event.__name__.__len__() == 5; verified with Python 3.14.4"]
    - [ev_mod_eq,     synchronize.Event.__module__.__eq__,                      ["multiprocessing.synchronize"],     true, "multiprocessing.synchronize.Event.__module__ == 'multiprocessing.synchronize'; verified with Python 3.14.4"]
    - [ev_mod_len,    synchronize.Event.__module__.__len__,                     [],                                   27,   "multiprocessing.synchronize.Event.__module__.__len__() == 27; verified with Python 3.14.4"]
    - [ev_base_eq,    "synchronize.Event.__bases__[0].__name__.__eq__",         ["object"],                          true, "multiprocessing.synchronize.Event.__bases__[0].__name__ == 'object' — Event inherits directly from object, not from SemLock; verified with Python 3.14.4"]
    - [co_name_eq,    synchronize.Condition.__name__.__eq__,                    ["Condition"],                       true, "multiprocessing.synchronize.Condition.__name__ == 'Condition'; verified with Python 3.14.4"]
    - [co_name_len,   synchronize.Condition.__name__.__len__,                   [],                                   9,    "multiprocessing.synchronize.Condition.__name__.__len__() == 9; verified with Python 3.14.4"]
    - [co_mod_eq,     synchronize.Condition.__module__.__eq__,                  ["multiprocessing.synchronize"],     true, "multiprocessing.synchronize.Condition.__module__ == 'multiprocessing.synchronize'; verified with Python 3.14.4"]
    - [co_mod_len,    synchronize.Condition.__module__.__len__,                 [],                                   27,   "multiprocessing.synchronize.Condition.__module__.__len__() == 27; verified with Python 3.14.4"]
    - [co_base_eq,    "synchronize.Condition.__bases__[0].__name__.__eq__",     ["object"],                          true, "multiprocessing.synchronize.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object; verified with Python 3.14.4"]
    - [ba_name_eq,    synchronize.Barrier.__name__.__eq__,                      ["Barrier"],                         true, "multiprocessing.synchronize.Barrier.__name__ == 'Barrier'; verified with Python 3.14.4"]
    - [ba_name_len,   synchronize.Barrier.__name__.__len__,                     [],                                   7,    "multiprocessing.synchronize.Barrier.__name__.__len__() == 7; verified with Python 3.14.4"]
    - [ba_mod_eq,     synchronize.Barrier.__module__.__eq__,                    ["multiprocessing.synchronize"],     true, "multiprocessing.synchronize.Barrier.__module__ == 'multiprocessing.synchronize'; verified with Python 3.14.4"]
    - [ba_mod_len,    synchronize.Barrier.__module__.__len__,                   [],                                   27,   "multiprocessing.synchronize.Barrier.__module__.__len__() == 27; verified with Python 3.14.4"]
    - [ba_base_eq,    "synchronize.Barrier.__bases__[0].__name__.__eq__",       ["Barrier"],                         true, "multiprocessing.synchronize.Barrier.__bases__[0].__name__ == 'Barrier' — mp Barrier inherits from threading.Barrier; both classes share the name 'Barrier'; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra245
# ---------------------------------------------------------------------------

invariant multiprocessing_extra245.semaphore_lock_rlock_share_semlock_base:
  description: "multiprocessing.synchronize.RLock.__bases__[0].__name__.__eq__('SemLock') returns True — RLock, Lock, and Semaphore all share SemLock as their single base class, establishing them as the three SemLock-derived synchronization primitives in multiprocessing.synchronize(len=27); verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: "synchronize.RLock.__bases__[0].__name__.__eq__"
  args: ["SemLock"]
  expected: true

invariant multiprocessing_extra245.barrier_inherits_threading_barrier:
  description: "multiprocessing.synchronize.Barrier.__bases__[0].__name__.__eq__('Barrier') returns True — the multiprocessing Barrier wraps threading.Barrier; both the mp class and its base class are named 'Barrier', creating a same-name inheritance; verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: "synchronize.Barrier.__bases__[0].__name__.__eq__"
  args: ["Barrier"]
  expected: true
