spec: multiprocessing_extra245
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/synchronize.py"
  notes:
    - "multiprocessing.synchronize.Semaphore.__name__ == 'Semaphore' (len=9); __module__ == 'multiprocessing.synchronize' (len=27); __bases__[0].__name__ == 'SemLock'."
    - "multiprocessing.synchronize.Lock.__name__ == 'Lock' (len=4); __bases__[0].__name__ == 'SemLock' — Lock, RLock, and Semaphore all inherit from 'SemLock'."
    - "multiprocessing.synchronize.RLock.__name__ == 'RLock' (len=5); __bases__[0].__name__ == 'SemLock'."
    - "multiprocessing.synchronize.Event.__name__ == 'Event' (len=5); __bases__[0].__name__ == 'object' — Event and Condition inherit directly from object, not from SemLock."
    - "multiprocessing.synchronize.Condition.__name__ == 'Condition' (len=9); __bases__[0].__name__ == 'object'."
    - "multiprocessing.synchronize.Barrier.__name__ == 'Barrier' (len=7); __bases__[0].__name__ == 'Barrier' — mp Barrier inherits from threading.Barrier; both classes share the same __name__ 'Barrier'."
    - "All six classes share __module__ == 'multiprocessing.synchronize' (len=27)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.synchronize SemLock-based class identity
#
# Semaphore.__name__ == 'Semaphore' (len=9)
# Semaphore.__module__ == 'multiprocessing.synchronize' (len=27)
# Semaphore.__bases__[0].__name__ == 'SemLock'
# Lock.__name__ == 'Lock' (len=4)
# Lock.__module__ == 'multiprocessing.synchronize' (len=27)
# Lock.__bases__[0].__name__ == 'SemLock'
# RLock.__name__ == 'RLock' (len=5)
# RLock.__module__ == 'multiprocessing.synchronize' (len=27)
# RLock.__bases__[0].__name__ == 'SemLock'
# ---------------------------------------------------------------------------

table multiprocessing_extra245.semlock_based_class_identity:
  description: "multiprocessing.synchronize Semaphore(len=9), Lock(len=4), and RLock(len=5) class identity — all three inherit from 'SemLock'; all defined in multiprocessing.synchronize(len=27); verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: mp245sl

  columns: [id, function, args, expected, description]
  rows:
    - [sem_name_eq,    synchronize.Semaphore.__name__.__eq__,                       ["Semaphore"],                       true, "multiprocessing.synchronize.Semaphore.__name__ == 'Semaphore'; verified with Python 3.14.4"]
    - [sem_name_len,   synchronize.Semaphore.__name__.__len__,                      [],                                   9,    "multiprocessing.synchronize.Semaphore.__name__.__len__() == 9; verified with Python 3.14.4"]
    - [sem_mod_eq,     synchronize.Semaphore.__module__.__eq__,                     ["multiprocessing.synchronize"],     true, "multiprocessing.synchronize.Semaphore.__module__ == 'multiprocessing.synchronize'; verified with Python 3.14.4"]
    - [sem_mod_len,    synchronize.Semaphore.__module__.__len__,                    [],                                   27,   "multiprocessing.synchronize.Semaphore.__module__.__len__() == 27; verified with Python 3.14.4"]
    - [sem_base_eq,    "synchronize.Semaphore.__bases__[0].__name__.__eq__",        ["SemLock"],                         true, "multiprocessing.synchronize.Semaphore.__bases__[0].__name__ == 'SemLock'; verified with Python 3.14.4"]
    - [lk_name_eq,     synchronize.Lock.__name__.__eq__,                            ["Lock"],                            true, "multiprocessing.synchronize.Lock.__name__ == 'Lock'; verified with Python 3.14.4"]
    - [lk_name_len,    synchronize.Lock.__name__.__len__,                           [],                                   4,    "multiprocessing.synchronize.Lock.__name__.__len__() == 4; verified with Python 3.14.4"]
    - [lk_mod_eq,      synchronize.Lock.__module__.__eq__,                          ["multiprocessing.synchronize"],     true, "multiprocessing.synchronize.Lock.__module__ == 'multiprocessing.synchronize'; verified with Python 3.14.4"]
    - [lk_mod_len,     synchronize.Lock.__module__.__len__,                         [],                                   27,   "multiprocessing.synchronize.Lock.__module__.__len__() == 27; verified with Python 3.14.4"]
    - [lk_base_eq,     "synchronize.Lock.__bases__[0].__name__.__eq__",             ["SemLock"],                         true, "multiprocessing.synchronize.Lock.__bases__[0].__name__ == 'SemLock'; verified with Python 3.14.4"]
    - [rl_name_eq,     synchronize.RLock.__name__.__eq__,                           ["RLock"],                           true, "multiprocessing.synchronize.RLock.__name__ == 'RLock'; verified with Python 3.14.4"]
    - [rl_name_len,    synchronize.RLock.__name__.__len__,                          [],                                   5,    "multiprocessing.synchronize.RLock.__name__.__len__() == 5; verified with Python 3.14.4"]
    - [rl_mod_eq,      synchronize.RLock.__module__.__eq__,                         ["multiprocessing.synchronize"],     true, "multiprocessing.synchronize.RLock.__module__ == 'multiprocessing.synchronize'; verified with Python 3.14.4"]
    - [rl_mod_len,     synchronize.RLock.__module__.__len__,                        [],                                   27,   "multiprocessing.synchronize.RLock.__module__.__len__() == 27; verified with Python 3.14.4"]
    - [rl_base_eq,     "synchronize.RLock.__bases__[0].__name__.__eq__",            ["SemLock"],                         true, "multiprocessing.synchronize.RLock.__bases__[0].__name__ == 'SemLock' — Lock, RLock, and Semaphore all share SemLock as their base; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# multiprocessing.synchronize object-based class identity
#
# Event.__name__ == 'Event' (len=5)
# Event.__module__ == 'multiprocessing.synchronize' (len=27)
