spec: glob_extra14
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/glob.py"
    - "glob_extra13.zspec.zsdl — covers __qualname__.__len__() and __module__.__len__() for glob/iglob/escape."
    - "glob_extra11.zspec.zsdl — covers __qualname__ equality and __name__ for glob/iglob/escape; __module__ equality for all three."
  notes:
    - "This spec extends glob_extra13.zspec.zsdl."
    - "Focus: glob.translate (added in Python 3.12) __qualname__ and __module__; __qualname__.__class__.__name__ == 'str' for glob/iglob/escape (qualnames are string objects)."
    - "glob.translate is available on Python 3.12+; spec is version-gated accordingly."
    - "glob.translate.__qualname__ == 'translate' — top-level function, qualname equals its simple name."
    - "glob.translate.__module__ == 'glob' — translate is defined in the glob module."
    - "len(glob.translate.__qualname__) == 9 — 'translate' has 9 characters."
    - "glob.glob.__qualname__.__class__.__name__ == 'str' — the qualname attribute is a Python string object."
    - "glob.iglob.__qualname__.__class__.__name__ == 'str' — qualname is a Python string object."
    - "glob.escape.__qualname__.__class__.__name__ == 'str' — qualname is a Python string object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__class__.__name__ for glob public functions
#
# glob_extra11 covers that each __qualname__ equals the function name string.
# glob_extra13 covers the length of those strings. No prior glob spec verifies
# that the __qualname__ attribute is itself a str object (not some other type).
# All three functions' __qualname__ values are plain Python str instances.
# Verified: all three yield 'str'.
# ---------------------------------------------------------------------------

table glob_extra14.function_qualname_class_names:
  description: "__qualname__.__class__.__name__ == 'str' for glob public functions — qualname is a str object"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqcn14

  columns: [id, function, args, expected]
  rows:
    - [glob,   "glob.__qualname__.__class__.__name__.__eq__",   ["str"], true]
    - [iglob,  "iglob.__qualname__.__class__.__name__.__eq__",  ["str"], true]
    - [escape, "escape.__qualname__.__class__.__name__.__eq__", ["str"], true]

# ---------------------------------------------------------------------------
# Table: glob.translate identity — Python 3.12+
#
# glob.translate was added in Python 3.12. It converts a glob pattern into a
# regular expression string. No prior glob spec covers translate in any form.
# translate.__qualname__ == 'translate' and translate.__module__ == 'glob'.
# Verified: __qualname__='translate', __module__='glob', len(__qualname__)=9.
# ---------------------------------------------------------------------------

table glob_extra14.translate_identity:
  description: "glob.translate __qualname__ and __module__ identity (Python 3.12+)"
  kind: python_call_eq
  category: function_identity
  id_prefix: trans14

  columns: [id, function, args, expected]
  rows:
    - [qualname, translate.__qualname__.__eq__, ["translate"], true]
    - [module,   translate.__module__.__eq__,   ["glob"],      true]

# ---------------------------------------------------------------------------
# Standalone: glob.translate.__qualname__.__len__() == 9
#
# 'translate' has 9 characters. No prior glob spec covers translate's
# qualname length. This standalone invariant anchors the length independently
# of the table above for direct lookup in the extra14 namespace.
# Verified: len('translate') == 9.
# ---------------------------------------------------------------------------

invariant glob_extra14.translate.qualname_length:
  description: "glob.translate.__qualname__.__len__() == 9 — 'translate' has 9 characters"
  category: function_identity
  kind: python_call_eq
  function: translate.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# Standalone: glob.glob.__qualname__.__class__.__name__ == 'str'
#
# The __qualname__ of any Python function is always a str object. This
# standalone invariant anchors that fact for glob.glob independently of the
# table, providing a direct invariant in the extra14 namespace.
# Verified: glob.glob.__qualname__.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant glob_extra14.glob.qualname_is_str:
  description: "glob.glob.__qualname__.__class__.__name__ == 'str' — qualname attribute is a Python string object"
  category: function_identity
  kind: python_call_eq
  function: "glob.__qualname__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true
