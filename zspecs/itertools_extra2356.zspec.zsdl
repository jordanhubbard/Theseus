spec: itertools_extra2356
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 604 (_extra2356): __init__ and __new__ implementation type classification."
    - "All itertools types are C types: __init__ == 'wrapper_descriptor', __new__ == 'builtin_function_or_method'."
    - "Classes covered: chain, cycle, count, combinations, permutations, product, islice."
    - "__doc__ for all itertools types is 'str' (each type has a C-level docstring)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __init__ implementation type — all itertools types are C types
# ---------------------------------------------------------------------------

table itertools_extra2356.init_types:
  description: "itertools class __init__ implementation type — all C types return 'wrapper_descriptor'"
  kind: python_call_eq
  category: type_identity
  id_prefix: it2356
  columns: [id, function, args, expected]
  rows:
    - ["it2356001", "itertools.chain.__init__.__class__.__name__",        [], "wrapper_descriptor"]
    - ["it2356002", "itertools.cycle.__init__.__class__.__name__",        [], "wrapper_descriptor"]
    - ["it2356003", "itertools.count.__init__.__class__.__name__",        [], "wrapper_descriptor"]
    - ["it2356004", "itertools.combinations.__init__.__class__.__name__", [], "wrapper_descriptor"]
    - ["it2356005", "itertools.permutations.__init__.__class__.__name__", [], "wrapper_descriptor"]
    - ["it2356006", "itertools.product.__init__.__class__.__name__",      [], "wrapper_descriptor"]
    - ["it2356007", "itertools.islice.__init__.__class__.__name__",       [], "wrapper_descriptor"]

# ---------------------------------------------------------------------------
# __new__ implementation type — all itertools types are C types
# ---------------------------------------------------------------------------

table itertools_extra2356.new_types:
  description: "itertools class __new__ implementation type — all C types return 'builtin_function_or_method'"
  kind: python_call_eq
  category: type_identity
  id_prefix: it2356
  columns: [id, function, args, expected]
  rows:
    - ["it2356008", "itertools.chain.__new__.__class__.__name__",        [], "builtin_function_or_method"]
    - ["it2356009", "itertools.cycle.__new__.__class__.__name__",        [], "builtin_function_or_method"]
    - ["it2356010", "itertools.count.__new__.__class__.__name__",        [], "builtin_function_or_method"]
    - ["it2356011", "itertools.combinations.__new__.__class__.__name__", [], "builtin_function_or_method"]
    - ["it2356012", "itertools.permutations.__new__.__class__.__name__", [], "builtin_function_or_method"]
    - ["it2356013", "itertools.product.__new__.__class__.__name__",      [], "builtin_function_or_method"]
    - ["it2356014", "itertools.islice.__new__.__class__.__name__",       [], "builtin_function_or_method"]

# ---------------------------------------------------------------------------
# __doc__ class names — all itertools types have C-level docstrings
# ---------------------------------------------------------------------------

table itertools_extra2356.doc_class_names:
  description: "itertools class __doc__.__class__.__name__ — all C types have str docstrings"
  kind: python_call_eq
  category: type_identity
  id_prefix: it2356
  columns: [id, function, args, expected]
  rows:
    - ["it2356015", "itertools.chain.__doc__.__class__.__name__",        [], "str"]
    - ["it2356016", "itertools.cycle.__doc__.__class__.__name__",        [], "str"]
    - ["it2356017", "itertools.count.__doc__.__class__.__name__",        [], "str"]
    - ["it2356018", "itertools.combinations.__doc__.__class__.__name__", [], "str"]
    - ["it2356019", "itertools.permutations.__doc__.__class__.__name__", [], "str"]
    - ["it2356020", "itertools.product.__doc__.__class__.__name__",      [], "str"]
