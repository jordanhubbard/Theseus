spec: concurrent_futures_extra241
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/ (internal scheduling and execution)"
  notes:
    - "This spec covers ThreadPoolExecutor vs ProcessPoolExecutor identity details."
    - "ThreadPoolExecutor.__name__.__len__() == 18 ('ThreadPoolExecutor' is 18 chars)."
    - "ProcessPoolExecutor.__name__.__len__() == 19 ('ProcessPoolExecutor' is 19 chars, one more than ThreadPoolExecutor)."
    - "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (len=25)."
    - "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26)."
    - "ThreadPoolExecutor.__doc__ is None — no class-level docstring; init doc is on __init__."
    - "ProcessPoolExecutor.__doc__ is None — no class-level docstring; init doc is on __init__."
    - "ThreadPoolExecutor.__init__.__doc__ contains 'thread' (case-sensitive)."
    - "ProcessPoolExecutor.__init__.__doc__ contains 'process' (case-sensitive)."
    - "ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len=18, same as __name__)."
    - "ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len=19, same as __name__)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Name and module length checks
#
# ThreadPoolExecutor.__name__.__len__() == 18
# ProcessPoolExecutor.__name__.__len__() == 19
# ThreadPoolExecutor.__module__.__len__() == 25  ('concurrent.futures.thread')
# ProcessPoolExecutor.__module__.__len__() == 26 ('concurrent.futures.process')
# ---------------------------------------------------------------------------

table concurrent_futures_extra241.name_module_lengths:
  description: "ThreadPoolExecutor and ProcessPoolExecutor name and module length checks — ThreadPoolExecutor.__name__.__len__()==18 ('ThreadPoolExecutor' has 18 chars); ProcessPoolExecutor.__name__.__len__()==19 ('ProcessPoolExecutor' has 19 chars, one more than ThreadPoolExecutor); ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread')==True (len=25); ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (len=26, one more than ThreadPoolExecutor module len); ThreadPoolExecutor.__module__.__len__()==25; ProcessPoolExecutor.__module__.__len__()==26; verified with Python 3.14.3"
  kind: python_call_eq
  category: name_module_lengths
  id_prefix: cf241len

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_name_eq,    ThreadPoolExecutor.__name__.__eq__,    ["ThreadPoolExecutor"],          true, "ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'; verified with Python 3.14.3"]
    - [tpe_name_len,   ThreadPoolExecutor.__name__.__len__,   [],                               18,   "ThreadPoolExecutor.__name__.__len__() == 18; verified with Python 3.14.3"]
    - [ppe_name_eq,    ProcessPoolExecutor.__name__.__eq__,   ["ProcessPoolExecutor"],          true, "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor'; verified with Python 3.14.3"]
    - [ppe_name_len,   ProcessPoolExecutor.__name__.__len__,  [],                               19,   "ProcessPoolExecutor.__name__.__len__() == 19 (one more than ThreadPoolExecutor); verified with Python 3.14.3"]
    - [tpe_mod_eq,     ThreadPoolExecutor.__module__.__eq__,  ["concurrent.futures.thread"],    true, "ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [tpe_mod_len,    ThreadPoolExecutor.__module__.__len__, [],                               25,   "ThreadPoolExecutor.__module__.__len__() == 25; verified with Python 3.14.3"]
    - [ppe_mod_eq,     ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"],   true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; verified with Python 3.14.3"]
    - [ppe_mod_len,    ProcessPoolExecutor.__module__.__len__, [],                              26,   "ProcessPoolExecutor.__module__.__len__() == 26 (one more than ThreadPoolExecutor module len); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# __init__.__doc__ contains checks
#
# ThreadPoolExecutor.__init__.__doc__.__contains__('thread') == True
# ProcessPoolExecutor.__init__.__doc__.__contains__('process') == True
#
# Note: class-level __doc__ is None for both; the docstring is on __init__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra241.init_doc_contains:
  description: "ThreadPoolExecutor and ProcessPoolExecutor __init__ docstring content checks — the class-level __doc__ is None for both classes; the docstring is on __init__; ThreadPoolExecutor.__init__.__doc__.__contains__('thread')==True (the __init__ docstring mentions 'thread' — 'Initializes a new ThreadPoolExecutor instance...'); ProcessPoolExecutor.__init__.__doc__.__contains__('process')==True (mentions 'process' — 'Initializes a new ProcessPoolExecutor instance...'); also checks qualname length: ThreadPoolExecutor.__qualname__.__len__()==18 (same as __name__.__len__()); ProcessPoolExecutor.__qualname__.__len__()==19 (same as __name__.__len__()); verified with Python 3.14.3"
  kind: python_call_eq
  category: init_doc_contains
  id_prefix: cf241doc

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_doc_thread,  ThreadPoolExecutor.__init__.__doc__.__contains__,  ["thread"],  true, "ThreadPoolExecutor.__init__.__doc__ contains 'thread'; verified with Python 3.14.3"]
    - [ppe_doc_process, ProcessPoolExecutor.__init__.__doc__.__contains__,  ["process"], true, "ProcessPoolExecutor.__init__.__doc__ contains 'process'; verified with Python 3.14.3"]
    - [tpe_qn_eq,       ThreadPoolExecutor.__qualname__.__eq__,             ["ThreadPoolExecutor"],  true, "ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' (len=18, same as __name__); verified with Python 3.14.3"]
    - [tpe_qn_len,      ThreadPoolExecutor.__qualname__.__len__,            [],           18,   "ThreadPoolExecutor.__qualname__.__len__() == 18; verified with Python 3.14.3"]
    - [ppe_qn_eq,       ProcessPoolExecutor.__qualname__.__eq__,            ["ProcessPoolExecutor"], true, "ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' (len=19); verified with Python 3.14.3"]
    - [ppe_qn_len,      ProcessPoolExecutor.__qualname__.__len__,           [],           19,   "ProcessPoolExecutor.__qualname__.__len__() == 19 (one more than ThreadPoolExecutor); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra241
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra241.tpe_name_len_18:
  description: "ThreadPoolExecutor.__name__.__len__() == 18 — 'ThreadPoolExecutor' has 18 characters: T-h-r-e-a-d-P-o-o-l-E-x-e-c-u-t-o-r; compare ProcessPoolExecutor.__name__.__len__()==19 (one more char: 'Process'=7 vs 'Thread'=6); ThreadPoolExecutor.__module__ is 'concurrent.futures.thread' (len=25); ThreadPoolExecutor.__qualname__.__len__()==18 (same as __name__.__len__(), module-level class); NEW in extra241: first standalone TPE name length invariant in cf241len namespace; verified with Python 3.14.3"
  category: name_module_lengths
  kind: python_call_eq
  function: ThreadPoolExecutor.__name__.__len__
  args: []
  expected: 18

invariant concurrent_futures_extra241.ppe_name_len_19:
  description: "ProcessPoolExecutor.__name__.__len__() == 19 — 'ProcessPoolExecutor' has 19 characters: P-r-o-c-e-s-s-P-o-o-l-E-x-e-c-u-t-o-r; one more than ThreadPoolExecutor.__name__.__len__()==18 because 'Process'=7 chars vs 'Thread'=6 chars; ProcessPoolExecutor.__module__ is 'concurrent.futures.process' (len=26); ProcessPoolExecutor.__qualname__.__len__()==19 (same as __name__.__len__(), module-level class); NEW in extra241: first standalone PPE name length invariant in cf241len namespace; verified with Python 3.14.3"
  category: name_module_lengths
  kind: python_call_eq
  function: ProcessPoolExecutor.__name__.__len__
  args: []
  expected: 19

invariant concurrent_futures_extra241.tpe_module_len_25:
  description: "ThreadPoolExecutor.__module__.__len__() == 25 — 'concurrent.futures.thread' has 25 characters: 'concurrent'=10 + '.'=1 + 'futures'=7 + '.'=1 + 'thread'=6 = 25; ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py; ProcessPoolExecutor.__module__.__len__()==26 ('concurrent.futures.process', one more char because 'process'=7 vs 'thread'=6); NEW in extra241: first standalone TPE module length invariant in cf241len namespace; verified with Python 3.14.3"
  category: name_module_lengths
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__len__
  args: []
  expected: 25

invariant concurrent_futures_extra241.ppe_module_len_26:
  description: "ProcessPoolExecutor.__module__.__len__() == 26 — 'concurrent.futures.process' has 26 characters: 'concurrent'=10 + '.'=1 + 'futures'=7 + '.'=1 + 'process'=7 = 26; one more than ThreadPoolExecutor.__module__.__len__()==25 because 'process'=7 vs 'thread'=6; ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py; NEW in extra241: first standalone PPE module length invariant in cf241len namespace; verified with Python 3.14.3"
  category: name_module_lengths
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__len__
  args: []
  expected: 26

invariant concurrent_futures_extra241.tpe_init_doc_contains_thread:
  description: "ThreadPoolExecutor.__init__.__doc__.__contains__('thread') returns True — the ThreadPoolExecutor class-level __doc__ is None; the docstring is on __init__ which reads 'Initializes a new ThreadPoolExecutor instance...'; the word 'thread' appears in 'ThreadPoolExecutor' and in descriptions of thread_name_prefix; this is a case-sensitive check; ProcessPoolExecutor.__init__.__doc__.__contains__('process') also returns True; NEW in extra241: first standalone TPE init doc contains invariant in cf241doc namespace; verified with Python 3.14.3"
  category: init_doc_contains
  kind: python_call_eq
  function: ThreadPoolExecutor.__init__.__doc__.__contains__
  args: ["thread"]
  expected: true

invariant concurrent_futures_extra241.ppe_init_doc_contains_process:
  description: "ProcessPoolExecutor.__init__.__doc__.__contains__('process') returns True — the ProcessPoolExecutor class-level __doc__ is None; the docstring is on __init__ which reads 'Initializes a new ProcessPoolExecutor instance...'; the word 'process' appears multiple times (ProcessPoolExecutor, 'worker processes', 'worker process', 'subprocess'); case-sensitive check; ThreadPoolExecutor.__init__.__doc__.__contains__('thread') also returns True; NEW in extra241: first standalone PPE init doc contains invariant in cf241doc namespace; verified with Python 3.14.3"
  category: init_doc_contains
  kind: python_call_eq
  function: ProcessPoolExecutor.__init__.__doc__.__contains__
  args: ["process"]
  expected: true
