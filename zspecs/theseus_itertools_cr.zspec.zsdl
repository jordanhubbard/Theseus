spec: theseus_itertools_cr
version: ">=3.9"
backend: python_cleanroom(theseus_itertools_cr)
blocks: itertools

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html"
  notes:
    - "Clean-room itertools. Do NOT import itertools."
    - "chain(*iterables): chains multiple iterables; list(chain([1,2],[3,4])) == [1,2,3,4]."
    - "islice(iterable, stop): slices iterator; list(islice(range(10), 3)) == [0,1,2]."
    - "product(*iterables): cartesian product; list(product([1,2],[3,4])) == [(1,3),(1,4),(2,3),(2,4)]."
    - "combinations(iterable, r): r-length combos; list(combinations([1,2,3],2)) == [(1,2),(1,3),(2,3)]."
    - "Export: chain, islice, product, combinations, permutations, accumulate, cycle, repeat."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_itertools_cr.chain:
  description: "list(chain([1,2],[3,4])) == [1,2,3,4]"
  category: chain
  kind: python_call_eq
  function: itertools_chain
  args: []
  expected: [1, 2, 3, 4]

invariant theseus_itertools_cr.islice:
  description: "list(islice(range(10), 3)) == [0,1,2]"
  category: islice
  kind: python_call_eq
  function: itertools_islice
  args: []
  expected: [0, 1, 2]

invariant theseus_itertools_cr.combinations:
  description: "list(combinations([1,2,3],2)) == [(1,2),(1,3),(2,3)]"
  category: combinations
  kind: python_call_eq
  function: itertools_combinations
  args: []
  expected: [[1, 2], [1, 3], [2, 3]]
