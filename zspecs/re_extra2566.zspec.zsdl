spec: re_extra2566
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2566 (_extra2566): __getattr__, __setattr__, __delattr__ dict-presence checks for re module C-extension types."
    - "re.Pattern and re.Match are C-extension types implemented in _sre. Despite being C types, neither defines __setattr__, __delattr__, or __getattr__ in their class __dict__."
    - "re.Pattern and re.Match do define __repr__, __hash__, __eq__, and their respective core methods (match/search for Pattern; group/groups for Match) in their class __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table re_extra2566.getattr_protocol:
  description: "re C-extension types __getattr__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2566

  columns: [id, function, args, expected]
  rows:
    - ["re2566001", "re.Pattern.__dict__.__contains__", ["__getattr__"], false]
    - ["re2566002", "re.Match.__dict__.__contains__",   ["__getattr__"], false]

table re_extra2566.setattr_protocol:
  description: "re C-extension types __setattr__ dict-presence — all False (C-level immutability not via Python-level __setattr__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2566s

  columns: [id, function, args, expected]
  rows:
    - ["re2566s001", "re.Pattern.__dict__.__contains__", ["__setattr__"], false]
    - ["re2566s002", "re.Match.__dict__.__contains__",   ["__setattr__"], false]

table re_extra2566.delattr_protocol:
  description: "re C-extension types __delattr__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2566d

  columns: [id, function, args, expected]
  rows:
    - ["re2566d001", "re.Pattern.__dict__.__contains__", ["__delattr__"], false]
    - ["re2566d002", "re.Match.__dict__.__contains__",   ["__delattr__"], false]

table re_extra2566.all_three_combined:
  description: "re C-extension types: combined check across all three attribute-access dunders"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2566x

  columns: [id, function, args, expected]
  rows:
    - ["re2566x001", "re.Pattern.__dict__.__contains__", ["__getattr__"], false]
    - ["re2566x002", "re.Pattern.__dict__.__contains__", ["__setattr__"], false]
    - ["re2566x003", "re.Pattern.__dict__.__contains__", ["__delattr__"], false]
    - ["re2566x004", "re.Match.__dict__.__contains__",   ["__getattr__"], false]
    - ["re2566x005", "re.Match.__dict__.__contains__",   ["__setattr__"], false]
    - ["re2566x006", "re.Match.__dict__.__contains__",   ["__delattr__"], false]
    - ["re2566x007", "re.Pattern.__dict__.__contains__", ["__repr__"],     true]
    - ["re2566x008", "re.Match.__dict__.__contains__",   ["__repr__"],     true]
    - ["re2566x009", "re.Pattern.__dict__.__contains__", ["match"],        true]
    - ["re2566x010", "re.Match.__dict__.__contains__",   ["group"],        true]
