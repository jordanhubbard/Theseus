spec: pathlib_extra295
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — PurePath class reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py, Lib/pathlib/_local.py"
  notes:
    - "PurePath.__bytes__ exists and has qualname 'PurePath.__bytes__'"
    - "All operator and comparison dunder methods are defined directly on PurePath"
    - "__fspath__ is present on PurePath in Python 3.9+"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table pathlib_extra295.operator_method_qualnames:
  description: "PurePath operator dunder method __qualname__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: ple295

  columns: [id, function, args, expected, description]
  rows:
    - [ple295001, pathlib.PurePath.__truediv__.__qualname__,  [], "PurePath.__truediv__",  "__truediv__ qualname"]
    - [ple295002, pathlib.PurePath.__rtruediv__.__qualname__, [], "PurePath.__rtruediv__", "__rtruediv__ qualname"]
    - [ple295003, pathlib.PurePath.__str__.__qualname__,      [], "PurePath.__str__",      "__str__ qualname"]
    - [ple295004, pathlib.PurePath.__repr__.__qualname__,     [], "PurePath.__repr__",     "__repr__ qualname"]
    - [ple295005, pathlib.PurePath.__hash__.__qualname__,     [], "PurePath.__hash__",     "__hash__ qualname"]
    - [ple295006, pathlib.PurePath.__eq__.__qualname__,       [], "PurePath.__eq__",       "__eq__ qualname"]

table pathlib_extra295.comparison_method_qualnames:
  description: "PurePath comparison and path protocol dunder method __qualname__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: ple295c

  columns: [id, function, args, expected, description]
  rows:
    - [ple295c001, pathlib.PurePath.__lt__.__qualname__,     [], "PurePath.__lt__",     "__lt__ qualname"]
    - [ple295c002, pathlib.PurePath.__le__.__qualname__,     [], "PurePath.__le__",     "__le__ qualname"]
    - [ple295c003, pathlib.PurePath.__gt__.__qualname__,     [], "PurePath.__gt__",     "__gt__ qualname"]
    - [ple295c004, pathlib.PurePath.__ge__.__qualname__,     [], "PurePath.__ge__",     "__ge__ qualname"]
    - [ple295c005, pathlib.PurePath.__fspath__.__qualname__, [], "PurePath.__fspath__", "__fspath__ qualname"]

invariant pathlib_extra295.bytes_qualname:
  description: "PurePath.__bytes__ qualname is 'PurePath.__bytes__'"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__bytes__.__qualname__
  args: []
  expected: "PurePath.__bytes__"

invariant pathlib_extra295.truediv_confirmed:
  description: "PurePath.__truediv__.__qualname__ confirmed as path-join operator"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__truediv__.__qualname__
  args: []
  expected: "PurePath.__truediv__"

invariant pathlib_extra295.rtruediv_confirmed:
  description: "PurePath.__rtruediv__.__qualname__ confirmed for right-hand path joining"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__rtruediv__.__qualname__
  args: []
  expected: "PurePath.__rtruediv__"
