spec: re_extra8
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and re_extra through re_extra7."
    - "Focus: __qualname__ attributes for re functions, exception, and core types."
    - "re.error.__qualname__ == 'error' (not 're.error' — qualname is unqualified within the module)."
    - "re.Match.__qualname__ == 'Match' and re.Pattern.__qualname__ == 'Pattern' (C-level types)."
    - "re.IGNORECASE and re.MULTILINE are members of the RegexFlag enum; their __class__.__name__ == 'RegexFlag'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for re functions (top-level callables)
# ---------------------------------------------------------------------------

table re_extra8.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [compile,   compile.__qualname__.__eq__,   ["compile"],   true]
    - [match,     match.__qualname__.__eq__,     ["match"],     true]
    - [search,    search.__qualname__.__eq__,    ["search"],    true]
    - [fullmatch, fullmatch.__qualname__.__eq__, ["fullmatch"], true]
    - [sub,       sub.__qualname__.__eq__,       ["sub"],       true]
    - [split,     split.__qualname__.__eq__,     ["split"],     true]
    - [findall,   findall.__qualname__.__eq__,   ["findall"],   true]
    - [finditer,  finditer.__qualname__.__eq__,  ["finditer"],  true]

# ---------------------------------------------------------------------------
# __qualname__ for re exception and core C-level types
# ---------------------------------------------------------------------------

invariant re_extra8.error.qualname:
  description: "re.error.__qualname__ == 'error'"
  category: qualnames
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

invariant re_extra8.Match.qualname:
  description: "re.Match.__qualname__ == 'Match'"
  category: qualnames
  kind: python_call_eq
  function: Match.__qualname__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra8.Pattern.qualname:
  description: "re.Pattern.__qualname__ == 'Pattern'"
  category: qualnames
  kind: python_call_eq
  function: Pattern.__qualname__.__eq__
  args: ["Pattern"]
  expected: true

# ---------------------------------------------------------------------------
# RegexFlag enum members: __class__.__name__ == 'RegexFlag'
# ---------------------------------------------------------------------------

invariant re_extra8.IGNORECASE.class_name:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag'"
  category: flags
  kind: python_call_eq
  function: IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra8.MULTILINE.class_name:
  description: "re.MULTILINE.__class__.__name__ == 'RegexFlag'"
  category: flags
  kind: python_call_eq
  function: MULTILINE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true
