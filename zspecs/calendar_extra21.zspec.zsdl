spec: calendar_extra21
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
    - "calendar_extra3.zspec.zsdl — covers __qualname__ for Calendar/TextCalendar/HTMLCalendar/isleap/monthrange/weekday; isleap/__module__"
    - "calendar_extra7.zspec.zsdl — covers Calendar/__qualname__; isleap; leapdays; monthrange; firstweekday/__module__"
    - "calendar_extra17.zspec.zsdl — covers Calendar.__init__.__qualname__/__module__; TextCalendar/__init__.__qualname__; HTMLCalendar/__init__.__qualname__; monthrange/__module__; isleap/__module__; leapdays/__module__; weekday/__module__"
    - "calendar_extra18.zspec.zsdl — covers Calendar/__init__.__name__; TextCalendar/__init__.__name__; HTMLCalendar/__init__.__name__; isleap/leapdays/weekday/monthrange __qualname__ and __module__ standalone invariants; monthcalendar/__qualname__"
    - "calendar_extra19.zspec.zsdl — covers Calendar/TextCalendar/HTMLCalendar __module__.__len__() and __name__.__len__(); isleap/leapdays/weekday/monthrange __module__.__len__(); isleap/__name__.__len__() and weekday/__name__.__len__()"
    - "calendar_extra20.zspec.zsdl — covers __qualname__.__len__() for Calendar/TextCalendar/HTMLCalendar/LocaleTextCalendar/LocaleHTMLCalendar; __module__.__len__() and __name__.__len__() for LocaleTextCalendar/LocaleHTMLCalendar; __qualname__.__len__() for itermonthdates/itermonthdays/monthdatescalendar/getfirstweekday"
  notes:
    - "This spec extends calendar_extra20.zspec.zsdl."
    - "Prior specs covered: Calendar/TextCalendar/HTMLCalendar/LocaleTextCalendar/LocaleHTMLCalendar __name__/__module__/__qualname__/__bases__, isleap/leapdays/weekday/monthrange/monthcalendar __name__/__module__/__qualname__, __init__.__name__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for classes, __qualname__.__len__() for itermonthdates/itermonthdays/monthdatescalendar/getfirstweekday."
    - "This spec covers: __mro__.__len__() for Calendar, TextCalendar, HTMLCalendar, LocaleTextCalendar; __bases__[0].__name__ for Calendar, TextCalendar, HTMLCalendar; __qualname__.__len__() for Calendar.itermonthdays2, Calendar.itermonthdays3, Calendar.itermonthdays4, TextCalendar.formatmonth, TextCalendar.formatyear, HTMLCalendar.formatmonth."
    - "calendar.Calendar.__mro__ == ['Calendar', 'object'] (len 2) — verified Python 3.12."
    - "calendar.TextCalendar.__mro__ == ['TextCalendar', 'Calendar', 'object'] (len 3) — verified Python 3.12."
    - "calendar.HTMLCalendar.__mro__ == ['HTMLCalendar', 'Calendar', 'object'] (len 3) — verified Python 3.12."
    - "calendar.LocaleTextCalendar.__mro__ == ['LocaleTextCalendar', 'TextCalendar', 'Calendar', 'object'] (len 4) — verified Python 3.12."
    - "calendar.Calendar.__bases__[0].__name__ == 'object' — verified Python 3.12."
    - "calendar.TextCalendar.__bases__[0].__name__ == 'Calendar' — verified Python 3.12."
    - "calendar.HTMLCalendar.__bases__[0].__name__ == 'Calendar' — verified Python 3.12."
    - "calendar.Calendar.itermonthdays2.__qualname__ == 'Calendar.itermonthdays2' (len 23) — verified Python 3.12."
    - "calendar.Calendar.itermonthdays3.__qualname__ == 'Calendar.itermonthdays3' (len 23) — verified Python 3.12."
    - "calendar.Calendar.itermonthdays4.__qualname__ == 'Calendar.itermonthdays4' (len 23) — verified Python 3.12."
    - "calendar.TextCalendar.formatmonth.__qualname__ == 'TextCalendar.formatmonth' (len 24) — verified Python 3.12."
    - "calendar.TextCalendar.formatyear.__qualname__ == 'TextCalendar.formatyear' (len 23) — verified Python 3.12."
    - "calendar.HTMLCalendar.formatmonth.__qualname__ == 'HTMLCalendar.formatmonth' (len 24) — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __mro__.__len__() for Calendar, TextCalendar, HTMLCalendar, LocaleTextCalendar
#
# The MRO depth reflects the inheritance hierarchy:
#   Calendar           -> [Calendar, object]                            -> 2
#   TextCalendar       -> [TextCalendar, Calendar, object]              -> 3
#   HTMLCalendar       -> [HTMLCalendar, Calendar, object]              -> 3
#   LocaleTextCalendar -> [LocaleTextCalendar, TextCalendar, Calendar, object] -> 4
# No prior calendar spec checks __mro__.__len__() for any of these classes.
# ---------------------------------------------------------------------------

table calendar_extra21.class_mro_depths:
  description: "__mro__.__len__() for Calendar, TextCalendar, HTMLCalendar, LocaleTextCalendar"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cmd21

  columns: [id, function, args, expected]
  rows:
    - [Calendar,           Calendar.__mro__.__len__,           [], 2]
    - [TextCalendar,       TextCalendar.__mro__.__len__,       [], 3]
    - [HTMLCalendar,       HTMLCalendar.__mro__.__len__,       [], 3]
    - [LocaleTextCalendar, LocaleTextCalendar.__mro__.__len__, [], 4]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for Calendar, TextCalendar, HTMLCalendar
#
# The immediate base class of each calendar class:
#   Calendar     -> object   (Calendar directly extends object)
#   TextCalendar -> Calendar (TextCalendar extends Calendar)
#   HTMLCalendar -> Calendar (HTMLCalendar extends Calendar)
# No prior calendar spec checks __bases__[0].__name__ for any of these three.
# Note: __bases__[0].__name__ contains '[' in the function path, so MUST be quoted.
# ---------------------------------------------------------------------------

table calendar_extra21.class_bases_names:
  description: "__bases__[0].__name__ for Calendar, TextCalendar, HTMLCalendar"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cbn21

  columns: [id, function, args, expected, method, method_args]
  rows:
    - [Calendar_base,     "Calendar.__bases__[0].__name__.__eq__",     ["object"],   true, __len__, []]
    - [TextCalendar_base, "TextCalendar.__bases__[0].__name__.__eq__", ["Calendar"], true, __len__, []]
    - [HTMLCalendar_base, "HTMLCalendar.__bases__[0].__name__.__eq__", ["Calendar"], true, __len__, []]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for Calendar.itermonthdays2/3/4 method qualnames
#
# All three iterator variants follow the same naming pattern:
#   Calendar.itermonthdays2 -> 'Calendar.itermonthdays2' -> 23
#   Calendar.itermonthdays3 -> 'Calendar.itermonthdays3' -> 23
#   Calendar.itermonthdays4 -> 'Calendar.itermonthdays4' -> 23
# calendar_extra20 covered itermonthdays (len 22) but not itermonthdays2/3/4.
# ---------------------------------------------------------------------------

invariant calendar_extra21.Calendar.itermonthdays2.qualname_len:
  description: "calendar.Calendar.itermonthdays2.__qualname__.__len__() == 23 — 'Calendar.itermonthdays2' has 23 characters"
  category: method_identity
  kind: python_call_eq
  function: Calendar.itermonthdays2.__qualname__.__len__
  args: []
  expected: 23

