spec: threading_extra269
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.local.__name__ == '_local' (len=6) — the C implementation name has a leading underscore."
    - "threading.local.__module__ == '_thread' (len=7) — local comes from the C extension _thread."
    - "threading.local.__class__.__name__ == 'type' — local is a C-level type."
    - "threading.excepthook.__name__ == '_excepthook' (len=11) — C implementation name with leading underscore."
    - "threading.excepthook.__module__ == '_thread' (len=7) — excepthook is in the C extension."
    - "threading.excepthook.__class__.__name__ == 'builtin_function_or_method' — C builtin."
    - "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' (len=15) — C structseq type, leading underscore."
    - "threading.ExceptHookArgs.__module__ == '_thread' (len=7)."
    - "threading.ExceptHookArgs.__bases__[0].__name__ == 'tuple' — structseq inherits from tuple."
    - "threading.ExceptHookArgs.n_fields == 4; n_sequence_fields == 4; n_unnamed_fields == 0."
    - "threading.get_ident.__name__ == 'get_ident' (len=8); __module__ == '_thread'; __class__.__name__ == 'builtin_function_or_method'."
    - "threading.get_native_id.__name__ == 'get_native_id' (len=13); __module__ == '_thread'."
    - "ExceptHookArgs.__name__ (15) is longest name in spec; get_native_id (13) second longest."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.local, excepthook, ExceptHookArgs identity
#
# local.__name__ (6) is shortest name in spec.
# excepthook.__name__ (11) has leading underscore.
# ExceptHookArgs.__name__ (15) is longest in spec.
# All three have __module__ == '_thread'.
# ---------------------------------------------------------------------------

table threading_extra269.local_excepthook_excepthookargs_identity:
  description: "threading.local(6), excepthook(11), ExceptHookArgs(15) identity — all have __module__ == '_thread'(7); local is C type; excepthook is builtin_function_or_method; ExceptHookArgs(15) is longest name in spec; all names have leading underscore in C impl; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex269a

  columns: [id, function, args, expected, description]
  rows:
    - [lo_name_eq,         local.__name__.__eq__,                       ["_local"],                     true, "threading.local.__name__ == '_local' — C implementation name with leading underscore; verified with Python 3.14.3"]
    - [lo_name_len,        local.__name__.__len__,                      [],                             6,    "threading.local.__name__.__len__() == 6 — shortest name in spec; verified with Python 3.14.3"]
    - [lo_qn_eq,           local.__qualname__.__eq__,                   ["_local"],                     true, "threading.local.__qualname__ == '_local' — qualname equals name; verified with Python 3.14.3"]
    - [lo_mod_eq,          local.__module__.__eq__,                     ["_thread"],                    true, "threading.local.__module__ == '_thread' — comes from C extension _thread; verified with Python 3.14.3"]
    - [lo_mod_len,         local.__module__.__len__,                    [],                             7,    "threading.local.__module__.__len__() == 7 — '_thread' len=7; verified with Python 3.14.3"]
    - [lo_cls_eq,          local.__class__.__name__.__eq__,             ["type"],                       true, "threading.local.__class__.__name__ == 'type' — local is a C-level type; verified with Python 3.14.3"]
    - [eh_name_eq,         excepthook.__name__.__eq__,                  ["_excepthook"],                true, "threading.excepthook.__name__ == '_excepthook' — C implementation name; verified with Python 3.14.3"]
    - [eh_name_len,        excepthook.__name__.__len__,                 [],                             11,   "threading.excepthook.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [eh_qn_eq,           excepthook.__qualname__.__eq__,              ["_excepthook"],                true, "threading.excepthook.__qualname__ == '_excepthook' — qualname equals name; verified with Python 3.14.3"]
    - [eh_mod_eq,          excepthook.__module__.__eq__,                ["_thread"],                    true, "threading.excepthook.__module__ == '_thread' — C extension; verified with Python 3.14.3"]
    - [eh_cls_eq,          excepthook.__class__.__name__.__eq__,        ["builtin_function_or_method"], true, "threading.excepthook.__class__.__name__ == 'builtin_function_or_method' — C builtin; verified with Python 3.14.3"]
    - [ea_name_eq,         ExceptHookArgs.__name__.__eq__,              ["_ExceptHookArgs"],            true, "threading.ExceptHookArgs.__name__ == '_ExceptHookArgs' — C structseq type; verified with Python 3.14.3"]
    - [ea_name_len,        ExceptHookArgs.__name__.__len__,             [],                             15,   "threading.ExceptHookArgs.__name__.__len__() == 15 — longest name in spec; verified with Python 3.14.3"]
    - [ea_qn_eq,           ExceptHookArgs.__qualname__.__eq__,          ["_ExceptHookArgs"],            true, "threading.ExceptHookArgs.__qualname__ == '_ExceptHookArgs' — qualname equals name; verified with Python 3.14.3"]
    - [ea_mod_eq,          ExceptHookArgs.__module__.__eq__,            ["_thread"],                    true, "threading.ExceptHookArgs.__module__ == '_thread' — C extension; verified with Python 3.14.3"]
    - [ea_cls_eq,          ExceptHookArgs.__class__.__name__.__eq__,    ["type"],                       true, "threading.ExceptHookArgs.__class__.__name__ == 'type' — C structseq type; verified with Python 3.14.3"]
    - [ea_base_eq,         ExceptHookArgs.__bases__.__getitem__(0).__name__.__eq__, ["tuple"],           true, "threading.ExceptHookArgs.__bases__[0].__name__ == 'tuple' — structseq inherits from tuple; verified with Python 3.14.3"]
    - [ea_nfields,         ExceptHookArgs.n_fields.__eq__,              [4],                            true, "threading.ExceptHookArgs.n_fields == 4 — four fields: exc_type, exc_value, exc_traceback, thread; verified with Python 3.14.3"]
    - [ea_nseq,            ExceptHookArgs.n_sequence_fields.__eq__,     [4],                            true, "threading.ExceptHookArgs.n_sequence_fields == 4 — all four fields are sequence fields; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.get_ident and threading.get_native_id identity
#
# Both are C builtins from _thread extension.
# get_ident.__name__ (8) < get_native_id.__name__ (13).
# ---------------------------------------------------------------------------

table threading_extra269.get_ident_get_native_id_identity:
  description: "threading.get_ident(8) and get_native_id(13) identity — both C builtins from _thread(7); get_native_id(13) longer than get_ident(8); both are builtin_function_or_method; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex269g

  columns: [id, function, args, expected, description]
  rows:
    - [gi_name_eq,         get_ident.__name__.__eq__,                   ["get_ident"],                  true, "threading.get_ident.__name__ == 'get_ident'; verified with Python 3.14.3"]
    - [gi_name_len,        get_ident.__name__.__len__,                  [],                             8,    "threading.get_ident.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [gi_qn_eq,           get_ident.__qualname__.__eq__,               ["get_ident"],                  true, "threading.get_ident.__qualname__ == 'get_ident' — qualname equals name; verified with Python 3.14.3"]
    - [gi_mod_eq,          get_ident.__module__.__eq__,                 ["_thread"],                    true, "threading.get_ident.__module__ == '_thread' — C extension; verified with Python 3.14.3"]
    - [gi_cls_eq,          get_ident.__class__.__name__.__eq__,         ["builtin_function_or_method"], true, "threading.get_ident.__class__.__name__ == 'builtin_function_or_method' — C builtin; verified with Python 3.14.3"]
    - [gn_name_eq,         get_native_id.__name__.__eq__,               ["get_native_id"],              true, "threading.get_native_id.__name__ == 'get_native_id'; verified with Python 3.14.3"]
    - [gn_name_len,        get_native_id.__name__.__len__,              [],                             13,   "threading.get_native_id.__name__.__len__() == 13 — longer than get_ident(8); verified with Python 3.14.3"]
    - [gn_qn_eq,           get_native_id.__qualname__.__eq__,           ["get_native_id"],              true, "threading.get_native_id.__qualname__ == 'get_native_id' — qualname equals name; verified with Python 3.14.3"]
    - [gn_mod_eq,          get_native_id.__module__.__eq__,             ["_thread"],                    true, "threading.get_native_id.__module__ == '_thread' — C extension; verified with Python 3.14.3"]
    - [gn_cls_eq,          get_native_id.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "threading.get_native_id.__class__.__name__ == 'builtin_function_or_method' — C builtin; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra269
# ---------------------------------------------------------------------------

invariant threading_extra269.local_name_is_shortest:
  description: "threading.local.__name__.__len__() == 6 — shortest name in spec; shorter than get_ident(8), excepthook(11), get_native_id(13), ExceptHookArgs(15)"
  category: identity
  kind: python_call_eq
  function: local.__name__.__len__
  args: []
  expected: 6

invariant threading_extra269.excepthookargs_name_is_longest:
  description: "threading.ExceptHookArgs.__name__.__len__() == 15 — longest name in spec; longer than get_native_id(13), excepthook(11), get_ident(8), local(6)"
  category: identity
  kind: python_call_eq
  function: ExceptHookArgs.__name__.__len__
  args: []
  expected: 15

invariant threading_extra269.all_have_thread_module:
  description: "threading.local.__module__ == '_thread' — all objects in this spec have __module__ == '_thread'; local, excepthook, ExceptHookArgs, get_ident, and get_native_id all come from the C extension"
  category: identity
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra269.excepthookargs_n_fields_is_four:
  description: "threading.ExceptHookArgs.n_fields == 4 — ExceptHookArgs has four fields: exc_type, exc_value, exc_traceback, thread"
  category: identity
  kind: python_call_eq
  function: ExceptHookArgs.n_fields.__eq__
  args: [4]
  expected: true

invariant threading_extra269.get_ident_is_builtin:
  description: "threading.get_ident.__class__.__name__ == 'builtin_function_or_method' — get_ident is a C builtin from _thread; same class as get_native_id and excepthook"
  category: identity
  kind: python_call_eq
  function: get_ident.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
