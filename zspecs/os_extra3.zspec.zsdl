spec: os_extra3
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/<module>.py"
  notes:
    - "Extends os.zspec.zsdl, os_extra.zspec.zsdl, os_extra2.zspec.zsdl, os_environ.zspec.zsdl, os_path.zspec.zsdl, os_path_extra.zspec.zsdl, and os_stat.zspec.zsdl."
    - "os.zspec.zsdl covers: O_RDONLY/O_WRONLY/O_RDWR values, extsep/curdir/pardir values, sep/pathsep length, name=='posix', function names table, getenv, getpid>0, urandom type/len, strerror, getcwd type."
    - "os_extra.zspec.zsdl covers: sep/linesep/pathsep class names, curdir/pardir/extsep values, name class name, getcwd/getpid/cpu_count class names, getpid positive, urandom class name and length."
    - "os_extra2.zspec.zsdl covers: devnull/sep/linesep class names, curdir/pardir/extsep values, altsep is NoneType, getcwd/listdir/makedirs function names."
    - "This spec adds: type checks for O_RDONLY/O_WRONLY/O_RDWR as ints, F_OK/R_OK/W_OK/X_OK values and type checks, SEEK_SET/SEEK_CUR/SEEK_END values and type checks, DEVNULL class name check."
    - "os.F_OK == 0, os.R_OK == 4, os.W_OK == 2, os.X_OK == 1 on all POSIX platforms (POSIX.1 standard)."
    - "os.SEEK_SET == 0, os.SEEK_CUR == 1, os.SEEK_END == 2 — these match POSIX lseek constants."
    - "os.DEVNULL is '/dev/null' on Unix or 'nul' on Windows; its type is always str."
    - "os.O_RDONLY, os.O_WRONLY, os.O_RDWR are plain int objects on all platforms."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Open flags O_RDONLY / O_WRONLY / O_RDWR — type checks
#
# Values are already in os.zspec.zsdl; this spec verifies they are plain ints.
# ---------------------------------------------------------------------------

invariant os_extra3.O_RDONLY.is_int:
  description: "os.O_RDONLY.__class__.__name__ == 'int' — open flag is a plain int"
  category: open_flags
  kind: python_call_eq
  function: O_RDONLY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant os_extra3.O_WRONLY.is_int:
  description: "os.O_WRONLY.__class__.__name__ == 'int' — open flag is a plain int"
  category: open_flags
  kind: python_call_eq
  function: O_WRONLY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant os_extra3.O_RDWR.is_int:
  description: "os.O_RDWR.__class__.__name__ == 'int' — open flag is a plain int"
  category: open_flags
  kind: python_call_eq
  function: O_RDWR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Access mode flags — F_OK / R_OK / W_OK / X_OK
#
# Used with os.access(). POSIX defines: F_OK==0, R_OK==4, W_OK==2, X_OK==1.
# ---------------------------------------------------------------------------

invariant os_extra3.F_OK.value:
  description: "os.F_OK == 0 — test for existence of file"
  category: access_flags
  kind: python_call_eq
  function: F_OK.__eq__
  args: [0]
  expected: true

invariant os_extra3.F_OK.is_int:
  description: "os.F_OK.__class__.__name__ == 'int' — access flag is a plain int"
  category: access_flags
  kind: python_call_eq
  function: F_OK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant os_extra3.R_OK.value:
  description: "os.R_OK == 4 — test for read permission"
  category: access_flags
  kind: python_call_eq
  function: R_OK.__eq__
  args: [4]
  expected: true

invariant os_extra3.R_OK.is_int:
  description: "os.R_OK.__class__.__name__ == 'int' — access flag is a plain int"
  category: access_flags
  kind: python_call_eq
  function: R_OK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant os_extra3.W_OK.value:
  description: "os.W_OK == 2 — test for write permission"
  category: access_flags
  kind: python_call_eq
  function: W_OK.__eq__
  args: [2]
  expected: true

invariant os_extra3.W_OK.is_int:
  description: "os.W_OK.__class__.__name__ == 'int' — access flag is a plain int"
  category: access_flags
  kind: python_call_eq
  function: W_OK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant os_extra3.X_OK.value:
  description: "os.X_OK == 1 — test for execute permission"
  category: access_flags
  kind: python_call_eq
  function: X_OK.__eq__
  args: [1]
  expected: true

invariant os_extra3.X_OK.is_int:
  description: "os.X_OK.__class__.__name__ == 'int' — access flag is a plain int"
  category: access_flags
  kind: python_call_eq
  function: X_OK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Seek constants — SEEK_SET / SEEK_CUR / SEEK_END
#
# Used with os.lseek(). Values match POSIX lseek whence constants.
# ---------------------------------------------------------------------------

invariant os_extra3.SEEK_SET.value:
  description: "os.SEEK_SET == 0 — seek from beginning of file"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant os_extra3.SEEK_SET.is_int:
  description: "os.SEEK_SET.__class__.__name__ == 'int' — seek constant is a plain int"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_SET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant os_extra3.SEEK_CUR.value:
  description: "os.SEEK_CUR == 1 — seek from current position"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant os_extra3.SEEK_CUR.is_int:
  description: "os.SEEK_CUR.__class__.__name__ == 'int' — seek constant is a plain int"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_CUR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant os_extra3.SEEK_END.value:
  description: "os.SEEK_END == 2 — seek from end of file"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant os_extra3.SEEK_END.is_int:
  description: "os.SEEK_END.__class__.__name__ == 'int' — seek constant is a plain int"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_END.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# DEVNULL constant — null device path
#
# os.DEVNULL is '/dev/null' on Unix, 'nul' on Windows. Always a str.
# os_extra2 already verifies devnull (lowercase) class name;
# this spec verifies DEVNULL (uppercase) which is the canonical public constant.
# ---------------------------------------------------------------------------

invariant os_extra3.DEVNULL.is_str:
  description: "os.DEVNULL.__class__.__name__ == 'str' — null device path is always a str"
  category: constants
  kind: python_call_eq
  function: DEVNULL.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra3.DEVNULL.nonempty:
  description: "len(os.DEVNULL) > 0 — DEVNULL path is always a non-empty string"
  category: constants
  kind: python_call_eq
  function: DEVNULL.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true
