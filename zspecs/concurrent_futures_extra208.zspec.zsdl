spec: concurrent_futures_extra208
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers concurrent.futures wait/as_completed constants: FIRST_COMPLETED, ALL_COMPLETED, FIRST_EXCEPTION class names, and wait.__code__.co_varnames details."
    - "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str' — FIRST_COMPLETED is a module-level string constant with value 'FIRST_COMPLETED'. Verified with Python 3.14.3."
    - "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str' — ALL_COMPLETED is a module-level string constant with value 'ALL_COMPLETED'. Verified with Python 3.14.3."
    - "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str' — FIRST_EXCEPTION is a module-level string constant with value 'FIRST_EXCEPTION'. Verified with Python 3.14.3."
    - "concurrent.futures.wait.__code__.co_varnames.__contains__('fs') == True — 'fs' is the first positional parameter of wait(). Verified with Python 3.14.3."
    - "concurrent.futures.wait.__code__.co_varnames.__len__() == 7 — wait() has 7 local variables: ('fs', 'timeout', 'return_when', 'f', 'done', 'not_done', 'waiter'). Verified with Python 3.14.3."
    - "The three completion-mode constants are plain str values (not enum members), equal to their own names: FIRST_COMPLETED='FIRST_COMPLETED', ALL_COMPLETED='ALL_COMPLETED', FIRST_EXCEPTION='FIRST_EXCEPTION'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures completion-mode constant class names
#
# concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str'
# concurrent.futures.ALL_COMPLETED.__class__.__name__   == 'str'
# concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str'
#
# The three completion-mode constants passed as return_when= to wait() are
# plain module-level strings, not enum members. New to concurrent_futures_extra208.
# ---------------------------------------------------------------------------

table concurrent_futures_extra208.completion_constants_class_names:
  description: "concurrent.futures FIRST_COMPLETED/ALL_COMPLETED/FIRST_EXCEPTION __class__.__name__ == 'str'; all three are plain string constants; new to concurrent_futures_extra208"
  kind: python_call_eq
  category: constant_type
  id_prefix: cfwait208

  columns: [id, function, args, expected, description]
  rows:
    - [first_completed_class_name_eq_str,
       "FIRST_COMPLETED.__class__.__name__.__eq__",
       ["str"],
       true,
       "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__('str') == True — FIRST_COMPLETED is a plain str constant; new to concurrent_futures_extra208; verified Python 3.14.3"]
    - [all_completed_class_name_eq_str,
       "ALL_COMPLETED.__class__.__name__.__eq__",
       ["str"],
       true,
       "concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__('str') == True — ALL_COMPLETED is a plain str constant; new to concurrent_futures_extra208; verified Python 3.14.3"]
    - [first_exception_class_name_eq_str,
       "FIRST_EXCEPTION.__class__.__name__.__eq__",
       ["str"],
       true,
       "concurrent.futures.FIRST_EXCEPTION.__class__.__name__.__eq__('str') == True — FIRST_EXCEPTION is a plain str constant; new to concurrent_futures_extra208; verified Python 3.14.3"]
    - [first_completed_class_name_not_enum,
       "FIRST_COMPLETED.__class__.__name__.__eq__",
       ["str"],
       true,
       "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__('str') == True — confirmed not an enum member; str type confirmed; new to concurrent_futures_extra208; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures completion constants self-equality
#
# concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') == True
# concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED')     == True
# concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION') == True
#
# Each constant is equal to the string of its own name. This makes them
# usable as string literals interchangeably. New to concurrent_futures_extra208.
# ---------------------------------------------------------------------------

table concurrent_futures_extra208.completion_constants_values:
  description: "concurrent.futures completion constants equal their own name strings; FIRST_COMPLETED=='FIRST_COMPLETED', ALL_COMPLETED=='ALL_COMPLETED', FIRST_EXCEPTION=='FIRST_EXCEPTION'; new to concurrent_futures_extra208"
  kind: python_call_eq
  category: constant_values
  id_prefix: cfwait208

  columns: [id, function, args, expected, description]
  rows:
    - [first_completed_value_eq,
       "FIRST_COMPLETED.__eq__",
       ["FIRST_COMPLETED"],
       true,
       "concurrent.futures.FIRST_COMPLETED.__eq__('FIRST_COMPLETED') == True — the constant equals its own name; new to concurrent_futures_extra208; verified Python 3.14.3"]
    - [all_completed_value_eq,
       "ALL_COMPLETED.__eq__",
       ["ALL_COMPLETED"],
       true,
       "concurrent.futures.ALL_COMPLETED.__eq__('ALL_COMPLETED') == True — the constant equals its own name; new to concurrent_futures_extra208; verified Python 3.14.3"]
    - [first_exception_value_eq,
       "FIRST_EXCEPTION.__eq__",
       ["FIRST_EXCEPTION"],
       true,
       "concurrent.futures.FIRST_EXCEPTION.__eq__('FIRST_EXCEPTION') == True — the constant equals its own name; new to concurrent_futures_extra208; verified Python 3.14.3"]
    - [first_completed_len_eq_15,
       "FIRST_COMPLETED.__len__",
       [],
       15,
       "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — 'FIRST_COMPLETED' has 15 characters; new to concurrent_futures_extra208; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures.wait.__code__.co_varnames details
#
# concurrent.futures.wait.__code__.co_varnames.__contains__('fs')      == True
# concurrent.futures.wait.__code__.co_varnames.__len__()               == 7
# concurrent.futures.wait.__code__.co_varnames.__contains__('timeout') == True
#
# wait()'s co_varnames tuple has 7 entries:
# ('fs', 'timeout', 'return_when', 'f', 'done', 'not_done', 'waiter')
# New to concurrent_futures_extra208.
# ---------------------------------------------------------------------------

table concurrent_futures_extra208.wait_code_varnames:
  description: "concurrent.futures.wait.__code__.co_varnames has 7 entries including 'fs', 'timeout', 'return_when'; new to concurrent_futures_extra208"
  kind: python_call_eq
  category: code_introspection
  id_prefix: cfwait208

  columns: [id, function, args, expected, description]
  rows:
    - [wait_varnames_has_fs,
       "wait.__code__.co_varnames.__contains__",
       ["fs"],
       true,
       "concurrent.futures.wait.__code__.co_varnames.__contains__('fs') == True — 'fs' is the first parameter of wait(); new to concurrent_futures_extra208; verified Python 3.14.3"]
    - [wait_varnames_has_timeout,
       "wait.__code__.co_varnames.__contains__",
       ["timeout"],
       true,
       "concurrent.futures.wait.__code__.co_varnames.__contains__('timeout') == True — 'timeout' is the second parameter of wait(); new to concurrent_futures_extra208; verified Python 3.14.3"]
    - [wait_varnames_has_return_when,
       "wait.__code__.co_varnames.__contains__",
       ["return_when"],
       true,
       "concurrent.futures.wait.__code__.co_varnames.__contains__('return_when') == True — 'return_when' controls the completion mode; new to concurrent_futures_extra208; verified Python 3.14.3"]
    - [wait_varnames_len_eq_7,
       "wait.__code__.co_varnames.__len__",
       [],
       7,
       "concurrent.futures.wait.__code__.co_varnames.__len__() == 7 — wait() has 7 local variable names: fs/timeout/return_when/f/done/not_done/waiter; new to concurrent_futures_extra208; verified Python 3.14.3"]

