invariant concurrent_futures_extra208.wait_varnames_has_fs:
  description: "concurrent.futures.wait.__code__.co_varnames.__contains__('fs') == True — 'fs' is the first positional parameter of wait(fs, timeout=None, return_when=ALL_COMPLETED); new to concurrent_futures_extra208; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_introspection
  kind: python_call_eq
