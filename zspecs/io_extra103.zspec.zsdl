spec: io_extra103
version: ">=3.9"
backend: python_module(io)
extends: io_extra102

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/textio.c"
  notes:
    - "This spec extends io_extra102.zspec.zsdl."
    - "This spec covers: io.TextIOWrapper method and property class names."
    - "io.TextIOWrapper is a C extension type from _io."
    - "Regular methods (read, write, seek, tell, flush, close, etc.) are 'method_descriptor' when accessed on the class."
    - "Slot wrappers (__init__, __repr__) are 'wrapper_descriptor'."
    - "__enter__ and __exit__ are 'method_descriptor' (not wrapper_descriptor)."
    - "Properties (encoding, errors, line_buffering, write_through, buffer) are 'member_descriptor' or 'getset_descriptor'."
    - "encoding is 'member_descriptor', errors is 'getset_descriptor', line_buffering is 'member_descriptor'."
    - "buffer is 'member_descriptor', closed is 'getset_descriptor'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper core method class names
# read, write, readline, readlines, writelines -> method_descriptor
# ---------------------------------------------------------------------------

table io_extra103.TextIOWrapper_core_methods_classname:
  description: "io.TextIOWrapper core methods (read, write, readline, readlines, writelines) __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iotextiowrappermethod103

  columns: [id, function, args, expected]
  rows:
    - [tiow_read_cls,       TextIOWrapper.read.__class__.__name__.__eq__,       ["method_descriptor"], true]
    - [tiow_write_cls,      TextIOWrapper.write.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [tiow_readline_cls,   TextIOWrapper.readline.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [tiow_readlines_cls,  TextIOWrapper.readlines.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [tiow_writelines_cls, TextIOWrapper.writelines.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [tiow_read_not_wr,    TextIOWrapper.read.__class__.__name__.__eq__,       ["wrapper_descriptor"], false]

# ---------------------------------------------------------------------------
# io.TextIOWrapper aux method class names
# seek, tell, flush, close, readable, writable, seekable -> method_descriptor
# ---------------------------------------------------------------------------

table io_extra103.TextIOWrapper_aux_methods_classname:
  description: "io.TextIOWrapper aux methods (seek, tell, flush, close, readable, writable, seekable) __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iotextiowrappermethod103

  columns: [id, function, args, expected]
  rows:
    - [tiow_seek_cls,     TextIOWrapper.seek.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [tiow_tell_cls,     TextIOWrapper.tell.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [tiow_flush_cls,    TextIOWrapper.flush.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [tiow_close_cls,    TextIOWrapper.close.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [tiow_readable_cls, TextIOWrapper.readable.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [tiow_writable_cls, TextIOWrapper.writable.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [tiow_seekable_cls, TextIOWrapper.seekable.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [tiow_seek_not_fn,  TextIOWrapper.seek.__class__.__name__.__eq__,     ["function"],          false]

# ---------------------------------------------------------------------------
# io.TextIOWrapper dunder method class names
# __init__, __repr__ -> wrapper_descriptor
# __enter__, __exit__ -> method_descriptor
# ---------------------------------------------------------------------------

table io_extra103.TextIOWrapper_dunder_methods_classname:
  description: "io.TextIOWrapper dunder methods: __init__ and __repr__ are 'wrapper_descriptor'; __enter__ and __exit__ are 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iotextiowrappermethod103

  columns: [id, function, args, expected]
  rows:
    - [tiow_init_cls,       TextIOWrapper.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [tiow_repr_cls,       TextIOWrapper.__repr__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [tiow_enter_cls,      TextIOWrapper.__enter__.__class__.__name__.__eq__, ["method_descriptor"],  true]
    - [tiow_exit_cls,       TextIOWrapper.__exit__.__class__.__name__.__eq__,  ["method_descriptor"],  true]
    - [tiow_init_not_meth,  TextIOWrapper.__init__.__class__.__name__.__eq__,  ["method_descriptor"],  false]
    - [tiow_enter_not_wr,   TextIOWrapper.__enter__.__class__.__name__.__eq__, ["wrapper_descriptor"], false]

# ---------------------------------------------------------------------------
# io.TextIOWrapper property class names
# encoding -> member_descriptor, errors -> getset_descriptor,
# line_buffering -> member_descriptor, buffer -> member_descriptor,
# closed -> getset_descriptor
# ---------------------------------------------------------------------------

table io_extra103.TextIOWrapper_property_classnames:
  description: "io.TextIOWrapper property class names: encoding/line_buffering/buffer are 'member_descriptor'; errors/closed are 'getset_descriptor'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iotextiowrappermethod103

  columns: [id, function, args, expected]
  rows:
    - [tiow_encoding_cls,      TextIOWrapper.encoding.__class__.__name__.__eq__,      ["member_descriptor"],  true]
    - [tiow_errors_cls,        TextIOWrapper.errors.__class__.__name__.__eq__,        ["getset_descriptor"],  true]
    - [tiow_linebuf_cls,       TextIOWrapper.line_buffering.__class__.__name__.__eq__, ["member_descriptor"],  true]
    - [tiow_buffer_cls,        TextIOWrapper.buffer.__class__.__name__.__eq__,        ["member_descriptor"],  true]
    - [tiow_closed_cls,        TextIOWrapper.closed.__class__.__name__.__eq__,        ["getset_descriptor"],  true]
    - [tiow_encoding_not_prop, TextIOWrapper.encoding.__class__.__name__.__eq__,      ["property"],           false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra103.TextIOWrapper.read_is_method_descriptor:
  description: "io.TextIOWrapper.read.__class__.__name__ == 'method_descriptor' (TextIOWrapper is a C extension type; its regular methods are method_descriptor when accessed on the class)"
  category: method_descriptor
  kind: python_call_eq
  function: TextIOWrapper.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra103.TextIOWrapper.init_is_wrapper_descriptor:
  description: "io.TextIOWrapper.__init__.__class__.__name__ == 'wrapper_descriptor' (slot wrappers on C extension types are wrapper_descriptor, not method_descriptor)"
  category: method_descriptor
  kind: python_call_eq
  function: TextIOWrapper.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant io_extra103.TextIOWrapper.enter_is_method_descriptor:
  description: "io.TextIOWrapper.__enter__.__class__.__name__ == 'method_descriptor' (__enter__ is a regular C method on TextIOWrapper, not a slot wrapper)"
  category: method_descriptor
  kind: python_call_eq
  function: TextIOWrapper.__enter__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra103.TextIOWrapper.encoding_is_member_descriptor:
  description: "io.TextIOWrapper.encoding.__class__.__name__ == 'member_descriptor' (C-level struct members exposed as descriptors are 'member_descriptor')"
  category: method_descriptor
  kind: python_call_eq
  function: TextIOWrapper.encoding.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant io_extra103.TextIOWrapper.errors_is_getset_descriptor:
  description: "io.TextIOWrapper.errors.__class__.__name__ == 'getset_descriptor' (C-level getter/setter properties are 'getset_descriptor', distinct from 'member_descriptor')"
  category: method_descriptor
  kind: python_call_eq
  function: TextIOWrapper.errors.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true
