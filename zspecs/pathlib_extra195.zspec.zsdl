  notes:
    - "pathlib.PurePath.__str__.__name__ == '__str__' (len=7); class='function'."
    - "pathlib.PurePath.__repr__.__name__ == '__repr__' (len=8); class='function'."
    - "pathlib.PurePath.__fspath__.__name__ == '__fspath__' (len=10); class='function'."
    - "pathlib.PurePath.__hash__.__name__ == '__hash__' (len=8); class='function'."
    - "pathlib.PurePath.__eq__.__name__ == '__eq__' (len=6); class='function'."
    - "pathlib.PurePath.__lt__.__name__ == '__lt__' (len=6); class='function'; tied with __eq__."
    - "pathlib.PurePath.__truediv__.__name__ == '__truediv__' (len=11); class='function'."
    - "pathlib.PurePath.__rtruediv__.__name__ == '__rtruediv__' (len=12); class='function'; longest of the 8 dunders."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

