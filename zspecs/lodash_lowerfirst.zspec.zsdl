spec: lodash_lowerfirst
version: ">=4.0.0"
backend: node(lodash.lowerfirst)

docs: https://lodash.com/docs/#lowerFirst

provenance:
  derived_from:
    - "lodash.lowerfirst README — https://www.npmjs.com/package/lodash.lowerfirst"
    - "Test vectors verified with lodash.lowerfirst@4.3.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.lowerfirst exports the _.lowerFirst function directly as module.exports."
    - "lowerFirst(string) converts the first character to lower case."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string with first character lowercased."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_lowerfirst.lowerfirst:
  kind: node_module_call_eq
  function: ~
  category: lowerfirst
  id_prefix: llof

  columns: [id, args, expected]
  rows:
    - [upper,    ["Hello"],    "hello"]
    - [lower,    ["hello"],    "hello"]
    - [all_up,   ["FOO BAR"],  "fOO BAR"]
    - [empty,    [""],         ""]

