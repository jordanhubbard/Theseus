    - "Prior spec extra109 covered accumulate.__new__.__qualname__.__eq__('accumulate.__new__') and __new__.__class__.__name__. Prior extra110 covered accumulate.__init__.__qualname__.__eq__('object.__init__') and __init__.__class__.__name__. New here: accumulate.__next__.__qualname__ and __iter__.__qualname__ equality and length; accumulate.__name__ equality and length; cross-comparison of qualname lengths."
    - "itertools.accumulate.__next__.__qualname__ == 'accumulate.__next__' (len 19). Verified with Python 3.14.3."
    - "itertools.accumulate.__iter__.__qualname__ == 'accumulate.__iter__' (len 19). Verified with Python 3.14.3."
    - "itertools.accumulate.__new__.__qualname__ == 'accumulate.__new__' (len 18). Verified with Python 3.14.3."
    - "itertools.accumulate.__next__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.accumulate.__iter__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.accumulate.__name__ == 'accumulate' (len 10). Verified with Python 3.14.3."
    - "accumulate.__next__.__qualname__ len=19: 'accumulate'(10) + '.'(1) + '__next__'(8) = 19. Same for __iter__ qualname. accumulate.__new__.__qualname__ len=18: 'accumulate'(10) + '.'(1) + '__new__'(7) = 18."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.accumulate.__next__ and __iter__ slot qualname equality
#
# Wave 273 theme: itertools.accumulate is a C-extension type that produces
# running totals (or other cumulative operations). It has 10 chars in its name
# ('accumulate'), which drives slot qualname lengths. co_varnames[0] is 'accumulate'.
# accumulate.__next__.__qualname__ == 'accumulate.__next__' (len 19):
#   'accumulate'(10) + '.'(1) + '__next__'(8) = 19.
# accumulate.__iter__.__qualname__ == 'accumulate.__iter__' (len 19):
#   'accumulate'(10) + '.'(1) + '__iter__'(8) = 19.
# Both are wrapper_descriptor type slots (C-level tp_iternext and tp_iter slots).
# Contrast with groupby (7-char name): groupby.__next__ qualname len = 16 (extra121).
# accumulate qualname lengths are 3 more than groupby because 'accumulate' is
# 3 chars longer than 'groupby'.
#
# accumulate.__next__.__qualname__ == 'accumulate.__next__'  (len 19)
# accumulate.__iter__.__qualname__ == 'accumulate.__iter__'  (len 19)
#
# New to extra122.
# ---------------------------------------------------------------------------

table itertools_extra122.accumulate_next_iter_qualname_eq:
  description: "itertools.accumulate slot qualname equality: __next__='accumulate.__next__'(19), __iter__='accumulate.__iter__'(19); both wrapper_descriptor; 10+1+8=19; 3 more than groupby (16, extra121); wave 273; new to extra122"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsaccniq122

  columns: [id, function, args, expected, description]
  rows:
    - [acc_next_qualname_eq,
       "accumulate.__next__.__qualname__.__eq__",
       ["accumulate.__next__"],
       true,
       "itertools.accumulate.__next__.__qualname__.__eq__('accumulate.__next__') == True — accumulate exposes its tp_iternext slot as __next__; qualname is 'accumulate.__next__' (19 chars = 10+1+8); str.__eq__('accumulate.__next__') returns True; new to extra122"]
    - [acc_iter_qualname_eq,
       "accumulate.__iter__.__qualname__.__eq__",
       ["accumulate.__iter__"],
       true,
       "itertools.accumulate.__iter__.__qualname__.__eq__('accumulate.__iter__') == True — accumulate exposes its tp_iter slot as __iter__; qualname is 'accumulate.__iter__' (19 chars = 10+1+8); str.__eq__('accumulate.__iter__') returns True; new to extra122"]
    - [acc_next_qualname_len,
       "accumulate.__next__.__qualname__.__len__",
       [],
       19,
       "itertools.accumulate.__next__.__qualname__.__len__() == 19 — 'accumulate.__next__' = accumulate(10)+dot(1)+__next__(8) = 19; same as __iter__ qualname length; 3 more than groupby.__next__ qualname (16, extra121); str.__len__() returns 19; new to extra122"]
    - [acc_next_class_name_eq,
       "accumulate.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.accumulate.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — tp_iternext slot on accumulate is a wrapper_descriptor; consistent with all itertools C-iterator __next__ slots; str.__eq__('wrapper_descriptor') returns True; new to extra122"]
    - [acc_iter_class_name_eq,
       "accumulate.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.accumulate.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — tp_iter slot on accumulate is a wrapper_descriptor; consistent with all itertools C-iterator __iter__ slots; str.__eq__('wrapper_descriptor') returns True; new to extra122"]

# ---------------------------------------------------------------------------
# Table 2: itertools.accumulate.__new__ qualname and accumulate.__name__
#
# Wave 273 theme: accumulate.__new__.__qualname__ == 'accumulate.__new__'
# (len 18): 'accumulate'(10) + '.'(1) + '__new__'(7) = 18. This is 1 less than
# the __next__ and __iter__ qualnames (both 19) because '__new__' has 7 chars
# while '__next__' and '__iter__' both have 8 chars. The same length pattern
# holds for groupby: groupby.__new__ qualname len=15, groupby.__next__ len=16
# (extra121). accumulate.__name__ == 'accumulate' (10 chars) — 3 more than
# groupby (7 chars), explaining why accumulate qualname lengths exceed
# groupby qualname lengths by 3.
#
# accumulate.__new__.__qualname__ == 'accumulate.__new__'  (len 18)
# accumulate.__name__ == 'accumulate'                       (len 10)
#
# New to extra122.
# ---------------------------------------------------------------------------

table itertools_extra122.accumulate_new_qualname_and_name:
  description: "itertools.accumulate.__new__ qualname: 'accumulate.__new__'(18); 10+1+7=18, one less than __next__/__iter__ (19); accumulate.__name__='accumulate'(10); 3 more chars than groupby (7); wave 273; new to extra122"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsaccnwq122

  columns: [id, function, args, expected, description]
  rows:
    - [acc_new_qualname_eq,
       "accumulate.__new__.__qualname__.__eq__",
       ["accumulate.__new__"],
       true,
       "itertools.accumulate.__new__.__qualname__.__eq__('accumulate.__new__') == True — accumulate exposes its tp_new slot as __new__; qualname is 'accumulate.__new__' (18 chars); prior extra109 covered __new__.__class__.__name__; str.__eq__('accumulate.__new__') returns True; new to extra122"]
    - [acc_new_qualname_len,
       "accumulate.__new__.__qualname__.__len__",
       [],
       18,
       "itertools.accumulate.__new__.__qualname__.__len__() == 18 — 'accumulate.__new__' = accumulate(10)+dot(1)+__new__(7) = 18; one less than __next__/__iter__ qualnames (19) because '__new__' is 7 chars vs 8; str.__len__() returns 18; new to extra122"]
    - [acc_name_eq,
       "accumulate.__name__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — the class name is 'accumulate'; 10 chars; drives all slot qualname lengths; str.__eq__('accumulate') returns True; new to extra122"]
    - [acc_name_len,
       "accumulate.__name__.__len__",
       [],
       10,
       "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' has 10 chars: a-c-c-u-m-u-l-a-t-e; 3 more than groupby (7); explains why accumulate slot qualnames are 3 longer than corresponding groupby qualnames; str.__len__() returns 10; new to extra122"]
    - [acc_qualname_eq,
       "accumulate.__qualname__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate.__qualname__.__eq__('accumulate') == True — accumulate is a module-level C type; its __qualname__ equals its __name__ ('accumulate'); no nesting prefix; str.__eq__('accumulate') returns True; new to extra122"]

# ---------------------------------------------------------------------------
# Table 3: itertools.accumulate slot qualname length cross-comparison
#
# Wave 273 theme: Comparing qualname lengths across accumulate's three slot
# types. __next__ and __iter__ share length 19 (both slot names are 8 chars);
# __new__ has length 18 (slot name is 7 chars). The difference of 1 between
# __new__ (18) and __next__/__iter__ (19) is universal: it holds for groupby
# (15 vs 16, extra121), starmap, product, and any other itertools C type.
# Confirming: accumulate.__next__ qualname len (19) > accumulate.__new__
# qualname len (18) > accumulate.__init__ qualname (15, 'object.__init__',
# which is inherited so its qualname refers to object not accumulate).
#
# accumulate.__next__.__qualname__.__len__() == 19
# accumulate.__iter__.__qualname__.__len__() == 19
# accumulate.__new__.__qualname__.__len__()  == 18
#
# New to extra122.
# ---------------------------------------------------------------------------

table itertools_extra122.accumulate_slot_qualname_length_comparison:
  description: "itertools.accumulate slot qualname length comparison: __next__ len=19, __iter__ len=19, __new__ len=18; __next__==__iter__ (both 8-char slot names); __new__ is 1 less (7-char slot name); mirrors groupby pattern (extra121); wave 273; new to extra122"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolsaccslc122

  columns: [id, function, args, expected, description]
  rows:
    - [acc_next_len_19,
       "accumulate.__next__.__qualname__.__len__",
       [],
       19,
       "itertools.accumulate.__next__.__qualname__.__len__() == 19 — formula: 'accumulate'(10)+dot(1)+'__next__'(8)=19; 3 more than groupby.__next__ qualname len (16, extra121) because 'accumulate' is 3 chars longer than 'groupby'; str.__len__() returns 19; new to extra122"]
    - [acc_iter_len_19,
       "accumulate.__iter__.__qualname__.__len__",
       [],
       19,
       "itertools.accumulate.__iter__.__qualname__.__len__() == 19 — formula: 'accumulate'(10)+dot(1)+'__iter__'(8)=19; equal to __next__ qualname length because '__iter__' and '__next__' share the same 8-char length; str.__len__() returns 19; new to extra122"]
    - [acc_new_len_18,
       "accumulate.__new__.__qualname__.__len__",
       [],
       18,
       "itertools.accumulate.__new__.__qualname__.__len__() == 18 — formula: 'accumulate'(10)+dot(1)+'__new__'(7)=18; one less than __next__/__iter__ (19) because '__new__' is 7 chars; matches the pattern groupby.__new__ (15) = groupby (7)+dot+__new__(7); str.__len__() returns 18; new to extra122"]
    - [acc_next_qualname_ne_new,
       "accumulate.__next__.__qualname__.__eq__",
       ["accumulate.__new__"],
       false,
       "itertools.accumulate.__next__.__qualname__.__eq__('accumulate.__new__') == False — __next__ qualname is 'accumulate.__next__', not 'accumulate.__new__'; they are different slot names; str.__eq__('accumulate.__new__') returns False; new to extra122"]
    - [acc_next_iter_qualname_eq_each_other,
       "accumulate.__next__.__qualname__.__eq__",
       ["accumulate.__iter__"],
       false,
       "itertools.accumulate.__next__.__qualname__.__eq__('accumulate.__iter__') == False — __next__ qualname is 'accumulate.__next__', not 'accumulate.__iter__'; distinct slot qualnames despite equal lengths; str.__eq__('accumulate.__iter__') returns False; new to extra122"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra122
# ---------------------------------------------------------------------------

invariant itertools_extra122.acc_next_qualname_eq:
  description: "itertools.accumulate.__next__.__qualname__ == 'accumulate.__next__' — tp_iternext slot; len=19; 10+1+8=19; prior specs covered __new__ and __init__ qualnames; wave 273; new to extra122"
  kind: python_call_eq
  function: accumulate.__next__.__qualname__.__eq__
  args: ["accumulate.__next__"]
  expected: true

invariant itertools_extra122.acc_iter_qualname_eq:
  description: "itertools.accumulate.__iter__.__qualname__ == 'accumulate.__iter__' — tp_iter slot; len=19; same length as __next__ qualname; both wrapper_descriptor; wave 273; new to extra122"
  kind: python_call_eq
  function: accumulate.__iter__.__qualname__.__eq__
  args: ["accumulate.__iter__"]
  expected: true

invariant itertools_extra122.acc_new_qualname_len:
  description: "itertools.accumulate.__new__.__qualname__.__len__() == 18 — 'accumulate.__new__' = 10+1+7=18; one less than __next__/__iter__ (19); wave 273; new to extra122"
  kind: python_call_eq
  function: accumulate.__new__.__qualname__.__len__
  args: []
  expected: 18

invariant itertools_extra122.acc_name_len:
  description: "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' has 10 chars; 3 more than groupby (7); drives all slot qualname lengths being 3 more than groupby; wave 273; new to extra122"
  kind: python_call_eq
  function: accumulate.__name__.__len__
  args: []
  expected: 10

invariant itertools_extra122.acc_next_class_wrapper_descriptor:
  description: "itertools.accumulate.__next__.__class__.__name__ == 'wrapper_descriptor' — tp_iternext slot type; consistent with all itertools C-iterator __next__ slots; wave 273; new to extra122"
  kind: python_call_eq
  function: accumulate.__next__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

