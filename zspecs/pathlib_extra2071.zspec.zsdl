spec: pathlib_extra2071
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "pathlib.Path, pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath are path types; none define numeric sign operators."
    - "None of the pathlib types define __pos__ or __neg__; path objects are not numeric."
    - "None of the pathlib types define __getattribute__ in their own __dict__."
    - "pathlib.PurePath defines __reduce__ (True) — PurePath customizes pickling to reconstruct via its constructor."
    - "pathlib.Path, pathlib.PurePosixPath, pathlib.PureWindowsPath do NOT define __reduce__ in their own __dict__ (False) — they inherit from PurePath."
    - "None of the pathlib types define __reduce_ex__ in their own __dict__."
    - "None of the pathlib types define __copy__ or __deepcopy__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table pathlib_extra2071.unary_sign_protocol:
  description: "pathlib types __pos__/__neg__ dict-presence checks — all False; path types are not numeric"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2071

  columns: [id, function, args, expected]
  rows:
    - ["pl2071001", "pathlib.Path.__dict__.__contains__",           ["__pos__"], false]
    - ["pl2071002", "pathlib.Path.__dict__.__contains__",           ["__neg__"], false]
    - ["pl2071003", "pathlib.PurePath.__dict__.__contains__",       ["__pos__"], false]
    - ["pl2071004", "pathlib.PurePath.__dict__.__contains__",       ["__neg__"], false]
    - ["pl2071005", "pathlib.PurePosixPath.__dict__.__contains__",  ["__pos__"], false]
    - ["pl2071006", "pathlib.PurePosixPath.__dict__.__contains__",  ["__neg__"], false]
    - ["pl2071007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__pos__"], false]
    - ["pl2071008", "pathlib.PureWindowsPath.__dict__.__contains__", ["__neg__"], false]

table pathlib_extra2071.getattribute_protocol:
  description: "pathlib types __getattribute__ dict-presence checks — all False; attribute lookup inherits from object"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2071

  columns: [id, function, args, expected]
  rows:
    - ["pl2071009", "pathlib.Path.__dict__.__contains__",           ["__getattribute__"], false]
    - ["pl2071010", "pathlib.PurePath.__dict__.__contains__",       ["__getattribute__"], false]
    - ["pl2071011", "pathlib.PurePosixPath.__dict__.__contains__",  ["__getattribute__"], false]
    - ["pl2071012", "pathlib.PureWindowsPath.__dict__.__contains__", ["__getattribute__"], false]

table pathlib_extra2071.reduce_protocol:
  description: "pathlib types __reduce__/__reduce_ex__ dict-presence — PurePath defines __reduce__ (True); all others False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2071

  columns: [id, function, args, expected]
  rows:
    - ["pl2071013", "pathlib.Path.__dict__.__contains__",           ["__reduce__"],    false]
    - ["pl2071014", "pathlib.Path.__dict__.__contains__",           ["__reduce_ex__"], false]
    - ["pl2071015", "pathlib.PurePath.__dict__.__contains__",       ["__reduce__"],    true]
    - ["pl2071016", "pathlib.PurePath.__dict__.__contains__",       ["__reduce_ex__"], false]
    - ["pl2071017", "pathlib.PurePosixPath.__dict__.__contains__",  ["__reduce__"],    false]
    - ["pl2071018", "pathlib.PurePosixPath.__dict__.__contains__",  ["__reduce_ex__"], false]
    - ["pl2071019", "pathlib.PureWindowsPath.__dict__.__contains__", ["__reduce__"],    false]
    - ["pl2071020", "pathlib.PureWindowsPath.__dict__.__contains__", ["__reduce_ex__"], false]

table pathlib_extra2071.copy_protocol:
  description: "pathlib types __copy__/__deepcopy__ dict-presence checks — all False; copy protocol not customized in pathlib classes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2071

  columns: [id, function, args, expected]
  rows:
    - ["pl2071021", "pathlib.Path.__dict__.__contains__",           ["__copy__"],     false]
    - ["pl2071022", "pathlib.Path.__dict__.__contains__",           ["__deepcopy__"], false]
    - ["pl2071023", "pathlib.PurePath.__dict__.__contains__",       ["__copy__"],     false]
    - ["pl2071024", "pathlib.PurePath.__dict__.__contains__",       ["__deepcopy__"], false]
    - ["pl2071025", "pathlib.PurePosixPath.__dict__.__contains__",  ["__copy__"],     false]
    - ["pl2071026", "pathlib.PurePosixPath.__dict__.__contains__",  ["__deepcopy__"], false]
    - ["pl2071027", "pathlib.PureWindowsPath.__dict__.__contains__", ["__copy__"],     false]
    - ["pl2071028", "pathlib.PureWindowsPath.__dict__.__contains__", ["__deepcopy__"], false]
    - ["pl2071029", "pathlib.Path.__dict__.__contains__",           ["__pos__"],      false]
    - ["pl2071030", "pathlib.PurePath.__dict__.__contains__",       ["__pos__"],      false]
