spec: th3361
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 671 (th3361): __invert__, __floor__, __ceil__ dict-presence checks for threading types."
    - "Theme: __invert__/__floor__/__ceil__ dict-presence (unary ~x, math.floor(x), math.ceil(x))."
    - "All values False — threading synchronization and thread-management types have no numeric protocol support."
    - "None of the threading types define __invert__, __floor__, or __ceil__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3361.invert:
  description: "threading types __invert__ dict-presence checks; wave 671"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3361
  columns: [id, function, args, expected]
  rows:
    - ["th3361001", operator.contains, [threading.Thread.__dict__,           "__invert__"], false]
    - ["th3361002", operator.contains, [threading.Event.__dict__,            "__invert__"], false]
    - ["th3361003", operator.contains, [threading.Condition.__dict__,        "__invert__"], false]
    - ["th3361004", operator.contains, [threading.Semaphore.__dict__,        "__invert__"], false]
    - ["th3361005", operator.contains, [threading.BoundedSemaphore.__dict__, "__invert__"], false]
    - ["th3361006", operator.contains, [threading.Timer.__dict__,            "__invert__"], false]
    - ["th3361007", operator.contains, [threading.Barrier.__dict__,          "__invert__"], false]
    - ["th3361008", operator.contains, [threading.local.__dict__,            "__invert__"], false]
    - ["th3361009", operator.contains, [type(threading.Lock()).__dict__,     "__invert__"], false]
    - ["th3361010", operator.contains, [type(threading.RLock()).__dict__,    "__invert__"], false]

