spec: hashlib_extra248
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"

provenance:
  derived_from:
    - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions, NIST, August 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.14.3 hashlib on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha3/sha3module.c"
  notes:
    - "This spec extends hashlib.zspec.zsdl, hashlib_extra.zspec.zsdl, hashlib_extra2.zspec.zsdl, and hashlib_extra3.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "hashlib.zspec.zsdl covers: sha256/sha1/md5/sha512/sha3_256/sha3_512/blake2b/blake2s known vectors; digest_size/block_size attrs; algorithms_guaranteed; sha256.name_attr."
    - "hashlib_extra.zspec.zsdl covers: blake2b/blake2s default/custom digest_size; sha3_224/sha3_384 attrs; algorithms_available type; pbkdf2_hmac."
    - "hashlib_extra2.zspec.zsdl covers: md5/sha1/sha256 empty hexdigest; sha256/sha512 digest_size eq; md5(b'hello') hexdigest; algorithms_guaranteed type; new() api."
    - "hashlib_extra3.zspec.zsdl covers: sha512/sha384/sha224/sha3_256/sha3_512/blake2b/blake2s name attrs; sha512/md5 block_size; openssl constructor __name__; algorithms len."
    - "shake_128 and shake_256 are XOF (extendable-output functions) from FIPS 202; they accept a length argument to hexdigest/digest."
    - "On OpenSSL-backed CPython builds (macOS/Linux), shake_128.__name__ == 'openssl_shake_128' and shake_256.__name__ == 'openssl_shake_256'."
    - "shake_128.__module__ == '_hashlib' and shake_256.__module__ == '_hashlib' on OpenSSL-backed builds."
    - "shake_128(b'').hexdigest(32) == '7f9c2ba4e88f827d616045507605853ed73b8093f6efbc88eb1a6eacfa66ef26' — 32-byte output = 64 hex chars."
    - "shake_256(b'').hexdigest(32) == '46b9dd2b0ba88d13233b3feb743eeb243fcd52ea62b81b82b50c27646ed5762f' — 32-byte output = 64 hex chars."
    - "shake_128 has block_size == 168 (rate = 1344 bits = 168 bytes, capacity = 256 bits per FIPS 202)."
    - "shake_256 has block_size == 136 (rate = 1088 bits = 136 bytes, capacity = 512 bits per FIPS 202)."
    - "shake_128 does NOT have a digest_size attribute (XOF functions have variable output length)."
    - "shake_128(b'').name == 'shake_128' — canonical algorithm name on the instance."
    - "shake_256(b'').name == 'shake_256' — canonical algorithm name on the instance."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names passed to hashlib.new(). XOF hexdigest/digest require a length argument."
  stderr: "null"
  stickiness: "N/A — hash objects are independent; module-level attributes are read-only."
  codes: {}

# ---------------------------------------------------------------------------
# shake_128 and shake_256 constructor identity
# On OpenSSL-backed builds (macOS/Linux) these are C-extension types.
# ---------------------------------------------------------------------------

table hl248shake.constructor_names:
  description: "shake_128 and shake_256 constructor __name__ on OpenSSL-backed builds"
  kind: python_call_eq
  category: identity
  id_prefix: hl248shake

  columns: [id, function, args, expected]
  rows:
    - [shake128_name,   shake_128.__name__.__eq__,   ["openssl_shake_128"], true]
    - [shake256_name,   shake_256.__name__.__eq__,   ["openssl_shake_256"], true]
    - [shake128_module, shake_128.__module__.__eq__,  ["_hashlib"],          true]
    - [shake256_module, shake_256.__module__.__eq__,  ["_hashlib"],          true]

# ---------------------------------------------------------------------------
# shake_128 and shake_256 class name of the constructor
# ---------------------------------------------------------------------------

invariant hl248shake.shake_128.constructor_class_name:
  description: "hashlib.shake_128.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: shake_128.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hl248shake.shake_256.constructor_class_name:
  description: "hashlib.shake_256.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: shake_256.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# shake_128 and shake_256 instance .name attribute
# ---------------------------------------------------------------------------

invariant hl248shake.shake_128.instance_name:
  description: "hashlib.shake_128(b'').name == 'shake_128'"
  category: properties
  kind: python_call_eq
  function: shake_128
  args: [!hex ""]
  method: name.__eq__
  method_args: ["shake_128"]
  expected: true

invariant hl248shake.shake_256.instance_name:
  description: "hashlib.shake_256(b'').name == 'shake_256'"
  category: properties
  kind: python_call_eq
  function: shake_256
  args: [!hex ""]
  method: name.__eq__
  method_args: ["shake_256"]
  expected: true

# ---------------------------------------------------------------------------
# shake_128 and shake_256 block_size attributes (from FIPS 202 rate values)
# ---------------------------------------------------------------------------

invariant hl248shake.shake_128.block_size:
  description: "hashlib.shake_128(b'').block_size == 168 (rate = 1344 bits = 168 bytes per FIPS 202)"
  category: properties
  kind: python_call_eq
  function: shake_128
  args: [!hex ""]
  method: block_size.__eq__
  method_args: [168]
  expected: true

invariant hl248shake.shake_256.block_size:
  description: "hashlib.shake_256(b'').block_size == 136 (rate = 1088 bits = 136 bytes per FIPS 202)"
  category: properties
  kind: python_call_eq
  function: shake_256
  args: [!hex ""]
  method: block_size.__eq__
  method_args: [136]
  expected: true

# ---------------------------------------------------------------------------
# shake_128 and shake_256 hexdigest output length
# hexdigest(32) produces 32 bytes = 64 hex characters
# ---------------------------------------------------------------------------

invariant hl248shake.shake_128.hexdigest_len:
  description: "len(hashlib.shake_128(b'').hexdigest(32)) == 64 (32 bytes = 64 hex chars)"
  category: known_vector
  kind: python_call_eq
  function: shake_128
  args: [!hex ""]
  method: hexdigest
  method_args: [32]
  expected: "7f9c2ba4e88f827d616045507605853ed73b8093f6efbc88eb1a6eacfa66ef26"

invariant hl248shake.shake_256.hexdigest_len:
  description: "len(hashlib.shake_256(b'').hexdigest(32)) == 64 (32 bytes = 64 hex chars)"
  category: known_vector
  kind: python_call_eq
  function: shake_256
  args: [!hex ""]
  method: hexdigest
  method_args: [32]
  expected: "46b9dd2b0ba88d13233b3feb743eeb243fcd52ea62b81b82b50c27646ed5762f"

# ---------------------------------------------------------------------------
# hexdigest output length check via __len__
# Both functions: hexdigest(32).__len__() == 64
# ---------------------------------------------------------------------------

invariant hl248shake.shake_128.hexdigest_char_count:
  description: "hashlib.shake_128(b'').hexdigest(32).__len__() == 64 (32 bytes -> 64 hex chars)"
  category: known_vector
  kind: python_call_eq
  function: shake_128
  args: [!hex ""]
  method: hexdigest.__call__
  method_args: [32]
  expected: "7f9c2ba4e88f827d616045507605853ed73b8093f6efbc88eb1a6eacfa66ef26"

invariant hl248shake.shake_256.hexdigest_char_count:
  description: "hashlib.shake_256(b'').hexdigest(32).__len__() == 64 (32 bytes -> 64 hex chars)"
  category: known_vector
  kind: python_call_eq
  function: shake_256
  args: [!hex ""]
  method: hexdigest.__call__
  method_args: [32]
  expected: "46b9dd2b0ba88d13233b3feb743eeb243fcd52ea62b81b82b50c27646ed5762f"

# ---------------------------------------------------------------------------
# Instance __class__.__name__ — HASHXOF on OpenSSL-backed builds
# ---------------------------------------------------------------------------

invariant hl248shake.shake_128.instance_class_name:
  description: "hashlib.shake_128(b'').__class__.__name__ == 'HASHXOF' on OpenSSL-backed builds"
  category: identity
  kind: python_call_eq
  function: shake_128
  args: [!hex ""]
  method: __class__.__name__.__eq__
  method_args: ["HASHXOF"]
  expected: true

invariant hl248shake.shake_256.instance_class_name:
  description: "hashlib.shake_256(b'').__class__.__name__ == 'HASHXOF' on OpenSSL-backed builds"
  category: identity
  kind: python_call_eq
  function: shake_256
  args: [!hex ""]
  method: __class__.__name__.__eq__
  method_args: ["HASHXOF"]
  expected: true
