# ---------------------------------------------------------------------------
# socket.__spec__.origin.__class__.__name__.__eq__('str') — standalone
#
# socket.__spec__.origin.__class__.__name__ is 'str' (3 chars). The origin attribute of a
# ModuleSpec is the filesystem path to the module source file. For socket, this is the
# absolute path to socket.py on the current system. Because the path is platform-specific
# (different on macOS, Linux, Windows, and between Python installations), the spec does not
# hardcode the actual path. Instead, we verify that origin is a 'str' object (which it always
# is for Python source modules) and that it contains the string 'socket' as a substring.
# origin.__class__.__name__ == 'str' (3 chars) confirms the type without binding to a
# specific path value. No prior socket spec anchors origin.__class__.__name__ as a standalone
# under sockspec163. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra163.socket_spec_origin_class_str:
  description: "socket.__spec__.origin.__class__.__name__.__eq__('str') == True — 'str' (3 chars; origin is a filesystem path string to socket.py; platform-specific absolute path; type check avoids hardcoding path value); origin is the source file path used by the import system; socket_extra156 does not anchor origin type; same pattern as struct_extra159 structspec159 which anchors struct.__spec__.origin.__class__.__name__=='str'; first sockspec163 standalone for origin.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__spec__.origin.__contains__('socket') — standalone
#
# socket.__spec__.origin.__contains__('socket') is True. The filesystem path to socket.py
# always contains the string 'socket' as a substring (e.g., '.../lib/python3.14/socket.py').
# This is a robust cross-platform check that does not hardcode the full path. The module
# name 'socket' appears in the filename and typically also in directory path components.
# origin.__contains__('socket') == True works on any platform where Python is installed.
# This is the recommended way to check origin content in ZSDL specs without platform-specific
# hardcoding. No prior socket spec anchors origin.__contains__('socket') as a standalone
# under sockspec163. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra163.socket_spec_origin_contains_socket:
  description: "socket.__spec__.origin.__contains__('socket') == True — origin is the path to socket.py; 'socket' appears in the filename and often in the directory path; cross-platform safe check (avoids hardcoding absolute path); origin.__class__.__name__=='str' (the path is a str); socket.__spec__.name=='socket' (6 chars; the spec module name); origin.__contains__('socket') is the structural verification without path hardcoding; same pattern as struct_extra159 which anchors struct.__spec__.origin.__contains__('struct'); first sockspec163 standalone for origin.__contains__"
  category: identity
  kind: python_call_eq
  function: __spec__.origin.__contains__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') — standalone
#
# socket.__spec__.submodule_search_locations.__class__.__name__ is 'NoneType' (8 chars).
# submodule_search_locations is None for plain modules (not packages). socket is a plain
# module (Lib/socket.py is a single file), not a package (there is no socket/ directory
# with __init__.py). The Python import system sets submodule_search_locations to None for
# non-package modules. For package modules, submodule_search_locations would be a list of
# directory paths. 'NoneType' (8 chars = 'None'=4 + 'Type'=4) is the class name of Python's
# None object. This check confirms that socket is a plain module (not a package) without
# using 'is None' which is not supported in python_call_eq specs.
# No prior socket spec anchors submodule_search_locations as a standalone under sockspec163.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

