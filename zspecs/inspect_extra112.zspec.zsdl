spec: inspect_extra112
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra111.zspec.zsdl."
    - "This spec covers: inspect.Signature.__init__, inspect.Parameter.__init__, and inspect.BoundArguments.__init__ code attributes (co_name, co_argcount) and qualnames; wave 263."
    - "inspect.Signature.__init__.__code__.co_name == '__init__'. Verified with Python 3.14.3."
    - "inspect.Signature.__init__.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.Parameter.__init__.__code__.co_name == '__init__'. Verified with Python 3.14.3."
    - "inspect.Parameter.__init__.__code__.co_argcount == 3. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__init__.__code__.co_name == '__init__'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__init__.__code__.co_argcount == 3. Verified with Python 3.14.3."
    - "type(inspect.Signature.__init__).__name__ == 'function'. Verified with Python 3.14.3."
    - "type(inspect.Parameter.__init__).__name__ == 'function'. Verified with Python 3.14.3."
    - "inspect.Signature.__init__.__qualname__ == 'Signature.__init__'. Verified with Python 3.14.3."
    - "len(inspect.Signature.__init__.__qualname__) == 18. Verified with Python 3.14.3."
    - "inspect.Parameter.__init__.__qualname__ == 'Parameter.__init__'. Verified with Python 3.14.3."
    - "len(inspect.Parameter.__init__.__qualname__) == 18. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__init__.__qualname__ == 'BoundArguments.__init__'. Verified with Python 3.14.3."
    - "len(inspect.BoundArguments.__init__.__qualname__) == 23. Verified with Python 3.14.3."
    - "Signature.__init__ co_argcount is 2 (self + parameters). Parameter.__init__ co_argcount is 3 (self + name + kind with more defaults). BoundArguments.__init__ co_argcount is 3 (self + signature + arguments). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Signature.__init__ and inspect.Parameter.__init__ co_name and co_argcount
#
# Wave 263 theme: inspect.Signature and inspect.Parameter are pure-Python classes
# in Lib/inspect.py. Their __init__ methods are plain Python 'function' objects
# with dotted qualnames. Signature.__init__(self, parameters=None,
# return_annotation=_empty, __validate_parameters__=True) has co_argcount 2
# (only the first 2 are positional: self and parameters; the rest have defaults).
# Actually co_argcount counts ALL positional-or-keyword args including defaults.
# Verified: co_argcount == 2 means Signature.__init__ has 2 defined params
# (self and parameters counted as the explicit args without going to
# __validate_parameters__=True and return_annotation being keyword-only).
# Parameter.__init__(self, name, kind, ...) has co_argcount 3.
# BoundArguments.__init__(self, signature, arguments) has co_argcount 3.
#
# inspect.Signature.__init__.__code__.co_name == '__init__'
# inspect.Signature.__init__.__code__.co_argcount == 2
# type(inspect.Signature.__init__).__name__ == 'function'
# inspect.Parameter.__init__.__code__.co_name == '__init__'
# inspect.Parameter.__init__.__code__.co_argcount == 3
#
# New to extra112.
# ---------------------------------------------------------------------------

table inspect_extra112.init_co_attrs:
  description: "inspect Signature/Parameter/BoundArguments __init__ co_name and co_argcount: Signature(2), Parameter(3), BoundArguments(3); all type 'function'; wave 263; new to extra112"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectinit112

  columns: [id, function, args, expected, description]
  rows:
    - [signature_init_co_name,
       "Signature.__init__.__code__.co_name.__eq__",
       ["__init__"],
       true,
       "inspect.Signature.__init__.__code__.co_name.__eq__('__init__') == True — inspect.Signature.__init__ is defined inside the Signature class body in Lib/inspect.py; its __code__.co_name is '__init__' (the def-statement name, not the dotted qualname); str.__eq__('__init__') returns True; new to extra112"]
    - [signature_init_co_argcount_2,
       "Signature.__init__.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.Signature.__init__.__code__.co_argcount.__eq__(2) == True — inspect.Signature.__init__ has 2 positional-or-keyword parameters counting from co_argcount: self and parameters; additional parameters (return_annotation, __validate_parameters__) are keyword-only or have other encoding; co_argcount is 2; int.__eq__(2) returns True; new to extra112"]
    - [signature_init_type_function,
       "Signature.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.Signature.__init__.__class__.__name__.__eq__('function') == True — inspect.Signature is a pure-Python class; its __init__ method is a plain Python function (type 'function') not a C wrapper_descriptor; str.__eq__('function') returns True; new to extra112"]
    - [parameter_init_co_name,
       "Parameter.__init__.__code__.co_name.__eq__",
       ["__init__"],
       true,
       "inspect.Parameter.__init__.__code__.co_name.__eq__('__init__') == True — inspect.Parameter.__init__ is defined inside the Parameter class body; its __code__.co_name is '__init__'; str.__eq__('__init__') returns True; new to extra112"]
    - [parameter_init_co_argcount_3,
       "Parameter.__init__.__code__.co_argcount.__eq__",
       [3],
       true,
       "inspect.Parameter.__init__.__code__.co_argcount.__eq__(3) == True — inspect.Parameter.__init__ has co_argcount 3; this includes self, name (required positional arg), and kind (required positional arg); additional arguments (default, annotation) are either keyword-only or have keyword-only encoding; int.__eq__(3) returns True; new to extra112"]
    - [parameter_init_type_function,
       "Parameter.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.Parameter.__init__.__class__.__name__.__eq__('function') == True — inspect.Parameter is a pure-Python class; its __init__ is a plain Python function (type 'function'); str.__eq__('function') returns True; new to extra112"]
    - [boundarguments_init_co_name,
       "BoundArguments.__init__.__code__.co_name.__eq__",
       ["__init__"],
       true,
       "inspect.BoundArguments.__init__.__code__.co_name.__eq__('__init__') == True — inspect.BoundArguments.__init__ is defined inside the BoundArguments class body; its __code__.co_name is '__init__'; str.__eq__('__init__') returns True; new to extra112"]
    - [boundarguments_init_co_argcount_3,
       "BoundArguments.__init__.__code__.co_argcount.__eq__",
       [3],
       true,
       "inspect.BoundArguments.__init__.__code__.co_argcount.__eq__(3) == True — inspect.BoundArguments.__init__(self, signature, arguments) has 3 positional-or-keyword parameters: self, signature (the Signature that created these bound arguments), and arguments (an OrderedDict of parameter name to value); co_argcount is 3; int.__eq__(3) returns True; new to extra112"]

# ---------------------------------------------------------------------------
# Table 2: inspect __init__ qualnames — Signature, Parameter, BoundArguments
#
# Wave 263 theme: inspect.Signature, inspect.Parameter, and
# inspect.BoundArguments are pure-Python classes in Lib/inspect.py. Their
# __init__ qualnames follow the dotted 'ClassName.__init__' pattern.
# Signature.__init__ and Parameter.__init__ both have qualname length 18
# (9+1+8 = 'Signature' (9) + '.' (1) + '__init__' (8) == 18, and
# 'Parameter' (9) + '.' (1) + '__init__' (8) == 18).
# BoundArguments.__init__ has qualname 'BoundArguments.__init__' (len 23):
# 'BoundArguments' (14) + '.' (1) + '__init__' (8) == 23.
#
# inspect.Signature.__init__.__qualname__ == 'Signature.__init__'
# len(inspect.Signature.__init__.__qualname__) == 18
# inspect.Parameter.__init__.__qualname__ == 'Parameter.__init__'
# len(inspect.Parameter.__init__.__qualname__) == 18
# inspect.BoundArguments.__init__.__qualname__ == 'BoundArguments.__init__'
# len(inspect.BoundArguments.__init__.__qualname__) == 23
#
# New to extra112.
# ---------------------------------------------------------------------------

table inspect_extra112.init_qualnames:
  description: "inspect __init__ qualnames: Signature.__init__(18), Parameter.__init__(18), BoundArguments.__init__(23); same-length pattern for Signature and Parameter; wave 263; new to extra112"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectiqn112

  columns: [id, function, args, expected, description]
  rows:
    - [signature_init_qualname_eq,
       "Signature.__init__.__qualname__.__eq__",
       ["Signature.__init__"],
       true,
       "inspect.Signature.__init__.__qualname__.__eq__('Signature.__init__') == True — inspect.Signature.__init__ is defined inside the Signature class body; its __qualname__ follows the dotted 'Signature.__init__' pattern (class-qualified name); str.__eq__('Signature.__init__') returns True; new to extra112"]
    - [signature_init_qualname_len_18,
       "Signature.__init__.__qualname__.__len__",
       [],
       18,
       "inspect.Signature.__init__.__qualname__.__len__() == 18 — 'Signature.__init__' has 18 characters: S-i-g-n-a-t-u-r-e-.-_-_-i-n-i-t-_-_ (9+1+8); str.__len__() returns 18; int.__eq__(18) returns True; new to extra112"]
    - [parameter_init_qualname_eq,
       "Parameter.__init__.__qualname__.__eq__",
       ["Parameter.__init__"],
       true,
       "inspect.Parameter.__init__.__qualname__.__eq__('Parameter.__init__') == True — inspect.Parameter.__init__ is defined inside the Parameter class body; its __qualname__ is 'Parameter.__init__'; str.__eq__('Parameter.__init__') returns True; new to extra112"]
    - [parameter_init_qualname_len_18,
       "Parameter.__init__.__qualname__.__len__",
       [],
       18,
       "inspect.Parameter.__init__.__qualname__.__len__() == 18 — 'Parameter.__init__' has 18 characters: P-a-r-a-m-e-t-e-r-.-_-_-i-n-i-t-_-_ (9+1+8); the same length as 'Signature.__init__' (18); both class names have 9 characters; str.__len__() returns 18; int.__eq__(18) returns True; new to extra112"]
    - [boundarguments_init_qualname_eq,
       "BoundArguments.__init__.__qualname__.__eq__",
       ["BoundArguments.__init__"],
       true,
       "inspect.BoundArguments.__init__.__qualname__.__eq__('BoundArguments.__init__') == True — inspect.BoundArguments.__init__ is defined inside the BoundArguments class body; its __qualname__ is 'BoundArguments.__init__'; str.__eq__('BoundArguments.__init__') returns True; new to extra112"]
    - [boundarguments_init_qualname_len_23,
       "BoundArguments.__init__.__qualname__.__len__",
       [],
       23,
       "inspect.BoundArguments.__init__.__qualname__.__len__() == 23 — 'BoundArguments.__init__' has 23 characters: B-o-u-n-d-A-r-g-u-m-e-n-t-s-.-_-_-i-n-i-t-_-_ (14+1+8); 5 more than Signature/Parameter qualnames (18); str.__len__() returns 23; int.__eq__(23) returns True; new to extra112"]

# ---------------------------------------------------------------------------
# Table 3: inspect __init__ co_argcount comparisons and type contrasts
#
# Wave 263 theme: inspect.Signature.__init__, inspect.Parameter.__init__, and
# inspect.BoundArguments.__init__ are all pure-Python functions. Parameter.__init__
# and BoundArguments.__init__ share co_argcount 3. Signature.__init__ has
# co_argcount 2. All three are type 'function' (not C descriptors).
# The qualname lengths of Signature.__init__ and Parameter.__init__ are both 18,
# while BoundArguments.__init__ is 23 — the class name length is the only
# differentiator (9 vs 14 characters in the class name).
#
# Note: all three have the same co_name '__init__'
# Signature.__init__ co_argcount == 2  (fewer than Parameter/BoundArguments)
# Parameter.__init__ co_argcount == 3
# BoundArguments.__init__ co_argcount == 3 (same as Parameter)
# qualname lengths: Signature (18) == Parameter (18) != BoundArguments (23)
#
# New to extra112.
# ---------------------------------------------------------------------------

table inspect_extra112.init_argcount_comparisons:
  description: "inspect __init__ argcount comparisons: Signature(2) vs Parameter(3)/BoundArguments(3); qualname lengths Signature(18)==Parameter(18)!=BoundArguments(23); all type 'function'; wave 263; new to extra112"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectiac112

  columns: [id, function, args, expected, description]
  rows:
    - [signature_init_co_argcount_less_than_parameter,
       "Signature.__init__.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.Signature.__init__.__code__.co_argcount.__eq__(2) == True — Signature.__init__ has co_argcount 2 (fewer than Parameter.__init__ co_argcount 3); Signature's positional params are self and parameters; int.__eq__(2) returns True; new to extra112"]
    - [parameter_init_co_argcount_eq_3,
       "Parameter.__init__.__code__.co_argcount.__eq__",
       [3],
       true,
       "inspect.Parameter.__init__.__code__.co_argcount.__eq__(3) == True — Parameter.__init__ has co_argcount 3; this is the same as BoundArguments.__init__; int.__eq__(3) returns True; new to extra112"]
    - [boundarguments_init_co_argcount_eq_3,
       "BoundArguments.__init__.__code__.co_argcount.__eq__",
       [3],
       true,
       "inspect.BoundArguments.__init__.__code__.co_argcount.__eq__(3) == True — BoundArguments.__init__(self, signature, arguments) has 3 parameters; same co_argcount as Parameter.__init__; int.__eq__(3) returns True; new to extra112"]
    - [signature_qualname_len_eq_parameter_qualname_len,
       "Signature.__init__.__qualname__.__len__",
       [],
       18,
       "inspect.Signature.__init__.__qualname__.__len__() == 18 — 'Signature.__init__' (18) has the same length as 'Parameter.__init__' (18) because both class names 'Signature' and 'Parameter' have 9 characters; str.__len__() returns 18; int.__eq__(18) returns True; new to extra112"]
    - [boundarguments_qualname_len_greater,
       "BoundArguments.__init__.__qualname__.__len__",
       [],
       23,
       "inspect.BoundArguments.__init__.__qualname__.__len__() == 23 — 'BoundArguments.__init__' (23) is 5 longer than 'Signature.__init__' (18) because 'BoundArguments' (14 chars) is 5 chars longer than 'Signature' (9 chars); str.__len__() returns 23; int.__eq__(23) returns True; new to extra112"]
    - [all_inits_co_name_eq_init,
       "BoundArguments.__init__.__code__.co_name.__eq__",
       ["__init__"],
       true,
       "inspect.BoundArguments.__init__.__code__.co_name.__eq__('__init__') == True — all three __init__ methods (Signature, Parameter, BoundArguments) share the same co_name '__init__'; co_name is the simple def-statement name; str.__eq__('__init__') returns True; new to extra112"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra112
# ---------------------------------------------------------------------------

invariant inspect_extra112.signature_init_co_argcount:
  description: "inspect.Signature.__init__.__code__.co_argcount == 2 — fewer positional params than Parameter/BoundArguments __init__; self and parameters; wave 263; new to extra112"
  kind: python_call_eq
  function: Signature.__init__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra112.parameter_init_co_argcount:
  description: "inspect.Parameter.__init__.__code__.co_argcount == 3 — self, name, kind positional; same as BoundArguments.__init__; wave 263; new to extra112"
  kind: python_call_eq
  function: Parameter.__init__.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant inspect_extra112.signature_init_qualname:
  description: "inspect.Signature.__init__.__qualname__ == 'Signature.__init__' — length 18; same as Parameter.__init__ qualname length; wave 263; new to extra112"
  kind: python_call_eq
  function: Signature.__init__.__qualname__.__eq__
  args: ["Signature.__init__"]
  expected: true

invariant inspect_extra112.parameter_init_qualname:
  description: "inspect.Parameter.__init__.__qualname__ == 'Parameter.__init__' — length 18; same length as Signature.__init__ qualname; wave 263; new to extra112"
  kind: python_call_eq
  function: Parameter.__init__.__qualname__.__eq__
  args: ["Parameter.__init__"]
  expected: true

invariant inspect_extra112.boundarguments_init_qualname_len:
  description: "len(inspect.BoundArguments.__init__.__qualname__) == 23 — 'BoundArguments.__init__' is 23 chars; 5 more than Signature/Parameter (18); wave 263; new to extra112"
  kind: python_call_eq
  function: BoundArguments.__init__.__qualname__.__len__
  args: []
  expected: 23

