spec: re_extra586
version: ">=3.9"
backend: python_module(re)
docs: "Behavioral spec covering re module function __name__ and __module__ identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module function reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All top-level functions in the re module should report __name__ equal to their unqualified name"
    - "Selected functions also checked for __module__ == 're'"
  created_at: "2026-04-12T00:00:00Z"

table re586mn:
  description: "re module function __name__ identity checks"
  columns: [id, function, args, expected]
  rows:
    - [re586mn01, re.compile.__name__.__eq__, ["compile"], true]
    - [re586mn02, re.match.__name__.__eq__, ["match"], true]
    - [re586mn03, re.search.__name__.__eq__, ["search"], true]
    - [re586mn04, re.fullmatch.__name__.__eq__, ["fullmatch"], true]
    - [re586mn05, re.findall.__name__.__eq__, ["findall"], true]
    - [re586mn06, re.finditer.__name__.__eq__, ["finditer"], true]
    - [re586mn07, re.sub.__name__.__eq__, ["sub"], true]
    - [re586mn08, re.subn.__name__.__eq__, ["subn"], true]
    - [re586mn09, re.split.__name__.__eq__, ["split"], true]
    - [re586mn10, re.escape.__name__.__eq__, ["escape"], true]
    - [re586mn11, re.purge.__name__.__eq__, ["purge"], true]

table re586qn:
  description: "re module function __module__ identity checks"
  columns: [id, function, args, expected]
  rows:
    - [re586qn01, re.compile.__module__.__eq__, ["re"], true]
    - [re586qn02, re.match.__module__.__eq__, ["re"], true]
    - [re586qn03, re.search.__module__.__eq__, ["re"], true]
