spec: pathlib_extra240
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path.suffix/suffixes/stem behavioral contracts."
    - "pathlib.PurePosixPath('a/b.tar.gz').suffix == '.gz' — last suffix including dot; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('a/b.tar.gz').stem == 'b.tar' — name without last suffix; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('a/b.tar.gz').suffixes == ['.tar', '.gz'] — list of all suffixes; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('a/b.txt').suffix == '.txt' — single suffix; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('a/b').suffix == '' — no extension gives empty string; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('a/b.txt').stem == 'b' — stem without extension; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('a/b').stem == 'b' — stem with no extension equals filename; verified Python 3.14.3 macOS."
    - "len(pathlib.PurePosixPath('a/b.tar.gz').suffixes) == 2 — two suffixes; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('a/b.tar.gz').suffixes[0] == '.tar' — first suffix; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('a/b.tar.gz').suffixes[1] == '.gz' — second suffix; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath.suffix behavioral contracts
# suffix returns the last file extension including the dot, or '' if none.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra240.PurePosixPath.suffix_targz:
  description: "PurePosixPath('a/b.tar.gz').suffix == '.gz' — last suffix of compound extension; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b.tar.gz"]
  method: suffix
  expected: ".gz"

invariant pathlib_extra240.PurePosixPath.suffix_txt:
  description: "PurePosixPath('a/b.txt').suffix == '.txt' — single extension suffix; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b.txt"]
  method: suffix
  expected: ".txt"

invariant pathlib_extra240.PurePosixPath.suffix_none:
  description: "PurePosixPath('a/b').suffix == '' — no extension gives empty suffix; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b"]
  method: suffix
  expected: ""

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath.stem behavioral contracts
# stem returns the final path component without its last suffix.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra240.PurePosixPath.stem_targz:
  description: "PurePosixPath('a/b.tar.gz').stem == 'b.tar' — stem of compound extension removes only last suffix; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b.tar.gz"]
  method: stem
  expected: "b.tar"

invariant pathlib_extra240.PurePosixPath.stem_txt:
  description: "PurePosixPath('a/b.txt').stem == 'b' — stem removes single extension; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b.txt"]
  method: stem
  expected: "b"

invariant pathlib_extra240.PurePosixPath.stem_none:
  description: "PurePosixPath('a/b').stem == 'b' — stem with no extension equals filename; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b"]
  method: stem
  expected: "b"

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath.suffixes behavioral contracts
# suffixes returns a list of all extensions including their dots.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra240.PurePosixPath.suffixes_len:
  description: "len(PurePosixPath('a/b.tar.gz').suffixes) == 2 — compound extension yields 2 suffixes; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b.tar.gz"]
  method: suffixes
  method_chain: __len__
  expected: 2

invariant pathlib_extra240.PurePosixPath.suffixes_first:
  description: "PurePosixPath('a/b.tar.gz').suffixes[0] == '.tar' — first suffix in compound extension; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b.tar.gz"]
  method: suffixes
  method_chain: __getitem__
  method_chain_args: [0]
  expected: ".tar"

invariant pathlib_extra240.PurePosixPath.suffixes_second:
  description: "PurePosixPath('a/b.tar.gz').suffixes[1] == '.gz' — second suffix in compound extension; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b.tar.gz"]
  method: suffixes
  method_chain: __getitem__
  method_chain_args: [1]
  expected: ".gz"

invariant pathlib_extra240.PurePosixPath.suffixes_empty_len:
  description: "len(PurePosixPath('a/b').suffixes) == 0 — no extension gives empty suffixes list; verified Python 3.14.3 macOS"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["a/b"]
  method: suffixes
  method_chain: __len__
  expected: 0
