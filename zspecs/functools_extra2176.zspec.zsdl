spec: functools_extra2176
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
    - "functools_extra2161.zspec.zsdl — covers fget/fset/fdel and __objclass__/__func__ dict-presence, descriptor protocol checks"
  notes:
    - "Wave 2176 (_extra2176): iterator/sequence protocol dict-presence theme — __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "functools.partial, functools.partialmethod, functools.cached_property, and functools._lru_cache_wrapper do NOT define any of the 8 iterator/sequence protocol dunders in their own __dict__."
    - "functools types are utility wrappers and descriptor objects, not iterators or sequences — they carry no __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, or __missing__."
    - "functools.partial is a C-extension type wrapping a callable; it is not iterable and does not behave as a sequence or mapping."
    - "functools.cached_property is a descriptor implementing __get__ and __set_name__ but has no iteration protocol."
    - "functools.partialmethod is a pure-Python descriptor class; it carries __get__ but no iteration dunders."
    - "functools._lru_cache_wrapper is the C-level wrapper type produced by @functools.lru_cache; it exposes cache_info/cache_clear but no iteration protocol."
  created_at: "2026-04-12"
error_model: python_exceptions

table functools_extra2176.iter_next_absent:
  description: "functools types do NOT define __iter__ or __next__ — they are not iterators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2176
  columns: [id, function, args, expected]
  rows:
    - ["ft2176001", "functools.partial.__dict__.__contains__",           ["__iter__"],  false]
    - ["ft2176002", "functools.partial.__dict__.__contains__",           ["__next__"],  false]
    - ["ft2176003", "functools.partialmethod.__dict__.__contains__",     ["__iter__"],  false]
    - ["ft2176004", "functools.partialmethod.__dict__.__contains__",     ["__next__"],  false]
    - ["ft2176005", "functools.cached_property.__dict__.__contains__",   ["__iter__"],  false]
    - ["ft2176006", "functools.cached_property.__dict__.__contains__",   ["__next__"],  false]

