spec: asyncio_extra286
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-protocol.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html — asyncio protocol and transport class hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/protocols.py, Lib/asyncio/transports.py"
  notes:
    - "asyncio.Transport.__bases__ has 2 entries in Python 3.14: ReadTransport and WriteTransport"
    - "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport'"
    - "All protocol classes inherit from BaseProtocol"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra286.protocol_names:
  description: "Protocol class __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio286p

  columns: [id, function, args, expected, description]
  rows:
    - [asyncio286p001, asyncio.Protocol.__name__.__eq__, ["Protocol"], true, "Protocol class name is 'Protocol'"]
    - [asyncio286p002, asyncio.BaseProtocol.__name__.__eq__, ["BaseProtocol"], true, "BaseProtocol class name is 'BaseProtocol'"]
    - [asyncio286p003, asyncio.DatagramProtocol.__name__.__eq__, ["DatagramProtocol"], true, "DatagramProtocol class name is 'DatagramProtocol'"]
    - [asyncio286p004, asyncio.SubprocessProtocol.__name__.__eq__, ["SubprocessProtocol"], true, "SubprocessProtocol class name is 'SubprocessProtocol'"]
    - [asyncio286p005, asyncio.BufferedProtocol.__name__.__eq__, ["BufferedProtocol"], true, "BufferedProtocol class name is 'BufferedProtocol'"]

table asyncio_extra286.transport_names:
  description: "Transport class __name__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio286t

  columns: [id, function, args, expected, description]
  rows:
    - [asyncio286t001, asyncio.BaseTransport.__name__.__eq__, ["BaseTransport"], true, "BaseTransport class name is 'BaseTransport'"]
    - [asyncio286t002, asyncio.ReadTransport.__name__.__eq__, ["ReadTransport"], true, "ReadTransport class name is 'ReadTransport'"]
    - [asyncio286t003, asyncio.WriteTransport.__name__.__eq__, ["WriteTransport"], true, "WriteTransport class name is 'WriteTransport'"]
    - [asyncio286t004, asyncio.Transport.__name__.__eq__, ["Transport"], true, "Transport class name is 'Transport'"]
    - [asyncio286t005, asyncio.DatagramTransport.__name__.__eq__, ["DatagramTransport"], true, "DatagramTransport class name is 'DatagramTransport'"]

invariant asyncio_extra286.protocol_module:
  description: "asyncio.Protocol.__module__ == 'asyncio'"
  category: identity
  kind: python_call_eq
  function: asyncio.Protocol.__module__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra286.baseprotocol_module:
  description: "asyncio.BaseProtocol.__module__ == 'asyncio'"
  category: identity
  kind: python_call_eq
  function: asyncio.BaseProtocol.__module__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra286.protocol_base_is_baseprotocol:
  description: "asyncio.Protocol.__bases__[0].__name__ == 'BaseProtocol'"
  category: identity
  kind: python_call_eq
  function: "asyncio.Protocol.__bases__[0].__name__.__eq__"
  args: ["BaseProtocol"]
  expected: true

invariant asyncio_extra286.baseprotocol_base_is_object:
  description: "asyncio.BaseProtocol.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "asyncio.BaseProtocol.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra286.basetransport_module:
  description: "asyncio.BaseTransport.__module__ == 'asyncio'"
  category: identity
  kind: python_call_eq
  function: asyncio.BaseTransport.__module__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra286.readtransport_base_is_basetransport:
  description: "asyncio.ReadTransport.__bases__[0].__name__ == 'BaseTransport'"
  category: identity
  kind: python_call_eq
  function: "asyncio.ReadTransport.__bases__[0].__name__.__eq__"
  args: ["BaseTransport"]
  expected: true

invariant asyncio_extra286.writetransport_base_is_basetransport:
  description: "asyncio.WriteTransport.__bases__[0].__name__ == 'BaseTransport'"
  category: identity
  kind: python_call_eq
  function: "asyncio.WriteTransport.__bases__[0].__name__.__eq__"
  args: ["BaseTransport"]
  expected: true

invariant asyncio_extra286.transport_bases0_is_readtransport:
  description: "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport' (Python 3.14 MRO)"
  category: identity
  kind: python_call_eq
  function: "asyncio.Transport.__bases__[0].__name__.__eq__"
  args: ["ReadTransport"]
  expected: true
