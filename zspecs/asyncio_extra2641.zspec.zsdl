spec: asyncio_extra2641
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio classes documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier, StreamReader __dict__ for __copy__, __deepcopy__, __sizeof__ presence (all false)"]
  created_at: "2026-04-13"
error_model: python_exceptions

table asyncio_extra2641.queue_task_future_dict_presence:
  description: "asyncio.Queue, asyncio.Task, asyncio.Future __dict__ does not contain __copy__, __deepcopy__, __sizeof__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2641qtf
  columns: [id, function, args, expected]
  rows:
    - ["as2641qtf001", asyncio.Queue.__dict__.__contains__, ["__copy__"], false]
    - ["as2641qtf002", asyncio.Queue.__dict__.__contains__, ["__deepcopy__"], false]
    - ["as2641qtf003", asyncio.Queue.__dict__.__contains__, ["__sizeof__"], false]
    - ["as2641qtf004", asyncio.Task.__dict__.__contains__, ["__copy__"], false]
    - ["as2641qtf005", asyncio.Task.__dict__.__contains__, ["__deepcopy__"], false]
    - ["as2641qtf006", asyncio.Task.__dict__.__contains__, ["__sizeof__"], false]
    - ["as2641qtf007", asyncio.Future.__dict__.__contains__, ["__copy__"], false]
    - ["as2641qtf008", asyncio.Future.__dict__.__contains__, ["__deepcopy__"], false]
    - ["as2641qtf009", asyncio.Future.__dict__.__contains__, ["__sizeof__"], false]

