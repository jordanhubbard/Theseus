spec: pathlib_extra275
version: ">=3.10"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib.Path filesystem-mutating methods (stat, lstat, chmod, rename, replace, symlink_to, hardlink_to, touch, rmdir) are plain Python functions."
    - "All Path traversal/stat method __class__.__name__ == 'function'."
    - "Path method qualnames follow 'Path.<method_name>' pattern."
    - "hardlink_to was added in Python 3.10 (replacing link_to which was deprecated and removed)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: Path traversal/stat method __name__ identity
# ---------------------------------------------------------------------------

table pathlib_extra275.path_stat_method_names:
  description: "pathlib.Path stat/traversal method __name__ for stat, lstat, chmod, rename, replace, symlink_to, hardlink_to, touch, rmdir"
  kind: python_call_eq
  category: identity
  id_prefix: nm

  columns: [id, function, args, expected, description]
  rows:
    - [stat_name,        Path.stat.__name__.__eq__,        ["stat"],        true, "pathlib.Path.stat.__name__ == 'stat'"]
    - [lstat_name,       Path.lstat.__name__.__eq__,       ["lstat"],       true, "pathlib.Path.lstat.__name__ == 'lstat'"]
    - [chmod_name,       Path.chmod.__name__.__eq__,       ["chmod"],       true, "pathlib.Path.chmod.__name__ == 'chmod'"]
    - [rename_name,      Path.rename.__name__.__eq__,      ["rename"],      true, "pathlib.Path.rename.__name__ == 'rename'"]
    - [replace_name,     Path.replace.__name__.__eq__,     ["replace"],     true, "pathlib.Path.replace.__name__ == 'replace'"]
    - [symlink_to_name,  Path.symlink_to.__name__.__eq__,  ["symlink_to"],  true, "pathlib.Path.symlink_to.__name__ == 'symlink_to'"]
    - [hardlink_to_name, Path.hardlink_to.__name__.__eq__, ["hardlink_to"], true, "pathlib.Path.hardlink_to.__name__ == 'hardlink_to'"]
    - [touch_name,       Path.touch.__name__.__eq__,       ["touch"],       true, "pathlib.Path.touch.__name__ == 'touch'"]
    - [rmdir_name,       Path.rmdir.__name__.__eq__,       ["rmdir"],       true, "pathlib.Path.rmdir.__name__ == 'rmdir'"]

# ---------------------------------------------------------------------------
# Table: Path traversal/stat method __class__.__name__ (all 'function')
# ---------------------------------------------------------------------------

table pathlib_extra275.path_stat_method_classes:
  description: "pathlib.Path stat/traversal method __class__.__name__ for stat, lstat, chmod, rename, replace, symlink_to, hardlink_to, touch, rmdir"
  kind: python_call_eq
  category: identity
  id_prefix: cls

  columns: [id, function, args, expected, description]
  rows:
    - [stat_class,        Path.stat.__class__.__name__.__eq__,        ["function"], true, "pathlib.Path.stat.__class__.__name__ == 'function'"]
    - [lstat_class,       Path.lstat.__class__.__name__.__eq__,       ["function"], true, "pathlib.Path.lstat.__class__.__name__ == 'function'"]
    - [chmod_class,       Path.chmod.__class__.__name__.__eq__,       ["function"], true, "pathlib.Path.chmod.__class__.__name__ == 'function'"]
    - [rename_class,      Path.rename.__class__.__name__.__eq__,      ["function"], true, "pathlib.Path.rename.__class__.__name__ == 'function'"]
    - [replace_class,     Path.replace.__class__.__name__.__eq__,     ["function"], true, "pathlib.Path.replace.__class__.__name__ == 'function'"]
    - [symlink_to_class,  Path.symlink_to.__class__.__name__.__eq__,  ["function"], true, "pathlib.Path.symlink_to.__class__.__name__ == 'function'"]
    - [hardlink_to_class, Path.hardlink_to.__class__.__name__.__eq__, ["function"], true, "pathlib.Path.hardlink_to.__class__.__name__ == 'function'"]
    - [touch_class,       Path.touch.__class__.__name__.__eq__,       ["function"], true, "pathlib.Path.touch.__class__.__name__ == 'function'"]
    - [rmdir_class,       Path.rmdir.__class__.__name__.__eq__,       ["function"], true, "pathlib.Path.rmdir.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# Standalone invariants: qualnames
# ---------------------------------------------------------------------------

invariant pathlib_extra275.Path.stat.qualname:
  description: "pathlib.Path.stat.__qualname__ == 'Path.stat'"
  category: identity
  kind: python_call_eq
  function: Path.stat.__qualname__.__eq__
  args: ["Path.stat"]
  expected: true

invariant pathlib_extra275.Path.lstat.qualname:
  description: "pathlib.Path.lstat.__qualname__ == 'Path.lstat'"
  category: identity
  kind: python_call_eq
  function: Path.lstat.__qualname__.__eq__
  args: ["Path.lstat"]
  expected: true

invariant pathlib_extra275.Path.chmod.qualname:
  description: "pathlib.Path.chmod.__qualname__ == 'Path.chmod'"
  category: identity
  kind: python_call_eq
  function: Path.chmod.__qualname__.__eq__
  args: ["Path.chmod"]
  expected: true

invariant pathlib_extra275.Path.rename.qualname:
  description: "pathlib.Path.rename.__qualname__ == 'Path.rename'"
  category: identity
  kind: python_call_eq
  function: Path.rename.__qualname__.__eq__
  args: ["Path.rename"]
  expected: true

invariant pathlib_extra275.Path.symlink_to.qualname:
  description: "pathlib.Path.symlink_to.__qualname__ == 'Path.symlink_to'"
  category: identity
  kind: python_call_eq
  function: Path.symlink_to.__qualname__.__eq__
  args: ["Path.symlink_to"]
  expected: true

invariant pathlib_extra275.Path.hardlink_to.qualname:
  description: "pathlib.Path.hardlink_to.__qualname__ == 'Path.hardlink_to'"
  category: identity
  kind: python_call_eq
  function: Path.hardlink_to.__qualname__.__eq__
  args: ["Path.hardlink_to"]
  expected: true
