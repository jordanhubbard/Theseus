spec: hashlib_extra57
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra56.zspec.zsdl — covers blake2b/blake2s __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); hashlib module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); sha256/md5/sha1/pbkdf2_hmac/sha3_256/new __qualname__.__class__.__name__.__eq__('str')."
    - "hashlib_extra55.zspec.zsdl — covers algorithms_guaranteed.__contains__ for sha224/sha384/blake2b/blake2s/sha3_256/sha3_512; algorithms_available/__guaranteed__ __class__.__module__.__len__()==8; hashlib.__name__.__eq__('hashlib') and __name__.__len__()==7."
    - "hashlib_extra50.zspec.zsdl — covers sha256/new/blake2b __class__.__module__.__eq__('builtins') (3 representative rows only; does NOT cover md5/sha1/sha3_256/blake2s)."
  notes:
    - "This spec extends hashlib through hashlib_extra56; it does NOT duplicate invariants present in those files."
    - "Wave 221 theme: __class__.__module__ string equality checks + __init__.__class__ checks for class objects."
    - "Coverage gap 1: hashlib_extra50 checks sha256/new/blake2b __class__.__module__.__eq__('builtins') as three representative rows, but does NOT cover md5, sha1, sha3_256, or blake2s on the __class__.__module__ axis. All four are module-level callables whose __class__ lives in builtins. Extending to all four completes the __class__.__module__.__eq__('builtins') coverage for the main hashlib callables. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__class__.__module__ == 'builtins'. md5 is a builtin_function_or_method (OpenSSL-backed); its type's __module__ is 'builtins'. hashlib_extra50 covers sha256/__class__/__module__ but NOT md5. No prior hashlib spec checks md5.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__class__.__module__ == 'builtins'. sha1 is a builtin_function_or_method; same pattern as md5. No prior hashlib spec checks sha1.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__class__.__module__ == 'builtins'. sha3_256 is a builtin_function_or_method (OpenSSL-backed). No prior hashlib spec checks sha3_256.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__class__.__module__ == 'builtins'. blake2s is a C extension type; its metaclass (type) has __module__ == 'builtins'. hashlib_extra50 covers blake2b/__class__/__module__ but NOT blake2s. No prior hashlib spec checks blake2s.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior hashlib spec checks __init__.__class__.__name__ or __init__.__class__.__module__ for blake2b or blake2s. blake2b and blake2s are C extension types; their __init__ is a 'wrapper_descriptor' (the C slot wrapper for tp_init). struct_extra40 establishes this pattern for struct.Struct, but no hashlib spec has checked __init__.__class__ for any hashlib type. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__init__.__class__.__name__ == 'wrapper_descriptor'. blake2b is a C extension type; its __init__ descriptor is a wrapper_descriptor (CPython's C slot wrapper). No prior hashlib spec checks __init__.__class__.__name__.__eq__('wrapper_descriptor') for any hashlib type. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__init__.__class__.__name__ == 'wrapper_descriptor'. Same pattern as blake2b; both are C extension types with slot-wrapped __init__. No prior hashlib spec checks this for blake2s. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__init__.__class__.__module__ == 'builtins'. wrapper_descriptor is a C type whose __module__ is 'builtins'. No prior hashlib spec checks blake2b.__init__.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__init__.__class__.__module__ == 'builtins'. Same reasoning as blake2b. No prior hashlib spec checks blake2s.__init__.__class__.__module__.__eq__('builtins'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib md5/sha1/sha3_256/blake2s __class__.__module__.__eq__('builtins')
#
# hashlib_extra50 checks sha256/new/blake2b __class__.__module__.__eq__('builtins')
# as three representative rows covering the three distinct __class__ kinds
# (builtin_function_or_method, function, type). It does NOT cover md5, sha1,
# sha3_256, or blake2s. All four of these are module-level callables whose
# __class__ is defined in builtins. Completing coverage to all main callables
# on the __class__.__module__ axis provides additional regression vectors.
# ---------------------------------------------------------------------------

table hashlib_extra57.callable_class_module_eq:
  description: "hashlib.md5/sha1/sha3_256/blake2s __class__.__module__.__eq__('builtins') — hashlib_extra50 covers sha256/new/blake2b __class__.__module__.__eq__('builtins') (3 representative rows) but NOT md5/sha1/sha3_256/blake2s; all four have __class__ from builtins; novel extension of the __class__.__module__ axis"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibmod57

  columns: [id, function, args, expected]
  rows:
    - [md5_class_module_eq,     md5.__class__.__module__.__eq__,     ["builtins"], true]
    - [sha1_class_module_eq,    sha1.__class__.__module__.__eq__,    ["builtins"], true]
    - [sha3_256_class_module_eq, sha3_256.__class__.__module__.__eq__, ["builtins"], true]
    - [blake2s_class_module_eq, blake2s.__class__.__module__.__eq__, ["builtins"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b and blake2s __init__.__class__.__name__.__eq__('wrapper_descriptor')
#
# No prior hashlib spec checks __init__.__class__.__name__ for any hashlib type.
# blake2b and blake2s are C extension types; their __init__ is implemented as
# a C slot (tp_init), exposed in Python as a 'wrapper_descriptor'. This is the
# standard CPython pattern for C extension types without an explicit Python-level
# __init__ method. The __class__.__name__ check catches any change to the
# internal descriptor type used for C slot wrappers.
# ---------------------------------------------------------------------------

table hashlib_extra57.blake_init_class_name_eq:
  description: "hashlib.blake2b/__init__/__class__/__name__.__eq__('wrapper_descriptor') and blake2s same — C extension types use slot wrappers for __init__; __init__.__class__.__name__ == 'wrapper_descriptor'; no prior hashlib spec checks __init__.__class__.__name__.__eq__ for any hashlib type"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibmod57

  columns: [id, function, args, expected]
  rows:
    - [blake2b_init_class_name_eq, blake2b.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [blake2s_init_class_name_eq, blake2s.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b __init__.__class__.__module__.__eq__('builtins')
#
# No prior hashlib spec checks __init__.__class__.__module__ for any hashlib type.
# wrapper_descriptor is a C builtin type; its __module__ is 'builtins'. This
# is an independent regression vector from the __class__.__name__ check above:
# if the descriptor type is renamed but still in builtins, __name__ catches it
# but __module__ would not; if moved out of builtins, __module__ catches it.
# ---------------------------------------------------------------------------

invariant hashlib_extra57.blake2b.init_class_module_eq:
  description: "hashlib.blake2b.__init__.__class__.__module__ == 'builtins' — wrapper_descriptor is a C builtin type; __module__ is 'builtins'; independent from __class__.__name__ axis; no prior hashlib spec checks __init__.__class__.__module__.__eq__('builtins') for any hashlib type"
  category: type_structure
  kind: python_call_eq
  function: blake2b.__init__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant hashlib_extra57.blake2s.init_class_module_eq:
  description: "hashlib.blake2s.__init__.__class__.__module__ == 'builtins' — same wrapper_descriptor pattern as blake2b; no prior hashlib spec checks __init__.__class__.__module__.__eq__('builtins') for blake2s"
  category: type_structure
  kind: python_call_eq
  function: blake2s.__init__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
