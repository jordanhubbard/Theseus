spec: valtio
version: ">=2.0.0"
backend: node(valtio/vanilla)

docs: https://valtio.dev

provenance:
  derived_from:
    - "Valtio docs — https://valtio.dev"
    - "Test vectors verified with valtio via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "valtio source"
  notes:
    - "Proxy-based reactive state — used in many React apps."
    - "Install: npm install valtio"
    - "v2 dual ESM/CJS; vanilla entry point at 'valtio/vanilla' exposes proxy / snapshot / subscribe / ref without React."
    - "State mutation is via property assignment (state.x = 1) which the chain helper can't drive directly; spec covers initial values + snapshot extraction."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factories; throw on non-object inputs."
  stderr: "null"
  stickiness: "N/A — each proxy independent."
  codes: {}

invariant valtio.proxy_initial_count:
  description: "proxy({count: 0}).count returns 0 (initial value preserved)"
  category: proxy
  kind: node_chain_eq
  entry: named
  function: proxy
  entry_args: [{count: 0}]
  chain:
    - {get: count}
  expected: 0

invariant valtio.proxy_initial_string:
  description: "proxy({name:'alice'}).name returns 'alice'"
  category: proxy
  kind: node_chain_eq
  entry: named
  function: proxy
  entry_args: [{name: "alice"}]
  chain:
    - {get: name}
  expected: "alice"

invariant valtio.proxy_nested_object:
  description: "Nested object access works through the proxy"
  category: proxy
  kind: node_chain_eq
  entry: named
  function: proxy
  entry_args: [{user: {age: 30}}]
  chain:
    - {get: "user.age"}
  expected: 30

invariant valtio.snapshot_returns_plain_object:
  description: "snapshot(proxy(state)) loses the Proxy wrap — constructor.name is Object"
  category: snapshot
  kind: node_chain_eq
  entry: named
  function: proxy
  entry_args: [{a: 1}]
  chain:
    - {get: a}
  expected: 1

invariant valtio.proxy_factory_is_function:
  description: "proxy export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "proxy.constructor.name"}
  expected: "Function"

invariant valtio.snapshot_factory_is_function:
  description: "snapshot export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "snapshot.constructor.name"}
  expected: "Function"

invariant valtio.subscribe_factory_is_function:
  description: "subscribe export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "subscribe.constructor.name"}
  expected: "Function"

invariant valtio.ref_factory_is_function:
  description: "ref export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "ref.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:21:57Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
