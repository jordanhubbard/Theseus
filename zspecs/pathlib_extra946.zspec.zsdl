spec: pathlib_extra946
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib module identity, PurePath and Path class name identities"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra946.module_identity:
  description: "pathlib module-level attribute identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: pl946m
  columns: [id, function, args, expected]
  rows:
    - [pl946m001, pathlib.__name__.__eq__,    ["pathlib"], true]
    - [pl946m002, pathlib.__package__.__eq__, ["pathlib"], true]
    - [pl946m003, pathlib.__spec__.name.__eq__, ["pathlib"], true]

table pathlib_extra946.pure_class_names:
  description: "pathlib pure path class __name__ identity"
  kind: python_call_eq
  category: pure_class_names
  id_prefix: pl946p
  columns: [id, function, args, expected]
  rows:
    - [pl946p001, pathlib.PurePath.__name__.__eq__,        ["PurePath"],        true]
    - [pl946p002, pathlib.PurePosixPath.__name__.__eq__,   ["PurePosixPath"],   true]
    - [pl946p003, pathlib.PureWindowsPath.__name__.__eq__, ["PureWindowsPath"], true]
    - [pl946p004, pathlib.PurePath.__module__.__eq__,      ["pathlib"],         true]
    - [pl946p005, pathlib.PurePosixPath.__module__.__eq__, ["pathlib"],         true]
    - [pl946p006, pathlib.PureWindowsPath.__module__.__eq__, ["pathlib"],       true]

table pathlib_extra946.concrete_class_names:
  description: "pathlib concrete path class __name__ identity"
  kind: python_call_eq
  category: concrete_class_names
  id_prefix: pl946c
  columns: [id, function, args, expected]
  rows:
    - [pl946c001, pathlib.Path.__name__.__eq__,        ["Path"],        true]
    - [pl946c002, pathlib.PosixPath.__name__.__eq__,   ["PosixPath"],   true]
    - [pl946c003, pathlib.WindowsPath.__name__.__eq__, ["WindowsPath"], true]
    - [pl946c004, pathlib.Path.__module__.__eq__,      ["pathlib"],     true]
    - [pl946c005, pathlib.PosixPath.__module__.__eq__, ["pathlib"],     true]
    - [pl946c006, pathlib.WindowsPath.__module__.__eq__, ["pathlib"],   true]
    - [pl946c007, pathlib.Path.__name__.__eq__,        ["NotPath"],     false]
