spec: uuid_extra250
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.UUID.__init__.__class__.__name__ == 'function' — all dunder methods on UUID are plain Python functions."
    - "uuid.UUID has no __bytes__ dunder method; UUID byte data is accessed via the .bytes and .bytes_le properties."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__'; same pattern for __eq__, __lt__, __repr__, __str__."
    - "uuid.UUID.__int__.__qualname__ == 'UUID.__int__' and __class__.__name__ == 'function'."
    - "All qualnames follow the pattern 'UUID.<method_name>'."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__init__ identity
# ---------------------------------------------------------------------------

invariant uuid_extra250.UUID.__init__.qualname:
  description: "uuid.UUID.__init__.__qualname__ == 'UUID.__init__'"
  category: identity
  kind: python_call_eq
  function: UUID.__init__.__qualname__.__eq__
  args: ["UUID.__init__"]
  expected: true

invariant uuid_extra250.UUID.__init__.class_name:
  description: "uuid.UUID.__init__.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: UUID.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

