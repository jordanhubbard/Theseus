# ---------------------------------------------------------------------------
# Table 2: inspect.getmro — function identity and code attrs
#
# Wave 278 theme: inspect.getmro — returns the MRO of a class as a tuple.
#
# inspect.getmro.__qualname__ == 'getmro' (len 6)
# inspect.getmro.__module__ == 'inspect'
# inspect.getmro.__code__.co_argcount == 1
# inspect.getmro.__class__.__name__ == 'function'
#
# getmro(cls) returns the tuple of base classes of cls including cls itself
# in method resolution order (equivalent to cls.__mro__). New to extra149.
# ---------------------------------------------------------------------------

