# Condition.wait.__qualname__     == 'Condition.wait'       (len=14)
# Condition.wait_for.__qualname__ == 'Condition.wait_for'   (len=18)
# Condition.notify.__qualname__   == 'Condition.notify'     (len=16)
# Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20)
# Condition.__mro__.__len__() == 4  [Condition, _ContextManagerMixin, _LoopBoundMixin, object]
# Condition.__module__ == 'asyncio.locks'
# ---------------------------------------------------------------------------

table asyncio_extra101.asyncio_condition_qualnames:
  description: "asyncio.Condition method __qualname__ checks in asynciocondqn101 namespace — wave 254 theme: asyncio.Condition is a pure-Python class in Lib/asyncio/locks.py with a 4-element MRO ([Condition, _ContextManagerMixin, _LoopBoundMixin, object]); Condition defines four methods: wait (a coroutine), wait_for (a coroutine), notify, and notify_all; Condition does NOT have acquire/release methods (it uses async-with via _ContextManagerMixin); Condition.__init__.__qualname__.__eq__('Condition.__init__')==True (len=18: 'Condition.'=10 + '__init__'=8); Condition.wait.__qualname__.__eq__('Condition.wait')==True (len=14: 'Condition.'=10 + 'wait'=4); Condition.wait_for.__qualname__.__eq__('Condition.wait_for')==True (len=18: 'Condition.'=10 + 'wait_for'=8, same length as __init__); Condition.notify.__qualname__.__eq__('Condition.notify')==True (len=16: 'Condition.'=10 + 'notify'=6); Condition.notify_all.__qualname__.__eq__('Condition.notify_all')==True (len=20: 'Condition.'=10 + 'notify_all'=10, the longest); all methods have class='function' (pure-Python); Condition.__module__=='asyncio.locks'; verified with Python 3.14.3"
