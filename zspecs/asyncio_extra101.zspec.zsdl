# ---------------------------------------------------------------------------
# Standalone invariants — extra101
# ---------------------------------------------------------------------------

invariant asyncio_extra101.Condition_mro_len_is_4:
  description: "asyncio.Condition.__mro__.__len__() == 4 — Condition's MRO is [Condition, _ContextManagerMixin, _LoopBoundMixin, object] (length=4); this 4-element chain is deeper than most asyncio primitives: asyncio.Task.__mro__.__len__()==3, asyncio.Future.__mro__.__len__()==2, asyncio.Queue.__mro__.__len__()==3; the extra depth comes from the two mixin classes (_ContextManagerMixin provides async-with context manager support, _LoopBoundMixin provides event loop binding); Condition.__module__ is 'asyncio.locks'; Condition does NOT have acquire/release methods — it uses the context manager protocol; Condition.wait.__qualname__=='Condition.wait' (len=14, shortest); Condition.notify_all.__qualname__=='Condition.notify_all' (len=20, longest); NEW in extra101: first standalone Condition MRO length invariant in asynciocondqn101 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra101.BoundedSemaphore_acquire_qualname_inherited:
  description: "asyncio.BoundedSemaphore.acquire.__qualname__.__eq__('Semaphore.acquire') returns True — BoundedSemaphore.acquire.__qualname__ is 'Semaphore.acquire' (len=17), NOT 'BoundedSemaphore.acquire'; this reveals that BoundedSemaphore inherits acquire from Semaphore and does NOT override it; only BoundedSemaphore.release is overridden (qualname='BoundedSemaphore.release', len=24) to enforce the upper bound on the semaphore count; BoundedSemaphore.__bases__[0].__name__ is 'Semaphore'; BoundedSemaphore.__mro__.__len__() is 5 ([BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]); this inherited-vs-own qualname pattern parallels concurrent.futures.ThreadPoolExecutor.map whose qualname is 'Executor.map' (not 'ThreadPoolExecutor.map') because it inherits map from Executor; NEW in extra101: first standalone BoundedSemaphore acquire inherited qualname invariant in asynciocondqn101 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true

invariant asyncio_extra101.Queue_module_is_asyncio_queues:
  description: "asyncio.Queue.__module__.__eq__('asyncio.queues') returns True — asyncio.Queue is defined in Lib/asyncio/queues.py (the 'asyncio.queues' submodule); this contrasts with asyncio.Condition and asyncio.BoundedSemaphore whose module is 'asyncio.locks' (Lib/asyncio/locks.py); Queue.__mro__.__len__() is 3 ([Queue, _LoopBoundMixin, object]); Queue has 10 public methods (empty, full, get, get_nowait, join, maxsize, put, put_nowait, qsize, shutdown, task_done) and Queue.put_nowait.__qualname__.__len__()==16 (tied with get_nowait for longest method qualname, compared to Queue.put.__qualname__.__len__()==9 for shortest); NEW in extra101: first standalone Queue module invariant in asynciocondqn101 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra101.Condition_notify_all_qualname_len_20:
  description: "asyncio.Condition.notify_all.__qualname__.__len__() == 20 — Condition.notify_all.__qualname__ is 'Condition.notify_all' (20 characters: 'Condition.'=10 + 'notify_all'=10); this is the longest Condition method qualname; compare all Condition method qualname lengths: wait=14, notify=16, __init__=18, wait_for=18, notify_all=20; all Condition methods have class='function' (pure-Python, defined in Lib/asyncio/locks.py); Condition.__module__ is 'asyncio.locks'; Condition.notify_all wakes all coroutines waiting on the condition, while Condition.notify(n=1) wakes only n waiters; NEW in extra101: first standalone Condition.notify_all qualname length invariant in asynciocondqn101 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.notify_all.__qualname__.__len__
  args: []
  expected: 20

invariant asyncio_extra101.BoundedSemaphore_mro_len_is_5:
  description: "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — BoundedSemaphore's MRO is [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (length=5); this is the deepest MRO in the asyncio locks hierarchy; compare: Condition.__mro__.__len__()==4 (lacks the Semaphore intermediate), Queue.__mro__.__len__()==3, asyncio.Task.__mro__.__len__()==3, asyncio.Future.__mro__.__len__()==2; BoundedSemaphore.__bases__[0].__name__ is 'Semaphore'; BoundedSemaphore.__module__ is 'asyncio.locks'; BoundedSemaphore.__init__.__qualname__.__len__() is 25 (longest __init__ qualname in this spec); NEW in extra101: first standalone BoundedSemaphore MRO length invariant in asynciocondqn101 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__mro__.__len__
  args: []
  expected: 5

