spec: posixpath_extra2
version: ">=3.0"
backend: python_module(posixpath)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python posixpath documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py"
  notes:
    - "This spec extends posixpath.zspec.zsdl and posixpath_extra.zspec.zsdl."
    - "Covers module-level constants sep, curdir, pardir, and the module __name__ attribute."
    - "posixpath.sep is '/' — the POSIX path separator."
    - "posixpath.curdir is '.' — the current directory marker."
    - "posixpath.pardir is '..' — the parent directory marker."
    - "posixpath.__name__ == 'posixpath' confirms this is the posixpath module."
    - "posixpath.split.__name__ == 'split' and posixpath.abspath.__name__ == 'abspath' are additional name checks not in prior specs."
    - "Note: posixpath.normpath.__name__ is '_path_normpath' on CPython 3.12+; the spec checks the actual value."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __name__ attribute
# ---------------------------------------------------------------------------

invariant posixpath_extra2.module.name:
  description: "posixpath.__name__ == 'posixpath'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["posixpath"]
  expected: true

# ---------------------------------------------------------------------------
# Module constants — sep, curdir, pardir
# ---------------------------------------------------------------------------

invariant posixpath_extra2.constants.sep:
  description: "posixpath.sep == '/' — POSIX path separator"
  category: constants
  kind: python_call_eq
  function: sep.__eq__
  args: ["/"]
  expected: true

invariant posixpath_extra2.constants.curdir:
  description: "posixpath.curdir == '.' — current directory marker"
  category: constants
  kind: python_call_eq
  function: curdir.__eq__
  args: ["."]
  expected: true

invariant posixpath_extra2.constants.pardir:
  description: "posixpath.pardir == '..' — parent directory marker"
  category: constants
  kind: python_call_eq
  function: pardir.__eq__
  args: [".."]
  expected: true

# ---------------------------------------------------------------------------
# Additional function name checks not in prior posixpath specs
# ---------------------------------------------------------------------------

invariant posixpath_extra2.function_names.normpath:
  description: "posixpath.normpath.__name__ == '_path_normpath' on CPython 3.12+"
  category: function_names
  kind: python_call_eq
  function: normpath.__name__.__eq__
  args: ["_path_normpath"]
  expected: true

invariant posixpath_extra2.function_names.abspath:
  description: "posixpath.abspath.__name__ == 'abspath'"
  category: function_names
  kind: python_call_eq
  function: abspath.__name__.__eq__
  args: ["abspath"]
  expected: true

# ---------------------------------------------------------------------------
# split — two-part decomposition
# ---------------------------------------------------------------------------

invariant posixpath_extra2.split.head_and_tail:
  description: "posixpath.split('/a/b/c')[0] == '/a/b' — head component"
  category: split
  kind: python_call_eq
  function: split
  args: ["/a/b/c"]
  method: __getitem__
  method_args: [0]
  expected: "/a/b"

invariant posixpath_extra2.split.tail:
  description: "posixpath.split('/a/b/c')[1] == 'c' — tail component"
  category: split
  kind: python_call_eq
  function: split
  args: ["/a/b/c"]
  method: __getitem__
  method_args: [1]
  expected: "c"
