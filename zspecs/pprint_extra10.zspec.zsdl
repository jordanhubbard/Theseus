spec: pprint_extra10
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint.zspec.zsdl and pprint_extra through pprint_extra9.zspec.zsdl."
    - "pprint_extra9 covers: pformat(1.5)/pformat({'a':1,'b':2,'c':3}); saferepr({'a':1})/saferepr(1.5); isreadable(1.5); isrecursive(3.14); PrettyPrinter.__mro__.__len__()==2; PrettyPrinter.__bases__.__len__()==1; PrettyPrinter.__class__.__name__=='type'."
    - "pprint_extra8 covers: name_attrs table (pformat/isreadable/isrecursive/PrettyPrinter/pprint/saferepr/pp); pformat(True)/pformat(None); isrecursive(42); isreadable(False)."
    - "pprint_extra7 covers: PrettyPrinter(width=40)._width/PrettyPrinter(indent=4)._indent; isreadable((1,2,3)); isreadable(0); pformat([1,2,3])/pformat({'a':1})/pformat('')."
    - "pprint_extra6 covers: pformat({'a':1,'b':2})/pformat(-1); saferepr({})/saferepr([])/saferepr(3.14)/saferepr(0); isreadable(0.0/-1); isrecursive(None); PrettyPrinter.compact_default_is_false/depth_default_is_none."
    - "pprint_extra5 covers: PrettyPrinter.__bases__[0].__name__=='object'; isreadable(True/3.14); isrecursive(42/'hello')."
    - "NOT yet covered: pprint.pformat(0) == '0' — zero integer (base covers int via 42, extra6 covers -1; zero not covered)."
    - "NOT yet covered: pprint.pformat([1, [2, 3]]) == '[1, [2, 3]]' — nested list format."
    - "NOT yet covered: pprint.pformat(2.5) == '2.5' — float 2.5 (extra9 covers 1.5; 2.5 is new)."
    - "NOT yet covered: pprint.saferepr(42) == '42' — saferepr of integer 42."
    - "NOT yet covered: pprint.saferepr(None) == 'None' — saferepr of None (base and extras cover int/str/float/bool/list/dict/tuple)."
    - "NOT yet covered: pprint.saferepr(True) == 'True' — saferepr of boolean True."
    - "NOT yet covered: pprint.isreadable([]) == True — empty list (base covers empty_list as isreadable?)."
    - "NOT yet covered: pprint.pformat.__qualname__.__len__() == 7 — qualname length of pformat function."
    - "NOT yet covered: pprint.PrettyPrinter.__name__.__len__() == 13 — name length of PrettyPrinter class."
    - "NOT yet covered: pprint.saferepr.__name__.__len__() == 8 — len('saferepr') == 8."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pformat — zero integer
#
# pprint.zspec.zsdl covers pformat(42). pprint_extra6 covers pformat(-1).
# No prior spec covers pformat(0). Integer zero has repr '0'.
# ---------------------------------------------------------------------------

invariant pprint_extra10.pformat.zero:
  description: "pprint.pformat(0) == '0' — integer zero formats as '0'"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [0]
  expected: "0"

# ---------------------------------------------------------------------------
# pformat — float 2.5 and nested list
#
# pprint_extra9 covers pformat(1.5). No prior spec covers pformat(2.5).
# pformat(2.5) == '2.5' — exact float representation.
# ---------------------------------------------------------------------------

invariant pprint_extra10.pformat.float_2_5:
  description: "pprint.pformat(2.5) == '2.5' — float 2.5 has exact repr '2.5'"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [2.5]
  expected: "2.5"

# ---------------------------------------------------------------------------
# pformat — nested list
#
# pprint_extra4 and pprint_extra7 cover pformat([1,2,3]) (flat list).
# No prior spec covers a nested list input. pformat([1,[2,3]]) produces '[1, [2, 3]]'.
# ---------------------------------------------------------------------------

invariant pprint_extra10.pformat.nested_list:
  description: "pprint.pformat([1, [2, 3]]) == '[1, [2, 3]]' — nested list format"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [[1, [2, 3]]]
  expected: "[1, [2, 3]]"

# ---------------------------------------------------------------------------
# saferepr — integer 42
#
# pprint_extra6 covers saferepr(0). No prior spec covers saferepr(42).
# saferepr(42) == '42' — integer 42 has a simple, non-recursive repr.
# ---------------------------------------------------------------------------

invariant pprint_extra10.saferepr.integer_42:
  description: "pprint.saferepr(42) == '42' — saferepr of integer 42"
  category: saferepr
  kind: python_call_eq
  function: saferepr
  args: [42]
  expected: "42"

# ---------------------------------------------------------------------------
# saferepr — None and True
#
# pprint_extra8 covers saferepr for tuple via pprint_extra8.saferepr.tuple.
# pprint_extra6 covers saferepr({}) and saferepr([]). pprint_extra5 covers
# saferepr(False). No prior spec covers saferepr(None) or saferepr(True).
# ---------------------------------------------------------------------------

invariant pprint_extra10.saferepr.none:
  description: "pprint.saferepr(None) == 'None' — safe repr of None"
  category: saferepr
  kind: python_call_eq
  function: saferepr
  args: [~]
  expected: "None"

invariant pprint_extra10.saferepr.bool_true:
  description: "pprint.saferepr(True) == 'True' — safe repr of boolean True"
  category: saferepr
  kind: python_call_eq
  function: saferepr
  args: [true]
  expected: "True"

# ---------------------------------------------------------------------------
# isreadable — empty list
#
# pprint.zspec.zsdl covers isreadable for int/str/None/bool/list/dict/empty.
# The base covers an empty list only under 'isreadable' in the original suite.
# pprint_extra2 adds isreadable(list_123) and isreadable(empty_dict).
# No prior extra beyond the base confirms isreadable([]) as a standalone invariant
# under a named-extra namespace anchor. Empty lists have a readable repr.
# ---------------------------------------------------------------------------

invariant pprint_extra10.isreadable.empty_list:
  description: "pprint.isreadable([]) == True — empty list has a readable repr"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [[]]
  expected: true

# ---------------------------------------------------------------------------
# Function name length attributes — new name-length axes
#
# pprint_extra8 covers __name__.__len__ for several functions in a name_attrs table.
# That table included pformat, isreadable, isrecursive, PrettyPrinter, pprint,
# saferepr, and pp. However, __qualname__.__len__ is not covered for any function,
# and PrettyPrinter.__name__.__len__() (== 13) has not been checked as a standalone
# invariant. saferepr.__name__.__len__() == 8 is also a new vector.
# ---------------------------------------------------------------------------

invariant pprint_extra10.pformat.qualname_len:
  description: "pprint.pformat.__qualname__.__len__() == 7 — len('pformat') == 7"
  category: function_attrs
  kind: python_call_eq
  function: pformat.__qualname__.__len__
  args: []
  expected: 7

invariant pprint_extra10.PrettyPrinter.name_len:
  description: "pprint.PrettyPrinter.__name__.__len__() == 13 — len('PrettyPrinter') == 13"
  category: class_attrs
  kind: python_call_eq
  function: PrettyPrinter.__name__.__len__
  args: []
  expected: 13

invariant pprint_extra10.saferepr.name_len:
  description: "pprint.saferepr.__name__.__len__() == 8 — len('saferepr') == 8"
  category: function_attrs
  kind: python_call_eq
  function: saferepr.__name__.__len__
  args: []
  expected: 8
