spec: configparser_extra5
version: ">=3.9"
backend: python_module(configparser)

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — Python configparser documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/configparser.py"
  notes:
    - "This spec extends configparser.zspec.zsdl and prior extras."
    - "configparser (base) covers: __name__ for all public classes and exceptions, DEFAULTSECT, initial state, MRO checks."
    - "configparser_extra covers: ConfigParser/__name__/__module__, RawConfigParser/__name__, Error/__name__, NoSectionError/__name__/__base__, NoOptionError/__name__/__base__, DuplicateSectionError/__name__, InterpolationError/__name__, ConfigParser().sections()==[], DEFAULTSECT=='DEFAULT'."
    - "configparser_extra2 covers: __module__ for RawConfigParser/BasicInterpolation/ExtendedInterpolation/Error/NoSectionError/NoOptionError/DuplicateSectionError/ParsingError/MissingSectionHeaderError, exception hierarchy bases, ConfigParser method names, is_type checks, DEFAULTSECT class name."
    - "configparser_extra3 covers: __name__ tables for ConfigParser/RawConfigParser and all exceptions, DEFAULTSECT/MAX_INTERPOLATION_DEPTH values, Error base, NoSectionError base, ConfigParser instance class, ConfigParser __module__, RawConfigParser base."
    - "configparser_extra4 covers: __qualname__ for all major classes and exceptions."
    - "configparser.SafeConfigParser was removed in Python 3.12 — skipped."
    - "This spec adds: configparser.__name__ == 'configparser' (module-level __name__, new), ConfigParser.__bases__[0].__name__ == 'RawConfigParser' (ConfigParser directly inherits RawConfigParser; prior specs only cover RawConfigParser's base = MutableMapping), and __module__ for Error/NoSectionError/NoOptionError verified via a table (extra2 notes coverage but not in a table; extra3 does not cover these __module__ values at all)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# configparser.__name__ == 'configparser' — the module's own __name__ attribute.
# Distinct from ConfigParser.__name__ (a class attribute).
# Not covered in any prior configparser spec.
# ---------------------------------------------------------------------------

invariant configparser_extra5.module.name:
  description: "configparser.__name__ == 'configparser' — the module object's __name__"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["configparser"]
  expected: true

# ---------------------------------------------------------------------------
# ConfigParser.__bases__[0].__name__ == 'RawConfigParser'
# ConfigParser inherits directly from RawConfigParser. Prior specs confirm
# RawConfigParser.__bases__[0].__name__ == 'MutableMapping' (extra3), but
# ConfigParser's own direct base has not been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant configparser_extra5.ConfigParser.base_name:
  description: "configparser.ConfigParser.__bases__[0].__name__ == 'RawConfigParser'"
  category: hierarchy
  kind: python_call_eq
  function: ConfigParser.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "RawConfigParser"

# ---------------------------------------------------------------------------
# __module__ table for exception classes — Error, NoSectionError, NoOptionError
# extra2 covers these in notes; not expressed as a standalone table in any prior spec.
# ---------------------------------------------------------------------------

table configparser_extra5.exception_modules:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: excmod

  columns: [id, function, args, expected]
  rows:
    - [Error,          Error.__module__.__eq__,          ["configparser"], true]
    - [NoSectionError, NoSectionError.__module__.__eq__, ["configparser"], true]
    - [NoOptionError,  NoOptionError.__module__.__eq__,  ["configparser"], true]

# ---------------------------------------------------------------------------
# RawConfigParser.__module__ == 'configparser'
# extra2 notes cover this; adding as an explicit invariant for completeness.
# ---------------------------------------------------------------------------

invariant configparser_extra5.RawConfigParser.module:
  description: "configparser.RawConfigParser.__module__ == 'configparser'"
  category: module_affiliation
  kind: python_call_eq
  function: RawConfigParser.__module__.__eq__
  args: ["configparser"]
  expected: true

# ---------------------------------------------------------------------------
# NoSectionError.__bases__[0].__name__ == 'Error' via __eq__ dotted chain
# extra3 uses __bases__.__getitem__ method pattern; this uses __eq__ for cross-check.
# ---------------------------------------------------------------------------

invariant configparser_extra5.NoOptionError.base_name:
  description: "configparser.NoOptionError.__bases__[0].__name__ == 'Error'"
  category: hierarchy
  kind: python_call_eq
  function: NoOptionError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"
