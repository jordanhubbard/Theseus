spec: io_extra537
version: ">=3.9"
backend: python_module(io)
docs: "Behavioral specs for io module class __qualname__ and __doc__ type identity"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: strict

table io_extra537.qualname_checks:
  description: "Verify __qualname__ for core io classes"
  kind: python_call_eq
  category: identity
  id_prefix: qn
  columns: [id, function, args, expected]
  rows:
    - [qn001, io.IOBase.__qualname__.__eq__, ["IOBase"], true]
    - [qn002, io.RawIOBase.__qualname__.__eq__, ["RawIOBase"], true]
    - [qn003, io.BufferedIOBase.__qualname__.__eq__, ["BufferedIOBase"], true]
    - [qn004, io.TextIOBase.__qualname__.__eq__, ["TextIOBase"], true]
    - [qn005, io.StringIO.__qualname__.__eq__, ["StringIO"], true]
    - [qn006, io.BytesIO.__qualname__.__eq__, ["BytesIO"], true]
    - [qn007, io.FileIO.__qualname__.__eq__, ["FileIO"], true]
    - [qn008, io.BufferedReader.__qualname__.__eq__, ["BufferedReader"], true]
    - [qn009, io.BufferedWriter.__qualname__.__eq__, ["BufferedWriter"], true]
    - [qn010, io.TextIOWrapper.__qualname__.__eq__, ["TextIOWrapper"], true]

table io_extra537.doc_type_checks:
  description: "Verify __doc__ is of type str for key io classes"
  kind: python_call_eq
  category: type_identity
  id_prefix: dt
  columns: [id, function, args, expected]
  rows:
    - [dt001, io.IOBase.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [dt002, io.StringIO.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [dt003, io.BytesIO.__doc__.__class__.__name__.__eq__, ["str"], true]
