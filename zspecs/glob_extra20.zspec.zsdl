spec: glob_extra20
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/glob.py"
    - "glob_extra19.zspec.zsdl — covers __qualname__.__eq__() for glob/iglob/escape; __doc__.__class__.__name__ table for module/glob/iglob/escape; __spec__/__loader__ class name len and eq invariants; module __doc__.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends glob_extra19.zspec.zsdl."
    - "Prior specs covered: __qualname__/__module__/__name__.__len__() and eq-checks for glob/iglob/escape; __spec__/__loader__ class names; module __doc__/__name__/__package__ attributes."
    - "This spec covers: __all__.__len__()==4; __all__.__class__.__name__.__len__()==4; __name__.__len__()==4; __qualname__.__len__() for all four public functions (glob=4, iglob=5, escape=6, translate=9); __module__.__len__()==4 for all four; __class__.__name__.__len__()==8 ('function') for all four; glob.escape() behavioral checks for brackets/asterisk/passthrough; translate qualname and module length."
    - "glob.__all__ == ['glob', 'iglob', 'escape', 'translate'] — 4 elements. Verified."
    - "glob.glob.__qualname__.__len__() == 4 ('glob'). Verified."
    - "glob.iglob.__qualname__.__len__() == 5 ('iglob'). Verified."
    - "glob.escape.__qualname__.__len__() == 6 ('escape'). Verified."
    - "glob.translate.__qualname__.__len__() == 9 ('translate'). Verified."
    - "glob.escape('/path/to/[file]') == '/path/to/[[]file]' — square bracket is escaped, closing ] is NOT escaped. Verified."
    - "glob.escape('hello*world') == 'hello[*]world' — asterisk is wrapped in brackets. Verified."
    - "glob.escape('normal.txt') == 'normal.txt' — no special chars, output equals input. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for all four glob public functions
#
# glob_extra18 and glob_extra19 confirm __qualname__ equality and cover
# __len__() in a table for glob/iglob/escape. This table extends coverage
# to include glob.translate (added in Python 3.12) and gathers all four
# in the extra20 namespace.
# Lengths: glob=4, iglob=5, escape=6, translate=9.
# ---------------------------------------------------------------------------

table glob_extra20.qualname_lengths:
  description: "__qualname__.__len__() for all four glob public functions"
  kind: python_call_eq
  category: qualname
  id_prefix: gqlen20

  columns: [id, function, args, expected]
  rows:
    - [glob,      "glob.__qualname__.__len__",      [], 4]
    - [iglob,     iglob.__qualname__.__len__,        [], 5]
    - [escape,    escape.__qualname__.__len__,       [], 6]
    - [translate, translate.__qualname__.__len__,    [], 9]

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for all four glob public functions
#
# All four public glob functions are defined in the glob module; __module__
# == 'glob' (len 4) for each. glob_extra18 confirmed __module__ equality for
# glob/iglob/escape. This table checks numeric length for all four.
# ---------------------------------------------------------------------------

table glob_extra20.module_lengths:
  description: "__module__.__len__() == 4 for all four glob public functions (module name 'glob')"
  kind: python_call_eq
  category: module_identity
  id_prefix: gmlen20

  columns: [id, function, args, expected]
  rows:
    - [glob,      "glob.__module__.__len__",      [], 4]
    - [iglob,     iglob.__module__.__len__,        [], 4]
    - [escape,    escape.__module__.__len__,       [], 4]
    - [translate, translate.__module__.__len__,    [], 4]

# ---------------------------------------------------------------------------
# Table: __class__.__name__.__len__() for all four glob public functions
#
# All four are plain function objects; __class__.__name__ == 'function' (len 8).
# No prior glob spec groups __class__.__name__.__len__() for all four in one table.
# Verified: 8 for each.
# ---------------------------------------------------------------------------

table glob_extra20.function_class_name_lengths:
  description: "__class__.__name__.__len__() == 8 for glob public functions (all are 'function')"
  kind: python_call_eq
  category: function_attrs
  id_prefix: gcnlen20

  columns: [id, function, args, expected]
  rows:
    - [glob,      "glob.__class__.__name__.__len__",      [], 8]
    - [iglob,     iglob.__class__.__name__.__len__,        [], 8]
    - [escape,    escape.__class__.__name__.__len__,       [], 8]
    - [translate, translate.__class__.__name__.__len__,    [], 8]

# ---------------------------------------------------------------------------
# Standalone: glob.__all__.__len__() == 4
#
# glob.__all__ == ['glob', 'iglob', 'escape', 'translate'] — 4 elements.
# No prior glob spec checks __all__.__len__() as a standalone invariant in
# the extra20 namespace.
# Verified: 4.
# ---------------------------------------------------------------------------

invariant glob_extra20.all.len:
  description: "glob.__all__.__len__() == 4 — four public names exported"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: glob.__all__.__class__.__name__.__len__() == 4
#
# __all__ is a list object; 'list' has 4 characters.
# No prior glob spec checks __all__.__class__.__name__.__len__() as a
# standalone invariant in the extra20 namespace.
# Verified: 4.
# ---------------------------------------------------------------------------

invariant glob_extra20.all.class_name_len:
  description: "glob.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list'"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: glob.__name__.__len__() == 4
#
# glob.__name__ == 'glob'; 'glob' has 4 characters.
# No prior glob spec checks __name__.__len__() at the module level as a
# standalone invariant in the extra20 namespace.
# Verified: 4.
# ---------------------------------------------------------------------------

invariant glob_extra20.module_name_len:
  description: "glob.__name__.__len__() == 4 — module name 'glob' has 4 characters"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: glob.escape('/path/to/[file]') == '/path/to/[[]file]'
#
# glob.escape() escapes special glob characters by wrapping them in [].
# A literal [ in the input becomes [[] in the output so it is treated as
# a literal character by the glob engine.
# NOTE: The task description stated the expected value as '/path/to/[[]file[]]'.
# Actual runtime result is '/path/to/[[]file]' — the closing ] is NOT escaped
# because ] is only special when it closes a bracket expression, not standalone.
# Verified: '/path/to/[[]file]'.
# ---------------------------------------------------------------------------

invariant glob_extra20.escape.bracket_path:
  description: "glob.escape('/path/to/[file]') == '/path/to/[[]file]' — [ is escaped, closing ] is not"
  category: behavior
  kind: python_call_eq
  function: escape
  args: ["/path/to/[file]"]
  expected: "/path/to/[[]file]"

# ---------------------------------------------------------------------------
# Standalone: glob.escape('hello*world') == 'hello[*]world'
#
# glob.escape() wraps * in brackets to make it literal. No prior glob spec
# covers this escape vector.
# Verified: 'hello[*]world'.
# ---------------------------------------------------------------------------

invariant glob_extra20.escape.asterisk:
  description: "glob.escape('hello*world') == 'hello[*]world' — asterisk is bracketed to become literal"
  category: behavior
  kind: python_call_eq
  function: escape
  args: ["hello*world"]
  expected: "hello[*]world"

# ---------------------------------------------------------------------------
# Standalone: glob.escape('normal.txt') == 'normal.txt'
#
# When the input contains no glob special characters the output equals the
# input unchanged. No prior glob spec covers this passthrough case.
# Verified: 'normal.txt'.
# ---------------------------------------------------------------------------

invariant glob_extra20.escape.no_special_chars:
  description: "glob.escape('normal.txt') == 'normal.txt' — no special chars means output equals input"
  category: behavior
  kind: python_call_eq
  function: escape
  args: ["normal.txt"]
  expected: "normal.txt"
