spec: glob_extra20
version: ">=3.9"
backend: python_module(glob)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/glob.py"
    - "glob_extra19.zspec.zsdl — covers __qualname__.__eq__() for glob/iglob/escape; __doc__.__class__.__name__=='str' for module and functions; __spec__/__loader__ class name len (10/16) and eq standalone invariants."
    - "glob_extra18.zspec.zsdl — covers __qualname__/__module__/__name__.__len__() for glob/iglob/escape in tables; module __name__.__len__()==4; __package__.__len__()==0; __name__.__class__.__name__=='str'."
  notes:
    - "This spec extends glob_extra19.zspec.zsdl."
    - "Prior specs covered: __qualname__/__module__/__name__ equality and lengths for glob/iglob/escape; __spec__/__loader__ class name len/eq; __doc__.__class__.__name__=='str'; module __name__/__package__ len; __qualname__.__eq__() for public functions."
    - "This spec covers: glob.__all__.__len__()==4; glob.__all__.__class__.__name__=='list'; glob.__all__.__contains__ membership for all 4 entries; translate function qualname and name lengths; __all__.__class__.__name__.__len__()==4; glob._iglob.__class__.__name__=='function'; glob.__spec__.name.__eq__('glob'); glob.__spec__.name.__len__()==4; glob.__all__[0].__len__()==4 ('glob'); glob.__all__[-1].__len__()==9 ('translate')."
    - "glob.__all__ == ['glob', 'iglob', 'escape', 'translate'] — 4 entries including translate (added Python 3.12+)."
    - "glob.translate.__qualname__ == 'translate' (len 9). Verified."
    - "glob._iglob.__class__.__name__ == 'function' — private helper; verified with Python 3.14."
    - "glob.__spec__.name == 'glob' (len 4). glob.__spec__.name.__eq__('glob') == True. Verified."
    - "glob.__all__.__class__.__name__ == 'list' (len 4 for 'list'). Verified."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __all__ membership checks for all 4 glob public names
#
# glob.__all__ == ['glob', 'iglob', 'escape', 'translate']. No prior glob
# spec covers __all__.__contains__() checks for 'translate'. Extra19 covers
# __qualname__.__eq__() for glob/iglob/escape only. This table groups all 4.
# Verified: all four return True.
# ---------------------------------------------------------------------------

table glob_extra20.all_contains:
  description: "__all__.__contains__() confirms all 4 public names are in glob.__all__"
  kind: python_call_eq
  category: all_membership
  id_prefix: allc20

  columns: [id, function, args, expected]
  rows:
    - [glob,      "__all__.__contains__", ["glob"],      true]
    - [iglob,     "__all__.__contains__", ["iglob"],     true]
    - [escape,    "__all__.__contains__", ["escape"],    true]
    - [translate, "__all__.__contains__", ["translate"], true]

# ---------------------------------------------------------------------------
# Table: translate function name and qualname lengths
#
# glob.translate was added in Python 3.12. No prior glob spec covers
# translate.__name__.__len__() or translate.__qualname__.__len__().
# len('translate') == 9. Verified.
# ---------------------------------------------------------------------------

table glob_extra20.translate_name_qualname_lengths:
  description: "translate.__name__.__len__() and __qualname__.__len__() — both 9 for 'translate'"
  kind: python_call_eq
  category: function_attrs
  id_prefix: tnql20

  columns: [id, function, args, expected]
  rows:
    - [name_len,    "translate.__name__.__len__",    [], 9]
    - [qualname_len, "translate.__qualname__.__len__", [], 9]

# ---------------------------------------------------------------------------
# Table: __spec__.name and __all__.__class__.__name__ string lengths
#
# glob.__spec__.name == 'glob' (len 4). glob.__all__.__class__.__name__ == 'list' (len 4).
# Both happen to be length 4, for different reasons. This table groups the two
# orthogonal length checks. No prior glob spec covers either via a table.
# Verified: both 4.
# ---------------------------------------------------------------------------

table glob_extra20.spec_name_and_all_class_name_lengths:
  description: "glob.__spec__.name.__len__()==4 and glob.__all__.__class__.__name__.__len__()==4"
  kind: python_call_eq
  category: module_identity
  id_prefix: sancnl20

  columns: [id, function, args, expected]
  rows:
    - [spec_name_len,          "__spec__.name.__len__",          [], 4]
    - [all_class_name_len, "__all__.__class__.__name__.__len__", [], 4]

# ---------------------------------------------------------------------------
# Standalone: glob.__all__.__len__() == 4
#
# glob exports exactly 4 public names: glob, iglob, escape, translate.
# No prior glob spec checks __all__.__len__(). Verified: 4.
# ---------------------------------------------------------------------------

invariant glob_extra20.all.len:
  description: "glob.__all__.__len__() == 4 — exactly 4 public names exported: glob, iglob, escape, translate"
  category: all_membership
  kind: python_call_eq
  function: "__all__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: glob.__all__.__class__.__name__ == 'list'
#
# __all__ is a plain Python list. No prior glob spec checks
# __all__.__class__.__name__ via __eq__. Verified: True.
# ---------------------------------------------------------------------------

invariant glob_extra20.all.class_name:
  description: "glob.__all__.__class__.__name__.__eq__('list') == True — __all__ is a list"
  category: all_membership
  kind: python_call_eq
  function: "__all__.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: glob.__spec__.name.__eq__('glob') == True
#
# glob.__spec__.name confirms the module's registered name. No prior glob spec
# checks __spec__.name via __eq__. Extra19 checks __spec__.__class__.__name__.
# Verified: True.
# ---------------------------------------------------------------------------

invariant glob_extra20.spec.name_eq:
  description: "glob.__spec__.name.__eq__('glob') == True — spec registered name is 'glob'"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.name.__eq__"
  args: ["glob"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: glob._iglob.__class__.__name__ == 'function'
#
# glob._iglob is a private helper function. Its __class__.__name__ == 'function'.
# No prior glob spec covers _iglob.__class__.__name__. Verified: 'function'.
# ---------------------------------------------------------------------------

invariant glob_extra20.iglob_private.class_name:
  description: "glob._iglob.__class__.__name__.__eq__('function') == True — private _iglob is a function"
  category: function_attrs
  kind: python_call_eq
  function: "_iglob.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: glob.translate.__qualname__.__eq__('translate') == True
#
# For a top-level function, __qualname__ equals __name__. No prior glob spec
# covers translate.__qualname__.__eq__(). Verified: True.
# ---------------------------------------------------------------------------

invariant glob_extra20.translate.qualname_eq:
  description: "glob.translate.__qualname__.__eq__('translate') == True — top-level function qualname equals name"
  category: function_attrs
  kind: python_call_eq
  function: "translate.__qualname__.__eq__"
  args: ["translate"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: glob.__all__[0].__len__() == 4
#
# glob.__all__[0] == 'glob'. len('glob') == 4. No prior glob spec checks
# __all__[0].__len__(). Verified: 4.
# ---------------------------------------------------------------------------

invariant glob_extra20.all.first_len:
  description: "glob.__all__[0].__len__() == 4 — first exported name is 'glob' (4 characters)"
  category: all_membership
  kind: python_call_eq
  function: "__all__[0].__len__"
  args: []
  expected: 4
