  columns: [id, function, args, expected]
  rows:
    - ["th2791019", "threading.Thread.__dict__.__contains__",          ["__ixor__"], false]
    - ["th2791020", "threading.Lock.__dict__.__contains__",            ["__ixor__"], false]
    - ["th2791021", "threading.Event.__dict__.__contains__",           ["__ixor__"], false]
    - ["th2791022", "threading.Condition.__dict__.__contains__",       ["__ixor__"], false]
    - ["th2791023", "threading.Semaphore.__dict__.__contains__",       ["__ixor__"], false]
