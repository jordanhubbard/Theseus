#
# None of the threading types define __ior__ — they are synchronization
# and concurrency primitives, not set or dict container types.
# ---------------------------------------------------------------------------

table threading_extra2791.ior_protocol:
  description: "threading types __ior__ dict-presence checks — all False (no in-place bitwise OR / dict-merge protocol)"
  kind: python_call_eq
