    - ["th2791013", "threading.Condition.__dict__.__contains__",       ["__ior__"], false]
    - ["th2791014", "threading.Semaphore.__dict__.__contains__",       ["__ior__"], false]
    - ["th2791015", "threading.BoundedSemaphore.__dict__.__contains__", ["__ior__"], false]
    - ["th2791016", "threading.Timer.__dict__.__contains__",           ["__ior__"], false]
    - ["th2791017", "threading.Barrier.__dict__.__contains__",         ["__ior__"], false]
    - ["th2791018", "threading.local.__dict__.__contains__",           ["__ior__"], false]

# ---------------------------------------------------------------------------
# Table 3: __ixor__ dict-presence (in-place bitwise XOR ^=)
#
# None of the threading types define __ixor__ — symmetric-difference has
# no meaning for thread synchronization or thread-local storage objects.
# ---------------------------------------------------------------------------

table threading_extra2791.ixor_protocol:
  description: "threading types __ixor__ dict-presence checks — all False (no in-place bitwise XOR / set-symmetric-difference protocol)"
  kind: python_call_eq
