spec: threading_extra2791
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "any proprietary source"
  notes:
    - "Wave 633 (_extra2791): __iand__, __ior__, and __ixor__ dict-presence checks (in-place bitwise AND &=, OR |=, XOR ^=)."
    - "threading.Thread does NOT define __iand__, __ior__, or __ixor__ — thread lifecycle management has no bitwise mutation semantics."
    - "threading.Lock (alias for _thread.lock) does NOT define these operators — it is a mutex primitive with acquire/release only."
    - "threading.Event does NOT define these operators — it is a flag-based synchronization primitive."
    - "threading.Condition does NOT define these operators — it is a monitor-style synchronization primitive."
    - "threading.Semaphore does NOT define these operators — it is a counting semaphore, not a collection type."
    - "threading.BoundedSemaphore does NOT define these operators — same rationale as Semaphore."
    - "threading.Timer does NOT define these operators — it is a Thread subclass for delayed execution."
    - "threading.Barrier does NOT define these operators — it is a phase synchronization barrier."
    - "threading.local does NOT define these operators — it provides thread-local storage, not set/dict merging."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __iand__ dict-presence (in-place bitwise AND &=)
#
# threading.Thread, Lock, Event, Condition, Semaphore — none define __iand__.
# Synchronization primitives have no set-intersection semantics.
# ---------------------------------------------------------------------------

table threading_extra2791.iand_protocol:
  description: "threading types __iand__ dict-presence checks — all False (no in-place bitwise AND / set-intersection protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2791
  columns: [id, function, args, expected]
  rows:
    - ["th2791001", "threading.Thread.__dict__.__contains__",          ["__iand__"], false]
    - ["th2791002", "threading.Lock.__dict__.__contains__",            ["__iand__"], false]
    - ["th2791003", "threading.Event.__dict__.__contains__",           ["__iand__"], false]
    - ["th2791004", "threading.Condition.__dict__.__contains__",       ["__iand__"], false]
    - ["th2791005", "threading.Semaphore.__dict__.__contains__",       ["__iand__"], false]
    - ["th2791006", "threading.BoundedSemaphore.__dict__.__contains__", ["__iand__"], false]
    - ["th2791007", "threading.Timer.__dict__.__contains__",           ["__iand__"], false]
    - ["th2791008", "threading.Barrier.__dict__.__contains__",         ["__iand__"], false]
    - ["th2791009", "threading.local.__dict__.__contains__",           ["__iand__"], false]

# ---------------------------------------------------------------------------
