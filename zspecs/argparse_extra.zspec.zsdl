spec: argparse_extra
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html — Python argparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/argparse.py"
  notes:
    - "Extends argparse.zspec.zsdl and argparse_formatters.zspec.zsdl with method name, module, and additional class name invariants."
    - "ArgumentParser.__module__ == 'argparse' — defined in the top-level argparse module."
    - "ArgumentParser.parse_args.__name__ == 'parse_args' — verified via class attribute access."
    - "ArgumentParser.add_argument.__name__ == 'add_argument' — defined on _ActionsContainer but accessible via ArgumentParser."
    - "Action.__bases__[0].__name__ == '_AttributeHolder' — Action's direct base is the internal _AttributeHolder mixin."
    - "ArgumentError.__module__ == 'argparse' — exception defined in the argparse module."
    - "HelpFormatter.__module__ == 'argparse' — formatter class defined in the argparse module."
    - "Namespace.__module__ == 'argparse' — Namespace class defined in the argparse module."
    - "All expected values verified by running Python 3.12 argparse module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ArgumentParser — class name and module affiliation
# ---------------------------------------------------------------------------

invariant argparse_extra.argumentparser.name:
  description: "argparse.ArgumentParser.__name__ == 'ArgumentParser'"
  category: class_names
  kind: python_call_eq
  function: ArgumentParser.__name__.__eq__
  args: ["ArgumentParser"]
  expected: true

invariant argparse_extra.argumentparser.module:
  description: "argparse.ArgumentParser.__module__ == 'argparse'"
  category: class_modules
  kind: python_call_eq
  function: ArgumentParser.__module__.__eq__
  args: ["argparse"]
  expected: true

# ---------------------------------------------------------------------------
# ArgumentParser method names — accessed as class attributes
# ---------------------------------------------------------------------------

invariant argparse_extra.argumentparser.parse_args_name:
  description: "ArgumentParser.parse_args.__name__ == 'parse_args'"
  category: methods
  kind: python_call_eq
  function: ArgumentParser.parse_args.__name__.__eq__
  args: ["parse_args"]
  expected: true

invariant argparse_extra.argumentparser.add_argument_name:
  description: "ArgumentParser.add_argument.__name__ == 'add_argument'"
  category: methods
  kind: python_call_eq
  function: ArgumentParser.add_argument.__name__.__eq__
  args: ["add_argument"]
  expected: true

# ---------------------------------------------------------------------------
# Namespace — class name and module
# ---------------------------------------------------------------------------

invariant argparse_extra.namespace.name:
  description: "argparse.Namespace.__name__ == 'Namespace'"
  category: class_names
  kind: python_call_eq
  function: Namespace.__name__.__eq__
  args: ["Namespace"]
  expected: true

invariant argparse_extra.namespace.module:
  description: "argparse.Namespace.__module__ == 'argparse'"
  category: class_modules
  kind: python_call_eq
  function: Namespace.__module__.__eq__
  args: ["argparse"]
  expected: true

# ---------------------------------------------------------------------------
# HelpFormatter — class name and module
# ---------------------------------------------------------------------------

invariant argparse_extra.helpformatter.name:
  description: "argparse.HelpFormatter.__name__ == 'HelpFormatter'"
  category: class_names
  kind: python_call_eq
  function: HelpFormatter.__name__.__eq__
  args: ["HelpFormatter"]
  expected: true

invariant argparse_extra.helpformatter.module:
  description: "argparse.HelpFormatter.__module__ == 'argparse'"
  category: class_modules
  kind: python_call_eq
  function: HelpFormatter.__module__.__eq__
  args: ["argparse"]
  expected: true

# ---------------------------------------------------------------------------
# ArgumentError — class name and module
# ---------------------------------------------------------------------------

invariant argparse_extra.argumenterror.name:
  description: "argparse.ArgumentError.__name__ == 'ArgumentError'"
  category: class_names
  kind: python_call_eq
  function: ArgumentError.__name__.__eq__
  args: ["ArgumentError"]
  expected: true

invariant argparse_extra.argumenterror.module:
  description: "argparse.ArgumentError.__module__ == 'argparse'"
  category: class_modules
  kind: python_call_eq
  function: ArgumentError.__module__.__eq__
  args: ["argparse"]
  expected: true

# ---------------------------------------------------------------------------
# Action — class name, module, and base class
#
# Action.__bases__[0].__name__ == '_AttributeHolder' — Action's direct parent
# is the internal _AttributeHolder mixin, not object.
# ---------------------------------------------------------------------------

invariant argparse_extra.action.name:
  description: "argparse.Action.__name__ == 'Action'"
  category: class_names
  kind: python_call_eq
  function: Action.__name__.__eq__
  args: ["Action"]
  expected: true

invariant argparse_extra.action.module:
  description: "argparse.Action.__module__ == 'argparse'"
  category: class_modules
  kind: python_call_eq
  function: Action.__module__.__eq__
  args: ["argparse"]
  expected: true

invariant argparse_extra.action.base_class:
  description: "argparse.Action.__bases__[0].__name__ == '_AttributeHolder' — Action's direct base is the internal _AttributeHolder mixin"
  category: class_hierarchy
  kind: python_call_eq
  function: Action.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_AttributeHolder"

# ---------------------------------------------------------------------------
# ArgumentDefaultsHelpFormatter — class name
# ---------------------------------------------------------------------------

invariant argparse_extra.argumentdefaultshelpformatter.name:
  description: "argparse.ArgumentDefaultsHelpFormatter.__name__ == 'ArgumentDefaultsHelpFormatter'"
  category: class_names
  kind: python_call_eq
  function: ArgumentDefaultsHelpFormatter.__name__.__eq__
  args: ["ArgumentDefaultsHelpFormatter"]
  expected: true

# ---------------------------------------------------------------------------
# FileType — class name and module
# ---------------------------------------------------------------------------

invariant argparse_extra.filetype.name:
  description: "argparse.FileType.__name__ == 'FileType'"
  category: class_names
  kind: python_call_eq
  function: FileType.__name__.__eq__
  args: ["FileType"]
  expected: true

invariant argparse_extra.filetype.module:
  description: "argparse.FileType.__module__ == 'argparse'"
  category: class_modules
  kind: python_call_eq
  function: FileType.__module__.__eq__
  args: ["argparse"]
  expected: true
