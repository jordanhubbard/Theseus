spec: http_cookiejar
version: ">=3.0"
backend: python_module(http.cookiejar)

docs: https://docs.python.org/3/library/http.cookiejar.html

provenance:
  derived_from:
    - "Python http.cookiejar documentation — https://docs.python.org/3/library/http.cookiejar.html"
    - "Test vectors verified by running Python 3.14.3 http.cookiejar module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/cookiejar.py"
  notes:
    - "http.cookiejar provides classes for managing HTTP cookies, primarily for use with urllib."
    - "CookieJar stores cookies as an iterable collection; a newly created jar contains no cookies."
    - "DefaultCookiePolicy inherits from CookiePolicy and implements the RFC 2965 / Netscape policy rules."
    - "FileCookieJar inherits from CookieJar and adds load/save to persistent storage."
    - "LWPCookieJar and MozillaCookieJar are FileCookieJar subclasses for specific on-disk formats."
    - "LoadError is raised when a FileCookieJar cannot load its backing file; it inherits from OSError."
    - "Cookie is a data class representing a single HTTP cookie with all its attributes."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — core http.cookiejar classes
# ---------------------------------------------------------------------------

table http_cookiejar.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [cookiejar,             CookieJar.__name__.__eq__,             ["CookieJar"],             true]
    - [cookiepolicy,          CookiePolicy.__name__.__eq__,          ["CookiePolicy"],          true]
    - [defaultcookiepolicy,   DefaultCookiePolicy.__name__.__eq__,   ["DefaultCookiePolicy"],   true]
    - [filecookiejar,         FileCookieJar.__name__.__eq__,         ["FileCookieJar"],         true]
    - [lwpcookiejar,          LWPCookieJar.__name__.__eq__,          ["LWPCookieJar"],          true]
    - [mozillacookiejar,      MozillaCookieJar.__name__.__eq__,      ["MozillaCookieJar"],      true]
    - [cookie,                Cookie.__name__.__eq__,                ["Cookie"],                true]
    - [loaderror,             LoadError.__name__.__eq__,             ["LoadError"],             true]

# ---------------------------------------------------------------------------
# Module identity
# ---------------------------------------------------------------------------

invariant http_cookiejar.module.cookiejar:
  description: "CookieJar.__module__ == 'http.cookiejar'"
  category: module
  kind: python_call_eq
  function: CookieJar.__module__.__eq__
  args: ["http.cookiejar"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy checks
# ---------------------------------------------------------------------------

invariant http_cookiejar.hierarchy.defaultcookiepolicy_base:
  description: "DefaultCookiePolicy.__bases__[0].__name__ == 'CookiePolicy'"
  category: hierarchy
  kind: python_call_eq
  function: DefaultCookiePolicy.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "CookiePolicy"

invariant http_cookiejar.hierarchy.filecookiejar_base:
  description: "FileCookieJar.__bases__[0].__name__ == 'CookieJar'"
  category: hierarchy
  kind: python_call_eq
  function: FileCookieJar.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "CookieJar"

invariant http_cookiejar.hierarchy.loaderror_base:
  description: "LoadError.__bases__[0].__name__ == 'OSError'"
  category: hierarchy
  kind: python_call_eq
  function: LoadError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# Behavioral — empty CookieJar has zero cookies
# ---------------------------------------------------------------------------

invariant http_cookiejar.cookiejar.empty_len:
  description: "CookieJar().__len__() == 0 — a newly created CookieJar contains no cookies"
  category: behavior
  kind: python_call_eq
  function: CookieJar
  args: []
  method: __len__
  method_args: []
  expected: 0

