spec: uuid_extra2221
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid.zspec.zsdl"
  notes:
    - "Wave _extra2221: identity/display protocol dict-presence checks for uuid classes."
    - "Covers __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__ presence in UUID and SafeUUID class dicts."
    - "uuid.UUID is a pure Python class that explicitly defines __hash__, __repr__, __str__, __eq__, and comparison operators."
    - "uuid.UUID.__hash__ is present in __dict__ — UUID defines a custom hash based on the integer value."
    - "uuid.UUID.__repr__ is present in __dict__ — UUID defines a custom repr returning UUID('...')."
    - "uuid.UUID.__str__ is present in __dict__ — UUID defines a custom str returning the hyphenated hex string."
    - "uuid.UUID.__doc__ and __module__ are present; __qualname__ and __name__ are NOT in the class __dict__."
    - "uuid.SafeUUID is an IntEnum subclass; it inherits display protocol from IntEnum and does not define its own."
    - "uuid.SafeUUID.__hash__, __repr__, __str__ are NOT in SafeUUID.__dict__ — inherited from IntEnum/int."
    - "uuid.SafeUUID.__doc__ and __module__ are in SafeUUID.__dict__ (set at class-body level)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2221.UUID_identity_protocol:
  description: "uuid.UUID identity/display protocol dict-presence: __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2221

  columns: [id, function, args, expected]
  rows:
    - ["uu2221001", "uuid.UUID.__dict__.__contains__", ["__hash__"],     true]
    - ["uu2221002", "uuid.UUID.__dict__.__contains__", ["__repr__"],     true]
    - ["uu2221003", "uuid.UUID.__dict__.__contains__", ["__str__"],      true]
    - ["uu2221004", "uuid.UUID.__dict__.__contains__", ["__doc__"],      true]
    - ["uu2221005", "uuid.UUID.__dict__.__contains__", ["__module__"],   true]
    - ["uu2221006", "uuid.UUID.__dict__.__contains__", ["__qualname__"], false]
    - ["uu2221007", "uuid.UUID.__dict__.__contains__", ["__name__"],     false]

table uuid_extra2221.SafeUUID_identity_protocol:
  description: "uuid.SafeUUID identity/display protocol dict-presence: __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2221

  columns: [id, function, args, expected]
  rows:
    - ["uu2221008", "uuid.SafeUUID.__dict__.__contains__", ["__hash__"],     false]
    - ["uu2221009", "uuid.SafeUUID.__dict__.__contains__", ["__repr__"],     false]
    - ["uu2221010", "uuid.SafeUUID.__dict__.__contains__", ["__str__"],      false]
    - ["uu2221011", "uuid.SafeUUID.__dict__.__contains__", ["__doc__"],      true]
    - ["uu2221012", "uuid.SafeUUID.__dict__.__contains__", ["__module__"],   true]
    - ["uu2221013", "uuid.SafeUUID.__dict__.__contains__", ["__qualname__"], false]
    - ["uu2221014", "uuid.SafeUUID.__dict__.__contains__", ["__name__"],     false]

table uuid_extra2221.UUID_constructor_protocol:
  description: "uuid.UUID constructor/lifecycle dict-presence: __new__, __init__, __format__, __bytes__, __reduce__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2221

  columns: [id, function, args, expected]
  rows:
    - ["uu2221015", "uuid.UUID.__dict__.__contains__", ["__new__"],    false]
    - ["uu2221016", "uuid.UUID.__dict__.__contains__", ["__init__"],   true]
    - ["uu2221017", "uuid.UUID.__dict__.__contains__", ["__format__"], false]
    - ["uu2221018", "uuid.UUID.__dict__.__contains__", ["__bytes__"],  false]
    - ["uu2221019", "uuid.UUID.__dict__.__contains__", ["__reduce__"], false]

table uuid_extra2221.SafeUUID_constructor_protocol:
  description: "uuid.SafeUUID constructor/lifecycle dict-presence: __new__, __init__, __format__, __bytes__, __reduce__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2221

  columns: [id, function, args, expected]
  rows:
    - ["uu2221020", "uuid.SafeUUID.__dict__.__contains__", ["__new__"],    true]
    - ["uu2221021", "uuid.SafeUUID.__dict__.__contains__", ["__init__"],   false]
    - ["uu2221022", "uuid.SafeUUID.__dict__.__contains__", ["__format__"], false]
    - ["uu2221023", "uuid.SafeUUID.__dict__.__contains__", ["__bytes__"],  false]
    - ["uu2221024", "uuid.SafeUUID.__dict__.__contains__", ["__reduce__"], false]

table uuid_extra2221.cross_checks:
  description: "uuid cross-checks: UUID defines display protocol but SafeUUID inherits it"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2221

  columns: [id, function, args, expected]
  rows:
    - ["uu2221025", "uuid.UUID.__dict__.__contains__",     ["__hash__"], true]
    - ["uu2221026", "uuid.SafeUUID.__dict__.__contains__", ["__hash__"], false]
    - ["uu2221027", "uuid.UUID.__dict__.__contains__",     ["__repr__"], true]
    - ["uu2221028", "uuid.SafeUUID.__dict__.__contains__", ["__repr__"], false]
    - ["uu2221029", "uuid.UUID.__dict__.__contains__",     ["__str__"],  true]
    - ["uu2221030", "uuid.SafeUUID.__dict__.__contains__", ["__str__"],  false]
