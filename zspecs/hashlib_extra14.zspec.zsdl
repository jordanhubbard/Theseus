spec: hashlib_extra14
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha3/sha3module.c"
  notes:
    - "This spec extends hashlib through hashlib_extra13; it does NOT duplicate invariants present in those files."
    - "hashlib_extra13 covers: sha3_256/__name__/__qualname__/__module__; shake_256/__name__/__qualname__/__module__; sha512/__name__, sha384/__name__, sha224/__name__; shake_256.digest_size==0; new('sha3_256').name; new('sha384').digest_size==48; new('sha224').digest_size==28; algorithms_guaranteed contains 'sha3_224'."
    - "NOT yet covered in any prior hashlib spec: algorithms_guaranteed.__class__.__name__ == 'set'."
    - "NOT yet covered: algorithms_available.__class__.__name__ == 'set'."
    - "NOT yet covered: new('md5').block_size == 64 as a standalone python_call_eq invariant."
    - "NOT yet covered: new('sha1').block_size == 64 as a standalone python_call_eq invariant."
    - "NOT yet covered: new('sha512').block_size == 128 as a standalone python_call_eq invariant."
    - "NOT yet covered: new('sha3_256').block_size == 136 as a standalone python_call_eq invariant."
    - "NOT yet covered: sha256().copy().name == 'sha256' — copy() preserves the algorithm name."
    - "NOT yet covered: sha256().copy().digest_size == 32 — copy() preserves digest_size."
    - "NOT yet covered: sha256().copy().block_size == 64 — copy() preserves block_size."
    - "NOT yet covered: sha256(b'abc').hexdigest() known good value as python_call_eq invariant in extra14 namespace."
    - "NOT yet covered: md5(b'abc').hexdigest() known good value in extra14 namespace."
    - "NOT yet covered: sha1(b'abc').hexdigest() as python_call_eq invariant in extra14 namespace (prior specs only verify length, not value)."
    - "new('sha256').__class__.__name__ == 'HASH' — not yet covered as standalone invariant."
    - "hashlib.algorithms_guaranteed is of type set (not frozenset) — verified Python 3.12 macOS."
    - "hashlib.new('sha256').copy().name == 'sha256' — the copy preserves all attributes."
    - "hashlib.sha256(b'abc').hexdigest() == 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad' — FIPS 180-4 SHA-256 known vector."
    - "hashlib.md5(b'abc').hexdigest() == '900150983cd24fb0d6963f7d28e17f72' — RFC 1321 MD5 known vector."
    - "hashlib.sha1(b'abc').hexdigest() == 'a9993e364706816aba3e25717850c26c9cd0d89d' — FIPS 180-4 SHA-1 known vector."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# algorithms_guaranteed and algorithms_available type checks
#
# No prior hashlib spec verifies that these module-level attributes are of
# type 'set'. The set membership checks (.__contains__) have been tested, but
# the container class itself has not been verified.
# ---------------------------------------------------------------------------

invariant hashlib_extra14.algorithms_guaranteed.class_name:
  description: "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — it is a plain set, not frozenset"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra14.algorithms_available.class_name:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set' — it is a plain set, not frozenset"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# new() factory — block_size attribute for several algorithms
#
# Prior specs (hashlib_extra13, etc.) cover new() digest_size for many algs.
# block_size via the new() factory is covered for sha256 (hashlib_extra3)
# and sha3_256 (hashlib_extra3/6). NOT yet covered for md5, sha1, sha512.
# ---------------------------------------------------------------------------

table hashlib_extra14.new_block_sizes:
  kind: python_call_eq
  category: new_factory
  id_prefix: block

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [md5,     new, ["md5"],     block_size.__eq__, [64],  true]
    - [sha1,    new, ["sha1"],    block_size.__eq__, [64],  true]
    - [sha512,  new, ["sha512"],  block_size.__eq__, [128], true]
    - [sha3_256, new, ["sha3_256"], block_size.__eq__, [136], true]

# ---------------------------------------------------------------------------
# new() return type — __class__.__name__ == 'HASH'
#
# hashlib.sha256().__class__.__name__ and hashlib.sha256().__class__.__name__
# have been verified via method_chain in prior specs. The new() factory's
# return type has not been explicitly checked as a standalone invariant.
# ---------------------------------------------------------------------------

invariant hashlib_extra14.new.sha256.class_name:
  description: "hashlib.new('sha256').__class__.__name__ == 'HASH' — new() returns a HASH object"
  category: new_factory
  kind: python_call_eq
  function: new
  args: ["sha256"]
  method: __class__.__name__.__eq__
  method_args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# sha256().copy() — preserves name, digest_size, block_size
#
# The copy() method duplicates a hash object mid-stream. No prior hashlib spec
# verifies that copy() preserves name, digest_size, or block_size.
# ---------------------------------------------------------------------------

invariant hashlib_extra14.sha256.copy.name:
  description: "hashlib.sha256().copy().name == 'sha256' — copy() preserves the algorithm name"
  category: copy
  kind: python_call_eq
  function: sha256
  args: []
  method: copy().name.__eq__
  method_args: ["sha256"]
  expected: true

invariant hashlib_extra14.sha256.copy.digest_size:
  description: "hashlib.sha256().copy().digest_size == 32 — copy() preserves digest_size"
  category: copy
  kind: python_call_eq
  function: sha256
  args: []
  method: copy().digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra14.sha256.copy.block_size:
  description: "hashlib.sha256().copy().block_size == 64 — copy() preserves block_size"
  category: copy
  kind: python_call_eq
  function: sha256
  args: []
  method: copy().block_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# Known-good hexdigest values — sha256, md5, sha1 for input b'abc'
#
# Prior specs verify sha256/md5/sha1 hexdigest via the sha256 table in
# hashlib.zspec.zsdl and update-based checks. Here we anchor the known-good
# values as standalone python_call_eq invariants from the extra14 namespace.
# hashlib_extra12 covers sha256(b'').hexdigest length, NOT value from b'abc'.
# hashlib_extra1/2 cover sha256(b'abc') hexdigest value but via the main spec.
# ---------------------------------------------------------------------------

invariant hashlib_extra14.sha256.hexdigest_abc:
  description: "hashlib.sha256(b'abc').hexdigest() == 'ba7816bf...' — FIPS 180-4 SHA-256 known vector"
  category: known_vector
  kind: python_call_eq
  function: sha256
  args: [!hex 616263]
  method: hexdigest
  method_args: []
  expected: "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"

invariant hashlib_extra14.md5.hexdigest_abc:
  description: "hashlib.md5(b'abc').hexdigest() == '900150983cd24fb0d6963f7d28e17f72' — RFC 1321 MD5 known vector"
  category: known_vector
  kind: python_call_eq
  function: md5
  args: [!hex 616263]
  method: hexdigest
  method_args: []
  expected: "900150983cd24fb0d6963f7d28e17f72"

invariant hashlib_extra14.sha1.hexdigest_abc:
  description: "hashlib.sha1(b'abc').hexdigest() == 'a9993e364706816aba3e25717850c26c9cd0d89d' — FIPS 180-4 SHA-1 known vector"
  category: known_vector
  kind: python_call_eq
  function: sha1
  args: [!hex 616263]
  method: hexdigest
  method_args: []
  expected: "a9993e364706816aba3e25717850c26c9cd0d89d"
