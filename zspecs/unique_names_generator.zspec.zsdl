spec: unique_names_generator
version: ">=4.0.0"
backend: node(unique-names-generator)

docs: https://github.com/andreasonny83/unique-names-generator#readme

provenance:
  derived_from:
    - "unique-names-generator README — https://github.com/andreasonny83/unique-names-generator#readme"
    - "Test vectors verified with unique-names-generator via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "unique-names-generator source"
  notes:
    - "Generate unique random names from curated word lists — used for ephemeral resource naming."
    - "Install: npm install unique-names-generator"
    - "v4 CJS; named exports uniqueNamesGenerator + word lists (adjectives, animals, colors, countries, languages, names, starWars) + NumberDictionary."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factories; uniqueNamesGenerator throws on missing dictionaries."
  stderr: "null"
  stickiness: "N/A — random output each call."
  codes: {}

invariant unique_names_generator.adjectives_count:
  description: "adjectives word list has 1202 entries"
  category: vocabulary
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "adjectives.length"}
  expected: 1202

invariant unique_names_generator.animals_count:
  description: "animals word list has 355 entries"
  category: vocabulary
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "animals.length"}
  expected: 355

invariant unique_names_generator.colors_count:
  description: "colors word list has 52 entries"
  category: vocabulary
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "colors.length"}
  expected: 52

invariant unique_names_generator.countries_count:
  description: "countries word list has 254 entries"
  category: vocabulary
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "countries.length"}
  expected: 254

invariant unique_names_generator.starWars_count:
  description: "starWars word list has 82 entries"
  category: vocabulary
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "starWars.length"}
  expected: 82

invariant unique_names_generator.has_uniqueNamesGenerator:
  description: "uniqueNamesGenerator is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "uniqueNamesGenerator.constructor.name"}
  expected: "Function"

invariant unique_names_generator.has_NumberDictionary:
  description: "NumberDictionary is exported (it's a class with a generate() static — typeof Function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "NumberDictionary.constructor.name"}
  expected: "Function"
