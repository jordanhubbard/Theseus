spec: decimal_extra143
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal module rounding mode string constants (ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR, ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN, ROUND_05UP) — all are plain str, not enums. Also covers module-level attrs __spec__.name, __doc__, __name__, HAVE_THREADS, HAVE_CONTEXTVAR, and DefaultContext.prec / BasicContext.prec."
    - "Unlike re.RegexFlag (enum, int values) and io.SEEK_SET (plain int), decimal rounding modes are plain str constants named after themselves: decimal.ROUND_UP == 'ROUND_UP'."
    - "Rounding constant lengths: ROUND_UP=8 (shortest), ROUND_DOWN/ROUND_05UP=10, ROUND_FLOOR=11, ROUND_CEILING/ROUND_HALF_UP=13, ROUND_HALF_DOWN/ROUND_HALF_EVEN=15 (longest)."
    - "decimal has no __all__ attribute — confirmed with hasattr(decimal, '__all__') == False."
    - "decimal.__spec__.name == 'decimal' (len=7); decimal.__doc__.__len__() == 2546; decimal.__name__ == 'decimal' (len=7)."
    - "decimal.HAVE_THREADS == True (bool); decimal.HAVE_CONTEXTVAR == True (bool)."
    - "decimal.DefaultContext.prec == 28 (the default precision for the default context); decimal.BasicContext.prec == 9."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal rounding mode string constants — values and class
# All 8 rounding modes are plain str objects whose value is their own name.
# ROUND_UP=8 (shortest), ROUND_HALF_DOWN/ROUND_HALF_EVEN=15 (longest).
# ---------------------------------------------------------------------------

table decimal_extra143.rounding_constants_values:
  description: "decimal rounding constants: all are plain str equal to their own name; ROUND_UP=8, ROUND_DOWN/ROUND_05UP=10, ROUND_FLOOR=11, ROUND_CEILING/ROUND_HALF_UP=13, ROUND_HALF_DOWN/ROUND_HALF_EVEN=15"
  kind: python_call_eq
  category: constants
  id_prefix: decround143

  columns: [id, function, args, expected, description]
  rows:
    - [rup_eq,    ROUND_UP.__eq__,         ["ROUND_UP"],         true, "decimal.ROUND_UP == 'ROUND_UP' (len=8; rounds away from zero; 1.5 rounds to 2, -1.5 rounds to -2)"]
    - [rup_len,   ROUND_UP.__len__,        [],                   8,    "decimal.ROUND_UP.__len__() == 8 ('ROUND_UP' has 8 characters; the shortest rounding mode name)"]
    - [rdown_eq,  ROUND_DOWN.__eq__,       ["ROUND_DOWN"],       true, "decimal.ROUND_DOWN == 'ROUND_DOWN' (len=10; rounds toward zero; truncates towards zero)"]
    - [rdown_len, ROUND_DOWN.__len__,      [],                   10,   "decimal.ROUND_DOWN.__len__() == 10 ('ROUND_DOWN' has 10 characters; tied with ROUND_05UP)"]
    - [rceil_eq,  ROUND_CEILING.__eq__,    ["ROUND_CEILING"],    true, "decimal.ROUND_CEILING == 'ROUND_CEILING' (len=13; rounds toward positive infinity; ceil in math terms)"]
    - [rceil_len, ROUND_CEILING.__len__,   [],                   13,   "decimal.ROUND_CEILING.__len__() == 13 ('ROUND_CEILING' has 13 characters; tied with ROUND_HALF_UP)"]
    - [rflr_eq,   ROUND_FLOOR.__eq__,      ["ROUND_FLOOR"],      true, "decimal.ROUND_FLOOR == 'ROUND_FLOOR' (len=11; rounds toward negative infinity; floor in math terms)"]
    - [rflr_len,  ROUND_FLOOR.__len__,     [],                   11,   "decimal.ROUND_FLOOR.__len__() == 11 ('ROUND_FLOOR' has 11 characters)"]
    - [rhup_eq,   ROUND_HALF_UP.__eq__,    ["ROUND_HALF_UP"],    true, "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' (len=13; rounds to nearest with ties going away from zero; the common school rounding)"]
    - [rhup_len,  ROUND_HALF_UP.__len__,   [],                   13,   "decimal.ROUND_HALF_UP.__len__() == 13 ('ROUND_HALF_UP' has 13 characters; tied with ROUND_CEILING)"]
    - [rhdw_eq,   ROUND_HALF_DOWN.__eq__,  ["ROUND_HALF_DOWN"],  true, "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN' (len=15; rounds to nearest with ties going toward zero)"]
    - [rhdw_len,  ROUND_HALF_DOWN.__len__, [],                   15,   "decimal.ROUND_HALF_DOWN.__len__() == 15 ('ROUND_HALF_DOWN' has 15 characters; tied with ROUND_HALF_EVEN for the longest rounding mode name)"]
    - [rhev_eq,   ROUND_HALF_EVEN.__eq__,  ["ROUND_HALF_EVEN"],  true, "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' (len=15; banker's rounding — ties go to the nearest even digit; the default rounding mode for new Contexts)"]
    - [rhev_len,  ROUND_HALF_EVEN.__len__, [],                   15,   "decimal.ROUND_HALF_EVEN.__len__() == 15 ('ROUND_HALF_EVEN' has 15 characters; tied with ROUND_HALF_DOWN for the longest)"]
    - [r05_eq,    ROUND_05UP.__eq__,       ["ROUND_05UP"],       true, "decimal.ROUND_05UP == 'ROUND_05UP' (len=10; rounds toward zero unless last digit would be 0 or 5, then away from zero; an unusual IEEE 754 mode)"]
    - [r05_len,   ROUND_05UP.__len__,      [],                   10,   "decimal.ROUND_05UP.__len__() == 10 ('ROUND_05UP' has 10 characters; tied with ROUND_DOWN)"]

# ---------------------------------------------------------------------------
# decimal rounding mode constants class identity
# All 8 are plain str, not enum members or any other type.
# ROUND_HALF_EVEN is the default rounding in the DefaultContext.
# ---------------------------------------------------------------------------

table decimal_extra143.rounding_constants_class:
  description: "decimal rounding constants are all plain str: ROUND_UP, ROUND_CEILING, ROUND_HALF_EVEN each have __class__.__name__=='str'"
  kind: python_call_eq
  category: constants
  id_prefix: decround143

  columns: [id, function, args, expected, description]
  rows:
    - [rup_cls,   ROUND_UP.__class__.__name__.__eq__,         ["str"], true, "decimal.ROUND_UP.__class__.__name__ == 'str' (unlike re.RegexFlag which uses IntFlag enum members, decimal rounding modes are plain str constants)"]
    - [rceil_cls, ROUND_CEILING.__class__.__name__.__eq__,    ["str"], true, "decimal.ROUND_CEILING.__class__.__name__ == 'str'"]
    - [rflr_cls,  ROUND_FLOOR.__class__.__name__.__eq__,      ["str"], true, "decimal.ROUND_FLOOR.__class__.__name__ == 'str'"]
    - [rhev_cls,  ROUND_HALF_EVEN.__class__.__name__.__eq__,  ["str"], true, "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' (the default rounding mode is a str, not an enum; Context instances compare rounding with string equality)"]
    - [r05_cls,   ROUND_05UP.__class__.__name__.__eq__,       ["str"], true, "decimal.ROUND_05UP.__class__.__name__ == 'str'"]

# ---------------------------------------------------------------------------
# decimal module-level scalar attributes
# __spec__.name == 'decimal' (len=7); __doc__ len == 2546; __name__ == 'decimal'.
# HAVE_THREADS == True (bool); HAVE_CONTEXTVAR == True (bool).
# DefaultContext.prec == 28; BasicContext.prec == 9.
# ---------------------------------------------------------------------------

table decimal_extra143.module_level_attrs:
  description: "decimal module-level attrs: __spec__.name=='decimal' (7), __doc__ len=2546, __name__=='decimal' (7), HAVE_THREADS/HAVE_CONTEXTVAR are True bool, DefaultContext.prec==28, BasicContext.prec==9"
  kind: python_call_eq
  category: identity
  id_prefix: decround143

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,    __spec__.name.__eq__,                  ["decimal"], true, "decimal.__spec__.name == 'decimal' (the module spec name; len=7)"]
    - [spec_name_len,   __spec__.name.__len__,                 [],          7,    "decimal.__spec__.name.__len__() == 7 ('decimal' has 7 characters; same length as decimal.Decimal.__name__ and decimal.Context.__name__ from decimal_extra141/142)"]
    - [doc_len_eq,      __doc__.__len__,                       [],          2546, "decimal.__doc__.__len__() == 2546 (the decimal module docstring is 2546 characters long; a comprehensive reference covering Context, rounding, and arithmetic)"]
    - [name_eq,         __name__.__eq__,                       ["decimal"], true, "decimal.__name__ == 'decimal' (the module name attribute; same value as __spec__.name)"]
    - [name_len,        __name__.__len__,                      [],          7,    "decimal.__name__.__len__() == 7 ('decimal' has 7 characters)"]
    - [havethreads_eq,  HAVE_THREADS.__eq__,                   [true],      true, "decimal.HAVE_THREADS == True (bool; indicates this build of the decimal module supports thread-local contexts)"]
    - [havectxvar_eq,   HAVE_CONTEXTVAR.__eq__,                [true],      true, "decimal.HAVE_CONTEXTVAR == True (bool; indicates the decimal module uses contextvars for thread-local context storage)"]
    - [defctx_prec,     DefaultContext.prec.__eq__,            [28],        true, "decimal.DefaultContext.prec == 28 (the default arithmetic precision in digits; IEEE 754-2008 recommends 34 for decimal128, but Python uses 28 as the default)"]
    - [basicctx_prec,   BasicContext.prec.__eq__,              [9],         true, "decimal.BasicContext.prec == 9 (the BasicContext uses 9 digits of precision; it mimics the IEEE 754 standard decimal context more strictly than DefaultContext)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra143.ROUND_UP.eq_self:
  description: "decimal.ROUND_UP == 'ROUND_UP' (len=8) — decimal rounding mode constants are plain str objects whose value is identical to their attribute name; this design (used since Python 2.4) predates enums; the str value is passed directly to context methods like context.quantize(x, rounding=decimal.ROUND_UP)"
  category: constants
  kind: python_call_eq
  function: ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra143.ROUND_HALF_EVEN.eq_self:
  description: "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' (len=15; tied with ROUND_HALF_DOWN for the longest rounding mode name) — ROUND_HALF_EVEN is the default rounding mode for new decimal.Context objects; it is banker's rounding: 0.5 rounds to 0, 1.5 rounds to 2, 2.5 rounds to 2, etc."
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra143.ROUND_HALF_DOWN.len_15:
  description: "decimal.ROUND_HALF_DOWN.__len__() == 15 ('ROUND_HALF_DOWN' has 15 characters; tied with ROUND_HALF_EVEN for the longest rounding mode constant name; both have 4-letter second parts: 'DOWN' and 'EVEN' after the 'ROUND_HALF_' prefix (11 chars))"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_DOWN.__len__
  args: []
  expected: 15

invariant decimal_extra143.ROUND_UP.class_is_str:
  description: "decimal.ROUND_UP.__class__.__name__ == 'str' — decimal rounding modes are plain str constants, unlike re.RegexFlag members which are IntFlag enum members (int subclass); the choice of str for rounding modes is a historical design decision predating Python's enum module (added in Python 3.4)"
  category: constants
  kind: python_call_eq
  function: ROUND_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra143.ROUND_CEILING.len_13:
  description: "decimal.ROUND_CEILING.__len__() == 13 ('ROUND_CEILING' has 13 characters; tied with ROUND_HALF_UP at 13; both have 7-character second components: 'CEILING' and 'HALF_UP' after 'ROUND_' (6 chars))"
  category: constants
  kind: python_call_eq
  function: ROUND_CEILING.__len__
  args: []
  expected: 13

invariant decimal_extra143.spec_name_eq_decimal:
  description: "decimal.__spec__.name == 'decimal' (len=7) — the decimal module spec name has the same length (7) as decimal.Decimal.__name__ ('Decimal', 7) and decimal.Context.__name__ ('Context', 7); all three are 7-character strings — the module name and its two main class names share this length"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra143.DefaultContext.prec_28:
  description: "decimal.DefaultContext.prec == 28 — the DefaultContext provides 28 significant digits of precision; this is enough to represent any IEEE 754 double-precision float exactly (which needs at most 17 significant decimal digits); Python chose 28 as a practical default exceeding IEEE 754 decimal64's 16 digits"
  category: identity
  kind: python_call_eq
  function: DefaultContext.prec.__eq__
  args: [28]
  expected: true

invariant decimal_extra143.doc.len_2546:
  description: "decimal.__doc__.__len__() == 2546 — the decimal module-level docstring is 2546 characters long; it is longer than io.__doc__ (1473 from io_extra153) and pathlib.__doc__ (192 from pathlib_extra153) but shorter than re.__doc__ (6152 from re_extra149)"
  category: identity
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 2546
