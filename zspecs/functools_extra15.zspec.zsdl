spec: functools_extra15
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra14.zspec.zsdl."
    - "functools_extra14 covers: __name__.__len__() for cmp_to_key/total_ordering/lru_cache/singledispatch/singledispatchmethod; __qualname__.__len__() for cmp_to_key/total_ordering/singledispatch/singledispatchmethod."
    - "functools_extra13 covers: __name__.__len__() for reduce/partial/wraps/cached_property; partial/__bases__[0].__name__; cached_property/__bases__[0].__name__; reduce/__qualname__.__len__(); partial/__qualname__.__len__(); wraps/__qualname__; cached_property/__qualname__."
    - "functools_extra12 covers: __module__ for wraps/total_ordering/singledispatch/cache/lru_cache/singledispatchmethod/cached_property/partialmethod; partial/__module__; reduce/__module__; cmp_to_key/__module__."
    - "functools_extra9 covers: partial/__bases__.__len__(); cached_property/__bases__.__len__(); partialmethod/__bases__.__len__(); partialmethod/__bases__.__getitem__(0).__name__; WRAPPER_ASSIGNMENTS/__len__."
    - "functools_extra8 covers: partial/__qualname__.__eq__; partial/__qualname__.__len__."
    - "NOT yet covered: functools.partialmethod.__name__ == 'partialmethod' (standalone __eq__ invariant)."
    - "NOT yet covered: functools.partialmethod.__qualname__ == 'partialmethod' (standalone __eq__ invariant)."
    - "NOT yet covered: functools.partialmethod.__name__.__len__() == 13 — 'partialmethod' has 13 characters."
    - "NOT yet covered: functools.partialmethod.__qualname__.__len__() == 13 — qualname length."
    - "NOT yet covered: functools.partialmethod.__bases__[0].__name__ == 'object' (extra9 checks __bases__.__len__() and __bases__.__getitem__ with method, but not name directly)."
    - "NOT yet covered: functools.total_ordering.__qualname__ == 'total_ordering' (standalone __eq__; extra14 covers __len__() only)."
    - "NOT yet covered: functools.WRAPPER_ASSIGNMENTS[5] == '__type_params__' (positive index 5; [-1] is covered in extra10, but not [5] directly)."
    - "NOT yet covered: functools.WRAPPER_UPDATES.__contains__('__dict__') == True (standalone boolean invariant)."
    - "functools.partialmethod.__name__ == 'partialmethod' — 13 characters."
    - "functools.partialmethod.__qualname__ == 'partialmethod' — top-level class, qualname equals name."
    - "functools.partialmethod.__name__.__len__() == 13."
    - "functools.partialmethod.__qualname__.__len__() == 13."
    - "functools.total_ordering.__qualname__ == 'total_ordering' — standalone __eq__ invariant."
    - "functools.WRAPPER_ASSIGNMENTS[5] == '__type_params__' — by positive index 5 (not -1)."
    - "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is in WRAPPER_UPDATES."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partialmethod — __name__ and __qualname__ standalone invariants
#
# functools_extra12 covers partialmethod.__module__ == 'functools'.
# functools_extra9 covers partialmethod.__bases__.__len__() == 1 and
# partialmethod.__bases__.__getitem__(0) with method: __name__ == 'object'.
# No prior spec checks partialmethod.__name__ or partialmethod.__qualname__
# as standalone __eq__ invariants.
# ---------------------------------------------------------------------------

invariant functools_extra15.partialmethod.name:
  description: "functools.partialmethod.__name__ == 'partialmethod' — top-level class name"
  category: class_names
  kind: python_call_eq
  function: partialmethod.__name__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra15.partialmethod.qualname:
  description: "functools.partialmethod.__qualname__ == 'partialmethod' — top-level class, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: partialmethod.__qualname__.__eq__
  args: ["partialmethod"]
  expected: true

# ---------------------------------------------------------------------------
# partialmethod — __name__ and __qualname__ string lengths
#
# No prior spec checks __name__.__len__() or __qualname__.__len__() for
# partialmethod. 'partialmethod' has 13 characters.
# ---------------------------------------------------------------------------

invariant functools_extra15.partialmethod.name_len:
  description: "len(functools.partialmethod.__name__) == 13 — 'partialmethod' has 13 characters"
  category: class_names
  kind: python_call_eq
  function: partialmethod.__name__.__len__
  args: []
  expected: 13

invariant functools_extra15.partialmethod.qualname_len:
  description: "len(functools.partialmethod.__qualname__) == 13 — 'partialmethod' has 13 characters"
  category: qualnames
  kind: python_call_eq
  function: partialmethod.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# total_ordering __qualname__ — standalone __eq__ invariant
#
# functools_extra14 covers total_ordering.__qualname__.__len__() == 14.
# functools_extra8 records total_ordering.__qualname__ in a table row.
# No prior spec verifies total_ordering.__qualname__ as a standalone __eq__
# boolean invariant.
# ---------------------------------------------------------------------------

invariant functools_extra15.total_ordering.qualname:
  description: "functools.total_ordering.__qualname__ == 'total_ordering' — standalone __eq__ invariant"
  category: qualnames
  kind: python_call_eq
  function: total_ordering.__qualname__.__eq__
  args: ["total_ordering"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS[5] — positive-index access
#
# functools_extra10 covers WRAPPER_ASSIGNMENTS[-1] == '__type_params__'.
# functools_extra9 covers WRAPPER_ASSIGNMENTS[0] via __getitem__.
# No prior spec accesses WRAPPER_ASSIGNMENTS by positive index 5 directly.
# Index 5 and -1 are equivalent in a 6-element tuple, but these are distinct
# expression axes: the negative-index form tests wraparound semantics,
# the positive-index form tests direct forward access.
# ---------------------------------------------------------------------------

invariant functools_extra15.WRAPPER_ASSIGNMENTS.index5:
  description: "functools.WRAPPER_ASSIGNMENTS[5] == '__type_params__' — last element by positive index"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__getitem__
  args: [5]
  method: __eq__
  method_args: ["__type_params__"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES __contains__ — membership test
#
# functools_extra9 covers WRAPPER_UPDATES.__len__() == 1 and
# WRAPPER_UPDATES.__getitem__(0) == '__dict__'.
# No prior spec calls WRAPPER_UPDATES.__contains__ to verify '__dict__' is
# a member. This is a distinct behavioral axis from index access.
# ---------------------------------------------------------------------------

invariant functools_extra15.WRAPPER_UPDATES.contains_dict:
  description: "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is in WRAPPER_UPDATES"
  category: constants
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true
