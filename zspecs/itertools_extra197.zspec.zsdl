spec: itertools_extra197
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.pairwise (new in Python 3.10) and itertools.batched (new in Python 3.12) identity — __name__, __module__, __qualname__, __bases__[0].__name__."
    - "itertools.pairwise.__name__ == 'pairwise' — pairwise is a C extension type in itertoolsmodule.c; added in Python 3.10. Verified with Python 3.14.3."
    - "itertools.pairwise.__module__ == 'itertools' — pairwise's __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.pairwise.__qualname__ == 'pairwise' — pairwise is defined at module scope; __qualname__ is the simple name. Verified with Python 3.14.3."
    - "itertools.pairwise.__bases__[0].__name__ == 'object' — pairwise inherits directly from object with no intermediary. Verified with Python 3.14.3."
    - "itertools.batched.__name__ == 'batched' — batched is a C extension type in itertoolsmodule.c; added in Python 3.12. Verified with Python 3.14.3."
    - "itertools.batched.__module__ == 'itertools' — batched's __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.batched.__qualname__ == 'batched' — batched is defined at module scope; __qualname__ is the simple name. Verified with Python 3.14.3."
    - "itertools.batched.__bases__[0].__name__ == 'object' — batched inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.pairwise identity — __name__, __module__, __qualname__
#
# itertools.pairwise.__name__.__eq__('pairwise') == True
# itertools.pairwise.__module__.__eq__('itertools') == True
# itertools.pairwise.__qualname__.__eq__('pairwise') == True
#
# pairwise was added in Python 3.10; it is a C extension type defined in
# Modules/itertoolsmodule.c. It returns successive overlapping pairs from
# its input iterable. New to extra197.
# ---------------------------------------------------------------------------

table itertools_extra197.pairwise_identity:
  description: "itertools.pairwise __name__, __module__, __qualname__; C extension type added in Python 3.10; new to extra197"
  kind: python_call_eq
  category: string_identity
  id_prefix: iterpairwise197

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_name_eq_pairwise,
       pairwise.__name__.__eq__,
       ["pairwise"],
       true,
       "itertools.pairwise.__name__.__eq__('pairwise') == True — pairwise is a C extension type in Modules/itertoolsmodule.c added in Python 3.10; __name__ is 'pairwise'; str.__eq__('pairwise') returns True; new to extra197"]
    - [pairwise_module_eq_itertools,
       pairwise.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.pairwise.__module__.__eq__('itertools') == True — pairwise is a C extension type whose __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra197"]
    - [pairwise_qualname_eq_pairwise,
       pairwise.__qualname__.__eq__,
       ["pairwise"],
       true,
       "itertools.pairwise.__qualname__.__eq__('pairwise') == True — pairwise is defined at module scope; __qualname__ is the simple type name 'pairwise' with no enclosing scope prefix; str.__eq__('pairwise') returns True; new to extra197"]

# ---------------------------------------------------------------------------
# Table 2: itertools.batched identity — __name__, __module__, __qualname__
#
# itertools.batched.__name__.__eq__('batched') == True
# itertools.batched.__module__.__eq__('itertools') == True
# itertools.batched.__qualname__.__eq__('batched') == True
#
# batched was added in Python 3.12; it is a C extension type defined in
# Modules/itertoolsmodule.c. It yields non-overlapping batches of a fixed
# size from its input iterable. New to extra197.
# ---------------------------------------------------------------------------

table itertools_extra197.batched_identity:
  description: "itertools.batched __name__, __module__, __qualname__; C extension type added in Python 3.12; new to extra197"
  kind: python_call_eq
  category: string_identity
  id_prefix: iterpairwise197

  columns: [id, function, args, expected, description]
  rows:
    - [batched_name_eq_batched,
       batched.__name__.__eq__,
       ["batched"],
       true,
       "itertools.batched.__name__.__eq__('batched') == True — batched is a C extension type in Modules/itertoolsmodule.c added in Python 3.12; __name__ is 'batched'; str.__eq__('batched') returns True; new to extra197"]
    - [batched_module_eq_itertools,
       batched.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.batched.__module__.__eq__('itertools') == True — batched is a C extension type whose __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra197"]
    - [batched_qualname_eq_batched,
       batched.__qualname__.__eq__,
       ["batched"],
       true,
       "itertools.batched.__qualname__.__eq__('batched') == True — batched is defined at module scope; __qualname__ is the simple type name 'batched' with no enclosing scope prefix; str.__eq__('batched') returns True; new to extra197"]

# ---------------------------------------------------------------------------
# Table 3: pairwise and batched __bases__[0].__name__ cross-check
#
# itertools.pairwise.__bases__[0].__name__.__eq__('object') == True
# itertools.batched.__bases__[0].__name__.__eq__('object') == True
#
# Both pairwise and batched are C extension types that inherit directly from
# object with no intermediary base class. __bases__[0].__name__ == 'object'
# for both. New to extra197.
# ---------------------------------------------------------------------------

table itertools_extra197.pairwise_batched_bases:
  description: "itertools.pairwise and batched __bases__[0].__name__=='object'; both are C extension types inheriting directly from object; new to extra197"
  kind: python_call_eq
  category: identity
  id_prefix: iterpairwise197

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_base,
       "pairwise.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.pairwise.__bases__[0].__name__.__eq__('object') == True — pairwise is a C extension type; its only base is object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra197"]
    - [batched_base,
       "batched.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.batched.__bases__[0].__name__.__eq__('object') == True — batched is a C extension type; its only base is object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra197"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra197
# ---------------------------------------------------------------------------

invariant itertools_extra197.pairwise_name:
  description: "itertools.pairwise.__name__ == 'pairwise' — C extension type added in Python 3.10; new to extra197"
  kind: python_call_eq
  function: pairwise.__name__.__eq__
  args: ["pairwise"]
  expected: true

invariant itertools_extra197.pairwise_module:
  description: "itertools.pairwise.__module__ == 'itertools' — C extension type; __module__ is 'itertools'; new to extra197"
  kind: python_call_eq
  function: pairwise.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra197.pairwise_qualname:
  description: "itertools.pairwise.__qualname__ == 'pairwise' — top-level type; no enclosing scope prefix; new to extra197"
  kind: python_call_eq
  function: pairwise.__qualname__.__eq__
  args: ["pairwise"]
  expected: true

invariant itertools_extra197.pairwise_bases_object:
  description: "itertools.pairwise.__bases__[0].__name__ == 'object' — C extension type; sole base is object; new to extra197"
  kind: python_call_eq
  function: "pairwise.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra197.batched_name:
  description: "itertools.batched.__name__ == 'batched' — C extension type added in Python 3.12; new to extra197"
  kind: python_call_eq
  function: batched.__name__.__eq__
  args: ["batched"]
  expected: true

invariant itertools_extra197.batched_module:
  description: "itertools.batched.__module__ == 'itertools' — C extension type; __module__ is 'itertools'; new to extra197"
  kind: python_call_eq
  function: batched.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra197.batched_qualname:
  description: "itertools.batched.__qualname__ == 'batched' — top-level type; no enclosing scope prefix; new to extra197"
  kind: python_call_eq
  function: batched.__qualname__.__eq__
  args: ["batched"]
  expected: true

invariant itertools_extra197.batched_bases_object:
  description: "itertools.batched.__bases__[0].__name__ == 'object' — C extension type; sole base is object; new to extra197"
  kind: python_call_eq
  function: "batched.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
