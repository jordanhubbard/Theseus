spec: re_extra160
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Match method __qualname__ values — group, groups, groupdict, start, end, span, expand, __repr__."
    - "All re.Match method qualnames use the 'Match.' prefix (6 characters). This contrasts with re.Pattern methods which also use 'Pattern.' (8 characters)."
    - "re.Match.group.__qualname__ == 'Match.group' (len=11; 'Match.' (6) + 'group' (5) = 11; tied with Match.start at 11)."
    - "re.Match.groups.__qualname__ == 'Match.groups' (len=12; 'Match.' (6) + 'groups' (6) = 12; tied with Match.expand at 12)."
    - "re.Match.groupdict.__qualname__ == 'Match.groupdict' (len=15; 'Match.' (6) + 'groupdict' (9) = 15)."
    - "re.Match.start.__qualname__ == 'Match.start' (len=11; 'Match.' (6) + 'start' (5) = 11; tied with Match.group at 11)."
    - "re.Match.end.__qualname__ == 'Match.end' (len=9; 'Match.' (6) + 'end' (3) = 9; the shortest Match method qualname)."
    - "re.Match.span.__qualname__ == 'Match.span' (len=10; 'Match.' (6) + 'span' (4) = 10)."
    - "re.Match.expand.__qualname__ == 'Match.expand' (len=12; 'Match.' (6) + 'expand' (6) = 12; tied with Match.groups at 12)."
    - "re.Match.__repr__.__qualname__ == 'Match.__repr__' (len=14; 'Match.' (6) + '__repr__' (8) = 14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match method __qualname__ values (group 1)
# end, span, group, start, groups, expand — core result-access methods.
# end=9, span=10, group=11, start=11, groups=12, expand=12
# end is shortest; group and start tied at 11; groups and expand tied at 12.
# All use 'Match.' prefix (6 characters).
# ---------------------------------------------------------------------------

table re_extra160.Match_method_qualnames_group1:
  description: "re.Match method __qualname__ values: end='Match.end' (len=9), span='Match.span' (len=10), group=start='Match.group'/'Match.start' (len=11), groups=expand='Match.groups'/'Match.expand' (len=12); end is shortest"
  kind: python_call_eq
  category: qualname
  id_prefix: rematchq160

  columns: [id, function, args, expected, description]
  rows:
    - [end_qeq,    "Match.end.__qualname__.__eq__",    ["Match.end"],    true, "re.Match.end.__qualname__ == 'Match.end' (Match.end() returns the end index of the match within the string; equivalent to m.span()[1]; 'Match.end' has 9 characters: 'Match.' (6) + 'end' (3) = 9; the shortest re.Match method qualname of all eight covered in this spec; 'end' (3 chars) is the shortest Match method name; Match.end() is typically used together with Match.start() to extract the matched substring via string[m.start():m.end()])"]
    - [span_qeq,   "Match.span.__qualname__.__eq__",   ["Match.span"],   true, "re.Match.span.__qualname__ == 'Match.span' (Match.span() returns a 2-tuple (m.start(group), m.end(group)); 'Match.span' has 10 characters: 'Match.' (6) + 'span' (4) = 10; one character longer than 'Match.end' (9); span() is the most convenient way to get both match boundaries at once; compare with re.Pattern.sub qualname length 11 ('Pattern.' (8) + 'sub' (3) = 11) — the Pattern prefix adds 2 chars over the Match prefix for any 3-char method name)"]
    - [group_qeq,  "Match.group.__qualname__.__eq__",  ["Match.group"],  true, "re.Match.group.__qualname__ == 'Match.group' (Match.group() returns one or more subgroups of the match; group(0) or group() returns the entire match; group(1), group(2), etc. return the numbered capturing groups; 'Match.group' has 11 characters: 'Match.' (6) + 'group' (5) = 11; tied with 'Match.start' (also 11); both group and start have 5-character method names producing the same qualname length)"]
    - [start_qeq,  "Match.start.__qualname__.__eq__",  ["Match.start"],  true, "re.Match.start.__qualname__ == 'Match.start' (Match.start() returns the start index of the match within the string; equivalent to m.span()[0]; 'Match.start' has 11 characters: 'Match.' (6) + 'start' (5) = 11; tied with 'Match.group' (also 11) — both have 5-character method names; Match.start() and Match.end() are complementary: together they give the slice [start:end] of the matched text in the original string)"]

# ---------------------------------------------------------------------------
# re.Match method __qualname__ values (group 2)
# groups, expand, groupdict, __repr__ — additional access and utility methods.
# groups=12, expand=12, groupdict=15, __repr__=14
# groups and expand tied at 12; groupdict is the longest non-dunder at 15.
# ---------------------------------------------------------------------------

table re_extra160.Match_method_qualnames_group2:
  description: "re.Match method __qualname__ values: groups=expand='Match.groups'/'Match.expand' (len=12), __repr__='Match.__repr__' (len=14), groupdict='Match.groupdict' (len=15); groupdict is the longest"
  kind: python_call_eq
  category: qualname
  id_prefix: rematchq160

  columns: [id, function, args, expected, description]
  rows:
    - [groups_qeq,    "Match.groups.__qualname__.__eq__",    ["Match.groups"],    true, "re.Match.groups.__qualname__ == 'Match.groups' (Match.groups() returns a tuple of all capturing groups in the match; groups that did not participate in the match return the default value (None or a provided default); 'Match.groups' has 12 characters: 'Match.' (6) + 'groups' (6) = 12; tied with 'Match.expand' (also 12); 'groups' (6 chars) is the same length as 'expand' (6 chars); Match.groups() is the bulk-access complement to group() which accesses individual groups)"]
    - [expand_qeq,    "Match.expand.__qualname__.__eq__",    ["Match.expand"],    true, "re.Match.expand.__qualname__ == 'Match.expand' (Match.expand() returns the string obtained by doing backslash substitution on the template string — the same substitution as done by re.sub(); 'Match.expand' has 12 characters: 'Match.' (6) + 'expand' (6) = 12; tied with 'Match.groups' (also 12); the name 'expand' refers to expanding backreferences like \\1, \\g<name> in the template string using the match's captured groups)"]
    - [repr_qeq,      "Match.__repr__.__qualname__.__eq__",  ["Match.__repr__"],  true, "re.Match.__repr__.__qualname__ == 'Match.__repr__' (Match.__repr__() returns a developer-friendly string representation of the match object showing the pattern, match span, and matched text; 'Match.__repr__' has 14 characters: 'Match.' (6) + '__repr__' (8) = 14; the dunder double-underscores add characters: __repr__ (8 chars) is longer than any non-dunder method name in the Match class; repr() on a Match object shows e.g. '<re.Match object; span=(0, 3), match=abc>')"]
    - [groupdict_qeq, "Match.groupdict.__qualname__.__eq__", ["Match.groupdict"], true, "re.Match.groupdict.__qualname__ == 'Match.groupdict' (Match.groupdict() returns a dictionary mapping group names to their matched strings; only named groups (defined with (?P<name>...) syntax) appear in the dict; 'Match.groupdict' has 15 characters: 'Match.' (6) + 'groupdict' (9) = 15; the longest Match method qualname in this spec; 'groupdict' (9 chars) is the longest non-dunder method name; groupdict() is most useful when patterns use named capturing groups for readability)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra160.Match_end_is_shortest_qualname_at_9:
  description: "re.Match.end.__qualname__.__len__() == 9 — 'Match.end' is the shortest of all eight Match method qualnames in this spec with only 9 characters: 'Match.' (6) + 'end' (3) = 9; the complete ascending length order is: end=9, span=10, group=start=11, groups=expand=12, __repr__=14, groupdict=15; 'end' (3 chars) is the shortest Match method name; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Match.end.__qualname__.__len__"
  args: []
  expected: 9

invariant re_extra160.Match_group_start_tied_at_11:
  description: "re.Match.group.__qualname__.__len__() == 11 — 'Match.group' has 11 characters: 'Match.' (6) + 'group' (5) = 11; tied with 'Match.start' (also 11: 'Match.' (6) + 'start' (5) = 11); group() and start() are the two 5-character Match method names; Match.group() is the primary way to retrieve matched text while Match.start() gives the starting position; both qualnames have length 11; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Match.group.__qualname__.__len__"
  args: []
  expected: 11

invariant re_extra160.Match_groupdict_is_longest_qualname_at_15:
  description: "re.Match.groupdict.__qualname__.__len__() == 15 — 'Match.groupdict' is the longest non-dunder Match method qualname at 15 characters: 'Match.' (6) + 'groupdict' (9) = 15; 'groupdict' (9 chars) is the longest non-dunder method name in this spec; the complete ranking: end=9, span=10, group=start=11, groups=expand=12, __repr__=14, groupdict=15; groupdict() returns a dict of all named capturing group matches; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "Match.groupdict.__qualname__.__len__"
  args: []
  expected: 15
