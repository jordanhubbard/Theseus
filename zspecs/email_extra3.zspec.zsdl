spec: email_extra3
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "Python 3 email package documentation — https://docs.python.org/3/library/email.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/__init__.py"
    - "email_extra.zspec.zsdl — covers email.__name__, message_from_string/bytes/file/binary_file __name__; message_from_string/bytes behavior"
    - "email_extra2.zspec.zsdl — covers email.policy/errors/contentmanager/generator class names and modules via email backend"
    - "email_message_extra.zspec.zsdl — covers email.message.Message/MIMEPart/EmailMessage __qualname__ and __module__ from email.message backend"
  notes:
    - "This spec extends email_extra.zspec.zsdl and email_extra2.zspec.zsdl."
    - "Focus: __qualname__ for the four email top-level convenience functions and __module__ for message_from_string."
    - "email.message_from_string.__qualname__ == 'message_from_string' — top-level function qualname equals name."
    - "email.message_from_bytes.__qualname__ == 'message_from_bytes'."
    - "email.message_from_file.__qualname__ == 'message_from_file'."
    - "email.message_from_binary_file.__qualname__ == 'message_from_binary_file'."
    - "email.message_from_string.__module__ == 'email' — defined in the email package __init__."
    - "email.message_from_bytes.__module__ == 'email'."
    - "email.message_from_file.__module__ == 'email'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for top-level email convenience functions
# (email_extra covers __name__; __qualname__ is new in this spec)
# ---------------------------------------------------------------------------

table email_extra3.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [message_from_string,      message_from_string.__qualname__.__eq__,      ["message_from_string"],      true]
    - [message_from_bytes,       message_from_bytes.__qualname__.__eq__,       ["message_from_bytes"],       true]
    - [message_from_file,        message_from_file.__qualname__.__eq__,        ["message_from_file"],        true]
    - [message_from_binary_file, message_from_binary_file.__qualname__.__eq__, ["message_from_binary_file"], true]

# ---------------------------------------------------------------------------
# __module__ for top-level email convenience functions
# (email_extra covers __name__ only; __module__ is new in this spec)
# ---------------------------------------------------------------------------

table email_extra3.function_modules:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [message_from_string,      message_from_string.__module__.__eq__,      ["email"], true]
    - [message_from_bytes,       message_from_bytes.__module__.__eq__,       ["email"], true]
    - [message_from_file,        message_from_file.__module__.__eq__,        ["email"], true]
    - [message_from_binary_file, message_from_binary_file.__module__.__eq__, ["email"], true]

# ---------------------------------------------------------------------------
# email package — __spec__.name check (package identity)
# (email_extra covers __name__ == 'email'; __spec__ is new)
# ---------------------------------------------------------------------------

invariant email_extra3.package.spec_name:
  description: "email.__spec__.name == 'email' — package loader spec confirms name"
  category: package
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["email"]
  expected: true

# ---------------------------------------------------------------------------
# email.message submodule — reachable via email backend attribute chain
# (confirms that email.message is importable as an attribute of email)
# ---------------------------------------------------------------------------

invariant email_extra3.message_submodule.Message_name:
  description: "email.message.Message.__name__ == 'Message' — reachable via email.message chain"
  category: submodule
  kind: python_call_eq
  function: message.Message.__name__.__eq__
  args: ["Message"]
  expected: true

invariant email_extra3.message_submodule.EmailMessage_name:
  description: "email.message.EmailMessage.__name__ == 'EmailMessage' — reachable via email.message chain"
  category: submodule
  kind: python_call_eq
  function: message.EmailMessage.__name__.__eq__
  args: ["EmailMessage"]
  expected: true
