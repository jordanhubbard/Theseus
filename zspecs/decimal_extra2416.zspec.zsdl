    - ["dc2416008", "decimal.Inexact.__dict__.__contains__", ["__iter__"], false]
    - ["dc2416009", "decimal.Rounded.__dict__.__contains__", ["__iter__"], false]
    - ["dc2416010", "decimal.FloatOperation.__dict__.__contains__", ["__iter__"], false]

