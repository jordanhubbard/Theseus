spec: decimal_extra2416
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/decimal.html"
    - "CPython source — Modules/_decimal/_decimal.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "decimal.Decimal and decimal.Context do not define __iter__ or __next__ in their class __dict__."
    - "decimal.DecimalException and its subclasses (InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Subnormal, Rounded, Clamped, FloatOperation) are exception classes and define neither __iter__ nor __next__."
    - "decimal.DecimalTuple is a namedtuple (inherits from tuple); it does not define __iter__ or __next__ in its own class __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ in class __dict__ — Decimal, Context, DecimalException hierarchy
# ===

table decimal_extra2416.iter_in_dict:
  description: "__iter__ dict-presence for decimal module types — none define __iter__ in their own __dict__"
  kind: python_call_eq
