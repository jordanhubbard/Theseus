spec: wave_extra3
version: ">=3.9"
backend: python_module(wave)

docs: https://docs.python.org/3/library/wave.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/wave.html — Python wave module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/wave.py"
    - "wave.zspec.zsdl — covers __name__ checks (table), module checks for Wave_read/Wave_write (table), open __name__, Error base, type checks (table), method name checks (tables)"
    - "wave_extra.zspec.zsdl — covers class __name__ checks (table), open __name__, Wave_read.__module__, Error base"
    - "wave_extra2.zspec.zsdl — covers open/__name__, Wave_read/__name__/__module__, Wave_write/__name__/__module__, Error/__name__/__module__/__base__/is_type, Wave_read/Wave_write is_type, open is_function"
  notes:
    - "This spec extends wave.zspec.zsdl, wave_extra.zspec.zsdl, and wave_extra2.zspec.zsdl."
    - "Focus: __qualname__ checks for Wave_read, Wave_write, Error, and open."
    - "All four are top-level names so __qualname__ equals __name__ for each."
    - "wave_extra2 covers Wave_write.__module__ and Error.__module__; those are omitted here."
    - "wave_extra2 covers open.__module__ as open.__class__.__name__; wave.zspec covers Wave_write.__module__."
    - "The remaining genuinely new axes are the __qualname__ attributes for all four exports."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for public wave exports
# All four are top-level names; __qualname__ == __name__ for each.
# No existing spec (wave, wave_extra, wave_extra2) checks __qualname__.
# ---------------------------------------------------------------------------

table wave_extra3.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Wave_read,  Wave_read.__qualname__.__eq__,  ["Wave_read"],  true]
    - [Wave_write, Wave_write.__qualname__.__eq__, ["Wave_write"], true]
    - [Error,      Error.__qualname__.__eq__,      ["Error"],      true]
    - [open,       open.__qualname__.__eq__,       ["open"],       true]

# ---------------------------------------------------------------------------
# __module__ checks not yet covered by prior specs
# wave.zspec.zsdl covers Wave_read.__module__ and Wave_write.__module__ (table).
# wave_extra.zspec.zsdl covers Wave_read.__module__.
# wave_extra2.zspec.zsdl covers Wave_read.__module__, Wave_write.__module__, Error.__module__.
# open.__module__ has not been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant wave_extra3.open.module:
  description: "wave.open.__module__ == 'wave'"
  category: modules
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["wave"]
  expected: true
