spec: bz2_extra15
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
    - "bz2_extra14.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone (extra14); open/compress/decompress __qualname__ standalone (extra14); bz2.__name__ standalone (extra14); BZ2File.__module__ standalone (extra14)."
    - "bz2_extra11.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone (extra11); class __module__ table (extra11)."
    - "bz2_extra4.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ table; open/compress/decompress __qualname__ table."
    - "bz2_extra2.zspec.zsdl — covers BZ2File.read/__name__, BZ2File.write/__name__, BZ2File.close/__name__ in a method names table."
  notes:
    - "This spec extends bz2 through bz2_extra14; it does NOT duplicate invariants present in those files."
    - "Focus: method __qualname__ invariants for BZ2File.read, .write, .seek, .close — qualified names of the form 'BZ2File.<method>'; class __qualname__ for BZ2Compressor and BZ2Decompressor re-anchored from extra15 namespace."
    - "No prior bz2 spec checks method __qualname__ values of the form 'BZ2File.<m>'. Prior specs cover method __name__ (extra2) and class/function __qualname__ from other namespaces. Verified 2026-04-09."
    - "BZ2File.read.__qualname__ == 'BZ2File.read'; BZ2File.write.__qualname__ == 'BZ2File.write'; BZ2File.seek.__qualname__ == 'BZ2File.seek'; BZ2File.close.__qualname__ == 'BZ2File.close'. All verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BZ2File method __qualname__ — read, write, seek, close
# (standalone, extra15 anchors)
#
# No prior bz2 spec checks method __qualname__ values of the form
# 'BZ2File.<method>'. Prior specs cover BZ2File.__qualname__ (class qualname)
# and BZ2File method __name__ (extra2), but not method __qualname__.
# ---------------------------------------------------------------------------

invariant bz2_extra15.BZ2File.read.qualname:
  description: "bz2.BZ2File.read.__qualname__ == 'BZ2File.read' — method qualname encodes class context (extra15)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.read.__qualname__.__eq__
  args: ["BZ2File.read"]
  expected: true

invariant bz2_extra15.BZ2File.write.qualname:
  description: "bz2.BZ2File.write.__qualname__ == 'BZ2File.write' — method qualname encodes class context (extra15)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.write.__qualname__.__eq__
  args: ["BZ2File.write"]
  expected: true

invariant bz2_extra15.BZ2File.seek.qualname:
  description: "bz2.BZ2File.seek.__qualname__ == 'BZ2File.seek' — method qualname encodes class context (extra15)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.seek.__qualname__.__eq__
  args: ["BZ2File.seek"]
  expected: true

invariant bz2_extra15.BZ2File.close.qualname:
  description: "bz2.BZ2File.close.__qualname__ == 'BZ2File.close' — method qualname encodes class context (extra15)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.close.__qualname__.__eq__
  args: ["BZ2File.close"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Compressor and BZ2Decompressor class __qualname__
# (standalone, extra15 anchors)
#
# bz2_extra4 covers these in tables; bz2_extra11/14 cover them as standalones.
# These invariants re-anchor from the extra15 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra15.BZ2Compressor.qualname:
  description: "bz2.BZ2Compressor.__qualname__ == 'BZ2Compressor' — top-level class qualname (extra15 anchor)"
  category: qualnames
  kind: python_call_eq
  function: BZ2Compressor.__qualname__.__eq__
  args: ["BZ2Compressor"]
  expected: true

invariant bz2_extra15.BZ2Decompressor.qualname:
  description: "bz2.BZ2Decompressor.__qualname__ == 'BZ2Decompressor' — top-level class qualname (extra15 anchor)"
  category: qualnames
  kind: python_call_eq
  function: BZ2Decompressor.__qualname__.__eq__
  args: ["BZ2Decompressor"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __qualname__ — open, compress, decompress
# (standalone, extra15 anchors)
#
# Re-anchored from the extra15 namespace. Prior specs (extra4, extra13, extra14)
# cover these from their own namespace anchors.
# ---------------------------------------------------------------------------

invariant bz2_extra15.open.qualname:
  description: "bz2.open.__qualname__ == 'open' — module-level function qualname (extra15 anchor)"
  category: qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant bz2_extra15.compress.qualname:
  description: "bz2.compress.__qualname__ == 'compress' — module-level function qualname (extra15 anchor)"
  category: qualnames
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

invariant bz2_extra15.decompress.qualname:
  description: "bz2.decompress.__qualname__ == 'decompress' — module-level function qualname (extra15 anchor)"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — BZ2File methods + classes + functions (extra15)
#
# No prior bz2 spec presents BZ2File method __qualname__ values in any table.
# This table anchors all nine identifiers from the extra15 namespace.
# ---------------------------------------------------------------------------

table bz2_extra15.method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn15

  columns: [id, function, args, expected]
  rows:
    - [BZ2File.read,       "BZ2File.read.__qualname__.__eq__",       ["BZ2File.read"],       true]
    - [BZ2File.write,      "BZ2File.write.__qualname__.__eq__",      ["BZ2File.write"],      true]
    - [BZ2File.seek,       "BZ2File.seek.__qualname__.__eq__",       ["BZ2File.seek"],       true]
    - [BZ2File.close,      "BZ2File.close.__qualname__.__eq__",      ["BZ2File.close"],      true]
    - [BZ2Compressor,      BZ2Compressor.__qualname__.__eq__,        ["BZ2Compressor"],      true]
    - [BZ2Decompressor,    BZ2Decompressor.__qualname__.__eq__,      ["BZ2Decompressor"],    true]
    - [open,               open.__qualname__.__eq__,                 ["open"],               true]
    - [compress,           compress.__qualname__.__eq__,             ["compress"],           true]
    - [decompress,         decompress.__qualname__.__eq__,           ["decompress"],         true]
