spec: statistics_extra2
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "Python 3 statistics documentation — https://docs.python.org/3/library/statistics.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
    - "statistics.zspec.zsdl — covers function names (mean, fmean, geometric_mean, harmonic_mean, median, median_low, median_high, median_grouped, mode, multimode, pstdev, pvariance, stdev, variance, quantiles, NormalDist class name, StatisticsError class name)"
    - "statistics_extra.zspec.zsdl — covers mean([1,2,3]) == 2, median([1,2,3]) == 2, mode([1,1,2,3]) == 1, stdev([1,2,3]).__class__.__name__ == 'float', StatisticsError.__bases__[0].__name__ == 'ValueError', NormalDist(0,1).__class__.__name__ == 'NormalDist', pstdev([1,2,3]) class name, variance([1,2,3]) class name"
  notes:
    - "This spec extends statistics.zspec.zsdl and statistics_extra.zspec.zsdl."
    - "Focus: __name__ and __module__ attributes of key functions and classes, class hierarchy for NormalDist and StatisticsError."
    - "statistics.mean.__name__ == 'mean' — function-level name attribute."
    - "statistics.median.__name__ == 'median' — function-level name attribute."
    - "statistics.mode.__name__ == 'mode' — function-level name attribute."
    - "statistics.stdev.__name__ == 'stdev' — function-level name attribute."
    - "statistics.variance.__name__ == 'variance' — function-level name attribute."
    - "statistics.pstdev.__name__ == 'pstdev' — function-level name attribute."
    - "statistics.pvariance.__name__ == 'pvariance' — function-level name attribute."
    - "statistics.NormalDist.__name__ == 'NormalDist' — class-level name attribute."
    - "statistics.StatisticsError.__name__ == 'StatisticsError' — class-level name attribute."
    - "statistics.mean.__module__ == 'statistics' — functions live in the statistics module."
    - "statistics.median.__module__ == 'statistics'."
    - "statistics.NormalDist.__module__ == 'statistics'."
    - "statistics.StatisticsError.__module__ == 'statistics'."
    - "statistics.NormalDist.__bases__[0].__name__ == 'object' — NormalDist inherits directly from object."
    - "statistics.StatisticsError.__bases__[0].__name__ == 'ValueError'."
    - "All expected values verified by running Python 3.12 statistics module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

table statistics_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [mean,       mean.__name__.__eq__,      ["mean"],      true]
    - [median,     median.__name__.__eq__,    ["median"],    true]
    - [mode,       mode.__name__.__eq__,      ["mode"],      true]
    - [stdev,      stdev.__name__.__eq__,     ["stdev"],     true]
    - [variance,   variance.__name__.__eq__,  ["variance"],  true]
    - [pstdev,     pstdev.__name__.__eq__,    ["pstdev"],    true]
    - [pvariance,  pvariance.__name__.__eq__,  ["pvariance"], true]

# ---------------------------------------------------------------------------
# Function __module__ checks
# ---------------------------------------------------------------------------

invariant statistics_extra2.mean.module:
  description: "statistics.mean.__module__ == 'statistics'"
  category: function_module
  kind: python_call_eq
  function: mean.__module__.__eq__
  args: ["statistics"]
  expected: true

invariant statistics_extra2.median.module:
  description: "statistics.median.__module__ == 'statistics'"
  category: function_module
  kind: python_call_eq
  function: median.__module__.__eq__
  args: ["statistics"]
  expected: true

# ---------------------------------------------------------------------------
# NormalDist — class identity (name, module, and base class)
# ---------------------------------------------------------------------------

invariant statistics_extra2.NormalDist.class_name:
  description: "statistics.NormalDist.__name__ == 'NormalDist'"
  category: class_metadata
  kind: python_call_eq
  function: NormalDist.__name__.__eq__
  args: ["NormalDist"]
  expected: true

invariant statistics_extra2.NormalDist.module:
  description: "statistics.NormalDist.__module__ == 'statistics'"
  category: class_metadata
  kind: python_call_eq
  function: NormalDist.__module__.__eq__
  args: ["statistics"]
  expected: true

invariant statistics_extra2.NormalDist.base_is_object:
  description: "statistics.NormalDist.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: NormalDist.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# StatisticsError — class identity (name, module, and base class)
# ---------------------------------------------------------------------------

invariant statistics_extra2.StatisticsError.class_name:
  description: "statistics.StatisticsError.__name__ == 'StatisticsError'"
  category: class_metadata
  kind: python_call_eq
  function: StatisticsError.__name__.__eq__
  args: ["StatisticsError"]
  expected: true

invariant statistics_extra2.StatisticsError.module:
  description: "statistics.StatisticsError.__module__ == 'statistics'"
  category: class_metadata
  kind: python_call_eq
  function: StatisticsError.__module__.__eq__
  args: ["statistics"]
  expected: true

invariant statistics_extra2.StatisticsError.base_is_ValueError:
  description: "statistics.StatisticsError.__bases__[0].__name__ == 'ValueError'"
  category: class_hierarchy
  kind: python_call_eq
  function: StatisticsError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"

# ---------------------------------------------------------------------------
# Additional function __module__ checks — stdev and variance
# ---------------------------------------------------------------------------

invariant statistics_extra2.stdev.module:
  description: "statistics.stdev.__module__ == 'statistics'"
  category: function_module
  kind: python_call_eq
  function: stdev.__module__.__eq__
  args: ["statistics"]
  expected: true

invariant statistics_extra2.variance.module:
  description: "statistics.variance.__module__ == 'statistics'"
  category: function_module
  kind: python_call_eq
  function: variance.__module__.__eq__
  args: ["statistics"]
  expected: true

invariant statistics_extra2.mode.module:
  description: "statistics.mode.__module__ == 'statistics'"
  category: function_module
  kind: python_call_eq
  function: mode.__module__.__eq__
  args: ["statistics"]
  expected: true
