spec: statistics_extra2
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "Python 3 statistics documentation — https://docs.python.org/3/library/statistics.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
    - "statistics.zspec.zsdl — covers mean, fmean, geometric_mean, median, mode, variance, stdev, NormalDist mean/stdev"
    - "statistics_extra.zspec.zsdl — covers StatisticsError, NormalDist variance/cdf, multimode, harmonic_mean, stdev"
  notes:
    - "This spec extends statistics.zspec.zsdl and statistics_extra.zspec.zsdl with coverage not already present."
    - "NormalDist.__name__ == 'NormalDist' — class name check on the class itself."
    - "NormalDist.__module__ == 'statistics' — class lives in the statistics module."
    - "fmean([1,2,3]) == 2.0 — fmean always returns float; this mirrors statistics.zspec.zsdl but uses a type check."
    - "geometric_mean([1,4]) == 2.0 — (1*4)^(1/2) = 4^(1/2) = 2.0."
    - "harmonic_mean([1,2,4]) is a float — checked via __class__.__name__."
    - "quantiles([1,2,3,4,5], n=4) returns a list of 3 cut points (quartiles Q1, Q2, Q3)."
    - "All expected values verified by running Python 3.12 statistics module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NormalDist — class identity (name and module on the class itself)
# ---------------------------------------------------------------------------

invariant statistics_extra2.NormalDist.class_name:
  description: "NormalDist.__name__ == 'NormalDist'"
  category: class_metadata
  kind: python_call_eq
  function: NormalDist.__name__.__eq__
  args: ["NormalDist"]
  expected: true

invariant statistics_extra2.NormalDist.module:
  description: "NormalDist.__module__ == 'statistics'"
  category: class_metadata
  kind: python_call_eq
  function: NormalDist.__module__.__eq__
  args: ["statistics"]
  expected: true

# ---------------------------------------------------------------------------
# NormalDist — mean, stdev, variance on fresh instances
# (mean and stdev are in statistics.zspec.zsdl; variance is in statistics_extra.zspec.zsdl
#  but we add a second set for different parameter values not yet covered)
# ---------------------------------------------------------------------------

invariant statistics_extra2.NormalDist.mean_zero_one:
  description: "NormalDist(0, 1).mean == 0 — standard normal mean attribute"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: mean
  expected: 0

invariant statistics_extra2.NormalDist.stdev_zero_one:
  description: "NormalDist(0, 1).stdev == 1 — standard normal stdev attribute"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: stdev
  expected: 1

invariant statistics_extra2.NormalDist.variance_zero_one:
  description: "NormalDist(0, 1).variance == 1 — stdev**2 == 1 for standard normal"
  category: NormalDist
  kind: python_call_eq
  function: NormalDist
  args: [0, 1]
  method: variance
  expected: 1

# ---------------------------------------------------------------------------
# StatisticsError — class identity and hierarchy
# (class_name and base already in statistics_extra.zspec.zsdl — we add module)
# ---------------------------------------------------------------------------

invariant statistics_extra2.StatisticsError.class_name:
  description: "StatisticsError.__name__ == 'StatisticsError'"
  category: class_metadata
  kind: python_call_eq
  function: StatisticsError.__name__.__eq__
  args: ["StatisticsError"]
  expected: true

invariant statistics_extra2.StatisticsError.base_is_ValueError:
  description: "StatisticsError.__bases__[0].__name__ == 'ValueError'"
  category: class_hierarchy
  kind: python_call_eq
  function: StatisticsError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "ValueError"

# ---------------------------------------------------------------------------
# fmean — additional type-level check (returns float)
# fmean([1,2,3]) == 2.0 is in statistics.zspec.zsdl; here we verify the
# return type is float via __class__.__name__
# ---------------------------------------------------------------------------

invariant statistics_extra2.fmean.returns_float:
  description: "fmean([1, 2, 3]).__class__.__name__ == 'float' — fmean always returns a float"
  category: fmean
  kind: python_call_eq
  function: fmean
  args: [[1, 2, 3]]
  method: __class__
  method_chain: __name__
  method_chain_args: []
  expected: "float"

# ---------------------------------------------------------------------------
# geometric_mean — (1*4)^(1/2) = 2.0
# statistics.zspec.zsdl has geometric_mean([1,2,4])==2.0; add a different vector
# ---------------------------------------------------------------------------

invariant statistics_extra2.geometric_mean.one_four:
  description: "geometric_mean([1, 4]) == 2.0 — (1*4)^(1/2) = 2.0"
  category: geometric_mean
  kind: python_call_eq
  function: geometric_mean
  args: [[1, 4]]
  expected: 2.0

# ---------------------------------------------------------------------------
# harmonic_mean — return type check
# statistics_extra.zspec.zsdl has harmonic_mean([1,2,4]) == 1.714...; here we
# verify the return type is float
# ---------------------------------------------------------------------------

invariant statistics_extra2.harmonic_mean.returns_float:
  description: "harmonic_mean([1, 2, 4]).__class__.__name__ == 'float'"
  category: harmonic_mean
  kind: python_call_eq
  function: harmonic_mean
  args: [[1, 2, 4]]
  method: __class__
  method_chain: __name__
  method_chain_args: []
  expected: "float"

# ---------------------------------------------------------------------------
# quantiles — returns a list of n-1 cut points (Python 3.8+)
# quantiles(data, n=4) returns Q1, Q2, Q3 as a 3-element list
# ---------------------------------------------------------------------------

invariant statistics_extra2.quantiles.returns_list:
  description: "quantiles([1,2,3,4,5], n=4).__class__.__name__ == 'list'"
  category: quantiles
  kind: python_call_eq
  function: quantiles
  args: [[1, 2, 3, 4, 5]]
  kwargs:
    n: 4
  method: __class__
  method_chain: __name__
  method_chain_args: []
  expected: "list"

invariant statistics_extra2.quantiles.length:
  description: "len(quantiles([1,2,3,4,5], n=4)) == 3 — n-1 cut points for quartiles"
  category: quantiles
  kind: python_call_eq
  function: quantiles
  args: [[1, 2, 3, 4, 5]]
  kwargs:
    n: 4
  method: __len__
  method_args: []
  expected: 3
