spec: xml_sax
version: ">=3.0"
backend: python_module(xml.sax)

docs: https://docs.python.org/3/library/xml.sax.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/xml.sax.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "xml.sax source: Lib/xml/sax/__init__.py (PSF; source inspection permitted)"
  not_derived_from:
    - "xml.sax source: internal SAX parser implementation (Lib/xml/sax/expatreader.py)"
  notes:
    - "xml.sax exposes: make_parser, parse, parseString at module level."
    - "Exception hierarchy: SAXException is the base; SAXParseException, SAXNotSupportedException, SAXNotRecognizedException are subclasses."
    - "SAXReaderNotAvailable is also re-exported from xml.sax at top level."
    - "Handler/feature constants live in xml.sax.handler submodule (not re-exported to xml.sax namespace)."
    - "ContentHandler, ErrorHandler, DTDHandler, EntityResolver, InputSource are re-exported from xml.sax directly."
    - "make_parser() with no args returns an ExpatParser (xml.sax.expatreader.ExpatParser)."
    - "SAXException('msg').getMessage() returns the message string passed to the constructor."
    - "SAXException.__module__ starts with 'xml.sax' (impl is in xml.sax._exceptions)."
    - "All expected values verified by running Python 3.12 xml.sax module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Top-level function name checks
# ---------------------------------------------------------------------------

table xml_sax.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [make_parser,  make_parser.__name__.__eq__,  ["make_parser"],  true]
    - [parse,        parse.__name__.__eq__,         ["parse"],        true]
    - [parsestring,  parseString.__name__.__eq__,   ["parseString"],  true]

# ---------------------------------------------------------------------------
# Exception class name checks
# ---------------------------------------------------------------------------

table xml_sax.exception_class_names:
  kind: python_call_eq
  category: classes
  id_prefix: ecname

  columns: [id, function, args, expected]
  rows:
    - [saxexception,             SAXException.__name__.__eq__,             ["SAXException"],              true]
    - [saxparseexception,        SAXParseException.__name__.__eq__,        ["SAXParseException"],         true]
    - [saxnotsupported,          SAXNotSupportedException.__name__.__eq__,  ["SAXNotSupportedException"],  true]
    - [saxnotrecognized,         SAXNotRecognizedException.__name__.__eq__, ["SAXNotRecognizedException"], true]

# ---------------------------------------------------------------------------
# Handler and utility class name checks (re-exported into xml.sax)
# ---------------------------------------------------------------------------

table xml_sax.handler_class_names:
  kind: python_call_eq
  category: classes
  id_prefix: hcname

  columns: [id, function, args, expected]
  rows:
    - [contenthandler,  ContentHandler.__name__.__eq__,  ["ContentHandler"],  true]
    - [errorhandler,    ErrorHandler.__name__.__eq__,    ["ErrorHandler"],    true]
    - [dtdhandler,      DTDHandler.__name__.__eq__,      ["DTDHandler"],      true]
    - [entityresolver,  EntityResolver.__name__.__eq__,  ["EntityResolver"],  true]
    - [inputsource,     InputSource.__name__.__eq__,     ["InputSource"],     true]

# ---------------------------------------------------------------------------
# SAXException — getMessage() and __str__
# ---------------------------------------------------------------------------

invariant xml_sax.saxexception_getmessage:
  description: "SAXException('test error').getMessage() == 'test error'"
  category: behavior
  kind: python_call_eq
  function: SAXException
  args: ["test error"]
  method: getMessage
  method_args: []
  expected: "test error"

invariant xml_sax.saxexception_str:
  description: "str(SAXException('hello')) == 'hello'"
  category: behavior
  kind: python_call_eq
  function: SAXException
  args: ["hello"]
  method: __str__
  method_args: []
  expected: "hello"

# ---------------------------------------------------------------------------
# Exception module origin — confirms they live within xml.sax package
# ---------------------------------------------------------------------------

table xml_sax.exception_modules:
  kind: python_call_eq
  category: classes
  id_prefix: emod

  columns: [id, function, args, expected]
  rows:
    - [saxexception_mod,    SAXException.__module__.startswith,            ["xml.sax"], true]
    - [saxparseexc_mod,     SAXParseException.__module__.startswith,       ["xml.sax"], true]
    - [saxnotsup_mod,       SAXNotSupportedException.__module__.startswith, ["xml.sax"], true]
    - [saxnotrec_mod,       SAXNotRecognizedException.__module__.startswith, ["xml.sax"], true]

# ---------------------------------------------------------------------------
# make_parser — returns an ExpatParser instance
# ---------------------------------------------------------------------------

invariant xml_sax.make_parser_type:
  description: "type(xml.sax.make_parser()).__name__ == 'ExpatParser'"
  category: behavior
  kind: python_call_eq
  function: make_parser
  args: []
  method: __class__
  method_args: []
  method_chain: __name__
  expected: "ExpatParser"
