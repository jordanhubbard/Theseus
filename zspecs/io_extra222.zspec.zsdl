spec: io_extra222
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "io.DEFAULT_BUFFER_SIZE is platform-dependent; on macOS/Darwin 25.4.0 with Python 3.14.3 it is 131072 (128 KiB), not 8192. Verified with Python 3.14.3."
    - "io.SEEK_SET==0, io.SEEK_CUR==1, io.SEEK_END==2 are stable POSIX-derived constants. Verified with Python 3.14.3."
    - "io.UnsupportedOperation has two bases: OSError and ValueError. Verified with Python 3.14.3."
    - "BytesIO.write() and StringIO.read() both raise ValueError('I/O operation on closed file.') after close(). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io module integer constants — SEEK_SET, SEEK_CUR, SEEK_END
# ---------------------------------------------------------------------------

table io_extra222.seek_constants:
  description: "io SEEK_* integer constant equality checks — io.SEEK_SET==0, io.SEEK_CUR==1, io.SEEK_END==2; type is int for all three; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: ioextra222a

  columns: [id, function, args, expected, description]
  rows:
    - [seek_set_eq,    io.SEEK_SET.__eq__,           [0],     true, "io.SEEK_SET == 0; verified with Python 3.14.3"]
    - [seek_cur_eq,    io.SEEK_CUR.__eq__,           [1],     true, "io.SEEK_CUR == 1; verified with Python 3.14.3"]
    - [seek_end_eq,    io.SEEK_END.__eq__,           [2],     true, "io.SEEK_END == 2; verified with Python 3.14.3"]
    - [seek_set_type,  io.SEEK_SET.__class__.__name__.__eq__, ["int"], true, "type(io.SEEK_SET).__name__ == 'int'; verified with Python 3.14.3"]
    - [seek_cur_type,  io.SEEK_CUR.__class__.__name__.__eq__, ["int"], true, "type(io.SEEK_CUR).__name__ == 'int'; verified with Python 3.14.3"]
    - [seek_end_type,  io.SEEK_END.__class__.__name__.__eq__, ["int"], true, "type(io.SEEK_END).__name__ == 'int'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE type and value
# ---------------------------------------------------------------------------

table io_extra222.default_buffer_size:
  description: "io.DEFAULT_BUFFER_SIZE is an int; on macOS/Darwin 25.4.0 it equals 131072 (128 KiB); type is int; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: ioextra222b

  columns: [id, function, args, expected, description]
  rows:
    - [dbs_eq,    io.DEFAULT_BUFFER_SIZE.__eq__,           [131072], true, "io.DEFAULT_BUFFER_SIZE == 131072 on macOS/Darwin 25.4.0; verified with Python 3.14.3"]
    - [dbs_type,  io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"], true, "type(io.DEFAULT_BUFFER_SIZE).__name__ == 'int'; verified with Python 3.14.3"]
    - [dbs_gt,    io.DEFAULT_BUFFER_SIZE.__gt__,           [0],     true, "io.DEFAULT_BUFFER_SIZE > 0 (always positive); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation identity checks
# ---------------------------------------------------------------------------

table io_extra222.unsupported_operation_identity:
  description: "io.UnsupportedOperation identity: __name__=='UnsupportedOperation', __module__=='io', first base is OSError; UnsupportedOperation has two bases: OSError and ValueError; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioextra222c

  columns: [id, function, args, expected, description]
  rows:
    - [unsup_name,   io.UnsupportedOperation.__name__.__eq__,           ["UnsupportedOperation"], true, "io.UnsupportedOperation.__name__ == 'UnsupportedOperation'; verified with Python 3.14.3"]
    - [unsup_mod,    io.UnsupportedOperation.__module__.__eq__,         ["io"],                   true, "io.UnsupportedOperation.__module__ == 'io'; verified with Python 3.14.3"]
    - [unsup_base0,  "io.UnsupportedOperation.__bases__[0].__name__.__eq__", ["OSError"],         true, "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' (first base); verified with Python 3.14.3"]
    - [unsup_base1,  "io.UnsupportedOperation.__bases__[1].__name__.__eq__", ["ValueError"],      true, "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError' (second base); verified with Python 3.14.3"]
    - [unsup_nbases, io.UnsupportedOperation.__bases__.__len__,         [],                       2,    "len(io.UnsupportedOperation.__bases__) == 2 (OSError, ValueError); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# BytesIO write after close raises ValueError
# ---------------------------------------------------------------------------

invariant io_extra222.bytesio_write_after_close_raises:
  description: "io.BytesIO().close() then .write(b'data') raises ValueError('I/O operation on closed file.'); closing a BytesIO invalidates it for all I/O; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: io.BytesIO.__init__
  args: []
  raises: ValueError

invariant io_extra222.stringio_read_after_close_raises:
  description: "io.StringIO().close() then .read() raises ValueError('I/O operation on closed file'); closing a StringIO invalidates it for all I/O; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: io.StringIO.__init__
  args: []
  raises: ValueError

# ---------------------------------------------------------------------------
# Standalone identity invariants
# ---------------------------------------------------------------------------

invariant io_extra222.seek_set_eq_0:
  description: "io.SEEK_SET.__eq__(0) returns True — SEEK_SET is the standard POSIX constant for absolute seek position; value is 0; type is int; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: io.SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra222.seek_end_eq_2:
  description: "io.SEEK_END.__eq__(2) returns True — SEEK_END is the standard POSIX constant for seek relative to end of stream; value is 2; type is int; SEEK_SET=0, SEEK_CUR=1, SEEK_END=2; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: io.SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra222.unsupported_operation_name_len:
  description: "io.UnsupportedOperation.__name__.__len__() == 20 — 'UnsupportedOperation' has 20 characters: 'Unsupported'=11 + 'Operation'=9 = 20; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: io.UnsupportedOperation.__name__.__len__
  args: []
  expected: 20
