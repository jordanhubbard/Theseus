spec: hashlib_extra225
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.md5().__class__.__class__.__name__ == 'type' — the HASH class is a type object."
    - "hashlib.md5().__class__.__mro__.__len__() == 2 — HASH MRO: HASH -> object (2 entries)."
    - "hashlib.md5().__class__.__mro__[0].__name__ == 'HASH' — first MRO entry is HASH itself."
    - "hashlib.md5().__class__.__mro__[1].__name__ == 'object' — second MRO entry is object."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method' — md5 is a C-level builtin."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method' — sha256 is a C-level builtin."
    - "hashlib.new.__class__.__name__ == 'function' — new is a pure Python function."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — guaranteed set."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — available set."
    - "hashlib.algorithms_guaranteed.__class__.__bases__[0].__name__ == 'object' — set base is object."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib HASH class MRO and type contracts
#
# hashlib.md5().__class__.__class__.__name__ == 'type'
# hashlib.md5().__class__.__mro__.__len__()  == 2
# hashlib.md5().__class__.__mro__[0].__name__ == 'HASH'
# hashlib.md5().__class__.__mro__[1].__name__ == 'object'
# ---------------------------------------------------------------------------

table hashlib_extra225.hash_class_mro_and_type:
  description: "hashlib HASH class MRO and type contracts in hashlib225 namespace — wave 225 theme: HASH is a type; MRO is HASH -> object (length 2); md5 and sha256 are builtin_function_or_method; new is a pure Python function; algorithms_guaranteed and algorithms_available are set instances whose class bases[0] is object; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlib225

  columns: [id, function, args, expected, description]
  rows:
    - [hash_metaclass_name,         hashlib.md5().__class__.__class__.__name__.__eq__,                 ["type"],                      true,  "hashlib.md5().__class__.__class__.__name__ == 'type' — HASH is itself a type object"]
    - [hash_mro_len,                hashlib.md5().__class__.__mro__.__len__,                           [],                            2,     "hashlib.md5().__class__.__mro__.__len__() == 2 — HASH MRO has 2 entries: HASH and object"]
    - [hash_mro_0_name,             "hashlib.md5().__class__.__mro__[0].__name__.__eq__",              ["HASH"],                      true,  "hashlib.md5().__class__.__mro__[0].__name__ == 'HASH' — first MRO entry is HASH itself"]
    - [hash_mro_1_name,             "hashlib.md5().__class__.__mro__[1].__name__.__eq__",              ["object"],                    true,  "hashlib.md5().__class__.__mro__[1].__name__ == 'object' — second MRO entry is object"]
    - [md5_class_name,              hashlib.md5.__class__.__name__.__eq__,                             ["builtin_function_or_method"], true,  "hashlib.md5.__class__.__name__ == 'builtin_function_or_method' — md5 is a C-level builtin"]
    - [sha256_class_name,           hashlib.sha256.__class__.__name__.__eq__,                          ["builtin_function_or_method"], true,  "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method' — sha256 is a C-level builtin"]
    - [new_class_name,              hashlib.new.__class__.__name__.__eq__,                             ["function"],                  true,  "hashlib.new.__class__.__name__ == 'function' — new is a pure Python dispatch function"]
    - [algorithms_guaranteed_class, hashlib.algorithms_guaranteed.__class__.__name__.__eq__,           ["set"],                       true,  "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — guaranteed algorithms is a set"]
    - [algorithms_available_class,  hashlib.algorithms_available.__class__.__name__.__eq__,            ["set"],                       true,  "hashlib.algorithms_available.__class__.__name__ == 'set' — available algorithms is a set"]
    - [set_bases_0_name,            "hashlib.algorithms_guaranteed.__class__.__bases__[0].__name__.__eq__", ["object"],               true,  "hashlib.algorithms_guaranteed.__class__.__bases__[0].__name__ == 'object' — set directly extends object"]

# ---------------------------------------------------------------------------
# Standalone invariants for HASH MRO entries using integer-indexed access
# ---------------------------------------------------------------------------

invariant hashlib_extra225.hash_mro_entry0_name_eq:
  description: "hashlib.md5().__class__.__mro__[0].__name__.__eq__('HASH') == True — first MRO entry of the HASH type is HASH itself; C-level type exposed by _hashlib extension module; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "hashlib.md5().__class__.__mro__[0].__name__.__eq__"
  args: ["HASH"]
  expected: true

invariant hashlib_extra225.hash_mro_entry1_name_eq:
  description: "hashlib.md5().__class__.__mro__[1].__name__.__eq__('object') == True — second and final MRO entry is object; HASH has no intermediate base classes; MRO terminates at object; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "hashlib.md5().__class__.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true
