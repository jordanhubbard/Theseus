spec: threading_extra2476
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2476 (_extra2476): __contains__ and __getitem__ dict-presence checks across threading types."
    - "Theme: membership-test and item-access protocol presence in class __dict__."
    - "threading.Thread: concurrency primitive — defines start/run/join/name/daemon/ident/is_alive but NOT __contains__ or __getitem__."
    - "threading.Lock: mutex primitive — defines acquire/release/locked/__enter__/__exit__ but NOT __contains__ or __getitem__."
    - "threading.Event: signaling primitive — defines is_set/set/clear/wait but NOT __contains__ or __getitem__."
    - "threading.Condition: monitor primitive — defines wait/notify/notify_all but NOT __contains__ or __getitem__."
    - "threading.Semaphore: counting primitive — defines acquire/release/__enter__/__exit__ but NOT __contains__ or __getitem__."
    - "threading.Barrier: barrier primitive — defines wait/reset/abort/parties/n_waiting/broken but NOT __contains__ or __getitem__."
    - "threading.local: thread-local storage — defines __getattribute__/__setattr__/__delattr__ but NOT __contains__ or __getitem__."
    - "No threading synchronization type defines membership-test or item-access protocols — they are synchronization primitives, not containers."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __contains__ dict-presence across threading synchronization types
#
# Threading primitives are synchronization objects, not containers.
# Thread, Lock, Event, Condition, Semaphore, Barrier, Timer, local — none
# define __contains__ in their class __dict__. All checks return False.
# ---------------------------------------------------------------------------

table threading_extra2476.contains_protocol:
  description: "threading synchronization types __contains__ dict-presence — all False — wave 2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2476

  columns: [id, function, args, expected]
  rows:
    - ["th2476001", "threading.Thread.__dict__.__contains__", ["__contains__"], false]
    - ["th2476002", "threading.Lock.__dict__.__contains__", ["__contains__"], false]
    - ["th2476003", "threading.Event.__dict__.__contains__", ["__contains__"], false]
    - ["th2476004", "threading.Condition.__dict__.__contains__", ["__contains__"], false]
    - ["th2476005", "threading.Semaphore.__dict__.__contains__", ["__contains__"], false]
    - ["th2476006", "threading.Barrier.__dict__.__contains__", ["__contains__"], false]
    - ["th2476007", "threading.local.__dict__.__contains__", ["__contains__"], false]

# ---------------------------------------------------------------------------
# Table 2: __getitem__ dict-presence across threading synchronization types
#
# No threading type defines __getitem__. These classes manage concurrency
# state and lifecycle rather than acting as key-value containers.
# All checks return False.
# ---------------------------------------------------------------------------

table threading_extra2476.getitem_protocol:
  description: "threading synchronization types __getitem__ dict-presence — all False — wave 2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2476

  columns: [id, function, args, expected]
  rows:
    - ["th2476008", "threading.Thread.__dict__.__contains__", ["__getitem__"], false]
    - ["th2476009", "threading.Lock.__dict__.__contains__", ["__getitem__"], false]
    - ["th2476010", "threading.Event.__dict__.__contains__", ["__getitem__"], false]
    - ["th2476011", "threading.Condition.__dict__.__contains__", ["__getitem__"], false]
    - ["th2476012", "threading.Semaphore.__dict__.__contains__", ["__getitem__"], false]
    - ["th2476013", "threading.Barrier.__dict__.__contains__", ["__getitem__"], false]
    - ["th2476014", "threading.local.__dict__.__contains__", ["__getitem__"], false]

# ---------------------------------------------------------------------------
# Table 3: Confirmed attrs present in threading class __dict__
#
# Threading types have rich synchronization APIs. This table confirms which
# keys ARE defined in each class __dict__ to contrast with the absent
# __contains__ and __getitem__ keys.
# ---------------------------------------------------------------------------

table threading_extra2476.confirmed_present_keys:
  description: "threading types known-present dict keys to contrast absent protocol keys — wave 2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2476

  columns: [id, function, args, expected]
  rows:
    - ["th2476015", "threading.Thread.__dict__.__contains__", ["start"], true]
    - ["th2476016", "threading.Thread.__dict__.__contains__", ["run"], true]
    - ["th2476017", "threading.Thread.__dict__.__contains__", ["join"], true]
    - ["th2476018", "threading.Thread.__dict__.__contains__", ["name"], true]
    - ["th2476019", "threading.Thread.__dict__.__contains__", ["daemon"], true]
    - ["th2476020", "threading.Thread.__dict__.__contains__", ["ident"], true]
    - ["th2476021", "threading.Thread.__dict__.__contains__", ["is_alive"], true]
    - ["th2476022", "threading.Lock.__dict__.__contains__", ["acquire"], true]
    - ["th2476023", "threading.Lock.__dict__.__contains__", ["release"], true]
    - ["th2476024", "threading.Lock.__dict__.__contains__", ["locked"], true]
    - ["th2476025", "threading.Event.__dict__.__contains__", ["is_set"], true]
    - ["th2476026", "threading.Event.__dict__.__contains__", ["set"], true]
    - ["th2476027", "threading.Event.__dict__.__contains__", ["clear"], true]
    - ["th2476028", "threading.Event.__dict__.__contains__", ["wait"], true]
    - ["th2476029", "threading.Barrier.__dict__.__contains__", ["parties"], true]
    - ["th2476030", "threading.Barrier.__dict__.__contains__", ["n_waiting"], true]
    - ["th2476031", "threading.Barrier.__dict__.__contains__", ["broken"], true]
    - ["th2476032", "threading.Barrier.__dict__.__contains__", ["reset"], true]

# ---------------------------------------------------------------------------
# Table 4: KeyError from threading class __dict__.__getitem__ for absent keys
#
# Because no threading type defines __contains__ or __getitem__ in its
# class __dict__, looking them up via __getitem__ on the class __dict__
# (a mappingproxy) raises KeyError.
# ---------------------------------------------------------------------------

table threading_extra2476.getitem_raises_keyerror:
  description: "threading class __dict__.__getitem__ raises KeyError for __contains__ and __getitem__ — wave 2476"
  kind: python_call_raises
  category: dict_contains
  id_prefix: th2476

  columns: [id, function, args, expected]
  rows:
    - ["th2476033", "threading.Thread.__dict__.__getitem__", ["__contains__"], "KeyError"]
    - ["th2476034", "threading.Thread.__dict__.__getitem__", ["__getitem__"], "KeyError"]
    - ["th2476035", "threading.Lock.__dict__.__getitem__", ["__contains__"], "KeyError"]
    - ["th2476036", "threading.Lock.__dict__.__getitem__", ["__getitem__"], "KeyError"]
    - ["th2476037", "threading.Condition.__dict__.__getitem__", ["__contains__"], "KeyError"]
    - ["th2476038", "threading.Barrier.__dict__.__getitem__", ["__getitem__"], "KeyError"]
