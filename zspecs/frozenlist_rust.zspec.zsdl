spec: frozenlist_rust
version: ">=3.9"
backend: rust_module(frozenlist_rust)

docs: https://github.com/aio-libs/frozenlist

provenance:
  derived_from:
    - "https://github.com/aio-libs/frozenlist — frozenlist"
  notes:
    - "frozenlist provides a list-like sequence that can be frozen."
    - "frozenlist.FrozenList([1, 2, 3]).freeze() disables mutation."
    - "frozenlist.FrozenList([1, 2, 3])[0] == 1."
    - "frozenlist.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant frozenlist_rust.getitem_first:
  description: "FrozenList([1, 2, 3])[0] == 1"
  category: getitem
  kind: python_call_eq
  function: frozenlist_getitem_first
  args: []
  expected: 1

invariant frozenlist_rust.len_three:
  description: "len(FrozenList([1, 2, 3])) == 3"
  category: len
  kind: python_call_eq
  function: frozenlist_len_three
  args: []
  expected: 3

invariant frozenlist_rust.version_nonempty:
  description: "frozenlist.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: frozenlist_version_nonempty
  args: []
  expected: true

