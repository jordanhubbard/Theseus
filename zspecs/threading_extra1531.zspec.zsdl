# ---------------------------------------------------------------------------
# Standalone invariants — extra1531
# ---------------------------------------------------------------------------

invariant threading_extra1531.thread_no_lt:
  description: "threading.Thread.__dict__.__contains__('__lt__') == False — Thread defines no __lt__; wave 549; new to extra1531"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__lt__"]
  expected: false

invariant threading_extra1531.thread_no_eq:
  description: "threading.Thread.__dict__.__contains__('__eq__') == False — Thread defines no __eq__; identity comparison used; wave 549; new to extra1531"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__eq__"]
  expected: false

