spec: asyncio_extra246
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py and Modules/_asynciomodule.c (internal implementation)"
  notes:
    - "This spec covers asyncio.create_task and asyncio.current_task function identity."
    - "asyncio.create_task.__module__ == 'asyncio.tasks' (len=13) — defined in Lib/asyncio/tasks.py."
    - "asyncio.current_task.__module__ == '_asyncio' (len=8) — defined in C extension _asynciomodule.c."
    - "asyncio.create_task.__class__.__name__ == 'function' — Python function in asyncio.tasks."
    - "asyncio.current_task.__class__.__name__ == 'builtin_function_or_method' — C builtin in _asyncio."
    - "asyncio.create_task.__name__.__len__() == 11 ('create_task' is 11 chars)."
    - "asyncio.current_task.__name__.__len__() == 12 ('current_task' is 12 chars)."
    - "Both functions have __qualname__ equal to __name__ (module-level)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.create_task function identity
#
# asyncio.create_task is a Python function defined in asyncio.tasks.
# __name__ == 'create_task' (len=11)
# __module__ == 'asyncio.tasks' (len=13)
# __qualname__ == 'create_task' (len=11)
# __class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table asyncio_extra246.create_task_identity:
  description: "asyncio.create_task function identity checks — create_task is a Python function defined in asyncio.tasks; create_task.__name__.__eq__('create_task')==True (len=11); create_task.__module__.__eq__('asyncio.tasks')==True (len=13); create_task.__qualname__.__eq__('create_task')==True (len=11, module-level function so qualname equals name); create_task.__class__.__name__.__eq__('function')==True; create_task.__name__.__len__()==11; create_task.__module__.__len__()==13; verified with Python 3.14.3"
  kind: python_call_eq
  category: create_task_identity
  id_prefix: aiocreate246

  columns: [id, function, args, expected, description]
  rows:
    - [ct_name_eq,    create_task.__name__.__eq__,           ["create_task"],    true, "asyncio.create_task.__name__ == 'create_task'; verified with Python 3.14.3"]
    - [ct_name_len,   create_task.__name__.__len__,          [],                 11,   "asyncio.create_task.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [ct_module_eq,  create_task.__module__.__eq__,         ["asyncio.tasks"],  true, "asyncio.create_task.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [ct_module_len, create_task.__module__.__len__,        [],                 13,   "asyncio.create_task.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [ct_qname_eq,   create_task.__qualname__.__eq__,       ["create_task"],    true, "asyncio.create_task.__qualname__ == 'create_task' (len=11, qualname equals name); verified with Python 3.14.3"]
    - [ct_qname_len,  create_task.__qualname__.__len__,      [],                 11,   "asyncio.create_task.__qualname__.__len__() == 11; verified with Python 3.14.3"]
    - [ct_cls_nm,     create_task.__class__.__name__.__eq__, ["function"],       true, "asyncio.create_task.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.current_task function identity
#
# asyncio.current_task is a C builtin defined in _asyncio (C extension).
# __name__ == 'current_task' (len=12)
# __module__ == '_asyncio' (len=8)
# __qualname__ == 'current_task' (len=12)
# __class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table asyncio_extra246.current_task_identity:
  description: "asyncio.current_task function identity checks — current_task is a C builtin defined in the _asyncio C extension; current_task.__name__.__eq__('current_task')==True (len=12); current_task.__module__.__eq__('_asyncio')==True (len=8, C extension module, shorter than create_task.__module__.__len__()==13); current_task.__qualname__.__eq__('current_task')==True (len=12); current_task.__class__.__name__.__eq__('builtin_function_or_method')==True (C builtin, not a Python function); current_task.__name__.__len__()==12 (one more than create_task.__name__.__len__()==11); verified with Python 3.14.3"
  kind: python_call_eq
  category: current_task_identity
  id_prefix: aiocurrtask246

  columns: [id, function, args, expected, description]
  rows:
    - [cur_name_eq,    current_task.__name__.__eq__,           ["current_task"],             true, "asyncio.current_task.__name__ == 'current_task'; verified with Python 3.14.3"]
    - [cur_name_len,   current_task.__name__.__len__,          [],                           12,   "asyncio.current_task.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [cur_module_eq,  current_task.__module__.__eq__,         ["_asyncio"],                 true, "asyncio.current_task.__module__ == '_asyncio' (C extension); verified with Python 3.14.3"]
    - [cur_module_len, current_task.__module__.__len__,        [],                           8,    "asyncio.current_task.__module__.__len__() == 8; verified with Python 3.14.3"]
    - [cur_qname_eq,   current_task.__qualname__.__eq__,       ["current_task"],             true, "asyncio.current_task.__qualname__ == 'current_task' (len=12, qualname equals name); verified with Python 3.14.3"]
    - [cur_qname_len,  current_task.__qualname__.__len__,      [],                           12,   "asyncio.current_task.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [cur_cls_nm,     current_task.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "asyncio.current_task.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra246
# ---------------------------------------------------------------------------

invariant asyncio_extra246.create_task_module_is_asyncio_tasks:
  description: "asyncio.create_task.__module__.__eq__('asyncio.tasks') returns True — create_task is defined in Lib/asyncio/tasks.py; __module__ == 'asyncio.tasks' (len=13); contrast current_task.__module__ == '_asyncio' (len=8, C extension); create_task.__name__ is 'create_task' (len=11); create_task.__qualname__ equals __name__; create_task.__class__.__name__ == 'function'; NEW in extra246: first standalone create_task module invariant in aiocreate246 namespace; verified with Python 3.14.3"
  category: create_task_identity
  kind: python_call_eq
  function: create_task.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra246.create_task_name_len_11:
  description: "asyncio.create_task.__name__.__len__() == 11 — 'create_task' has 11 chars: c-r-e-a-t-e-_-t-a-s-k; compare current_task.__name__.__len__()==12 (one more); create_task.__module__.__len__()==13 ('asyncio.tasks'); create_task.__qualname__.__len__()==11 (same as __name__.__len__()); create_task.__class__.__name__ == 'function'; NEW in extra246: first standalone create_task name length invariant; verified with Python 3.14.3"
  category: create_task_identity
  kind: python_call_eq
  function: create_task.__name__.__len__
  args: []
  expected: 11

invariant asyncio_extra246.create_task_class_is_function:
  description: "asyncio.create_task.__class__.__name__.__eq__('function') returns True — create_task is a Python function (not a C builtin); __class__.__name__ == 'function'; contrast with current_task.__class__.__name__ == 'builtin_function_or_method' (len=26); create_task.__module__ == 'asyncio.tasks' (len=13); create_task.__name__ == 'create_task' (len=11); NEW in extra246: first standalone create_task class invariant; verified with Python 3.14.3"
  category: create_task_identity
  kind: python_call_eq
  function: create_task.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra246.current_task_module_is_asyncio_c:
  description: "asyncio.current_task.__module__.__eq__('_asyncio') returns True — current_task is defined in the C extension _asyncio (Modules/_asynciomodule.c); __module__ == '_asyncio' (len=8); contrast create_task.__module__ == 'asyncio.tasks' (len=13, Python module); current_task.__name__ is 'current_task' (len=12); current_task.__class__.__name__ == 'builtin_function_or_method'; NEW in extra246: first standalone current_task module invariant in aiocurrtask246 namespace; verified with Python 3.14.3"
  category: current_task_identity
  kind: python_call_eq
  function: current_task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra246.current_task_name_len_12:
  description: "asyncio.current_task.__name__.__len__() == 12 — 'current_task' has 12 chars: c-u-r-r-e-n-t-_-t-a-s-k; one more than create_task.__name__.__len__()==11 ('create_task'); current_task.__module__.__len__()==8 ('_asyncio'); current_task.__qualname__.__len__()==12 (same as __name__.__len__()); current_task.__class__.__name__ == 'builtin_function_or_method'; NEW in extra246: first standalone current_task name length invariant; verified with Python 3.14.3"
  category: current_task_identity
  kind: python_call_eq
  function: current_task.__name__.__len__
  args: []
  expected: 12

invariant asyncio_extra246.current_task_class_is_builtin:
  description: "asyncio.current_task.__class__.__name__.__eq__('builtin_function_or_method') returns True — current_task is a C builtin (not a Python function); __class__.__name__ == 'builtin_function_or_method' (len=26); contrast with create_task.__class__.__name__ == 'function'; current_task.__module__ == '_asyncio' (len=8); current_task.__name__ == 'current_task' (len=12); the C implementation provides current_task as a builtin for performance; NEW in extra246: first standalone current_task class invariant; verified with Python 3.14.3"
  category: current_task_identity
  kind: python_call_eq
  function: current_task.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant asyncio_extra246.create_task_qualname_eq_name:
  description: "asyncio.create_task.__qualname__.__eq__('create_task') returns True — create_task is a module-level function so qualname equals name; __qualname__ == 'create_task' (len=11); same as __name__ == 'create_task' (len=11); compare: a method's qualname would be 'ClassName.method_name'; create_task.__module__ == 'asyncio.tasks' (len=13); create_task.__class__.__name__ == 'function'; NEW in extra246: first standalone create_task qualname invariant; verified with Python 3.14.3"
  category: create_task_identity
  kind: python_call_eq
  function: create_task.__qualname__.__eq__
  args: ["create_task"]
  expected: true
