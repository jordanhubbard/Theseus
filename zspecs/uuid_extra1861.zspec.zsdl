spec: uuid_extra1861
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python uuid documentation — https://docs.python.org/3/library/uuid.html"
    - "RFC 9562 — Universally Unique IDentifiers (UUID)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 571: bitwise and in-place operators for uuid module classes"
    - "UUID is not a numeric bit type; it does not define bitwise operators in its own __dict__"
    - "SafeUUID is an IntEnum but __or__/__and__ live in IntEnum/int, not in SafeUUID.__dict__ directly"
    - "uuid6/uuid7/uuid8 are not part of the standard library as of Python 3.12"
  created_at: "2026-04-12"

table uuid_extra1861.bitwise_operators:
  columns: [id, function, args, expected]
  rows:
    - ["uu1861-bit-001", "uuid.UUID.__dict__.__contains__", ["__or__"], false]
    - ["uu1861-bit-002", "uuid.UUID.__dict__.__contains__", ["__and__"], false]
    - ["uu1861-bit-003", "uuid.UUID.__dict__.__contains__", ["__xor__"], false]
    - ["uu1861-bit-004", "uuid.UUID.__dict__.__contains__", ["__lshift__"], false]
    - ["uu1861-bit-005", "uuid.UUID.__dict__.__contains__", ["__rshift__"], false]
    - ["uu1861-bit-006", "uuid.UUID.__dict__.__contains__", ["__invert__"], false]
    - ["uu1861-bit-007", "uuid.SafeUUID.__dict__.__contains__", ["__or__"], false]
    - ["uu1861-bit-008", "uuid.SafeUUID.__dict__.__contains__", ["__and__"], false]

table uuid_extra1861.inplace_operators:
  columns: [id, function, args, expected]
  rows:
    - ["uu1861-iop-001", "uuid.UUID.__dict__.__contains__", ["__iadd__"], false]
    - ["uu1861-iop-002", "uuid.UUID.__dict__.__contains__", ["__isub__"], false]
    - ["uu1861-iop-003", "uuid.UUID.__dict__.__contains__", ["__imul__"], false]
    - ["uu1861-iop-004", "uuid.UUID.__dict__.__contains__", ["__ior__"], false]
    - ["uu1861-iop-005", "uuid.UUID.__dict__.__contains__", ["__iand__"], false]
    - ["uu1861-iop-006", "uuid.SafeUUID.__dict__.__contains__", ["__iadd__"], false]
    - ["uu1861-iop-007", "uuid.SafeUUID.__dict__.__contains__", ["__ior__"], false]
    - ["uu1861-iop-008", "uuid.UUID.__dict__.__contains__", ["__ifloordiv__"], false]

table uuid_extra1861.uuid_generation_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["uu1861-gen-001", "uuid.__dict__.__contains__", ["uuid1"], true]
    - ["uu1861-gen-002", "uuid.__dict__.__contains__", ["uuid3"], true]
    - ["uu1861-gen-003", "uuid.__dict__.__contains__", ["uuid4"], true]
    - ["uu1861-gen-004", "uuid.__dict__.__contains__", ["uuid5"], true]
    - ["uu1861-gen-005", "uuid.__dict__.__contains__", ["uuid6"], false]
    - ["uu1861-gen-006", "uuid.__dict__.__contains__", ["uuid7"], false]
    - ["uu1861-gen-007", "uuid.__dict__.__contains__", ["uuid8"], false]
    - ["uu1861-gen-008", "uuid.__dict__.__contains__", ["getnode"], true]
    - ["uu1861-gen-009", "uuid.__dict__.__contains__", ["RESERVED_NCS"], true]
    - ["uu1861-gen-010", "uuid.__dict__.__contains__", ["RFC_4122"], true]
