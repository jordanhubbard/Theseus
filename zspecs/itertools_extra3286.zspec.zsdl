spec: it3286
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 666 (it3286): __iadd__, __isub__, __imul__ dict-presence checks for itertools types."
    - "Theme: __iadd__/__isub__/__imul__ in-place arithmetic dict-presence."
    - "In-place augmented assignment operators (+=, -=, *=) fall back to __add__/__sub__/__mul__ if not defined."
    - "All values False — callable/iterator/inspection/synchronization types have no in-place arithmetic operators."
    - "No itertools iterator type defines __iadd__, __isub__, or __imul__ in its own __dict__."
    - "All 18 itertools iterator types are C-level types; they implement iterator protocol (__iter__/__next__), not in-place arithmetic protocols."
    - "itertools.pairwise requires Python >= 3.10."
    - "All 18 itertools iterator types are checked."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

