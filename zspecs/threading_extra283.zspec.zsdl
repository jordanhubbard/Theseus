spec: threading_extra283
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Lock.__name__ == 'lock' (lowercase) — the underlying C type is named 'lock', not 'Lock'."
    - "threading.Lock.__module__ == '_thread' — Lock is implemented in the _thread C extension."
    - "threading.Lock.__doc__ is not None — the C type ships with a docstring."
    - "threading.Thread.__name__ == 'Thread'; __module__ == 'threading' — pure-Python class."
    - "threading.Thread.__doc__ is not None — Thread ships with a docstring."
    - "threading.local.__name__ == '_local' (underscore prefix) — the underlying C type is named '_local'."
    - "threading.local.__module__ == '_thread' — local is implemented in the _thread C extension."
    - "threading.local.__doc__ == 'Thread-local data' — the exact docstring on Python 3.14.3."
    - "threading.Condition.__name__ == 'Condition'; __module__ == 'threading' — pure-Python class."
    - "threading.Condition.__doc__ is not None — Condition ships with a docstring."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Lock and threading.local — C-extension type identity
#
# Lock.__name__ == 'lock' (lowercase) — the C type is named 'lock'.
# Lock.__module__ == '_thread' — implemented in the _thread C extension.
# local.__name__ == '_local' — the C type is named '_local'.
# local.__module__ == '_thread' — implemented in the _thread C extension.
# local.__doc__ == 'Thread-local data' — exact docstring on Python 3.14.3.
# ---------------------------------------------------------------------------

table threading_extra283.c_extension_types:
  description: "threading.Lock and threading.local — C-extension type identity, __name__, __module__, docstrings; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex283ct

  columns: [id, function, args, expected, description]
  rows:
    - [ct_lock_name,   Lock.__name__.__eq__,                ["lock"],          true,  "threading.Lock.__name__ == 'lock' (lowercase — C type name); verified with Python 3.14.3"]
    - [ct_lock_mod,    Lock.__module__.__eq__,               ["_thread"],       true,  "threading.Lock.__module__ == '_thread' (C extension); verified with Python 3.14.3"]
    - [ct_lock_cls,    Lock.__class__.__name__.__eq__,       ["type"],          true,  "threading.Lock.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [ct_lock_doc,    Lock.__doc__.__eq__,                  [null],            false, "threading.Lock.__doc__ is not None — Lock ships with a docstring; verified with Python 3.14.3"]
    - [ct_local_name,  local.__name__.__eq__,                ["_local"],        true,  "threading.local.__name__ == '_local' (underscore prefix — C type name); verified with Python 3.14.3"]
    - [ct_local_mod,   local.__module__.__eq__,              ["_thread"],       true,  "threading.local.__module__ == '_thread' (C extension); verified with Python 3.14.3"]
    - [ct_local_doc,   local.__doc__.__eq__,                 ["Thread-local data"], true, "threading.local.__doc__ == 'Thread-local data'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.Thread and threading.Condition — pure-Python class identity
#
# Thread.__name__ == 'Thread'; __module__ == 'threading'; __doc__ is not None.
# Condition.__name__ == 'Condition'; __module__ == 'threading'; __doc__ is not None.
# ---------------------------------------------------------------------------

table threading_extra283.pure_python_classes:
  description: "threading.Thread and threading.Condition — pure-Python class identity and docstrings; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex283pp

  columns: [id, function, args, expected, description]
  rows:
    - [pp_thr_name,  Thread.__name__.__eq__,              ["Thread"],    true,  "threading.Thread.__name__ == 'Thread'; verified with Python 3.14.3"]
    - [pp_thr_mod,   Thread.__module__.__eq__,             ["threading"], true,  "threading.Thread.__module__ == 'threading' (pure-Python); verified with Python 3.14.3"]
    - [pp_thr_cls,   Thread.__class__.__name__.__eq__,     ["type"],      true,  "threading.Thread.__class__.__name__ == 'type' (it is a class); verified with Python 3.14.3"]
    - [pp_thr_doc,   Thread.__doc__.__eq__,                [null],        false, "threading.Thread.__doc__ is not None — Thread ships with a docstring; verified with Python 3.14.3"]
    - [pp_cond_name, Condition.__name__.__eq__,            ["Condition"], true,  "threading.Condition.__name__ == 'Condition'; verified with Python 3.14.3"]
    - [pp_cond_mod,  Condition.__module__.__eq__,          ["threading"], true,  "threading.Condition.__module__ == 'threading' (pure-Python); verified with Python 3.14.3"]
    - [pp_cond_cls,  Condition.__class__.__name__.__eq__,  ["type"],      true,  "threading.Condition.__class__.__name__ == 'type' (it is a class); verified with Python 3.14.3"]
    - [pp_cond_doc,  Condition.__doc__.__eq__,             [null],        false, "threading.Condition.__doc__ is not None — Condition ships with a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra283
# ---------------------------------------------------------------------------

invariant threading_extra283.lock_name_is_lowercase_lock:
  description: "threading.Lock.__name__ == 'lock' — the underlying C type name is lowercase 'lock', not 'Lock'"
  category: identity
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra283.lock_module_is_thread:
  description: "threading.Lock.__module__ == '_thread' — Lock is implemented in the _thread C extension"
  category: identity
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra283.lock_has_docstring:
  description: "threading.Lock.__doc__.__eq__(None) == False — Lock ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: Lock.__doc__.__eq__
  args: [null]
  expected: false

invariant threading_extra283.thread_has_docstring:
  description: "threading.Thread.__doc__.__eq__(None) == False — Thread ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: Thread.__doc__.__eq__
  args: [null]
  expected: false

invariant threading_extra283.thread_module_is_threading:
  description: "threading.Thread.__module__ == 'threading' — Thread is defined in the pure-Python threading module"
  category: identity
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra283.local_name_is_underscore_local:
  description: "threading.local.__name__ == '_local' — the C type is named '_local' with an underscore prefix"
  category: identity
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra283.local_doc_is_thread_local_data:
  description: "threading.local.__doc__ == 'Thread-local data' — exact docstring of the _local C type"
  category: identity
  kind: python_call_eq
  function: local.__doc__.__eq__
  args: ["Thread-local data"]
  expected: true

invariant threading_extra283.local_module_is_thread:
  description: "threading.local.__module__ == '_thread' — local is implemented in the _thread C extension"
  category: identity
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra283.condition_has_docstring:
  description: "threading.Condition.__doc__.__eq__(None) == False — Condition ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: Condition.__doc__.__eq__
  args: [null]
  expected: false

invariant threading_extra283.condition_module_is_threading:
  description: "threading.Condition.__module__ == 'threading' — Condition is defined in the pure-Python threading module"
  category: identity
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["threading"]
  expected: true
