spec: re_extra190
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.Pattern.flags.__class__.__name__ == 'member_descriptor' — NOT getset_descriptor; confirmed Python 3.14.3 macOS."
    - "re.Pattern.groups.__class__.__name__ == 'member_descriptor' — NOT getset_descriptor; confirmed Python 3.14.3 macOS."
    - "re.Pattern.groupindex.__class__.__name__ == 'getset_descriptor' — the one exception among the four attributes; confirmed Python 3.14.3 macOS."
    - "re.Pattern.pattern.__class__.__name__ == 'member_descriptor' — NOT getset_descriptor; confirmed Python 3.14.3 macOS."
    - "re.Pattern.__name__ == 'Pattern' (len=7)."
    - "re.Pattern.__module__ == 're' — exposed in the re namespace even though the C type lives in _sre."
    - "re.Pattern.__qualname__ == 'Pattern' (no enclosing class, top-level name)."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits directly from object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Pattern attribute descriptor types
# flags, groups, pattern => member_descriptor; groupindex => getset_descriptor
# ---------------------------------------------------------------------------

table re_extra190.pattern_attr_descriptor_types:
  description: "re.Pattern attribute descriptor types: flags/groups/pattern are member_descriptor; groupindex is getset_descriptor"
  kind: python_call_eq
  category: identity
  id_prefix: repatternattrs190

  columns: [id, function, args, expected, description]
  rows:
    - [flags_cls_eq,      re.Pattern.flags.__class__.__name__.__eq__,      ["member_descriptor"],  true, "re.Pattern.flags.__class__.__name__ == 'member_descriptor'; confirmed Python 3.14.3 macOS"]
    - [groups_cls_eq,     re.Pattern.groups.__class__.__name__.__eq__,     ["member_descriptor"],  true, "re.Pattern.groups.__class__.__name__ == 'member_descriptor'; confirmed Python 3.14.3 macOS"]
    - [groupindex_cls_eq, re.Pattern.groupindex.__class__.__name__.__eq__, ["getset_descriptor"],  true, "re.Pattern.groupindex.__class__.__name__ == 'getset_descriptor'; confirmed Python 3.14.3 macOS"]
    - [pattern_cls_eq,    re.Pattern.pattern.__class__.__name__.__eq__,    ["member_descriptor"],  true, "re.Pattern.pattern.__class__.__name__ == 'member_descriptor'; confirmed Python 3.14.3 macOS"]
    - [flags_cls_len,     re.Pattern.flags.__class__.__name__.__len__,     [],                     17,   "re.Pattern.flags.__class__.__name__ 'member_descriptor' length == 17; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.Pattern class identity — __name__, __module__, __qualname__
# ---------------------------------------------------------------------------

table re_extra190.pattern_class_identity:
  description: "re.Pattern class identity: __name__=='Pattern'(7), __module__=='re', __qualname__=='Pattern'"
  kind: python_call_eq
  category: identity
  id_prefix: repatternattrs190

  columns: [id, function, args, expected, description]
  rows:
    - [patt_name_eq,     re.Pattern.__name__.__eq__,     ["Pattern"], true, "re.Pattern.__name__ == 'Pattern'; confirmed Python 3.14.3 macOS"]
    - [patt_name_len,    re.Pattern.__name__.__len__,    [],          7,    "re.Pattern.__name__.__len__() == 7 — P(1)a(2)t(3)t(4)e(5)r(6)n(7); confirmed Python 3.14.3 macOS"]
    - [patt_module_eq,   re.Pattern.__module__.__eq__,   ["re"],      true, "re.Pattern.__module__ == 're'; confirmed Python 3.14.3 macOS"]
    - [patt_qualname_eq, re.Pattern.__qualname__.__eq__, ["Pattern"], true, "re.Pattern.__qualname__ == 'Pattern'; confirmed Python 3.14.3 macOS"]
    - [patt_module_len,  re.Pattern.__module__.__len__,  [],          2,    "re.Pattern.__module__ 're' length == 2; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.Pattern inheritance — __bases__[0].__name__
# Pattern inherits directly from object
# ---------------------------------------------------------------------------

table re_extra190.pattern_bases_identity:
  description: "re.Pattern base class identity: __bases__[0].__name__=='object', confirming Pattern inherits directly from object"
  kind: python_call_eq
  category: identity
  id_prefix: repatternattrs190

  columns: [id, function, args, expected, description]
  rows:
    - [base0_name_eq,    "re.Pattern.__bases__[0].__name__.__eq__",    ["object"], true, "re.Pattern.__bases__[0].__name__ == 'object'; confirmed Python 3.14.3 macOS"]
    - [base0_name_len,   "re.Pattern.__bases__[0].__name__.__len__",   [],         6,    "re.Pattern.__bases__[0].__name__.__len__() == 6 — o(1)b(2)j(3)e(4)c(5)t(6); confirmed Python 3.14.3 macOS"]
    - [patt_name_eq2,    re.Pattern.__name__.__eq__,                   ["Pattern"], true, "re.Pattern.__name__ == 'Pattern' (cross-table confirmation); confirmed Python 3.14.3 macOS"]
    - [groupix_cls_eq2,  re.Pattern.groupindex.__class__.__name__.__eq__, ["getset_descriptor"], true, "re.Pattern.groupindex.__class__.__name__ == 'getset_descriptor' (cross-table confirmation); confirmed Python 3.14.3 macOS"]
    - [patt_cls_eq2,     re.Pattern.pattern.__class__.__name__.__eq__, ["member_descriptor"], true, "re.Pattern.pattern.__class__.__name__ == 'member_descriptor' (cross-table confirmation); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra190.flags_is_member_descriptor:
  description: "re.Pattern.flags.__class__.__name__ == 'member_descriptor' — flags is a C struct member slot, not a computed getset; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.flags.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra190.groups_is_member_descriptor:
  description: "re.Pattern.groups.__class__.__name__ == 'member_descriptor' — groups is a C struct member slot; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.groups.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra190.groupindex_is_getset_descriptor:
  description: "re.Pattern.groupindex.__class__.__name__ == 'getset_descriptor' — groupindex uses a getter/setter pair in the C type; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.groupindex.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant re_extra190.pattern_is_member_descriptor:
  description: "re.Pattern.pattern.__class__.__name__ == 'member_descriptor' — pattern is a C struct member slot; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.pattern.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra190.pattern_name_eq:
  description: "re.Pattern.__name__ == 'Pattern' — the class name of the compiled regular expression type; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra190.pattern_name_len_7:
  description: "re.Pattern.__name__.__len__() == 7 — 'Pattern' has 7 characters: P(1)a(2)t(3)t(4)e(5)r(6)n(7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__name__.__len__
  args: []
  expected: 7

invariant re_extra190.pattern_module_eq:
  description: "re.Pattern.__module__ == 're' — exposed in the re namespace; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra190.pattern_bases_object:
  description: "re.Pattern.__bases__[0].__name__ == 'object' — Pattern inherits directly from object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "re.Pattern.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
