spec: hashlib_extra227
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.__doc__.__contains__('hash') == True — module docstring contains 'hash'."
    - "hashlib.md5.__doc__.__contains__('md5') == True — md5 function docstring contains 'md5'."
    - "hashlib.new.__doc__.__contains__('hash') == True — new() docstring contains 'hash'."
    - "hashlib.md5().__class__.__doc__.__contains__('hash') == True — HASH class docstring contains 'hash'."
    - "hashlib.algorithms_guaranteed.__class__.__doc__.__contains__('unique') == True — set docstring contains 'unique'."
    - "hashlib.sha256().__class__.__name__ == 'HASH' — sha256() returns a HASH instance."
    - "hashlib.sha256(b'abc').hexdigest().__len__() == 64 — SHA-256 hex digest is 64 characters."
    - "hashlib.sha256(b'abc').hexdigest() == 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad'."
    - "hashlib.md5(b'abc').hexdigest() == '900150983cd24fb0d6963f7d28e17f72'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib __doc__ contains checks
#
# hashlib.__doc__.__contains__('hash')                     == True
# hashlib.md5.__doc__.__contains__('md5')                  == True
# hashlib.new.__doc__.__contains__('hash')                 == True
# hashlib.md5().__class__.__doc__.__contains__('hash')     == True
# hashlib.algorithms_guaranteed.__class__.__doc__.__contains__('unique') == True
# ---------------------------------------------------------------------------

table hashlib_extra227.doc_contains_checks:
  description: "hashlib __doc__ contains checks in hashlib227 namespace — wave 227 theme: module docstring contains 'hash'; md5 function docstring contains 'md5'; new() docstring contains 'hash'; HASH class docstring contains 'hash' (not 'HASH' — confirmed False); algorithms_guaranteed is a set whose docstring contains 'unique'; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: doc_contains
  id_prefix: hashlib227

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_hash,       hashlib.__doc__.__contains__,                                ["hash"],   true, "hashlib.__doc__.__contains__('hash') == True — module docstring mentions hash"]
    - [md5_doc_md5,           hashlib.md5.__doc__.__contains__,                            ["md5"],    true, "hashlib.md5.__doc__.__contains__('md5') == True — md5 function docstring mentions md5"]
    - [new_doc_hash,          hashlib.new.__doc__.__contains__,                            ["hash"],   true, "hashlib.new.__doc__.__contains__('hash') == True — new() docstring mentions hash"]
    - [hash_class_doc_hash,   hashlib.md5().__class__.__doc__.__contains__,                ["hash"],   true, "hashlib.md5().__class__.__doc__.__contains__('hash') == True — HASH class docstring mentions hash"]
    - [alg_set_doc_unique,    hashlib.algorithms_guaranteed.__class__.__doc__.__contains__, ["unique"], true, "hashlib.algorithms_guaranteed.__class__.__doc__.__contains__('unique') == True — set docstring contains 'unique'"]

# ---------------------------------------------------------------------------
# hashlib sha256 class name, hexdigest length, and known digest values
#
# hashlib.sha256().__class__.__name__           == 'HASH'
# hashlib.sha256(b'abc').hexdigest().__len__()  == 64
# hashlib.sha256(b'abc').hexdigest()            == 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad'
# hashlib.md5(b'abc').hexdigest()               == '900150983cd24fb0d6963f7d28e17f72'
# ---------------------------------------------------------------------------

table hashlib_extra227.sha256_md5_digest_checks:
  description: "hashlib sha256 class name, hexdigest length, and known digest value checks in hashlib227a namespace — wave 227 theme: sha256() class is HASH; sha256(b'abc') hex digest is 64 chars; full SHA-256 digest of 'abc'; full MD5 digest of 'abc'; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: digest_values
  id_prefix: hashlib227a

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_class_name,     hashlib.sha256().__class__.__name__.__eq__,              ["HASH"],                                                                    true, "hashlib.sha256().__class__.__name__ == 'HASH' — sha256() returns a HASH instance"]
    - [sha256_hexlen,         hashlib.sha256(b'abc').hexdigest().__len__,              [],                                                                          64,   "hashlib.sha256(b'abc').hexdigest().__len__() == 64 — SHA-256 hex digest is 64 characters"]
    - [sha256_abc_hexdigest,  hashlib.sha256(b'abc').hexdigest.__eq__,                 ["ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"],        true, "hashlib.sha256(b'abc').hexdigest() == 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad' — SHA-256 of b'abc'"]
    - [md5_abc_hexdigest,     hashlib.md5(b'abc').hexdigest.__eq__,                    ["900150983cd24fb0d6963f7d28e17f72"],                                        true, "hashlib.md5(b'abc').hexdigest() == '900150983cd24fb0d6963f7d28e17f72' — MD5 of b'abc'"]

# ---------------------------------------------------------------------------
# Standalone invariants for hashlib __doc__ contains checks
# ---------------------------------------------------------------------------

invariant hashlib_extra227.module_doc_contains_hash:
  description: "hashlib.__doc__.__contains__('hash') == True — hashlib module docstring is 'hashlib module - A common interface to many hash functions.\\n...' which contains 'hash'; confirms module docstring is present and identifies the module purpose; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: hashlib.__doc__.__contains__
  args: ["hash"]
  expected: true

invariant hashlib_extra227.sha256_hexdigest_len_64:
  description: "hashlib.sha256(b'abc').hexdigest().__len__() == 64 — SHA-256 produces a 256-bit (32-byte) digest; hex encoding doubles the byte count to 64 hex characters; confirmed with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: digest_values
  kind: python_call_eq
  function: hashlib.sha256(b'abc').hexdigest().__len__
  args: []
  expected: 64

invariant hashlib_extra227.sha256_abc_full_digest:
  description: "hashlib.sha256(b'abc').hexdigest.__eq__('ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad') == True — SHA-256 of ASCII 'abc' is a well-known FIPS 180-4 test vector; full 64-character hex string; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: digest_values
  kind: python_call_eq
  function: hashlib.sha256(b'abc').hexdigest.__eq__
  args: ["ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"]
  expected: true
