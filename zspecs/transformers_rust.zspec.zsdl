spec: transformers_rust
version: ">=3.9"
backend: rust_module(transformers_rust)

docs: https://huggingface.co/docs/transformers/index

provenance:
  derived_from:
    - "https://huggingface.co/docs/transformers/index — Transformers documentation"
  not_derived_from:
    - "transformers source: transformers/configuration_utils.py"
  notes:
    - "HuggingFace Transformers provides pre-trained models."
    - "AutoConfig is available in transformers namespace."
    - "transformers.__version__ is a non-empty string."
    - "transformers.AutoConfig.__name__ == 'AutoConfig'."
    - "transformers.AutoTokenizer.__name__ == 'AutoTokenizer'."
    - "transformers.AutoModel.__name__ == 'AutoModel'."
    - "Expose transformers_version() -> str: transformers.__version__."
    - "Expose transformers_has_auto_config() -> bool: hasattr(transformers, 'AutoConfig')."
    - "Expose transformers_autoconfig_name() -> str: transformers.AutoConfig.__name__."
    - "All test vectors verified against transformers 4.49.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# transformers_version — version string is non-empty
invariant transformers_rust.version.nonempty:
  description: "transformers.__version__ is a non-empty string"
  category: version
  kind: python_call_eq
  function: transformers_has_auto_config
  args: []
  expected: true

# transformers_autoconfig_name — class name check
invariant transformers_rust.autoconfig.class_name:
  description: "AutoConfig.__name__ == 'AutoConfig'"
  category: autoconfig
  kind: python_call_eq
  function: transformers_autoconfig_name
  args: []
  expected: "AutoConfig"

# transformers class presence checks
table transformers_rust.classes.present:
  kind: python_call_eq
  category: class_presence
  id_prefix: tf_cls
  function: transformers_has_class

  columns: [id, args, expected]
  rows:
    - [auto_config,    ["AutoConfig"],    true]
    - [auto_tokenizer, ["AutoTokenizer"], true]
    - [auto_model,     ["AutoModel"],     true]
    - [pipeline,       ["pipeline"],      true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:11:26Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
