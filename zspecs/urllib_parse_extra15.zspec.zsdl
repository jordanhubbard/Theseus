spec: urllib_parse_extra15
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html
rfcs:
  - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
    - "urllib_parse_extra4.zspec.zsdl — covers __qualname__.__eq__ for urlparse/urlsplit/urljoin/urlencode/quote/unquote and ParseResult/SplitResult/DefragResult."
    - "urllib_parse_extra5.zspec.zsdl — covers __qualname__.__eq__ for quote_plus/unquote_plus/parse_qs/parse_qsl."
    - "urllib_parse_extra14.zspec.zsdl — covers __qualname__.__len__() for urlparse/urlencode/quote/unquote/urljoin/urlsplit and result classes ParseResult/SplitResult."
  notes:
    - "This spec extends the urllib_parse chain through urllib_parse_extra14; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) __qualname__.__eq__ for urlunparse — not covered by extra4 (which covers urlparse/urlsplit/urljoin/urlencode/quote/unquote only); (2) __qualname__.__len__() for urlunparse/quote_plus/unquote_plus — extra14 covers lengths for urlparse/urlencode/quote/unquote/urljoin/urlsplit but NOT urlunparse/quote_plus/unquote_plus; (3) standalone cross-namespace qualname checks for quote_plus and unquote_plus."
    - "urllib.parse.urlunparse.__qualname__ == 'urlunparse' — extra4 does not include urlunparse in its __qualname__.__eq__ table; extra_base covers urlunparse behavioral only. No prior spec checks urlunparse.__qualname__.__eq__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.urlunparse.__qualname__.__len__() == 10 — len('urlunparse') == 10. No prior spec checks urlunparse.__qualname__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.quote_plus.__qualname__.__len__() == 10 — len('quote_plus') == 10. extra5 checks __qualname__.__eq__; extra14 checks lengths for quote (5) and unquote (7) but not quote_plus. No prior spec checks quote_plus.__qualname__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "urllib.parse.unquote_plus.__qualname__.__len__() == 12 — len('unquote_plus') == 12. Same rationale as quote_plus. No prior spec checks unquote_plus.__qualname__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# urlunparse __qualname__.__eq__
#
# urllib_parse_extra4 covers __qualname__.__eq__ for urlparse/urlsplit/urljoin/
# urlencode/quote/unquote. urllib_parse_extra5 adds quote_plus/unquote_plus/
# parse_qs/parse_qsl. urlunparse is not included in either table.
# urllib.parse.urlunparse.__qualname__ == 'urlunparse'. Verified Python 3.12.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra15.urlunparse.qualname_eq:
  description: "urllib.parse.urlunparse.__qualname__ == 'urlunparse' — no prior spec checks this attribute"
  category: function_qualnames
  kind: python_call_eq
  function: urlunparse.__qualname__.__eq__
  args: ["urlunparse"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__.__len__() for urlunparse, quote_plus, unquote_plus
#
# urllib_parse_extra14 covers __qualname__.__len__() for urlparse/urlencode/
# quote/unquote/urljoin/urlsplit. It does NOT cover urlunparse, quote_plus,
# or unquote_plus. No prior spec checks __qualname__.__len__() for any of
# these three functions.
# len('urlunparse') == 10; len('quote_plus') == 10; len('unquote_plus') == 12.
# ---------------------------------------------------------------------------

table urllib_parse_extra15.function_qualname_lengths:
  description: "Length of __qualname__ strings for urlunparse, quote_plus, and unquote_plus"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqlen15

  columns: [id, function, args, expected]
  rows:
    - [urlunparse,  urlunparse.__qualname__.__len__,  [], 10]
    - [quote_plus,  quote_plus.__qualname__.__len__,  [], 10]
    - [unquote_plus, unquote_plus.__qualname__.__len__, [], 12]

# ---------------------------------------------------------------------------
# quote_plus and unquote_plus __qualname__.__eq__ — cross-namespace anchors
#
# urllib_parse_extra5 covers quote_plus.__qualname__.__eq__ and
# unquote_plus.__qualname__.__eq__ in its table. The standalone invariants
# below anchor these same properties from the extra15 namespace, providing
# a cross-namespace regression checkpoint.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra15.quote_plus.qualname_eq:
  description: "urllib.parse.quote_plus.__qualname__ == 'quote_plus' — cross-namespace anchor (extra5 covers in table)"
  category: function_qualnames
  kind: python_call_eq
  function: quote_plus.__qualname__.__eq__
  args: ["quote_plus"]
  expected: true

invariant urllib_parse_extra15.unquote_plus.qualname_eq:
  description: "urllib.parse.unquote_plus.__qualname__ == 'unquote_plus' — cross-namespace anchor (extra5 covers in table)"
  category: function_qualnames
  kind: python_call_eq
  function: unquote_plus.__qualname__.__eq__
  args: ["unquote_plus"]
  expected: true
