spec: cmath_extra7
version: ">=3.9"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmath.html — Python cmath module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "This spec extends cmath.zspec.zsdl and prior extras through cmath_extra6.zspec.zsdl."
    - "cmath_extra/cmath_extra2: phase/polar/rect/isclose/isfinite/isinf/isnan __name__ already covered."
    - "cmath_extra2: phase.__module__ == 'cmath' already covered."
    - "cmath_extra6: isclose.__module__ == 'cmath' and sqrt.__module__ == 'cmath' already covered."
    - "No prior spec covers polar.__module__ == 'cmath'."
    - "No prior spec covers rect.__module__ == 'cmath'."
    - "No prior spec covers isfinite.__module__ == 'cmath'."
    - "No prior spec covers isinf.__module__ == 'cmath'."
    - "No prior spec covers isnan.__module__ == 'cmath'."
    - "No prior spec covers phase(0.5) == 0.0 (fractional positive float input)."
    - "No prior spec covers phase(-0.5) == pi (fractional negative float input)."
    - "No prior spec covers phase(2.5) == 0.0 (non-unit positive float input)."
    - "No prior spec covers phase(-2.5) == pi (non-unit negative float input)."
    - "No prior spec covers isfinite(3.14) == True (pi-like float input)."
    - "No prior spec covers isfinite(100.0) == True (large float input)."
    - "No prior spec covers isinf(2.0) == False (non-integer float)."
    - "No prior spec covers isnan(3.14) == False (pi-like float input)."
    - "phase(0.5) == 0.0 — positive fractional real has angle zero."
    - "phase(-0.5) == 3.141592653589793 — negative fractional real has angle pi."
    - "phase(2.5) == 0.0 — positive non-integer real has angle zero."
    - "phase(-2.5) == 3.141592653589793 — negative non-integer real has angle pi."
    - "polar.__module__ == 'cmath' — polar is defined in the cmath module."
    - "rect.__module__ == 'cmath' — rect is defined in the cmath module."
    - "isfinite.__module__ == 'cmath' — isfinite is defined in the cmath module."
    - "isinf.__module__ == 'cmath' — isinf is defined in the cmath module."
    - "isnan.__module__ == 'cmath' — isnan is defined in the cmath module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cmath.phase with fractional float arguments
#
# cmath.zspec covers phase(1.0)==0.0, phase(-1.0)==pi, phase(0.0)==0.0.
# cmath_extra5 covers phase(-1)==pi (integer). cmath_extra6 covers phase(1)==0.0.
# No prior spec covers fractional float inputs such as 0.5, -0.5, 2.5, -2.5.
# phase(x) for real x is 0.0 when x > 0, and pi when x < 0.
# ---------------------------------------------------------------------------

table cmath_extra7.phase_fractional:
  kind: python_call_eq
  category: phase
  id_prefix: phase_frac

  columns: [id, function, args, expected]
  rows:
    - [pos_half,     phase, [0.5],  0.0]
    - [neg_half,     phase, [-0.5], 3.141592653589793]
    - [pos_two_half, phase, [2.5],  0.0]
    - [neg_two_half, phase, [-2.5], 3.141592653589793]

# ---------------------------------------------------------------------------
# polar and rect __module__
#
# cmath_extra2 confirms phase.__module__ == 'cmath'.
# cmath_extra6 confirms isclose.__module__ and sqrt.__module__.
# No prior spec covers polar.__module__ or rect.__module__.
# ---------------------------------------------------------------------------

invariant cmath_extra7.polar.module:
  description: "cmath.polar.__module__ == 'cmath' — polar is defined in the cmath module"
  category: function_identity
  kind: python_call_eq
  function: polar.__module__.__eq__
  args: ["cmath"]
  expected: true

invariant cmath_extra7.rect.module:
  description: "cmath.rect.__module__ == 'cmath' — rect is defined in the cmath module"
  category: function_identity
  kind: python_call_eq
  function: rect.__module__.__eq__
  args: ["cmath"]
  expected: true

# ---------------------------------------------------------------------------
# isfinite, isinf, and isnan __module__
#
# No prior spec covers __module__ for isfinite, isinf, or isnan.
# cmath_extra2 and cmath_extra6 only confirm __module__ for phase, sqrt, and isclose.
# All cmath predicate functions are implemented in the C cmath extension module.
# ---------------------------------------------------------------------------

table cmath_extra7.predicate_module:
  kind: python_call_eq
  category: function_identity
  id_prefix: pred_module

  columns: [id, function, args, expected]
  rows:
    - [isfinite, isfinite.__module__.__eq__, ["cmath"], true]
    - [isinf,    isinf.__module__.__eq__,    ["cmath"], true]
    - [isnan,    isnan.__module__.__eq__,    ["cmath"], true]

# ---------------------------------------------------------------------------
# isfinite with new float inputs
#
# cmath.zspec covers isfinite(1.0/inf/-inf/0.0); cmath_extra2 covers isfinite(2/-99).
# No prior spec covers isfinite(3.14) or isfinite(100.0).
# ---------------------------------------------------------------------------

invariant cmath_extra7.isfinite.pi_like_float:
  description: "cmath.isfinite(3.14) == True — a pi-like float is finite"
  category: predicates
  kind: python_call_eq
  function: isfinite
  args: [3.14]
  expected: true

invariant cmath_extra7.isfinite.large_float:
  description: "cmath.isfinite(100.0) == True — a large float is finite"
  category: predicates
  kind: python_call_eq
  function: isfinite
  args: [100.0]
  expected: true

# ---------------------------------------------------------------------------
# isinf and isnan with new float inputs
#
# cmath.zspec covers isinf(inf/1.0/0.0); cmath_extra2 covers isinf(0/-1) integers.
# No prior spec covers isinf(2.0) or isnan(3.14) float inputs.
# ---------------------------------------------------------------------------

invariant cmath_extra7.isinf.two_float:
  description: "cmath.isinf(2.0) == False — a normal float is not infinite"
  category: predicates
  kind: python_call_eq
  function: isinf
  args: [2.0]
  expected: false

invariant cmath_extra7.isnan.pi_like_float:
  description: "cmath.isnan(3.14) == False — a pi-like float is not NaN"
  category: predicates
  kind: python_call_eq
  function: isnan
  args: [3.14]
  expected: false
