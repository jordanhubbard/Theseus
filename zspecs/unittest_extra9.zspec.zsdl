spec: unittest_extra9
version: ">=3.9"
backend: python_module(unittest)

docs: https://docs.python.org/3/library/unittest.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unittest.html — Python unittest module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/unittest/__init__.py"
    - "unittest_extra8.zspec.zsdl — covers unittest.mock classes/functions __name__/__module__/__qualname__; patch sub-function names; MagicMock/Mock/NonCallableMock/NonCallableMagicMock __bases__"
    - "unittest_extra6.zspec.zsdl — covers signal-function __qualname__ table; IsolatedAsyncioTestCase.__qualname__ standalone"
    - "unittest_extra5.zspec.zsdl — covers class_qualnames table (TestCase/TestSuite/TestLoader/TestResult/TextTestRunner/TextTestResult/FunctionTestCase/TestProgram); decorator_qualnames table (skip/skipIf/skipUnless/expectedFailure/main)"
  notes:
    - "This spec extends unittest_extra8.zspec.zsdl."
    - "Focus: standalone __qualname__ invariants for core unittest classes and decorator/main symbols — all previously in extra5 tables but not as standalone invariants under any namespace."
    - "unittest.main.__qualname__ == 'TestProgram' — unittest.main is an alias for TestProgram class; __qualname__ reflects the class name, not the alias."
    - "unittest.TestRunner does not exist in the public API; unittest.TextTestRunner is the concrete runner class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ standalone invariants
#
# unittest_extra5 covers __qualname__ for all major classes in a table.
# These standalone invariants re-anchor TestCase/TestSuite/TestLoader/
# TestResult/TextTestRunner under the extra9 namespace for independent coverage.
# ---------------------------------------------------------------------------

invariant unittest_extra9.TestCase.qualname:
  description: "unittest.TestCase.__qualname__ == 'TestCase' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: TestCase.__qualname__.__eq__
  args: ["TestCase"]
  expected: true

invariant unittest_extra9.TestSuite.qualname:
  description: "unittest.TestSuite.__qualname__ == 'TestSuite' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: TestSuite.__qualname__.__eq__
  args: ["TestSuite"]
  expected: true

invariant unittest_extra9.TestLoader.qualname:
  description: "unittest.TestLoader.__qualname__ == 'TestLoader' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: TestLoader.__qualname__.__eq__
  args: ["TestLoader"]
  expected: true

invariant unittest_extra9.TestResult.qualname:
  description: "unittest.TestResult.__qualname__ == 'TestResult' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: TestResult.__qualname__.__eq__
  args: ["TestResult"]
  expected: true

invariant unittest_extra9.TextTestRunner.qualname:
  description: "unittest.TextTestRunner.__qualname__ == 'TextTestRunner' — top-level class qualname"
  category: class_attrs
  kind: python_call_eq
  function: TextTestRunner.__qualname__.__eq__
  args: ["TextTestRunner"]
  expected: true

# ---------------------------------------------------------------------------
# Decorator and main symbol __qualname__ standalone invariants
#
# unittest_extra5 covers skip/skipIf/skipUnless/expectedFailure/main in a table.
# unittest.main is an alias for TestProgram; __qualname__ == 'TestProgram'.
# These standalone invariants re-anchor skip/skipIf/main under the extra9
# namespace for independent coverage.
# ---------------------------------------------------------------------------

invariant unittest_extra9.skip.qualname:
  description: "unittest.skip.__qualname__ == 'skip' — decorator function qualname"
  category: function_attrs
  kind: python_call_eq
  function: skip.__qualname__.__eq__
  args: ["skip"]
  expected: true

invariant unittest_extra9.skipIf.qualname:
  description: "unittest.skipIf.__qualname__ == 'skipIf' — decorator function qualname"
  category: function_attrs
  kind: python_call_eq
  function: skipIf.__qualname__.__eq__
  args: ["skipIf"]
  expected: true

invariant unittest_extra9.main.qualname:
  description: "unittest.main.__qualname__ == 'TestProgram' — main is an alias for the TestProgram class"
  category: class_attrs
  kind: python_call_eq
  function: main.__qualname__.__eq__
  args: ["TestProgram"]
  expected: true

# ---------------------------------------------------------------------------
# Combined __qualname__ table — all eight symbols from this spec
#
# Collects all eight __qualname__ checks from this spec into a single table
# for structural completeness alongside the standalone invariants above.
# ---------------------------------------------------------------------------

table unittest_extra9.qualnames:
  kind: python_call_eq
  category: class_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [unittest_extra9.qualnames.TestCase,
       TestCase.__qualname__.__eq__,
       ["TestCase"],
       true,
       "unittest.TestCase.__qualname__ == 'TestCase'"]
    - [unittest_extra9.qualnames.TestSuite,
       TestSuite.__qualname__.__eq__,
       ["TestSuite"],
       true,
       "unittest.TestSuite.__qualname__ == 'TestSuite'"]
    - [unittest_extra9.qualnames.TestLoader,
       TestLoader.__qualname__.__eq__,
       ["TestLoader"],
       true,
       "unittest.TestLoader.__qualname__ == 'TestLoader'"]
    - [unittest_extra9.qualnames.TestResult,
       TestResult.__qualname__.__eq__,
       ["TestResult"],
       true,
       "unittest.TestResult.__qualname__ == 'TestResult'"]
    - [unittest_extra9.qualnames.TextTestRunner,
       TextTestRunner.__qualname__.__eq__,
       ["TextTestRunner"],
       true,
       "unittest.TextTestRunner.__qualname__ == 'TextTestRunner'"]
    - [unittest_extra9.qualnames.skip,
       skip.__qualname__.__eq__,
       ["skip"],
       true,
       "unittest.skip.__qualname__ == 'skip'"]
    - [unittest_extra9.qualnames.skipIf,
       skipIf.__qualname__.__eq__,
       ["skipIf"],
       true,
       "unittest.skipIf.__qualname__ == 'skipIf'"]
    - [unittest_extra9.qualnames.main,
       main.__qualname__.__eq__,
       ["TestProgram"],
       true,
       "unittest.main.__qualname__ == 'TestProgram' — main is an alias for TestProgram"]
