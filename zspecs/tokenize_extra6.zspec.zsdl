spec: tokenize_extra6
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize.zspec.zsdl — covers NAME/NUMBER/STRING/NEWLINE/INDENT/DEDENT/OP/COMMENT/ENCODING/NL int type checks, function __name__ for tokenize/generate_tokens/detect_encoding"
    - "tokenize_extra.zspec.zsdl — covers TokenInfo/__name__/__module__, TokenError/__name__/bases, function __name__ for tokenize/generate_tokens/detect_encoding/open/untokenize, ENCODING/COMMENT/NAME/NUMBER/STRING/NEWLINE/OP/ENDMARKER int type checks"
    - "tokenize_extra2.zspec.zsdl — covers TokenInfo/__name__/_fields len/_fields membership/_fields[0]/_fields[1], function __name__ table, COMMENT is_int"
    - "tokenize_extra3.zspec.zsdl — covers function __module__ table, TokenError/__name__/__module__/base, TokenInfo/__name__/__module__/base/bases_len, token constant int checks (COMMENT/STRING/NUMBER/NAME/ENCODING), untokenize/__name__"
    - "tokenize_extra4.zspec.zsdl — covers _fields[2]/_fields[3]/_fields[4], open/__module__, TokenError/__bases__/__len__==1, TokenInfo/__qualname__, TokenError/__qualname__, function __qualname__ table"
    - "tokenize_extra5.zspec.zsdl — covers open/__qualname__, ERRORTOKEN/__class__/__name__, TYPE_COMMENT/__class__/__name__"
  notes:
    - "This spec extends the tokenize series with invariants not covered in any prior tokenize spec."
    - "TokenInfo._make is a classmethod on namedtuples that constructs a TokenInfo from an iterable; __name__ == '_make'."
    - "TokenInfo._asdict returns an OrderedDict mapping field names to values; __name__ == '_asdict'."
    - "TokenInfo._replace returns a new TokenInfo with specified fields replaced; __name__ == '_replace'."
    - "tokenize.COMMENT == 65 — exact value on Python 3.12+; stable since Python 3.12."
    - "tokenize.NL == 66 — exact value on Python 3.12+; NL is the non-logical newline token."
    - "tokenize.ENDMARKER == 0 — re-exported from token; stable across all Python 3.x."
    - "tokenize.ERRORTOKEN == 67 — exact value on Python 3.12+."
    - "tokenize.TYPE_COMMENT == 57 — re-exported from token; added in Python 3.8."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TokenInfo namedtuple helper methods — _make, _asdict, _replace
# None of these __name__ checks appear in any prior tokenize spec.
# ---------------------------------------------------------------------------

invariant tokenize_extra6.TokenInfo.make_name:
  description: "tokenize.TokenInfo._make.__name__ == '_make' — namedtuple classmethod for construction"
  category: token_info
  kind: python_call_eq
  function: TokenInfo._make.__name__.__eq__
  args: ["_make"]
  expected: true

invariant tokenize_extra6.TokenInfo.asdict_name:
  description: "tokenize.TokenInfo._asdict.__name__ == '_asdict' — namedtuple method for dict conversion"
  category: token_info
  kind: python_call_eq
  function: TokenInfo._asdict.__name__.__eq__
  args: ["_asdict"]
  expected: true

invariant tokenize_extra6.TokenInfo.replace_name:
  description: "tokenize.TokenInfo._replace.__name__ == '_replace' — namedtuple method for field replacement"
  category: token_info
  kind: python_call_eq
  function: TokenInfo._replace.__name__.__eq__
  args: ["_replace"]
  expected: true

# ---------------------------------------------------------------------------
# TokenInfo._fields is a tuple — type identity check
# Prior specs check len and field names; this verifies the container type.
# ---------------------------------------------------------------------------

invariant tokenize_extra6.TokenInfo.fields_is_tuple:
  description: "tokenize.TokenInfo._fields.__class__.__name__ == 'tuple'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo._fields.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# tokenize-specific token constant exact values (Python 3.12+)
# Prior tokenize specs only check __class__.__name__ == 'int', not exact values.
# COMMENT, NL, ENDMARKER, ERRORTOKEN, TYPE_COMMENT exact values are new here.
# ---------------------------------------------------------------------------

table tokenize_extra6.token_constant_values:
  kind: python_call_eq
  category: constants
  id_prefix: tokval

  columns: [id, function, args, expected]
  rows:
    - [endmarker,    ENDMARKER.__eq__,    [0],  true]
    - [type_comment, TYPE_COMMENT.__eq__,  [57], true]
    - [comment,      COMMENT.__eq__,       [65], true]
    - [nl,           NL.__eq__,            [66], true]
    - [errortoken,   ERRORTOKEN.__eq__,    [67], true]
