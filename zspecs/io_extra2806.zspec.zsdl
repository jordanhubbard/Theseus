spec: io_extra2806
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2791.zspec.zsdl — covers __iand__/__ior__/__ixor__ dict-presence"
    - "io_extra2776.zspec.zsdl — covers __isub__/__imul__/__itruediv__ dict-presence"
    - "io_extra2761.zspec.zsdl — covers __matmul__/__truediv__/__iadd__ dict-presence"
    - "io_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "io_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
  notes:
    - "Wave 634 (io_extra2806) theme: __ilshift__, __irshift__, and __ipow__ dict-presence checks."
    - "None of the io classes define __ilshift__, __irshift__, or __ipow__ in their own __dict__."
    - "__ilshift__ supports the <<= operator; io stream classes do not implement in-place left-shift semantics."
    - "__irshift__ supports the >>= operator; io stream classes do not implement in-place right-shift semantics."
    - "__ipow__ supports the **= operator; io stream classes do not implement in-place exponentiation semantics."
    - "Covers io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and io.TextIOWrapper."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __ilshift__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2806.no_ilshift_in_io_classes:
  description: "__ilshift__ is absent from all io class __dict__s — io stream classes do not implement the <<= in-place left-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2806

  columns: [id, function, args, expected]
  rows:
    - ["io2806001", "io.IOBase.__dict__.__contains__",         ["__ilshift__"], false]
    - ["io2806002", "io.RawIOBase.__dict__.__contains__",      ["__ilshift__"], false]
    - ["io2806003", "io.BufferedIOBase.__dict__.__contains__", ["__ilshift__"], false]
    - ["io2806004", "io.TextIOBase.__dict__.__contains__",     ["__ilshift__"], false]
    - ["io2806005", "io.BytesIO.__dict__.__contains__",        ["__ilshift__"], false]
    - ["io2806006", "io.StringIO.__dict__.__contains__",       ["__ilshift__"], false]

# ---------------------------------------------------------------------------
# __irshift__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2806.no_irshift_in_io_classes:
  description: "__irshift__ is absent from all io class __dict__s — io stream classes do not implement the >>= in-place right-shift protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2806

  columns: [id, function, args, expected]
  rows:
    - ["io2806007", "io.IOBase.__dict__.__contains__",          ["__irshift__"], false]
    - ["io2806008", "io.FileIO.__dict__.__contains__",          ["__irshift__"], false]
    - ["io2806009", "io.BufferedReader.__dict__.__contains__",  ["__irshift__"], false]
    - ["io2806010", "io.BufferedWriter.__dict__.__contains__",  ["__irshift__"], false]
    - ["io2806011", "io.BufferedRandom.__dict__.__contains__",  ["__irshift__"], false]
    - ["io2806012", "io.TextIOWrapper.__dict__.__contains__",   ["__irshift__"], false]

# ---------------------------------------------------------------------------
# __ipow__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2806.no_ipow_in_io_classes:
  description: "__ipow__ is absent from all io class __dict__s — io stream classes do not implement the **= in-place exponentiation protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2806

  columns: [id, function, args, expected]
  rows:
    - ["io2806013", "io.IOBase.__dict__.__contains__",         ["__ipow__"], false]
    - ["io2806014", "io.BytesIO.__dict__.__contains__",        ["__ipow__"], false]
    - ["io2806015", "io.StringIO.__dict__.__contains__",       ["__ipow__"], false]
    - ["io2806016", "io.FileIO.__dict__.__contains__",         ["__ipow__"], false]
    - ["io2806017", "io.BufferedReader.__dict__.__contains__", ["__ipow__"], false]
    - ["io2806018", "io.BufferedWriter.__dict__.__contains__", ["__ipow__"], false]

# ---------------------------------------------------------------------------
# Complementary: io stream classes have I/O methods but not in-place shift or exponentiation hooks
# Confirms that io classes are sequential I/O objects, not integer or numeric types
# ---------------------------------------------------------------------------

table io_extra2806.io_has_stream_methods_not_inplace_shift_pow_hooks:
  description: "io.BytesIO defines read/write/seek/tell but NOT __ilshift__/__irshift__/__ipow__; io.StringIO similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2806

  columns: [id, function, args, expected]
  rows:
    - ["io2806019", "io.BytesIO.__dict__.__contains__",  ["read"],      true]
    - ["io2806020", "io.BytesIO.__dict__.__contains__",  ["write"],     true]
    - ["io2806021", "io.BytesIO.__dict__.__contains__",  ["seek"],      true]
    - ["io2806022", "io.BytesIO.__dict__.__contains__",  ["tell"],      true]
    - ["io2806023", "io.BytesIO.__dict__.__contains__",  ["__ilshift__"], false]
    - ["io2806024", "io.BytesIO.__dict__.__contains__",  ["__irshift__"], false]
    - ["io2806025", "io.BytesIO.__dict__.__contains__",  ["__ipow__"],    false]
    - ["io2806026", "io.StringIO.__dict__.__contains__", ["read"],      true]
    - ["io2806027", "io.StringIO.__dict__.__contains__", ["write"],     true]
    - ["io2806028", "io.StringIO.__dict__.__contains__", ["seek"],      true]
    - ["io2806029", "io.StringIO.__dict__.__contains__", ["tell"],      true]
    - ["io2806030", "io.StringIO.__dict__.__contains__", ["__ilshift__"], false]
    - ["io2806031", "io.StringIO.__dict__.__contains__", ["__irshift__"], false]
    - ["io2806032", "io.StringIO.__dict__.__contains__", ["__ipow__"],    false]
