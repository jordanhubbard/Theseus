# ---------------------------------------------------------------------------
# Standalone invariants — extra94
# ---------------------------------------------------------------------------

invariant itertools_extra94.itertools_name_eq_itertools:
  description: "itertools.__name__ == 'itertools' — top-level C extension module identity; wave 254; new to extra94"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra94.itertools_spec_class_name:
  description: "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — C extension module has ModuleSpec; wave 254; new to extra94"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant itertools_extra94.chain_bases0_eq_object:
  description: "itertools.chain.__bases__[0].__name__ == 'object' — C type inherits from object; wave 254; new to extra94"
  kind: python_call_eq
  function: chain.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant itertools_extra94.compress_bases0_eq_object:
  description: "itertools.compress.__bases__[0].__name__ == 'object' — C type inherits from object; wave 254; new to extra94"
  kind: python_call_eq
