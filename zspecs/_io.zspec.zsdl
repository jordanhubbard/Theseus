spec: _io
version: ">=3.2"
backend: python_module(_io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "Python io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "_io is the C extension that implements the core I/O classes; the pure-Python io module re-exports from it."
    - "BytesIO and StringIO are the primary in-memory stream classes tested here."
    - "UnsupportedOperation inherits from both OSError and ValueError; __bases__[0] is OSError."
    - "RawIOBase, BufferedIOBase, and TextIOBase are abstract base classes for the I/O hierarchy."
    - "BytesIO(b'hello').read() returns b'hello' as bytes; this is compared using the !ascii tag."
    - "StringIO('hello').read() returns 'hello' as a str."
    - "BytesIO.__module__ == '_io' — the class is defined in the C extension, not in io.py."
    - "StringIO.__module__ == '_io' — likewise for StringIO."
    - "All expected values verified by running Python 3.12 _io on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant _io.BytesIO.class_name:
  description: "_io.BytesIO.__name__ == 'BytesIO'"
  category: classnames
  kind: python_call_eq
  function: BytesIO.__name__.__eq__
  args: ["BytesIO"]
  expected: true

invariant _io.StringIO.class_name:
  description: "_io.StringIO.__name__ == 'StringIO'"
  category: classnames
  kind: python_call_eq
  function: StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant _io.UnsupportedOperation.class_name:
  description: "_io.UnsupportedOperation.__name__ == 'UnsupportedOperation'"
  category: classnames
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

# ---------------------------------------------------------------------------
# Module checks — classes are defined in _io (C extension)
# ---------------------------------------------------------------------------

invariant _io.BytesIO.module:
  description: "_io.BytesIO.__module__ == '_io'"
  category: classnames
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant _io.StringIO.module:
  description: "_io.StringIO.__module__ == '_io'"
  category: classnames
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

# ---------------------------------------------------------------------------
# Base class check — UnsupportedOperation.__bases__[0].__name__ == 'OSError'
# ---------------------------------------------------------------------------

invariant _io.UnsupportedOperation.base:
  description: "_io.UnsupportedOperation.__bases__[0].__name__ == 'OSError'"
  category: classnames
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "OSError"

# ---------------------------------------------------------------------------
# BytesIO — instantiation and read
# ---------------------------------------------------------------------------

invariant _io.bytesio.read_all:
  description: "_io.BytesIO(b'hello').read() == b'hello'"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: "hello"}]
  method: read
  method_args: []
  expected: !ascii "hello"

invariant _io.bytesio.getvalue_length:
  description: "len(_io.BytesIO(b'hello').getvalue()) == 5"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: "hello"}]
  method: getvalue
  method_chain: __len__
  expected: 5

invariant _io.bytesio.tell_initial:
  description: "_io.BytesIO(b'hello').tell() == 0 — stream position starts at 0"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: "hello"}]
  method: tell
  method_args: []
  expected: 0

invariant _io.bytesio.readable:
  description: "_io.BytesIO(b'hello').readable() == True"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: "hello"}]
  method: readable
  method_args: []
  expected: true

invariant _io.bytesio.seekable:
  description: "_io.BytesIO(b'hello').seekable() == True"
  category: bytesio
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: "hello"}]
  method: seekable
  method_args: []
  expected: true

# ---------------------------------------------------------------------------
# StringIO — instantiation and read
# ---------------------------------------------------------------------------

invariant _io.stringio.read_all:
  description: "_io.StringIO('hello').read() == 'hello'"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: read
  method_args: []
  expected: "hello"

invariant _io.stringio.getvalue:
  description: "_io.StringIO('hello').getvalue() == 'hello'"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: getvalue
  method_args: []
  expected: "hello"

invariant _io.stringio.tell_initial:
  description: "_io.StringIO('hello').tell() == 0 — stream position starts at 0"
  category: stringio
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: tell
  method_args: []
  expected: 0
