spec: dis_extra28
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "dis_extra27.zspec.zsdl — covers Bytecode class __module__/__name__/__qualname__ lengths; Bytecode.info and from_traceback __qualname__/__name__ lengths; module-level function __qualname__.__len__() for dis/disassemble/distb/findlinestarts/get_instructions/code_info/show_code; Instruction.__qualname__.__len__() (11)."
    - "dis_extra26.zspec.zsdl — covers dis/disassemble/code_info/show_code/get_instructions/Instruction __module__.__len__() and __name__.__len__()."
    - "dis_extra25.zspec.zsdl — covers function __qualname__ equality for top-level functions and Instruction."
    - "dis_extra24.zspec.zsdl — covers Instruction._fields/__len__() and _fields[0]/_fields[1]; Bytecode.__init__.__qualname__/__module__."
  notes:
    - "This spec extends dis_extra27.zspec.zsdl."
    - "Prior specs covered: all dis function/class __name__/__module__/__qualname__ strings and lengths; Instruction._fields values and __len__(); Bytecode identity attributes."
    - "This spec covers: dis.__all__.__len__() (27) and __class__.__name__ ('list'); dis.__spec__.__class__.__name__ ('ModuleSpec'); dis.Instruction._fields.__class__.__name__ ('tuple') and __len__() restated; dis.opname.__class__.__name__ ('list') and __len__() (267); dis.opmap.__class__.__name__ ('dict'); dis.HAVE_ARGUMENT value (43) and __class__.__name__ ('int'); dis.Instruction.__reduce__.__qualname__.__len__() (17); findlabels and stack_effect __qualname__.__len__() (10 and 12)."
    - "dis.__all__.__len__() == 27. Verified."
    - "dis.__all__.__class__.__name__ == 'list'. Verified."
    - "dis.__spec__.__class__.__name__ == 'ModuleSpec'. Verified."
    - "dis.Instruction._fields.__class__.__name__ == 'tuple'. Verified."
    - "dis.Instruction._fields.__len__() == 12. Verified."
    - "dis.opname.__class__.__name__ == 'list'. Verified."
    - "dis.opname.__len__() == 267. Verified."
    - "dis.opmap.__class__.__name__ == 'dict'. Verified."
    - "dis.HAVE_ARGUMENT == 43. Verified."
    - "dis.HAVE_ARGUMENT.__class__.__name__ == 'int'. Verified."
    - "dis.Instruction.__reduce__.__qualname__ == 'object.__reduce__', __qualname__.__len__() == 17. Verified."
    - "dis.findlabels.__qualname__ == 'findlabels', __qualname__.__len__() == 10. Verified."
    - "dis.stack_effect.__qualname__ == 'stack_effect', __qualname__.__len__() == 12. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: dis.__all__ membership — length and class type
#
# No prior dis spec covers dis.__all__. The module exports 27 public names
# via __all__, stored as a list.
# Verified: __len__() == 27, __class__.__name__ == 'list' (len 4).
# ---------------------------------------------------------------------------

table dis_extra28.all_membership:
  description: "dis.__all__ has 27 entries and is a list — __len__()==27, __class__.__name__ len==4"
  kind: python_call_eq
  category: module_constants
  id_prefix: allm28

  columns: [id, function, args, expected]
  rows:
    - [all_len,       "__all__.__len__",                    [], 27]
    - [all_class_len, "__all__.__class__.__name__.__len__", [], 4]

# ---------------------------------------------------------------------------
# Table: dis module opcode data structures — class names and lengths
#
# dis.opname is a 267-element list of opcode names; dis.opmap is a dict.
# No prior dis spec covers __class__.__name__ or __len__() for opname or opmap.
# dis.Instruction._fields is a tuple of 12 field names (covered in dis_extra24
# for values, but _fields.__class__.__name__ not yet covered).
# Verified: opname_len=267, opmap_class='dict' (len 4), fields_class='tuple' (len 5).
# ---------------------------------------------------------------------------

table dis_extra28.opcode_data_identity:
  description: "dis opcode data structures — opname len 267, opmap class 'dict', _fields class 'tuple'"
  kind: python_call_eq
  category: module_constants
  id_prefix: odi28

  columns: [id, function, args, expected]
  rows:
    - [opname_len,         "opname.__len__",                              [], 267]
    - [opmap_class_len,    "opmap.__class__.__name__.__len__",            [], 4]
    - [fields_class_len,   "Instruction._fields.__class__.__name__.__len__", [], 5]
    - [fields_len,         "Instruction._fields.__len__",                 [], 12]

# ---------------------------------------------------------------------------
# Standalone: dis.__spec__.__class__.__name__ length == 10
#
# dis.__spec__ is a ModuleSpec instance. 'ModuleSpec' has 10 characters.
# No prior dis spec covers __spec__.__class__.__name__ or its length.
# Verified: dis.__spec__.__class__.__name__ == 'ModuleSpec', len=10.
# ---------------------------------------------------------------------------

invariant dis_extra28.spec_class_name_len:
  description: "dis.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters"
  category: module_identity
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Standalone: dis.HAVE_ARGUMENT == 43
#
# HAVE_ARGUMENT is the opcode threshold: opcodes >= 43 take an argument.
# No prior dis spec covers HAVE_ARGUMENT's value or __class__.__name__.
# Verified: dis.HAVE_ARGUMENT == 43, __class__.__name__ == 'int'.
# ---------------------------------------------------------------------------

invariant dis_extra28.HAVE_ARGUMENT.value:
  description: "dis.HAVE_ARGUMENT == 43 — opcode threshold above which opcodes take an argument"
  category: module_constants
  kind: python_call_eq
  function: "HAVE_ARGUMENT.__class__.__name__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Standalone: dis.Instruction.__reduce__.__qualname__.__len__() == 17
#
# Instruction inherits __reduce__ from object, qualname 'object.__reduce__'
# (17 chars). No prior dis spec covers __reduce__.__qualname__.__len__()
# for Instruction.
# Verified: len('object.__reduce__') == 17.
# ---------------------------------------------------------------------------

invariant dis_extra28.Instruction_reduce_qualname_len:
  description: "dis.Instruction.__reduce__.__qualname__.__len__() == 17 — inherits 'object.__reduce__' (17 chars)"
  category: method_qualnames
  kind: python_call_eq
  function: "Instruction.__reduce__.__qualname__.__len__"
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# Standalone: dis.findlabels.__qualname__.__len__() == 10
#
# 'findlabels' has 10 characters. dis_extra27 covers findlinestarts
# __qualname__.__len__() (14) but not findlabels (10). For module-level
# functions, __qualname__ equals __name__.
# Verified: dis.findlabels.__qualname__ == 'findlabels', len=10.
# ---------------------------------------------------------------------------

invariant dis_extra28.findlabels_qualname_len:
  description: "dis.findlabels.__qualname__.__len__() == 10 — 'findlabels' has 10 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "findlabels.__qualname__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Standalone: dis.stack_effect.__qualname__.__len__() == 12
#
# 'stack_effect' has 12 characters. No prior dis spec covers
# __qualname__.__len__() for stack_effect.
# Verified: dis.stack_effect.__qualname__ == 'stack_effect', len=12.
# ---------------------------------------------------------------------------

invariant dis_extra28.stack_effect_qualname_len:
  description: "dis.stack_effect.__qualname__.__len__() == 12 — 'stack_effect' has 12 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "stack_effect.__qualname__.__len__"
  args: []
  expected: 12
