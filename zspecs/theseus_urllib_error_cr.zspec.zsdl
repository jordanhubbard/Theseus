spec: theseus_urllib_error_cr
version: ">=3.0"
backend: python_cleanroom(theseus_urllib_error_cr)
blocks: urllib.error

docs: https://docs.python.org/3/library/urllib.error.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/urllib.error.html"
  not_derived_from:
    - "CPython source: Lib/urllib/error.py"
  notes:
    - "Clean-room urllib.error module. Do NOT import urllib.error."

error_model: python_exceptions

invariant theseus_urllib_error_cr.urlerror2_class:
  description: "URLError is an OSError subclass"
  category: behavior
  kind: python_call_eq
  function: urlerror2_class
  args: []
  expected: true

invariant theseus_urllib_error_cr.urlerror2_httperror:
  description: "HTTPError has code, msg, headers attributes"
  category: behavior
  kind: python_call_eq
  function: urlerror2_httperror
  args: []
  expected: true

invariant theseus_urllib_error_cr.urlerror2_contenttoo:
  description: "ContentTooShortError exists as IOError subclass"
  category: behavior
  kind: python_call_eq
  function: urlerror2_contenttoo
  args: []
  expected: true
