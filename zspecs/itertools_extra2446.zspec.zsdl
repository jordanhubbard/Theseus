spec: itertools_extra2446
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave (_extra2446): __enter__/__exit__ context manager protocol dict-presence checks."
    - "All itertools C-extension types are iterator types, not context managers."
    - "None of the itertools types define __enter__ or __exit__ in their own __dict__."
    - "itertools.chain, cycle, count, islice, groupby, product, combinations, permutations, combinations_with_replacement, compress, dropwhile, takewhile, filterfalse, zip_longest, accumulate, starmap, batched, pairwise — none are context managers."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table itertools_extra2446.enter_protocol_iterators:
  description: "itertools iterator types __enter__ dict-presence checks — none are context managers"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2446
  columns: [id, function, args, expected]
  rows:
    - ["it2446001", "itertools.chain.__dict__.__contains__",                       ["__enter__"], false]
    - ["it2446002", "itertools.cycle.__dict__.__contains__",                       ["__enter__"], false]
    - ["it2446003", "itertools.count.__dict__.__contains__",                       ["__enter__"], false]
    - ["it2446004", "itertools.islice.__dict__.__contains__",                      ["__enter__"], false]
    - ["it2446005", "itertools.groupby.__dict__.__contains__",                     ["__enter__"], false]
    - ["it2446006", "itertools.product.__dict__.__contains__",                     ["__enter__"], false]
    - ["it2446007", "itertools.combinations.__dict__.__contains__",                ["__enter__"], false]
    - ["it2446008", "itertools.permutations.__dict__.__contains__",                ["__enter__"], false]
    - ["it2446009", "itertools.combinations_with_replacement.__dict__.__contains__", ["__enter__"], false]

