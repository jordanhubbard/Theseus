spec: gc_extra26
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends prior gc specs through gc_extra25.zspec.zsdl."
    - "gc_extra15 covers: callbacks.__class__.__name__ == 'list' in the extra15 namespace."
    - "gc_extra17 covers: DEBUG_STATS/DEBUG_COLLECTABLE/DEBUG_UNCOLLECTABLE/DEBUG_SAVEALL/DEBUG_LEAK __class__.__name__ == 'int' in the extra17 namespace."
    - "Focus: Re-anchoring gc.callbacks.__class__.__name__ and gc.DEBUG_* __class__.__name__ invariants in the gc_extra26 namespace, consistent with the pattern established in gc_extra24 for gc.garbage.__class__.__name__."
    - "gc.callbacks.__class__.__name__ == 'list' — callbacks is the list of functions invoked at collection start/end."
    - "gc.DEBUG_LEAK.__class__.__name__ == 'int' — DEBUG_LEAK value is 38."
    - "gc.DEBUG_SAVEALL.__class__.__name__ == 'int' — DEBUG_SAVEALL value is 32."
    - "gc.DEBUG_STATS.__class__.__name__ == 'int' — DEBUG_STATS value is 1."
    - "gc.DEBUG_COLLECTABLE.__class__.__name__ == 'int' — DEBUG_COLLECTABLE value is 2."
    - "gc.DEBUG_UNCOLLECTABLE.__class__.__name__ == 'int' — DEBUG_UNCOLLECTABLE value is 4."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# gc.callbacks type check — __class__.__name__ == 'list'
#
# gc.callbacks is the list of user-registered callback functions invoked
# before and after each collection cycle.
# gc_extra15 records this check in the extra15 namespace.
# This invariant re-anchors it in the gc_extra26 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra26.callbacks.class_name:
  description: "gc.callbacks.__class__.__name__ == 'list' — callbacks holds collection callback functions"
  category: module_attrs
  kind: python_call_eq
  function: callbacks.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# gc.DEBUG_* constant type checks — __class__.__name__ == 'int'
#
# The five gc.DEBUG_* constants are C-level integer values.
# gc_extra17 records their __class__.__name__ == 'int' in the extra17 namespace.
# gc_extra21 records their integer values as standalone invariants.
# This spec re-anchors the __class__.__name__ checks in the gc_extra26 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra26.DEBUG_LEAK.class_name:
  description: "gc.DEBUG_LEAK.__class__.__name__ == 'int' — DEBUG_LEAK is an integer constant (value 38)"
  category: module_attrs
  kind: python_call_eq
  function: DEBUG_LEAK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra26.DEBUG_SAVEALL.class_name:
  description: "gc.DEBUG_SAVEALL.__class__.__name__ == 'int' — DEBUG_SAVEALL is an integer constant (value 32)"
  category: module_attrs
  kind: python_call_eq
  function: DEBUG_SAVEALL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra26.DEBUG_STATS.class_name:
  description: "gc.DEBUG_STATS.__class__.__name__ == 'int' — DEBUG_STATS is an integer constant (value 1)"
  category: module_attrs
  kind: python_call_eq
  function: DEBUG_STATS.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra26.DEBUG_COLLECTABLE.class_name:
  description: "gc.DEBUG_COLLECTABLE.__class__.__name__ == 'int' — DEBUG_COLLECTABLE is an integer constant (value 2)"
  category: module_attrs
  kind: python_call_eq
  function: DEBUG_COLLECTABLE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra26.DEBUG_UNCOLLECTABLE.class_name:
  description: "gc.DEBUG_UNCOLLECTABLE.__class__.__name__ == 'int' — DEBUG_UNCOLLECTABLE is an integer constant (value 4)"
  category: module_attrs
  kind: python_call_eq
  function: DEBUG_UNCOLLECTABLE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all six __class__.__name__ checks
#
# Covers gc.callbacks (list) and the five gc.DEBUG_* constants (int).
# ---------------------------------------------------------------------------

table gc_extra26.class_names:
  description: "__class__.__name__ type checks for gc.callbacks and gc.DEBUG_* constants"
  kind: python_call_eq
  category: module_attrs

  columns: [id, function, args, expected]
  rows:
    - [callbacks,          callbacks.__class__.__name__.__eq__,          ["list"], true]
    - [DEBUG_LEAK,         DEBUG_LEAK.__class__.__name__.__eq__,         ["int"],  true]
    - [DEBUG_SAVEALL,      DEBUG_SAVEALL.__class__.__name__.__eq__,      ["int"],  true]
    - [DEBUG_STATS,        DEBUG_STATS.__class__.__name__.__eq__,        ["int"],  true]
    - [DEBUG_COLLECTABLE,  DEBUG_COLLECTABLE.__class__.__name__.__eq__,  ["int"],  true]
    - [DEBUG_UNCOLLECTABLE, DEBUG_UNCOLLECTABLE.__class__.__name__.__eq__, ["int"], true]
