spec: functools_extra34
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra33.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property; __name__.__len__() for reduce/cmp_to_key; __module__.__len__() for partial/lru_cache/wraps (9) and reduce (10)."
    - "This spec covers: __qualname__.__len__() for update_wrapper, partialmethod, singledispatchmethod, cache, total_ordering, singledispatch, cmp_to_key, cached_property; __module__.__len__() for total_ordering, singledispatch, cmp_to_key, cached_property, update_wrapper, partialmethod, singledispatchmethod, cache."
    - "update_wrapper and total_ordering have __qualname__.__len__() == 14 (same as their __name__.__len__())."
    - "partialmethod.__qualname__.__len__() == 13; singledispatchmethod.__qualname__.__len__() == 20."
    - "cache.__qualname__.__len__() == 5 (same as wraps.__name__.__len__())."
    - "cmp_to_key.__module__ == '_functools' (len 10, C extension); all others have __module__ == 'functools' (len 9)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — Python-attributed callables
#
# functools_extra33 records __name__.__len__() for these callables but does not
# record __qualname__.__len__(). For module-level functions and classes, __qualname__
# equals __name__, so the lengths match. This table captures __qualname__.__len__()
# for update_wrapper (14), partialmethod (13), singledispatchmethod (20), cache (5),
# total_ordering (14), and singledispatch (14). No prior functools spec records
# __qualname__.__len__() for these callables in the extra34 namespace.
# ---------------------------------------------------------------------------

table functools_extra34.qualname_lens_python:
  description: "__qualname__.__len__() for Python-attributed functools callables"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper,       update_wrapper.__qualname__.__len__,       [], 14, "len(functools.update_wrapper.__qualname__) == 14"]
    - [partialmethod,        partialmethod.__qualname__.__len__,        [], 13, "len(functools.partialmethod.__qualname__) == 13"]
    - [singledispatchmethod, singledispatchmethod.__qualname__.__len__, [], 20, "len(functools.singledispatchmethod.__qualname__) == 20"]
    - [cache,                cache.__qualname__.__len__,                [], 5,  "len(functools.cache.__qualname__) == 5"]
    - [total_ordering,       total_ordering.__qualname__.__len__,       [], 14, "len(functools.total_ordering.__qualname__) == 14"]
    - [singledispatch,       singledispatch.__qualname__.__len__,       [], 14, "len(functools.singledispatch.__qualname__) == 14"]

# ---------------------------------------------------------------------------
# __module__.__len__() table — additional callables
#
# functools_extra33 records __module__.__len__() for partial, lru_cache, wraps
# (all 9), and reduce (10). This table extends coverage to total_ordering,
# singledispatch, cached_property, update_wrapper, partialmethod,
# singledispatchmethod, and cache — all report __module__ == 'functools' (len 9).
# cmp_to_key is the other C-extension callable with __module__ == '_functools' (len 10).
# No prior functools spec records these __module__.__len__() values in extra34.
# ---------------------------------------------------------------------------

table functools_extra34.module_lens_extended:
  description: "__module__.__len__() for additional functools callables"
  kind: python_call_eq
  category: string_properties
  id_prefix: module_len

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering,       total_ordering.__module__.__len__,       [], 9,  "len(functools.total_ordering.__module__) == 9"]
    - [singledispatch,       singledispatch.__module__.__len__,       [], 9,  "len(functools.singledispatch.__module__) == 9"]
    - [cached_property,      cached_property.__module__.__len__,      [], 9,  "len(functools.cached_property.__module__) == 9"]
    - [update_wrapper,       update_wrapper.__module__.__len__,       [], 9,  "len(functools.update_wrapper.__module__) == 9"]
    - [partialmethod,        partialmethod.__module__.__len__,        [], 9,  "len(functools.partialmethod.__module__) == 9"]
    - [singledispatchmethod, singledispatchmethod.__module__.__len__, [], 9,  "len(functools.singledispatchmethod.__module__) == 9"]
    - [cache,                cache.__module__.__len__,                [], 9,  "len(functools.cache.__module__) == 9"]
    - [cmp_to_key,           cmp_to_key.__module__.__len__,           [], 10, "len(functools.cmp_to_key.__module__) == 10 (C extension '_functools')"]

# ---------------------------------------------------------------------------
# functools.singledispatchmethod.__qualname__.__len__() — standalone invariant
#
# singledispatchmethod.__qualname__ == 'singledispatchmethod' (20 chars), the
# longest __qualname__ among common functools callables. This records the
# standalone length invariant in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra34.singledispatchmethod.qualname_len:
  description: "len(functools.singledispatchmethod.__qualname__) == 20 — 'singledispatchmethod' is 20 chars"
  category: string_properties
  kind: python_call_eq
  function: singledispatchmethod.__qualname__.__len__
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# functools.cache.__qualname__.__len__() — standalone invariant
#
# cache.__qualname__ == 'cache' (5 chars). cache is a simple wrapper around
# lru_cache(maxsize=None), added in Python 3.9. Despite its short name, it
# provides an unbounded memoization cache. No prior functools spec records
# cache.__qualname__.__len__() as a standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra34.cache.qualname_len:
  description: "len(functools.cache.__qualname__) == 5 — 'cache' is 5 chars"
  category: string_properties
  kind: python_call_eq
  function: cache.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# functools.cmp_to_key.__module__.__len__() — standalone invariant
#
# cmp_to_key is a C-extension function; __module__ == '_functools' (10 chars).
# This parallels functools.reduce, which also has __module__ == '_functools'.
# Both C-extension callables contrast with the Python-attributed ones that
# report __module__ == 'functools' (9 chars). No prior functools spec records
# cmp_to_key.__module__.__len__() as a standalone in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra34.cmp_to_key.module_len:
  description: "len(functools.cmp_to_key.__module__) == 10 — '_functools' is 10 chars (C extension)"
  category: string_properties
  kind: python_call_eq
  function: cmp_to_key.__module__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# functools.partialmethod.__qualname__.__len__() — standalone invariant
#
# partialmethod.__qualname__ == 'partialmethod' (13 chars). partialmethod is
# a descriptor class for partial application of methods, analogous to partial
# for regular functions. Its name length (13) is one less than update_wrapper
# and total_ordering (14). No prior functools spec records this standalone
# invariant in the extra34 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra34.partialmethod.qualname_len:
  description: "len(functools.partialmethod.__qualname__) == 13 — 'partialmethod' is 13 chars"
  category: string_properties
  kind: python_call_eq
  function: partialmethod.__qualname__.__len__
  args: []
  expected: 13
