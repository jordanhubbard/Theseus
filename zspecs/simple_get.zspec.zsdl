spec: simple_get
version: ">=4.0.0"
backend: node(simple-get)

docs: https://github.com/feross/simple-get#readme

provenance:
  derived_from:
    - "simple-get README — https://github.com/feross/simple-get#readme"
    - "Test vectors verified with simple-get via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "simple-get source"
  notes:
    - "Simplest way to make HTTP/HTTPS requests in Node — used by mount-fest, FlightAware, etc."
    - "Install: npm install simple-get"
    - "v4 CJS; module export IS the simpleGet function; .concat / .post / .put / .patch / .head / .delete / .get attached."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Calls callback(err, response) — never throws synchronously."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant simple_get.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant simple_get.has_concat:
  description: ".concat is a function (auto-buffers response)"
  category: methods
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "concat.constructor.name"}
  expected: "Function"

invariant simple_get.has_post:
  description: ".post is a function"
  category: methods
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "post.constructor.name"}
  expected: "Function"

invariant simple_get.has_put:
  description: ".put is a function"
  category: methods
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "put.constructor.name"}
  expected: "Function"

invariant simple_get.has_patch:
  description: ".patch is a function"
  category: methods
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "patch.constructor.name"}
  expected: "Function"

invariant simple_get.has_head:
  description: ".head is a function"
  category: methods
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "head.constructor.name"}
  expected: "Function"

invariant simple_get.has_delete:
  description: ".delete is a function"
  category: methods
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "delete.constructor.name"}
  expected: "Function"

invariant simple_get.has_get:
  description: ".get is a function (alias of module export)"
  category: methods
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "get.constructor.name"}
  expected: "Function"

