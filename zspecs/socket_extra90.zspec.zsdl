spec: socket_extra90
version: ">=3.9"
extends: socket_extra89
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra89.zspec.zsdl — covers socket module integer constants class identity (AF_INET/AF_INET6/AF_UNSPEC AddressFamily, SOCK_DGRAM/SOCK_RAW/SOCK_SEQPACKET SocketKind, IPPROTO_TCP/IPPROTO_UDP/IPPROTO_ICMP int, SOL_SOCKET/SOL_TCP int) (table + invariants)."
    - "socket_extra88.zspec.zsdl — covers socket.socket.__dict__ negative membership / AddressFamily and SocketKind class identity (__qualname__/__module__/__mro__.__len__()==6/__name__) (table + invariants)."
    - "socket_extra86.zspec.zsdl — covers socket.socket/__module__/__qualname__/__mro__.__len__()==3/__bases__[0].__name__ / AF_INET/SOCK_STREAM class identity / AddressFamily/SocketKind __bases__[0].__name__/__qualname__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra89; it does NOT duplicate invariants present in those files."
    - "Wave 256 theme: socket.socket Python-level method __class__.__name__ identity."
    - "socket.socket.accept.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.sendfile.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.detach.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.dup.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__enter__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__exit__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__repr__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.accept/close/makefile/__init__/sendfile/detach/dup/__enter__/__exit__/__repr__ are all Python-level functions defined in Lib/socket.py; __class__.__name__ is 'function' for all of them."
    - "Note: socket.socket.bind/connect/listen/recv/send are C-level method_descriptor objects (from _socket.SocketType), NOT 'function'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.accept/__class__/__name__.__eq__('function')
# socket.socket.close/__class__/__name__.__eq__('function')
# socket.socket.makefile/__class__.__name__.__eq__('function')
# socket.socket.__init__/__class__.__name__.__eq__('function')
#
# Wave 256 theme: socket Python-level method class names (group 1).
#
# accept, close, makefile, and __init__ are all Python functions defined in
# Lib/socket.py. Their __class__.__name__ is 'function'. This is in contrast
# to the C-backed methods (bind, connect, etc.) which are method_descriptor.
# No prior socket spec anchors these __class__.__name__.__eq__ calls under
# socketmethcls90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra90.socket_methods_group1:
  description: "socket.socket.accept/__class__.__name__.__eq__('function')==True / socket.close/__class__.__name__.__eq__('function')==True / socket.makefile/__class__.__name__.__eq__('function')==True / socket.__init__/__class__.__name__.__eq__('function')==True — accept/close/makefile/__init__ are Python-level functions in Lib/socket.py (not C method_descriptors); their __class__.__name__ is 'function'; first socketmethcls90 anchor for socket Python method class names"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketmethcls90

  columns: [id, function, args, expected]
  rows:
    - [socket_accept_func,   socket.accept.__class__.__name__.__eq__,   ["function"], true]
    - [socket_close_func,    socket.close.__class__.__name__.__eq__,    ["function"], true]
    - [socket_makefile_func, socket.makefile.__class__.__name__.__eq__, ["function"], true]
    - [socket_init_func,     socket.__init__.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# socket.socket.sendfile/__class__/__name__.__eq__('function')
# socket.socket.detach/__class__.__name__.__eq__('function')
# socket.socket.dup/__class__/__name__.__eq__('function')
# socket.socket.accept/__class__/__name__.__eq__('function') (cross-check)
#
# Wave 256 theme: socket Python-level method class names (group 2).
#
# sendfile, detach, and dup are also Python-level functions in Lib/socket.py.
# Their __class__.__name__ is 'function'. The cross-check repeats accept from
# group 1. No prior socket spec anchors sendfile/detach/dup __class__.__name__.__eq__
# calls under socketmethcls90.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra90.socket_methods_group2:
  description: "socket.socket.sendfile/__class__.__name__.__eq__('function')==True / socket.detach/__class__.__name__.__eq__('function')==True / socket.dup/__class__.__name__.__eq__('function')==True / socket.accept/__class__.__name__.__eq__('function')==True — sendfile/detach/dup are Python-level functions in Lib/socket.py like accept/close/makefile; cross-check anchors accept; first socketmethcls90 anchor for sendfile/detach/dup class names"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketmethcls90

  columns: [id, function, args, expected]
  rows:
    - [socket_sendfile_func,  socket.sendfile.__class__.__name__.__eq__, ["function"], true]
    - [socket_detach_func,    socket.detach.__class__.__name__.__eq__,   ["function"], true]
    - [socket_dup_func,       socket.dup.__class__.__name__.__eq__,      ["function"], true]
    - [socket_accept_func2,   socket.accept.__class__.__name__.__eq__,   ["function"], true]

# ---------------------------------------------------------------------------
# socket.socket.__enter__/__class__/__name__.__eq__('function')
# socket.socket.__exit__/__class__/__name__.__eq__('function')
# socket.socket.__repr__/__class__/__name__.__eq__('function')
# socket.socket.__init__/__class__/__name__.__eq__('function') (cross-check)
#
# Wave 256 theme: socket dunder method class names.
#
# __enter__, __exit__, and __repr__ are all Python-level functions on
# socket.socket, not C wrappers. Their __class__.__name__ is 'function'.
# Cross-check repeats __init__ from group 1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra90.socket_dunder_methods:
  description: "socket.socket.__enter__/__class__.__name__.__eq__('function')==True / socket.__exit__/__class__.__name__.__eq__('function')==True / socket.__repr__/__class__.__name__.__eq__('function')==True / socket.__init__/__class__.__name__.__eq__('function')==True — __enter__/__exit__/__repr__ are Python-level functions on socket.socket (defined in Lib/socket.py); cross-check anchors __init__; first socketmethcls90 anchor for socket dunder method class names"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketmethcls90

  columns: [id, function, args, expected]
  rows:
    - [socket_enter_func,   socket.__enter__.__class__.__name__.__eq__, ["function"], true]
    - [socket_exit_func,    socket.__exit__.__class__.__name__.__eq__,  ["function"], true]
    - [socket_repr_func,    socket.__repr__.__class__.__name__.__eq__,  ["function"], true]
    - [socket_init_func2,   socket.__init__.__class__.__name__.__eq__,  ["function"], true]

# ---------------------------------------------------------------------------
# socket.create_connection/__class__/__name__.__eq__('function')
# socket.create_server/__class__/__name__.__eq__('function')
# socket.getfqdn/__class__/__name__.__eq__('function')
# socket.socket.sendfile/__class__/__name__.__eq__('function') (cross-check)
#
# Wave 256 theme: module-level Python function class names.
#
# socket.create_connection, create_server, and getfqdn are module-level Python
# functions defined in Lib/socket.py. Their __class__.__name__ is 'function'.
# This is in contrast to socket.gethostname and socket.gethostbyname which are
# C-backed builtin_function_or_method objects.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra90.socket_module_func_class_names:
  description: "socket.create_connection/__class__.__name__.__eq__('function')==True / socket.create_server/__class__.__name__.__eq__('function')==True / socket.getfqdn/__class__.__name__.__eq__('function')==True / socket.socket.sendfile/__class__.__name__.__eq__('function')==True — create_connection/create_server/getfqdn are module-level Python functions in Lib/socket.py; cross-check anchors sendfile; first socketmethcls90 anchor for module-level Python function class names"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketmethcls90

  columns: [id, function, args, expected]
  rows:
    - [create_connection_func,  create_connection.__class__.__name__.__eq__, ["function"], true]
    - [create_server_func,      create_server.__class__.__name__.__eq__,     ["function"], true]
    - [getfqdn_func,            getfqdn.__class__.__name__.__eq__,           ["function"], true]
    - [socket_sendfile_func2,   socket.sendfile.__class__.__name__.__eq__,   ["function"], true]

# ---------------------------------------------------------------------------
# socket.socket.accept.__class__.__name__.__eq__('function') — standalone
#
# socket.socket.accept is a Python-level function defined in Lib/socket.py.
# Its __class__.__name__ is 'function'. No prior socket spec anchors
# socket.accept.__class__.__name__.__eq__ as a standalone under socketmethcls90.
# First standalone for socket.socket.accept class identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra90.socket_accept_func:
  description: "socket.socket.accept.__class__.__name__.__eq__('function') == True — socket.socket.accept is a Python-level function in Lib/socket.py (not a C method_descriptor); its __class__.__name__ is 'function'; no prior socket spec anchors this __eq__ call; first standalone for socket.socket.accept class identity under socketmethcls90"
  category: class_attrs
  kind: python_call_eq
  function: socket.accept.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__enter__.__class__.__name__.__eq__('function') — standalone
#
# socket.socket.__enter__ is a Python-level function (context manager entry).
# Its __class__.__name__ is 'function'. No prior socket spec anchors
# socket.__enter__.__class__.__name__.__eq__ as a standalone under socketmethcls90.
# First standalone for socket.socket.__enter__ class identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra90.socket_enter_func:
  description: "socket.socket.__enter__.__class__.__name__.__eq__('function') == True — socket.socket.__enter__ is a Python-level function providing context manager support (returns self); its __class__.__name__ is 'function'; no prior socket spec anchors this __eq__ call; first standalone for socket.socket.__enter__ class identity under socketmethcls90"
  category: class_attrs
  kind: python_call_eq
  function: socket.__enter__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_connection.__class__.__name__.__eq__('function') — standalone
#
# socket.create_connection is a module-level Python function in Lib/socket.py.
# Its __class__.__name__ is 'function'. No prior socket spec anchors
# create_connection.__class__.__name__.__eq__ as a standalone under socketmethcls90.
# First standalone for socket.create_connection class identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
