invariant socket_extra90.socket_sendfile_func:
  description: "socket.socket.sendfile.__class__.__name__.__eq__('function') == True — socket.socket.sendfile is a Python-level function in Lib/socket.py for efficient file sending; its __class__.__name__ is 'function'; no prior socket spec anchors this __eq__ call; first standalone for socket.socket.sendfile class identity under socketmethcls90"
  category: class_attrs
  kind: python_call_eq
  function: socket.sendfile.__class__.__name__.__eq__
