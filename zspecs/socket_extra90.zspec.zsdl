invariant socket_extra90.create_connection_func:
  description: "socket.create_connection.__class__.__name__.__eq__('function') == True — socket.create_connection is a pure-Python convenience function in Lib/socket.py; its __class__.__name__ is 'function'; no prior socket spec anchors this __eq__ call; first standalone for socket.create_connection class identity under socketmethcls90"
  category: class_attrs
  kind: python_call_eq
  function: create_connection.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.sendfile.__class__.__name__.__eq__('function') — standalone
#
# socket.socket.sendfile is a Python-level function on socket.socket.
# Its __class__.__name__ is 'function'. No prior socket spec anchors
