spec: asyncio_extra1501
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-future.html — Python asyncio Future and Task documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-stream.html — Python asyncio streams documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "Wave 547 theme: async protocol method __dict__ presence checks for asyncio classes."
    - "asyncio.Future.__dict__.__contains__('__await__')==True — Future defines __await__ in its own __dict__; this makes Future directly awaitable; the C-accelerated asyncio.Future in _asyncio defines __await__ as a method that returns an iterator over the future's result."
    - "asyncio.Task.__dict__.__contains__('__await__')==True — Task also defines __await__ in its own __dict__ (inherited from Future but overridden at the C level); Task is a Future subclass that wraps a coroutine."
    - "asyncio.TaskGroup.__dict__.__contains__('__aenter__')==True and __aexit__==True — TaskGroup is an async context manager that manages a group of tasks; both methods are defined directly in TaskGroup.__dict__."
    - "asyncio.Timeout.__dict__.__contains__('__aenter__')==True and __aexit__==True — Timeout is an async context manager introduced in Python 3.11 for coroutine timeout control."
    - "asyncio.AbstractServer.__dict__.__contains__('__aenter__')==True and __aexit__==True — AbstractServer supports async with for server lifecycle management."
    - "asyncio.Barrier.__dict__.__contains__('__aenter__')==True and __aexit__==True — Barrier is an async context manager for coroutine synchronization."
    - "asyncio.StreamReader.__dict__.__contains__('__aiter__')==True and __anext__==True — StreamReader is an async iterator supporting async for loops over incoming data chunks."
    - "asyncio.Lock does NOT define __aenter__ in its own __dict__ — Lock inherits __aenter__/__aexit__ from asyncio.locks._ContextManagerMixin, so they are NOT in Lock.__dict__ directly."
    - "asyncio.Future does NOT define __aenter__ in its own __dict__ — Future is awaitable (__await__) but is not an async context manager."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Future and asyncio.Task __await__ in own __dict__
#
# asyncio.Future.__dict__.__contains__('__await__') == True
# asyncio.Task.__dict__.__contains__('__await__')   == True
# asyncio.Future.__dict__.__contains__('__aenter__') == False  (not a ctx mgr)
# asyncio.Task.__dict__.__contains__('__aenter__')   == False  (not a ctx mgr)
# asyncio.Future.__dict__.__contains__('__aiter__')  == False  (not async iter)
# asyncio.Task.__dict__.__contains__('__aiter__')    == False  (not async iter)
# ---------------------------------------------------------------------------

table asyncio_extra1501.future_task_await_dict:
  description: "asyncio.Future and asyncio.Task __await__ presence in own __dict__ — as1501ft namespace. asyncio.Future.__dict__.__contains__('__await__')==True (Future defines __await__ directly in its C-level __dict__; this is what makes Future directly awaitable with the await keyword; Future.__await__ returns a generator-based iterator that yields until the future result is set; the C implementation in _asynciomodule.c defines FutureType_await which is registered as __await__); asyncio.Task.__dict__.__contains__('__await__')==True (Task also defines __await__ in its own C-level __dict__; Task is a Future subclass but defines its own __await__ at the C level); asyncio.Future.__dict__.__contains__('__aenter__')==False (Future is awaitable but NOT an async context manager — it defines __await__ but not __aenter__/__aexit__); asyncio.Task.__dict__.__contains__('__aenter__')==False (same as Future — Task is awaitable but not an async context manager); asyncio.Future.__dict__.__contains__('__aiter__')==False (Future is not an async iterator); asyncio.Task.__dict__.__contains__('__aiter__')==False (Task is not an async iterator); verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: as1501ft

  columns: [id, function, args, expected, description]
  rows:
    - [as1501ft001, asyncio.Future.__dict__.__contains__, ["__await__"],  true,  "asyncio.Future.__dict__.__contains__('__await__')==True — Future defines __await__ in its own C-level __dict__; verified with Python 3.14.4"]
    - [as1501ft002, asyncio.Task.__dict__.__contains__,   ["__await__"],  true,  "asyncio.Task.__dict__.__contains__('__await__')==True — Task defines __await__ in its own C-level __dict__; verified with Python 3.14.4"]
    - [as1501ft003, asyncio.Future.__dict__.__contains__, ["__aenter__"], false, "asyncio.Future.__dict__.__contains__('__aenter__')==False — Future is awaitable but not an async context manager; verified with Python 3.14.4"]
    - [as1501ft004, asyncio.Task.__dict__.__contains__,   ["__aenter__"], false, "asyncio.Task.__dict__.__contains__('__aenter__')==False — Task is awaitable but not an async context manager; verified with Python 3.14.4"]
    - [as1501ft005, asyncio.Future.__dict__.__contains__, ["__aiter__"],  false, "asyncio.Future.__dict__.__contains__('__aiter__')==False — Future is not an async iterator; verified with Python 3.14.4"]
    - [as1501ft006, asyncio.Task.__dict__.__contains__,   ["__aiter__"],  false, "asyncio.Task.__dict__.__contains__('__aiter__')==False — Task is not an async iterator; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.TaskGroup, asyncio.Timeout, asyncio.AbstractServer __aenter__/__aexit__
#
# asyncio.TaskGroup.__dict__.__contains__('__aenter__') == True
# asyncio.TaskGroup.__dict__.__contains__('__aexit__')  == True
# asyncio.Timeout.__dict__.__contains__('__aenter__')   == True
# asyncio.Timeout.__dict__.__contains__('__aexit__')    == True
# asyncio.AbstractServer.__dict__.__contains__('__aenter__') == True
# asyncio.AbstractServer.__dict__.__contains__('__aexit__')  == True
# ---------------------------------------------------------------------------

table asyncio_extra1501.context_managers_aenter_aexit_dict:
  description: "asyncio async context managers with __aenter__/__aexit__ in their own __dict__ — as1501cm namespace. asyncio.TaskGroup.__dict__.__contains__('__aenter__')==True (TaskGroup is an async context manager introduced in Python 3.11; __aenter__ returns self and __aexit__ cancels remaining tasks on exception; TaskGroup manages a set of related tasks as a group; both __aenter__ and __aexit__ are defined directly in TaskGroup.__dict__); asyncio.TaskGroup.__dict__.__contains__('__aexit__')==True (see above); asyncio.Timeout.__dict__.__contains__('__aenter__')==True (Timeout is an async context manager introduced in Python 3.11 via asyncio.timeout(); __aenter__ sets up the timeout deadline and __aexit__ cancels the timeout or re-raises TimeoutError; both defined directly in Timeout.__dict__); asyncio.Timeout.__dict__.__contains__('__aexit__')==True (see above); asyncio.AbstractServer.__dict__.__contains__('__aenter__')==True (AbstractServer supports 'async with server:' idiom; __aenter__ returns self and __aexit__ calls close() and wait_closed()); asyncio.AbstractServer.__dict__.__contains__('__aexit__')==True (see above); verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: as1501cm

  columns: [id, function, args, expected, description]
  rows:
    - [as1501cm001, asyncio.TaskGroup.__dict__.__contains__,     ["__aenter__"], true, "asyncio.TaskGroup.__dict__.__contains__('__aenter__')==True — TaskGroup is an async context manager (Python 3.11+); verified with Python 3.14.4"]
    - [as1501cm002, asyncio.TaskGroup.__dict__.__contains__,     ["__aexit__"],  true, "asyncio.TaskGroup.__dict__.__contains__('__aexit__')==True — TaskGroup defines __aexit__ to cancel remaining tasks on exception; verified with Python 3.14.4"]
    - [as1501cm003, asyncio.Timeout.__dict__.__contains__,       ["__aenter__"], true, "asyncio.Timeout.__dict__.__contains__('__aenter__')==True — Timeout is an async context manager for coroutine timeout control; verified with Python 3.14.4"]
    - [as1501cm004, asyncio.Timeout.__dict__.__contains__,       ["__aexit__"],  true, "asyncio.Timeout.__dict__.__contains__('__aexit__')==True — Timeout defines __aexit__ to cancel or re-raise TimeoutError; verified with Python 3.14.4"]
    - [as1501cm005, asyncio.AbstractServer.__dict__.__contains__, ["__aenter__"], true, "asyncio.AbstractServer.__dict__.__contains__('__aenter__')==True — AbstractServer supports 'async with' for server lifecycle; verified with Python 3.14.4"]
    - [as1501cm006, asyncio.AbstractServer.__dict__.__contains__, ["__aexit__"],  true, "asyncio.AbstractServer.__dict__.__contains__('__aexit__')==True — AbstractServer.__aexit__ calls close() and wait_closed(); verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Barrier and asyncio.StreamReader async protocol checks
#
# asyncio.Barrier.__dict__.__contains__('__aenter__') == True
# asyncio.Barrier.__dict__.__contains__('__aexit__')  == True
# asyncio.StreamReader.__dict__.__contains__('__aiter__') == True
# asyncio.StreamReader.__dict__.__contains__('__anext__') == True
# asyncio.Lock.__dict__.__contains__('__aenter__')    == False  (inherited, not own)
# asyncio.Semaphore.__dict__.__contains__('__aenter__') == False (inherited, not own)
# ---------------------------------------------------------------------------

table asyncio_extra1501.barrier_streamreader_lock_dict:
  description: "asyncio.Barrier, asyncio.StreamReader, asyncio.Lock async protocol __dict__ checks — as1501bs namespace. asyncio.Barrier.__dict__.__contains__('__aenter__')==True (Barrier is an async context manager and synchronization primitive; all waiting coroutines are released simultaneously; both __aenter__ and __aexit__ defined directly in Barrier.__dict__); asyncio.Barrier.__dict__.__contains__('__aexit__')==True (see above); asyncio.StreamReader.__dict__.__contains__('__aiter__')==True (StreamReader implements the async iterator protocol via __aiter__ defined in its own __dict__; this allows 'async for line in reader:' iteration); asyncio.StreamReader.__dict__.__contains__('__anext__')==True (StreamReader.__anext__ is defined in its own __dict__; it reads one line per iteration, raising StopAsyncIteration at EOF); asyncio.Lock.__dict__.__contains__('__aenter__')==False (KEY: Lock does NOT define __aenter__ in its own __dict__; Lock inherits __aenter__/__aexit__ from asyncio.locks._ContextManagerMixin; they are NOT in Lock.__dict__ directly — only in _ContextManagerMixin.__dict__); asyncio.Semaphore.__dict__.__contains__('__aenter__')==False (same as Lock — Semaphore also inherits from _ContextManagerMixin and does not define __aenter__ in its own __dict__); verified with Python 3.14.4"
  kind: python_call_eq
  category: async_protocol
  id_prefix: as1501bs

  columns: [id, function, args, expected, description]
  rows:
    - [as1501bs001, asyncio.Barrier.__dict__.__contains__,    ["__aenter__"], true,  "asyncio.Barrier.__dict__.__contains__('__aenter__')==True — Barrier defines __aenter__ directly in its own __dict__; verified with Python 3.14.4"]
    - [as1501bs002, asyncio.Barrier.__dict__.__contains__,    ["__aexit__"],  true,  "asyncio.Barrier.__dict__.__contains__('__aexit__')==True — Barrier defines __aexit__ directly in its own __dict__; verified with Python 3.14.4"]
    - [as1501bs003, asyncio.StreamReader.__dict__.__contains__, ["__aiter__"],  true,  "asyncio.StreamReader.__dict__.__contains__('__aiter__')==True — StreamReader defines __aiter__ for 'async for' iteration; verified with Python 3.14.4"]
    - [as1501bs004, asyncio.StreamReader.__dict__.__contains__, ["__anext__"],  true,  "asyncio.StreamReader.__dict__.__contains__('__anext__')==True — StreamReader defines __anext__ to yield lines asynchronously; verified with Python 3.14.4"]
    - [as1501bs005, asyncio.Lock.__dict__.__contains__,       ["__aenter__"], false, "asyncio.Lock.__dict__.__contains__('__aenter__')==False — Lock inherits __aenter__ from _ContextManagerMixin; NOT in Lock.__dict__ directly; verified with Python 3.14.4"]
    - [as1501bs006, asyncio.Semaphore.__dict__.__contains__,  ["__aenter__"], false, "asyncio.Semaphore.__dict__.__contains__('__aenter__')==False — Semaphore inherits __aenter__ from _ContextManagerMixin; NOT in Semaphore.__dict__ directly; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1501
# ---------------------------------------------------------------------------

invariant asyncio_extra1501.future_dict_has_await:
  description: "asyncio.Future.__dict__.__contains__('__await__') returns True — asyncio.Future defines __await__ in its own C-level __dict__; this is the async protocol method that makes Future directly awaitable; the CPython implementation in Modules/_asynciomodule.c registers __await__ on the FutureType C type; '__await__' in asyncio.Future.__dict__ is True (verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12); wave 547 theme: async protocol __dict__ presence checks"
  category: async_protocol
  kind: python_call_eq
  function: asyncio.Future.__dict__.__contains__
  args: ["__await__"]
  expected: true

invariant asyncio_extra1501.task_dict_has_await:
  description: "asyncio.Task.__dict__.__contains__('__await__') returns True — asyncio.Task defines __await__ in its own C-level __dict__; Task is a subclass of Future and also defines __await__ at the C level; both Future and Task have '__await__' in their own __dict__ (not just inherited); this distinguishes them from sync classes like concurrent.futures.Future which has '__await__' not in its __dict__; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12; wave 547 theme"
  category: async_protocol
  kind: python_call_eq
  function: asyncio.Task.__dict__.__contains__
  args: ["__await__"]
  expected: true

invariant asyncio_extra1501.taskgroup_dict_has_aenter:
  description: "asyncio.TaskGroup.__dict__.__contains__('__aenter__') returns True — asyncio.TaskGroup defines __aenter__ in its own __dict__; TaskGroup is an async context manager (introduced Python 3.11) that groups related tasks and cancels them together on error; TaskGroup.__aenter__ enters the group scope and TaskGroup.__aexit__ waits for all tasks and propagates exceptions; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12; wave 547 theme"
  category: async_protocol
  kind: python_call_eq
  function: asyncio.TaskGroup.__dict__.__contains__
  args: ["__aenter__"]
  expected: true

invariant asyncio_extra1501.streamreader_dict_has_aiter:
  description: "asyncio.StreamReader.__dict__.__contains__('__aiter__') returns True — asyncio.StreamReader defines __aiter__ in its own __dict__; StreamReader supports 'async for line in reader:' because it defines both __aiter__ and __anext__ directly on the class; __aiter__ returns self and __anext__ reads the next line asynchronously, raising StopAsyncIteration at EOF; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12; wave 547 theme"
  category: async_protocol
  kind: python_call_eq
  function: asyncio.StreamReader.__dict__.__contains__
  args: ["__aiter__"]
  expected: true

invariant asyncio_extra1501.lock_dict_no_aenter:
  description: "asyncio.Lock.__dict__.__contains__('__aenter__') returns False — asyncio.Lock does NOT define __aenter__ in its own __dict__; Lock inherits __aenter__ and __aexit__ from asyncio.locks._ContextManagerMixin; the _ContextManagerMixin base class defines these methods and Lock.__mro__ includes _ContextManagerMixin before object; while 'async with lock:' works for Lock, the method is NOT in Lock.__dict__ but in _ContextManagerMixin.__dict__; verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12; wave 547 theme"
  category: async_protocol
  kind: python_call_eq
  function: asyncio.Lock.__dict__.__contains__
  args: ["__aenter__"]
  expected: false
