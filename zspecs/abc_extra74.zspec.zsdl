spec: abc_extra74
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra73.zspec.zsdl."
    - "This spec covers: wave 244 theme — abc ABC/ABCMeta __dict__ membership for key methods. NEW in extra74: ABC.__dict__.__contains__('__abstractmethods__')==True (ABC sets __abstractmethods__ as a class-level frozenset in its definition); ABC.__dict__.__contains__('__subclasshook__')==False (__subclasshook__ is NOT in ABC.__dict__; it is defined in ABCMeta via the type); ABC.__dict__.__contains__('__init_subclass__')==False (__init_subclass__ is NOT in ABC.__dict__ on Python 3.14.3); ABCMeta.__dict__.__contains__('register')==True; ABCMeta.__dict__.__contains__('__instancecheck__')==True; ABCMeta.__dict__.__contains__('__subclasscheck__')==True; ABCMeta.__dict__.__contains__('_dump_registry')==True; ABCMeta.__dict__.__contains__('__new__')==True; ABCMeta.register.__class__.__name__=='function'; ABCMeta._dump_registry.__class__.__name__=='function'; abstractproperty.__dict__.__contains__('__init__')==False; abstractproperty.__dict__.__contains__('__isabstractmethod__')==True; abstractproperty.__dict__.__class__.__name__=='mappingproxy'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('__abstractmethods__') == True. ABC defines __abstractmethods__ as a frozenset at class level to indicate it is abstract. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('__subclasshook__') == False. __subclasshook__ is NOT defined directly in ABC.__dict__; it is inherited from ABCMeta machinery. ABC.__dict__ keys are: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('__init_subclass__') == False. __init_subclass__ is NOT in ABC.__dict__ on Python 3.14.3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('register') == True. register is a method defined directly in ABCMeta in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True. __instancecheck__ is defined in ABCMeta to support isinstance() checks with ABCs. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True. __subclasscheck__ is defined in ABCMeta to support issubclass() checks with ABCs. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('_dump_registry') == True. _dump_registry is a helper method defined in ABCMeta for debugging. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('__new__') == True. __new__ is defined in ABCMeta to set up the abstract method tracking machinery. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__class__.__name__ == 'function'. register is a plain Python function defined in ABCMeta (not a classmethod or staticmethod wrapper). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta._dump_registry.__class__.__name__ == 'function'. _dump_registry is a plain Python function defined in ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__dict__.__contains__('__init__') == False. abstractproperty does NOT define __init__ in its own __dict__; it inherits __init__ from property. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__dict__.__contains__('__isabstractmethod__') == True. abstractproperty defines __isabstractmethod__ as a class attribute set to True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ objects are always mappingproxy in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABC.__dict__ membership checks — extra74
#
# Wave 244 theme: ABC/ABCMeta __dict__ membership for key methods.
#
# ABC.__dict__.__contains__('__abstractmethods__') == True
# ABC.__dict__.__contains__('__subclasshook__') == False
# ABC.__dict__.__contains__('__init_subclass__') == False
# ---------------------------------------------------------------------------

table abc_extra74.ABC_dict_membership:
  description: "abc ABC.__dict__ membership checks in abcmore74 namespace — wave 244 theme: ABC/ABCMeta __dict__ membership; ABC.__dict__.__contains__('__abstractmethods__')==True (ABC defines __abstractmethods__ as a class-level frozenset); ABC.__dict__.__contains__('__subclasshook__')==False (__subclasshook__ is NOT in ABC.__dict__; ABC.__dict__ keys are module, firstlineno, doc, slots, static_attributes, abstractmethods, _abc_impl); ABC.__dict__.__contains__('__init_subclass__')==False (__init_subclass__ not in ABC.__dict__ on Python 3.14.3); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcmore74

  columns: [id, function, args, expected, description]
  rows:
    - [abc_dict_has_abstractmethods, ABC.__dict__.__contains__, ["__abstractmethods__"], true,  "ABC.__dict__.__contains__('__abstractmethods__') == True — ABC defines __abstractmethods__ as a class-level frozenset; verified with Python 3.14.3"]
    - [abc_dict_no_subclasshook,     ABC.__dict__.__contains__, ["__subclasshook__"],    false, "ABC.__dict__.__contains__('__subclasshook__') == False — __subclasshook__ is NOT in ABC.__dict__; verified with Python 3.14.3"]
    - [abc_dict_no_init_subclass,    ABC.__dict__.__contains__, ["__init_subclass__"],   false, "ABC.__dict__.__contains__('__init_subclass__') == False — __init_subclass__ not in ABC.__dict__ on Python 3.14.3; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta.__dict__ membership checks — extra74
#
# ABCMeta.__dict__.__contains__('register') == True
# ABCMeta.__dict__.__contains__('__instancecheck__') == True
# ABCMeta.__dict__.__contains__('__subclasscheck__') == True
# ABCMeta.__dict__.__contains__('_dump_registry') == True
# ABCMeta.__dict__.__contains__('__new__') == True
# ---------------------------------------------------------------------------

table abc_extra74.ABCMeta_dict_membership:
  description: "abc ABCMeta.__dict__ membership checks in abcmore74 namespace — wave 244 theme: ABCMeta __dict__ membership; ABCMeta.__dict__.__contains__('register')==True; ABCMeta.__dict__.__contains__('__instancecheck__')==True; ABCMeta.__dict__.__contains__('__subclasscheck__')==True; ABCMeta.__dict__.__contains__('_dump_registry')==True; ABCMeta.__dict__.__contains__('__new__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcmore74a

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_has_register,      ABCMeta.__dict__.__contains__, ["register"],          true, "ABCMeta.__dict__.__contains__('register') == True — register is defined in ABCMeta; verified with Python 3.14.3"]
    - [abcmeta_dict_has_instancecheck, ABCMeta.__dict__.__contains__, ["__instancecheck__"], true, "ABCMeta.__dict__.__contains__('__instancecheck__') == True — __instancecheck__ supports isinstance() with ABCs; verified with Python 3.14.3"]
    - [abcmeta_dict_has_subclasscheck, ABCMeta.__dict__.__contains__, ["__subclasscheck__"], true, "ABCMeta.__dict__.__contains__('__subclasscheck__') == True — __subclasscheck__ supports issubclass() with ABCs; verified with Python 3.14.3"]
    - [abcmeta_dict_has_dump_registry, ABCMeta.__dict__.__contains__, ["_dump_registry"],    true, "ABCMeta.__dict__.__contains__('_dump_registry') == True — _dump_registry is a helper method in ABCMeta; verified with Python 3.14.3"]
    - [abcmeta_dict_has_new,           ABCMeta.__dict__.__contains__, ["__new__"],            true, "ABCMeta.__dict__.__contains__('__new__') == True — __new__ is defined in ABCMeta to set up abstract method tracking; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta method class names — extra74
#
# ABCMeta.register.__class__.__name__ == 'function'
# ABCMeta._dump_registry.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table abc_extra74.ABCMeta_method_class_names:
  description: "abc ABCMeta.register and _dump_registry __class__.__name__ checks in abcmore74 namespace — wave 244 theme: ABCMeta method class names; ABCMeta.register.__class__.__name__=='function' (register is a plain Python function in ABCMeta, not a classmethod or staticmethod wrapper); ABCMeta._dump_registry.__class__.__name__=='function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmore74b

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_register_class_name,      ABCMeta.register.__class__.__name__.__eq__,      ["function"], true, "ABCMeta.register.__class__.__name__ == 'function' — register is a plain Python function in ABCMeta; verified with Python 3.14.3"]
    - [abcmeta_dump_reg_class_name,      ABCMeta._dump_registry.__class__.__name__.__eq__, ["function"], true, "ABCMeta._dump_registry.__class__.__name__ == 'function' — _dump_registry is a plain Python function in ABCMeta; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc abstractproperty.__dict__ membership and class name + cross-check
# — extra74
# ---------------------------------------------------------------------------

table abc_extra74.abstractproperty_dict_and_cross_check:
  description: "abc abstractproperty __dict__ membership and class name checks plus cross-check in abcmore74 namespace — wave 244 theme: abstractproperty.__dict__ + cross-check; abstractproperty.__dict__.__contains__('__init__')==False (abstractproperty does NOT define __init__; inherits from property); abstractproperty.__dict__.__contains__('__isabstractmethod__')==True; abstractproperty.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is always mappingproxy in CPython); ABC.__dict__.__contains__('__abstractmethods__')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcmore74c

  columns: [id, function, args, expected, description]
  rows:
    - [absprop_dict_no_init,         abstractproperty.__dict__.__contains__,               ["__init__"],           false, "abstractproperty.__dict__.__contains__('__init__') == False — abstractproperty does NOT define __init__; inherits from property; verified with Python 3.14.3"]
    - [absprop_dict_has_isabstract,  abstractproperty.__dict__.__contains__,               ["__isabstractmethod__"], true, "abstractproperty.__dict__.__contains__('__isabstractmethod__') == True — abstractproperty defines __isabstractmethod__ = True; verified with Python 3.14.3"]
    - [absprop_dict_class_name,      abstractproperty.__dict__.__class__.__name__.__eq__,  ["mappingproxy"],       true, "abstractproperty.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always mappingproxy in CPython; verified with Python 3.14.3"]
    - [abc_abstractmethods_cross,    ABC.__dict__.__contains__,                             ["__abstractmethods__"], true, "ABC.__dict__.__contains__('__abstractmethods__') == True — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra74
# ---------------------------------------------------------------------------

invariant abc_extra74.ABC_dict_has_abstractmethods:
  description: "abc.ABC.__dict__.__contains__('__abstractmethods__') returns True — ABC defines __abstractmethods__ as a class-level frozenset to indicate it is abstract; NEW in extra74: first standalone __dict__.__contains__('__abstractmethods__') invariant for ABC in abcmore74 namespace; wave 244; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ABC.__dict__.__contains__
  args: ["__abstractmethods__"]
  expected: true

invariant abc_extra74.ABC_dict_no_subclasshook:
  description: "abc.ABC.__dict__.__contains__('__subclasshook__') returns False — __subclasshook__ is NOT in ABC.__dict__; ABC.__dict__ contains only: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl; NEW in extra74: first standalone __dict__.__contains__('__subclasshook__')==False invariant for ABC in abcmore74 namespace; wave 244; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ABC.__dict__.__contains__
  args: ["__subclasshook__"]
  expected: false

invariant abc_extra74.ABCMeta_dict_has_register:
  description: "abc.ABCMeta.__dict__.__contains__('register') returns True — register is defined directly in ABCMeta in abc.py for registering virtual subclasses; NEW in extra74: first standalone __dict__.__contains__('register') invariant for ABCMeta in abcmore74 namespace; wave 244; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: ABCMeta.__dict__.__contains__
  args: ["register"]
  expected: true

invariant abc_extra74.abstractproperty_dict_has_isabstractmethod:
  description: "abc.abstractproperty.__dict__.__contains__('__isabstractmethod__') returns True — abstractproperty defines __isabstractmethod__ as a class attribute set to True, marking decorated properties as abstract; NEW in extra74: first standalone __dict__.__contains__('__isabstractmethod__') invariant for abstractproperty in abcmore74 namespace; wave 244; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: abstractproperty.__dict__.__contains__
  args: ["__isabstractmethod__"]
  expected: true

invariant abc_extra74.abstractproperty_dict_class_name:
  description: "abc.abstractproperty.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — class __dict__ objects are always read-only mappingproxy in CPython; abstractproperty is a Python class so its __dict__ is a mappingproxy; NEW in extra74: first standalone __dict__.__class__.__name__ invariant for abstractproperty in abcmore74 namespace; wave 244; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: abstractproperty.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
