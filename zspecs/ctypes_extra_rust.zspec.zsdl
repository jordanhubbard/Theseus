spec: ctypes_extra_rust
version: ">=3.9"
backend: rust_module(ctypes_extra_rust)

docs: https://docs.python.org/3/library/ctypes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ctypes.html — ctypes stdlib"
  notes:
    - "ctypes provides C-compatible data types and calls DLLs."
    - "ctypes.c_int is a type."
    - "ctypes.CDLL is a class."
    - "ctypes.sizeof(ctypes.c_int) > 0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant ctypes_extra_rust.c_int_sizeof_positive:
  description: "ctypes.sizeof(ctypes.c_int) > 0"
  category: sizeof
  kind: python_call_eq
  function: ctypes_extra_sizeof_c_int_positive
  args: []
  expected: true

invariant ctypes_extra_rust.has_cdll:
  description: "ctypes.CDLL is a class"
  category: presence
  kind: python_call_eq
  function: ctypes_extra_has_cdll
  args: []
  expected: true

invariant ctypes_extra_rust.has_c_int:
  description: "ctypes.c_int is a type"
  category: presence
  kind: python_call_eq
  function: ctypes_extra_has_c_int
  args: []
  expected: true

