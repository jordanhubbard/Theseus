spec: uuid_extra94
version: ">=3.9"
backend: python_module(uuid)
extends: uuid_extra93

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra93.zspec.zsdl — covers uuid.__name__/__spec__.name/__spec__.__class__.__name__/__loader__.__class__.__name__ lengths / __spec__.has_location / UUID/__module__/__len__()/uuid1/__module__/__len__()/uuid4/__module__/__len__() (table + invariants)."
    - "uuid_extra92.zspec.zsdl — covers uuid.UUID property fget.__code__.co_name equality / fget.__code__.co_argcount==1 / co_name.__len__() values (table + invariants)."
    - "uuid_extra91.zspec.zsdl — covers uuid.UUID.__init__/__str__/__repr__/__eq__/__hash__/__lt__/__int__ __qualname__.__len__() / uuid1/uuid4 __qualname__.__len__() / qualname equality cross-checks (table + invariants)."
    - "uuid_extra90.zspec.zsdl — covers NAMESPACE_URL/OID/X500 class names / NAMESPACE_* version==1 / RFC_4122/RESERVED_* class names and __len__() / UUID.__class__.__name__=='type' (table + invariants)."
    - "uuid_extra89.zspec.zsdl — covers UUID method __module__.__eq__('uuid') / UUID.fields.fget class/qualname / getnode/__code__.co_name / uuid5.__module__ (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers uuid.UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra93; it does NOT duplicate invariants present in those files."
    - "Wave 265 theme: uuid.UUID.__slots__ / UUID.__bases__ and __mro__ / UUID.__setattr__ class / uuid3/uuid5/getnode __qualname__ lengths / SafeUUID class identity."
    - "uuid.UUID.__slots__.__class__.__name__ == 'tuple'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__[0] == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__[1] == 'is_safe'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__[2] == '__weakref__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__setattr__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__qualname__.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__qualname__.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__qualname__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__class__.__name__ == 'EnumType'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__mro__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID.__slots__ is a 3-tuple containing 'int' (the UUID integer value storage), 'is_safe' (SafeUUID enum field), and '__weakref__' (weak reference support)."
    - "Note: UUID.__mro__ has depth 2 (UUID + object), the minimal depth for a class with no intermediate base."
    - "Note: UUID.__setattr__ is a 'function' (pure Python override) because UUID instances are immutable — __setattr__ is overridden to raise AttributeError for any attribute write."
    - "Note: SafeUUID.__mro__.__len__()==3 because SafeUUID inherits from Enum which has its own base chain."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__class__.__name__.__eq__('tuple')
# uuid.UUID.__slots__.__len__()==3
# uuid.UUID.__slots__[0].__eq__('int')
# uuid.UUID.__slots__[1].__eq__('is_safe')
# uuid.UUID.__slots__[2].__eq__('__weakref__')
#
# Wave 265 theme: UUID.__slots__ class identity and contents.
#
# UUID defines __slots__ as a 3-tuple: ('int', 'is_safe', '__weakref__').
# 'int' stores the 128-bit integer representation of the UUID value.
# 'is_safe' stores a SafeUUID enum value indicating how the UUID was generated.
# '__weakref__' enables weak reference support. Using __slots__ prevents the
# creation of a per-instance __dict__, making UUID instances memory-efficient.
# No prior uuid spec anchors UUID.__slots__ class name, length, or element
# values under uuidslots94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra94.UUID_slots_identity:
  description: "uuid.UUID.__slots__/__class__.__name__.__eq__('tuple')==True / __slots__/__len__()==3 / __slots__[0].__eq__('int')==True / __slots__[1].__eq__('is_safe')==True / __slots__[2].__eq__('__weakref__')==True — UUID.__slots__ is a 3-tuple; 'int' stores the 128-bit integer, 'is_safe' the SafeUUID enum field, '__weakref__' enables weak references; no __dict__ per instance; no prior uuid spec anchors __slots__ contents; first uuidslots94 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidslots94

  columns: [id, function, args, expected, description]
  rows:
    - [slots_class,    "UUID.__slots__.__class__.__name__.__eq__",  ["tuple"],        true, "UUID.__slots__ is a tuple"]
    - [slots_len,      UUID.__slots__.__len__,                      [],               3,    "UUID.__slots__ has 3 entries: 'int', 'is_safe', '__weakref__'"]
    - [slots_0,        "UUID.__slots__[0].__eq__",                  ["int"],          true, "First slot is 'int': stores the 128-bit UUID integer value"]
    - [slots_1,        "UUID.__slots__[1].__eq__",                  ["is_safe"],      true, "Second slot is 'is_safe': stores a SafeUUID enum value"]
    - [slots_2,        "UUID.__slots__[2].__eq__",                  ["__weakref__"],  true, "Third slot is '__weakref__': enables weak reference support"]

# ---------------------------------------------------------------------------
# uuid.UUID.__bases__[0].__name__.__eq__('object')
# uuid.UUID.__mro__.__len__()==2
# uuid.UUID.__setattr__.__class__.__name__.__eq__('function')
#
# Wave 265 theme: UUID class inheritance, MRO depth, and __setattr__ type.
#
# UUID inherits directly from object — its single base class is object, giving
# a minimal MRO of depth 2. UUID.__setattr__ is overridden as a pure-Python
# function to make UUID instances immutable: it raises AttributeError on any
# attribute write. No prior uuid spec anchors UUID.__bases__[0].__name__,
# UUID.__mro__.__len__(), or UUID.__setattr__.__class__.__name__ under
# uuidslots94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra94.UUID_mro_and_setattr:
  description: "uuid.UUID/__bases__[0]/__name__.__eq__('object')==True / UUID/__mro__/__len__()==2 / UUID/__setattr__/__class__.__name__.__eq__('function')==True — UUID inherits directly from object (minimal MRO depth 2); __setattr__ is overridden as a pure-Python function that raises AttributeError, making UUID instances immutable; no prior uuid spec anchors these; first uuidslots94 anchor for UUID MRO and __setattr__"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidslots94

  columns: [id, function, args, expected, description]
  rows:
    - [bases_object,    "UUID.__bases__[0].__name__.__eq__",          ["object"],     true, "UUID's only base class is object"]
    - [mro_len,         UUID.__mro__.__len__,                         [],             2,    "MRO depth 2: UUID + object (minimal depth)"]
    - [setattr_class,   "UUID.__setattr__.__class__.__name__.__eq__", ["function"],   true, "__setattr__ is overridden as a pure-Python function to enforce immutability"]

# ---------------------------------------------------------------------------
# uuid.uuid3.__qualname__.__len__()==5
# uuid.uuid5.__qualname__.__len__()==5
# uuid.getnode.__qualname__.__len__()==7
# uuid.SafeUUID.__class__.__name__.__eq__('EnumType')
# uuid.SafeUUID.__module__.__eq__('uuid')
# uuid.SafeUUID.__mro__.__len__()==3
#
# Wave 265 theme: uuid3/uuid5/getnode __qualname__ lengths + SafeUUID class identity.
#
# uuid3 and uuid5 generate name-based UUIDs using MD5 and SHA-1 respectively.
# Their __qualname__ is 'uuid3' and 'uuid5' (both 5 chars). getnode returns the
# hardware address of the machine (7 chars qualname). SafeUUID is an IntEnum
# (actually an Enum subclass) whose metaclass is EnumType — this is the
# standard metaclass for all Python enums. SafeUUID is defined in uuid.py so
# its __module__ is 'uuid'. Its MRO has depth 3: SafeUUID -> Enum -> object.
# No prior uuid spec anchors these values under uuidslots94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra94.uuid_fn_qualname_lengths_and_SafeUUID:
  description: "uuid.uuid3/__qualname__/__len__()==5 / uuid5/__qualname__/__len__()==5 / getnode/__qualname__/__len__()==7 / SafeUUID/__class__.__name__.__eq__('EnumType')==True / SafeUUID/__module__.__eq__('uuid')==True / SafeUUID/__mro__/__len__()==3 — uuid3/uuid5 are 5-char qualnames; getnode is 7 chars; SafeUUID metaclass is EnumType; SafeUUID is defined in uuid.py; MRO depth 3 (SafeUUID + Enum + object); no prior uuid spec anchors these; first uuidslots94 anchor"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidslots94

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_qlen,          uuid3.__qualname__.__len__,                [], 5,    "'uuid3' is 5 chars; generates name-based UUID using MD5"]
    - [uuid5_qlen,          uuid5.__qualname__.__len__,                [], 5,    "'uuid5' is 5 chars; generates name-based UUID using SHA-1"]
    - [getnode_qlen,        getnode.__qualname__.__len__,              [], 7,    "'getnode' is 7 chars; returns hardware address of the machine"]
    - [SafeUUID_class,      "SafeUUID.__class__.__name__.__eq__",      ["EnumType"], true, "SafeUUID metaclass is EnumType (standard metaclass for all Python enums)"]
    - [SafeUUID_module,     "SafeUUID.__module__.__eq__",              ["uuid"],    true, "SafeUUID is defined in uuid.py, __module__ is 'uuid'"]
    - [SafeUUID_mro_len,    SafeUUID.__mro__.__len__,                  [],          3,    "MRO depth 3: SafeUUID + Enum + object"]

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__len__()==3 — standalone
#
# uuid.UUID.__slots__.__len__() is 3. The three slots are 'int', 'is_safe',
# and '__weakref__'. UUID uses __slots__ instead of __dict__ for memory
# efficiency: a UUID instance stores only the integer representation and the
# is_safe flag. Without __slots__, each instance would carry a full __dict__.
# No prior uuid spec anchors UUID.__slots__.__len__()==3 as a standalone under
# uuidslots94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra94.UUID_slots_len_3:
  description: "uuid.UUID.__slots__.__len__() == 3 — UUID.__slots__ contains 3 entries: 'int', 'is_safe', '__weakref__'; __slots__ avoids per-instance __dict__ for memory efficiency; no prior uuid spec anchors UUID.__slots__.__len__() as a standalone; first standalone for UUID.__slots__ length under uuidslots94"
  category: type_identity
  kind: python_call_eq
  function: UUID.__slots__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# uuid.UUID.__mro__.__len__()==2 — standalone
#
# uuid.UUID.__mro__.__len__() is 2. UUID inherits directly from object with no
# intermediate base class. The MRO (Method Resolution Order) contains only
# the UUID class itself and object, giving the minimal possible MRO depth of
# 2. This contrasts with SafeUUID (depth 3, through Enum) and with exception
# classes which have deeper MROs. No prior uuid spec anchors
# UUID.__mro__.__len__()==2 as a standalone under uuidslots94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra94.UUID_mro_len_2:
  description: "uuid.UUID.__mro__.__len__() == 2 — UUID inherits directly from object; MRO is (UUID, object) with minimal depth 2; contrasts with SafeUUID (depth 3) and exception classes; no prior uuid spec anchors UUID.__mro__.__len__() as a standalone; first standalone for UUID MRO depth under uuidslots94"
  category: type_identity
  kind: python_call_eq
  function: UUID.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# uuid.UUID.__setattr__.__class__.__name__.__eq__('function') — standalone
#
# uuid.UUID.__setattr__.__class__.__name__ is 'function'. UUID overrides
# __setattr__ to raise AttributeError on any attribute write, making UUID
# instances effectively immutable. The override is implemented as a pure-Python
# function (class 'function') in Lib/uuid.py, not as a C builtin. This
# prevents accidental modification of the UUID value after construction.
# No prior uuid spec anchors UUID.__setattr__.__class__.__name__ as a
# standalone under uuidslots94. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra94.UUID_setattr_function:
  description: "uuid.UUID.__setattr__.__class__.__name__.__eq__('function') == True — UUID.__setattr__ is a pure-Python function that raises AttributeError on attribute writes, enforcing UUID immutability; defined in Lib/uuid.py (class 'function', not a C builtin); no prior uuid spec anchors UUID.__setattr__.__class__.__name__ as a standalone; first standalone for UUID immutability mechanism under uuidslots94"
  category: type_identity
  kind: python_call_eq
  function: "UUID.__setattr__.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__mro__.__len__()==3 — standalone
#
# uuid.SafeUUID.__mro__.__len__() is 3. SafeUUID is a Python enum that indicates
# whether a UUID was generated using a method that is safe for use in a
# multiprocessing/multithreading context. Its MRO is (SafeUUID, Enum, object),
# giving depth 3. This contrasts with UUID (depth 2) and with normal enum
# classes that may have deeper MROs. No prior uuid spec anchors
# SafeUUID.__mro__.__len__()==3 as a standalone under uuidslots94.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra94.SafeUUID_mro_len_3:
  description: "uuid.SafeUUID.__mro__.__len__() == 3 — SafeUUID is an enum indicating multiprocessing-safe UUID generation; MRO is (SafeUUID, Enum, object), depth 3; contrasts with UUID (depth 2); no prior uuid spec anchors SafeUUID.__mro__.__len__() as a standalone; first standalone for SafeUUID MRO depth under uuidslots94"
  category: type_identity
  kind: python_call_eq
  function: SafeUUID.__mro__.__len__
  args: []
  expected: 3
