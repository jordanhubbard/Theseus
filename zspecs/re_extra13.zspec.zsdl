spec: re_extra13
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra12.zspec.zsdl."
    - "re_extra9 covers Pattern/Match/error __name__/__module__ table; error __qualname__; Pattern/Match __qualname__ standalone."
    - "re_extra6 covers compile.__name__ as a standalone invariant; compile.__module__ standalone."
    - "re_extra8 covers error.__qualname__, Match.__qualname__, Pattern.__qualname__ standalone."
    - "NOT yet covered: re.compile.__qualname__ == 'compile' as a standalone invariant."
    - "NOT yet covered: re.Pattern.mro().__len__() == 2 as a standalone invariant."
    - "NOT yet covered: re.Match.mro().__len__() == 2 as a standalone invariant."
    - "NOT yet covered: re.error.mro().__len__() == 4 as a standalone invariant."
    - "re.compile.__qualname__ == 'compile' — module-level function has qualname equal to name."
    - "re.Pattern.mro() has 2 entries: [Pattern, object] — Pattern is a direct subtype of object."
    - "re.Match.mro() has 2 entries: [Match, object] — Match is a direct subtype of object."
    - "re.error.mro() has 4 entries: [PatternError, Exception, BaseException, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile.__qualname__ — standalone invariant
#
# re_extra6 covers compile.__name__ == 'compile' as a standalone invariant
# and compile.__module__ == 're' as a standalone invariant.
# No prior spec records compile.__qualname__ as a standalone invariant.
# For a module-level function, __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant re_extra13.compile.qualname:
  description: "re.compile.__qualname__ == 'compile'"
  category: function_qualnames
  kind: python_call_eq
  function: compile.__qualname__.__eq__
  args: ["compile"]
  expected: true

# ---------------------------------------------------------------------------
# MRO lengths — Pattern, Match, error
#
# No prior re spec records the MRO length for Pattern, Match, or error.
# Pattern and Match are C-level types that inherit directly from object (len 2).
# error (PatternError in 3.12+) inherits from Exception via BaseException (len 4).
# ---------------------------------------------------------------------------

invariant re_extra13.Pattern.mro_len:
  description: "re.Pattern.mro() has 2 entries: [Pattern, object]"
  category: mro
  kind: python_call_eq
  function: Pattern.mro
  args: []
  method: __len__
  expected: 2

invariant re_extra13.Match.mro_len:
  description: "re.Match.mro() has 2 entries: [Match, object]"
  category: mro
  kind: python_call_eq
  function: Match.mro
  args: []
  method: __len__
  expected: 2

invariant re_extra13.error.mro_len:
  description: "re.error.mro() has 4 entries: [PatternError, Exception, BaseException, object]"
  category: mro
  kind: python_call_eq
  function: error.mro
  args: []
  method: __len__
  expected: 4

# ---------------------------------------------------------------------------
# Table: MRO lengths for Pattern, Match, and error
#
# Bundles the three MRO-length invariants as table rows for machine indexing.
# No prior re spec covers mro().__len__() for any of these types.
# ---------------------------------------------------------------------------

table re_extra13.function_qualnames:
  description: "re module-level functions have __qualname__ equal to __name__"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqn

  columns: [id, function, args, expected]
  rows:
    - [compile_qualname, compile.__qualname__.__eq__,  ["compile"],  true]
    - [escape_qualname,  escape.__qualname__.__eq__,   ["escape"],   true]
    - [purge_qualname,   purge.__qualname__.__eq__,    ["purge"],    true]
