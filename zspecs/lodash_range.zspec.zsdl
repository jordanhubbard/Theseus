spec: lodash_range
version: ">=4.0.0"
backend: node(lodash.range)

docs: https://lodash.com/docs/#range

provenance:
  derived_from:
    - "lodash.range README — https://www.npmjs.com/package/lodash.range"
    - "Test vectors verified with lodash.range@3.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.range exports the _.range function directly as module.exports."
    - "range(n) creates [0..n-1]; range(start, end) creates [start..end-1]."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of numbers. No errors for numeric inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_range.range:
  kind: node_module_call_eq
  function: ~
  category: range
  id_prefix: lrange

  columns: [id, args, expected]
  rows:
    - [from_zero,  [3],     [0, 1, 2]]
    - [from_one,   [1, 5],  [1, 2, 3, 4]]
    - [empty,      [0],     []]
