spec: decimal_extra56
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra55.zspec.zsdl — covers decimal.__loader__.__class__.__name__.__eq__('SourceFileLoader') and __len__()==16; decimal.__file__.__class__.__name__.__eq__('str'); decimal.__cached__.__class__.__name__.__eq__('str')."
    - "decimal_extra54.zspec.zsdl — covers decimal.__package__.__eq__(''); Decimal/Context __doc__.__class__.__name__.__len__()==3; decimal.__spec__.__class__.__name__.__eq__('ModuleSpec'); decimal.__spec__.name.__eq__('decimal') and __len__()==7."
    - "decimal_extra53.zspec.zsdl — covers decimal has no __all__; Decimal/Context/DecimalException/InvalidOperation __eq__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "decimal_extra34.zspec.zsdl — covers decimal.__name__.__len__()==7; decimal.__file__.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends decimal_extra55.zspec.zsdl."
    - "Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations + __loader__.__name__ length checks."
    - "IMPORTANT: decimal is a pure Python module (decimal.py, NOT a package). Its loader is a SourceFileLoader instance. SourceFileLoader instances do NOT have a __name__ attribute (AttributeError). The wave 226 theme of '__loader__.__name__ length checks' is interpreted for decimal as __loader__.__class__.__name__ (i.e. 'SourceFileLoader', 16 chars). decimal_extra55 covers __loader__.__class__.__name__.__eq__('SourceFileLoader') and __len__()==16; this wave 226 spec re-anchors them in decspec56 namespace for cross-wave traceability. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__loader__.__class__.__name__.__eq__('SourceFileLoader') and __len__()==16 — decimal.py is a pure Python module (not a package) loaded by SourceFileLoader. The loader is an instance of SourceFileLoader. __loader__.__class__.__name__ is 'SourceFileLoader' (16 characters). decimal_extra55 covers both anchors in decload55 namespace; this wave 226 spec re-anchors them in decspec56 namespace. Cross-wave traceability anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__spec__.origin.__class__.__name__.__eq__('str') — decimal.__spec__.origin is the filesystem path to decimal.py (a str). Its __class__.__name__ is 'str'. No prior decimal spec checks __spec__.origin.__class__.__name__. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') — decimal is NOT a package (it is a single-file module decimal.py). Therefore submodule_search_locations is None and its __class__.__name__ is 'NoneType'. This contrasts with pathlib and re which are packages (submodule_search_locations is a list). No prior decimal spec checks submodule_search_locations. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "decimal.__spec__.has_location — True for SourceFileLoader modules. decimal is loaded from a filesystem path (decimal.py), so has_location is True. No prior decimal spec checks __spec__.has_location. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.__loader__.__class__.__name__ equality and length
#
# decimal.py is a pure Python module loaded by SourceFileLoader (an instance).
# SourceFileLoader instances have no __name__ attribute. The class name of the
# loader is accessed via __loader__.__class__.__name__ == 'SourceFileLoader'.
#
#   decimal.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True
#   decimal.__loader__.__class__.__name__.__len__()                  == 16
#
# decimal_extra55 covers both anchors in decload55 namespace.
# This wave 226 spec re-anchors them in decspec56 namespace for cross-wave
# traceability. The underlying C extension '_decimal' uses ExtensionFileLoader,
# but 'decimal' itself is the Python wrapper with SourceFileLoader.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra56.loader_class_name:
  description: "decimal.__loader__.__class__.__name__ eq and len — decimal.py is a pure Python module (not a package) loaded by SourceFileLoader; SourceFileLoader instances have no __name__ attr; __loader__.__class__.__name__=='SourceFileLoader' (16 chars); decimal_extra55 covers both equality and length in decload55 namespace; re-anchored in decspec56 namespace for cross-wave 226 traceability; NOTE: the C extension '_decimal' uses ExtensionFileLoader but 'decimal' itself uses SourceFileLoader; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: decspec56ldr

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_eq_SourceFileLoader, __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [loader_class_name_len_16,              __loader__.__class__.__name__.__len__, [],                  16  ]

# ---------------------------------------------------------------------------
# decimal.__spec__.origin.__class__.__name__.__eq__('str')
#
# decimal.__spec__.origin is the filesystem path to decimal.py.
# As a filesystem path string, its __class__.__name__ is 'str'.
#
#   decimal.__spec__.origin.__class__.__name__.__eq__('str') == True
#
# No prior decimal spec checks __spec__.origin.__class__.__name__. Novel.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra56.spec_origin_class_name:
  description: "decimal.__spec__.origin.__class__.__name__.__eq__('str') — decimal.__spec__.origin is the filesystem path to decimal.py; it is a str; __class__.__name__=='str'; contrasts with io.__spec__.origin which is 'frozen' (str with value 'frozen'); no prior decimal spec checks __spec__.origin.__class__.__name__; novel anchor in decspec56 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: decspec56origcls

  columns: [id, function, args, expected]
  rows:
    - [spec_origin_class_name_str, __spec__.origin.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# decimal.__spec__.submodule_search_locations — None (decimal is NOT a package)
#
# decimal is NOT a package; it is a single-file module (decimal.py). Therefore
# its __spec__.submodule_search_locations is None. The class name of None is
# 'NoneType'.
#
#   decimal.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True
#
# This contrasts with pathlib and re which ARE packages and have a list here.
# No prior decimal spec checks submodule_search_locations. Novel.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra56.spec_submodule_search_locations:
  description: "decimal.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') — decimal is NOT a package (single-file decimal.py) so submodule_search_locations is None; __class__.__name__=='NoneType'; contrasts with pathlib and re which are packages (submodule_search_locations is a list); no prior decimal spec checks submodule_search_locations; novel anchor in decspec56 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: decspec56ssl

  columns: [id, function, args, expected]
  rows:
    - [ssl_class_name_NoneType, __spec__.submodule_search_locations.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# decimal.__spec__.has_location — True for SourceFileLoader modules
#
# decimal is loaded from a filesystem path by SourceFileLoader. Therefore
# has_location is True.
#
#   decimal.__spec__.has_location.__eq__(True) == True
#
# This contrasts with io where has_location is False (loaded by FrozenImporter).
# No prior decimal spec checks __spec__.has_location. Novel anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra56.spec_has_location:
  description: "decimal.__spec__.has_location is True — decimal is loaded by SourceFileLoader from a filesystem path (decimal.py); has_location==True for file-backed modules; contrasts with io (FrozenImporter, has_location==False); no prior decimal spec checks __spec__.has_location; novel anchor in decspec56 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: decspec56hasloc

  columns: [id, function, args, expected]
  rows:
    - [has_location_true, __spec__.has_location.__eq__, [true], true]

invariant decimal_extra56.loader_class_name_eq_SourceFileLoader:
  description: "decimal.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — decimal.py is a pure Python module loaded by SourceFileLoader; re-anchored in decspec56 namespace for cross-wave 226 traceability; decimal_extra55 covers this in decload55 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant decimal_extra56.loader_class_name_len_16:
  description: "decimal.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; re-anchored in decspec56 namespace for cross-wave 226 traceability; decimal_extra55 covers this in decload55 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16

invariant decimal_extra56.spec_origin_class_name_str:
  description: "decimal.__spec__.origin.__class__.__name__.__eq__('str') == True — decimal.__spec__.origin is the filesystem path to decimal.py; it is a str; no prior decimal spec checks __spec__.origin.__class__.__name__; novel anchor in decspec56 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra56.spec_ssl_none_class_name:
  description: "decimal.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — decimal is not a package (single-file decimal.py) so submodule_search_locations is None; __class__.__name__ of None is 'NoneType'; contrasts with pathlib and re (packages, submodule_search_locations is a list); no prior decimal spec checks submodule_search_locations; novel anchor in decspec56 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant decimal_extra56.spec_has_location_true:
  description: "decimal.__spec__.has_location.__eq__(True) == True — decimal is loaded by SourceFileLoader from a filesystem path; has_location is True; contrasts with io (FrozenImporter, has_location==False); no prior decimal spec checks __spec__.has_location; novel anchor in decspec56 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true
