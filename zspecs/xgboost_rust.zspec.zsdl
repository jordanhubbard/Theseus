spec: xgboost_rust
version: ">=3.9"
backend: rust_module(xgboost_rust)

docs: https://xgboost.readthedocs.io/en/stable/python/python_api.html

provenance:
  derived_from:
    - "https://xgboost.readthedocs.io/en/stable/python/python_api.html — XGBoost Python API"
  not_derived_from:
    - "xgboost source: xgboost/sklearn.py"
  notes:
    - "XGBoost is a gradient boosting library."
    - "XGBClassifier().get_params() has key 'n_estimators'."
    - "XGBClassifier(n_estimators=50).get_params()['n_estimators'] == 50."
    - "XGBClassifier().get_params()['max_depth'] == 6 — default."
    - "XGBClassifier(max_depth=3).get_params()['max_depth'] == 3."
    - "Expose xgb_n_estimators(n) -> int: XGBClassifier(n_estimators=n).get_params()['n_estimators']."
    - "Expose xgb_max_depth(d) -> int: XGBClassifier(max_depth=d).get_params()['max_depth']."
    - "Expose xgb_default_max_depth() -> int: XGBClassifier().get_params()['max_depth']."
    - "All test vectors verified against xgboost 2.1.4."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# xgb_n_estimators — n_estimators parameter roundtrip
table xgboost_rust.params.n_estimators:
  kind: python_call_eq
  category: n_estimators
  id_prefix: xgb_ne
  function: xgb_n_estimators

  columns: [id, args, expected]
  rows:
    - [fifty,     [50],  50]
    - [hundred,   [100], 100]
    - [ten,       [10],  10]

# xgb_max_depth — max_depth parameter roundtrip
table xgboost_rust.params.max_depth:
  kind: python_call_eq
  category: max_depth
  id_prefix: xgb_md
  function: xgb_max_depth

  columns: [id, args, expected]
  rows:
    - [three, [3], 3]
    - [five,  [5], 5]

# xgb_default_max_depth — default max_depth is 6
invariant xgboost_rust.params.default_max_depth:
  description: "XGBClassifier default max_depth == 6"
  category: default_params
  kind: python_call_eq
  function: xgb_default_max_depth
  args: []
  expected: 6

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:08:51Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
