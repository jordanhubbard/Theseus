spec: re_extra_rust
version: ">=3.9"
backend: rust_module(re_extra_rust)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
  notes:
    - "Clean-room Rust reimplementation of Python re module extra functions, exposed via PyO3."
    - "re.escape(s) escapes all special regex characters in s."
    - "re.escape('hello.world') == 'hello\\\\.world'."
    - "re.escape('[test]') == '\\\\[test\\\\]'."
    - "re.fullmatch(pattern, string) returns Match if whole string matches, None otherwise."
    - "re.fullmatch('\\\\d+', '123') returns a truthy Match object."
    - "re.fullmatch('\\\\d+', '12a') returns None (falsy)."
    - "re.sub(pattern, repl, string) replaces all pattern matches with repl."
    - "re.sub('\\\\d+', 'X', 'abc 123 def') == 'abc X def'."
    - "re.split(pattern, string) splits string at each pattern match."
    - "re.split(',', 'a,b,c') == ['a', 'b', 'c']."
    - "All test vectors verified against Python 3.14.3 re module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# re.escape — escape special regex characters
table re_extra_rust.escape.vectors:
  kind: python_call_eq
  category: escape
  id_prefix: re_esc
  function: escape

  columns: [id, args, expected]
  rows:
    - [dot,      ["hello.world"],  "hello\\.world"]
    - [brackets, ["[test]"],       "\\[test\\]"]
    - [parens,   ["(a+b)"],        "\\(a\\+b\\)"]
    - [plain,    ["hello"],        "hello"]

# re.fullmatch — check if whole string matches pattern (result as bool)
table re_extra_rust.fullmatch.vectors:
  kind: python_call_eq
  category: fullmatch
  id_prefix: re_fm
  function: fullmatch
  method: __bool__

  columns: [id, args, expected]
  rows:
    - [digits_ok,   ["\\d+", "123"],         true]
    - [digits_fail, ["\\d+", "12a"],         false]
    - [exact_ok,    ["hello", "hello"],      true]
    - [exact_fail,  ["hello", "hello world"],false]
    - [alpha_ok,    ["[a-z]+", "abc"],       true]

# re.sub — substitute matches with replacement string
table re_extra_rust.sub.vectors:
  kind: python_call_eq
  category: sub
  id_prefix: re_sub
  function: sub

  columns: [id, args, expected]
  rows:
    - [digit_x,   ["\\d+", "X", "abc 123 def"],   "abc X def"]
    - [spaces,    ["\\s+", " ", "a   b   c"],       "a b c"]
    - [vowels,    ["[aeiou]", "*", "hello"],        "h*ll*"]
    - [no_match,  ["\\d+", "X", "no digits"],      "no digits"]

# re.split — split string on pattern matches
table re_extra_rust.split.vectors:
  kind: python_call_eq
  category: split
  id_prefix: re_sp
  function: split

  columns: [id, args, expected]
  rows:
    - [comma,  [",", "a,b,c"],           ["a", "b", "c"]]
    - [spaces, ["\\s+", "hello world"],  ["hello", "world"]]
    - [pipe,   ["\\|", "x|y|z"],         ["x", "y", "z"]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T21:49:59Z
  iterations: 1
  pass_count: 16
  fail_count: 0
  total_invariants: 16
  notes: Synthesis succeeded in 1 iteration(s). 16 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
