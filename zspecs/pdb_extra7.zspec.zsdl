spec: pdb_extra7
version: ">=3.9"
backend: python_module(pdb)

docs: https://docs.python.org/3/library/pdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pdb.html — Python pdb documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pdb.py"
  notes:
    - "This spec extends pdb.zspec.zsdl through pdb_extra6.zspec.zsdl."
    - "pdb covers: Pdb/__name__/__module__, Restart/__name__, run/runeval/runcall/set_trace/post_mortem/pm __name__ table, Pdb().prompt, Pdb().use_rawinput."
    - "pdb_extra covers: Pdb/__name__/__module__/__bases__[0].__name__, public function __name__ + help.__name__."
    - "pdb_extra2 covers: Pdb/__name__/__module__/__qualname__, run/runcall/post_mortem/set_trace/pm __name__ and __module__."
    - "pdb_extra3 covers: runeval/__module__, help/__module__, Restart/__module__, Restart.__bases__[0]/__name__, Pdb.__bases__.__len__==2, Pdb.__bases__[0]/__module__=='bdb', Pdb.__bases__[1]/__name__=='Cmd', Pdb.__bases__[1]/__module__=='cmd', function __qualname__ table."
    - "pdb_extra4 covers: Restart/__qualname__, Restart.__bases__.__len__==1, Pdb.__bases__[0]/__qualname__=='Bdb', Pdb.__bases__[1]/__qualname__=='Cmd', Pdb.__bases__.__class__.__name__=='tuple', Pdb/__name__/__class__.__name__=='str', Restart/__name__/__class__.__name__=='str'."
    - "pdb_extra5 covers: do_break/do_continue/do_step/do_next/do_quit/do_list __name__ table, do_break.__module__, Pdb().__class__.__name__, Pdb().skip/nosigint defaults, run.__class__.__name__, Pdb.MAX_CHAINED_EXCEPTION_DEPTH."
    - "pdb_extra6 covers: Pdb/__name__/__module__ via __eq__, Pdb.__bases__[0]/__name__=='Bdb' via __eq__, run/pm/runcall/runeval/set_trace/post_mortem __name__ via __eq__, Restart/__name__/__bases__[0]/__name__ via __eq__, line_prefix.__class__.__name__=='str'."
    - "NEW in this spec: Pdb.__mro__ (length 4, entries at indices 0..3), more do_* command method __qualname__ checks not covered by pdb_extra5 (do_where, do_up, do_down, do_args, do_return, do_jump), and pdb.line_prefix exact value."
    - "pdb.Pdb.__mro__ has length 4: [Pdb, Bdb, Cmd, object] — reflects the full multiple-inheritance chain."
    - "pdb.Pdb.__mro__[1].__name__ == 'Bdb' and .__module__ == 'bdb'."
    - "pdb.Pdb.__mro__[2].__name__ == 'Cmd' and .__module__ == 'cmd'."
    - "pdb.Pdb.__mro__[3].__name__ == 'object' and .__module__ == 'builtins'."
    - "pdb.Pdb.do_where.__qualname__ == 'Pdb.do_where' — not covered in pdb_extra5 (which covers do_break/do_continue/do_step/do_next/do_quit/do_list)."
    - "pdb.line_prefix == '\\n-> ' — the newline+arrow prefix used by pdb output lines."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pdb.__mro__ — full MRO length and entry names
# pdb_extra3 covers __bases__.__len__()==2 and specific base names.
# The MRO includes Bdb and Cmd plus object (4 entries total).
# Not covered in any prior pdb spec.
# ---------------------------------------------------------------------------

invariant pdb_extra7.Pdb.mro_len:
  description: "len(pdb.Pdb.__mro__) == 4 — MRO is [Pdb, Bdb, Cmd, object]"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__mro__.__len__
  args: []
  expected: 4

invariant pdb_extra7.Pdb.mro0_name:
  description: "pdb.Pdb.__mro__[0].__name__ == 'Pdb' — first MRO entry is Pdb itself"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__mro__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Pdb"]
  expected: true

invariant pdb_extra7.Pdb.mro1_name:
  description: "pdb.Pdb.__mro__[1].__name__ == 'Bdb' — second MRO entry is bdb.Bdb"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__mro__.__getitem__
  args: [1]
  method: __name__.__eq__
  method_args: ["Bdb"]
  expected: true

invariant pdb_extra7.Pdb.mro1_module:
  description: "pdb.Pdb.__mro__[1].__module__ == 'bdb' — Bdb is from the bdb module"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__mro__.__getitem__
  args: [1]
  method: __module__.__eq__
  method_args: ["bdb"]
  expected: true

invariant pdb_extra7.Pdb.mro2_name:
  description: "pdb.Pdb.__mro__[2].__name__ == 'Cmd' — third MRO entry is cmd.Cmd"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__mro__.__getitem__
  args: [2]
  method: __name__.__eq__
  method_args: ["Cmd"]
  expected: true

invariant pdb_extra7.Pdb.mro2_module:
  description: "pdb.Pdb.__mro__[2].__module__ == 'cmd' — Cmd is from the cmd module"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__mro__.__getitem__
  args: [2]
  method: __module__.__eq__
  method_args: ["cmd"]
  expected: true

invariant pdb_extra7.Pdb.mro3_name:
  description: "pdb.Pdb.__mro__[3].__name__ == 'object' — last MRO entry is object"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__mro__.__getitem__
  args: [3]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Pdb command-method __qualname__ — do_where, do_up, do_down, do_args,
# do_return, do_jump.
# pdb_extra5 covers do_break/do_continue/do_step/do_next/do_quit/do_list __name__.
# __qualname__ for all six, and __name__/__qualname__ for this new set, are new.
# ---------------------------------------------------------------------------

table pdb_extra7.command_method_qualnames:
  kind: python_call_eq
  category: command_methods
  id_prefix: cmdqn

  columns: [id, function, args, expected]
  rows:
    - [do_where,  Pdb.do_where.__qualname__.__eq__,  ["Pdb.do_where"],  true]
    - [do_up,     Pdb.do_up.__qualname__.__eq__,     ["Pdb.do_up"],     true]
    - [do_down,   Pdb.do_down.__qualname__.__eq__,   ["Pdb.do_down"],   true]
    - [do_args,   Pdb.do_args.__qualname__.__eq__,   ["Pdb.do_args"],   true]
    - [do_return, Pdb.do_return.__qualname__.__eq__, ["Pdb.do_return"], true]
    - [do_jump,   Pdb.do_jump.__qualname__.__eq__,   ["Pdb.do_jump"],   true]

# ---------------------------------------------------------------------------
# line_prefix exact value — '\n-> '
# pdb_extra6 confirms line_prefix.__class__.__name__ == 'str'.
# The exact value is new here.
# ---------------------------------------------------------------------------

invariant pdb_extra7.line_prefix.value:
  description: "pdb.line_prefix == '\\n-> ' — the newline-arrow prefix used in pdb output"
  category: module_constants
  kind: python_call_eq
  function: line_prefix.__eq__
  args: ["\n-> "]
  expected: true
