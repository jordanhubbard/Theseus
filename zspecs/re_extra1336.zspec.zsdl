spec: re_extra1336
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module Pattern, Match, and error documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 536 theme: __hash__ and __eq__ method descriptor checks for re module classes."
    - "re.Pattern defines custom __hash__ and __eq__ as C-level wrapper_descriptors; __hash__.__qualname__=='Pattern.__hash__' and __eq__.__qualname__=='Pattern.__eq__' — pattern equality is by value (flags + pattern string)."
    - "re.Match inherits __hash__ and __eq__ from object; neither is overridden — Match instances are hashable and comparable by identity only."
    - "re.error inherits __hash__ and __eq__ from object (exception classes do not override these); __hash__.__qualname__=='object.__hash__' and __eq__.__qualname__=='object.__eq__'."
    - "re.Pattern.__hash__.__class__.__name__ == 'wrapper_descriptor' (C extension method, not a Python function); verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "re.Match.__hash__.__qualname__ == 'object.__hash__' (not overridden — identity hash); verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern __hash__ and __eq__ descriptor checks
#
# re.Pattern.__hash__.__class__.__name__  == 'wrapper_descriptor'
# re.Pattern.__hash__.__qualname__        == 'Pattern.__hash__'
# re.Pattern.__eq__.__class__.__name__    == 'wrapper_descriptor'
# re.Pattern.__eq__.__qualname__          == 'Pattern.__eq__'
# ---------------------------------------------------------------------------

table re_extra1336.pattern_hash_eq:
  description: "re.Pattern __hash__ and __eq__ descriptor checks — wave 536 theme: Pattern defines custom __hash__ and __eq__ as C-extension wrapper_descriptors; __hash__.__qualname__=='Pattern.__hash__'; __eq__.__qualname__=='Pattern.__eq__'; Pattern equality is value-based (pattern string + flags), making compiled patterns hashable and comparable by content; verified with Python 3.12"
  kind: python_call_eq
  category: hash_eq_descriptors
  id_prefix: re1336pa

  columns: [id, function, args, expected, description]
  rows:
    - [re1336pa001, re.Pattern.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "re.Pattern.__hash__.__class__.__name__ == 'wrapper_descriptor' (C-extension method defining custom hash); verified with Python 3.12"]
    - [re1336pa002, re.Pattern.__hash__.__qualname__.__eq__,         ["Pattern.__hash__"],   true, "re.Pattern.__hash__.__qualname__ == 'Pattern.__hash__' (custom hash defined on Pattern itself); verified with Python 3.12"]
    - [re1336pa003, re.Pattern.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "re.Pattern.__eq__.__class__.__name__ == 'wrapper_descriptor' (C-extension method defining value equality); verified with Python 3.12"]
    - [re1336pa004, re.Pattern.__eq__.__qualname__.__eq__,           ["Pattern.__eq__"],     true, "re.Pattern.__eq__.__qualname__ == 'Pattern.__eq__' (custom eq defined on Pattern itself); verified with Python 3.12"]
    - [re1336pa005, re.Pattern.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "re.Pattern.__hash__ is a wrapper_descriptor (C-level), not 'function' (Python-level) nor 'NoneType' (unhashable); verified with Python 3.12"]
    - [re1336pa006, re.Pattern.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "re.Pattern.__eq__ is a wrapper_descriptor; Pattern defines both __hash__ and __eq__ so hash/eq are consistent; verified with Python 3.12"]
    - [re1336pa007, re.Pattern.__hash__.__qualname__.__eq__,         ["Pattern.__hash__"],   true, "Pattern.__hash__.__qualname__ starts with 'Pattern.' confirming it is defined on Pattern, not inherited from object; verified with Python 3.12"]
    - [re1336pa008, re.Pattern.__eq__.__qualname__.__eq__,           ["Pattern.__eq__"],     true, "Pattern.__eq__.__qualname__ starts with 'Pattern.' confirming it is defined on Pattern, not inherited from object; verified with Python 3.12"]

# ---------------------------------------------------------------------------
# re.Match __hash__ and __eq__ descriptor checks
#
# re.Match.__hash__.__class__.__name__  == 'wrapper_descriptor'
# re.Match.__hash__.__qualname__        == 'object.__hash__'
# re.Match.__eq__.__class__.__name__    == 'wrapper_descriptor'
# re.Match.__eq__.__qualname__          == 'object.__eq__'
# ---------------------------------------------------------------------------

table re_extra1336.match_hash_eq:
  description: "re.Match __hash__ and __eq__ descriptor checks — wave 536 theme: Match does NOT define custom __hash__ or __eq__; both are inherited from object; __hash__.__qualname__=='object.__hash__' (identity-based hash); __eq__.__qualname__=='object.__eq__' (identity-based equality); Match objects are hashable by identity only; verified with Python 3.12"
  kind: python_call_eq
  category: hash_eq_descriptors
  id_prefix: re1336ma

  columns: [id, function, args, expected, description]
  rows:
    - [re1336ma001, re.Match.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "re.Match.__hash__.__class__.__name__ == 'wrapper_descriptor' (inherits object.__hash__); verified with Python 3.12"]
    - [re1336ma002, re.Match.__hash__.__qualname__.__eq__,         ["object.__hash__"],    true, "re.Match.__hash__.__qualname__ == 'object.__hash__' (not overridden — identity hash); verified with Python 3.12"]
    - [re1336ma003, re.Match.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "re.Match.__eq__.__class__.__name__ == 'wrapper_descriptor' (inherits object.__eq__); verified with Python 3.12"]
    - [re1336ma004, re.Match.__eq__.__qualname__.__eq__,           ["object.__eq__"],      true, "re.Match.__eq__.__qualname__ == 'object.__eq__' (no custom __eq__ — identity equality); verified with Python 3.12"]
    - [re1336ma005, re.Match.__hash__.__qualname__.__eq__,         ["object.__hash__"],    true, "Match.__hash__.__qualname__=='object.__hash__' contrasts with Pattern.__hash__.__qualname__=='Pattern.__hash__'; verified with Python 3.12"]
    - [re1336ma006, re.Match.__eq__.__qualname__.__eq__,           ["object.__eq__"],      true, "Match.__eq__.__qualname__=='object.__eq__' contrasts with Pattern.__eq__.__qualname__=='Pattern.__eq__'; verified with Python 3.12"]
    - [re1336ma007, re.Match.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "re.Match.__hash__ is a wrapper_descriptor (C-level inherited from object); Match is hashable (not NoneType); verified with Python 3.12"]
    - [re1336ma008, re.Match.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "re.Match.__eq__ is a wrapper_descriptor; like __hash__, it comes from object, not from a Match-specific definition; verified with Python 3.12"]

# ---------------------------------------------------------------------------
# re.error __hash__ and __eq__ descriptor checks
#
# re.error.__hash__.__class__.__name__  == 'wrapper_descriptor'
# re.error.__hash__.__qualname__        == 'object.__hash__'
# re.error.__eq__.__class__.__name__    == 'wrapper_descriptor'
# re.error.__eq__.__qualname__          == 'object.__eq__'
# ---------------------------------------------------------------------------

table re_extra1336.error_hash_eq:
  description: "re.error __hash__ and __eq__ descriptor checks — wave 536 theme: re.error is an exception class (subclass of Exception); it inherits __hash__ and __eq__ from object; __hash__.__qualname__=='object.__hash__'; __eq__.__qualname__=='object.__eq__'; exception classes typically do not override equality or hashing; verified with Python 3.12"
  kind: python_call_eq
  category: hash_eq_descriptors
  id_prefix: re1336er

  columns: [id, function, args, expected, description]
  rows:
    - [re1336er001, re.error.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "re.error.__hash__.__class__.__name__ == 'wrapper_descriptor' (exception class, inherits object.__hash__); verified with Python 3.12"]
    - [re1336er002, re.error.__hash__.__qualname__.__eq__,         ["object.__hash__"],    true, "re.error.__hash__.__qualname__ == 'object.__hash__' (not overridden); verified with Python 3.12"]
    - [re1336er003, re.error.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "re.error.__eq__.__class__.__name__ == 'wrapper_descriptor' (exception class, inherits object.__eq__); verified with Python 3.12"]
    - [re1336er004, re.error.__eq__.__qualname__.__eq__,           ["object.__eq__"],      true, "re.error.__eq__.__qualname__ == 'object.__eq__' (no custom __eq__ on re.error); verified with Python 3.12"]
    - [re1336er005, re.error.__hash__.__qualname__.__eq__,         ["object.__hash__"],    true, "re.error.__hash__.__qualname__=='object.__hash__' — consistent with Match; both lack custom hash unlike Pattern; verified with Python 3.12"]
    - [re1336er006, re.error.__eq__.__qualname__.__eq__,           ["object.__eq__"],      true, "re.error.__eq__.__qualname__=='object.__eq__' — consistent with Match; both lack custom eq unlike Pattern; verified with Python 3.12"]
    - [re1336er007, re.error.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true, "re.error.__hash__ class is wrapper_descriptor (not NoneType), so re.error instances are hashable; verified with Python 3.12"]
    - [re1336er008, re.error.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true, "re.error.__eq__ class is wrapper_descriptor; re.error equality is by identity (standard for exceptions); verified with Python 3.12"]
