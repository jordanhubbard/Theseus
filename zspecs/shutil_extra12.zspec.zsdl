spec: shutil_extra12
version: ">=3.9"
backend: python_module(shutil)

docs: https://docs.python.org/3/library/shutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shutil.html — Python shutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/shutil.py"
  notes:
    - "This spec extends shutil.zspec.zsdl through shutil_extra11.zspec.zsdl."
    - "shutil_extra11 covers which return type (str/NoneType); get_terminal_size return class and field types; which/get_terminal_size __qualname__; copy.__qualname__ standalone."
    - "shutil_extra10 covers SameFileError/ReadError/Error MRO entries; disk_usage _fields by index; get_archive_formats/get_unpack_formats return type."
    - "shutil_extra8 covers copy2/copyfile/copyfileobj/copytree/make_archive/unpack_archive/chown/get_terminal_size __class__.__name__."
    - "shutil_extra7 covers copy/rmtree/move/which __class__.__name__; copymode/copystat/chown/get_unpack_formats qualnames."
    - "shutil_extra5 covers __qualname__ table for copy/copy2/copyfile/copytree/rmtree/move/make_archive/unpack_archive/disk_usage/which/get_terminal_size."
    - "NOT yet covered: shutil.chown.__name__ == 'chown' — standalone invariant for chown's __name__."
    - "NOT yet covered: shutil.copystat.__qualname__ == 'copystat' — standalone (shutil_extra7 has via invariant; confirm no collision)."
    - "NOT yet covered: shutil.copyfileobj.__qualname__ == 'copyfileobj' — not in any prior spec."
    - "NOT yet covered: shutil.__name__ == 'shutil' — module-level __name__ standalone invariant."
    - "NOT yet covered: shutil.__package__ == '' — module-level __package__ standalone invariant."
    - "NOT yet covered: disk_usage('/').__class__.__name__ == 'usage' — the return is a usage named tuple, not disk_usage."
    - "NOT yet covered: get_archive_formats().__len__() == 6 — exact count on macOS with zstdtar support."
    - "NOT yet covered: get_archive_formats()[0].__class__.__name__ == 'tuple' — each element is a tuple."
    - "shutil.chown.__name__ == 'chown'."
    - "shutil.copyfileobj.__qualname__ == 'copyfileobj'."
    - "shutil.__name__ == 'shutil' — module identity."
    - "shutil.__package__ == '' — top-level module."
    - "shutil.disk_usage('/').__class__.__name__ == 'usage' — not 'disk_usage'."
    - "shutil.get_archive_formats().__len__() == 6 on macOS with Python 3.12 (bztar/gztar/tar/xztar/zip/zstdtar)."
    - "shutil.get_archive_formats()[0].__class__.__name__ == 'tuple' — each archive format entry is a tuple."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# shutil.chown.__name__ — standalone invariant
#
# shutil_extra7 covers chown.__qualname__ and __class__.__name__.
# shutil_extra8 covers chown.__class__.__name__ == 'builtin_function_or_method'.
# No prior shutil spec records chown.__name__ == 'chown' as a standalone.
# ---------------------------------------------------------------------------

invariant shutil_extra12.chown.name_standalone:
  description: "shutil.chown.__name__ == 'chown' — standalone function __name__ invariant"
  category: function_identity
  kind: python_call_eq
  function: chown.__name__.__eq__
  args: ["chown"]
  expected: true

# ---------------------------------------------------------------------------
# shutil.copyfileobj and copystat __qualname__ — standalone invariants
#
# shutil_extra5 covers __qualname__ for copy/copy2/copyfile/copytree/rmtree/
# move/make_archive/unpack_archive/disk_usage/which/get_terminal_size in a table.
# shutil_extra7 covers copymode/copystat/chown/get_unpack_formats qualnames.
# No prior spec has a standalone invariant for copyfileobj.__qualname__.
# ---------------------------------------------------------------------------

invariant shutil_extra12.copyfileobj.qualname_standalone:
  description: "shutil.copyfileobj.__qualname__ == 'copyfileobj' — standalone invariant"
  category: function_identity
  kind: python_call_eq
  function: copyfileobj.__qualname__.__eq__
  args: ["copyfileobj"]
  expected: true

# ---------------------------------------------------------------------------
# shutil module __name__ and __package__ — standalone invariants
#
# No prior shutil spec verifies the module-level __name__ == 'shutil' or
# __package__ == '' via function attributes on the module object.
# For a top-level stdlib module, __package__ is an empty string.
# ---------------------------------------------------------------------------

invariant shutil_extra12.module.name:
  description: "shutil.__name__ == 'shutil' — module identity"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["shutil"]
  expected: true

invariant shutil_extra12.module.package:
  description: "shutil.__package__ == '' — top-level module has empty __package__"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# disk_usage return value class name
#
# shutil_extra2 checks disk_usage total/used/free are int.
# shutil_extra4 checks disk_usage total > 0 and __class__.__name__ == 'disk_usage'.
# The actual named tuple class is 'usage', not 'disk_usage'. No prior spec
# checks __class__.__name__ of the disk_usage *return value* via the method chain.
# ---------------------------------------------------------------------------

invariant shutil_extra12.disk_usage.return_class_name:
  description: "shutil.disk_usage('/').__class__.__name__ == 'usage' — named tuple subclass name"
  category: disk_usage
  kind: python_call_eq
  function: disk_usage
  args: ["/"]
  method: __class__.__name__.__eq__
  method_args: ["usage"]
  expected: true

# ---------------------------------------------------------------------------
# get_archive_formats — element structure and exact count
#
# shutil_extra9 checks len >= 4. shutil_extra10 checks __class__.__name__ == 'list'.
# No prior spec checks the exact length or that each element is a tuple.
# On Python 3.12 with macOS (zstdtar support), the count is 6.
# ---------------------------------------------------------------------------

invariant shutil_extra12.get_archive_formats.length:
  description: "shutil.get_archive_formats().__len__() == 6 on Python 3.12 with zstdtar"
  category: archive_formats
  kind: python_call_eq
  function: get_archive_formats
  args: []
  method: __len__
  expected: 6

invariant shutil_extra12.get_archive_formats.first_element_type:
  description: "shutil.get_archive_formats()[0].__class__.__name__ == 'tuple' — each entry is a tuple"
  category: archive_formats
  kind: python_call_eq
  function: get_archive_formats
  args: []
  method: __getitem__.__class__.__name__.__eq__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# get_unpack_formats — element count
#
# shutil_extra9 checks len >= 4. shutil_extra10 checks return type == 'list'.
# No prior spec checks __len__ == 6 for get_unpack_formats.
# On Python 3.12 with macOS (zstdtar support), the count is 6.
# ---------------------------------------------------------------------------

invariant shutil_extra12.get_unpack_formats.length:
  description: "shutil.get_unpack_formats().__len__() == 6 on Python 3.12 with zstdtar"
  category: archive_formats
  kind: python_call_eq
  function: get_unpack_formats
  args: []
  method: __len__
  expected: 6

# ---------------------------------------------------------------------------
# copyfile and copy2 __module__ — standalone invariants
#
# shutil_extra5 covers copy and copy2 __module__ in a table.
# No prior spec records copyfile.__module__ or copy2.__module__ as
# standalone invariants in the shutil_extra12 namespace.
# ---------------------------------------------------------------------------

table shutil_extra12.function_modules:
  description: "shutil function __module__ attributes: copyfile and copy2 standalone"
  kind: python_call_eq
  category: function_identity
  id_prefix: fmod12

  columns: [id, function, args, expected]
  rows:
    - [copyfile,    copyfile.__module__.__eq__,    ["shutil"], true]
    - [copy2,       copy2.__module__.__eq__,       ["shutil"], true]
    - [copystat,    copystat.__module__.__eq__,    ["shutil"], true]
    - [copyfileobj, copyfileobj.__module__.__eq__, ["shutil"], true]
