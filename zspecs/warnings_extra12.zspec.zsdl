spec: warnings_extra12
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Modules/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl through warnings_extra11.zspec.zsdl."
    - "Prior specs cover: __name__/__qualname__/__module__ for warn/warn_explicit/filterwarnings/simplefilter/resetwarnings/showwarning/formatwarning/catch_warnings/WarningMessage; warning category __class__.__name__; DeprecationWarning/__name__/__module__/__bases__/__mro__; FutureWarning/RuntimeWarning/SyntaxWarning/PendingDeprecationWarning/__bases__/__mro__; UserWarning/__module__/__bases__; filters/defaultaction/onceregistry attributes."
    - "This spec covers: warnings.deprecated class — __name__, __qualname__, __module__, __class__.__name__, __bases__[0].__name__, MRO length; WarningMessage.__class__.__name__; catch_warnings.__class__.__name__."
    - "warnings.deprecated is a new decorator class added in Python 3.13 (PEP 702). On earlier Pythons it raises AttributeError. However, identity metadata tests are forward-compatible and document the expected shape."
    - "warnings.deprecated.__module__ == '_py_warnings' because the class is defined in the C/Cython extension that backs the warnings module on CPython."
    - "warnings.deprecated.__bases__[0].__name__ == 'object' — deprecated inherits directly from object."
    - "warnings.WarningMessage.__class__.__name__ == 'type' — it is a plain class, not a metaclass instance."
    - "warnings.catch_warnings.__class__.__name__ == 'type' — plain class defined in warnings.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warnings.deprecated — identity attributes
#
# warnings.deprecated was added in Python 3.13 (PEP 702). No prior warnings
# spec records any attribute of this class. The tests below cover __name__,
# __qualname__, __module__, __class__.__name__, and the base class name.
# ---------------------------------------------------------------------------

invariant warnings_extra12.deprecated.name:
  description: "warnings.deprecated.__name__ == 'deprecated'"
  category: class_identity
  kind: python_call_eq
  function: deprecated.__name__.__eq__
  args: ["deprecated"]
  expected: true

invariant warnings_extra12.deprecated.qualname:
  description: "warnings.deprecated.__qualname__ == 'deprecated'"
  category: class_identity
  kind: python_call_eq
  function: deprecated.__qualname__.__eq__
  args: ["deprecated"]
  expected: true

invariant warnings_extra12.deprecated.module:
  description: "warnings.deprecated.__module__ == '_py_warnings'"
  category: class_identity
  kind: python_call_eq
  function: deprecated.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

invariant warnings_extra12.deprecated.class_name:
  description: "warnings.deprecated.__class__.__name__ == 'type'"
  category: class_identity
  kind: python_call_eq
  function: deprecated.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant warnings_extra12.deprecated.base0_name:
  description: "warnings.deprecated.__bases__[0].__name__ == 'object'"
  category: base_classes
  kind: python_call_eq
  function: deprecated.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant warnings_extra12.deprecated.mro_len:
  description: "len(warnings.deprecated.__mro__) == 2 — [deprecated, object]"
  category: class_identity
  kind: python_call_eq
  function: deprecated.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# WarningMessage and catch_warnings — __class__.__name__
#
# Both warnings.WarningMessage and warnings.catch_warnings are plain Python
# classes (metaclass == type). No prior warnings spec records
# __class__.__name__ for either of these as standalone invariants.
# ---------------------------------------------------------------------------

invariant warnings_extra12.WarningMessage.class_name:
  description: "warnings.WarningMessage.__class__.__name__ == 'type'"
  category: class_identity
  kind: python_call_eq
  function: WarningMessage.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant warnings_extra12.catch_warnings.class_name:
  description: "warnings.catch_warnings.__class__.__name__ == 'type'"
  category: class_identity
  kind: python_call_eq
  function: catch_warnings.__class__.__name__.__eq__
  args: ["type"]
  expected: true
