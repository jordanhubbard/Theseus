spec: itertools_extra871
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "itertools standard library module"
    - "CPython runtime C-extension type inspection"
  not_derived_from:
    - "more-itertools or any third-party itertools packages"
    - "toolz or cytoolz"
  notes:
    - "Covers remaining C-type class name checks and module-level attributes"
    - "tee is a Python-level function unlike most itertools which are C types"
    - "chain.from_iterable classmethod qualname and __self__ checks verify descriptor binding"
  created_at: "2026-04-12"

table itertools_extra871.ctype_and_module_attrs:
  description: "itertools remaining C-type class name checks and module-level attributes"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: it871xx
  columns: [id, function, args, expected]
  rows:
    - [it871xx001, itertools.product.__class__.__name__.__eq__, ["type"], true]
    - [it871xx002, itertools.permutations.__class__.__name__.__eq__, ["type"], true]
    - [it871xx003, itertools.combinations.__class__.__name__.__eq__, ["type"], true]
    - [it871xx004, itertools.combinations_with_replacement.__class__.__name__.__eq__, ["type"], true]
    - [it871xx005, itertools.takewhile.__class__.__name__.__eq__, ["type"], true]
    - [it871xx006, itertools.tee.__class__.__name__.__eq__, ["function"], true]
    - [it871xx007, itertools.__name__.__eq__, ["itertools"], true]
    - [it871xx008, itertools.__package__.__eq__, ["itertools"], true]
    - [it871xx009, itertools.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]
    - [it871xx010, itertools.tee.__code__.__class__.__name__.__eq__, ["code"], true]
    - [it871xx011, itertools.chain.from_iterable.__qualname__.__eq__, ["chain.from_iterable"], true]
    - [it871xx012, itertools.chain.from_iterable.__self__.__qualname__.__eq__, ["chain"], true]
