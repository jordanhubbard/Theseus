table multiprocessing_extra195.mp_sync_Semaphore_identity:
  description: "multiprocessing.synchronize.Semaphore class identity checks in mpsynclocks195 namespace — Semaphore.__name__=='Semaphore' (len=9: S(1)e(2)m(3)a(4)p(5)h(6)o(7)r(8)e(9); the process-safe counting semaphore; allows a fixed number of concurrent access grants); Semaphore.__module__=='multiprocessing.synchronize' (len=27; same module as Lock and RLock); Semaphore.__bases__[0].__name__=='SemLock' (len=7; Semaphore also inherits from SemLock, reflecting that all three primitives are implemented via the same POSIX semaphore mechanism); Semaphore.__name__ (9) > RLock.__name__ (5) > Lock.__name__ (4) — name length ordering; all three modules are the same (27); verified with Python 3.14.3"
  kind: python_call_eq
  category: Semaphore
  id_prefix: mpsynclocks195

  columns: [id, function, args, expected, description]
  rows:
    - [sem_name_eq,    multiprocessing.synchronize.Semaphore.__name__.__eq__,                ["Semaphore"],                     true, "multiprocessing.synchronize.Semaphore.__name__ == 'Semaphore' (len=9; process-safe counting semaphore); verified Python 3.14.3"]
    - [sem_name_len,   multiprocessing.synchronize.Semaphore.__name__.__len__,               [],                                9,    "multiprocessing.synchronize.Semaphore.__name__.__len__() == 9 ('Semaphore'=9: S(1)e(2)m(3)a(4)p(5)h(6)o(7)r(8)e(9)); verified Python 3.14.3"]
    - [sem_module_eq,  multiprocessing.synchronize.Semaphore.__module__.__eq__,              ["multiprocessing.synchronize"],   true, "multiprocessing.synchronize.Semaphore.__module__ == 'multiprocessing.synchronize' (len=27; same module as Lock and RLock); verified Python 3.14.3"]
    - [sem_module_len, multiprocessing.synchronize.Semaphore.__module__.__len__,             [],                                27,   "multiprocessing.synchronize.Semaphore.__module__.__len__() == 27 ('multiprocessing.synchronize'=27); verified Python 3.14.3"]
    - ["sem_base_eq",  "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__", ["SemLock"],                       true, "multiprocessing.synchronize.Semaphore.__bases__[0].__name__ == 'SemLock' (len=7; same base as Lock and RLock); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra195
# ---------------------------------------------------------------------------

invariant multiprocessing_extra195.mp_sync_Lock_name_eq:
  description: "multiprocessing.synchronize.Lock.__name__.__eq__('Lock') returns True — Lock.__name__=='Lock' (len=4: L(1)o(2)c(3)k(4)); multiprocessing.synchronize.Lock is the process-safe mutual exclusion lock that allows only one process at a time to acquire it; it is backed by a POSIX semaphore via the SemLock C extension class; Lock.__name__ (4) < RLock.__name__ (5) by 1; Lock.__name__ (4) < SemLock base name (7) by 3; Lock.__name__ (4) < Semaphore.__name__ (9) by 5; NEW in mpsynclocks195: first standalone Lock.__name__ invariant for multiprocessing.synchronize; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Lock
  kind: python_call_eq
  function: multiprocessing.synchronize.Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant multiprocessing_extra195.mp_sync_Lock_module_eq:
  description: "multiprocessing.synchronize.Lock.__module__.__eq__('multiprocessing.synchronize') returns True — Lock.__module__=='multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.'=1+'synchronize'=11=27); Lock, RLock, Semaphore, BoundedSemaphore, Event, and Condition are all defined in Lib/multiprocessing/synchronize.py; Lock.__module__ (27) == RLock.__module__ (27) == Semaphore.__module__ (27) — all three share the same implementation module; Lock.__module__ (27) > Lock.__name__ (4) by 23; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Lock
  kind: python_call_eq
  function: multiprocessing.synchronize.Lock.__module__.__eq__
  args: ["multiprocessing.synchronize"]
  expected: true

invariant multiprocessing_extra195.mp_sync_Lock_base_eq:
  description: "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__('SemLock') returns True — Lock.__bases__[0].__name__=='SemLock' (len=7: S(1)e(2)m(3)L(4)o(5)c(6)k(7)); SemLock is the private C-extension class in _multiprocessing that wraps a POSIX semaphore (sem_t); all three lock classes (Lock, RLock, Semaphore) inherit from SemLock; SemLock provides the low-level acquire(), release(), and _semlock attribute; Lock.__bases__[0].__name__ (7: 'SemLock') == RLock.__bases__[0].__name__ (7: 'SemLock') == Semaphore.__bases__[0].__name__ (7: 'SemLock'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Lock
  kind: python_call_eq
  function: "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__"
  args: ["SemLock"]
  expected: true

invariant multiprocessing_extra195.mp_sync_RLock_name_eq:
  description: "multiprocessing.synchronize.RLock.__name__.__eq__('RLock') returns True — RLock.__name__=='RLock' (len=5: R(1)L(2)o(3)c(4)k(5)); RLock is the process-safe reentrant lock; the owning process can acquire it multiple times without blocking, and must release it the same number of times; RLock.__name__ (5) > Lock.__name__ (4) by 1 — the 'R' prefix adds one character; RLock.__name__ (5) < Semaphore.__name__ (9) by 4; RLock.__name__ (5) < SemLock base name (7) by 2; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: RLock
  kind: python_call_eq
  function: multiprocessing.synchronize.RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant multiprocessing_extra195.mp_sync_RLock_base_eq:
  description: "multiprocessing.synchronize.RLock.__bases__[0].__name__.__eq__('SemLock') returns True — RLock.__bases__[0].__name__=='SemLock' (len=7); RLock inherits from the same SemLock C-extension class as Lock; the reentrant behavior is implemented in the pure-Python RLock class on top of the SemLock primitive; RLock.__bases__[0].__name__ (7) == Lock.__bases__[0].__name__ (7) == Semaphore.__bases__[0].__name__ (7) — all three share SemLock as their base; SemLock.__name__ (7) > Lock.__name__ (4) by 3; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: RLock
  kind: python_call_eq
  function: "multiprocessing.synchronize.RLock.__bases__[0].__name__.__eq__"
  args: ["SemLock"]
  expected: true

invariant multiprocessing_extra195.mp_sync_Semaphore_name_eq:
  description: "multiprocessing.synchronize.Semaphore.__name__.__eq__('Semaphore') returns True — Semaphore.__name__=='Semaphore' (len=9: S(1)e(2)m(3)a(4)p(5)h(6)o(7)r(8)e(9)); multiprocessing.synchronize.Semaphore is the process-safe counting semaphore; it maintains an internal counter and allows acquire() to succeed while the counter is positive; Semaphore.__name__ (9) is the longest class name in this spec; Semaphore.__name__ (9) > RLock.__name__ (5) by 4; Semaphore.__name__ (9) > Lock.__name__ (4) by 5; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Semaphore
  kind: python_call_eq
  function: multiprocessing.synchronize.Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant multiprocessing_extra195.mp_sync_Semaphore_module_eq:
  description: "multiprocessing.synchronize.Semaphore.__module__.__eq__('multiprocessing.synchronize') returns True — Semaphore.__module__=='multiprocessing.synchronize' (len=27); Semaphore is defined in Lib/multiprocessing/synchronize.py alongside Lock and RLock; Semaphore.__module__ (27) == Lock.__module__ (27) == RLock.__module__ (27) — all three synchronization primitives share the same implementation module; Semaphore.__module__ (27) > Semaphore.__name__ (9) by 18; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Semaphore
  kind: python_call_eq
  function: multiprocessing.synchronize.Semaphore.__module__.__eq__
  args: ["multiprocessing.synchronize"]
  expected: true

invariant multiprocessing_extra195.mp_sync_Semaphore_base_eq:
  description: "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__('SemLock') returns True — Semaphore.__bases__[0].__name__=='SemLock' (len=7); Semaphore inherits from SemLock, the same POSIX-semaphore C-extension wrapper used by Lock and RLock; all three synchronization primitives ultimately rely on the same underlying OS semaphore mechanism; Semaphore.__bases__[0].__name__ (7) == Lock.__bases__[0].__name__ (7) == RLock.__bases__[0].__name__ (7); NEW in mpsynclocks195: completing 8-invariant coverage for multiprocessing.synchronize lock classes; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: Semaphore
  kind: python_call_eq
  function: "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__"
  args: ["SemLock"]
  expected: true
