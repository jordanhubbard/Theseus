spec: multiprocessing_extra195
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#synchronization-primitives

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#synchronization-primitives — Python multiprocessing synchronization documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/synchronize.py"
    - "CPython source: Modules/_multiprocessing/semaphore.c"
  notes:
    - "multiprocessing.synchronize.Lock.__name__ == 'Lock' (len=4); the process-safe mutual exclusion lock."
    - "multiprocessing.synchronize.Lock.__module__ == 'multiprocessing.synchronize' (len=27); defined in the synchronize submodule."
    - "multiprocessing.synchronize.Lock.__bases__[0].__name__ == 'SemLock' (len=7); Lock inherits from the private SemLock class which wraps a POSIX semaphore."
    - "multiprocessing.synchronize.RLock.__name__ == 'RLock' (len=5); the process-safe reentrant lock."
    - "multiprocessing.synchronize.RLock.__module__ == 'multiprocessing.synchronize' (len=27); same module as Lock."
    - "multiprocessing.synchronize.RLock.__bases__[0].__name__ == 'SemLock' (len=7); RLock also inherits from SemLock."
    - "multiprocessing.synchronize.Semaphore.__name__ == 'Semaphore' (len=9); the process-safe counting semaphore."
    - "multiprocessing.synchronize.Semaphore.__module__ == 'multiprocessing.synchronize' (len=27); same module as Lock and RLock."
    - "multiprocessing.synchronize.Semaphore.__bases__[0].__name__ == 'SemLock' (len=7); Semaphore also inherits from SemLock."
    - "All three classes share SemLock as their base, which wraps a POSIX semaphore via Modules/_multiprocessing/semaphore.c."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.synchronize.Lock class identity
#
# Lock.__name__ == 'Lock' (len=4)
# Lock.__module__ == 'multiprocessing.synchronize' (len=27)
# Lock.__bases__[0].__name__ == 'SemLock' (len=7)
# ---------------------------------------------------------------------------

table multiprocessing_extra195.mp_sync_Lock_identity:
  description: "multiprocessing.synchronize.Lock class identity checks in mpsynclocks195 namespace — Lock.__name__=='Lock' (len=4: L(1)o(2)c(3)k(4); the process-safe mutual exclusion lock, analogous to threading.Lock but backed by a POSIX semaphore for cross-process synchronization); Lock.__module__=='multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.'=1+'synchronize'=11=27; defined in Lib/multiprocessing/synchronize.py); Lock.__bases__[0].__name__=='SemLock' (len=7: S(1)e(2)m(3)L(4)o(5)c(6)k(7); Lock inherits from SemLock which wraps a POSIX semaphore via C extension); Lock.__name__ (4) < SemLock.__name__ (7) by 3; verified with Python 3.14.3"
  kind: python_call_eq
  category: Lock
  id_prefix: mpsynclocks195

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,    multiprocessing.synchronize.Lock.__name__.__eq__,                   ["Lock"],                          true, "multiprocessing.synchronize.Lock.__name__ == 'Lock' (len=4; process-safe mutual exclusion lock); verified Python 3.14.3"]
    - [lock_name_len,   multiprocessing.synchronize.Lock.__name__.__len__,                  [],                                4,    "multiprocessing.synchronize.Lock.__name__.__len__() == 4 ('Lock'=4: L(1)o(2)c(3)k(4)); verified Python 3.14.3"]
    - [lock_module_eq,  multiprocessing.synchronize.Lock.__module__.__eq__,                 ["multiprocessing.synchronize"],   true, "multiprocessing.synchronize.Lock.__module__ == 'multiprocessing.synchronize' (len=27); verified Python 3.14.3"]
    - [lock_module_len, multiprocessing.synchronize.Lock.__module__.__len__,                [],                                27,   "multiprocessing.synchronize.Lock.__module__.__len__() == 27 ('multiprocessing.synchronize'=27: 'multiprocessing'=15+'.'=1+'synchronize'=11=27); verified Python 3.14.3"]
    - ["lock_base_eq",  "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__",    ["SemLock"],                       true, "multiprocessing.synchronize.Lock.__bases__[0].__name__ == 'SemLock' (len=7; inherits from private SemLock POSIX semaphore wrapper); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.synchronize.RLock class identity
#
# RLock.__name__ == 'RLock' (len=5)
# RLock.__module__ == 'multiprocessing.synchronize' (len=27)
# RLock.__bases__[0].__name__ == 'SemLock' (len=7)
# ---------------------------------------------------------------------------

table multiprocessing_extra195.mp_sync_RLock_identity:
  description: "multiprocessing.synchronize.RLock class identity checks in mpsynclocks195 namespace — RLock.__name__=='RLock' (len=5: R(1)L(2)o(3)c(4)k(5); the process-safe reentrant lock; can be acquired multiple times by the same process without deadlocking); RLock.__module__=='multiprocessing.synchronize' (len=27; same submodule as Lock); RLock.__bases__[0].__name__=='SemLock' (len=7; RLock also inherits from SemLock, the common base for all multiprocessing synchronization primitives backed by POSIX semaphores); RLock.__name__ (5) > Lock.__name__ (4) by 1; RLock.__name__ (5) < Semaphore.__name__ (9) by 4; all three share SemLock as their base; verified with Python 3.14.3"
  kind: python_call_eq
  category: RLock
  id_prefix: mpsynclocks195

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_name_eq,    multiprocessing.synchronize.RLock.__name__.__eq__,                  ["RLock"],                         true, "multiprocessing.synchronize.RLock.__name__ == 'RLock' (len=5; process-safe reentrant lock); verified Python 3.14.3"]
    - [rlock_name_len,   multiprocessing.synchronize.RLock.__name__.__len__,                 [],                                5,    "multiprocessing.synchronize.RLock.__name__.__len__() == 5 ('RLock'=5: R(1)L(2)o(3)c(4)k(5)); verified Python 3.14.3"]
    - [rlock_module_eq,  multiprocessing.synchronize.RLock.__module__.__eq__,                ["multiprocessing.synchronize"],   true, "multiprocessing.synchronize.RLock.__module__ == 'multiprocessing.synchronize' (len=27; same module as Lock); verified Python 3.14.3"]
    - [rlock_module_len, multiprocessing.synchronize.RLock.__module__.__len__,               [],                                27,   "multiprocessing.synchronize.RLock.__module__.__len__() == 27 ('multiprocessing.synchronize'=27); verified Python 3.14.3"]
    - ["rlock_base_eq",  "multiprocessing.synchronize.RLock.__bases__[0].__name__.__eq__",   ["SemLock"],                       true, "multiprocessing.synchronize.RLock.__bases__[0].__name__ == 'SemLock' (len=7; same base as Lock); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.synchronize.Semaphore class identity
