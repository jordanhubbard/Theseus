spec: ft3421
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 675 (ft3421): __hash__, __eq__, __lt__ dict-presence checks for functools types."
    - "Theme: __hash__/__eq__/__lt__ dict-presence (hash(x), x==y, x<y)."
    - "functools.partial defines __hash__ (true): __hash__ is explicitly set to None in functools.partial.__dict__, making partial objects unhashable; the key IS present in the dict."
    - "functools.partial defines __eq__ (true): partial objects define __eq__ to compare wrapped callable and bound arguments."
    - "functools.partial does NOT define __lt__ in its own __dict__ (false)."
    - "All other functools types (partialmethod, cached_property, lru_cache wrapper) do not define __hash__, __eq__, or __lt__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "type(functools.lru_cache(lambda: None)) accesses the internal _lru_cache_wrapper C type at runtime."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3421.hash:
  description: "functools types __hash__ dict-presence checks; wave 675"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3421
  columns: [id, function, args, expected]
  rows:
    - ["ft3421001", operator.contains, [functools.partial.__dict__,                          "__hash__"], true]
    - ["ft3421002", operator.contains, [functools.partialmethod.__dict__,                    "__hash__"], false]
    - ["ft3421003", operator.contains, [functools.cached_property.__dict__,                  "__hash__"], false]
    - ["ft3421004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,    "__hash__"], false]

