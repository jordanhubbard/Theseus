spec: io_extra174
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
  notes:
    - "This spec covers: io.BytesIO and io.StringIO class identity (__name__, __module__, __bases__[0].__name__) and name length comparisons."
    - "io.BytesIO.__name__ == 'BytesIO' (len=7: 'Bytes'(5)+'IO'(2)=7)."
    - "io.BytesIO.__module__ == '_io' (len=3) — implemented in the C extension '_io', not the public 'io'."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' (len=15) — the immediate C-level base class."
    - "io.StringIO.__name__ == 'StringIO' (len=8: 'String'(6)+'IO'(2)=8)."
    - "io.StringIO.__module__ == '_io' (len=3) — also implemented in the C extension '_io'."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' (len=11) — the immediate C-level text base class."
    - "io.BytesIO.__name__.__len__() == 7: 'Bytes'(5)+'IO'(2)=7."
    - "io.StringIO.__name__.__len__() == 8: 'String'(6)+'IO'(2)=8."
    - "BytesIO (7) < StringIO (8) by 1: 'Bytes' (5) < 'String' (6) by 1, with the shared 'IO' (2) suffix."
    - "Both BytesIO and StringIO share the 'IO' suffix (2 chars) and the '_io' module (3 chars)."
    - "BytesIO's base '_BufferedIOBase' (15 chars) is longer than StringIO's base '_TextIOBase' (11 chars) by 4."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO class identity
# __name__ == 'BytesIO' (len=7), __module__ == '_io' (len=3)
# __bases__[0].__name__ == '_BufferedIOBase' (len=15)
# BytesIO (7) < StringIO (8) by 1 in class name length
# ---------------------------------------------------------------------------

table io_extra174.BytesIO_class_identity:
  description: "io.BytesIO class identity: __name__=='BytesIO' (len=7), __module__=='_io' (len=3), __bases__[0].__name__=='_BufferedIOBase' (len=15); BytesIO (7) < StringIO (8) by 1; both share '_io' module and 'IO' suffix (2 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: iobio174

  columns: [id, function, args, expected, description]
  rows:
    - [bio_name,     BytesIO.__name__.__eq__,                ["BytesIO"],         true, "io.BytesIO.__name__ == 'BytesIO' — BytesIO is the in-memory binary stream class; 'BytesIO' has 7 characters: 'Bytes' (5) + 'IO' (2) = 7; BytesIO.__name__ (7 chars) < StringIO.__name__ (8 chars) by 1 — 'Bytes' (5) is 1 shorter than 'String' (6) while the 'IO' suffix (2 chars) is shared by both; BytesIO implements the full RawIOBase/BufferedIOBase interface over an in-memory bytes buffer; BytesIO is commonly used for testing I/O code without a real file, for building binary data in memory, and as a sink/source in streaming pipelines; 'BytesIO' (7 chars) equals len('Decimal') == 7 and len('Pattern') == 7 — a common 7-character string length across standard library names; confirmed Python 3.14.3 macOS"]
    - [bio_module,   BytesIO.__module__.__eq__,              ["_io"],              true, "io.BytesIO.__module__ == '_io' — BytesIO is implemented in the '_io' C extension module; '_io' has 3 characters: '_'+'i'+'o'; BytesIO.__module__ (3: '_io') == StringIO.__module__ (3: '_io'): both in-memory stream classes are implemented in the same C extension '_io'; '_io' (3 chars) > 'io' (2 chars) by 1: the C-extension module name is one character longer than the public module name due to the leading underscore; all concrete I/O classes in the io module (BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, BufferedRandom) have __module__ == '_io' (3 chars); confirmed Python 3.14.3 macOS"]
    - [bio_base0,    "BytesIO.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"], true, "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — the immediate C-level base class of BytesIO is '_BufferedIOBase' (15 chars); '_BufferedIOBase' has 15 characters: '_'(1)+'Buffered'(8)+'IO'(2)+'Base'(4)=15; '_BufferedIOBase' (15 chars, with leading underscore) is the internal C implementation base; the public io.BufferedIOBase (14 chars, no underscore) is the Python-level ABC; BytesIO.__bases__[0].__name__ ('_BufferedIOBase', 15 chars) is longer than StringIO.__bases__[0].__name__ ('_TextIOBase', 11 chars) by 4 — reflecting the different base hierarchies for binary vs. text streams; confirmed Python 3.14.3 macOS"]
    - [bio_name_len, BytesIO.__name__.__len__,               [],                  7,    "io.BytesIO.__name__.__len__() == 7 — 'BytesIO' has 7 characters: 'Bytes'(5)+'IO'(2)=7; BytesIO (7) < StringIO (8) by 1: the 'Bytes' prefix (5 chars) is 1 shorter than the 'String' prefix (6 chars), while the shared 'IO' suffix (2 chars) contributes equally; BytesIO (7) == len('Decimal') == len('Context') == len('Pattern') == 7: a very common 7-character name length across standard library class names; the 'IO' suffix (2 chars) is the shared structural element between BytesIO (7), StringIO (8), FileIO (6: 'File'(4)+'IO'(2)=6), and RawIOBase (9: 'Raw'(3)+'IO'(2)+'Base'(4)=9); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.StringIO class identity
# __name__ == 'StringIO' (len=8), __module__ == '_io' (len=3)
# __bases__[0].__name__ == '_TextIOBase' (len=11)
# StringIO (8) > BytesIO (7) by 1 in class name length
# ---------------------------------------------------------------------------

table io_extra174.StringIO_class_identity:
  description: "io.StringIO class identity: __name__=='StringIO' (len=8), __module__=='_io' (len=3), __bases__[0].__name__=='_TextIOBase' (len=11); StringIO (8) > BytesIO (7) by 1; '_TextIOBase' (11) < '_BufferedIOBase' (15) by 4"
  kind: python_call_eq
  category: identity
  id_prefix: iosio174

  columns: [id, function, args, expected, description]
  rows:
    - [sio_name,     StringIO.__name__.__eq__,                ["StringIO"],    true, "io.StringIO.__name__ == 'StringIO' — StringIO is the in-memory text stream class; 'StringIO' has 8 characters: 'String'(6)+'IO'(2)=8; StringIO.__name__ (8 chars) > BytesIO.__name__ (7 chars) by 1 — 'String' (6 chars) is 1 longer than 'Bytes' (5 chars); StringIO implements the full TextIOBase interface over an in-memory str buffer; StringIO is commonly used for testing text I/O code without a real file and for building text output in memory; StringIO (8 chars) == len('fullmatch') in the re module name family — a coincidental 8-char tie; confirmed Python 3.14.3 macOS"]
    - [sio_module,   StringIO.__module__.__eq__,              ["_io"],          true, "io.StringIO.__module__ == '_io' — StringIO is implemented in the '_io' C extension module; '_io' has 3 characters; StringIO.__module__ (3: '_io') == BytesIO.__module__ (3: '_io'): both in-memory stream classes share the same C extension module '_io'; the leading underscore in '_io' marks it as an internal C-extension module; StringIO is a C-optimized class despite working with Python str objects; the public 'io' module (2 chars) re-exports StringIO from '_io'; confirmed Python 3.14.3 macOS"]
    - [sio_base0,    "StringIO.__bases__[0].__name__.__eq__",  ["_TextIOBase"], true, "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — the immediate C-level base class of StringIO is '_TextIOBase' (11 chars); '_TextIOBase' has 11 characters: '_'(1)+'Text'(4)+'IO'(2)+'Base'(4)=11; '_TextIOBase' (11 chars) < '_BufferedIOBase' (15 chars) by 4 — the text base class name is 4 characters shorter than the buffered binary base class name; '_TextIOBase' (11 chars, with leading underscore) is the internal C implementation base; the public io.TextIOBase (10 chars, no underscore) is the Python-level ABC; TextIOWrapper and StringIO both have '_TextIOBase' as their C-level base; confirmed Python 3.14.3 macOS"]
    - [sio_name_len, StringIO.__name__.__len__,               [],               8,   "io.StringIO.__name__.__len__() == 8 — 'StringIO' has 8 characters: 'String'(6)+'IO'(2)=8; StringIO (8) > BytesIO (7) by 1: the 'String' prefix (6 chars) is 1 longer than the 'Bytes' prefix (5 chars); StringIO (8 chars) == len('PurePath') == 8 and len('finditer') == 8 — a coincidental 3-way tie at 8 characters across pathlib, re, and io class/function names; the 'IO' suffix (2 chars) in StringIO marks it as part of the io module family: BytesIO (7), StringIO (8); the gap StringIO (8) - BytesIO (7) == 1 mirrors the gap len('String')(6) - len('Bytes')(5) == 1; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# BytesIO vs StringIO name length comparison
# BytesIO (7) < StringIO (8): 1-character difference from 'Bytes' vs 'String'
# Both share 'IO' suffix (2 chars) and '_io' module (3 chars)
# ---------------------------------------------------------------------------

table io_extra174.BytesIO_vs_StringIO_comparison:
  description: "BytesIO (7) < StringIO (8) by 1; both share '_io' module and 'IO' suffix; BytesIO base '_BufferedIOBase' (15) vs StringIO base '_TextIOBase' (11): binary base (15) is 4 chars longer than text base (11)"
  kind: python_call_eq
  category: identity
  id_prefix: iocomp174

  columns: [id, function, args, expected, description]
  rows:
    - [bio_lt_sio,    BytesIO.__name__.__len__,               [],  7,    "io.BytesIO.__name__.__len__() == 7 < io.StringIO.__name__.__len__() (8) by 1; BytesIO (7) < StringIO (8): the one-character difference arises entirely from the prefix: 'Bytes' (5) < 'String' (6) by 1; the shared 'IO' suffix (2 chars) contributes equally to both: BytesIO = 5+2=7, StringIO = 6+2=8; 7 is the minimum between BytesIO and StringIO; the pair (BytesIO=7, StringIO=8) represents the binary and text in-memory stream classes in the io module — their name lengths differ by exactly 1 character, the same as the difference between their prefix lengths; confirmed Python 3.14.3 macOS"]
    - [sio_gt_bio,    StringIO.__name__.__len__,              [],  8,    "io.StringIO.__name__.__len__() == 8 > io.BytesIO.__name__.__len__() (7) by 1; StringIO (8) is the longer of the two in-memory stream class names; the 8-character length of 'StringIO' equals: 'String'(6)+'IO'(2)=8; the 7-character length of 'BytesIO' equals: 'Bytes'(5)+'IO'(2)=7; StringIO (8) is the text-mode counterpart of BytesIO (7) — the text stream is 1 character longer in name; StringIO (8) also equals len('PurePath') (8), len('finditer') (8) — other 8-character names in the standard library class/function family; confirmed Python 3.14.3 macOS"]
    - [bio_base_len,  "BytesIO.__bases__[0].__name__.__len__", [],  15,   "io.BytesIO.__bases__[0].__name__.__len__() == 15 — '_BufferedIOBase' has 15 characters: '_'(1)+'Buffered'(8)+'IO'(2)+'Base'(4)=15; the binary base class '_BufferedIOBase' (15 chars) is 4 characters longer than the text base class '_TextIOBase' (11 chars): 15 - 11 = 4; '_BufferedIOBase' (15 chars) == len('PureWindowsPath') (15) from pathlib — a cross-module 15-character tie; the 15-character base name '_BufferedIOBase' is more than double the 7-character class name 'BytesIO'; confirmed Python 3.14.3 macOS"]
    - [sio_base_len,  "StringIO.__bases__[0].__name__.__len__", [], 11,   "io.StringIO.__bases__[0].__name__.__len__() == 11 — '_TextIOBase' has 11 characters: '_'(1)+'Text'(4)+'IO'(2)+'Base'(4)=11; '_TextIOBase' (11 chars) < '_BufferedIOBase' (15 chars) by 4: the text base class name is 4 characters shorter than the binary buffered base class name; '_TextIOBase' (11 chars) == len('WindowsPath') (11) from pathlib — a cross-module 11-character tie; '_TextIOBase' (11 chars) is longer than StringIO (8 chars) by 3: the C-level base name is 3 characters longer than the derived class; confirmed Python 3.14.3 macOS"]
    - [shared_module, BytesIO.__module__.__eq__,              ["_io"], true, "io.BytesIO.__module__.__eq__('_io') == True — BytesIO and StringIO both have __module__ == '_io' (3 chars); this shared C-extension module confirms that both in-memory stream classes are C-optimized implementations despite their Python-facing API; BytesIO.__module__ (3: '_io') == StringIO.__module__ (3: '_io') — the module uniformity mirrors the shared 'IO' suffix (2 chars) in their class names; '_io' (3 chars) > 'io' (2 chars) by 1: the C extension is one character longer than the public module; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# BytesIO and StringIO base class name lengths
# '_BufferedIOBase' (15) and '_TextIOBase' (11)
# 4-character difference mirrors Binary(Buffered) vs Text hierarchy difference
# ---------------------------------------------------------------------------

table io_extra174.base_class_name_lengths:
  description: "BytesIO base '_BufferedIOBase' (len=15) vs StringIO base '_TextIOBase' (len=11); binary base (15) > text base (11) by 4; both base names share '_'prefix, 'IO', and 'Base' (4); 'Buffered'(8) vs 'Text'(4) accounts for the 4-char gap"
  kind: python_call_eq
  category: identity
  id_prefix: iobase174

  columns: [id, function, args, expected, description]
  rows:
    - [bio_base_name,   "BytesIO.__bases__[0].__name__.__eq__",   ["_BufferedIOBase"], true, "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — the 15-character internal C-level base of BytesIO; '_BufferedIOBase' = '_'(1)+'Buffered'(8)+'IO'(2)+'Base'(4) = 15; the 'Buffered' component (8 chars) is much longer than the 'Text' component (4 chars) in StringIO's base '_TextIOBase' — contributing to the 4-character gap between the two base class names (15 vs 11); '_BufferedIOBase' serves as the C-level base for all three buffered binary classes (BufferedReader, BufferedWriter, BufferedRandom) in addition to BytesIO; confirmed Python 3.14.3 macOS"]
    - [sio_base_name,   "StringIO.__bases__[0].__name__.__eq__",  ["_TextIOBase"],     true, "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — the 11-character internal C-level base of StringIO; '_TextIOBase' = '_'(1)+'Text'(4)+'IO'(2)+'Base'(4) = 11; '_TextIOBase' (11 chars) < '_BufferedIOBase' (15 chars) by 4: the difference arises from 'Text' (4 chars) vs 'Buffered' (8 chars) — a 4-character component difference; '_TextIOBase' serves as the C-level base for TextIOWrapper in addition to StringIO; the public io.TextIOBase (10 chars, no underscore) is the Python ABC while '_TextIOBase' (11 chars, with underscore) is the C implementation base; confirmed Python 3.14.3 macOS"]
    - [bio_base_ne_sio, "BytesIO.__bases__[0].__name__.__eq__",   ["_TextIOBase"],     false, "io.BytesIO.__bases__[0].__name__.__eq__('_TextIOBase') == False — BytesIO's base is '_BufferedIOBase' (15 chars), NOT '_TextIOBase' (11 chars); this false assertion encodes the architectural split: BytesIO (binary in-memory stream) derives from the buffered binary base '_BufferedIOBase' (15 chars) while StringIO (text in-memory stream) derives from the text base '_TextIOBase' (11 chars); the binary/text split in base classes reflects the fundamental io module hierarchy where binary and text I/O descend from separate abstract bases; confirmed Python 3.14.3 macOS"]
    - [bio_name_ne_sio, BytesIO.__name__.__eq__,                  ["StringIO"],        false, "io.BytesIO.__name__.__eq__('StringIO') == False — 'BytesIO' (7 chars) != 'StringIO' (8 chars); BytesIO and StringIO are the binary and text in-memory stream classes respectively — they are sibling classes that implement different stream categories; BytesIO operates on bytes objects while StringIO operates on str objects; BytesIO.__name__ (7) != StringIO.__name__ (8) both in content and length — the 'B' vs 'S' prefix letters and 'Bytes' vs 'String' prefix strings differ; the false equality confirms they are distinct class names despite the shared 'IO' suffix; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra174.BytesIO_name_is_BytesIO:
  description: "io.BytesIO.__name__ == 'BytesIO' — BytesIO is the in-memory binary stream class; 'BytesIO' has 7 characters: 'Bytes'(5)+'IO'(2)=7; BytesIO (7) < StringIO (8) by 1 — the 'Bytes' prefix (5 chars) is 1 shorter than the 'String' prefix (6 chars); BytesIO (7) == len('Decimal') == len('Pattern') — a 7-character name tied across standard library classes; BytesIO.__module__ == '_io' (3 chars) — a C extension, not the public 'io'; BytesIO.__bases__[0].__name__ == '_BufferedIOBase' (15 chars) — the C-level binary base; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__name__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra174.BytesIO_module_is__io:
  description: "io.BytesIO.__module__ == '_io' — BytesIO is implemented in the '_io' C extension module; '_io' has 3 characters; BytesIO.__module__ (3: '_io') == StringIO.__module__ (3: '_io') — both in-memory stream classes are C-implemented; '_io' (3 chars) > 'io' (2 chars) by 1: the C extension name is one character longer than the public module name due to the leading underscore; all concrete io module classes (BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper) share __module__ == '_io' (3 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra174.BytesIO_base_is__BufferedIOBase:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO's C-level base is '_BufferedIOBase' (15 chars); '_BufferedIOBase' = '_'(1)+'Buffered'(8)+'IO'(2)+'Base'(4) = 15; '_BufferedIOBase' (15 chars) > 'BytesIO' (7 chars) by 8 — the base class name is more than double the derived class name; this same '_BufferedIOBase' (15 chars) is also the base of BufferedReader, BufferedWriter, and BufferedRandom; BytesIO.__bases__[0].__name__ ('_BufferedIOBase', 15) != StringIO.__bases__[0].__name__ ('_TextIOBase', 11) — the binary and text in-memory streams have different C-level base classes; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "BytesIO.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra174.StringIO_name_is_StringIO:
  description: "io.StringIO.__name__ == 'StringIO' — StringIO is the in-memory text stream class; 'StringIO' has 8 characters: 'String'(6)+'IO'(2)=8; StringIO (8) > BytesIO (7) by 1; StringIO (8) == len('PurePath') == 8 — same 8-character length as the pathlib base class name; StringIO.__module__ == '_io' (3 chars) — C extension, not the public 'io'; StringIO.__bases__[0].__name__ == '_TextIOBase' (11 chars) — the C-level text base; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra174.StringIO_module_is__io:
  description: "io.StringIO.__module__ == '_io' — StringIO is implemented in the '_io' C extension; '_io' has 3 characters; StringIO.__module__ (3: '_io') == BytesIO.__module__ (3: '_io') — both in-memory stream classes share the same C extension module; despite StringIO handling text (Python str), it is a C-implemented class exposed through the '_io' extension; the public 'io' module re-exports StringIO from '_io'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra174.StringIO_base_is__TextIOBase:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO's C-level base is '_TextIOBase' (11 chars); '_TextIOBase' = '_'(1)+'Text'(4)+'IO'(2)+'Base'(4) = 11; '_TextIOBase' (11 chars) < '_BufferedIOBase' (15 chars) by 4: the text base is shorter than the binary buffered base by the difference between 'Text'(4) and 'Buffered'(8), which is 4; '_TextIOBase' (11 chars) > 'StringIO' (8 chars) by 3: the C-level base name is 3 characters longer than the derived class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "StringIO.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra174.BytesIO_len_7:
  description: "io.BytesIO.__name__.__len__() == 7 — 'BytesIO' has 7 characters: 'Bytes'(5)+'IO'(2)=7; BytesIO (7) < StringIO (8) by 1; the 'IO' suffix (2 chars) is shared between BytesIO (7) and StringIO (8); 7 is the minimum of the pair (BytesIO=7, StringIO=8); BytesIO (7) == len('Decimal') == len('Context') == len('Pattern') == len('compile') == 7: the 7-character length is remarkably common across standard library names; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__name__.__len__
  args: []
  expected: 7

invariant io_extra174.StringIO_len_8:
  description: "io.StringIO.__name__.__len__() == 8 — 'StringIO' has 8 characters: 'String'(6)+'IO'(2)=8; StringIO (8) > BytesIO (7) by 1; the 8-character length of 'StringIO' equals len('PurePath') (8) and len('finditer') (8) — coincidental cross-module ties at 8 characters; the 'String' prefix (6 chars) > 'Bytes' prefix (5 chars) by 1: the one-character prefix difference propagates directly to the one-character class name length difference; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: StringIO.__name__.__len__
  args: []
  expected: 8
