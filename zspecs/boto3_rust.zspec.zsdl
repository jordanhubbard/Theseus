spec: boto3_rust
version: ">=3.9"
backend: rust_module(boto3_rust)

docs: https://boto3.amazonaws.com/v1/documentation/api/latest/reference/

provenance:
  derived_from:
    - "https://boto3.amazonaws.com/v1/documentation/api/latest/reference/ — boto3 docs"
  not_derived_from:
    - "boto3 source: boto3/__init__.py"
  notes:
    - "boto3 is the AWS SDK for Python."
    - "boto3.__version__ is a non-empty string."
    - "boto3.session.Session is available."
    - "boto3.session.Session().region_name may be None or a string."
    - "botocore.__version__ is a non-empty string."
    - "Expose boto3_has_session() -> bool: hasattr(boto3, 'session')."
    - "Expose boto3_version_nonempty() -> bool: len(boto3.__version__) > 0."
    - "Expose boto3_session_classname() -> str: boto3.session.Session.__name__."
    - "All test vectors verified against boto3 1.37.31."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# boto3_has_session — session module present
invariant boto3_rust.module.has_session:
  description: "boto3.session is available"
  category: module
  kind: python_call_eq
  function: boto3_has_session
  args: []
  expected: true

# boto3_version_nonempty — version non-empty
invariant boto3_rust.version.nonempty:
  description: "boto3.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: boto3_version_nonempty
  args: []
  expected: true

# boto3_session_classname — Session class name
invariant boto3_rust.session.classname:
  description: "boto3.session.Session.__name__ == 'Session'"
  category: session
  kind: python_call_eq
  function: boto3_session_classname
  args: []
  expected: "Session"

