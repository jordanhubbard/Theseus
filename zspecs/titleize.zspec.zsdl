spec: titleize
version: ">=4.0.0"
backend: node(titleize)

docs: https://www.npmjs.com/package/titleize

provenance:
  derived_from:
    - "titleize README — https://www.npmjs.com/package/titleize"
    - "Test vectors verified with titleize via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "titleize source"
  notes:
    - "titleize is an npm package. Install: npm install titleize"
    - "Capitalizes the first letter of each word. ESM package; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a title-cased string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table titleize.titleize:
  kind: node_module_call_eq
  function: "default"
  category: transform
  id_prefix: titlz

  columns: [id, args, expected]
  rows:
    - [two_words,   ["hello world"],      "Hello World"]
    - [three_words, ["foo bar baz"],      "Foo Bar Baz"]
    - [single,      ["hello"],            "Hello"]
