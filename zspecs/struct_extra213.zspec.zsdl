spec: struct_extra213
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic (for float/double format strings)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "verified with Python 3.14.3."
    - "struct.pack.__name__ == 'pack'; struct.unpack.__name__ == 'unpack'; struct.calcsize.__name__ == 'calcsize'."
    - "struct.pack.__module__ == '_struct'; struct.unpack.__module__ == '_struct'; struct.calcsize.__module__ == '_struct'."
    - "struct.Struct.__name__ == 'Struct'; struct.Struct.__module__ == '_struct'."
    - "struct.error.__name__ == 'error'; struct.error.__module__ == 'struct'."
    - "struct.calcsize('!H') == 2; struct.calcsize('!HHH') == 6; struct.calcsize('!III') == 12."
    - "struct.calcsize('!Q') == 8 (unsigned long long); struct.calcsize('!d') == 8 (double); struct.calcsize('!f') == 4 (float)."
    - "struct.Struct('!HHH').size == 6; struct.Struct('!HHH').format == '!HHH'."
    - "struct.Struct('!d').size == 8; struct.Struct('!f').size == 4."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module function __name__ and __module__ checks
#
# struct.pack.__name__       == 'pack'
# struct.unpack.__name__     == 'unpack'
# struct.calcsize.__name__   == 'calcsize'
# struct.pack.__module__     == '_struct'
# struct.unpack.__module__   == '_struct'
# struct.calcsize.__module__ == '_struct'
# ---------------------------------------------------------------------------

table struct_extra213.module_function_identity:
  description: "struct module-level function __name__ and __module__ checks in structeq213 namespace — wave 213 theme: pack/unpack/calcsize each retain their plain names; all three are implemented in the _struct C extension module; the __module__ attribute confirms the C extension origin rather than the Lib/struct.py wrapper; verified with Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: structeq213

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name,          "struct.pack.__name__.__eq__",       ["pack"],      true,  "struct.pack.__name__ == 'pack' — module-level pack function retains its plain name"]
    - [unpack_name,        "struct.unpack.__name__.__eq__",     ["unpack"],    true,  "struct.unpack.__name__ == 'unpack' — module-level unpack function retains its plain name"]
    - [calcsize_name,      "struct.calcsize.__name__.__eq__",   ["calcsize"],  true,  "struct.calcsize.__name__ == 'calcsize' — module-level calcsize function retains its plain name"]
    - [pack_module,        "struct.pack.__module__.__eq__",     ["_struct"],   true,  "struct.pack.__module__ == '_struct' — pack is implemented in the _struct C extension"]
    - [unpack_module,      "struct.unpack.__module__.__eq__",   ["_struct"],   true,  "struct.unpack.__module__ == '_struct' — unpack is implemented in the _struct C extension"]
    - [calcsize_module,    "struct.calcsize.__module__.__eq__", ["_struct"],   true,  "struct.calcsize.__module__ == '_struct' — calcsize is implemented in the _struct C extension"]

# ---------------------------------------------------------------------------
# struct.calcsize — multi-element and wide format checks
#
# struct.calcsize('!H')   == 2
# struct.calcsize('!HHH') == 6
# struct.calcsize('!III') == 12
# struct.calcsize('!Q')   == 8
# struct.calcsize('!d')   == 8
# struct.calcsize('!f')   == 4
# ---------------------------------------------------------------------------

table struct_extra213.calcsize_multi_and_wide:
  description: "struct.calcsize multi-element and wide-format size checks in structeq213a namespace — wave 213 theme: H=2 HHH=6 III=12 Q=8 d=8 f=4; network byte order (!prefix) eliminates platform alignment padding so sizes are strictly additive; Q is 64-bit unsigned long long; d is IEEE 754 double (8 bytes); f is IEEE 754 float (4 bytes); verified with Python 3.14.3"
  kind: python_call_eq
  category: calcsize
  id_prefix: structeq213a

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_H,    struct.calcsize,  ["!H"],    2,   "struct.calcsize('!H') == 2 — single unsigned short, 2 bytes"]
    - [calcsize_HHH,  struct.calcsize,  ["!HHH"],  6,   "struct.calcsize('!HHH') == 6 — three unsigned shorts, 3*2=6 bytes"]
    - [calcsize_III,  struct.calcsize,  ["!III"],  12,  "struct.calcsize('!III') == 12 — three unsigned ints, 3*4=12 bytes"]
    - [calcsize_Q,    struct.calcsize,  ["!Q"],    8,   "struct.calcsize('!Q') == 8 — unsigned long long, 8 bytes"]
    - [calcsize_d,    struct.calcsize,  ["!d"],    8,   "struct.calcsize('!d') == 8 — IEEE 754 double-precision float, 8 bytes"]
    - [calcsize_f,    struct.calcsize,  ["!f"],    4,   "struct.calcsize('!f') == 4 — IEEE 754 single-precision float, 4 bytes"]

# ---------------------------------------------------------------------------
# struct.Struct class and error class identity
#
# struct.Struct.__name__   == 'Struct'
# struct.Struct.__module__ == '_struct'
# struct.error.__name__    == 'error'
# struct.error.__module__  == 'struct'
# ---------------------------------------------------------------------------

table struct_extra213.class_identity:
  description: "struct.Struct and struct.error class identity attribute checks in structeq213b namespace — wave 213 theme: Struct.__name__ == 'Struct'; Struct.__module__ == '_struct' (C extension); error.__name__ == 'error'; error.__module__ == 'struct' (Python wrapper module); the module difference reflects that struct.error is exposed through the Python-level struct module while Struct is a direct C type; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: structeq213b

  columns: [id, function, args, expected, description]
  rows:
    - [struct_class_name,    "struct.Struct.__name__.__eq__",    ["Struct"],   true,  "struct.Struct.__name__ == 'Struct' — the Struct class simple name is 'Struct'"]
    - [struct_class_module,  "struct.Struct.__module__.__eq__",  ["_struct"],  true,  "struct.Struct.__module__ == '_struct' — Struct is a C type from the _struct extension module"]
    - [error_class_name,     "struct.error.__name__.__eq__",     ["error"],    true,  "struct.error.__name__ == 'error' — the exception class simple name is 'error'"]
    - [error_class_module,   "struct.error.__module__.__eq__",   ["struct"],   true,  "struct.error.__module__ == 'struct' — error is exposed in the Python-level 'struct' module namespace"]

# ---------------------------------------------------------------------------
# struct.Struct instance size and format for multi-element and float formats
#
# struct.Struct('!HHH').size   == 6
# struct.Struct('!HHH').format == '!HHH'
# struct.Struct('!d').size     == 8
# struct.Struct('!f').size     == 4
# ---------------------------------------------------------------------------

invariant struct_extra213.struct_HHH_size:
  description: "struct.Struct('!HHH').size == 6 — format '!HHH' packs three network-order unsigned shorts; each is 2 bytes so total size is 6 bytes; verified with Python 3.14.3"
  category: attributes
  kind: python_call_eq
  function: "struct.Struct('!HHH').size.__eq__"
  args: [6]
  expected: true

invariant struct_extra213.struct_HHH_format:
  description: "struct.Struct('!HHH').format == '!HHH' — the Struct .format attribute echoes back the format string as given; on Python 3.9+ this is a str (not bytes); verified with Python 3.14.3"
  category: attributes
  kind: python_call_eq
  function: "struct.Struct('!HHH').format.__eq__"
  args: ["!HHH"]
  expected: true

invariant struct_extra213.struct_d_size:
  description: "struct.Struct('!d').size == 8 — format '!d' packs a network-order IEEE 754 double-precision float; doubles are always 8 bytes; verified with Python 3.14.3"
  category: attributes
  kind: python_call_eq
  function: "struct.Struct('!d').size.__eq__"
  args: [8]
  expected: true
