spec: errno_extra2
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/errno.html"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "Extends errno.zspec.zsdl and errno_extra.zspec.zsdl."
    - "errno.zspec.zsdl covers POSIX constant values (EPERM=1, ENOENT=2, ESRCH=3, EINTR=4, EIO=5, EBADF=9, ENOMEM=12, EACCES=13, EINVAL=22); errorcode type/lookups; ENOTSUP type."
    - "errno_extra.zspec.zsdl covers ENOENT/EACCES/EEXIST/EPERM class names and values; errorcode class name; errorcode[2] == 'ENOENT'."
    - "This spec adds: class name checks for EPERM, ESRCH, EINTR, EIO, ENXIO, EISDIR, ENOTDIR, EEXIST as 'int'; errorcode class name as 'dict'; positivity checks for EPERM, ENOENT, EACCES; errorcode.__len__() >= 50."
    - "All errno constants are plain Python int objects — __class__.__name__ == 'int'."
    - "errno.EPERM > 0 — EPERM == 1, which is positive."
    - "errno.ENOENT > 0 — ENOENT == 2, which is positive."
    - "errno.EACCES > 0 — EACCES == 13, which is positive."
    - "errno.errorcode is a dict with at least 50 entries on any supported POSIX platform."
    - "errno.ENXIO == 6 on POSIX (device not configured); class is int."
    - "errno.EISDIR == 21 on POSIX (is a directory); class is int."
    - "errno.ENOTDIR == 20 on POSIX (not a directory); class is int."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "The errno module exposes read-only integer constants and the errorcode dict. No functions raise exceptions during normal use."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks — errno constants are plain int objects
# errno_extra covers ENOENT/EACCES/EEXIST/EPERM; here we add ESRCH/EINTR/EIO/
# ENXIO/EISDIR/ENOTDIR.
# ---------------------------------------------------------------------------

table errno_extra2.constant_class_names:
  description: "errno constants are plain int objects — __class__.__name__ == 'int'"
  kind: python_call_eq
  category: constant_types
  id_prefix: cls

  columns: [id, function, args, expected]
  rows:
    - [EPERM,   EPERM.__class__.__name__.__eq__,   ["int"], true]
    - [ENOENT,  ENOENT.__class__.__name__.__eq__,  ["int"], true]
    - [ESRCH,   ESRCH.__class__.__name__.__eq__,   ["int"], true]
    - [EINTR,   EINTR.__class__.__name__.__eq__,   ["int"], true]
    - [EIO,     EIO.__class__.__name__.__eq__,     ["int"], true]
    - [ENXIO,   ENXIO.__class__.__name__.__eq__,   ["int"], true]
    - [EACCES,  EACCES.__class__.__name__.__eq__,  ["int"], true]
    - [EEXIST,  EEXIST.__class__.__name__.__eq__,  ["int"], true]
    - [ENOTDIR, ENOTDIR.__class__.__name__.__eq__,  ["int"], true]
    - [EISDIR,  EISDIR.__class__.__name__.__eq__,   ["int"], true]

# ---------------------------------------------------------------------------
# errorcode — class name and size
# ---------------------------------------------------------------------------

invariant errno_extra2.errorcode_class_name:
  description: "errno.errorcode.__class__.__name__ == 'dict'"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant errno_extra2.errorcode_len_ge_50:
  description: "len(errno.errorcode) >= 50 — at least 50 error codes on any POSIX platform"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__len__
  args: []
  method: __ge__
  method_args: [50]
  expected: true

# ---------------------------------------------------------------------------
# Positivity checks — POSIX errno values are all positive integers
# ---------------------------------------------------------------------------

invariant errno_extra2.EPERM_positive:
  description: "errno.EPERM > 0 — EPERM == 1 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: EPERM.__gt__
  args: [0]
  expected: true

invariant errno_extra2.ENOENT_positive:
  description: "errno.ENOENT > 0 — ENOENT == 2 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: ENOENT.__gt__
  args: [0]
  expected: true

invariant errno_extra2.EACCES_positive:
  description: "errno.EACCES > 0 — EACCES == 13 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: EACCES.__gt__
  args: [0]
  expected: true
