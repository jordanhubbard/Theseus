spec: socket_extra180
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket.zspec.zsdl — core socket vectors."
    - "socket_extra.zspec.zsdl through socket_extra179.zspec.zsdl — prior extras."
  notes:
    - "This spec covers socket.AF_INET, AF_INET6, AF_UNIX member values and types on macOS/Darwin."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an AddressFamily IntEnum member."
    - "socket.AF_INET == 2 — AF_INET is 2 on all major platforms (Linux, macOS, BSD)."
    - "socket.AF_INET6.__class__.__name__ == 'AddressFamily' — AF_INET6 is an AddressFamily IntEnum member."
    - "socket.AF_INET6 == 30 — AF_INET6 is 30 on macOS/Darwin; it is 10 on Linux. Darwin-specific value."
    - "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — AF_UNIX is an AddressFamily IntEnum member."
    - "socket.AF_UNIX == 1 — AF_UNIX is 1 on macOS/Darwin."
    - "socket.SOCK_STREAM == 1 — SOCK_STREAM is 1 on macOS/Darwin and Linux."
    - "socket.SOCK_DGRAM == 2 — SOCK_DGRAM is 2 on macOS/Darwin and Linux."
    - "PLATFORM NOTE: AF_INET6=30 and AF_UNIX=1 are macOS/Darwin values. Linux uses AF_INET6=10 and AF_UNIX=1."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: AF_INET and AF_INET6 — class identity and integer values (Darwin)
#
# socket.AF_INET.__class__.__name__  == 'AddressFamily'
# socket.AF_INET.__eq__(2)           == True   (universal across platforms)
# socket.AF_INET6.__class__.__name__ == 'AddressFamily'
# socket.AF_INET6.__eq__(30)         == True   (Darwin only; Linux uses 10)
#
# AF_INET and AF_INET6 are members of the AddressFamily IntEnum. Their integer
# values are OS-defined. AF_INET=2 is consistent across Linux/macOS/BSD.
# AF_INET6=30 is specific to macOS/Darwin (BSD lineage); Linux uses 10.
# New to extra180.
# ---------------------------------------------------------------------------

table socket_extra180.af_inet_af_inet6_values:
  description: "AF_INET class=='AddressFamily', value==2; AF_INET6 class=='AddressFamily', value==30 (Darwin); new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: socketaf180

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_class_af,
       "AF_INET.__class__.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET is a member of the AddressFamily IntEnum; its __class__.__name__ is 'AddressFamily'; new to extra180"]
    - [af_inet_value_2,
       "AF_INET.__eq__",
       [2],
       true,
       "socket.AF_INET.__eq__(2) == True — AF_INET has integer value 2 on all major platforms (Linux, macOS, BSD); this is the POSIX-standardised AF_INET constant; new to extra180"]
    - [af_inet6_class_af,
       "AF_INET6.__class__.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AF_INET6.__class__.__name__.__eq__('AddressFamily') == True — AF_INET6 is a member of the AddressFamily IntEnum; its __class__.__name__ is 'AddressFamily'; new to extra180"]
    - [af_inet6_value_30,
       "AF_INET6.__eq__",
       [30],
       true,
       "socket.AF_INET6.__eq__(30) == True — AF_INET6 has integer value 30 on macOS/Darwin (BSD lineage); Linux uses value 10; this invariant is Darwin-specific; verified Python 3.14.3 macOS/Darwin 25.4.0; new to extra180"]

# ---------------------------------------------------------------------------
# Table 2: AF_UNIX — class identity and integer value (Darwin)
#
# socket.AF_UNIX.__class__.__name__ == 'AddressFamily'
# socket.AF_UNIX.__eq__(1)          == True   (macOS/Darwin; also Linux)
#
# AF_UNIX (Unix domain sockets) is also an AddressFamily IntEnum member.
# Its value is 1 on both macOS/Darwin and Linux, making it more portable
# than AF_INET6. New to extra180.
# ---------------------------------------------------------------------------

table socket_extra180.af_unix_values:
  description: "AF_UNIX class=='AddressFamily', value==1 (Darwin); new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: socketaf180

  columns: [id, function, args, expected, description]
  rows:
    - [af_unix_class_af,
       "AF_UNIX.__class__.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AF_UNIX.__class__.__name__.__eq__('AddressFamily') == True — AF_UNIX is a member of the AddressFamily IntEnum; its __class__.__name__ is 'AddressFamily'; new to extra180"]
    - [af_unix_value_1,
       "AF_UNIX.__eq__",
       [1],
       true,
       "socket.AF_UNIX.__eq__(1) == True — AF_UNIX has integer value 1 on macOS/Darwin; also 1 on Linux; AF_UNIX provides Unix domain (local) socket communication; new to extra180"]
    - [af_unix_class_not_int,
       "AF_UNIX.__class__.__name__.__eq__",
       ["int"],
       false,
       "socket.AF_UNIX.__class__.__name__.__eq__('int') == False — AF_UNIX is an AddressFamily member, not a plain int; although IntEnum members compare equal to ints, their __class__ is AddressFamily; new to extra180"]
    - [af_inet_value_not_30,
       "AF_INET.__eq__",
       [30],
       false,
       "socket.AF_INET.__eq__(30) == False — AF_INET has value 2, not 30; 30 is AF_INET6 on Darwin; new to extra180"]

# ---------------------------------------------------------------------------
# Table 3: SOCK_STREAM and SOCK_DGRAM — integer values
#
# socket.SOCK_STREAM.__eq__(1) == True
# socket.SOCK_DGRAM.__eq__(2)  == True
#
# SOCK_STREAM and SOCK_DGRAM are members of the SocketKind IntEnum.
# Their integer values (1 and 2 respectively) are consistent across
# macOS/Darwin and Linux. New to extra180.
# ---------------------------------------------------------------------------

table socket_extra180.sock_stream_dgram_values:
  description: "SOCK_STREAM==1, SOCK_DGRAM==2 on Darwin; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: socketaf180

  columns: [id, function, args, expected, description]
  rows:
    - [sock_stream_value_1,
       "SOCK_STREAM.__eq__",
       [1],
       true,
       "socket.SOCK_STREAM.__eq__(1) == True — SOCK_STREAM has integer value 1 on macOS/Darwin and Linux; it is the SocketKind member for TCP-style reliable ordered byte-stream sockets; new to extra180"]
    - [sock_dgram_value_2,
       "SOCK_DGRAM.__eq__",
       [2],
       true,
       "socket.SOCK_DGRAM.__eq__(2) == True — SOCK_DGRAM has integer value 2 on macOS/Darwin and Linux; it is the SocketKind member for UDP-style connectionless datagram sockets; new to extra180"]
    - [sock_stream_not_2,
       "SOCK_STREAM.__eq__",
       [2],
       false,
       "socket.SOCK_STREAM.__eq__(2) == False — SOCK_STREAM value is 1, not 2; 2 is SOCK_DGRAM; new to extra180"]
    - [sock_dgram_not_1,
       "SOCK_DGRAM.__eq__",
       [1],
       false,
       "socket.SOCK_DGRAM.__eq__(1) == False — SOCK_DGRAM value is 2, not 1; 1 is SOCK_STREAM; new to extra180"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra180
# ---------------------------------------------------------------------------

invariant socket_extra180.af_inet_class_address_family:
  description: "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an AddressFamily IntEnum member; new to extra180"
  category: identity
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra180.af_inet_value_2:
  description: "socket.AF_INET == 2 — AF_INET has value 2 on all major platforms; new to extra180"
  category: identity
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

invariant socket_extra180.af_inet6_class_address_family:
  description: "socket.AF_INET6.__class__.__name__ == 'AddressFamily' — AF_INET6 is an AddressFamily IntEnum member; new to extra180"
  category: identity
  kind: python_call_eq
  function: AF_INET6.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra180.af_inet6_value_30:
  description: "socket.AF_INET6 == 30 on macOS/Darwin — AF_INET6=30 is Darwin-specific (Linux uses 10); verified Python 3.14.3 macOS/Darwin 25.4.0; new to extra180"
  category: identity
  kind: python_call_eq
  function: AF_INET6.__eq__
  args: [30]
  expected: true

invariant socket_extra180.af_unix_class_address_family:
  description: "socket.AF_UNIX.__class__.__name__ == 'AddressFamily' — AF_UNIX is an AddressFamily IntEnum member; new to extra180"
  category: identity
  kind: python_call_eq
  function: AF_UNIX.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra180.af_unix_value_1:
  description: "socket.AF_UNIX == 1 on macOS/Darwin — AF_UNIX provides Unix domain socket communication; new to extra180"
  category: identity
  kind: python_call_eq
  function: AF_UNIX.__eq__
  args: [1]
  expected: true

invariant socket_extra180.sock_stream_value_1:
  description: "socket.SOCK_STREAM == 1 — SOCK_STREAM is 1 on macOS/Darwin and Linux; new to extra180"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true

invariant socket_extra180.sock_dgram_value_2:
  description: "socket.SOCK_DGRAM == 2 — SOCK_DGRAM is 2 on macOS/Darwin and Linux; new to extra180"
  category: identity
  kind: python_call_eq
  function: SOCK_DGRAM.__eq__
  args: [2]
  expected: true
