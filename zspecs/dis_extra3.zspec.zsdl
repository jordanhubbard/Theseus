spec: dis_extra3
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
  notes:
    - "This spec extends prior dis specs."
    - "Focus: __module__ and __name__ for dis functions and classes not yet covered."
    - "dis.Instruction.__name__ == 'Instruction'."
    - "dis.Bytecode.__name__ == 'Bytecode'."
    - "dis.findlinestarts.__name__ == 'findlinestarts'."
    - "dis.findlabels.__name__ == 'findlabels'."
    - "dis.get_instructions.__name__ == 'get_instructions'."
    - "dis.stack_effect.__name__ == 'stack_effect'."
    - "dis.opname is a list; dis.opmap is a dict."
    - "dis.HAVE_ARGUMENT == 90 (the minimum opcode that takes an argument)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table dis_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Instruction, Instruction.__name__.__eq__, ["Instruction"], true]
    - [Bytecode,    Bytecode.__name__.__eq__,    ["Bytecode"],    true]

table dis_extra3.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Instruction, Instruction.__module__.__eq__, ["dis"], true]
    - [Bytecode,    Bytecode.__module__.__eq__,    ["dis"], true]

table dis_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [findlinestarts,   findlinestarts.__name__.__eq__,   ["findlinestarts"],   true]
    - [findlabels,       findlabels.__name__.__eq__,       ["findlabels"],       true]
    - [get_instructions, get_instructions.__name__.__eq__, ["get_instructions"], true]
    - [stack_effect,     stack_effect.__name__.__eq__,     ["stack_effect"],     true]

invariant dis_extra3.opname.is_list:
  description: "dis.opname.__class__.__name__ == 'list'"
  category: opname
  kind: python_call_eq
  function: opname.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant dis_extra3.opname.length:
  description: "len(dis.opname) == 256 — one entry per byte value"
  category: opname
  kind: python_call_eq
  function: opname.__len__
  args: []
  expected: 256

invariant dis_extra3.opmap.is_dict:
  description: "dis.opmap.__class__.__name__ == 'dict'"
  category: opmap
  kind: python_call_eq
  function: opmap.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant dis_extra3.HAVE_ARGUMENT.value:
  description: "dis.HAVE_ARGUMENT == 90"
  category: constants
  kind: python_call_eq
  function: HAVE_ARGUMENT.__eq__
  args: [90]
  expected: true

invariant dis_extra3.Bytecode.module:
  description: "dis.Bytecode.__module__ == 'dis'"
  category: module
  kind: python_call_eq
  function: Bytecode.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra3.opmap.contains_LOAD_FAST:
  description: "'LOAD_FAST' in dis.opmap == True"
  category: opmap
  kind: python_call_eq
  function: opmap.__contains__
  args: ["LOAD_FAST"]
  expected: true

invariant dis_extra3.opmap.contains_RETURN_VALUE:
  description: "'RETURN_VALUE' in dis.opmap == True"
  category: opmap
  kind: python_call_eq
  function: opmap.__contains__
  args: ["RETURN_VALUE"]
  expected: true
