spec: inspect_extra616
version: ">=3.9"
backend: python_module(inspect)
docs: "Behavioral spec for inspect.Signature, Parameter, and BoundArguments class identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers Signature, Parameter, and BoundArguments class/qualname/module/doc identity."
  created_at: "2026-04-12T00:00:00Z"

table inspect_extra616.signature_identity:
  description: "inspect.Signature class identity checks"
  kind: python_call_eq
  category: inspect_identity
  id_prefix: in616si
  columns: [id, function, args, expected]
  rows:
    - [in616si001, inspect.Signature.__class__.__name__.__eq__, ["type"], true]
    - [in616si002, inspect.Signature.__qualname__.__eq__, ["Signature"], true]
    - [in616si003, inspect.Signature.__module__.__eq__, ["inspect"], true]
    - [in616si004, inspect.Signature.__doc__.__class__.__name__.__eq__, ["str"], true]

table inspect_extra616.parameter_identity:
  description: "inspect.Parameter and BoundArguments class identity checks"
  kind: python_call_eq
  category: inspect_identity
  id_prefix: in616pa
  columns: [id, function, args, expected]
  rows:
    - [in616pa001, inspect.Parameter.__class__.__name__.__eq__, ["type"], true]
    - [in616pa002, inspect.Parameter.__qualname__.__eq__, ["Parameter"], true]
    - [in616pa003, inspect.Parameter.__module__.__eq__, ["inspect"], true]
    - [in616pa004, inspect.Parameter.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in616pa005, inspect.BoundArguments.__class__.__name__.__eq__, ["type"], true]
    - [in616pa006, inspect.BoundArguments.__qualname__.__eq__, ["BoundArguments"], true]
    - [in616pa007, inspect.BoundArguments.__module__.__eq__, ["inspect"], true]
    - [in616pa008, inspect.BoundArguments.__doc__.__class__.__name__.__eq__, ["str"], true]
