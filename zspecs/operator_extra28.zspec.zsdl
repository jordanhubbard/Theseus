spec: operator_extra28
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator_extra27.zspec.zsdl."
    - "operator_extra27 covers: comparison operator qualnames (eq/ne/lt/le/gt/ge); comparison operator __module__ values; matmul/index/iconcat qualnames."
    - "operator_extra26 covers: attrgetter/itemgetter/methodcaller __module__ and __bases__[0].__name__ tables; concat/getitem/setitem/delitem sequence qualnames; neg/pos/abs/pow unary qualnames."
    - "operator_extra25 covers: bitwise operator qualnames (and_/or_/xor/invert/lshift/rshift); length_hint qualname."
    - "This spec covers: attrgetter/itemgetter/methodcaller __module__, __qualname__, and __init__.__name__ — all in the extra28 namespace; iadd/isub/imul/itruediv __name__ in the extra28 namespace."
    - "Key findings: attrgetter/itemgetter/methodcaller all report __module__ == 'operator' (public namespace) and have simple qualnames; their __init__.__name__ == '__init__'. The in-place operators iadd/isub/imul/itruediv have __name__ equal to their attribute name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__eq__ table — callable class module membership
#
# operator.attrgetter, itemgetter, and methodcaller are C-level types that
# implement lazy attribute lookup, item lookup, and method calling respectively.
# All three report __module__ == 'operator', the public module name, rather
# than '_operator'. This is the same pattern noted in operator_extra26; this
# table records these values in the extra28 namespace.
# No prior operator spec records all three together in the extra28 namespace.
# ---------------------------------------------------------------------------

table operator_extra28.callable_class_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra28.callable_class_modules.attrgetter,
       attrgetter.__module__.__eq__,
       ["operator"],
       true,
       "operator.attrgetter.__module__ == 'operator'"]
    - [operator_extra28.callable_class_modules.itemgetter,
       itemgetter.__module__.__eq__,
       ["operator"],
       true,
       "operator.itemgetter.__module__ == 'operator'"]
    - [operator_extra28.callable_class_modules.methodcaller,
       methodcaller.__module__.__eq__,
       ["operator"],
       true,
       "operator.methodcaller.__module__ == 'operator'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — callable class qualnames
#
# operator.attrgetter, itemgetter, and methodcaller are C-level types defined
# at module scope. Their qualnames are simple names equal to their class names,
# confirming no nesting. operator_extra23 records these qualnames in the extra23
# namespace; this table records them in the extra28 namespace.
# No prior operator spec records all three together in the extra28 namespace.
# ---------------------------------------------------------------------------

table operator_extra28.callable_class_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra28.callable_class_qualnames.attrgetter,
       attrgetter.__qualname__.__eq__,
       ["attrgetter"],
       true,
       "operator.attrgetter.__qualname__ == 'attrgetter'"]
    - [operator_extra28.callable_class_qualnames.itemgetter,
       itemgetter.__qualname__.__eq__,
       ["itemgetter"],
       true,
       "operator.itemgetter.__qualname__ == 'itemgetter'"]
    - [operator_extra28.callable_class_qualnames.methodcaller,
       methodcaller.__qualname__.__eq__,
       ["methodcaller"],
       true,
       "operator.methodcaller.__qualname__ == 'methodcaller'"]

# ---------------------------------------------------------------------------
# __init__.__name__.__eq__ table — callable class init slot names
#
# operator.attrgetter, itemgetter, and methodcaller are C-level types. Accessing
# their __init__ attribute yields the slot wrapper '__init__' inherited from or
# defined on the type. The __name__ of each slot wrapper is '__init__',
# confirming the standard initializer name. No prior operator spec records all
# three __init__.__name__ values together in the extra28 namespace.
# ---------------------------------------------------------------------------

table operator_extra28.callable_class_init_names:
  kind: python_call_eq
  category: method_names
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra28.callable_class_init_names.attrgetter,
       attrgetter.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "operator.attrgetter.__init__.__name__ == '__init__'"]
    - [operator_extra28.callable_class_init_names.itemgetter,
       itemgetter.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "operator.itemgetter.__init__.__name__ == '__init__'"]
    - [operator_extra28.callable_class_init_names.methodcaller,
       methodcaller.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "operator.methodcaller.__init__.__name__ == '__init__'"]

# ---------------------------------------------------------------------------
# __name__.__eq__ table — in-place arithmetic operator names
#
# operator.iadd, isub, imul, and itruediv are the in-place arithmetic operators
# corresponding to +=, -=, *=, and /=. They are C-level functions in _operator.
# Each has a simple __name__ equal to its attribute name (no 'i' prefix is
# stripped). No prior operator spec records all four in-place operator names
# together in the extra28 namespace.
# ---------------------------------------------------------------------------

table operator_extra28.inplace_arith_names:
  kind: python_call_eq
  category: function_names
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra28.inplace_arith_names.iadd,
       iadd.__name__.__eq__,
       ["iadd"],
       true,
       "operator.iadd.__name__ == 'iadd'"]
    - [operator_extra28.inplace_arith_names.isub,
       isub.__name__.__eq__,
       ["isub"],
       true,
       "operator.isub.__name__ == 'isub'"]
    - [operator_extra28.inplace_arith_names.imul,
       imul.__name__.__eq__,
       ["imul"],
       true,
       "operator.imul.__name__ == 'imul'"]
    - [operator_extra28.inplace_arith_names.itruediv,
       itruediv.__name__.__eq__,
       ["itruediv"],
       true,
       "operator.itruediv.__name__ == 'itruediv'"]

# ---------------------------------------------------------------------------
# attrgetter.__module__.__eq__ — standalone module membership
#
# operator.attrgetter is a C-level type that reports __module__ == 'operator',
# the public module name. This contrasts with the plain operator functions (e.g.
# operator.add, operator.eq) which report __module__ == '_operator'. The
# distinction captures how C-level classes vs. C-level functions are attributed.
# No prior operator spec records this standalone in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra28.attrgetter.module:
  description: "operator.attrgetter.__module__ == 'operator'"
  category: module_membership
  kind: python_call_eq
  function: attrgetter.__module__.__eq__
  args: ["operator"]
  expected: true

# ---------------------------------------------------------------------------
# attrgetter.__qualname__.__eq__ — standalone class qualname
#
# operator.attrgetter is a C-level callable class defined at module scope. Its
# qualname is 'attrgetter', a simple name with no enclosing scope. extra23
# records this in the extra23 namespace; this standalone records it in the
# extra28 namespace. No prior operator spec records this standalone in the
# extra28 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra28.attrgetter.qualname:
  description: "operator.attrgetter.__qualname__ == 'attrgetter'"
  category: qualnames
  kind: python_call_eq
  function: attrgetter.__qualname__.__eq__
  args: ["attrgetter"]
  expected: true

# ---------------------------------------------------------------------------
# iadd.__name__.__eq__ — standalone in-place operator name
#
# operator.iadd is the C-level function implementing the += in-place addition
# operator. Its __name__ is 'iadd', equal to its attribute name. This is the
# canonical name by which the function identifies itself. No prior operator spec
# records this standalone in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra28.iadd.name:
  description: "operator.iadd.__name__ == 'iadd'"
  category: function_names
  kind: python_call_eq
  function: iadd.__name__.__eq__
  args: ["iadd"]
  expected: true
