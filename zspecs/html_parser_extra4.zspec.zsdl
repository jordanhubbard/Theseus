spec: html_parser_extra4
version: ">=3.9"
backend: python_module(html.parser)

docs: https://docs.python.org/3/library/html.parser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.parser.html — Python html.parser module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/html/parser.py"
    - "html_parser.zspec.zsdl — covers HTMLParser.__name__, __module__, convert_charrefs default, getpos(), method __name__ (feed/reset/close/getpos/handle_starttag/handle_endtag/handle_data/handle_comment/handle_charref/handle_entityref), reset/close return None"
    - "html_extra5.zspec.zsdl — covers HTMLParser.__qualname__, method __qualname__ for 8 core methods, HTMLParser.__class__.__name__, HTMLParser.__bases__[0].__name__ (NOTE: html_extra5 incorrectly records 'object'; the correct value is 'ParserBase')"
    - "html_parser_extra2.zspec.zsdl — covers handle_decl/handle_pi/unknown_decl __name__/__qualname__; CDATA_CONTENT_ELEMENTS type/membership; convert_charrefs=False"
    - "html_parser_extra3.zspec.zsdl — covers method __module__ for all HTMLParser methods"
  notes:
    - "This spec covers axes not yet in html_parser.zspec.zsdl, html_extra5.zspec.zsdl, html_parser_extra2.zspec.zsdl, or html_parser_extra3.zspec.zsdl."
    - "html.parser.HTMLParser.__qualname__ == 'HTMLParser' — covered by html_extra5 but re-verified here with html.parser backend for authoritative confirmation."
    - "html.parser.HTMLParser.__module__ == 'html.parser' — covered by html_parser.zspec.zsdl; included here for completeness."
    - "html.parser.HTMLParser.__bases__[0].__name__ == 'ParserBase' — html_extra5 incorrectly records 'object'; this spec corrects the record using the html.parser backend."
    - "html.parser.HTMLParser.__bases__[0].__qualname__ == 'ParserBase' — not tested in any prior spec."
    - "html.parser.HTMLParser.__bases__[0].__module__ == '_markupbase' — not tested in any prior spec."
    - "html.parser.HTMLParser.__mro__ has length 3: [HTMLParser, ParserBase, object] — not tested in any prior spec."
    - "html.parser.HTMLParser.feed.__name__ == 'feed' — covered by html_parser.zspec.zsdl; included for cross-spec confirmation."
    - "html.parser.HTMLParser.handle_starttag.__name__ == 'handle_starttag' — covered by html_parser.zspec.zsdl; included for cross-spec confirmation."
    - "Note: html.parser.HTMLParseError was deprecated in Python 3.3 and removed in Python 3.5; it does not exist in Python 3.9+ and cannot be tested here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTMLParser class identity — __qualname__ and __module__
#
# html_extra5 covers __qualname__ via html.parser backend.
# html_parser.zspec.zsdl covers __module__ on the class.
# These invariants confirm both using fresh IDs in this spec.
# ---------------------------------------------------------------------------

invariant html_parser_extra4.HTMLParser.qualname:
  description: "html.parser.HTMLParser.__qualname__ == 'HTMLParser'"
  category: class_identity
  kind: python_call_eq
  function: HTMLParser.__qualname__.__eq__
  args: ["HTMLParser"]
  expected: true

invariant html_parser_extra4.HTMLParser.module:
  description: "html.parser.HTMLParser.__module__ == 'html.parser'"
  category: class_identity
  kind: python_call_eq
  function: HTMLParser.__module__.__eq__
  args: ["html.parser"]
  expected: true

# ---------------------------------------------------------------------------
# HTMLParser.__bases__[0] — base class is ParserBase, not object
#
# html_extra5.zspec.zsdl (using html.parser backend) records __bases__[0].__name__
# as 'object', which is incorrect. The actual base class is ParserBase from
# _markupbase. This spec records the correct value.
# ---------------------------------------------------------------------------

invariant html_parser_extra4.HTMLParser.base_name:
  description: "html.parser.HTMLParser.__bases__[0].__name__ == 'ParserBase'"
  category: class_hierarchy
  kind: python_call_eq
  function: HTMLParser.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "ParserBase"

invariant html_parser_extra4.HTMLParser.base_qualname:
  description: "html.parser.HTMLParser.__bases__[0].__qualname__ == 'ParserBase'"
  category: class_hierarchy
  kind: python_call_eq
  function: HTMLParser.__bases__.__getitem__
  args: [0]
  method: __qualname__
  method_args: []
  expected: "ParserBase"

invariant html_parser_extra4.HTMLParser.base_module:
  description: "html.parser.HTMLParser.__bases__[0].__module__ == '_markupbase'"
  category: class_hierarchy
  kind: python_call_eq
  function: HTMLParser.__bases__.__getitem__
  args: [0]
  method: __module__
  method_args: []
  expected: "_markupbase"

# ---------------------------------------------------------------------------
# HTMLParser MRO — length is 3 (HTMLParser → ParserBase → object)
#
# Not tested in any prior spec. MRO length is a stable behavioral invariant
# of the class hierarchy.
# ---------------------------------------------------------------------------

invariant html_parser_extra4.HTMLParser.mro_length:
  description: "len(html.parser.HTMLParser.__mro__) == 3"
  category: class_hierarchy
  kind: python_call_eq
  function: HTMLParser.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# HTMLParser.feed and handle_starttag __name__ — method identity
#
# html_parser.zspec.zsdl covers __name__ for both methods.
# These invariants confirm the same values with fresh IDs for cross-spec
# consistency tracking.
# ---------------------------------------------------------------------------

invariant html_parser_extra4.feed.name:
  description: "html.parser.HTMLParser.feed.__name__ == 'feed'"
  category: method_identity
  kind: python_call_eq
  function: HTMLParser.feed.__name__.__eq__
  args: ["feed"]
  expected: true

invariant html_parser_extra4.handle_starttag.name:
  description: "html.parser.HTMLParser.handle_starttag.__name__ == 'handle_starttag'"
  category: method_identity
  kind: python_call_eq
  function: HTMLParser.handle_starttag.__name__.__eq__
  args: ["handle_starttag"]
  expected: true

# ---------------------------------------------------------------------------
# HTMLParser.__dict__ membership — feed and handle_starttag are defined on
# HTMLParser directly (not inherited from ParserBase)
#
# Not tested in any prior spec.
# ---------------------------------------------------------------------------

invariant html_parser_extra4.HTMLParser.dict_has_feed:
  description: "'feed' in html.parser.HTMLParser.__dict__ == True"
  category: class_dict
  kind: python_call_eq
  function: HTMLParser.__dict__.__contains__
  args: ["feed"]
  expected: true

invariant html_parser_extra4.HTMLParser.dict_has_handle_starttag:
  description: "'handle_starttag' in html.parser.HTMLParser.__dict__ == True"
  category: class_dict
  kind: python_call_eq
  function: HTMLParser.__dict__.__contains__
  args: ["handle_starttag"]
  expected: true
