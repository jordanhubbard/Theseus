spec: theseus_posixpath_cr
version: ">=3.0"
backend: python_cleanroom(theseus_posixpath_cr)
blocks: posixpath

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/os.path.html"
  not_derived_from:
    - "CPython source: Lib/posixpath.py"
  notes:
    - "Clean-room posixpath module. Do NOT import posixpath."

error_model: python_exceptions

invariant theseus_posixpath_cr.posixpath2_split:
  description: "split() splits path into (head, tail)"
  category: behavior
  kind: python_call_eq
  function: posixpath2_split
  args: []
  expected: true

invariant theseus_posixpath_cr.posixpath2_join:
  description: "join() joins path components"
  category: behavior
  kind: python_call_eq
  function: posixpath2_join
  args: []
  expected: true

invariant theseus_posixpath_cr.posixpath2_normpath:
  description: "normpath() normalizes a POSIX path"
  category: behavior
  kind: python_call_eq
  function: posixpath2_normpath
  args: []
  expected: true
