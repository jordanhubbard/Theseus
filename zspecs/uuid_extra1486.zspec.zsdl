spec: uuid_extra1486
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "RFC 4122 source text"
  notes:
    - "Wave 546 extra1486: context manager protocol checks for uuid classes."
    - "uuid.UUID is a plain class; it has no __enter__ or __exit__ in its __dict__."
    - "uuid.SafeUUID is an Enum subclass; it also lacks __enter__ and __exit__."
    - "Neither UUID nor SafeUUID supports the context manager protocol (no 'with' usage)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1486.uuid_class_context_manager:
  description: "uuid.UUID has no context manager protocol (__enter__/__exit__ absent from __dict__)"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: uu1486ux
  columns: [id, function, args, expected]
  rows:
    - [uu1486ux001, uuid.UUID.__dict__.__contains__, ["__enter__"],          false]
    - [uu1486ux002, uuid.UUID.__dict__.__contains__, ["__exit__"],           false]
    - [uu1486ux003, uuid.UUID.__name__.__eq__,       ["UUID"],               true]
    - [uu1486ux004, uuid.UUID.__module__.__eq__,     ["uuid"],               true]
    - [uu1486ux005, uuid.UUID.__qualname__.__eq__,   ["UUID"],               true]
    - [uu1486ux006, uuid.UUID.__class__.__name__.__eq__, ["type"],           true]

table uuid_extra1486.safeuuid_class_context_manager:
  description: "uuid.SafeUUID has no context manager protocol (__enter__/__exit__ absent from __dict__)"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: uu1486sx
  columns: [id, function, args, expected]
  rows:
    - [uu1486sx001, uuid.SafeUUID.__dict__.__contains__, ["__enter__"],      false]
    - [uu1486sx002, uuid.SafeUUID.__dict__.__contains__, ["__exit__"],       false]
    - [uu1486sx003, uuid.SafeUUID.__name__.__eq__,       ["SafeUUID"],       true]
    - [uu1486sx004, uuid.SafeUUID.__module__.__eq__,     ["uuid"],           true]
    - [uu1486sx005, uuid.SafeUUID.__qualname__.__eq__,   ["SafeUUID"],       true]
    - [uu1486sx006, uuid.SafeUUID.__class__.__name__.__eq__, ["EnumType"],   true]

table uuid_extra1486.uuid_safeuuid_no_enter_exit:
  description: "Consolidated negative check: neither uuid.UUID nor uuid.SafeUUID carry __enter__/__exit__"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: uu1486nx
  columns: [id, function, args, expected]
  rows:
    - [uu1486nx001, uuid.UUID.__dict__.__contains__,       ["__enter__"],    false]
    - [uu1486nx002, uuid.UUID.__dict__.__contains__,       ["__exit__"],     false]
    - [uu1486nx003, uuid.SafeUUID.__dict__.__contains__,   ["__enter__"],    false]
    - [uu1486nx004, uuid.SafeUUID.__dict__.__contains__,   ["__exit__"],     false]
    - [uu1486nx005, uuid.UUID.__bases__.__class__.__name__.__eq__,    ["tuple"],  true]
    - [uu1486nx006, uuid.SafeUUID.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [uu1486nx007, uuid.UUID.__module__.__class__.__name__.__eq__,   ["str"],    true]
