spec: threading_extra1741
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol dict-presence checks."
    - "threading.Thread: Python class inheriting from object — not a descriptor, all four descriptor dunders absent from __dict__."
    - "threading.Lock: alias for _thread.lock (C extension) — not a descriptor, all four absent."
    - "threading.Event: Python class inheriting from object — not a descriptor, all four absent."
    - "threading.Condition: Python class inheriting from object — not a descriptor, all four absent."
    - "None of the threading synchronization or thread types implement the descriptor protocol."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: descriptor protocol dict-presence checks for threading types
#
# Wave 563 theme: which threading types define __get__, __set__, __delete__,
# __set_name__ in their own __dict__.
#
# threading.Thread: Python class in Lib/threading.py; represents a thread of
#   execution — not a descriptor, all four dunders absent.
# threading.Lock: alias for _thread.lock (C extension type from
#   Modules/_threadmodule.c) — not a descriptor, all four dunders absent.
# threading.Event: Python class in Lib/threading.py built on Condition —
#   not a descriptor, all four dunders absent.
# threading.Condition: Python class wrapping a lock for condition variables —
#   not a descriptor, all four dunders absent.
# ---------------------------------------------------------------------------

table threading_extra1741.descriptor_protocol:
  description: "threading types descriptor protocol dict-presence checks — all False — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1741

  columns: [id, function, args, expected]
  rows:
    - ["th1741001", "threading.Thread.__dict__.__contains__", ["__get__"], false]
    - ["th1741002", "threading.Thread.__dict__.__contains__", ["__set__"], false]
    - ["th1741003", "threading.Thread.__dict__.__contains__", ["__delete__"], false]
    - ["th1741004", "threading.Thread.__dict__.__contains__", ["__set_name__"], false]
    - ["th1741005", "threading.Event.__dict__.__contains__", ["__get__"], false]
    - ["th1741006", "threading.Event.__dict__.__contains__", ["__set__"], false]
    - ["th1741007", "threading.Event.__dict__.__contains__", ["__delete__"], false]
    - ["th1741008", "threading.Event.__dict__.__contains__", ["__set_name__"], false]
    - ["th1741009", "threading.Condition.__dict__.__contains__", ["__get__"], false]
    - ["th1741010", "threading.Condition.__dict__.__contains__", ["__set__"], false]
    - ["th1741011", "threading.Condition.__dict__.__contains__", ["__delete__"], false]
    - ["th1741012", "threading.Condition.__dict__.__contains__", ["__set_name__"], false]

# ---------------------------------------------------------------------------
# Table 2: non-descriptor contrast — threading types define ordinary methods
#
# Contrast: threading.Thread.__dict__ contains __init__, run, start, join,
# is_alive (regular methods), confirming the __dict__ is accessible and
# populated — the absence of descriptor dunders is meaningful.
# threading.Event has set, clear, wait, is_set in its __dict__.
# threading.Condition has acquire, release, wait, notify in its __dict__.
# The contrast confirms threading types are thread-synchronization tools,
# not attribute-management descriptors.
# ---------------------------------------------------------------------------

table threading_extra1741.non_descriptor_contrast:
  description: "threading types __dict__ has __init__/run/start/join but NOT descriptor dunders — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1741

  columns: [id, function, args, expected]
  rows:
    - ["th1741013", "threading.Thread.__dict__.__contains__", ["__init__"], true]
    - ["th1741014", "threading.Thread.__dict__.__contains__", ["run"], true]
    - ["th1741015", "threading.Thread.__dict__.__contains__", ["start"], true]
    - ["th1741016", "threading.Thread.__dict__.__contains__", ["join"], true]
    - ["th1741017", "threading.Thread.__dict__.__contains__", ["is_alive"], true]
    - ["th1741018", "threading.Event.__dict__.__contains__", ["set"], true]
    - ["th1741019", "threading.Event.__dict__.__contains__", ["clear"], true]
    - ["th1741020", "threading.Event.__dict__.__contains__", ["wait"], true]
    - ["th1741021", "threading.Condition.__dict__.__contains__", ["acquire"], true]
    - ["th1741022", "threading.Condition.__dict__.__contains__", ["notify"], true]
    - ["th1741023", "threading.Thread.__dict__.__contains__", ["__get__"], false]
    - ["th1741024", "threading.Event.__dict__.__contains__", ["__get__"], false]
    - ["th1741025", "threading.Condition.__dict__.__contains__", ["__set_name__"], false]
