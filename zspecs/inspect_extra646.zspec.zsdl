spec: inspect_extra646
version: ">=3.9"
backend: python_module(inspect)
docs: "Behavioral spec for inspect module classification and introspection functions __doc__ type, __qualname__, and __module__."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __doc__ type for inspect classification functions (ismodule, isclass, ismethod, isfunction, isgeneratorfunction, iscoroutinefunction, getmembers, getdoc, getsource, signature) and __qualname__/__module__/__doc__ for getfile."
  created_at: "2026-04-12T00:00:00Z"

table inspect_extra646.classification_doc_types:
  description: "Verify that inspect classification and introspection functions have __doc__ of type str"
  kind: python_call_eq
  category: doc_type
  id_prefix: in646fn
  columns: [id, function, args, expected]
  rows:
    - [in646fn001, inspect.ismodule.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in646fn002, inspect.isclass.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in646fn003, inspect.ismethod.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in646fn004, inspect.isfunction.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in646fn005, inspect.isgeneratorfunction.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in646fn006, inspect.iscoroutinefunction.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in646fn007, inspect.getmembers.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in646fn008, inspect.getdoc.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in646fn009, inspect.getsource.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [in646fn010, inspect.signature.__doc__.__class__.__name__.__eq__, ["str"], true]

table inspect_extra646.getfile_identity:
  description: "Verify inspect.getfile __qualname__, __module__, and __doc__ type"
  kind: python_call_eq
  category: function_identity
  id_prefix: in646qn
  columns: [id, function, args, expected]
  rows:
    - [in646qn001, inspect.getfile.__qualname__.__eq__, ["getfile"], true]
    - [in646qn002, inspect.getfile.__module__.__eq__, ["inspect"], true]
    - [in646qn003, inspect.getfile.__doc__.__class__.__name__.__eq__, ["str"], true]
