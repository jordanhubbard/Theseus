spec: asyncio_extra13
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Futures"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "https://docs.python.org/3/library/asyncio-stream.html — asyncio Streams"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_events.zspec.zsdl, asyncio_extra.zspec.zsdl through asyncio_extra12.zspec.zsdl."
    - "asyncio_extra12 covers: Task method __qualname__ (cancel/result/done/cancelled); Future method __qualname__ (cancel/result/done/cancelled/running/exception); Task/Future/Lock/Queue __class__.__name__ == 'type'."
    - "asyncio_extra11 covers: Lock/Semaphore/Event/BoundedSemaphore/Condition/Queue __bases__[0].__name__; Queue method __qualname__ (put_nowait/get_nowait/empty/full/qsize); Lock/Semaphore acquire/release __qualname__."
    - "asyncio_extra10 covers: QueueEmpty/QueueFull/CancelledError/TimeoutError __qualname__; run/wait/shield/wait_for __name__/__module__."
    - "asyncio_extra9 covers: CancelledError/TimeoutError/IncompleteReadError __bases__[0].__name__; PriorityQueue/LifoQueue __bases__[0].__name__; Condition/BoundedSemaphore/PriorityQueue/LifoQueue __module__."
    - "asyncio_extra8 covers: Task/Future/Event __module__; Task/Future/QueueEmpty/QueueFull __bases__[0].__name__; PriorityQueue/LifoQueue __name__ standalone."
    - "asyncio_extra7 covers: IncompleteReadError/__qualname__; PriorityQueue/__qualname__; LifoQueue/__qualname__; LimitOverrunError/__qualname__."
    - "asyncio_extra covers: StreamReader/__name__/__module__; StreamWriter/__name__/__module__; IncompleteReadError/__name__/__module__."
    - "NOT yet covered in any prior spec: Task.get_name.__qualname__ == 'Task.get_name'."
    - "NOT yet covered: Task.set_name.__qualname__ == 'Task.set_name'."
    - "NOT yet covered: Task.add_done_callback.__qualname__ == 'Task.add_done_callback'."
    - "NOT yet covered: StreamReader.__qualname__ == 'StreamReader'."
    - "NOT yet covered: StreamWriter.__qualname__ == 'StreamWriter'."
    - "NOT yet covered: StreamReader.__class__.__name__ == 'type'."
    - "NOT yet covered: StreamWriter.__class__.__name__ == 'type'."
    - "NOT yet covered: LifoQueue.__class__.__name__ == 'type'."
    - "NOT yet covered: PriorityQueue.__class__.__name__ == 'type'."
    - "NOT yet covered: BoundedSemaphore.__class__.__name__ == 'type'."
    - "NOT yet covered: Condition.__class__.__name__ == 'type'."
    - "NOT yet covered: Event.__class__.__name__ == 'type'."
    - "NOT yet covered: LimitOverrunError.__bases__[0].__name__ == 'Exception' — LimitOverrunError MRO."
    - "NOT yet covered: LimitOverrunError.__class__.__name__ == 'type'."
    - "NOT yet covered: IncompleteReadError.__class__.__name__ == 'type'."
    - "asyncio.Task.get_name.__qualname__ == 'Task.get_name' — method defined on Task."
    - "asyncio.Task.set_name.__qualname__ == 'Task.set_name' — method defined on Task."
    - "asyncio.Task.add_done_callback.__qualname__ == 'Task.add_done_callback' — overrides Future.add_done_callback."
    - "asyncio.StreamReader.__qualname__ == 'StreamReader' — top-level class in asyncio.streams."
    - "asyncio.StreamWriter.__qualname__ == 'StreamWriter' — top-level class in asyncio.streams."
    - "asyncio.StreamReader.__class__.__name__ == 'type'."
    - "asyncio.StreamWriter.__class__.__name__ == 'type'."
    - "asyncio.LifoQueue.__class__.__name__ == 'type'."
    - "asyncio.PriorityQueue.__class__.__name__ == 'type'."
    - "asyncio.BoundedSemaphore.__class__.__name__ == 'type'."
    - "asyncio.Condition.__class__.__name__ == 'type'."
    - "asyncio.Event.__class__.__name__ == 'type'."
    - "asyncio.LimitOverrunError.__bases__[0].__name__ == 'Exception'."
    - "asyncio.LimitOverrunError.__class__.__name__ == 'type'."
    - "asyncio.IncompleteReadError.__class__.__name__ == 'type'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Task additional method __qualname__
#
# asyncio_extra12 covers Task.cancel/result/done/cancelled __qualname__.
# No prior asyncio spec checks __qualname__ for Task.get_name, Task.set_name,
# or Task.add_done_callback. These are defined in asyncio/tasks.py on Task.
# Task.add_done_callback overrides Future.add_done_callback, so its
# __qualname__ is 'Task.add_done_callback' (not 'Future.add_done_callback').
# ---------------------------------------------------------------------------

table asyncio_extra13.Task_extra_method_qualnames:
  description: "asyncio.Task additional methods have __qualname__ == 'Task.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: tskexqname

  columns: [id, function, args, expected]
  rows:
    - [get_name,          Task.get_name.__qualname__.__eq__,          ["Task.get_name"],          true]
    - [set_name,          Task.set_name.__qualname__.__eq__,          ["Task.set_name"],          true]
    - [add_done_callback, Task.add_done_callback.__qualname__.__eq__, ["Task.add_done_callback"], true]

# ---------------------------------------------------------------------------
# StreamReader and StreamWriter __qualname__
#
# asyncio_extra covers StreamReader/__name__ and StreamWriter/__name__.
# No prior asyncio spec checks __qualname__ for either class.
# Both are defined at module scope in asyncio.streams, so
# __qualname__ == __name__ for both.
# ---------------------------------------------------------------------------

invariant asyncio_extra13.StreamReader.qualname:
  description: "asyncio.StreamReader.__qualname__ == 'StreamReader'"
  category: class_names
  kind: python_call_eq
  function: StreamReader.__qualname__.__eq__
  args: ["StreamReader"]
  expected: true

invariant asyncio_extra13.StreamWriter.qualname:
  description: "asyncio.StreamWriter.__qualname__ == 'StreamWriter'"
  category: class_names
  kind: python_call_eq
  function: StreamWriter.__qualname__.__eq__
  args: ["StreamWriter"]
  expected: true

# ---------------------------------------------------------------------------
# Class-level __class__.__name__ — metaclass checks for sync primitives,
# queue subclasses, and stream classes
#
# asyncio_extra12 covers Task/Future/Lock/Queue __class__.__name__.
# No prior asyncio spec checks the metaclass for BoundedSemaphore, Condition,
# Event, LifoQueue, PriorityQueue, StreamReader, or StreamWriter.
# ---------------------------------------------------------------------------

table asyncio_extra13.class_metaclass_names:
  description: "asyncio classes have __class__.__name__ == 'type' — plain Python classes"
  kind: python_call_eq
  category: class_types
  id_prefix: asynciocmeta

  columns: [id, function, args, expected]
  rows:
    - [BoundedSemaphore, BoundedSemaphore.__class__.__name__.__eq__, ["type"], true]
    - [Condition,        Condition.__class__.__name__.__eq__,        ["type"], true]
    - [Event,            Event.__class__.__name__.__eq__,            ["type"], true]
    - [LifoQueue,        LifoQueue.__class__.__name__.__eq__,        ["type"], true]
    - [PriorityQueue,    PriorityQueue.__class__.__name__.__eq__,    ["type"], true]
    - [StreamReader,     StreamReader.__class__.__name__.__eq__,     ["type"], true]
    - [StreamWriter,     StreamWriter.__class__.__name__.__eq__,     ["type"], true]

# ---------------------------------------------------------------------------
# LimitOverrunError class identity
#
# asyncio_extra7 covers LimitOverrunError.__qualname__. asyncio_extra covers
# LimitOverrunError.__name__ and __module__ (via IncompleteReadError module
# check — both live in asyncio.exceptions). No prior spec checks
# LimitOverrunError.__bases__[0].__name__ or __class__.__name__.
# LimitOverrunError inherits directly from Exception (not EOFError like
# IncompleteReadError), so its base is 'Exception'.
# ---------------------------------------------------------------------------

invariant asyncio_extra13.LimitOverrunError.base:
  description: "asyncio.LimitOverrunError.__bases__[0].__name__ == 'Exception'"
  category: class_hierarchy
  kind: python_call_eq
  function: LimitOverrunError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant asyncio_extra13.LimitOverrunError.metaclass:
  description: "asyncio.LimitOverrunError.__class__.__name__ == 'type'"
  category: class_types
  kind: python_call_eq
  function: LimitOverrunError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant asyncio_extra13.IncompleteReadError.metaclass:
  description: "asyncio.IncompleteReadError.__class__.__name__ == 'type'"
  category: class_types
  kind: python_call_eq
  function: IncompleteReadError.__class__.__name__.__eq__
  args: ["type"]
  expected: true
