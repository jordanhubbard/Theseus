spec: httpretty_rust
version: ">=3.9"
backend: rust_module(httpretty_rust)

docs: https://httpretty.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://httpretty.readthedocs.io/en/latest/ — HTTPretty documentation"
  not_derived_from:
    - "httpretty source: httpretty/__init__.py"
  notes:
    - "HTTPretty is an HTTP request mock tool for Python."
    - "httpretty.HTTPretty is available."
    - "httpretty.GET == 'GET'."
    - "httpretty.POST == 'POST'."
    - "httpretty.PUT == 'PUT'."
    - "Expose httpretty_get_method() -> str: httpretty.GET."
    - "Expose httpretty_post_method() -> str: httpretty.POST."
    - "Expose httpretty_has_httpretty() -> bool: hasattr(httpretty, 'HTTPretty')."
    - "All test vectors verified against httpretty 1.0.5."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# httpretty_get_method — GET constant
invariant httpretty_rust.methods.get:
  description: "httpretty.GET == 'GET'"
  category: methods
  kind: python_call_eq
  function: httpretty_get_method
  args: []
  expected: "GET"

# httpretty_post_method — POST constant
invariant httpretty_rust.methods.post:
  description: "httpretty.POST == 'POST'"
  category: methods
  kind: python_call_eq
  function: httpretty_post_method
  args: []
  expected: "POST"

# httpretty_has_httpretty — HTTPretty class present
invariant httpretty_rust.module.has_httpretty:
  description: "httpretty.HTTPretty is available"
  category: module
  kind: python_call_eq
  function: httpretty_has_httpretty
  args: []
  expected: true

