spec: cmath_extra4
version: ">=3.9"
backend: python_module(cmath)

docs: https://docs.python.org/3/library/cmath.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmath.html — Python cmath documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/cmathmodule.c"
  notes:
    - "This spec extends cmath.zspec.zsdl, cmath_extra.zspec.zsdl, cmath_extra2.zspec.zsdl, and cmath_extra3.zspec.zsdl."
    - "cmath.zspec: isfinite/isinf/isnan/isclose predicates; phase(1.0/-1.0/0.0); polar(5.0); sqrt; exp; log; constants pi/e/tau."
    - "cmath_extra: constant type checks; __name__ for all major functions."
    - "cmath_extra2: __module__ for phase; polar(1.0); rect(1.0,0.0); integer predicate inputs; function __name__ table."
    - "cmath_extra3: __qualname__ table for all functions; __class__.__name__ for constants."
    - "No prior spec covers cmath.sin(0).real == 0.0 or cmath.sin(0).imag == 0.0."
    - "No prior spec covers cmath.cos(0).real == 1.0 or cmath.cos(0).imag == -0.0."
    - "No prior spec covers cmath.tan(0).real == 0.0 or cmath.tan(0).imag == 0.0."
    - "No prior spec covers cmath.sqrt(0).real == 0.0 or cmath.sqrt(0).imag == 0.0."
    - "No prior spec covers cmath.tau > 6.28 or < 6.29 as value bounds (only type was covered)."
    - "No prior spec covers cmath.log(1+0j).real == 0.0 or .imag == 0.0 as zero-input check."
    - "No prior spec covers cmath.infj.real == 0.0 or cmath.nanj.real == 0.0 as value vectors."
    - "cmath.sin(0).real == 0.0 — sin of zero has zero real part."
    - "cmath.cos(0).real == 1.0 — cos of zero has unit real part."
    - "cmath.tan(0).real == 0.0 — tan of zero has zero real part."
    - "cmath.sqrt(0).real == 0.0 — sqrt of zero is zero."
    - "cmath.tau > 6.28 and < 6.29 — tau = 2*pi, bounds check on value."
    - "cmath.log(1+0j).real == 0.0 — log of 1+0j is 0+0j."
    - "cmath.infj.real == 0.0 — infj is 0+infj, real part is zero."
    - "cmath.nanj.real == 0.0 — nanj is 0+nanj, real part is zero."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cmath.sin(0) — real and imaginary components at zero
#
# cmath.zspec and cmath_extra cover sin.__name__. No prior spec covers
# sin value vectors. sin(0) == 0+0j, so real == 0.0 and imag == 0.0.
# ---------------------------------------------------------------------------

invariant cmath_extra4.sin.zero_real:
  description: "cmath.sin(0).real == 0.0 — sin of zero has zero real part"
  category: trig
  kind: python_call_eq
  function: sin
  args: [0]
  method: real
  expected: 0.0

invariant cmath_extra4.sin.zero_imag:
  description: "cmath.sin(0).imag == 0.0 — sin of zero has zero imaginary part"
  category: trig
  kind: python_call_eq
  function: sin
  args: [0]
  method: imag
  expected: 0.0

# ---------------------------------------------------------------------------
# cmath.cos(0) — real and imaginary components at zero
#
# cos(0) == 1+0j, so real == 1.0 and imag == -0.0 (negative zero, equal to 0.0).
# No prior spec covers cos value vectors.
# ---------------------------------------------------------------------------

invariant cmath_extra4.cos.zero_real:
  description: "cmath.cos(0).real == 1.0 — cos of zero has unit real part"
  category: trig
  kind: python_call_eq
  function: cos
  args: [0]
  method: real
  expected: 1.0

# ---------------------------------------------------------------------------
# cmath.tan(0) — real component at zero
#
# tan(0) == 0+0j. No prior spec covers tan value vectors at all.
# cmath_extra covers tan.__name__.
# ---------------------------------------------------------------------------

invariant cmath_extra4.tan.zero_real:
  description: "cmath.tan(0).real == 0.0 — tan of zero has zero real part"
  category: trig
  kind: python_call_eq
  function: tan
  args: [0]
  method: real
  expected: 0.0

invariant cmath_extra4.tan.zero_imag:
  description: "cmath.tan(0).imag == 0.0 — tan of zero has zero imaginary part"
  category: trig
  kind: python_call_eq
  function: tan
  args: [0]
  method: imag
  expected: 0.0

# ---------------------------------------------------------------------------
# cmath.sqrt(0) — zero input
#
# cmath.zspec covers sqrt(4.0) and sqrt(-1.0). No prior spec covers sqrt(0).
# sqrt(0+0j) == 0+0j, so real == 0.0.
# ---------------------------------------------------------------------------

invariant cmath_extra4.sqrt.zero_real:
  description: "cmath.sqrt(0).real == 0.0 — sqrt of zero is zero"
  category: sqrt
  kind: python_call_eq
  function: sqrt
  args: [0]
  method: real
  expected: 0.0

invariant cmath_extra4.sqrt.zero_imag:
  description: "cmath.sqrt(0).imag == 0.0 — sqrt of zero has zero imaginary part"
  category: sqrt
  kind: python_call_eq
  function: sqrt
  args: [0]
  method: imag
  expected: 0.0

# ---------------------------------------------------------------------------
# cmath.tau — value bounds
#
# cmath_extra and cmath_extra3 check tau.__class__.__name__ == 'float'.
# cmath_extra4 (via tau.__eq__ row in cmath_extra2 table for 'tau') checks exact equality.
# No prior spec checks tau > 6.28 or < 6.29 as bounds in the cmath namespace.
# tau = 2*pi = 6.283185307179586.
# ---------------------------------------------------------------------------

invariant cmath_extra4.tau.gt_6_28:
  description: "cmath.tau > 6.28 — tau = 2*pi starts with 6.28..."
  category: constants
  kind: python_call_eq
  function: tau.__gt__
  args: [6.28]
  expected: true

invariant cmath_extra4.tau.lt_6_29:
  description: "cmath.tau < 6.29 — tau = 2*pi is less than 6.29"
  category: constants
  kind: python_call_eq
  function: tau.__lt__
  args: [6.29]
  expected: true

# ---------------------------------------------------------------------------
# cmath.log(1+0j) — zero-value check
#
# cmath.zspec covers log(1.0).real == 0.0 and log(1.0).imag == 0.0.
# No prior spec covers log with a complex input (1+0j instead of 1.0).
# log(1+0j) == 0+0j; real == 0.0 and imag == 0.0.
# ---------------------------------------------------------------------------

invariant cmath_extra4.log.one_complex_real:
  description: "cmath.log(1+0j).real == 0.0 — log of unit complex number has zero real"
  category: log
  kind: python_call_eq
  function: log
  args: [1]
  method: real
  expected: 0.0

invariant cmath_extra4.log.one_complex_imag:
  description: "cmath.log(1+0j).imag == 0.0 — log of unit complex number has zero imaginary"
  category: log
  kind: python_call_eq
  function: log
  args: [1]
  method: imag
  expected: 0.0

# ---------------------------------------------------------------------------
# cmath.infj — purely imaginary infinity constant components
#
# cmath_extra covers infj.__class__.__name__ == 'complex'.
# No prior spec covers infj.real == 0.0 or infj.imag as a float value check.
# cmath.infj is 0+infj: real part is 0.0, imaginary part is positive infinity.
# ---------------------------------------------------------------------------

invariant cmath_extra4.infj.real_is_zero:
  description: "cmath.infj.real == 0.0 — imaginary infinity constant has zero real part"
  category: constants
  kind: python_call_eq
  function: infj.real.__eq__
  args: [0.0]
  expected: true

invariant cmath_extra4.nanj.real_is_zero:
  description: "cmath.nanj.real == 0.0 — imaginary NaN constant has zero real part"
  category: constants
  kind: python_call_eq
  function: nanj.real.__eq__
  args: [0.0]
  expected: true
