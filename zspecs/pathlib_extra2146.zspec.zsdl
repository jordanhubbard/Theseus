spec: pathlib_extra2146
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "Wave extra2146, theme: numeric conversion protocol dict-presence."
    - "Checks __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in pathlib class __dict__."
    - "pathlib.Path, PurePath, PurePosixPath, PureWindowsPath represent filesystem paths, not numbers."
    - "None of the pathlib classes define any numeric conversion dunder in their own __dict__."
    - "All seven numeric protocol methods are absent from every checked pathlib class __dict__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Numeric conversion protocol — __trunc__, __floor__, __ceil__
# pathlib path types are filesystem abstractions; no rounding semantics.
# ---------------------------------------------------------------------------

table pathlib_extra2146.trunc_floor_ceil_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["pl2146001", "pathlib.PurePath.__dict__.__contains__",        ["__trunc__"], false]
    - ["pl2146002", "pathlib.PurePath.__dict__.__contains__",        ["__floor__"], false]
    - ["pl2146003", "pathlib.PurePath.__dict__.__contains__",        ["__ceil__"],  false]
    - ["pl2146004", "pathlib.PurePosixPath.__dict__.__contains__",   ["__trunc__"], false]
    - ["pl2146005", "pathlib.PurePosixPath.__dict__.__contains__",   ["__floor__"], false]
    - ["pl2146006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__ceil__"],  false]
    - ["pl2146007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__trunc__"], false]
    - ["pl2146008", "pathlib.PureWindowsPath.__dict__.__contains__", ["__floor__"], false]
    - ["pl2146009", "pathlib.PureWindowsPath.__dict__.__contains__", ["__ceil__"],  false]
    - ["pl2146010", "pathlib.Path.__dict__.__contains__",            ["__trunc__"], false]
    - ["pl2146011", "pathlib.Path.__dict__.__contains__",            ["__floor__"], false]
    - ["pl2146012", "pathlib.Path.__dict__.__contains__",            ["__ceil__"],  false]

# ---------------------------------------------------------------------------
# Numeric conversion protocol — __index__, __complex__, __bool__, __int__
# Path objects are not integers; no numeric identity or complex representation.
# __bool__ is notably absent — pathlib does not implement truthiness via __bool__.
# ---------------------------------------------------------------------------

table pathlib_extra2146.index_complex_bool_int_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["pl2146013", "pathlib.PurePath.__dict__.__contains__",        ["__index__"],   false]
    - ["pl2146014", "pathlib.PurePath.__dict__.__contains__",        ["__complex__"], false]
    - ["pl2146015", "pathlib.PurePath.__dict__.__contains__",        ["__bool__"],    false]
    - ["pl2146016", "pathlib.PurePath.__dict__.__contains__",        ["__int__"],     false]
    - ["pl2146017", "pathlib.PurePosixPath.__dict__.__contains__",   ["__index__"],   false]
    - ["pl2146018", "pathlib.PurePosixPath.__dict__.__contains__",   ["__complex__"], false]
    - ["pl2146019", "pathlib.PurePosixPath.__dict__.__contains__",   ["__bool__"],    false]
    - ["pl2146020", "pathlib.PurePosixPath.__dict__.__contains__",   ["__int__"],     false]
    - ["pl2146021", "pathlib.PureWindowsPath.__dict__.__contains__", ["__index__"],   false]
    - ["pl2146022", "pathlib.PureWindowsPath.__dict__.__contains__", ["__complex__"], false]
    - ["pl2146023", "pathlib.PureWindowsPath.__dict__.__contains__", ["__bool__"],    false]
    - ["pl2146024", "pathlib.PureWindowsPath.__dict__.__contains__", ["__int__"],     false]
    - ["pl2146025", "pathlib.Path.__dict__.__contains__",            ["__index__"],   false]
    - ["pl2146026", "pathlib.Path.__dict__.__contains__",            ["__complex__"], false]
    - ["pl2146027", "pathlib.Path.__dict__.__contains__",            ["__bool__"],    false]
    - ["pl2146028", "pathlib.Path.__dict__.__contains__",            ["__int__"],     false]
