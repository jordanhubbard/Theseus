spec: tiny_queue
version: ">=0.2.0"
backend: node(tiny-queue)

docs: https://github.com/avoidwork/tiny-queue#readme

provenance:
  derived_from:
    - "tiny-queue README — https://github.com/avoidwork/tiny-queue#readme"
    - "Test vectors verified with tiny-queue via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "tiny-queue source"
  notes:
    - "Minimal Queue class with O(1) enqueue/dequeue (linked-list + offset trick)."
    - "Install: npm install tiny-queue"
    - "v0.2 CJS; module export IS the Queue class."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure data structure; no errors."
  stderr: "null"
  stickiness: "Each Queue instance owns its data."
  codes: {}

invariant tiny_queue.module_is_class:
  description: "Module export is a class (Function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant tiny_queue.class_name:
  description: "Class name is 'Queue'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: name}
  expected: "Queue"

invariant tiny_queue.proto_has_push:
  description: "Queue.prototype.push defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.push.constructor.name"}
  expected: "Function"

invariant tiny_queue.proto_has_shift:
  description: "Queue.prototype.shift defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.shift.constructor.name"}
  expected: "Function"

invariant tiny_queue.proto_has_slice:
  description: "Queue.prototype.slice defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.slice.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:38:48Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
