spec: abc_extra129
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py, Modules/_abc.c"
  notes:
    - "This spec covers: wave 257 theme — abc.update_abstractmethods function code object attributes, and abc.ABCMeta class identity. NEW in extra129: abc.update_abstractmethods.__qualname__=='update_abstractmethods' (len=22); abc.update_abstractmethods.__module__=='abc' (len=3); abc.update_abstractmethods.__code__.co_argcount==1; abc.update_abstractmethods.__code__.co_varnames.__len__()==5; 'cls' in abc.update_abstractmethods.__code__.co_varnames; abc.ABCMeta.__name__=='ABCMeta' (len=7); abc.ABCMeta.__module__=='abc' (len=3); abc.ABCMeta.__bases__[0].__name__=='type'; abc.ABCMeta.__mro__.__len__()==3; abc.ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15); abc.ABCMeta.__new__.__code__.co_argcount==4; abc.ABC.__name__=='ABC' (len=3); abc.ABC.__module__=='abc'; abc.ABC.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.update_abstractmethods.__code__.co_varnames == ('cls', 'abstracts', 'scls', 'name', 'value') (length=5). The first variable 'cls' is the sole positional argument (co_argcount==1); the remaining 4 are local variables. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type'. ABCMeta is a metaclass that inherits from type, giving MRO=[ABCMeta, type, object] (length=3). This allows ABCMeta to customize class creation for abstract base classes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.update_abstractmethods.__module__ == 'abc' (len=3). This is a pure Python function defined in Lib/abc.py, unlike abc.get_cache_token which is a builtin defined in Modules/_abc.c with __module__=='_abc'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.update_abstractmethods code object attributes — extra129
#
# Wave 257 theme: abc.update_abstractmethods code object and abc.ABCMeta identity.
#
# abc.update_abstractmethods.__qualname__                       == 'update_abstractmethods' (len=22)
# abc.update_abstractmethods.__module__                         == 'abc'                    (len=3)
# abc.update_abstractmethods.__code__.co_argcount               == 1
# abc.update_abstractmethods.__code__.co_varnames.__len__()     == 5
# abc.update_abstractmethods.__code__.co_varnames.__contains__('cls') == True
# ---------------------------------------------------------------------------

table abc_extra129.abc_update_abstractmethods_code_attrs:
  description: "abc.update_abstractmethods code object attribute checks in abcuam129 namespace — wave 257 theme: update_abstractmethods code object; update_abstractmethods.__qualname__.__eq__('update_abstractmethods')==True (len=22: 22 chars in 'update_abstractmethods'); update_abstractmethods.__module__.__eq__('abc')==True (len=3: pure Python function defined in Lib/abc.py, not in the C extension _abc); update_abstractmethods.__code__.co_argcount==1 (sole parameter is 'cls', the class whose abstract methods are to be updated); update_abstractmethods.__code__.co_varnames.__len__()==5 (co_varnames=('cls', 'abstracts', 'scls', 'name', 'value') — 1 parameter + 4 local variables); update_abstractmethods.__code__.co_varnames.__contains__('cls')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcuam129

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,        abc.update_abstractmethods.__qualname__.__eq__,                         ["update_abstractmethods"], true, "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' (len=22); verified with Python 3.14.3"]
    - [qn_len,       abc.update_abstractmethods.__qualname__.__len__,                        [],                        22,   "abc.update_abstractmethods.__qualname__.__len__() == 22; verified with Python 3.14.3"]
    - [module_eq,    abc.update_abstractmethods.__module__.__eq__,                           ["abc"],                   true, "abc.update_abstractmethods.__module__ == 'abc' (len=3, pure Python in Lib/abc.py); verified with Python 3.14.3"]
    - [module_len,   abc.update_abstractmethods.__module__.__len__,                          [],                        3,    "abc.update_abstractmethods.__module__.__len__() == 3 ('abc'=3); verified with Python 3.14.3"]
    - [co_argc,      abc.update_abstractmethods.__code__.co_argcount.__eq__,                 [1],                       true, "abc.update_abstractmethods.__code__.co_argcount == 1 (sole param: cls); verified with Python 3.14.3"]
    - [co_vars_len,  abc.update_abstractmethods.__code__.co_varnames.__len__,                [],                        5,    "abc.update_abstractmethods.__code__.co_varnames.__len__() == 5 — ('cls', 'abstracts', 'scls', 'name', 'value'); verified with Python 3.14.3"]
    - [co_vars_cls,  abc.update_abstractmethods.__code__.co_varnames.__contains__,           ["cls"],                   true, "abc.update_abstractmethods.__code__.co_varnames.__contains__('cls') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta class identity — extra129
#
# abc.ABCMeta.__name__                == 'ABCMeta'          (len=7)
# abc.ABCMeta.__module__              == 'abc'               (len=3)
# abc.ABCMeta.__qualname__            == 'ABCMeta'           (len=7)
# abc.ABCMeta.__bases__[0].__name__   == 'type'
# abc.ABCMeta.__mro__.__len__()       == 3
# abc.ABCMeta.__new__.__qualname__    == 'ABCMeta.__new__'   (len=15)
# abc.ABCMeta.__new__.__code__.co_argcount == 4
# ---------------------------------------------------------------------------

table abc_extra129.abc_abcmeta_class_identity:
  description: "abc.ABCMeta class identity checks in abcuam129 namespace — wave 257 theme: ABCMeta class identity; ABCMeta is a metaclass (its metaclass is type) with MRO=[ABCMeta, type, object] (len=3); ABCMeta.__name__.__eq__('ABCMeta')==True (len=7: 'ABC'=3+'Meta'=4); ABCMeta.__module__.__eq__('abc')==True (len=3); ABCMeta.__qualname__.__eq__('ABCMeta')==True (len=7, module-level class so qualname equals name); ABCMeta.__bases__[0].__name__.__eq__('type')==True (ABCMeta inherits from type to function as a metaclass); ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object]); ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__')==True (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7); ABCMeta.__new__.__code__.co_argcount==4 (mcs, name, bases, namespace); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcuam129a

  columns: [id, function, args, expected, description]
  rows:
    - [meta_name_eq,   abc.ABCMeta.__name__.__eq__,                       ["ABCMeta"],         true, "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [meta_name_len,  abc.ABCMeta.__name__.__len__,                      [],                  7,    "abc.ABCMeta.__name__.__len__() == 7 ('ABC'=3+'Meta'=4); verified with Python 3.14.3"]
    - [meta_module_eq, abc.ABCMeta.__module__.__eq__,                     ["abc"],             true, "abc.ABCMeta.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [meta_qn_eq,     abc.ABCMeta.__qualname__.__eq__,                   ["ABCMeta"],         true, "abc.ABCMeta.__qualname__ == 'ABCMeta' (len=7, module-level class); verified with Python 3.14.3"]
    - [meta_base0_eq,  "abc.ABCMeta.__bases__[0].__name__.__eq__",        ["type"],            true, "abc.ABCMeta.__bases__[0].__name__ == 'type' (ABCMeta subclasses type to be a metaclass); verified with Python 3.14.3"]
    - [meta_mro_len,   abc.ABCMeta.__mro__.__len__,                       [],                  3,    "abc.ABCMeta.__mro__.__len__() == 3 — [ABCMeta, type, object]; verified with Python 3.14.3"]
    - [new_qn_eq,      abc.ABCMeta.__new__.__qualname__.__eq__,           ["ABCMeta.__new__"], true, "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15); verified with Python 3.14.3"]
    - [new_qn_len,     abc.ABCMeta.__new__.__qualname__.__len__,          [],                  15,   "abc.ABCMeta.__new__.__qualname__.__len__() == 15 ('ABCMeta.__new__'=15: 'ABCMeta'=7+'.'=1+'__new__'=7); verified with Python 3.14.3"]
    - [new_argc,       abc.ABCMeta.__new__.__code__.co_argcount.__eq__,   [4],                 true, "abc.ABCMeta.__new__.__code__.co_argcount == 4 (mcs, name, bases, namespace); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC and abc.abstractmethod identity — extra129
#
# abc.ABC.__name__              == 'ABC'              (len=3)
# abc.ABC.__module__            == 'abc'              (len=3)
# abc.ABC.__qualname__          == 'ABC'              (len=3)
# abc.ABC.__bases__[0].__name__ == 'object'
# abc.ABC.__mro__.__len__()     == 2
# abc.abstractmethod.__name__   == 'abstractmethod'   (len=14)
# abc.abstractmethod.__module__ == 'abc'              (len=3)
# abc.abstractmethod.__qualname__ == 'abstractmethod' (len=14)
# ---------------------------------------------------------------------------

table abc_extra129.abc_abc_and_abstractmethod_identity:
  description: "abc.ABC and abc.abstractmethod identity checks in abcuam129 namespace — wave 257 theme: ABC and abstractmethod identity; ABC is a helper class using ABCMeta as its metaclass; ABC.__name__.__eq__('ABC')==True (len=3, shortest name in the abc module); ABC.__module__.__eq__('abc')==True (len=3); ABC.__bases__[0].__name__.__eq__('object')==True (ABC directly inherits from object); ABC.__mro__.__len__()==2 ([ABC, object], shallow hierarchy); abstractmethod is a function (not a class in CPython 3.14) that sets __isabstractmethod__=True on the decorated callable; abstractmethod.__name__.__eq__('abstractmethod')==True (len=14); abstractmethod.__module__.__eq__('abc')==True (len=3); abstractmethod.__qualname__.__eq__('abstractmethod')==True (len=14, module-level so qualname equals name); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcuam129b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,    abc.ABC.__name__.__eq__,                    ["ABC"],             true, "abc.ABC.__name__ == 'ABC' (len=3); verified with Python 3.14.3"]
    - [abc_name_len,   abc.ABC.__name__.__len__,                   [],                  3,    "abc.ABC.__name__.__len__() == 3 ('ABC'=3); verified with Python 3.14.3"]
    - [abc_module_eq,  abc.ABC.__module__.__eq__,                  ["abc"],             true, "abc.ABC.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [abc_base0_eq,   "abc.ABC.__bases__[0].__name__.__eq__",     ["object"],          true, "abc.ABC.__bases__[0].__name__ == 'object' (ABC directly inherits from object); verified with Python 3.14.3"]
    - [abc_mro_len,    abc.ABC.__mro__.__len__,                    [],                  2,    "abc.ABC.__mro__.__len__() == 2 — [ABC, object]; verified with Python 3.14.3"]
    - [am_name_eq,     abc.abstractmethod.__name__.__eq__,         ["abstractmethod"],  true, "abc.abstractmethod.__name__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [am_name_len,    abc.abstractmethod.__name__.__len__,        [],                  14,   "abc.abstractmethod.__name__.__len__() == 14 ('abstractmethod'=14); verified with Python 3.14.3"]
    - [am_module_eq,   abc.abstractmethod.__module__.__eq__,       ["abc"],             true, "abc.abstractmethod.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [am_qn_eq,       abc.abstractmethod.__qualname__.__eq__,     ["abstractmethod"],  true, "abc.abstractmethod.__qualname__ == 'abstractmethod' (len=14, module-level function); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra129
# ---------------------------------------------------------------------------

invariant abc_extra129.update_abstractmethods_qualname_len_22:
  description: "abc.update_abstractmethods.__qualname__.__len__() == 22 — abc.update_abstractmethods.__qualname__ is 'update_abstractmethods' (22 chars); this is the longest qualname among abc module functions: 'update_abstractmethods'=22 > 'abstractmethod'=14 (the function); update_abstractmethods was added in Python 3.10 to enable updating a class's set of abstract methods after the class is created; update_abstractmethods.__code__.co_argcount is 1 (sole parameter: 'cls'); update_abstractmethods.__module__ is 'abc' (len=3, pure Python, not the C _abc extension); NEW in extra129: first standalone update_abstractmethods qualname length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__qualname__.__len__
  args: []
  expected: 22

invariant abc_extra129.update_abstractmethods_co_varnames_len_5:
  description: "abc.update_abstractmethods.__code__.co_varnames.__len__() == 5 — co_varnames is ('cls', 'abstracts', 'scls', 'name', 'value') (5 items); the first variable 'cls' is the sole function parameter (co_argcount==1); the remaining 4 ('abstracts', 'scls', 'name', 'value') are local variables used within the function body; co_varnames.__contains__('cls') is True; update_abstractmethods.__qualname__ is 'update_abstractmethods' (len=22); update_abstractmethods.__module__ is 'abc' (len=3); NEW in extra129: first standalone update_abstractmethods co_varnames length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__code__.co_varnames.__len__
  args: []
  expected: 5

invariant abc_extra129.ABCMeta_mro_len_3:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — ABCMeta's MRO is [ABCMeta, type, object] (length=3); ABCMeta inherits from type because it is a metaclass — instances of ABCMeta are themselves classes, just as instances of type are classes; ABCMeta.__bases__[0].__name__ is 'type'; ABCMeta.__name__.__len__() is 7 ('ABCMeta'=7); ABCMeta.__module__ is 'abc' (len=3); ABCMeta.__new__.__qualname__ is 'ABCMeta.__new__' (len=15); ABCMeta.__new__.__code__.co_argcount is 4; NEW in extra129: first standalone ABCMeta MRO length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra129.ABCMeta_new_qualname_len_15:
  description: "abc.ABCMeta.__new__.__qualname__.__len__() == 15 — ABCMeta.__new__.__qualname__ is 'ABCMeta.__new__' (15 chars: 'ABCMeta'=7 + '.'=1 + '__new__'=7 = 15); ABCMeta.__new__.__code__.co_argcount is 4 (mcs, name, bases, namespace) — it receives the metaclass itself as the first argument (mcs) rather than an instance (self); this is the standard signature for metaclass __new__ methods; ABCMeta.__new__.__qualname__.__len__()==15 equals 'ABCMeta'=7 + '.'=1 + '__new__'=7; ABCMeta.__module__ is 'abc' (len=3); NEW in extra129: first standalone ABCMeta.__new__ qualname length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__qualname__.__len__
  args: []
  expected: 15

invariant abc_extra129.ABC_mro_len_2:
  description: "abc.ABC.__mro__.__len__() == 2 — abc.ABC's MRO is [ABC, object] (length=2); ABC is a helper class defined in Lib/abc.py using ABCMeta as its metaclass via 'class ABC(metaclass=ABCMeta): pass'; ABC directly inherits from object and has no intermediate base classes; ABC.__bases__[0].__name__ is 'object'; ABC.__name__.__len__() is 3 ('ABC'=3); ABC.__module__ is 'abc' (len=3); the shallow MRO contrasts with ABCMeta's own MRO (len=3: [ABCMeta, type, object]); subclasses of ABC will typically have ABC in their MRO followed by object; NEW in extra129: first standalone ABC MRO length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__mro__.__len__
  args: []
  expected: 2
