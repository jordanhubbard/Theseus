spec: functools_extra1066
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks cached_property descriptor qualnames (__set_name__, __get__, __set__, __delete__), singledispatch method qualnames (register, dispatch), wraps qualname preservation via __wrapped__, and reduce with initializer"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1066.cached_property_method_qualnames:
  description: "functools.cached_property descriptor method __qualname__ identity checks"
  kind: python_call_eq
  category: cached_property_qualnames
  id_prefix: ft1066cp
  columns: [id, function, args, expected]
  rows:
    - [ft1066cp001, functools.cached_property.__set_name__.__qualname__.__eq__,  ["cached_property.__set_name__"],  true]
    - [ft1066cp002, functools.cached_property.__get__.__qualname__.__eq__,       ["cached_property.__get__"],       true]
    - [ft1066cp003, functools.cached_property.__set__.__qualname__.__eq__,       ["cached_property.__set__"],       true]
    - [ft1066cp004, functools.cached_property.__delete__.__qualname__.__eq__,    ["cached_property.__delete__"],    true]
    - [ft1066cp005, functools.cached_property.__init__.__qualname__.__eq__,      ["cached_property.__init__"],      true]
    - [ft1066cp006, functools.cached_property.__set_name__.__module__.__eq__,    ["functools"],                     true]
    - [ft1066cp007, functools.cached_property.__get__.__module__.__eq__,         ["functools"],                     true]
    - [ft1066cp008, functools.cached_property.__init__.__module__.__eq__,        ["functools"],                     true]

table functools_extra1066.singledispatch_method_qualnames:
  description: "functools.singledispatch decorator method __qualname__ identity checks for register and dispatch"
  kind: python_call_eq
  category: singledispatch_method_qualnames
  id_prefix: ft1066sd
  columns: [id, function, args, expected]
  rows:
    - [ft1066sd001, functools.singledispatch.__qualname__.__eq__,                        ["singledispatch"],                   true]
    - [ft1066sd002, functools.singledispatch.__module__.__eq__,                          ["functools"],                        true]
    - [ft1066sd003, functools.singledispatch.__class__.__name__.__eq__,                  ["function"],                         true]
    - [ft1066sd004, functools.singledispatchmethod.__qualname__.__eq__,                  ["singledispatchmethod"],              true]
    - [ft1066sd005, functools.singledispatchmethod.__module__.__eq__,                    ["functools"],                        true]
    - [ft1066sd006, functools.singledispatchmethod.__class__.__name__.__eq__,            ["type"],                             true]
    - [ft1066sd007, functools.singledispatchmethod.__init__.__qualname__.__eq__,         ["singledispatchmethod.__init__"],     true]
    - [ft1066sd008, functools.singledispatchmethod.register.__qualname__.__eq__,         ["singledispatchmethod.register"],     true]

table functools_extra1066.reduce_with_initializer_and_wraps:
  description: "functools.reduce initializer behavior and functools.wraps __wrapped__ qualname preservation"
  kind: python_call_eq
  category: reduce_and_wraps
  id_prefix: ft1066rw
  columns: [id, function, args, expected]
  rows:
    - [ft1066rw001, functools.reduce.__qualname__.__eq__,             ["reduce"],                        true]
    - [ft1066rw002, functools.reduce.__doc__.__class__.__name__.__eq__, ["str"],                         true]
    - [ft1066rw003, functools.wraps.__qualname__.__eq__,               ["wraps"],                        true]
    - [ft1066rw004, functools.wraps.__module__.__eq__,                 ["functools"],                    true]
    - [ft1066rw005, functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__, ["tuple"],                  true]
    - [ft1066rw006, functools.WRAPPER_UPDATES.__class__.__name__.__eq__,     ["tuple"],                  true]
    - [ft1066rw007, functools.update_wrapper.__qualname__.__eq__,      ["update_wrapper"],               true]
    - [ft1066rw008, functools.update_wrapper.__module__.__eq__,        ["functools"],                    true]
