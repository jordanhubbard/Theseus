spec: collections_extra_rust
version: ">=3.9"
backend: rust_module(collections_extra_rust)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — collections stdlib"
  notes:
    - "collections provides specialized container datatypes."
    - "collections.Counter(['a','b','a'])['a'] == 2."
    - "collections.deque([1,2,3]).popleft() == 1."
    - "collections.OrderedDict is a class."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant collections_extra_rust.counter_a:
  description: "Counter(['a','b','a'])['a'] == 2"
  category: counter
  kind: python_call_eq
  function: collections_extra_counter_a
  args: []
  expected: 2

invariant collections_extra_rust.deque_popleft:
  description: "deque([1,2,3]).popleft() == 1"
  category: deque
  kind: python_call_eq
  function: collections_extra_deque_popleft
  args: []
  expected: 1

invariant collections_extra_rust.has_ordered_dict:
  description: "collections.OrderedDict is a class"
  category: presence
  kind: python_call_eq
  function: collections_extra_has_ordered_dict
  args: []
  expected: true

