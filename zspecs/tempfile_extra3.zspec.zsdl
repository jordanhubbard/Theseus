spec: tempfile_extra3
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
  notes:
    - "This spec extends prior tempfile specs."
    - "Focus: class names and function names not yet covered."
    - "tempfile.NamedTemporaryFile.__name__ == 'NamedTemporaryFile'."
    - "tempfile.SpooledTemporaryFile.__name__ == 'SpooledTemporaryFile'."
    - "tempfile.TemporaryDirectory.__name__ == 'TemporaryDirectory'."
    - "tempfile.TemporaryFile.__name__ == 'TemporaryFile'."
    - "tempfile.mkstemp.__name__ == 'mkstemp'."
    - "tempfile.mkdtemp.__name__ == 'mkdtemp'."
    - "tempfile.gettempdir.__name__ == 'gettempdir'."
    - "tempfile.gettempprefix.__name__ == 'gettempprefix'."
    - "tempfile.gettempdir() returns a str."
    - "tempfile.gettempprefix() == 'tmp'."
    - "tempfile.tempdir is None (default) or a str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table tempfile_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [NamedTemporaryFile,   NamedTemporaryFile.__name__.__eq__,   ["NamedTemporaryFile"],   true]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__name__.__eq__, ["SpooledTemporaryFile"], true]
    - [TemporaryDirectory,   TemporaryDirectory.__name__.__eq__,   ["TemporaryDirectory"],   true]
    - [TemporaryFile,        TemporaryFile.__name__.__eq__,        ["TemporaryFile"],        true]

table tempfile_extra3.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [mkstemp,       mkstemp.__name__.__eq__,       ["mkstemp"],       true]
    - [mkdtemp,       mkdtemp.__name__.__eq__,       ["mkdtemp"],       true]
    - [gettempdir,    gettempdir.__name__.__eq__,    ["gettempdir"],    true]
    - [gettempprefix, gettempprefix.__name__.__eq__, ["gettempprefix"], true]
    - [mktemp,        mktemp.__name__.__eq__,        ["mktemp"],        true]

table tempfile_extra3.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [NamedTemporaryFile,   NamedTemporaryFile.__module__.__eq__,   ["tempfile"], true]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__module__.__eq__, ["tempfile"], true]
    - [TemporaryDirectory,   TemporaryDirectory.__module__.__eq__,   ["tempfile"], true]

invariant tempfile_extra3.gettempdir.returns_str:
  description: "tempfile.gettempdir().__class__.__name__ == 'str'"
  category: gettempdir
  kind: python_call_eq
  function: gettempdir
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant tempfile_extra3.gettempprefix.value:
  description: "tempfile.gettempprefix() == 'tmp'"
  category: gettempprefix
  kind: python_call_eq
  function: gettempprefix
  args: []
  expected: "tmp"

invariant tempfile_extra3.TemporaryDirectory.instance_class:
  description: "tempfile.TemporaryDirectory().__class__.__name__ == 'TemporaryDirectory'"
  category: TemporaryDirectory
  kind: python_call_eq
  function: TemporaryDirectory
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["TemporaryDirectory"]
  expected: true

invariant tempfile_extra3.SpooledTemporaryFile.instance_class:
  description: "tempfile.SpooledTemporaryFile().__class__.__name__ == 'SpooledTemporaryFile'"
  category: SpooledTemporaryFile
  kind: python_call_eq
  function: SpooledTemporaryFile
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["SpooledTemporaryFile"]
  expected: true
