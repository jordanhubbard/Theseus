    - [ppe_init_qn_len,   concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__,  [],                                28,   "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 ('ProcessPoolExecutor.__init__'=28); verified Python 3.14.3"]
