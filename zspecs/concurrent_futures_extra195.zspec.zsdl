table concurrent_futures_extra195.cf_ProcessPoolExecutor_init_submit_map:
  description: "concurrent.futures.ProcessPoolExecutor method qualname checks (__init__/submit/map) in cfpoolmethods195 namespace — ProcessPoolExecutor.__init__.__qualname__=='ProcessPoolExecutor.__init__' (len=28: 'ProcessPoolExecutor'=19+'.'=1+'__init__'=8=28; __init__ configures max_workers, mp_context, initializer, initargs, max_tasks_per_child); ProcessPoolExecutor.submit.__qualname__=='ProcessPoolExecutor.submit' (len=26: 'ProcessPoolExecutor'=19+'.'=1+'submit'=6=26; submit schedules a callable for execution and returns a Future); ProcessPoolExecutor.map.__qualname__=='ProcessPoolExecutor.map' (len=23: 'ProcessPoolExecutor'=19+'.'=1+'map'=3=23; ProcessPoolExecutor overrides Executor.map for better performance); __init__.__qualname__ (28) == shutdown.__qualname__ (28); map.__qualname__ (23) < submit.__qualname__ (26) < __init__.__qualname__ (28); verified with Python 3.14.3"
  kind: python_call_eq
  category: process_pool_methods
  id_prefix: cfpoolmethods195

  columns: [id, function, args, expected, description]
