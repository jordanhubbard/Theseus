table concurrent_futures_extra195.cf_pool_qualname_length_ordering:
  description: "concurrent.futures executor qualname length ordering in cfpoolmethods195 namespace — length ordering confirmed: ThreadPoolExecutor.map.__qualname__ (12: 'Executor.map' — inherited) < ProcessPoolExecutor.map.__qualname__ (23) < ProcessPoolExecutor.submit.__qualname__ (26) < ThreadPoolExecutor.__init__.__qualname__ (27) < ProcessPoolExecutor.__init__.__qualname__ (28) == ProcessPoolExecutor.shutdown.__qualname__ (28); ThreadPoolExecutor.map (12) is dramatically shorter than all others because it resolves to the base Executor class; ProcessPoolExecutor.__init__ and shutdown are tied at 28 because both method names (__init__, shutdown) are 8 characters; verified with Python 3.14.3"
  kind: python_call_eq
  category: length_ordering
  id_prefix: cfpoolmethods195

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_map_qn_len,    concurrent.futures.ThreadPoolExecutor.map.__qualname__.__len__,        [],   12,   "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__len__() == 12 ('Executor.map'=12; shortest — inherited from base Executor); verified Python 3.14.3"]
    - [ppe_map_qn_len,    concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__,       [],   23,   "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__len__() == 23 ('ProcessPoolExecutor.map'=23); verified Python 3.14.3"]
    - [ppe_init_qn_len2,  concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__,  [],   28,   "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 (longest tied with shutdown); verified Python 3.14.3"]
    - [tpe_init_qn_len2,  concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__,   [],   27,   "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__len__() == 27 (one less than ProcessPoolExecutor.__init__); verified Python 3.14.3"]
    - [ppe_submit_qn_len2, concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__len__,   [],   26,   "concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__len__() == 26 ('ProcessPoolExecutor.submit'=26); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra195
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra195.cf_PPE_init_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__('ProcessPoolExecutor.__init__') returns True — qualname=='ProcessPoolExecutor.__init__' (len=28: 'ProcessPoolExecutor'=19+'.'=1+'__init__'=8=28); ProcessPoolExecutor.__init__ accepts max_workers, mp_context, initializer, initargs, and max_tasks_per_child parameters; PPE.__init__.__qualname__ (28) == PPE.shutdown.__qualname__ (28) — both method names are 8 characters (__init__ and shutdown); PPE.__init__.__qualname__ (28) > TPE.__init__.__qualname__ (27) by 1; NEW in cfpoolmethods195: first standalone ProcessPoolExecutor.__init__ qualname invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: process_pool_methods
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__
  args: ["ProcessPoolExecutor.__init__"]
  expected: true

invariant concurrent_futures_extra195.cf_PPE_submit_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__eq__('ProcessPoolExecutor.submit') returns True — qualname=='ProcessPoolExecutor.submit' (len=26: 'ProcessPoolExecutor'=19+'.'=1+'submit'=6=26); submit(fn, *args, **kwargs) schedules fn to be executed and returns a Future representing the execution; PPE.submit.__qualname__ (26) < PPE.__init__.__qualname__ (28) by 2; PPE.submit.__qualname__ (26) > PPE.map.__qualname__ (23) by 3; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: process_pool_methods
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__eq__
  args: ["ProcessPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra195.cf_PPE_map_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__('ProcessPoolExecutor.map') returns True — qualname=='ProcessPoolExecutor.map' (len=23: 'ProcessPoolExecutor'=19+'.'=1+'map'=3=23); ProcessPoolExecutor overrides map() from the base Executor class for efficient subprocess-based mapping; PPE.map.__qualname__ (23) < PPE.submit.__qualname__ (26) by 3; PPE.map.__qualname__ (23) > TPE.map.__qualname__ (12: 'Executor.map') by 11 — TPE does not override map so its qualname reflects the base class; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: process_pool_methods
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__
  args: ["ProcessPoolExecutor.map"]
  expected: true

invariant concurrent_futures_extra195.cf_PPE_shutdown_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__eq__('ProcessPoolExecutor.shutdown') returns True — qualname=='ProcessPoolExecutor.shutdown' (len=28: 'ProcessPoolExecutor'=19+'.'=1+'shutdown'=8=28); shutdown(wait=True, cancel_futures=False) signals the executor to free resources; PPE.shutdown.__qualname__ (28) == PPE.__init__.__qualname__ (28) — tied as the longest qualname in this spec; PPE.shutdown.__qualname__ (28) > PPE.submit.__qualname__ (26) by 2; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: executor_methods
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__eq__
  args: ["ProcessPoolExecutor.shutdown"]
  expected: true

invariant concurrent_futures_extra195.cf_TPE_init_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__') returns True — qualname=='ThreadPoolExecutor.__init__' (len=27: 'ThreadPoolExecutor'=18+'.'=1+'__init__'=8=27); ThreadPoolExecutor.__init__ accepts max_workers, thread_name_prefix, initializer, and initargs; TPE.__init__.__qualname__ (27) < PPE.__init__.__qualname__ (28) by 1 — ThreadPoolExecutor is one character shorter than ProcessPoolExecutor; TPE.__init__.__qualname__ (27) > PPE.submit.__qualname__ (26) by 1; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: executor_methods
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__
  args: ["ThreadPoolExecutor.__init__"]
  expected: true

invariant concurrent_futures_extra195.cf_TPE_map_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__('Executor.map') returns True — qualname=='Executor.map' (len=12: 'Executor'=8+'.'=1+'map'=3=12); ThreadPoolExecutor does NOT override map() — it inherits the implementation from the base Executor class, so the __qualname__ reflects the defining class Executor, not ThreadPoolExecutor; TPE.map.__qualname__ (12: 'Executor.map') is the shortest qualname in this spec by a wide margin; TPE.map.__qualname__ (12) < PPE.map.__qualname__ (23) by 11 — PPE does override map; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: executor_methods
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra195.cf_PPE_init_len_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__() == 28 — 'ProcessPoolExecutor.__init__' has 28 characters ('ProcessPoolExecutor'=19+'.'=1+'__init__'=8=28); PPE.__init__.__qualname__ (28) == PPE.shutdown.__qualname__ (28) — both are tied as the longest qualnames in this spec because __init__ and shutdown are both exactly 8 characters; PPE.__init__.__qualname__ (28) > TPE.__init__.__qualname__ (27) by 1; confirmed via __len__; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: length_ordering
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__len__
  args: []
  expected: 28

invariant concurrent_futures_extra195.cf_TPE_map_len_shortest:
  description: "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__len__() == 12 — 'Executor.map' has 12 characters ('Executor'=8+'.'=1+'map'=3=12); TPE.map.__qualname__ (12) is the shortest qualname in this spec; the dramatic shortness compared to PPE.map (23) arises from inheritance — ThreadPoolExecutor does not override map(), so Python reports the defining class Executor; length ordering: Executor.map (12) < ProcessPoolExecutor.map (23) < ProcessPoolExecutor.submit (26) < ThreadPoolExecutor.__init__ (27) < ProcessPoolExecutor.__init__ (28) == ProcessPoolExecutor.shutdown (28); NEW in cfpoolmethods195: completing 8-invariant coverage for ProcessPoolExecutor and ThreadPoolExecutor method qualnames; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: length_ordering
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.map.__qualname__.__len__
  args: []
  expected: 12

