spec: concurrent_futures_extra195
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (len=28)."
    - "concurrent.futures.ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' (len=26)."
    - "concurrent.futures.ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23)."
    - "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (len=28)."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27)."
    - "concurrent.futures.ThreadPoolExecutor.map.__qualname__ == 'Executor.map' (len=12); map is inherited from the base Executor class."
    - "Length ordering: Executor.map (12) < ProcessPoolExecutor.map (23) < ProcessPoolExecutor.submit (26) < ThreadPoolExecutor.__init__ (27) < ProcessPoolExecutor.__init__ (28) == ProcessPoolExecutor.shutdown (28)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

