table concurrent_futures_extra195.cf_PPE_shutdown_TPE_init_map:
  description: "concurrent.futures executor shutdown and ThreadPoolExecutor qualname checks in cfpoolmethods195 namespace — ProcessPoolExecutor.shutdown.__qualname__=='ProcessPoolExecutor.shutdown' (len=28: 'ProcessPoolExecutor'=19+'.'=1+'shutdown'=8=28; shutdown waits for workers and frees resources); ThreadPoolExecutor.__init__.__qualname__=='ThreadPoolExecutor.__init__' (len=27: 'ThreadPoolExecutor'=18+'.'=1+'__init__'=8=27; TPE.__init__ configures the thread pool); ThreadPoolExecutor.map.__qualname__=='Executor.map' (len=12: 'Executor'=8+'.'=1+'map'=3=12; map is NOT overridden in ThreadPoolExecutor — it is inherited from the base Executor class, so qualname reflects Executor); TPE.map.__qualname__ (12) is the shortest in this spec; PPE.shutdown.__qualname__ (28) == PPE.__init__.__qualname__ (28); TPE.__init__.__qualname__ (27) < PPE.__init__.__qualname__ (28) by 1; verified with Python 3.14.3"
  kind: python_call_eq
  category: executor_methods
  id_prefix: cfpoolmethods195

  columns: [id, function, args, expected, description]
