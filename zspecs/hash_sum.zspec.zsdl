spec: hash_sum
version: ">=1.0.0"
backend: node(hash-sum)

docs: https://www.npmjs.com/package/hash-sum

provenance:
  derived_from:
    - "hash-sum README — https://www.npmjs.com/package/hash-sum"
    - "Test vectors verified with hash-sum via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "hash-sum source"
  notes:
    - "hash-sum is an npm package. Install: npm install hash-sum"
    - "hash(value) computes a short deterministic hash string for any JavaScript value."
    - "Works on strings, objects, arrays, and primitives."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns short hex hash string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table hash_sum.hash:
  kind: node_module_call_eq
  function: ~
  category: hash
  id_prefix: hsum

  columns: [id, args, expected]
  rows:
    - [string,  ["hello"],        "7769969c"]
    - [string2, ["world"],        "7841995c"]
    - [object,  [{"a": 1, "b": 2}], "32179f90"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:50:28Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
