spec: portfinder
version: ">=1.0.0"
backend: node(portfinder)

docs: https://github.com/http-party/node-portfinder#readme

provenance:
  derived_from:
    - "portfinder README — https://github.com/http-party/node-portfinder#readme"
    - "Test vectors verified with portfinder via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "portfinder source"
  notes:
    - "Find an unused TCP port in a range — used by dev servers and test harnesses."
    - "Install: npm install portfinder"
    - "v1 CJS; module export is an object with getPort / getPortPromise / getPorts / getSocket / setBasePort / setHighestPort / basePort / highestPort."
    - "Spec covers shape + default range constants only — actual port probing is environment-dependent."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Errors back via callback when no port is available; promise variant rejects."
  stderr: "null"
  stickiness: "basePort / highestPort are module-level globals."
  codes: {}

invariant portfinder.has_getPort:
  description: "getPort() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "getPort.constructor.name"}
  expected: "Function"

invariant portfinder.has_getPortPromise:
  description: "getPortPromise() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "getPortPromise.constructor.name"}
  expected: "Function"

invariant portfinder.has_getPorts:
  description: "getPorts() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "getPorts.constructor.name"}
  expected: "Function"

invariant portfinder.has_getSocket:
  description: "getSocket() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "getSocket.constructor.name"}
  expected: "Function"

invariant portfinder.has_setBasePort:
  description: "setBasePort() helper exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "setBasePort.constructor.name"}
  expected: "Function"

invariant portfinder.default_basePort_8000:
  description: "Default basePort is 8000"
  category: defaults
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: basePort}
  expected: 8000

invariant portfinder.default_highestPort_65535:
  description: "Default highestPort is 65535 (IANA TCP ceiling)"
  category: defaults
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: highestPort}
  expected: 65535

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:44:33Z
  iterations: 2
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 2 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
