spec: hashlib_extra245
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra230.zspec.zsdl — covers algorithms_guaranteed.__contains__ for 'md5' and 'sha256'; block_size and digest_size tables."
    - "hashlib_extra244.zspec.zsdl — covers sha256 HASH method __name__/__qualname__ tables; digest_size/block_size standalone invariants."
    - "hashlib_extra233.zspec.zsdl — covers HASH type __name__=='HASH'; method __name__ and __qualname__ standalone invariants."
  notes:
    - "This spec covers hashlib.algorithms_available set contracts — class identity, membership, and length."
    - "hashlib_extra230 covers algorithms_guaranteed.__contains__; this spec covers algorithms_available (the superset) in the extra245 namespace."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — algorithms_available is a plain set (mutable), not a frozenset like algorithms_guaranteed. Verified Python 3.14.3."
    - "hashlib.algorithms_available.__contains__('sha256') == True — sha256 is always available as it is also in algorithms_guaranteed. Verified Python 3.14.3."
    - "hashlib.algorithms_available.__contains__('md5') == True — md5 is always available. Verified Python 3.14.3."
    - "hashlib.algorithms_available.__contains__('sha1') == True — sha1 is available on this platform. Verified Python 3.14.3."
    - "hashlib.algorithms_available.__contains__('sha512') == True — sha512 is available on this platform. Verified Python 3.14.3."
    - "hashlib.algorithms_available.__len__() == 19 — 19 algorithms available on this platform (Python 3.14.3 macOS/Darwin 25.4.0)."
    - "len(hashlib.algorithms_available) > 5 — a portable lower-bound; every real Python installation has more than 5 algorithms available."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_available set class identity
#
# hashlib.algorithms_available.__class__.__name__ == 'set'
#
# algorithms_available is a mutable set (not frozenset) of all algorithm
# names supported by the running OpenSSL installation plus pure-Python
# implementations. On Python 3.14.3 macOS this set has 19 entries.
# ---------------------------------------------------------------------------

table hashlib_extra245.algorithms_available_class:
  description: "algorithms_available.__class__.__name__=='set'; algorithms_available is a mutable set; new to extra245"
  kind: python_call_eq
  category: identity
  id_prefix: hl245avail

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq_set,
       "algorithms_available.__class__.__name__.__eq__",
       ["set"],
       true,
       "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — algorithms_available is a plain mutable set (not frozenset); algorithms_guaranteed is a frozenset; this is the orthogonal dimension in extra245 namespace; verified Python 3.14.3"]
    - [class_name_len_3,
       "algorithms_available.__class__.__name__.__len__",
       [],
       3,
       "hashlib.algorithms_available.__class__.__name__.__len__() == 3 — len('set') == 3; class name length anchor; algorithms_available class is 'set' (3 characters); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available membership contracts
#
# sha256, md5, sha1, sha512 must all be present in algorithms_available.
# sha384 is also available. These are the core NIST/FIPS hash algorithms.
# All are also in algorithms_guaranteed, so they must be in algorithms_available
# (guaranteed is a subset of available by definition).
# ---------------------------------------------------------------------------

table hashlib_extra245.algorithms_available_membership:
  description: "algorithms_available contains sha256/md5/sha1/sha512/sha384; core NIST hash algorithms; new to extra245"
  kind: python_call_eq
  category: membership
  id_prefix: hl245avail

  columns: [id, function, args, expected, description]
  rows:
    - [contains_sha256,
       "algorithms_available.__contains__",
       ["sha256"],
       true,
       "hashlib.algorithms_available.__contains__('sha256') == True — sha256 is in algorithms_available; also in algorithms_guaranteed; FIPS 180-4 SHA-256; new anchor in extra245 namespace; verified Python 3.14.3"]
    - [contains_md5,
       "algorithms_available.__contains__",
       ["md5"],
       true,
       "hashlib.algorithms_available.__contains__('md5') == True — md5 is in algorithms_available; also in algorithms_guaranteed; RFC 1321 MD5; new anchor in extra245 namespace; verified Python 3.14.3"]
    - [contains_sha1,
       "algorithms_available.__contains__",
       ["sha1"],
       true,
       "hashlib.algorithms_available.__contains__('sha1') == True — sha1 is in algorithms_available; also in algorithms_guaranteed; FIPS 180-4 SHA-1; new anchor in extra245 namespace; verified Python 3.14.3"]
    - [contains_sha512,
       "algorithms_available.__contains__",
       ["sha512"],
       true,
       "hashlib.algorithms_available.__contains__('sha512') == True — sha512 is in algorithms_available; also in algorithms_guaranteed; FIPS 180-4 SHA-512; new anchor in extra245 namespace; verified Python 3.14.3"]
    - [contains_sha384,
       "algorithms_available.__contains__",
       ["sha384"],
       true,
       "hashlib.algorithms_available.__contains__('sha384') == True — sha384 is in algorithms_available; also in algorithms_guaranteed; FIPS 180-4 SHA-384; new anchor in extra245 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed membership (extra245 namespace anchors)
#
# algorithms_guaranteed is a frozenset; it is a subset of algorithms_available.
# These anchors confirm the guaranteed subset in the extra245 namespace.
# ---------------------------------------------------------------------------

table hashlib_extra245.algorithms_guaranteed_membership:
  description: "algorithms_guaranteed contains sha256/md5/sha1/sha512; guaranteed subset anchors in extra245 namespace"
  kind: python_call_eq
  category: membership
  id_prefix: hl245guar

  columns: [id, function, args, expected, description]
  rows:
    - [guar_contains_sha256,
       "algorithms_guaranteed.__contains__",
       ["sha256"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('sha256') == True — sha256 is guaranteed on all Python platforms; frozenset membership; extra245 namespace anchor (extra230 covers as standalone); verified Python 3.14.3"]
    - [guar_contains_md5,
       "algorithms_guaranteed.__contains__",
       ["md5"],
       true,
       "hashlib.algorithms_guaranteed.__contains__('md5') == True — md5 is guaranteed on all Python platforms; frozenset membership; extra245 namespace anchor; verified Python 3.14.3"]
    - [guar_class_name_eq_frozenset,
       "algorithms_guaranteed.__class__.__name__.__eq__",
       ["frozenset"],
       true,
       "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('frozenset') == True — algorithms_guaranteed is a frozenset (immutable); algorithms_available is a plain set (mutable); this distinction is the key novelty of extra245; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra245.algorithms_available_class_name:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — algorithms_available is a plain mutable set in Python 3.14.3; this is distinct from algorithms_guaranteed which is a frozenset; the set stores all OpenSSL-backed and pure-Python hash algorithm name strings available in the current Python installation; on macOS/Darwin 25.4.0 with Python 3.14.3 the set contains 19 entries; algorithms_guaranteed is the portable subset; extra245 is the first namespace to anchor algorithms_available class identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "algorithms_available.__class__.__name__.__eq__"
  args: ["set"]
  expected: true

invariant hashlib_extra245.algorithms_available_contains_sha256:
  description: "hashlib.algorithms_available.__contains__('sha256') == True — sha256 is in algorithms_available on all real Python installations; it is also in algorithms_guaranteed (the guaranteed subset); FIPS 180-4 specifies SHA-256 as a 256-bit secure hash; algorithms_available is the union of OpenSSL-backed and built-in hashlib algorithms; extra230 anchors algorithms_guaranteed.__contains__('sha256') as standalone; extra245 anchors algorithms_available.__contains__('sha256') as the novel dimension; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: "algorithms_available.__contains__"
  args: ["sha256"]
  expected: true

invariant hashlib_extra245.algorithms_available_contains_md5:
  description: "hashlib.algorithms_available.__contains__('md5') == True — md5 is in algorithms_available; also in algorithms_guaranteed; RFC 1321 specifies MD5 as a 128-bit message digest; even though MD5 is cryptographically broken it remains available in hashlib for legacy compatibility; extra245 anchors this as a standalone in the extra245 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: "algorithms_available.__contains__"
  args: ["md5"]
  expected: true

invariant hashlib_extra245.algorithms_available_contains_sha1:
  description: "hashlib.algorithms_available.__contains__('sha1') == True — sha1 is in algorithms_available; FIPS 180-4 specifies SHA-1 as a 160-bit secure hash; SHA-1 is deprecated for cryptographic use but remains available in hashlib; algorithms_available tracks all platform-supported algorithms; extra245 is the first namespace to anchor sha1 in algorithms_available (not algorithms_guaranteed); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: "algorithms_available.__contains__"
  args: ["sha1"]
  expected: true

invariant hashlib_extra245.algorithms_available_contains_sha512:
  description: "hashlib.algorithms_available.__contains__('sha512') == True — sha512 is in algorithms_available; also in algorithms_guaranteed; FIPS 180-4 specifies SHA-512 as a 512-bit secure hash; SHA-512 uses a 128-byte internal block size; algorithms_available is a superset of algorithms_guaranteed; extra245 anchors sha512 in the available set as the novel dimension vs extra230 guaranteed anchors; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: membership
  kind: python_call_eq
  function: "algorithms_available.__contains__"
  args: ["sha512"]
  expected: true

invariant hashlib_extra245.algorithms_guaranteed_is_frozenset:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('frozenset') == True — algorithms_guaranteed is a frozenset (immutable); algorithms_available is a plain set (mutable); the distinction reflects that 'guaranteed' names are fixed across all Python platforms while 'available' names may vary by OS and OpenSSL version; on Python 3.14.3 macOS the guaranteed set has 14 members and the available set has 19; extra245 is the first namespace to anchor this class distinction as a standalone invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "algorithms_guaranteed.__class__.__name__.__eq__"
  args: ["frozenset"]
  expected: true
