spec: contextlib_extra28
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib_extra27.zspec.zsdl."
    - "Prior specs covered: contextmanager/asynccontextmanager/closing/suppress/redirect_stdout/redirect_stderr/ExitStack/AsyncExitStack/nullcontext/__name__/__module__/__qualname__, contextlib.__name__/__package__, AbstractContextManager.__name__/__module__, AbstractAsyncContextManager.__name__, ExitStack.__bases__[0].__name__, AsyncExitStack.__bases__[0].__name__, suppress.__bases__[0].__name__, ContextDecorator.__name__/__module__/__qualname__, chdir.__name__, various class __bases__."
    - "This spec covers: contextlib.contextmanager.__module__, contextlib.asynccontextmanager.__module__, contextlib.closing.__module__, contextlib.suppress.__module__, contextlib.redirect_stdout.__module__, contextlib.redirect_stderr.__module__, contextlib.nullcontext.__module__, contextlib.ExitStack.__module__, contextlib.AsyncExitStack.__module__, contextlib.closing.__bases__[0].__name__, contextlib.redirect_stdout.__bases__[0].__name__, contextlib.nullcontext.__bases__[0].__name__."
    - "contextlib.contextmanager.__module__ == 'contextlib' — contextmanager is a Python function defined in contextlib."
    - "contextlib.asynccontextmanager.__module__ == 'contextlib' — asynccontextmanager is a Python function defined in contextlib."
    - "contextlib.closing.__module__ == 'contextlib' — closing class is defined in contextlib."
    - "contextlib.suppress.__module__ == 'contextlib' — suppress class is defined in contextlib."
    - "contextlib.redirect_stdout.__module__ == 'contextlib' — redirect_stdout class is defined in contextlib."
    - "contextlib.redirect_stderr.__module__ == 'contextlib' — redirect_stderr class is defined in contextlib."
    - "contextlib.nullcontext.__module__ == 'contextlib' — nullcontext class is defined in contextlib."
    - "contextlib.ExitStack.__module__ == 'contextlib' — ExitStack class is defined in contextlib."
    - "contextlib.AsyncExitStack.__module__ == 'contextlib' — AsyncExitStack class is defined in contextlib."
    - "contextlib.closing.__bases__[0].__name__ == 'AbstractContextManager' — closing inherits directly from AbstractContextManager."
    - "contextlib.redirect_stdout.__bases__[0].__name__ == '_RedirectStream' — redirect_stdout inherits from the internal _RedirectStream base."
    - "contextlib.nullcontext.__bases__[0].__name__ == 'AbstractContextManager' — nullcontext inherits directly from AbstractContextManager."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ combined table for decorator functions (extra28 namespace)
#
# contextmanager and asynccontextmanager are plain Python functions defined
# in contextlib. Prior specs record __module__ for each in isolation or in
# mixed tables. This table groups just the two decorator functions together
# in the extra28 namespace.
# ---------------------------------------------------------------------------

table contextlib_extra28.decorator_modules:
  description: "__module__.__eq__ for contextlib decorator functions in the extra28 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [contextmanager,      contextmanager.__module__.__eq__,      ["contextlib"], true]
    - [asynccontextmanager, asynccontextmanager.__module__.__eq__, ["contextlib"], true]

# ---------------------------------------------------------------------------
# __module__ combined table for contextlib classes (extra28 namespace)
#
# closing/suppress/redirect_stdout/redirect_stderr/nullcontext/ExitStack/AsyncExitStack
# are all Python classes defined in contextlib. Prior specs cover subsets of
# these in isolation or in mixed-namespace tables. This table groups all seven
# together in the extra28 namespace for the first time.
# ---------------------------------------------------------------------------

table contextlib_extra28.class_modules:
  description: "__module__.__eq__ for contextlib classes in the extra28 namespace"
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [closing,          closing.__module__.__eq__,          ["contextlib"], true]
    - [suppress,         suppress.__module__.__eq__,         ["contextlib"], true]
    - [redirect_stdout,  redirect_stdout.__module__.__eq__,  ["contextlib"], true]
    - [redirect_stderr,  redirect_stderr.__module__.__eq__,  ["contextlib"], true]
    - [nullcontext,      nullcontext.__module__.__eq__,      ["contextlib"], true]
    - [ExitStack,        ExitStack.__module__.__eq__,        ["contextlib"], true]
    - [AsyncExitStack,   AsyncExitStack.__module__.__eq__,   ["contextlib"], true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ combined table for selected contextlib classes (extra28 namespace)
#
# closing and nullcontext both inherit from AbstractContextManager.
# redirect_stdout inherits from the internal _RedirectStream class.
# Prior specs (extra27) record these in a larger combined table; this table
# re-anchors these three in the extra28 namespace with a tighter grouping.
# ---------------------------------------------------------------------------

table contextlib_extra28.bases:
  description: "__bases__[0].__name__.__eq__ for selected contextlib classes in the extra28 namespace"
  kind: python_call_eq
  category: bases
  id_prefix: bases

  columns: [id, function, args, expected]
  rows:
    - [closing,         "closing.__bases__[0].__name__.__eq__",         ["AbstractContextManager"], true]
    - [nullcontext,     "nullcontext.__bases__[0].__name__.__eq__",     ["AbstractContextManager"], true]
    - [redirect_stdout, "redirect_stdout.__bases__[0].__name__.__eq__", ["_RedirectStream"],        true]

# ---------------------------------------------------------------------------
# contextlib.contextmanager.__module__ == 'contextlib' — standalone (extra28 namespace)
#
# contextmanager is a plain Python function. Its __module__ is 'contextlib'.
# Prior specs cover this in mixed tables. Re-anchored here as a standalone
# invariant in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra28.contextmanager.module:
  description: "contextlib.contextmanager.__module__ == 'contextlib' — Python function defined in contextlib"
  category: module_attrs
  kind: python_call_eq
  function: contextmanager.__module__.__eq__
  args: ["contextlib"]
  expected: true

# ---------------------------------------------------------------------------
# contextlib.ExitStack.__module__ == 'contextlib' — standalone (extra28 namespace)
#
# ExitStack is a Python class defined in contextlib. Its __module__ is
# 'contextlib'. Re-anchored as a standalone invariant in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant contextlib_extra28.ExitStack.module:
  description: "contextlib.ExitStack.__module__ == 'contextlib' — class defined in contextlib"
  category: module_attrs
  kind: python_call_eq
  function: ExitStack.__module__.__eq__
  args: ["contextlib"]
  expected: true

# ---------------------------------------------------------------------------
# contextlib.redirect_stdout.__bases__[0].__name__ == '_RedirectStream' — standalone
# (extra28 namespace)
#
# redirect_stdout inherits from the internal _RedirectStream helper class, not
# directly from AbstractContextManager. This is re-anchored as a standalone
# in the extra28 namespace to emphasize the inheritance distinguishing it from
# closing/nullcontext/suppress.
# ---------------------------------------------------------------------------

invariant contextlib_extra28.redirect_stdout.bases0.name:
  description: "contextlib.redirect_stdout.__bases__[0].__name__ == '_RedirectStream' — inherits from internal helper, not AbstractContextManager directly"
  category: bases
  kind: python_call_eq
  function: "redirect_stdout.__bases__[0].__name__.__eq__"
  args: ["_RedirectStream"]
  expected: true
