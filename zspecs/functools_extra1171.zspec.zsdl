spec: functools_extra1171
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools.__all__.__contains__ for lru_cache/cache/cached_property/singledispatch/wraps/partial/reduce/total_ordering, functools.cache __module__/__qualname__/__class__.__name__, functools.cache.__class__.__name__ — not covered in _extra1141/_extra1156"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1171.all_contains_public_api:
  description: "functools.__all__ contains expected public API names"
  kind: python_call_eq
  category: all_contains_public_api
  id_prefix: fn1171aa
  columns: [id, function, args, expected]
  rows:
    - [fn1171aa001, functools.__all__.__contains__,   ["lru_cache"],         true]
    - [fn1171aa002, functools.__all__.__contains__,   ["cache"],             true]
    - [fn1171aa003, functools.__all__.__contains__,   ["cached_property"],   true]
    - [fn1171aa004, functools.__all__.__contains__,   ["singledispatch"],    true]
    - [fn1171aa005, functools.__all__.__contains__,   ["wraps"],             true]
    - [fn1171aa006, functools.__all__.__contains__,   ["partial"],           true]
    - [fn1171aa007, functools.__all__.__contains__,   ["reduce"],            true]
    - [fn1171aa008, functools.__all__.__contains__,   ["total_ordering"],    true]

table functools_extra1171.cache_module_qualname_class:
  description: "functools.cache __module__, __qualname__, and __class__.__name__ identity"
  kind: python_call_eq
  category: cache_module_qualname_class
  id_prefix: fn1171ca
  columns: [id, function, args, expected]
  rows:
    - [fn1171ca001, functools.cache.__module__.__eq__,              ["functools"],   true]
    - [fn1171ca002, functools.cache.__qualname__.__eq__,            ["cache"],       true]
    - [fn1171ca003, functools.cache.__class__.__name__.__eq__,      ["function"],    true]
    - [fn1171ca004, functools.cache.__doc__.__class__.__name__.__eq__, ["str"],      true]
    - [fn1171ca005, functools.wraps.__qualname__.__eq__,            ["wraps"],       true]
    - [fn1171ca006, functools.wraps.__class__.__name__.__eq__,      ["function"],    true]
    - [fn1171ca007, functools.update_wrapper.__module__.__eq__,     ["functools"],   true]
    - [fn1171ca008, functools.update_wrapper.__class__.__name__.__eq__, ["function"], true]

table functools_extra1171.reduce_partial_class_identity:
  description: "functools.reduce and partial class-level identity checks"
  kind: python_call_eq
  category: reduce_partial_class_identity
  id_prefix: fn1171rp
  columns: [id, function, args, expected]
  rows:
    - [fn1171rp001, functools.reduce.__module__.__eq__,                     ["functools"],                    true]
    - [fn1171rp002, functools.reduce.__class__.__name__.__eq__,             ["builtin_function_or_method"],   true]
    - [fn1171rp003, functools.partial.__doc__.__class__.__name__.__eq__,    ["str"],                          true]
    - [fn1171rp004, functools.total_ordering.__class__.__name__.__eq__,     ["function"],                     true]
    - [fn1171rp005, functools.lru_cache.__qualname__.__eq__,                ["lru_cache"],                    true]
    - [fn1171rp006, functools.lru_cache.__class__.__name__.__eq__,          ["function"],                     true]
