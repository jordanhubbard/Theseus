spec: types_extra7
version: ">=3.10"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types.zspec.zsdl — covers __name__ for FunctionType/MethodType/ModuleType/NoneType/GeneratorType/MappingProxyType/SimpleNamespace/LambdaType/CoroutineType/AsyncGeneratorType/UnionType; SimpleNamespace attribute access; MappingProxyType __getitem__/__len__/__contains__"
    - "types_extra.zspec.zsdl — covers __name__ for CodeType/BuiltinFunctionType/TracebackType/FrameType"
    - "types_extra2.zspec.zsdl — covers __module__ for major types; __bases__[0].__name__ for FunctionType/GeneratorType/CoroutineType/AsyncGeneratorType/CodeType/FrameType/TracebackType/ModuleType/MethodType/SimpleNamespace"
    - "types_extra3.zspec.zsdl — covers EllipsisType/__name__/__module__/__bases__; NotImplementedType/__name__/__module__/__bases__; NoneType/__name__/__module__/__bases__; MappingProxyType/__name__/__module__; SimpleNamespace/__module__/__name__; class_modules table"
    - "types_extra4.zspec.zsdl — covers __name__/__module__ (table) for FunctionType/CodeType/FrameType/TracebackType/ModuleType/MethodType/BuiltinFunctionType/MappingProxyType/CellType/NoneType; SimpleNamespace/ModuleType/MappingProxyType instances"
    - "types_extra5.zspec.zsdl — covers __qualname__ for FunctionType/MethodType/GeneratorType/CoroutineType/ModuleType (table); BuiltinFunctionType/AsyncGeneratorType/LambdaType/SimpleNamespace/MappingProxyType/DynamicClassAttribute __qualname__"
    - "types_extra6.zspec.zsdl — covers __qualname__ for CellType/CodeType/FrameType/TracebackType/NoneType/EllipsisType/NotImplementedType (table); BuiltinFunctionType/LambdaType/MappingProxyType/CellType __bases__[0]; CellType.__module__"
  notes:
    - "This spec adds new axes: GenericAlias/__name__/__qualname__/__module__/__bases__[0] (not covered in any prior spec); UnionType/__qualname__/__module__ (not covered); BuiltinMethodType alias check; descriptor types not in prior specs (MethodWrapperType, WrapperDescriptorType, MethodDescriptorType, GetSetDescriptorType, MemberDescriptorType)."
    - "types.GenericAlias is the type created by list[int] syntax (Python 3.9+). Not covered in any prior spec."
    - "types.GenericAlias.__name__ == 'GenericAlias' — defined in the types module."
    - "types.GenericAlias.__qualname__ == 'GenericAlias'."
    - "types.GenericAlias.__module__ == 'types'."
    - "types.GenericAlias.__bases__[0].__name__ == 'object'."
    - "types.UnionType.__qualname__ == 'Union' — matches __name__; C-level type from typing."
    - "types.UnionType.__module__ == 'typing'."
    - "types.BuiltinMethodType is types.BuiltinFunctionType — both are the same type object."
    - "types.MethodWrapperType.__name__ == 'method-wrapper' — wraps C-level slot methods."
    - "types.WrapperDescriptorType.__name__ == 'wrapper_descriptor'."
    - "types.MethodDescriptorType.__name__ == 'method_descriptor'."
    - "types.GetSetDescriptorType.__name__ == 'getset_descriptor'."
    - "types.MemberDescriptorType.__name__ == 'member_descriptor'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GenericAlias — __name__, __qualname__, __module__
# types.GenericAlias is the type for parameterized generics (list[int], etc.).
# No prior spec covers GenericAlias in any way.
# ---------------------------------------------------------------------------

invariant types_extra7.GenericAlias.name:
  description: "types.GenericAlias.__name__ == 'GenericAlias'"
  category: class_names
  kind: python_call_eq
  function: GenericAlias.__name__.__eq__
  args: ["GenericAlias"]
  expected: true

invariant types_extra7.GenericAlias.qualname:
  description: "types.GenericAlias.__qualname__ == 'GenericAlias'"
  category: qualnames
  kind: python_call_eq
  function: GenericAlias.__qualname__.__eq__
  args: ["GenericAlias"]
  expected: true

invariant types_extra7.GenericAlias.module:
  description: "types.GenericAlias.__module__ == 'types'"
  category: class_modules
  kind: python_call_eq
  function: GenericAlias.__module__.__eq__
  args: ["types"]
  expected: true

invariant types_extra7.GenericAlias.base_is_object:
  description: "types.GenericAlias.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: GenericAlias.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# UnionType — __qualname__ and __module__
# types.zspec.zsdl covers UnionType.__name__ == 'Union'.
# No prior spec covers UnionType.__qualname__ or UnionType.__module__.
# ---------------------------------------------------------------------------

invariant types_extra7.UnionType.qualname:
  description: "types.UnionType.__qualname__ == 'Union' — matches __name__"
  category: qualnames
  kind: python_call_eq
  function: UnionType.__qualname__.__eq__
  args: ["Union"]
  expected: true

invariant types_extra7.UnionType.module:
  description: "types.UnionType.__module__ == 'typing'"
  category: class_modules
  kind: python_call_eq
  function: UnionType.__module__.__eq__
  args: ["typing"]
  expected: true

# ---------------------------------------------------------------------------
# BuiltinMethodType — identity alias check
# types.BuiltinMethodType is the same object as types.BuiltinFunctionType.
# No prior spec verifies the alias identity via __name__ (the alias name confirms it).
# ---------------------------------------------------------------------------

invariant types_extra7.BuiltinMethodType.name:
  description: "types.BuiltinMethodType.__name__ == 'builtin_function_or_method' — same type as BuiltinFunctionType"
  category: class_names
  kind: python_call_eq
  function: BuiltinMethodType.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# Descriptor types — __name__ checks
# types_extra, types_extra2, etc. cover FunctionType/MethodType/CodeType etc.
# but never touch the descriptor types introduced in later extras.
# No prior spec covers MethodWrapperType, WrapperDescriptorType,
# MethodDescriptorType, GetSetDescriptorType, or MemberDescriptorType.
# ---------------------------------------------------------------------------

table types_extra7.descriptor_class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: dcname

  columns: [id, function, args, expected]
  rows:
    - [MethodWrapperType,       MethodWrapperType.__name__.__eq__,       ["method-wrapper"],          true]
    - [WrapperDescriptorType,   WrapperDescriptorType.__name__.__eq__,   ["wrapper_descriptor"],      true]
    - [MethodDescriptorType,    MethodDescriptorType.__name__.__eq__,    ["method_descriptor"],       true]
    - [GetSetDescriptorType,    GetSetDescriptorType.__name__.__eq__,    ["getset_descriptor"],       true]
    - [MemberDescriptorType,    MemberDescriptorType.__name__.__eq__,    ["member_descriptor"],       true]

# ---------------------------------------------------------------------------
# Descriptor types — __qualname__ checks
# Qualnames for these descriptor types have not been tested in any prior spec.
# ---------------------------------------------------------------------------

table types_extra7.descriptor_class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: dqname

  columns: [id, function, args, expected]
  rows:
    - [MethodWrapperType,     MethodWrapperType.__qualname__.__eq__,     ["method-wrapper"],     true]
    - [WrapperDescriptorType, WrapperDescriptorType.__qualname__.__eq__, ["wrapper_descriptor"], true]
    - [MethodDescriptorType,  MethodDescriptorType.__qualname__.__eq__,  ["method_descriptor"],  true]
    - [GetSetDescriptorType,  GetSetDescriptorType.__qualname__.__eq__,  ["getset_descriptor"],  true]
    - [MemberDescriptorType,  MemberDescriptorType.__qualname__.__eq__,  ["member_descriptor"],  true]
