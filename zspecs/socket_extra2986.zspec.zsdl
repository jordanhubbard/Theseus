spec: sk2986
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket: Low-level networking interface"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (sk2986): __len__, __length_hint__, __contains__ dict-presence checks for socket types."
    - "socket.socket is a networking file descriptor wrapper — not a container or sequence type."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; socket.AddressInfo and socket.MsgFlag are IntFlag subclasses — integral enum types have no container/sequence semantics in their own __dict__."
    - "socket.error, socket.herror, socket.gaierror, and socket.timeout are exception classes — none are containers or sequences."
    - "None of the socket types define __len__, __length_hint__, or __contains__ in their own __dict__."
    - "Verified types: socket.socket, socket.AddressFamily, socket.SocketKind, socket.AddressInfo, socket.MsgFlag, socket.error, socket.herror, socket.gaierror, socket.timeout."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk2986.len:
  description: "socket types __len__ dict-presence checks; wave 646"
  kind: python_call_eq
