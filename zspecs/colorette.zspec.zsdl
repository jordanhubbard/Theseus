spec: colorette
version: ">=2.0.0"
backend: node(colorette)

docs: https://github.com/jorgebucaran/colorette#readme

provenance:
  derived_from:
    - "colorette README — https://github.com/jorgebucaran/colorette#readme"
    - "Test vectors verified with colorette@2.0.20 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "colorette source: index.js"
  notes:
    - "colorette exports color/style functions (red, green, bold, etc.) as named exports."
    - "When stdout is not a TTY, all functions return the input string unchanged."
    - "The verify harness runs node as a subprocess with piped stdout (not a TTY), so all invariants are in no-color mode."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "All functions return the input string unchanged in no-TTY mode. No errors thrown."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table colorette.no_tty:
  kind: node_module_call_eq
  category: no_tty
  id_prefix: ce

  columns: [id, function, args, expected]
  rows:
    - [red,    red,    ["error"],   "error"]
    - [green,  green,  ["ok"],      "ok"]
    - [blue,   blue,   ["info"],    "info"]
    - [bold,   bold,   ["header"],  "header"]
