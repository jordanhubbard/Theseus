spec: pathlib_extra85
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra84."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for open/read_text/write_text/iterdir/mkdir/exists/unlink/stat/rename/read_bytes/write_bytes/touch/rmdir/resolve/glob/rglob/is_dir/is_file/absolute/symlink_to/hardlink_to/lstat/expanduser/chmod/with_name/with_suffix/with_stem; PurePath/__dict__ membership; Path/__dict__ membership; Path.parent/name/suffix/stem/parts/drive as property descriptors."
    - "This spec covers: Path.read_text/__code__.co_name and co_argcount; Path.write_text/__code__.co_name and co_argcount; Path.read_bytes/__code__.co_name and co_argcount; Path.write_bytes/__code__.co_name and co_argcount; Path.open/__code__.co_name and co_argcount; Path.unlink/__code__.co_name and co_argcount; Path.rename/__code__.co_name and co_argcount; Path.replace/__code__.co_name and co_argcount."
    - "pathlib.Path.read_text.__code__.co_name == 'read_text' — verified by code object attribute."
    - "pathlib.Path.read_text.__code__.co_argcount == 4 — read_text(self, encoding=None, errors=None, newline=None): 4 positional-or-keyword args."
    - "pathlib.Path.write_text.__code__.co_name == 'write_text' — verified by code object attribute."
    - "pathlib.Path.write_text.__code__.co_argcount == 5 — write_text(self, data, encoding=None, errors=None, newline=None): 5 positional-or-keyword args."
    - "pathlib.Path.read_bytes.__code__.co_name == 'read_bytes' — verified by code object attribute."
    - "pathlib.Path.read_bytes.__code__.co_argcount == 1 — read_bytes(self): self only."
    - "pathlib.Path.write_bytes.__code__.co_name == 'write_bytes' — verified by code object attribute."
    - "pathlib.Path.write_bytes.__code__.co_argcount == 2 — write_bytes(self, data): self + data."
    - "pathlib.Path.open.__code__.co_name == 'open' — verified by code object attribute."
    - "pathlib.Path.open.__code__.co_argcount == 6 — open(self, mode, buffering, encoding, errors, newline): 6 positional-or-keyword args."
    - "pathlib.Path.unlink.__code__.co_name == 'unlink' — verified by code object attribute."
    - "pathlib.Path.unlink.__code__.co_argcount == 2 — unlink(self, missing_ok=False): self + missing_ok."
    - "pathlib.Path.rename.__code__.co_name == 'rename' — verified by code object attribute."
    - "pathlib.Path.rename.__code__.co_argcount == 2 — rename(self, target): self + target."
    - "pathlib.Path.replace.__code__.co_name == 'replace' — verified by code object attribute."
    - "pathlib.Path.replace.__code__.co_argcount == 2 — replace(self, target): self + target."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.read_text and Path.write_text __code__ attributes
# read_text(self, encoding=None, errors=None, newline=None): co_argcount == 4.
# write_text(self, data, encoding=None, errors=None, newline=None): co_argcount == 5.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra85.read_write_text_code:
  description: "Path.read_text and Path.write_text __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra85

  columns: [id, function, args, expected]
  rows:
    - [read_text_co_name,  Path.read_text.__code__.co_name.__eq__,      ["read_text"],  true]
    - [read_text_co_argc,  Path.read_text.__code__.co_argcount.__eq__,  [4],            true]
    - [write_text_co_name, Path.write_text.__code__.co_name.__eq__,     ["write_text"], true]
    - [write_text_co_argc, Path.write_text.__code__.co_argcount.__eq__, [5],            true]

# ---------------------------------------------------------------------------
# Path.read_bytes and Path.write_bytes __code__ attributes
# read_bytes(self): co_argcount == 1 (self only).
# write_bytes(self, data): co_argcount == 2 (self + data).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra85.read_write_bytes_code:
  description: "Path.read_bytes and Path.write_bytes __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra85

  columns: [id, function, args, expected]
  rows:
    - [read_bytes_co_name,  Path.read_bytes.__code__.co_name.__eq__,      ["read_bytes"],  true]
    - [read_bytes_co_argc,  Path.read_bytes.__code__.co_argcount.__eq__,  [1],             true]
    - [write_bytes_co_name, Path.write_bytes.__code__.co_name.__eq__,     ["write_bytes"], true]
    - [write_bytes_co_argc, Path.write_bytes.__code__.co_argcount.__eq__, [2],             true]

# ---------------------------------------------------------------------------
# Path.open and Path.unlink __code__ attributes
# open(self, mode, buffering, encoding, errors, newline): co_argcount == 6.
# unlink(self, missing_ok=False): co_argcount == 2 (self + missing_ok).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra85.open_unlink_code:
  description: "Path.open and Path.unlink __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra85

  columns: [id, function, args, expected]
  rows:
    - [open_co_name,   Path.open.__code__.co_name.__eq__,      ["open"],   true]
    - [open_co_argc,   Path.open.__code__.co_argcount.__eq__,  [6],        true]
    - [unlink_co_name, Path.unlink.__code__.co_name.__eq__,    ["unlink"], true]
    - [unlink_co_argc, Path.unlink.__code__.co_argcount.__eq__, [2],       true]

# ---------------------------------------------------------------------------
# Path.rename and Path.replace __code__ attributes
# rename(self, target): co_argcount == 2 (self + target).
# replace(self, target): co_argcount == 2 (self + target).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra85.rename_replace_code:
  description: "Path.rename and Path.replace __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra85

  columns: [id, function, args, expected]
  rows:
    - [rename_co_name,  Path.rename.__code__.co_name.__eq__,      ["rename"],  true]
    - [rename_co_argc,  Path.rename.__code__.co_argcount.__eq__,  [2],         true]
    - [replace_co_name, Path.replace.__code__.co_name.__eq__,     ["replace"], true]
    - [replace_co_argc, Path.replace.__code__.co_argcount.__eq__, [2],         true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra85.read_text_code.co_name:
  description: "pathlib.Path.read_text.__code__.co_name == 'read_text'"
  category: code_attrs
  kind: python_call_eq
  function: Path.read_text.__code__.co_name.__eq__
  args: ["read_text"]
  expected: true

invariant pathlib_extra85.read_text_code.co_argcount:
  description: "pathlib.Path.read_text.__code__.co_argcount == 4 (self + encoding + errors + newline)"
  category: code_attrs
  kind: python_call_eq
  function: Path.read_text.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant pathlib_extra85.write_bytes_code.co_name:
  description: "pathlib.Path.write_bytes.__code__.co_name == 'write_bytes'"
  category: code_attrs
  kind: python_call_eq
  function: Path.write_bytes.__code__.co_name.__eq__
  args: ["write_bytes"]
  expected: true

invariant pathlib_extra85.open_code.co_argcount:
  description: "pathlib.Path.open.__code__.co_argcount == 6 (self + mode + buffering + encoding + errors + newline)"
  category: code_attrs
  kind: python_call_eq
  function: Path.open.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant pathlib_extra85.rename_code.co_name:
  description: "pathlib.Path.rename.__code__.co_name == 'rename'"
  category: code_attrs
  kind: python_call_eq
  function: Path.rename.__code__.co_name.__eq__
  args: ["rename"]
  expected: true
