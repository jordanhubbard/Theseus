spec: ipaddress_extra6
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress.zspec.zsdl — covers IPv4/IPv6 address/network attributes and error cases"
    - "ipaddress_extra.zspec.zsdl — covers __name__ and __module__ for all 6 public classes (tables), packed_is_bytes, is_private, factory return types"
    - "ipaddress_extra2.zspec.zsdl — covers IPv4/IPv6/Network __name__ (table), ip_address/ip_network/ip_interface __name__ (table), loopback class name, packed_is_bytes"
    - "ipaddress_extra3.zspec.zsdl — covers ip_address/ip_network/ip_interface __module__, IPv4/IPv6Address __bases__[0].__name__, IPv4/IPv6Network __bases__[0].__name__, AddressValueError/NetmaskValueError full coverage"
    - "ipaddress_extra4.zspec.zsdl — covers IPv4Address is_private/is_loopback/is_unspecified/packed type/packed len, IPv6Address is_loopback/packed len, IPv4Network num_addresses/prefixlen/network_address class"
    - "ipaddress_extra5.zspec.zsdl — covers __qualname__ for all 6 classes, 3 factory functions, and 2 exception classes"
  notes:
    - "This spec extends the ipaddress chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: .version attribute values for IPv4Address and IPv6Address; .max_prefixlen values for IPv4Address and IPv6Address; IPv6Address.compressed return type."
    - "ipaddress.IPv4Address('192.168.1.1').version == 4 — version is an int, value 4. Not covered in any prior spec."
    - "ipaddress.IPv6Address('::1').version == 6 — version is an int, value 6. Not covered in any prior spec."
    - "ipaddress.IPv4Address('192.168.1.1').max_prefixlen == 32 — IPv4 always has 32-bit prefix space. Not covered in any prior spec."
    - "ipaddress.IPv6Address('::1').max_prefixlen == 128 — IPv6 always has 128-bit prefix space. Not covered in any prior spec."
    - "ipaddress.IPv4Network('10.0.0.0/8').version == 4 — version attribute present on network objects. Not covered in any prior spec."
    - "ipaddress.IPv6Network('2001:db8::/32').version == 6 — version attribute present on IPv6 network objects. Not covered in any prior spec."
    - "ipaddress.IPv6Address('::1').compressed.__class__.__name__ == 'str' — .compressed returns the shortest form as a str. Not covered in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# .version attribute — int value checks for address classes
#
# No prior spec covers the .version attribute of IPv4Address or IPv6Address.
# ipaddress_extra4 covers .packed type/len and is_private/is_loopback/is_unspecified;
# none of those specs touch .version.
# ---------------------------------------------------------------------------

invariant ipaddress_extra6.IPv4Address.version:
  description: "ipaddress.IPv4Address('192.168.1.1').version == 4"
  category: address_attributes
  kind: python_call_eq
  function: IPv4Address
  args: ["192.168.1.1"]
  method: version.__eq__
  method_args: [4]
  expected: true

invariant ipaddress_extra6.IPv6Address.version:
  description: "ipaddress.IPv6Address('::1').version == 6"
  category: address_attributes
  kind: python_call_eq
  function: IPv6Address
  args: ["::1"]
  method: version.__eq__
  method_args: [6]
  expected: true

# ---------------------------------------------------------------------------
# .version attribute — int value checks for network classes
#
# No prior spec covers .version on IPv4Network or IPv6Network.
# ---------------------------------------------------------------------------

invariant ipaddress_extra6.IPv4Network.version:
  description: "ipaddress.IPv4Network('10.0.0.0/8').version == 4"
  category: network_attributes
  kind: python_call_eq
  function: IPv4Network
  args: ["10.0.0.0/8"]
  method: version.__eq__
  method_args: [4]
  expected: true

invariant ipaddress_extra6.IPv6Network.version:
  description: "ipaddress.IPv6Network('2001:db8::/32').version == 6"
  category: network_attributes
  kind: python_call_eq
  function: IPv6Network
  args: ["2001:db8::/32"]
  method: version.__eq__
  method_args: [6]
  expected: true

# ---------------------------------------------------------------------------
# .max_prefixlen attribute — fixed-width constants for each address family
#
# IPv4 always has max_prefixlen == 32; IPv6 always has max_prefixlen == 128.
# These are class-level constants; no prior spec covers them.
# ---------------------------------------------------------------------------

invariant ipaddress_extra6.IPv4Address.max_prefixlen:
  description: "ipaddress.IPv4Address('192.168.1.1').max_prefixlen == 32"
  category: address_attributes
  kind: python_call_eq
  function: IPv4Address
  args: ["192.168.1.1"]
  method: max_prefixlen.__eq__
  method_args: [32]
  expected: true

invariant ipaddress_extra6.IPv6Address.max_prefixlen:
  description: "ipaddress.IPv6Address('::1').max_prefixlen == 128"
  category: address_attributes
  kind: python_call_eq
  function: IPv6Address
  args: ["::1"]
  method: max_prefixlen.__eq__
  method_args: [128]
  expected: true

# ---------------------------------------------------------------------------
# IPv6Address.compressed — shortest textual representation, always a str
#
# ipaddress_extra4 covers IPv6Address.packed length (16 bytes).
# No prior spec covers IPv6Address.compressed at all.
# ---------------------------------------------------------------------------

invariant ipaddress_extra6.IPv6Address.compressed_class:
  description: "ipaddress.IPv6Address('::1').compressed.__class__.__name__ == 'str'"
  category: address_attributes
  kind: python_call_eq
  function: IPv6Address
  args: ["::1"]
  method: compressed.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant ipaddress_extra6.IPv6Address.compressed_loopback:
  description: "ipaddress.IPv6Address('0:0:0:0:0:0:0:1').compressed == '::1'"
  category: address_attributes
  kind: python_call_eq
  function: IPv6Address
  args: ["0:0:0:0:0:0:0:1"]
  method: compressed.__eq__
  method_args: ["::1"]
  expected: true
