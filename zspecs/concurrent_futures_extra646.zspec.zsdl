spec: concurrent_futures_extra646
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module: Executor, wait, as_completed, and exception hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers identity checks for concurrent.futures.wait, as_completed, and exception/error class hierarchy"
  created_at: "2026-04-12T00:00:00Z"

table concurrent_futures_extra646.function_identity:
  description: "Identity checks for concurrent.futures top-level functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: cf646wt
  columns: [id, function, args, expected]
  rows:
    - [cf646wt001, concurrent.futures.wait.__class__.__name__.__eq__, ["function"], true]
    - [cf646wt002, concurrent.futures.as_completed.__class__.__name__.__eq__, ["function"], true]

table concurrent_futures_extra646.exception_identity:
  description: "Identity checks for concurrent.futures exception and error classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf646ex
  columns: [id, function, args, expected]
  rows:
    - [cf646ex001, concurrent.futures.BrokenExecutor.__class__.__name__.__eq__, ["type"], true]
    - [cf646ex002, concurrent.futures.InvalidStateError.__class__.__name__.__eq__, ["type"], true]
    - [cf646ex003, concurrent.futures.BrokenThreadPool.__qualname__.__eq__, ["BrokenThreadPool"], true]
    - [cf646ex004, concurrent.futures.BrokenProcessPool.__qualname__.__eq__, ["BrokenProcessPool"], true]
    - [cf646ex005, concurrent.futures.BrokenThreadPool.__module__.__eq__, ["concurrent.futures.thread"], true]
    - [cf646ex006, concurrent.futures.BrokenProcessPool.__module__.__eq__, ["concurrent.futures.process"], true]
    - [cf646ex007, concurrent.futures.CancelledError.__class__.__name__.__eq__, ["type"], true]
    - [cf646ex008, concurrent.futures.TimeoutError.__class__.__name__.__eq__, ["type"], true]
    - [cf646ex009, concurrent.futures.CancelledError.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf646ex010, concurrent.futures.TimeoutError.__module__.__eq__, ["concurrent.futures._base"], true]
