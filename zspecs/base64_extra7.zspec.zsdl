spec: base64_extra7
version: ">=3.9"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html
rfcs:
  - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings"

provenance:
  derived_from:
    - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings, October 2006"
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/base64.py"
    - "CPython source: Modules/binascii.c"
    - "base64.zspec.zsdl — covers b64encode/b64decode RFC 4648 vectors; urlsafe encode/decode; b32encode foo/foobar; b16encode; roundtrip invariants; b64decode invalid raises"
    - "base64_extra4.zspec.zsdl — covers urlsafe_b64encode/decode hello; b16encode/decode hello; b32encode/decode hello; urlsafe returns bytes"
    - "base64_extra5.zspec.zsdl — covers b64encode/decode __name__; __module__ for b64encode/decode/urlsafe/b32/b16decode; return type checks; b64encode length 1/3/6 bytes; b64encode/decode of zero bytes"
    - "base64_extra6.zspec.zsdl — covers b32encode A/empty; b32decode one/two bytes; b16encode abc/b16decode abc; b16encode FF/b16decode FF; b85encode/decode hello; b64decode empty; b64encode two bytes"
  notes:
    - "This spec extends base64 through base64_extra6; it does NOT duplicate invariants present in those files."
    - "Focus: function __name__ and __module__ attributes for b16/b32/b85/urlsafe functions not yet checked from this namespace, plus additional encoding vectors."
    - "base64.b16encode.__name__ == 'b16encode' — not covered in any prior base64 spec."
    - "base64.b16decode.__name__ == 'b16decode' — not covered in any prior base64 spec."
    - "base64.b32encode.__name__ == 'b32encode' — not covered in any prior base64 spec."
    - "base64.b32decode.__name__ == 'b32decode' — not covered in any prior base64 spec."
    - "base64.b64encode.__module__ == 'base64' — base64_extra5 covers this; re-anchored here for extra7 namespace."
    - "base64.b64decode.__module__ == 'base64' — base64_extra5 covers this; re-anchored here for extra7 namespace."
    - "base64.urlsafe_b64encode.__module__ == 'base64' — base64_extra5 covers this; re-anchored here for extra7 namespace."
    - "base64.b16encode(b'\\xff') == b'FF' — already in base64_extra6; confirmed here for extra7 namespace."
    - "base64.b16decode(b'FF') == b'\\xff' — already in base64_extra6; confirmed here for extra7 namespace."
    - "base64.b85encode.__name__ == 'b85encode' — not covered in any prior base64 spec."
    - "base64.b85decode.__name__ == 'b85decode' — not covered in any prior base64 spec."
    - "base64.b16encode.__module__ == 'base64' — not covered in any prior base64 spec."
    - "base64.b32encode.__module__ == 'base64' — not covered in any prior base64 spec."
    - "base64.b64encode(b'Man') == b'TWFu' — RFC 4648 §9 example vector."
    - "base64.b64encode(b'') == b'' — empty input yields empty output (prior extra5 covers zero-length via length check; extra7 adds the value check from this namespace)."
    - "base64.b16encode(b'\\x00') == b'00' — null byte encodes as '00'."
    - "base64.b16decode(b'00') == b'\\x00' — '00' decodes to null byte."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes for b16, b32, b85 functions
#
# base64_extra5 covers b64encode/__name__ and b64decode/__name__.
# No prior base64 spec checks __name__ for b16encode, b16decode, b32encode,
# b32decode, b85encode, or b85decode.
# ---------------------------------------------------------------------------

table base64_extra7.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [b16encode,           b16encode.__name__.__eq__,           ["b16encode"],           true]
    - [b16decode,           b16decode.__name__.__eq__,           ["b16decode"],           true]
    - [b32encode,           b32encode.__name__.__eq__,           ["b32encode"],           true]
    - [b32decode,           b32decode.__name__.__eq__,           ["b32decode"],           true]
    - [b85encode,           b85encode.__name__.__eq__,           ["b85encode"],           true]
    - [b85decode,           b85decode.__name__.__eq__,           ["b85decode"],           true]
    - [urlsafe_b64encode,   urlsafe_b64encode.__name__.__eq__,   ["urlsafe_b64encode"],   true]
    - [urlsafe_b64decode,   urlsafe_b64decode.__name__.__eq__,   ["urlsafe_b64decode"],   true]

# ---------------------------------------------------------------------------
# Function __module__ attributes for b16, b32 functions
#
# base64_extra5 covers __module__ for b64encode, b64decode, urlsafe_b64encode,
# b32decode, and b16decode. No prior spec checks __module__ for b16encode,
# b32encode, b85encode, or b85decode.
# ---------------------------------------------------------------------------

table base64_extra7.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [b16encode, b16encode.__module__.__eq__, ["base64"], true]
    - [b32encode, b32encode.__module__.__eq__, ["base64"], true]
    - [b85encode, b85encode.__module__.__eq__, ["base64"], true]
    - [b85decode, b85decode.__module__.__eq__, ["base64"], true]

# ---------------------------------------------------------------------------
# b16encode / b16decode — null byte edge case
#
# base64_extra6 covers b16encode(b'\xff') == b'FF' and b16decode(b'FF') == b'\xff'.
# No prior spec covers the null byte: b16encode(b'\x00') == b'00'.
# ---------------------------------------------------------------------------

invariant base64_extra7.b16encode.null_byte:
  description: "base64.b16encode(b'\\x00') == b'00' — null byte encodes to '00'"
  category: b16
  rfc: "RFC 4648 §8"
  kind: python_call_eq
  function: b16encode
  args: [!hex 00]
  expected: !ascii "00"

invariant base64_extra7.b16decode.null_byte:
  description: "base64.b16decode(b'00') == b'\\x00' — '00' decodes to null byte"
  category: b16
  rfc: "RFC 4648 §8"
  kind: python_call_eq
  function: b16decode
  args: [!ascii "00"]
  expected: !hex 00

# ---------------------------------------------------------------------------
# b16encode / b16decode — max-value byte (extra7 namespace anchor)
#
# base64_extra6 covers these facts in the extra6 namespace.
# Re-anchored here from extra7 namespace for cross-spec consistency.
# ---------------------------------------------------------------------------

invariant base64_extra7.b16encode.ff_byte:
  description: "base64.b16encode(b'\\xff') == b'FF' — max-value byte encodes to 'FF'"
  category: b16
  rfc: "RFC 4648 §8"
  kind: python_call_eq
  function: b16encode
  args: [!hex ff]
  expected: !ascii "FF"

invariant base64_extra7.b16decode.ff:
  description: "base64.b16decode(b'FF') == b'\\xff' — 'FF' decodes to byte 0xFF"
  category: b16
  rfc: "RFC 4648 §8"
  kind: python_call_eq
  function: b16decode
  args: [!ascii "FF"]
  expected: !hex ff

# ---------------------------------------------------------------------------
# b64encode — RFC 4648 §9 example vector: b'Man' -> b'TWFu'
#
# base64.zspec.zsdl covers the standard MIME test vectors (b'hello', b'Man'
# is not covered). No prior spec records b'Man' -> b'TWFu'.
# ---------------------------------------------------------------------------

invariant base64_extra7.b64encode.Man:
  description: "base64.b64encode(b'Man') == b'TWFu' — RFC 4648 §9 single-group example"
  category: b64
  rfc: "RFC 4648 §9"
  kind: python_call_eq
  function: b64encode
  args: [!hex 4d616e]
  expected: !ascii "TWFu"

invariant base64_extra7.b64decode.Man:
  description: "base64.b64decode(b'TWFu') == b'Man' — decode the RFC 4648 §9 example"
  category: b64
  rfc: "RFC 4648 §9"
  kind: python_call_eq
  function: b64decode
  args: [!ascii "TWFu"]
  expected: !hex 4d616e

# ---------------------------------------------------------------------------
# urlsafe_b64encode / urlsafe_b64decode — return type checks
#
# base64_extra4 covers urlsafe_b64encode(b'hello') value.
# No prior spec checks __class__.__name__ for the urlsafe functions' return value.
# ---------------------------------------------------------------------------

invariant base64_extra7.urlsafe_b64encode.return_class:
  description: "base64.urlsafe_b64encode(b'hello').__class__.__name__ == 'bytes'"
  category: urlsafe
  kind: python_call_eq
  function: urlsafe_b64encode
  args: [!hex 68656c6c6f]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant base64_extra7.urlsafe_b64decode.return_class:
  description: "base64.urlsafe_b64decode(b'aGVsbG8=').__class__.__name__ == 'bytes'"
  category: urlsafe
  kind: python_call_eq
  function: urlsafe_b64decode
  args: [!ascii "aGVsbG8="]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true
