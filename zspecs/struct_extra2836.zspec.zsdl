spec: struct_extra2836
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra2821.zspec.zsdl — covers __radd__, __rsub__, and __rmul__ absence for Struct, struct.error."
    - "struct_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, and __ipow__ absence for Struct, struct.error."
    - "struct_extra2791.zspec.zsdl — covers __iand__, __ior__, and __ixor__ absence for Struct, struct.error."
    - "struct_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for Struct, struct.error."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "struct.Struct.__dict__.__contains__('__rtruediv__') == False — struct.Struct is a binary format descriptor; it does not define the reflected true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__rfloordiv__') == False — struct.Struct does not define the reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__rmod__') == False — struct.Struct does not define the reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__rtruediv__') == False — struct.error is an Exception subclass; exception types never define reflected arithmetic operators in their own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__rfloordiv__') == False — struct.error does not define the reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__rmod__') == False — struct.error does not define the reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct.__dict__ — __rtruediv__, __rfloordiv__, __rmod__ absence
# struct.Struct is the compiled format object returned by struct.Struct(fmt).
# It exposes pack/unpack/pack_into/unpack_from/iter_unpack methods and the
# size/format attributes. Reflected division/modulo operators (__rtruediv__,
# __rfloordiv__, __rmod__) are invoked when the left operand does not support
# the operation; a binary format descriptor is not a numeric operand, so none
# are defined.
# ---------------------------------------------------------------------------

table struct_extra2836.struct_dict_rtruediv_rfloordiv_rmod:
  description: "struct.Struct.__dict__ does not contain __rtruediv__, __rfloordiv__, or __rmod__ — Struct is a binary format descriptor, not a numeric operand; reflected division and modulo operators are absent; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2836

  columns: [id, function, args, expected]
  rows:
    - ["st2836-struct-rtruediv",  struct.Struct.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["st2836-struct-rfloordiv", struct.Struct.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["st2836-struct-rmod",      struct.Struct.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Table 2: struct.error.__dict__ — __rtruediv__, __rfloordiv__, __rmod__ absence
# struct.error is a subclass of Exception raised on pack/unpack failures.
# Exception types never define reflected arithmetic operators in their own
# __dict__; arithmetic on exceptions is undefined.
# ---------------------------------------------------------------------------

table struct_extra2836.error_dict_rtruediv_rfloordiv_rmod:
  description: "struct.error.__dict__ does not contain __rtruediv__, __rfloordiv__, or __rmod__ — struct.error is an Exception subclass; exception types define no reflected division or modulo operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2836

  columns: [id, function, args, expected]
  rows:
    - ["st2836-error-rtruediv",  struct.error.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["st2836-error-rfloordiv", struct.error.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["st2836-error-rmod",      struct.error.__dict__.__contains__, ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct.__dict__ — per-dunder detail with descriptions
# ---------------------------------------------------------------------------

table struct_extra2836.struct_dict_detail:
  description: "struct.Struct.__dict__ reflected division/modulo operator absence detail — __rtruediv__, __rfloordiv__, and __rmod__ are not defined because Struct is a packing/unpacking tool, not a numeric operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2836

  columns: [id, function, args, expected, description]
  rows:
    - ["st2836-d-rtruediv",  struct.Struct.__dict__.__contains__, ["__rtruediv__"],  false, "struct.Struct does not support reflected / — binary format descriptors have no true division semantics"]
    - ["st2836-d-rfloordiv", struct.Struct.__dict__.__contains__, ["__rfloordiv__"], false, "struct.Struct does not support reflected // — right-hand floor division has no defined meaning for a format descriptor"]
    - ["st2836-d-rmod",      struct.Struct.__dict__.__contains__, ["__rmod__"],      false, "struct.Struct does not support reflected % — right-hand modulo is undefined for a binary format descriptor"]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — Struct and error both lack all three dunders
# ---------------------------------------------------------------------------

table struct_extra2836.all_types_all_dunders_absent:
  description: "struct.Struct and struct.error both lack __rtruediv__, __rfloordiv__, and __rmod__ in __dict__ — neither struct type defines reflected true division, floor division, or modulo operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2836

  columns: [id, function, args, expected]
  rows:
    - ["st2836-x-struct-rtruediv",  struct.Struct.__dict__.__contains__, ["__rtruediv__"],  false]
    - ["st2836-x-struct-rfloordiv", struct.Struct.__dict__.__contains__, ["__rfloordiv__"], false]
    - ["st2836-x-struct-rmod",      struct.Struct.__dict__.__contains__, ["__rmod__"],      false]
    - ["st2836-x-error-rtruediv",   struct.error.__dict__.__contains__,  ["__rtruediv__"],  false]
    - ["st2836-x-error-rfloordiv",  struct.error.__dict__.__contains__,  ["__rfloordiv__"], false]
    - ["st2836-x-error-rmod",       struct.error.__dict__.__contains__,  ["__rmod__"],      false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra2836.struct_no_rtruediv:
  description: "struct.Struct.__dict__.__contains__('__rtruediv__') == False — struct.Struct does not define the reflected true division operator; it is a binary packing/unpacking tool with no arithmetic semantics; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__rtruediv__"]
  expected: false

invariant struct_extra2836.struct_no_rfloordiv:
  description: "struct.Struct.__dict__.__contains__('__rfloordiv__') == False — struct.Struct does not define the reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__rfloordiv__"]
  expected: false

invariant struct_extra2836.struct_no_rmod:
  description: "struct.Struct.__dict__.__contains__('__rmod__') == False — struct.Struct does not define the reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__rmod__"]
  expected: false

invariant struct_extra2836.error_no_rtruediv:
  description: "struct.error.__dict__.__contains__('__rtruediv__') == False — struct.error (Exception subclass) does not define the reflected true division operator; exception types carry no arithmetic semantics; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__rtruediv__"]
  expected: false

invariant struct_extra2836.error_no_rfloordiv:
  description: "struct.error.__dict__.__contains__('__rfloordiv__') == False — struct.error does not define the reflected floor division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__rfloordiv__"]
  expected: false

invariant struct_extra2836.error_no_rmod:
  description: "struct.error.__dict__.__contains__('__rmod__') == False — struct.error does not define the reflected modulo operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
