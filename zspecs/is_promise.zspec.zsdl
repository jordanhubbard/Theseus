spec: is_promise
version: ">=4.0.0"
backend: node(is-promise)

docs: https://github.com/then/is-promise#readme

provenance:
  derived_from:
    - "is-promise README — https://github.com/then/is-promise#readme"
    - "Promises/A+ thenable definition — https://promisesaplus.com/#point-7"
    - "Test vectors verified with is-promise via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "is-promise source"
  notes:
    - "Tests if a value looks like a Promise (thenable with both .then and .catch as functions)."
    - "Install: npm install is-promise"
    - "v4 CJS; module export IS the function. Returns true for thenables, false otherwise."
    - "Invariants here cover the false-cases (objects, nulls, primitives) — the JSON entry_args wire can't construct real thenables (functions) so true-cases are out of scope."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on any input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant is_promise.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant is_promise.module_arity:
  description: "Module function declared length is 1"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant is_promise.plain_object_false:
  description: "Returns false for an empty object"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{}]
  chain: []
  expected: false

invariant is_promise.shaped_object_false:
  description: "Returns false for a plain object with arbitrary keys"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"foo": "bar"}]
  chain: []
  expected: false

invariant is_promise.then_string_not_function_false:
  description: "Object with .then as a string is not a thenable (must be a function)"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{"then": "not_a_function", "catch": "not_a_function"}]
  chain: []
  expected: false

invariant is_promise.null_false:
  description: "Returns false for null"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [null]
  chain: []
  expected: false

invariant is_promise.string_false:
  description: "Returns false for a plain string"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: ["promise"]
  chain: []
  expected: false

invariant is_promise.number_false:
  description: "Returns false for a number"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [42]
  chain: []
  expected: false

invariant is_promise.array_false:
  description: "Returns false for an array"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [[1, 2, 3]]
  chain: []
  expected: false
