spec: hashlib_extra88
version: ">=3.9"
extends: hashlib_extra87
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra87.zspec.zsdl — covers blake2b/blake2s __dict__.__contains__ for copy/digest/hexdigest/update/MAX_DIGEST_SIZE/MAX_KEY_SIZE/PERSON_SIZE / __dict__.__class__.__name__=='mappingproxy' / blake2b.copy.__class__.__name__=='method_descriptor' (table + invariants)."
    - "hashlib_extra86.zspec.zsdl — covers blake2b/blake2s __class__.__name__/'type' / __name__ / __module__/'_blake2' / __qualname__ / __bases__[0].__name__/'object' / __mro__.__len__()==2 / SALT_SIZE.__class__.__name__/'int' (table + invariants)."
    - "hashlib_extra85.zspec.zsdl — covers sha256/sha512/md5/sha1/__module__.__eq__('_hashlib') / sha3_256/sha3_512/shake_128/shake_256/__module__.__eq__('_hashlib') / file_digest/__class__/__name__/__module__/__code__/co_name/co_argcount (table + invariants)."
    - "hashlib_extra84.zspec.zsdl — covers sha256/__qualname__/__eq__('openssl_sha256')/True / sha512/md5/sha1/__qualname__/__len__() / sha224/sha384/sha3_256/sha3_512/__qualname__/__len__() / blake2b/blake2s/new/__qualname__/__len__() / algorithms_guaranteed/__len__()==14 (table + invariants)."
    - "hashlib_extra83.zspec.zsdl — covers sha256/sha512/md5/sha1/blake2b/blake2s __doc__.__class__.__name__ and algorithms_guaranteed/algorithms_available membership (table + invariants)."
    - "hashlib_extra80.zspec.zsdl — covers blake2b/blake2s class-level size constants and hexdigest/__class__/__name__ (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra87; it does NOT duplicate invariants present in those files."
    - "Wave 251 theme: hashlib blake2b/blake2s method __qualname__ string lengths and equality, plus __class__.__name__ / __name__ identity."
    - "hashlib.blake2b.copy.__qualname__ == 'blake2b.copy' — len 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.digest.__qualname__ == 'blake2b.digest' — len 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.hexdigest.__qualname__ == 'blake2b.hexdigest' — len 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.update.__qualname__ == 'blake2b.update' — len 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.copy.__qualname__ == 'blake2s.copy' — len 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.digest.__qualname__ == 'blake2s.digest' — len 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.hexdigest.__qualname__ == 'blake2s.hexdigest' — len 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.update.__qualname__ == 'blake2s.update' — len 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.copy.__class__.__name__ == 'method_descriptor' — C-level method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.digest.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.hexdigest.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.update.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b.copy/__qualname__/__len__() / blake2b.digest/__qualname__/__len__()
# hashlib.blake2b.hexdigest/__qualname__/__len__() / blake2b.update/__qualname__/__len__()
#
# Wave 251 theme: blake2b method __qualname__ string lengths.
#
# blake2b.copy.__qualname__ == 'blake2b.copy' (len 12).
# blake2b.digest.__qualname__ == 'blake2b.digest' (len 14).
# blake2b.hexdigest.__qualname__ == 'blake2b.hexdigest' (len 17).
# blake2b.update.__qualname__ == 'blake2b.update' (len 14).
# No prior hashlib spec checks __qualname__.__len__() for blake2b instance methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra88.blake2b_method_qualname_lengths:
  description: "hashlib.blake2b/copy/__qualname__/__len__()==12 / blake2b/digest/__qualname__/__len__()==14 / blake2b/hexdigest/__qualname__/__len__()==17 / blake2b/update/__qualname__/__len__()==14 — blake2b method __qualname__ strings are 'blake2b.<name>'; copy is 12 chars; digest is 14; hexdigest is 17; update is 14; no prior hashlib spec checks __qualname__.__len__() for blake2b instance methods; first __qualname__ length anchor for hashlib.blake2b instance methods"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra88

  columns: [id, function, args, expected]
  rows:
    - [blake2b_copy_qualname_len_12,      "blake2b.copy.__qualname__.__len__",      [], 12]
    - [blake2b_digest_qualname_len_14,    "blake2b.digest.__qualname__.__len__",    [], 14]
    - [blake2b_hexdigest_qualname_len_17, "blake2b.hexdigest.__qualname__.__len__", [], 17]
    - [blake2b_update_qualname_len_14,    "blake2b.update.__qualname__.__len__",    [], 14]

# ---------------------------------------------------------------------------
# hashlib.blake2s.copy/__qualname__/__len__() / blake2s.digest/__qualname__/__len__()
# hashlib.blake2s.hexdigest/__qualname__/__len__() / blake2s.update/__qualname__/__len__()
#
# Wave 251 theme: blake2s method __qualname__ string lengths.
#
# blake2s.copy.__qualname__ == 'blake2s.copy' (len 12).
# blake2s.digest.__qualname__ == 'blake2s.digest' (len 14).
# blake2s.hexdigest.__qualname__ == 'blake2s.hexdigest' (len 17).
# blake2s.update.__qualname__ == 'blake2s.update' (len 14).
# No prior hashlib spec checks __qualname__.__len__() for blake2s instance methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra88.blake2s_method_qualname_lengths:
  description: "hashlib.blake2s/copy/__qualname__/__len__()==12 / blake2s/digest/__qualname__/__len__()==14 / blake2s/hexdigest/__qualname__/__len__()==17 / blake2s/update/__qualname__/__len__()==14 — blake2s method __qualname__ strings mirror blake2b but use 'blake2s.' prefix; no prior hashlib spec checks __qualname__.__len__() for blake2s instance methods; first __qualname__ length anchor for hashlib.blake2s instance methods"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra88

  columns: [id, function, args, expected]
  rows:
    - [blake2s_copy_qualname_len_12,      "blake2s.copy.__qualname__.__len__",      [], 12]
    - [blake2s_digest_qualname_len_14,    "blake2s.digest.__qualname__.__len__",    [], 14]
    - [blake2s_hexdigest_qualname_len_17, "blake2s.hexdigest.__qualname__.__len__", [], 17]
    - [blake2s_update_qualname_len_14,    "blake2s.update.__qualname__.__len__",    [], 14]

# ---------------------------------------------------------------------------
# hashlib.blake2b.copy/__class__/__name__ / blake2b.digest/__class__/__name__
# hashlib.blake2b.hexdigest/__class__/__name__ / blake2b.update/__class__/__name__
#
# Wave 251 theme: blake2b method __class__.__name__ identity for digest/hexdigest/update.
#
# blake2b.digest, hexdigest, update are all method_descriptor (C-level).
# hashlib_extra87 covers blake2b.copy.__class__.__name__ == 'method_descriptor'.
# No prior hashlib spec checks __class__.__name__ for blake2b.digest/hexdigest/update.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra88.blake2b_method_class_names:
  description: "hashlib.blake2b/copy/__class__/__name__.__eq__('method_descriptor')==True / blake2b/digest/__class__/__name__.__eq__('method_descriptor')==True / blake2b/hexdigest/__class__/__name__.__eq__('method_descriptor')==True / blake2b/update/__class__/__name__.__eq__('method_descriptor')==True — all four blake2b instance methods are C-level method_descriptor objects from the _blake2 extension; hashlib_extra87 anchors copy's class; this table cross-checks digest/hexdigest/update; first __class__.__name__ anchor for hashlib.blake2b.digest/hexdigest/update"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra88

  columns: [id, function, args, expected]
  rows:
    - [blake2b_copy_class_method_desc,      blake2b.copy.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [blake2b_digest_class_method_desc,    blake2b.digest.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [blake2b_hexdigest_class_method_desc, blake2b.hexdigest.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [blake2b_update_class_method_desc,    blake2b.update.__class__.__name__.__eq__,    ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.copy/__qualname__/__eq__('blake2b.copy')
# hashlib.blake2b.digest/__qualname__/__eq__('blake2b.digest')
# hashlib.blake2b.__name__/__eq__('blake2b')
# hashlib.blake2s.copy/__qualname__/__eq__('blake2s.copy')
#
# Wave 251 theme: blake2b/blake2s method __qualname__ string equality and blake2b.__name__.
#
# blake2b.copy.__qualname__.__eq__('blake2b.copy') == True.
# blake2b.digest.__qualname__.__eq__('blake2b.digest') == True.
# blake2b.__name__.__eq__('blake2b') == True.
# blake2s.copy.__qualname__.__eq__('blake2s.copy') == True.
# No prior hashlib spec checks __qualname__.__eq__ for blake2b/blake2s instance methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra88.blake2b_qualname_eq_and_name:
  description: "hashlib.blake2b/copy/__qualname__/__eq__('blake2b.copy')==True / blake2b/digest/__qualname__/__eq__('blake2b.digest')==True / blake2b/__name__/__eq__('blake2b')==True / blake2s/copy/__qualname__/__eq__('blake2s.copy')==True — blake2b/blake2s instance method __qualname__ strings include the class prefix; blake2b.__name__ is 'blake2b'; no prior hashlib spec checks __qualname__.__eq__ for blake2b/blake2s methods; first __qualname__.__eq__ anchor for hashlib.blake2b/blake2s instance methods"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra88

  columns: [id, function, args, expected]
  rows:
    - [blake2b_copy_qualname_eq,    blake2b.copy.__qualname__.__eq__,    ["blake2b.copy"],    true]
    - [blake2b_digest_qualname_eq,  blake2b.digest.__qualname__.__eq__,  ["blake2b.digest"],  true]
    - [blake2b_name_eq,             blake2b.__name__.__eq__,             ["blake2b"],         true]
    - [blake2s_copy_qualname_eq,    blake2s.copy.__qualname__.__eq__,    ["blake2s.copy"],    true]

# ---------------------------------------------------------------------------
# hashlib.blake2b.copy.__qualname__.__len__() == 12 — standalone
#
# blake2b.copy.__qualname__ is 'blake2b.copy' (len 12). No prior hashlib spec
# checks blake2b.copy.__qualname__.__len__(). First __qualname__.__len__()
# standalone for hashlib.blake2b.copy. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra88.blake2b_copy_qualname_len_12:
  description: "hashlib.blake2b.copy.__qualname__.__len__() == 12 — 'blake2b.copy' is 12 characters; no prior hashlib spec checks blake2b.copy.__qualname__.__len__(); first __qualname__.__len__ standalone for hashlib.blake2b.copy"
  category: class_attrs
  kind: python_call_eq
  function: "blake2b.copy.__qualname__.__len__"
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# hashlib.blake2b.hexdigest.__qualname__.__len__() == 17 — standalone
#
# blake2b.hexdigest.__qualname__ is 'blake2b.hexdigest' (len 17). No prior
# hashlib spec checks blake2b.hexdigest.__qualname__.__len__(). First
# __qualname__.__len__() standalone for hashlib.blake2b.hexdigest.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra88.blake2b_hexdigest_qualname_len_17:
  description: "hashlib.blake2b.hexdigest.__qualname__.__len__() == 17 — 'blake2b.hexdigest' is 17 characters; no prior hashlib spec checks blake2b.hexdigest.__qualname__.__len__(); first __qualname__.__len__ standalone for hashlib.blake2b.hexdigest"
  category: class_attrs
  kind: python_call_eq
  function: "blake2b.hexdigest.__qualname__.__len__"
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# hashlib.blake2b.digest.__class__.__name__.__eq__('method_descriptor') — standalone
#
# blake2b.digest.__class__.__name__ is 'method_descriptor'. No prior hashlib
# spec checks blake2b.digest.__class__.__name__. First __class__.__name__
# standalone for hashlib.blake2b.digest. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra88.blake2b_digest_class_method_desc:
  description: "hashlib.blake2b.digest.__class__.__name__.__eq__('method_descriptor') == True — blake2b.digest is a C-level method_descriptor from the _blake2 extension; no prior hashlib spec checks blake2b.digest.__class__.__name__; first __class__.__name__ standalone for hashlib.blake2b.digest"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.digest.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2b.__name__.__eq__('blake2b') — standalone
#
# blake2b.__name__ is 'blake2b'. No prior hashlib spec checks
# blake2b.__name__.__eq__('blake2b') as a string-equality call.
# First __name__.__eq__ standalone for hashlib.blake2b.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra88.blake2b_name_eq:
  description: "hashlib.blake2b.__name__.__eq__('blake2b') == True — blake2b.__name__ is 'blake2b'; hashlib_extra86 anchors __name__ as a value check; this standalone anchors it as an __eq__ call; first __name__.__eq__ standalone for hashlib.blake2b"
  category: class_attrs
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.blake2s.copy.__qualname__.__len__() == 12 — standalone
#
# blake2s.copy.__qualname__ is 'blake2s.copy' (len 12). No prior hashlib spec
# checks blake2s.copy.__qualname__.__len__(). First __qualname__.__len__()
# standalone for hashlib.blake2s.copy. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra88.blake2s_copy_qualname_len_12:
  description: "hashlib.blake2s.copy.__qualname__.__len__() == 12 — 'blake2s.copy' is 12 characters (mirrors blake2b.copy's length); no prior hashlib spec checks blake2s.copy.__qualname__.__len__(); first __qualname__.__len__ standalone for hashlib.blake2s.copy"
  category: class_attrs
  kind: python_call_eq
  function: "blake2s.copy.__qualname__.__len__"
