spec: decimal_extra57
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra56.zspec.zsdl — covers decimal.__loader__.__class__.__name__.__eq__('SourceFileLoader') and __len__()==16; decimal.__spec__.origin.__class__.__name__.__eq__('str'); decimal.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType'); decimal.__spec__.has_location.__eq__(True)."
    - "decimal_extra55.zspec.zsdl — covers decimal.__loader__.__class__.__name__.__eq__('SourceFileLoader') and __len__()==16; decimal.__file__/__cached__ __class__.__name__.__eq__('str')."
    - "decimal_extra29.zspec.zsdl — covers Context.add/subtract/multiply/divide/sqrt/power/divmod/remainder/normalize/exp/ln/log10 __qualname__.__len__() values."
    - "decimal_extra23.zspec.zsdl — covers Context.create_decimal/quantize and Context.add/multiply/subtract __qualname__.__eq__()."
    - "decimal_extra22.zspec.zsdl — covers Decimal.__add__/__mul__/__neg__/__abs__/__sub__/__truediv__ __qualname__.__eq__(); Decimal.__pos__/__int__/__float__ __qualname__.__len__()."
    - "decimal_extra21.zspec.zsdl — covers Decimal.__add__/__mul__/__neg__/__abs__ __qualname__.__len__()."
  notes:
    - "This spec extends decimal_extra56.zspec.zsdl."
    - "Wave 227 theme: Class method __qualname__ string equality checks for methods not yet covered."
    - "Decimal comparison and conversion dunder __qualname__.__eq__() — Decimal is a C extension type (decimal module). Decimal.__lt__/__le__/__gt__/__ge__/__eq__/__ne__ are wrapper_descriptors with __qualname__=='Decimal.<dunder>'. Decimal.__pos__/__int__/__float__/__floordiv__/__mod__/__pow__ are also wrapper_descriptors or method_descriptors. Prior decimal specs cover __add__/__mul__/__neg__/__abs__/__sub__/__truediv__ __qualname__.__eq__(). The comparison operators (__lt__/__le__/__gt__/__ge__/__eq__/__ne__) and remaining arithmetic (__floordiv__/__mod__/__pow__/__pos__/__int__/__float__) __qualname__.__eq__() are not yet covered. Novel equality anchors in decqual57 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Context arithmetic method __qualname__.__eq__() — decimal_extra29 covers Context method __qualname__.__len__() for exp/ln/log10/divmod/remainder/normalize/power; decimal_extra23 covers Context.add/subtract/multiply/divide/sqrt and create_decimal/quantize __qualname__.__eq__(). Context.exp/ln/log10/divmod/remainder/normalize/power __qualname__.__eq__() string equality forms are not yet covered. Novel equality anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal comparison dunder method __qualname__.__eq__()
#
# Decimal is a C extension type. Its comparison operators are wrapper_descriptors
# defined directly on Decimal. Their __qualname__ follows 'Decimal.<dunder>'.
#
#   Decimal.__lt__.__qualname__ == 'Decimal.__lt__'  (len 14)
#   Decimal.__le__.__qualname__ == 'Decimal.__le__'  (len 14)
#   Decimal.__gt__.__qualname__ == 'Decimal.__gt__'  (len 14)
#   Decimal.__ge__.__qualname__ == 'Decimal.__ge__'  (len 14)
#   Decimal.__eq__.__qualname__ == 'Decimal.__eq__'  (len 14)
#   Decimal.__ne__.__qualname__ == 'Decimal.__ne__'  (len 14)
#
# No prior decimal spec checks __qualname__.__eq__() for any comparison dunder.
# Novel equality anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra57.decimal_comparison_qualnames:
  description: "Decimal.__lt__/__le__/__gt__/__ge__/__eq__/__ne__ __qualname__.__eq__() — Decimal is C extension type; comparison operators are wrapper_descriptors with __qualname__=='Decimal.<dunder>' (all 14 chars); no prior decimal spec checks __qualname__.__eq__() for any Decimal comparison operator; novel equality anchors in decqual57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_method_identity
  id_prefix: decqual57dcmp

  columns: [id, function, args, expected]
  rows:
    - [lt_qualname_eq, "Decimal.__lt__.__qualname__.__eq__", ["Decimal.__lt__"], true]
    - [le_qualname_eq, "Decimal.__le__.__qualname__.__eq__", ["Decimal.__le__"], true]
    - [gt_qualname_eq, "Decimal.__gt__.__qualname__.__eq__", ["Decimal.__gt__"], true]
    - [ge_qualname_eq, "Decimal.__ge__.__qualname__.__eq__", ["Decimal.__ge__"], true]
    - [eq_qualname_eq, "Decimal.__eq__.__qualname__.__eq__", ["Decimal.__eq__"], true]
    - [ne_qualname_eq, "Decimal.__ne__.__qualname__.__eq__", ["Decimal.__ne__"], true]

# ---------------------------------------------------------------------------
# Decimal arithmetic and conversion dunder __qualname__.__eq__()
#
# The following Decimal dunder methods have not had __qualname__.__eq__()
# checked in prior specs:
#   __floordiv__ (wrapper_descriptor, len 20), __mod__ (len 15),
#   __pow__ (len 15), __pos__ (len 15), __int__ (len 15), __float__ (len 17)
#
# decimal_extra22 covers __pos__/__int__/__float__ __qualname__.__len__() and
# __add__/__mul__/__neg__/__abs__/__sub__/__truediv__ __qualname__.__eq__().
# None of __floordiv__/__mod__/__pow__/__pos__/__int__/__float__ have
# __qualname__.__eq__() string equality checks yet.
# Novel equality anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra57.decimal_arith_qualnames:
  description: "Decimal.__floordiv__/__mod__/__pow__/__pos__/__int__/__float__ __qualname__.__eq__() — Decimal is C extension type; all are wrapper_descriptors with __qualname__=='Decimal.<dunder>'; decimal_extra22 covers __qualname__.__len__() for __pos__/__int__/__float__ and __qualname__.__eq__() for __add__/__mul__/__neg__/__abs__/__sub__/__truediv__ but NOT for __floordiv__/__mod__/__pow__/__pos__/__int__/__float__; novel equality anchors in decqual57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_method_identity
  id_prefix: decqual57darith

  columns: [id, function, args, expected]
  rows:
    - [floordiv_qualname_eq, "Decimal.__floordiv__.__qualname__.__eq__", ["Decimal.__floordiv__"], true]
    - [mod_qualname_eq,      "Decimal.__mod__.__qualname__.__eq__",      ["Decimal.__mod__"],      true]
    - [pow_qualname_eq,      "Decimal.__pow__.__qualname__.__eq__",      ["Decimal.__pow__"],      true]
    - [pos_qualname_eq,      "Decimal.__pos__.__qualname__.__eq__",      ["Decimal.__pos__"],      true]
    - [int_qualname_eq,      "Decimal.__int__.__qualname__.__eq__",      ["Decimal.__int__"],      true]
    - [float_qualname_eq,    "Decimal.__float__.__qualname__.__eq__",    ["Decimal.__float__"],    true]

# ---------------------------------------------------------------------------
# Context arithmetic method __qualname__.__eq__()
#
# Context is a C extension type. Its arithmetic methods are method_descriptors
# with __qualname__ following 'Context.<method>'. decimal_extra29 covers their
# __qualname__.__len__() values; decimal_extra23 covers Context.add/subtract/
# multiply/divide/sqrt/create_decimal/quantize __qualname__.__eq__(). The
# remaining Context methods (exp, ln, log10, divmod, remainder, normalize,
# power) have not had __qualname__.__eq__() checked yet.
#
#   Context.exp.__qualname__       == 'Context.exp'       (len 11)
#   Context.ln.__qualname__        == 'Context.ln'        (len 10)
#   Context.log10.__qualname__     == 'Context.log10'     (len 13)
#   Context.divmod.__qualname__    == 'Context.divmod'    (len 14)
#   Context.remainder.__qualname__ == 'Context.remainder' (len 17)
#   Context.normalize.__qualname__ == 'Context.normalize' (len 17)
#   Context.power.__qualname__     == 'Context.power'     (len 13)
#
# Novel equality anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra57.context_method_qualnames:
  description: "Context.exp/ln/log10/divmod/remainder/normalize/power __qualname__.__eq__() — Context is C extension type; method_descriptors with __qualname__=='Context.<method>'; decimal_extra29 covers __qualname__.__len__() for all seven; decimal_extra23 covers Context.add/subtract/multiply/divide/sqrt/create_decimal/quantize __qualname__.__eq__() but not these seven; novel equality anchors in decqual57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_method_identity
  id_prefix: decqual57ctx

  columns: [id, function, args, expected]
  rows:
    - [exp_qualname_eq,       Context.exp.__qualname__.__eq__,       ["Context.exp"],       true]
    - [ln_qualname_eq,        Context.ln.__qualname__.__eq__,        ["Context.ln"],        true]
    - [log10_qualname_eq,     Context.log10.__qualname__.__eq__,     ["Context.log10"],     true]
    - [divmod_qualname_eq,    Context.divmod.__qualname__.__eq__,    ["Context.divmod"],    true]
    - [remainder_qualname_eq, Context.remainder.__qualname__.__eq__, ["Context.remainder"], true]
    - [normalize_qualname_eq, Context.normalize.__qualname__.__eq__, ["Context.normalize"], true]
    - [power_qualname_eq,     Context.power.__qualname__.__eq__,     ["Context.power"],     true]

invariant decimal_extra57.decimal_lt_qualname_eq:
  description: "Decimal.__lt__.__qualname__.__eq__('Decimal.__lt__') == True — Decimal is C extension type; __lt__ is a wrapper_descriptor with __qualname__=='Decimal.__lt__' (14 chars); no prior decimal spec checks __qualname__.__eq__() for Decimal.__lt__; novel equality anchor in decqual57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: "Decimal.__lt__.__qualname__.__eq__"
  args: ["Decimal.__lt__"]
  expected: true

invariant decimal_extra57.decimal_floordiv_qualname_eq:
  description: "Decimal.__floordiv__.__qualname__.__eq__('Decimal.__floordiv__') == True — Decimal is C extension type; __floordiv__ is a wrapper_descriptor with __qualname__=='Decimal.__floordiv__' (20 chars); no prior decimal spec checks __qualname__.__eq__() for Decimal.__floordiv__; novel equality anchor in decqual57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: "Decimal.__floordiv__.__qualname__.__eq__"
  args: ["Decimal.__floordiv__"]
  expected: true

invariant decimal_extra57.context_exp_qualname_eq:
  description: "Context.exp.__qualname__.__eq__('Context.exp') == True — Context is C extension type; exp is a method_descriptor with __qualname__=='Context.exp' (11 chars); decimal_extra29 covers __qualname__.__len__()==11; no prior decimal spec checks __qualname__.__eq__() for Context.exp; novel equality anchor in decqual57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: Context.exp.__qualname__.__eq__
  args: ["Context.exp"]
  expected: true

invariant decimal_extra57.context_ln_qualname_eq:
  description: "Context.ln.__qualname__.__eq__('Context.ln') == True — Context is C extension type; ln is a method_descriptor with __qualname__=='Context.ln' (10 chars); decimal_extra29 covers __qualname__.__len__()==10; no prior decimal spec checks __qualname__.__eq__() for Context.ln; novel equality anchor in decqual57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: Context.ln.__qualname__.__eq__
  args: ["Context.ln"]
  expected: true

invariant decimal_extra57.context_remainder_qualname_eq:
  description: "Context.remainder.__qualname__.__eq__('Context.remainder') == True — Context is C extension type; remainder is a method_descriptor with __qualname__=='Context.remainder' (17 chars); decimal_extra29 covers __qualname__.__len__()==17; no prior decimal spec checks __qualname__.__eq__() for Context.remainder; novel equality anchor in decqual57 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_method_identity
  kind: python_call_eq
  function: Context.remainder.__qualname__.__eq__
  args: ["Context.remainder"]
  expected: true
