spec: upper_case_first
version: ">=2.0.2"
backend: node(upper-case-first)

docs: https://www.npmjs.com/package/upper-case-first

provenance:
  derived_from:
    - "upper-case-first README — https://www.npmjs.com/package/upper-case-first"
    - "Test vectors verified with upper-case-first via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "upper-case-first source"
  notes:
    - "upper-case-first is an npm package. Install: npm install upper-case-first"
    - "Uppercases the first character of a string, leaving the rest unchanged."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table upper_case_first.convert:
  kind: node_module_call_eq
  function: upperCaseFirst
  category: strings
  id_prefix: ucf

  columns: [id, args, expected]
  rows:
    - [lower,  ["hello world"], "Hello world"]
    - [upper,  ["HELLO"],       "HELLO"]
    - [single, ["a"],           "A"]
    - [mixed,  ["fOOBAR"],      "FOOBAR"]
