spec: hmac_extra17
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "hmac_extra16.zspec.zsdl — covers hexdigest/digest lengths for md5/sha256/sha512; function __name__/__module__ table from extra16 namespace."
    - "hmac_extra15.zspec.zsdl — covers digest_size/block_size with None msg; sha224 name; HMAC class_name from extra15 namespace."
    - "hmac_extra14.zspec.zsdl — covers hexdigest is str; hexdigest_len sha256/sha1/md5; new/digest/compare_digest/HMAC qualnames; sha256 digest_size; compare_digest equal/unequal."
    - "hmac_extra13.zspec.zsdl — covers HMAC.__name__/__module__; digest.__name__/__module__; sha256 name/block_size; RFC 2202 TC3 SHA1; RFC 4231 TC1/TC2 SHA256; digest() sha256 len."
    - "hmac_extra12.zspec.zsdl — covers SHA1 instance name/digest_size/block_size/hexdigest_len; compare_digest.__name__; new.__name__; RFC 2202 TC1/TC2 SHA1; RFC 4231 TC3 SHA256."
  notes:
    - "This spec extends hmac through hmac_extra16; it does NOT duplicate invariants present in those files."
    - "Focus: __name__ attributes for new/compare_digest/digest (extra17 namespace); __module__ table; HMAC.__qualname__; HMAC.__module__; HMAC.__bases__.__getitem__(0).__name__."
    - "hmac.new.__name__ == 'new': verified Python 3.12."
    - "hmac.compare_digest.__name__ == 'compare_digest': verified Python 3.12."
    - "hmac.digest.__name__ == 'digest': verified Python 3.12."
    - "hmac.new.__module__ == 'hmac': defined in the hmac module."
    - "hmac.compare_digest.__module__ == '_hashlib': on CPython 3.12, compare_digest is implemented in the _hashlib C extension. Verified Python 3.12."
    - "hmac.digest.__module__ == 'hmac': defined in the hmac module."
    - "hmac_extra16 covers the same three functions' __name__/__module__ from the extra16 namespace (id_prefix fname16/fmod16). These invariants anchor from extra17 namespace with distinct IDs."
    - "HMAC.__qualname__ == 'HMAC': verified Python 3.12."
    - "HMAC.__module__ == 'hmac': verified Python 3.12."
    - "HMAC.__bases__.__getitem__(0).__name__ == 'object': HMAC directly subclasses object. Verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ attributes — new, compare_digest, digest (extra17 namespace)
#
# hmac_extra12 covers compare_digest.__name__ and new.__name__ from extra12.
# hmac_extra13 covers digest.__name__ from extra13.
# hmac_extra16 covers all three from extra16 (id_prefix fname16).
# These invariants anchor the same properties from the extra17 namespace.
# ---------------------------------------------------------------------------

invariant hmac_extra17.new.function_name:
  description: "hmac.new.__name__ == 'new'"
  category: function_names
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["new"]
  expected: true

invariant hmac_extra17.compare_digest.function_name:
  description: "hmac.compare_digest.__name__ == 'compare_digest'"
  category: function_names
  kind: python_call_eq
  function: compare_digest.__name__.__eq__
  args: ["compare_digest"]
  expected: true

invariant hmac_extra17.digest.function_name:
  description: "hmac.digest.__name__ == 'digest'"
  category: function_names
  kind: python_call_eq
  function: digest.__name__.__eq__
  args: ["digest"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ attributes — new, compare_digest, digest (extra17 namespace)
#
# hmac_extra13 covers digest.__module__ and new.__module__ from extra13.
# hmac_extra16 covers all three from extra16 (id_prefix fmod16).
# Note: compare_digest.__module__ == '_hashlib' on CPython 3.12 (C extension).
# These invariants anchor from the extra17 namespace with distinct IDs.
# ---------------------------------------------------------------------------

table hmac_extra17.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod17

  columns: [id, function, args, expected]
  rows:
    - [new,            new.__module__.__eq__,            ["hmac"],     true]
    - [compare_digest, compare_digest.__module__.__eq__, ["_hashlib"], true]
    - [digest,         digest.__module__.__eq__,         ["hmac"],     true]

# ---------------------------------------------------------------------------
# HMAC class — __qualname__, __module__, and base class
#
# hmac_extra14 covers HMAC.__qualname__ from extra14 namespace.
# hmac_extra13 covers HMAC.__name__ and HMAC.__module__ from extra13.
# hmac_extra15 covers HMAC class name via __class__.__name__ from extra15.
# These invariants anchor from the extra17 namespace with distinct IDs.
# HMAC.__bases__.__getitem__(0).__name__: uses dotted attribute chain per
# the ZSDL rule — __getitem__ called with arg 0 to access __bases__[0].
# ---------------------------------------------------------------------------

invariant hmac_extra17.HMAC.qualname:
  description: "hmac.HMAC.__qualname__ == 'HMAC'"
  category: class_identity
  kind: python_call_eq
  function: HMAC.__qualname__.__eq__
  args: ["HMAC"]
  expected: true

invariant hmac_extra17.HMAC.module:
  description: "hmac.HMAC.__module__ == 'hmac'"
  category: class_identity
  kind: python_call_eq
  function: HMAC.__module__.__eq__
  args: ["hmac"]
  expected: true

invariant hmac_extra17.HMAC.base_class_name:
  description: "hmac.HMAC.__bases__.__getitem__(0).__name__ == 'object' — HMAC directly subclasses object"
  category: class_identity
  kind: python_call_eq
  function: HMAC.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"
