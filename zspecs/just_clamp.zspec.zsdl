spec: just_clamp
version: ">=4.2.0"
backend: node(just-clamp)

docs: https://www.npmjs.com/package/just-clamp

provenance:
  derived_from:
    - "just-clamp README — https://www.npmjs.com/package/just-clamp"
    - "Test vectors verified with just-clamp via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "just-clamp source"
  notes:
    - "just-clamp is an npm package. Install: npm install just-clamp"
    - "Clamps a number between min and max values."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_clamp.clamp:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: jclamp

  columns: [id, args, expected]
  rows:
    - [in_range,   [5, 1, 10],  5]
    - [below_min,  [0, 1, 10],  1]
    - [above_max,  [15, 1, 10], 10]

