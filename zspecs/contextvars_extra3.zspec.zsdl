spec: contextvars_extra3
version: ">=3.7"
backend: python_module(contextvars)

docs: https://docs.python.org/3/library/contextvars.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextvars.html — Python contextvars documentation"
    - "PEP 567 — Context Variables (https://peps.python.org/pep-0567/)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_contextvars.py or C extension internals"
  notes:
    - "This spec extends contextvars.zspec.zsdl and contextvars_extra2.zspec.zsdl with new axes."
    - "contextvars.zspec.zsdl covers: class names/modules for ContextVar/Context/Token; copy_context.__name__ and return type; ContextVar.get() with str and None defaults; Token/ContextVar base class == object; Token.MISSING.__class__.__name__ == 'object'."
    - "contextvars_extra2.zspec.zsdl covers: ContextVar/__qualname__; Token.__qualname__; Context.__bases__[0].__name__ == 'object'; Context.__bases__.__len__() == 1; copy_context.__module__ == 'contextvars'; ContextVar.__module__ standalone; ContextVar.get() with int default; ContextVar.name property; Token.MISSING.__class__.__name__.__len__() > 0; Context.__class__.__name__ == 'type'."
    - "NEW in this spec: ContextVar.__bases__.__len__() == 1 (not yet checked); Token.__bases__.__len__() == 1; copy_context.__class__.__name__ == 'builtin_function_or_method'; Context.__qualname__ == 'Context'; ContextVar.get() with bool default (True); Token.MISSING.__class__.__qualname__ == 'object'; ContextVar.__name__ length == 11 (len('ContextVar') + 1 is wrong — 'ContextVar' is 10 chars); Token.__module__ via standalone invariant."
    - "contextvars.ContextVar.__bases__.__len__() == 1 — ContextVar has exactly one direct base (object)."
    - "contextvars.Token.__bases__.__len__() == 1 — Token has exactly one direct base (object)."
    - "contextvars.copy_context.__class__.__name__ == 'builtin_function_or_method' — copy_context is a C builtin."
    - "contextvars.Context.__qualname__ == 'Context' — top-level class, qualname equals name."
    - "contextvars.ContextVar('v').get(True) == True — bool default is returned unchanged when variable is unset."
    - "contextvars.Token.MISSING.__class__.__qualname__ == 'object' — the MISSING sentinel is a plain object instance."
    - "contextvars.ContextVar.__name__.__len__() == 10 — 'ContextVar' is 10 characters."
    - "contextvars.Token.__module__ == 'contextvars' — standalone invariant not previously present."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ContextVar and Token __bases__.__len__() == 1
#
# contextvars.zspec.zsdl checks __bases__[0].__name__ == 'object' for both.
# contextvars_extra2 checks Context.__bases__.__len__() == 1.
# Not yet checked: the bases length for ContextVar and Token themselves.
# ---------------------------------------------------------------------------

invariant contextvars_extra3.ContextVar.bases_len:
  description: "len(contextvars.ContextVar.__bases__) == 1 — ContextVar has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: ContextVar.__bases__.__len__
  args: []
  expected: 1

invariant contextvars_extra3.Token.bases_len:
  description: "len(contextvars.Token.__bases__) == 1 — Token has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: Token.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# copy_context type — builtin_function_or_method
#
# contextvars.zspec.zsdl checks copy_context.__name__ == 'copy_context'.
# contextvars_extra2 checks copy_context.__module__ == 'contextvars'.
# No prior spec verifies the __class__.__name__ of copy_context itself,
# confirming it is a C-level builtin (not a Python function).
# ---------------------------------------------------------------------------

invariant contextvars_extra3.copy_context.class_name:
  description: "contextvars.copy_context.__class__.__name__ == 'builtin_function_or_method' — copy_context is a C builtin"
  category: functions
  kind: python_call_eq
  function: copy_context.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# Context.__qualname__ == 'Context'
#
# contextvars.zspec.zsdl checks Context.__name__ == 'Context'.
# contextvars_extra2 checks ContextVar.__qualname__ and Token.__qualname__.
# Not yet verified: Context.__qualname__ — a top-level class whose qualname
# must equal its name.
# ---------------------------------------------------------------------------

invariant contextvars_extra3.Context.qualname:
  description: "contextvars.Context.__qualname__ == 'Context' — top-level class, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: Context.__qualname__.__eq__
  args: ["Context"]
  expected: true

# ---------------------------------------------------------------------------
# ContextVar.get() with a bool default
#
# contextvars.zspec.zsdl tests get() with str and None defaults.
# contextvars_extra2 tests get() with int default (42).
# No prior spec tests get() with a bool default. True is a valid Python
# default; when the variable is unset, get() must return the bool as-is.
# ---------------------------------------------------------------------------

invariant contextvars_extra3.contextvar.get_default_bool:
  description: "ContextVar('v').get(True) == True — bool default is returned unchanged when variable is unset"
  category: behavior
  kind: python_call_eq
  function: ContextVar
  args: ["v"]
  method: get
  method_args: [true]
  expected: true

# ---------------------------------------------------------------------------
# Token.MISSING.__class__.__qualname__ == 'object'
#
# contextvars.zspec.zsdl checks Token.MISSING.__class__.__name__ == 'object'.
# contextvars_extra2 checks .__len__() > 0 on that name.
# No prior spec checks the __qualname__ of the MISSING sentinel's class.
# For a plain object instance, __class__.__qualname__ == 'object'.
# ---------------------------------------------------------------------------

invariant contextvars_extra3.token_missing.class_qualname:
  description: "Token.MISSING.__class__.__qualname__ == 'object' — the MISSING sentinel is a plain object instance"
  category: constants
  kind: python_call_eq
  function: Token.MISSING.__class__.__qualname__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# ContextVar.__name__ string length == 10
#
# 'ContextVar' is 10 characters long. No prior spec verifies the length of
# the __name__ attribute for ContextVar. This is a structural check distinct
# from the equality check already in contextvars.zspec.zsdl.
# ---------------------------------------------------------------------------

invariant contextvars_extra3.ContextVar.name_len:
  description: "len(contextvars.ContextVar.__name__) == 10 — 'ContextVar' has 10 characters"
  category: class_names
  kind: python_call_eq
  function: ContextVar.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# Token.__module__ standalone invariant
#
# contextvars.zspec.zsdl checks Token.__module__ in a table row alongside
# ContextVar and Context. No prior spec has a standalone invariant for
# Token.__module__. This adds it as an isolated invariant for completeness.
# ---------------------------------------------------------------------------

invariant contextvars_extra3.Token.module_standalone:
  description: "contextvars.Token.__module__ == 'contextvars' — standalone invariant"
  category: module
  kind: python_call_eq
  function: Token.__module__.__eq__
  args: ["contextvars"]
  expected: true
