spec: html_extra
version: ">=3.2"
backend: python_module(html)

docs: https://docs.python.org/3/library/html.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.html — Python html module documentation"
    - "Test vectors verified by running Python 3.14.3 html module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/html/__init__.py"
  notes:
    - "This spec covers aspects of html not in html.zspec.zsdl, html_entities.zspec.zsdl, or html_parser.zspec.zsdl."
    - "html.escape('<>&\"') == '&lt;&gt;&amp;&quot;' — all four special chars escaped by default."
    - "html.escape('<>&\"', quote=False) == '&lt;&gt;&amp;\"' — quote=False leaves double-quote unchanged."
    - "html.unescape('&lt;&gt;&amp;') == '<>&' — named entities decoded."
    - "escape and unescape are both defined in the html module; __module__ == 'html'."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# html.escape — function identity
# ---------------------------------------------------------------------------

invariant html_extra.escape.name:
  description: "html.escape.__name__ == 'escape'"
  category: identity
  kind: python_call_eq
  function: escape.__name__.__eq__
  args: ["escape"]
  expected: true

invariant html_extra.escape.module:
  description: "html.escape.__module__ == 'html'"
  category: identity
  kind: python_call_eq
  function: escape.__module__.__eq__
  args: ["html"]
  expected: true

# ---------------------------------------------------------------------------
# html.unescape — function identity
# ---------------------------------------------------------------------------

invariant html_extra.unescape.name:
  description: "html.unescape.__name__ == 'unescape'"
  category: identity
  kind: python_call_eq
  function: unescape.__name__.__eq__
  args: ["unescape"]
  expected: true

invariant html_extra.unescape.module:
  description: "html.unescape.__module__ == 'html'"
  category: identity
  kind: python_call_eq
  function: unescape.__module__.__eq__
  args: ["html"]
  expected: true

# ---------------------------------------------------------------------------
# html.escape — combined multi-character inputs (not in html.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant html_extra.escape.lt_gt_amp_dquote_default:
  description: "html.escape('<>&\"') == '&lt;&gt;&amp;&quot;' — all four chars escaped with default quote=True"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["<>&\""]
  expected: "&lt;&gt;&amp;&quot;"

invariant html_extra.escape.lt_gt_amp_dquote_noquote:
  description: "html.escape('<>&\"', quote=False) == '&lt;&gt;&amp;\"' — quote=False leaves double-quote unchanged"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["<>&\""]
  kwargs: {quote: false}
  expected: "&lt;&gt;&amp;\""

# ---------------------------------------------------------------------------
# html.unescape — combined entity string (not in html.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant html_extra.unescape.lt_gt_amp_combined:
  description: "html.unescape('&lt;&gt;&amp;') == '<>&'"
  category: unescape
  kind: python_call_eq
  function: unescape
  args: ["&lt;&gt;&amp;"]
  expected: "<>&"
