spec: sys_extra30
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
    - "sys_extra29.zspec.zsdl — covers __module__.__len__()==3 for getdefaultencoding/getfilesystemencoding/getsizeof/exit; __name__.__len__() for getdefaultencoding/getfilesystemencoding/getsizeof/exit/intern/exc_info/getrecursionlimit/setrecursionlimit."
  notes:
    - "This spec extends sys_extra29.zspec.zsdl."
    - "Prior specs covered: __module__.__len__()==3 and __name__.__len__() for sys built-in functions; stdin/stdout/stderr __class__.__name__; version_info __class__.__name__; getrecursionlimit()==1000; __name__/__package__ for module itself."
    - "This spec covers: __class__.__name__.__len__() for sys.version/argv/path/modules/stdin/platform/version_info; __class__.__name__.__eq__() eq-checks for sys.version/argv/path/modules/stdin/platform/version_info."
    - "sys.version.__class__.__name__=='str' (len 3). Verified."
    - "sys.argv.__class__.__name__=='list' (len 4). Verified."
    - "sys.path.__class__.__name__=='list' (len 4). Verified."
    - "sys.modules.__class__.__name__=='dict' (len 4). Verified."
    - "sys.stdin.__class__.__name__=='TextIOWrapper' (len 13). Verified."
    - "sys.platform.__class__.__name__=='str' (len 3). Verified."
    - "sys.version_info.__class__.__name__=='version_info' (len 12). Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __class__.__name__.__len__() for sys attributes
#
# No prior sys spec checks __len__() on __class__.__name__ for module-level
# attributes. This table covers version/argv/path/modules/stdin/platform/version_info.
# Lengths: str=3, list=4, dict=4, TextIOWrapper=13, version_info=12.
# Verified: version=3, argv=4, path=4, modules=4, stdin=13, platform=3, version_info=12.
# ---------------------------------------------------------------------------

table sys_extra30.attr_class_name_lengths:
  description: "__class__.__name__.__len__() for sys module attributes"
  kind: python_call_eq
  category: type_attrs
  id_prefix: acnlen30

  columns: [id, function, args, expected]
  rows:
    - [version,      version.__class__.__name__.__len__,      [], 3]
    - [argv,         argv.__class__.__name__.__len__,         [], 4]
    - [path,         path.__class__.__name__.__len__,         [], 4]
    - [modules,      modules.__class__.__name__.__len__,      [], 4]
    - [stdin,        stdin.__class__.__name__.__len__,        [], 13]
    - [platform,     platform.__class__.__name__.__len__,     [], 3]
    - [version_info, version_info.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Table: __class__.__name__.__eq__() for sys attributes
#
# No prior sys spec checks __class__.__name__.__eq__() for these module-level
# attributes. This table groups the eq-checks alongside the length table above
# for a dense, readable cross-reference.
# Verified: all values below.
# ---------------------------------------------------------------------------

table sys_extra30.attr_class_name_eq:
  description: "__class__.__name__.__eq__() for sys module attributes confirming exact type names"
  kind: python_call_eq
  category: type_attrs
  id_prefix: acneq30

  columns: [id, function, args, expected]
  rows:
    - [version,      version.__class__.__name__.__eq__,      ["str"],           true]
    - [argv,         argv.__class__.__name__.__eq__,         ["list"],          true]
    - [path,         path.__class__.__name__.__eq__,         ["list"],          true]
    - [modules,      modules.__class__.__name__.__eq__,      ["dict"],          true]
    - [stdin,        stdin.__class__.__name__.__eq__,        ["TextIOWrapper"], true]
    - [platform,     platform.__class__.__name__.__eq__,     ["str"],           true]
    - [version_info, version_info.__class__.__name__.__eq__, ["version_info"],  true]

# ---------------------------------------------------------------------------
# Standalone: sys.stdin.__class__.__name__.__len__() == 13
#
# sys.stdin is a TextIOWrapper. len('TextIOWrapper') == 13. This is the longest
# class name among the sys attributes in this spec and merits a standalone
# invariant for emphasis. No prior sys spec checks __len__() on this string.
# Verified: 13.
# ---------------------------------------------------------------------------

invariant sys_extra30.stdin.class_name_len:
  description: "sys.stdin.__class__.__name__.__len__() == 13 — 'TextIOWrapper' has 13 characters"
  category: type_attrs
  kind: python_call_eq
  function: stdin.__class__.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# Standalone: sys.version_info.__class__.__name__.__len__() == 12
#
# sys.version_info is an instance of the named tuple subclass 'version_info'.
# len('version_info') == 12. No prior sys spec checks __len__() on this string.
# Verified: 12.
# ---------------------------------------------------------------------------

invariant sys_extra30.version_info.class_name_len:
  description: "sys.version_info.__class__.__name__.__len__() == 12 — 'version_info' has 12 characters"
  category: type_attrs
  kind: python_call_eq
  function: version_info.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Standalone: sys.modules.__class__.__name__.__len__() == 4
#
# sys.modules is a dict. len('dict') == 4. No prior sys spec checks __len__()
# on sys.modules.__class__.__name__.
# Verified: 4.
# ---------------------------------------------------------------------------

invariant sys_extra30.modules.class_name_len:
  description: "sys.modules.__class__.__name__.__len__() == 4 — 'dict' has 4 characters"
  category: type_attrs
  kind: python_call_eq
  function: modules.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: sys.argv.__class__.__name__.__len__() == 4
#
# sys.argv is a list. len('list') == 4. No prior sys spec checks __len__()
# on sys.argv.__class__.__name__.
# Verified: 4.
# ---------------------------------------------------------------------------

invariant sys_extra30.argv.class_name_len:
  description: "sys.argv.__class__.__name__.__len__() == 4 — 'list' has 4 characters"
  category: type_attrs
  kind: python_call_eq
  function: argv.__class__.__name__.__len__
  args: []
  expected: 4
