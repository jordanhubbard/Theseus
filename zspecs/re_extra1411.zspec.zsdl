spec: re_extra1411
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers __sizeof__ method type/presence and __reduce_ex__ method type/presence for re module classes. re.error.__name__=='PatternError' (renamed from 'error' in Python 3.13; re.error is still the canonical name but __name__ is 'PatternError', len=12). re.Pattern.__sizeof__.__class__.__name__=='method_descriptor' (Pattern is a C-level type from _sre; '__sizeof__' not in re.Pattern.__dict__). re.Match.__sizeof__.__class__.__name__=='method_descriptor'. None of the re classes (error/PatternError, Pattern, Match) have '__sizeof__' or '__reduce_ex__' in their own __dict__. re.error.__mro__.__len__()==4 (MRO: [PatternError, Exception, BaseException, object]). re.Pattern.__mro__.__len__()==2. re.Match.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "re.error.__name__=='PatternError' (not 'error') in Python 3.13+; len=12. re.Pattern.__name__=='Pattern' (len=7). re.Match.__name__=='Match' (len=5). re.error.__module__=='re'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re class __sizeof__ type and dict presence checks — extra1411
#
# re.error.__sizeof__.__class__.__name__         == 'method_descriptor'
# re.error.__dict__.__contains__('__sizeof__')  == False
# re.Pattern.__sizeof__.__class__.__name__       == 'method_descriptor'
# re.Pattern.__dict__.__contains__('__sizeof__')== False
# re.Match.__sizeof__.__class__.__name__         == 'method_descriptor'
# re.Match.__dict__.__contains__('__sizeof__')  == False
# ---------------------------------------------------------------------------

table re_extra1411.re_sizeof_type:
  description: "re class __sizeof__ method type and __dict__ presence checks — wave 541 extra1411 theme. re.error.__sizeof__.__class__.__name__=='method_descriptor' (PatternError inherits __sizeof__ from BaseException/object chain; not in its own __dict__). re.error.__dict__.__contains__('__sizeof__')==False. re.Pattern.__sizeof__.__class__.__name__=='method_descriptor' (Pattern is a C-level type from _sre; __sizeof__ not in its own __dict__). re.Pattern.__dict__.__contains__('__sizeof__')==False. re.Match.__sizeof__.__class__.__name__=='method_descriptor'. re.Match.__dict__.__contains__('__sizeof__')==False. None of the three re classes define __sizeof__ in their own __dict__; all inherit it. All verified with Python 3.14.3."
  kind: python_call_eq
  category: sizeof_introspection
  id_prefix: re1411sz

  columns: [id, function, args, expected, description]
  rows:
    - [re1411sz001, re.error.__sizeof__.__class__.__name__.__eq__,   ["method_descriptor"], true,  "re.error.__sizeof__.__class__.__name__ == 'method_descriptor' (PatternError inherits from BaseException chain); verified with Python 3.14.3"]
    - [re1411sz002, re.error.__dict__.__contains__,                  ["__sizeof__"],         false, "re.error.__dict__.__contains__('__sizeof__') == False (not in PatternError's own dict); verified with Python 3.14.3"]
    - [re1411sz003, re.Pattern.__sizeof__.__class__.__name__.__eq__, ["method_descriptor"], true,  "re.Pattern.__sizeof__.__class__.__name__ == 'method_descriptor' (C-level type from _sre); verified with Python 3.14.3"]
    - [re1411sz004, re.Pattern.__dict__.__contains__,                ["__sizeof__"],         false, "re.Pattern.__dict__.__contains__('__sizeof__') == False; verified with Python 3.14.3"]
    - [re1411sz005, re.Match.__sizeof__.__class__.__name__.__eq__,   ["method_descriptor"], true,  "re.Match.__sizeof__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]
    - [re1411sz006, re.Match.__dict__.__contains__,                  ["__sizeof__"],         false, "re.Match.__dict__.__contains__('__sizeof__') == False; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# re class __reduce_ex__ type and dict presence checks — extra1411
#
# re.error.__reduce_ex__.__class__.__name__          == 'method_descriptor'
# re.error.__dict__.__contains__('__reduce_ex__')   == False
# re.Pattern.__reduce_ex__.__class__.__name__        == 'method_descriptor'
# re.Pattern.__dict__.__contains__('__reduce_ex__') == False
# re.Match.__reduce_ex__.__class__.__name__          == 'method_descriptor'
# re.Match.__dict__.__contains__('__reduce_ex__')   == False
# ---------------------------------------------------------------------------

table re_extra1411.re_reduce_ex_type:
  description: "re class __reduce_ex__ method type and __dict__ presence checks — wave 541 extra1411 theme. re.error.__reduce_ex__.__class__.__name__=='method_descriptor' (PatternError inherits __reduce_ex__ from BaseException; MRO is [PatternError, Exception, BaseException, object] len=4). re.error.__dict__.__contains__('__reduce_ex__')==False. re.Pattern.__reduce_ex__.__class__.__name__=='method_descriptor' (Pattern is a C-level immutable type; __reduce_ex__ not in its own dict). re.Pattern.__dict__.__contains__('__reduce_ex__')==False. re.Match.__reduce_ex__.__class__.__name__=='method_descriptor'. re.Match.__dict__.__contains__('__reduce_ex__')==False. All three re classes inherit __reduce_ex__ without defining it in their own __dict__. All verified with Python 3.14.3."
  kind: python_call_eq
  category: reduce_ex_introspection
  id_prefix: re1411rx

  columns: [id, function, args, expected, description]
  rows:
    - [re1411rx001, re.error.__reduce_ex__.__class__.__name__.__eq__,   ["method_descriptor"], true,  "re.error.__reduce_ex__.__class__.__name__ == 'method_descriptor' (inherits from BaseException; MRO len=4); verified with Python 3.14.3"]
    - [re1411rx002, re.error.__dict__.__contains__,                     ["__reduce_ex__"],      false, "re.error.__dict__.__contains__('__reduce_ex__') == False; verified with Python 3.14.3"]
    - [re1411rx003, re.Pattern.__reduce_ex__.__class__.__name__.__eq__, ["method_descriptor"], true,  "re.Pattern.__reduce_ex__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]
    - [re1411rx004, re.Pattern.__dict__.__contains__,                   ["__reduce_ex__"],      false, "re.Pattern.__dict__.__contains__('__reduce_ex__') == False; verified with Python 3.14.3"]
    - [re1411rx005, re.Match.__reduce_ex__.__class__.__name__.__eq__,   ["method_descriptor"], true,  "re.Match.__reduce_ex__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]
    - [re1411rx006, re.Match.__dict__.__contains__,                     ["__reduce_ex__"],      false, "re.Match.__dict__.__contains__('__reduce_ex__') == False; verified with Python 3.14.3"]
    - [re1411rx007, re.error.__mro__.__len__,                           [],                    4,     "re.error.__mro__.__len__() == 4 ([PatternError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [re1411rx008, re.error.__name__.__len__,                          [],                    12,    "re.error.__name__.__len__() == 12 ('PatternError'=12 chars; renamed from 'error' in Python 3.13); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# re class MRO length and name checks — extra1411
#
# re.Pattern.__mro__.__len__()   == 2  ([Pattern, object])
# re.Match.__mro__.__len__()     == 2  ([Match, object])
# re.error.__mro__.__len__()     == 4  ([PatternError, Exception, BaseException, object])
# re.error.__name__.__len__()    == 12 ('PatternError')
# re.Pattern.__name__.__len__()  == 7  ('Pattern')
# re.Match.__name__.__len__()    == 5  ('Match')
# ---------------------------------------------------------------------------

table re_extra1411.re_mro_and_name:
  description: "re class MRO length and class name length checks — wave 541 extra1411. re.Pattern.__mro__.__len__()==2 ([Pattern, object]; Pattern is a C-level type from _sre that does not subclass any Python-level base). re.Match.__mro__.__len__()==2 ([Match, object]; likewise a C-level type). re.error.__mro__.__len__()==4 ([PatternError, Exception, BaseException, object]; deepest chain in this batch because PatternError is a proper Python exception). re.error.__name__.__len__()==12 ('PatternError'=12 chars; renamed from 'error' in Python 3.13; re.error alias still works but __name__ is 'PatternError'). re.Pattern.__name__.__len__()==7 ('Pattern'=7 chars). re.Match.__name__.__len__()==5 ('Match'=5 chars; shortest in this batch). re.Pattern.__name__.__eq__('Pattern')==True. re.Match.__name__.__eq__('Match')==True. All verified with Python 3.14.3."
  kind: python_call_eq
  category: mro_identity
  id_prefix: re1411mr

  columns: [id, function, args, expected, description]
  rows:
    - [re1411mr001, re.Pattern.__mro__.__len__,          [], 2,  "re.Pattern.__mro__.__len__() == 2 ([Pattern, object]; C-level type, no Python base); verified with Python 3.14.3"]
    - [re1411mr002, re.Match.__mro__.__len__,            [], 2,  "re.Match.__mro__.__len__() == 2 ([Match, object]; C-level type); verified with Python 3.14.3"]
    - [re1411mr003, re.error.__mro__.__len__,            [], 4,  "re.error.__mro__.__len__() == 4 ([PatternError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [re1411mr004, re.error.__name__.__len__,           [], 12, "re.error.__name__.__len__() == 12 ('PatternError'=12 chars; renamed from 'error' in Python 3.13); verified with Python 3.14.3"]
    - [re1411mr005, re.Pattern.__name__.__len__,         [], 7,  "re.Pattern.__name__.__len__() == 7 ('Pattern'=7 chars); verified with Python 3.14.3"]
    - [re1411mr006, re.Match.__name__.__len__,           [], 5,  "re.Match.__name__.__len__() == 5 ('Match'=5 chars); verified with Python 3.14.3"]
    - [re1411mr007, re.Pattern.__name__.__eq__,          ["Pattern"], true, "re.Pattern.__name__ == 'Pattern'; verified with Python 3.14.3"]
    - [re1411mr008, re.error.__name__.__eq__,            ["PatternError"], true, "re.error.__name__ == 'PatternError' (canonical class name in Python 3.13+); verified with Python 3.14.3"]
