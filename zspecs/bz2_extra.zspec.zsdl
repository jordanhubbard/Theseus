spec: bz2_extra
version: ">=3.0"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/bz2.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "bz2 source: Lib/bz2.py (PSF; source inspection permitted)"
  not_derived_from:
    - "bz2 source: internal C extension _bz2 implementation details"
  notes:
    - "Complements bz2.zspec.zsdl which covers compress/decompress roundtrip, magic bytes, and class identity."
    - "bz2.BZ2File.__name__ == 'BZ2File' — the file-like class for bzip2-compressed I/O."
    - "bz2.BZ2Compressor.__name__ == 'BZ2Compressor' — incremental compressor."
    - "bz2.BZ2Decompressor.__name__ == 'BZ2Decompressor' — incremental decompressor."
    - "bz2.BZ2File.__module__ == 'bz2' — all public bz2 classes live in the bz2 module."
    - "bz2.compress.__name__ == 'compress' — top-level convenience function."
    - "bz2.decompress.__name__ == 'decompress' — top-level convenience function."
    - "bz2.open.__name__ == 'open' — module-level open that wraps BZ2File."
    - "bz2.compress(b'hello') returns a bytes object."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks
# ---------------------------------------------------------------------------

table bz2_extra.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [BZ2File,         BZ2File.__name__.__eq__,         ["BZ2File"],         true]
    - [BZ2Compressor,   BZ2Compressor.__name__.__eq__,   ["BZ2Compressor"],   true]
    - [BZ2Decompressor, BZ2Decompressor.__name__.__eq__, ["BZ2Decompressor"], true]

# ---------------------------------------------------------------------------
# Module membership checks
# ---------------------------------------------------------------------------

invariant bz2_extra.BZ2File.module:
  description: "bz2.BZ2File.__module__ == 'bz2'"
  category: modules
  kind: python_call_eq
  function: BZ2File.__module__.__eq__
  args: ["bz2"]
  expected: true

invariant bz2_extra.BZ2Compressor.module:
  description: "bz2.BZ2Compressor.__module__ == 'bz2'"
  category: modules
  kind: python_call_eq
  function: BZ2Compressor.__module__.__eq__
  args: ["bz2"]
  expected: true

invariant bz2_extra.BZ2Decompressor.module:
  description: "bz2.BZ2Decompressor.__module__ == 'bz2'"
  category: modules
  kind: python_call_eq
  function: BZ2Decompressor.__module__.__eq__
  args: ["bz2"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

table bz2_extra.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__name__.__eq__,   ["compress"],   true]
    - [decompress, decompress.__name__.__eq__, ["decompress"], true]
    - [open,       open.__name__.__eq__,       ["open"],       true]

# ---------------------------------------------------------------------------
# compress() — output is bytes
# ---------------------------------------------------------------------------

invariant bz2_extra.compress.returns_bytes:
  description: "bz2.compress(b'hello').__class__.__name__ == 'bytes'"
  category: compress
  kind: python_call_eq
  function: compress
  args: [{type: bytes_ascii, value: "hello"}]
  method: __class__
  method_chain: __name__
  expected: "bytes"
