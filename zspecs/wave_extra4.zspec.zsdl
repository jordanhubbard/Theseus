spec: wave_extra4
version: ">=3.9"
backend: python_module(wave)

docs: https://docs.python.org/3/library/wave.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/wave.html — Python wave module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/wave.py"
    - "wave.zspec.zsdl — covers Wave_read/Wave_write/Error __name__ (table), module checks (table), open __name__, Error base, type checks (table), Wave_read/Wave_write method names (tables)"
    - "wave_extra.zspec.zsdl — covers Wave_read/Wave_write/Error __name__ (table), open __name__, Wave_read.__module__, Error.__bases__[0].__name__"
    - "wave_extra2.zspec.zsdl — covers open/__name__/__class__.__name__, Wave_read/__name__/__module__/__class__.__name__, Wave_write/__name__/__module__/__class__.__name__, Error/__name__/__module__/__base__/__class__.__name__"
    - "wave_extra3.zspec.zsdl — covers __qualname__ for Wave_read, Wave_write, Error, open; open.__module__"
  notes:
    - "This spec extends all prior wave specs."
    - "Focus: __bases__.__len__ and direct base class name for Wave_read, Wave_write, and Error."
    - "Wave_read and Wave_write each inherit directly from object (one base class)."
    - "wave.Error inherits directly from Exception (one base class); this __len__ check is new."
    - "wave.Error.__bases__.__len__ is not covered by any prior spec (prior specs only check __bases__[0].__name__)."
    - "wave.Wave_read.__bases__[0].__name__ and wave.Wave_write.__bases__[0].__name__ are not covered by any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__.__len__ checks for Wave_read, Wave_write, and Error
# Prior specs check __bases__[0].__name__ for Error only; __len__ is new for all three.
# ---------------------------------------------------------------------------

invariant wave_extra4.Wave_read.bases_len:
  description: "len(wave.Wave_read.__bases__) == 1 — Wave_read has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Wave_read.__bases__.__len__
  args: []
  expected: 1

invariant wave_extra4.Wave_write.bases_len:
  description: "len(wave.Wave_write.__bases__) == 1 — Wave_write has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Wave_write.__bases__.__len__
  args: []
  expected: 1

invariant wave_extra4.Error.bases_len:
  description: "len(wave.Error.__bases__) == 1 — Error has exactly one direct base class (Exception)"
  category: class_hierarchy
  kind: python_call_eq
  function: Error.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Direct base class name for Wave_read and Wave_write
# Prior specs only check Error.__bases__[0].__name__; Wave_read and Wave_write are new.
# In CPython 3.9+, Wave_read and Wave_write both inherit directly from object.
# ---------------------------------------------------------------------------

invariant wave_extra4.Wave_read.base_is_object:
  description: "wave.Wave_read.__bases__[0].__name__ == 'object' — Wave_read inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Wave_read.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant wave_extra4.Wave_write.base_is_object:
  description: "wave.Wave_write.__bases__[0].__name__ == 'object' — Wave_write inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Wave_write.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# Method type-identity checks — Wave_read and Wave_write methods are functions
# Prior specs check method __name__ and __qualname__; __class__.__name__ is new.
# For methods accessed on a class (unbound), __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table wave_extra4.Wave_read.method_types:
  kind: python_call_eq
  category: method_identity
  id_prefix: wave_read_method_type

  columns: [id, function, args, expected]
  rows:
    - [getnchannels, Wave_read.getnchannels.__class__.__name__.__eq__, ["function"], true]
    - [getsampwidth, Wave_read.getsampwidth.__class__.__name__.__eq__, ["function"], true]
    - [getframerate, Wave_read.getframerate.__class__.__name__.__eq__, ["function"], true]
    - [getnframes,   Wave_read.getnframes.__class__.__name__.__eq__,   ["function"], true]
    - [readframes,   Wave_read.readframes.__class__.__name__.__eq__,   ["function"], true]
    - [close,        Wave_read.close.__class__.__name__.__eq__,        ["function"], true]
