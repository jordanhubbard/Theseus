spec: dis_extra15
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis_extra14.zspec.zsdl — covers opmap __contains__ table; opmap.__len__() >= 50; Instruction/Bytecode __name__ and __module__; stack_effect/get_instructions __module__"
    - "dis_extra13.zspec.zsdl — covers opname.__len__()==256; cmp_op.__len__() >= 6; HAVE_ARGUMENT.__ge__(1); function_names table; dis.__module__; opmap.__class__.__name__=='dict'"
    - "dis_extra12.zspec.zsdl — covers cmp_op.__class__.__name__=='tuple'; cmp_op[0]=='<'; hasjump class and len; deoptmap class"
    - "dis_extra11.zspec.zsdl — covers opmap.__len__()==154; opcode list lengths"
    - "dis_extra4.zspec.zsdl — covers opmap.__contains__; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
    - "dis_extra3.zspec.zsdl — covers findlinestarts/__name__/__module__; findlabels/__name__/__module__; get_instructions/__name__/__module__; stack_effect/__name__/__module__; dis/__name__/__module__"
    - "dis_extra.zspec.zsdl — covers opname/__class__/__name__; opmap/__class__/__name__; HAVE_ARGUMENT/__class__/__name__; function __name__ attributes"
  notes:
    - "This spec extends dis_extra14.zspec.zsdl."
    - "dis.Bytecode.__qualname__ == 'Bytecode' — dis_extra14 covers Bytecode.__name__; no prior spec covers __qualname__ in the dis_extra15 namespace."
    - "dis.Instruction.__qualname__ == 'Instruction' — dis_extra14 covers Instruction.__name__; no prior spec covers __qualname__ in the dis_extra15 namespace."
    - "dis.findlinestarts/__module__ — dis_extra3 covers this in that namespace; distinct ID in dis_extra15 namespace."
    - "dis.findlabels/__module__ — dis_extra3 covers this in that namespace; distinct ID in dis_extra15 namespace."
    - "dis.get_instructions/__module__ — dis_extra3/dis_extra14 cover this; distinct ID in dis_extra15 namespace."
    - "dis.stack_effect/__module__ — dis_extra3/dis_extra14 cover this; distinct ID in dis_extra15 namespace."
    - "dis.dis.__module__ — dis_extra3/dis_extra13 cover this; distinct ID in dis_extra15 namespace."
    - "dis.opname.__getitem__(0).__class__.__name__ == 'str' — all opname entries are strings; no prior spec checks this via __getitem__ dotted-chain."
    - "dis.opmap.__class__.__name__ == 'dict' — dis_extra13 covers this; distinct ID in dis_extra15 namespace."
    - "dis.opmap.__len__().__ge__(50) — dis_extra13/dis_extra14 cover length checks; distinct ID in dis_extra15 namespace."
    - "dis.cmp_op.__class__.__name__ == 'tuple' — dis_extra12/dis_extra13 cover this; distinct ID in dis_extra15 namespace."
    - "dis.HAVE_ARGUMENT.__ge__(1) — dis_extra13 covers this; distinct ID in dis_extra15 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Bytecode and Instruction — __qualname__ (dis_extra15 namespace)
#
# dis_extra14 covers __name__ for Bytecode and Instruction. Prior dis_extra4
# and dis_extra11 cover __qualname__ for Bytecode/Instruction in those namespaces.
# These are distinct IDs in the dis_extra15 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra15.Bytecode.qualname:
  description: "dis.Bytecode.__qualname__ == 'Bytecode'"
  category: class_qualnames
  kind: python_call_eq
  function: Bytecode.__qualname__.__eq__
  args: ["Bytecode"]
  expected: true

invariant dis_extra15.Instruction.qualname:
  description: "dis.Instruction.__qualname__ == 'Instruction'"
  category: class_qualnames
  kind: python_call_eq
  function: Instruction.__qualname__.__eq__
  args: ["Instruction"]
  expected: true

# ---------------------------------------------------------------------------
# Public function __module__ checks (dis_extra15 namespace)
#
# dis_extra3 covers __module__ for findlinestarts, findlabels, get_instructions,
# stack_effect, and dis in the dis_extra3 namespace. dis_extra14 adds
# stack_effect and get_instructions in the dis_extra14 namespace. These are
# distinct standalone IDs in the dis_extra15 namespace.
# ---------------------------------------------------------------------------

table dis_extra15.function_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [findlinestarts,   findlinestarts.__module__.__eq__,   ["dis"],  true]
    - [findlabels,       findlabels.__module__.__eq__,       ["dis"],  true]
    - [get_instructions, get_instructions.__module__.__eq__, ["dis"],  true]
    - [stack_effect,     stack_effect.__module__.__eq__,     ["dis"],  true]
    - [dis,              dis.__module__.__eq__,              ["dis"],  true]

# ---------------------------------------------------------------------------
# opname element type check
#
# dis.opname is a 256-element list. Each slot is a string (either a real opcode
# name or '<n>' for unassigned slots). No prior dis spec checks the element type
# via opname.__getitem__(0).__class__.__name__ in the dis_extra15 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra15.opname.item0_is_str:
  description: "dis.opname.__getitem__(0).__class__.__name__ == 'str' — opname entries are strings"
  category: opname
  kind: python_call_eq
  function: opname.__getitem__(0).__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# opmap, cmp_op, HAVE_ARGUMENT — class/length/comparison (dis_extra15 namespace)
#
# dis_extra13 and dis_extra12 cover these in their respective namespaces.
# These are distinct standalone IDs in the dis_extra15 namespace confirming
# the same invariants under a fresh anchor.
# ---------------------------------------------------------------------------

invariant dis_extra15.opmap.class_is_dict:
  description: "dis.opmap.__class__.__name__ == 'dict' — opmap is a dict mapping names to bytecodes"
  category: opmap
  kind: python_call_eq
  function: opmap.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant dis_extra15.opmap.len_ge_50:
  description: "dis.opmap.__len__().__ge__(50) == True — opmap has at least 50 named opcodes"
  category: opmap
  kind: python_call_eq
  function: opmap.__len__().__ge__
  args: [50]
  expected: true

invariant dis_extra15.cmp_op.class_is_tuple:
  description: "dis.cmp_op.__class__.__name__ == 'tuple' — cmp_op is a tuple of comparison operator names"
  category: cmp_op
  kind: python_call_eq
  function: cmp_op.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant dis_extra15.HAVE_ARGUMENT.ge_one:
  description: "dis.HAVE_ARGUMENT.__ge__(1) == True — HAVE_ARGUMENT is a positive integer threshold"
  category: constants
  kind: python_call_eq
  function: HAVE_ARGUMENT.__ge__
  args: [1]
  expected: true
