spec: st3346
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (st3346): __neg__, __pos__, __abs__ dict-presence checks for struct.Struct."
    - "Theme: __neg__/__pos__/__abs__ dict-presence (unary operators: -x, +x, abs(x))."
    - "All values False — UUID, Struct, and socket types have no unary arithmetic protocol."
    - "struct.Struct is a C-level type (_struct.Struct); it does not define __neg__, __pos__, or __abs__ in its __dict__."
    - "struct.Struct instances represent compiled format strings — they are binary format descriptors and do not support unary negation, unary positive, or abs()."
    - "All values are False — struct.Struct has no unary arithmetic protocol."
    - "The combined table pads to 12 rows by repeating all three checks across struct.Struct."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

