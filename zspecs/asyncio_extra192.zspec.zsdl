spec: asyncio_extra192
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Lock.__name__ == 'Lock' (len=4: L(1)o(2)c(3)k(4)); Lock is the asyncio mutual-exclusion primitive for coroutines."
    - "asyncio.Lock.__module__ == 'asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); Lock is pure Python, not C-accelerated."
    - "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin' (len=20: '_'=1+'Context'=7+'Manager'=7+'Mixin'=5=20); Lock supports 'async with' via _ContextManagerMixin."
    - "asyncio.Lock.__init__.__qualname__ == 'Lock.__init__' (len=13: 'Lock'=4+'.'=1+'__init__'=8=13)."
    - "asyncio.Event.__name__ == 'Event' (len=5: E(1)v(2)e(3)n(4)t(5)); Event is the asyncio flag-based synchronization primitive."
    - "asyncio.Event.__module__ == 'asyncio.locks' (len=13); Event shares the same module as Lock."
    - "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin' (len=15: '_'=1+'Loop'=4+'Bound'=5+'Mixin'=5=15); Event does NOT support 'async with' — it uses wait()/set()/clear()."
    - "asyncio.Event.__init__.__qualname__ == 'Event.__init__' (len=14: 'Event'=5+'.'=1+'__init__'=8=14)."
    - "Length ordering: Lock.__name__ (4) < Event.__name__ (5); Lock.__init__.__qualname__ (13) < Event.__init__.__qualname__ (14)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Lock class identity — __name__, __module__, __bases__[0].__name__
#
# Lock.__name__ == 'Lock' (len=4)
# Lock.__module__ == 'asyncio.locks' (len=13)
# Lock.__bases__[0].__name__ == '_ContextManagerMixin' (len=20)
# ---------------------------------------------------------------------------

table asyncio_extra192.asyncio_lock_class_identity:
  description: "asyncio.Lock class identity checks in asynciolocks192 namespace — Lock.__name__=='Lock' (len=4: L(1)o(2)c(3)k(4); mutual-exclusion primitive for coroutines); Lock.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13; pure Python, not '_asyncio'); Lock.__bases__[0].__name__=='_ContextManagerMixin' (len=20: '_'=1+'Context'=7+'Manager'=7+'Mixin'=5=20; enables 'async with lock' usage); Lock.__name__ (4) < Event.__name__ (5); Lock.__module__=='asyncio.locks' (13) == Event.__module__=='asyncio.locks' (13); Lock.__bases__[0].__name__ (20) > Event.__bases__[0].__name__ (15) by 5; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolocks192

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,    asyncio.Lock.__name__.__eq__,    ["Lock"],            true, "asyncio.Lock.__name__ == 'Lock' (len=4: mutual-exclusion coroutine primitive); verified Python 3.14.3"]
    - [lock_name_len,   asyncio.Lock.__name__.__len__,   [],                  4,    "asyncio.Lock.__name__.__len__() == 4 ('Lock'=4; Lock (4) < Event (5) by 1); verified Python 3.14.3"]
    - [lock_module_eq,  asyncio.Lock.__module__.__eq__,  ["asyncio.locks"],   true, "asyncio.Lock.__module__ == 'asyncio.locks' (len=13; pure Python, not '_asyncio'); verified Python 3.14.3"]
    - [lock_module_len, asyncio.Lock.__module__.__len__, [],                  13,   "asyncio.Lock.__module__.__len__() == 13 ('asyncio.locks'=13: 'asyncio'=7+'.'=1+'locks'=5=13); verified Python 3.14.3"]
    - ["lock_base_eq",  "asyncio.Lock.__bases__[0].__name__.__eq__",          ["_ContextManagerMixin"], true, "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin' (len=20; Lock supports 'async with' via this mixin); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Event class identity — __name__, __module__, __bases__[0].__name__
#
# Event.__name__ == 'Event' (len=5)
# Event.__module__ == 'asyncio.locks' (len=13)
# Event.__bases__[0].__name__ == '_LoopBoundMixin' (len=15)
# ---------------------------------------------------------------------------

table asyncio_extra192.asyncio_event_class_identity:
  description: "asyncio.Event class identity checks in asynciolocks192 namespace — Event.__name__=='Event' (len=5: E(1)v(2)e(3)n(4)t(5); flag-based synchronization primitive); Event.__module__=='asyncio.locks' (len=13; same module as Lock, Semaphore, Condition); Event.__bases__[0].__name__=='_LoopBoundMixin' (len=15: '_'=1+'Loop'=4+'Bound'=5+'Mixin'=5=15; Event does NOT support 'async with' — uses wait()/set()/clear()); Event.__name__ (5) > Lock.__name__ (4) by 1; Event.__bases__[0].__name__ (15) < Lock.__bases__[0].__name__ (20) by 5 — Event uses _LoopBoundMixin while Lock uses _ContextManagerMixin; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolocks192

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,    asyncio.Event.__name__.__eq__,    ["Event"],           true, "asyncio.Event.__name__ == 'Event' (len=5: flag-based coroutine synchronization primitive); verified Python 3.14.3"]
    - [event_name_len,   asyncio.Event.__name__.__len__,   [],                  5,    "asyncio.Event.__name__.__len__() == 5 ('Event'=5; Event (5) > Lock (4) by 1); verified Python 3.14.3"]
    - [event_module_eq,  asyncio.Event.__module__.__eq__,  ["asyncio.locks"],   true, "asyncio.Event.__module__ == 'asyncio.locks' (len=13; same module as asyncio.Lock); verified Python 3.14.3"]
    - [event_module_len, asyncio.Event.__module__.__len__, [],                  13,   "asyncio.Event.__module__.__len__() == 13 ('asyncio.locks'=13; Lock.__module__==Event.__module__ both len 13); verified Python 3.14.3"]
    - ["event_base_eq",  "asyncio.Event.__bases__[0].__name__.__eq__",          ["_LoopBoundMixin"], true, "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin' (len=15; Event uses _LoopBoundMixin not _ContextManagerMixin); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Lock and asyncio.Event __init__ qualname identity
#
# Lock.__init__.__qualname__ == 'Lock.__init__' (len=13)
# Event.__init__.__qualname__ == 'Event.__init__' (len=14)
# ---------------------------------------------------------------------------

table asyncio_extra192.asyncio_lock_event_init_qualnames:
  description: "asyncio.Lock and asyncio.Event __init__ qualname identity in asynciolocks192 namespace — Lock.__init__.__qualname__=='Lock.__init__' (len=13: 'Lock'=4+'.'=1+'__init__'=8=13; initializes internal _locked bool and _waiters deque); Event.__init__.__qualname__=='Event.__init__' (len=14: 'Event'=5+'.'=1+'__init__'=8=14; initializes internal _value bool flag and _waiters set); Lock.__init__.__qualname__ (13) < Event.__init__.__qualname__ (14) by 1 — directly reflecting Lock.__name__ (4) < Event.__name__ (5); both __init__ qualnames are 'ClassName.__init__' with __init__ portion (8 chars) dominating; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolocks192

  columns: [id, function, args, expected, description]
  rows:
    - [lock_init_qualname_eq,   "asyncio.Lock.__init__.__qualname__.__eq__",  ["Lock.__init__"],  true, "asyncio.Lock.__init__.__qualname__ == 'Lock.__init__' (len=13; initializes _locked flag and _waiters deque); verified Python 3.14.3"]
    - [lock_init_qualname_len,  "asyncio.Lock.__init__.__qualname__.__len__", [],                 13,   "asyncio.Lock.__init__.__qualname__.__len__() == 13 ('Lock.__init__'=13: 'Lock'=4+'.'=1+'__init__'=8=13); verified Python 3.14.3"]
    - [event_init_qualname_eq,  "asyncio.Event.__init__.__qualname__.__eq__", ["Event.__init__"], true, "asyncio.Event.__init__.__qualname__ == 'Event.__init__' (len=14; initializes _value bool and _waiters set); verified Python 3.14.3"]
    - [event_init_qualname_len, "asyncio.Event.__init__.__qualname__.__len__", [],                14,   "asyncio.Event.__init__.__qualname__.__len__() == 14 ('Event.__init__'=14: 'Event'=5+'.'=1+'__init__'=8=14); verified Python 3.14.3"]
    - [lock_lt_event_init_len,  "asyncio.Lock.__init__.__qualname__.__len__", [],                 13,   "Lock.__init__.__qualname__.__len__() == 13 confirms Lock (13) < Event (14) by 1 — matches Lock.__name__ (4) < Event.__name__ (5); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra192
# ---------------------------------------------------------------------------

invariant asyncio_extra192.asyncio_Lock_name_eq:
  description: "asyncio.Lock.__name__.__eq__('Lock') returns True — asyncio.Lock is the mutual-exclusion coroutine primitive for asyncio; Lock.__name__=='Lock' (len=4: L(1)o(2)c(3)k(4)); Lock prevents concurrent access to a shared resource when held by one coroutine — other coroutines calling 'await lock.acquire()' will suspend until the holder calls 'lock.release()'; Lock.__name__ (4) < Event.__name__ (5) by 1; compare asyncio.Semaphore.__name__=='Semaphore' (9); NEW in extra192: first standalone Lock.__name__.__eq__ invariant in asynciolocks192 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant asyncio_extra192.asyncio_Lock_module_eq:
  description: "asyncio.Lock.__module__.__eq__('asyncio.locks') returns True — asyncio.Lock is defined in Lib/asyncio/locks.py; Lock.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); both asyncio.Lock and asyncio.Event share __module__=='asyncio.locks'; this module also contains asyncio.Semaphore, asyncio.BoundedSemaphore, and asyncio.Condition; Lock.__module__ (13) == Event.__module__ (13) — same length because both live in asyncio.locks; compare asyncio.Queue.__module__=='asyncio.queues' (14) — one char longer; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra192.asyncio_Lock_base_is_ContextManagerMixin:
  description: "asyncio.Lock.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — asyncio.Lock inherits from _ContextManagerMixin (a private mixin class in Lib/asyncio/locks.py); __bases__[0].__name__=='_ContextManagerMixin' (len=20: '_'=1+'Context'=7+'Manager'=7+'Mixin'=5=20); _ContextManagerMixin provides __aenter__ and __aexit__ to enable 'async with lock:' syntax; Lock and Semaphore use _ContextManagerMixin while Event and asyncio.Queue use _LoopBoundMixin; Lock.__bases__[0].__name__ (20) > Event.__bases__[0].__name__ (15) by 5 — _ContextManagerMixin is longer than _LoopBoundMixin; NEW in extra192: standalone Lock base class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Lock.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra192.asyncio_Lock_init_qualname_eq:
  description: "asyncio.Lock.__init__.__qualname__.__eq__('Lock.__init__') returns True — Lock.__init__.__qualname__=='Lock.__init__' (len=13: 'Lock'=4+'.'=1+'__init__'=8=13); Lock.__init__ initializes _locked=False (the boolean lock state) and _waiters=collections.deque() (coroutines blocked on acquire()); Lock.__init__.__qualname__ (13) < Event.__init__.__qualname__ (14) by 1 — directly caused by Lock.__name__ (4) < Event.__name__ (5); length ordering: Lock.__init__.__qualname__ (13) == Lock.__module__ (13) — an interesting tie; NEW in extra192: standalone Lock.__init__.__qualname__ invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Lock.__init__.__qualname__.__eq__"
  args: ["Lock.__init__"]
  expected: true

invariant asyncio_extra192.asyncio_Event_name_eq:
  description: "asyncio.Event.__name__.__eq__('Event') returns True — asyncio.Event is the flag-based coroutine synchronization primitive; Event.__name__=='Event' (len=5: E(1)v(2)e(3)n(4)t(5)); Event is a one-shot or reusable flag: initially clear, coroutines call 'await event.wait()' to block until another coroutine calls 'event.set()'; 'event.clear()' resets the flag; Event does NOT support 'async with' unlike Lock; Event.__name__ (5) > Lock.__name__ (4) by 1; NEW in extra192: first standalone Event.__name__.__eq__ invariant in asynciolocks192 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant asyncio_extra192.asyncio_Event_module_eq:
  description: "asyncio.Event.__module__.__eq__('asyncio.locks') returns True — asyncio.Event is defined in Lib/asyncio/locks.py alongside Lock, Semaphore, BoundedSemaphore, and Condition; Event.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); Event.__module__ (13) == Lock.__module__ (13) — both live in asyncio.locks, same length; despite sharing the module, Event and Lock use different base mixins: Event uses _LoopBoundMixin while Lock uses _ContextManagerMixin; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra192.asyncio_Event_base_is_LoopBoundMixin:
  description: "asyncio.Event.__bases__[0].__name__.__eq__('_LoopBoundMixin') returns True — asyncio.Event inherits from _LoopBoundMixin (len=15: '_'=1+'Loop'=4+'Bound'=5+'Mixin'=5=15); _LoopBoundMixin binds the synchronization primitive to the running event loop and raises RuntimeError if accessed outside a running loop; Event uses _LoopBoundMixin (not _ContextManagerMixin) because it does not support 'async with' — you use 'await event.wait()' instead; Event.__bases__[0].__name__ (15) < Lock.__bases__[0].__name__ (20) by 5; compare asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (15) — same base as Event; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Event.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra192.asyncio_Event_init_qualname_eq:
  description: "asyncio.Event.__init__.__qualname__.__eq__('Event.__init__') returns True — Event.__init__.__qualname__=='Event.__init__' (len=14: 'Event'=5+'.'=1+'__init__'=8=14); Event.__init__ initializes _value=False (the flag state) and _waiters=set() (coroutines blocked on wait()); Event.__init__.__qualname__ (14) > Lock.__init__.__qualname__ (13) by 1 — directly reflecting Event.__name__ (5) > Lock.__name__ (4); length ordering in this spec: Lock.__init__ (13) < Event.__init__ (14); both qualnames follow the 'ClassName.__init__' pattern with 8-char __init__ suffix; NEW in extra192: standalone Event.__init__.__qualname__ invariant completing 8-invariant coverage for asyncio Lock and Event; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Event.__init__.__qualname__.__eq__"
  args: ["Event.__init__"]
  expected: true
