spec: re2881
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/re_extra2866.zspec.zsdl — wave 638 predecessor (covered __rand__, __ror__, __rxor__)"
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "Wave 639 theme: __iadd__, __isub__, __imul__ dict-presence checks (in-place augmented assignment operators)."
    - "re.RegexFlag is an IntFlag subclass — IntFlag defines reflected and binary bitwise ops but NOT in-place arithmetic ops (__iadd__, __isub__, __imul__)."
    - "re.RegexFlag.__iadd__, re.RegexFlag.__isub__, and re.RegexFlag.__imul__ are ALL absent (False) — verified with Python 3.14.4."
    - "re.Pattern (type(re.compile(''))) does NOT define any in-place arithmetic operators — compiled patterns are not arithmetic operands."
    - "re.Match (type(re.match('',''))) does NOT define any in-place arithmetic operators — match objects are not arithmetic operands."
    - "The contrast with wave 638 (__rand__/__ror__/__rxor__ present on RegexFlag) highlights that IntFlag supports reflected bitwise ops but not in-place numeric ops."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __iadd__ dict-presence
# RegexFlag: False (IntFlag has no in-place add); Pattern and Match: False
# ---------------------------------------------------------------------------

table re2881.iadd:
  description: "__iadd__ is absent from re.RegexFlag (IntFlag defines bitwise ops, not in-place arithmetic), Pattern, and Match"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2881

  columns: [id, function, args, expected]
  rows:
    - ["re2881001", "re.RegexFlag.__dict__.__contains__",                    ["__iadd__"], false]
    - ["re2881002", "type(re.compile('')).__dict__.__contains__",            ["__iadd__"], false]
    - ["re2881003", "type(re.match('', '')).__dict__.__contains__",          ["__iadd__"], false]
    - ["re2881004", "re.RegexFlag.__dict__.__contains__",                    ["__add__"],  false]
    - ["re2881005", "type(re.compile('')).__dict__.__contains__",            ["__add__"],  false]
    - ["re2881006", "type(re.match('', '')).__dict__.__contains__",          ["__add__"],  false]

