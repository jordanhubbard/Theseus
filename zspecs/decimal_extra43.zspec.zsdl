spec: decimal_extra43
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra42.zspec.zsdl — covers ROUND_* __class__.__qualname__.__eq__('str'); MIN_ETINY.__class__.__name__/__qualname__.__eq__('int')."
    - "decimal_extra41.zspec.zsdl — covers Subnormal/Clamped/FloatOperation __qualname__.__eq__() and __qualname__.__len__(); FloatOperation.__bases__.__len__()==2."
    - "decimal_extra35.zspec.zsdl — covers Decimal.__name__/__qualname__/__module__ lengths."
    - "decimal_extra29.zspec.zsdl — covers Decimal.__class__.__name__.__eq__('type') (repeated in decimal_extra.zspec.zsdl)."
    - "decimal_extra26.zspec.zsdl — covers Context.__name__/__qualname__/__module__ lengths."
    - "decimal_extra17.zspec.zsdl — covers DecimalException.__name__/__qualname__/__module__/__mro__/__bases__ identity."
    - "decimal_extra6.zspec.zsdl — covers getcontext/__name__/__qualname__/__module__ equality."
  notes:
    - "This spec extends decimal_extra42.zspec.zsdl."
    - "Prior specs collectively covered: Decimal.__name__/__qualname__/__module__ equality and lengths (decimal_extra/decimal_extra35); Context.__name__/__qualname__/__module__ equality and lengths (decimal_extra/decimal_extra26); DecimalException.__name__/__qualname__/__module__/__mro__/__bases__ identity (decimal_extra17); getcontext/__name__/__qualname__/__module__ equality (decimal_extra6); Decimal.__class__.__name__.__eq__('type') (decimal_extra29/decimal_extra). NO prior decimal spec checks Decimal.__class__.__name__.__len__() or Decimal.__class__.__qualname__.__eq__('type') via the __qualname__ path. NO prior decimal spec checks Context.__class__.__name__.__len__() or Context.__class__.__qualname__.__eq__('type'). NO prior decimal spec checks getcontext.__class__.__name__ or setcontext.__class__.__name__ or localcontext.__class__.__name__ at all."
    - "This spec covers: decimal.Decimal.__class__.__name__.__len__()==4 (NOVEL — decimal_extra29 checks Decimal.__class__.__name__.__eq__('type'); no prior decimal spec checks Decimal.__class__.__name__.__len__()==4; novel length anchor); decimal.Decimal.__class__.__qualname__.__eq__('type') (NOVEL — no prior decimal spec accesses Decimal.__class__.__qualname__; novel __qualname__ path anchor); decimal.Context.__class__.__name__.__len__()==4 (NOVEL — no prior decimal spec checks Context.__class__.__name__.__len__()); decimal.Context.__class__.__qualname__.__eq__('type') (NOVEL — no prior decimal spec checks Context.__class__.__qualname__); decimal.DecimalException.__class__.__name__.__len__()==4 (NOVEL — decimal_extra17 covers DecimalException identity but not __class__.__name__.__len__(); novel); decimal.getcontext.__class__.__name__.__eq__('builtin_function_or_method') (NOVEL — no prior decimal spec checks getcontext.__class__.__name__ at all); decimal.setcontext.__class__.__name__.__eq__('builtin_function_or_method') (NOVEL); decimal.localcontext.__class__.__name__.__eq__('builtin_function_or_method') (NOVEL)."
    - "decimal.Decimal.__class__.__name__ == 'type' (len 4). Decimal is a C-extension type. Its metaclass is 'type'. decimal_extra29 checks the equality string; no prior decimal spec checks __class__.__name__.__len__(). Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Decimal.__class__.__qualname__ == 'type'. For top-level builtin types, __qualname__==__name__. No prior decimal spec checks Decimal.__class__.__qualname__. Novel __qualname__ path anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.getcontext.__class__.__name__ == 'builtin_function_or_method' (len 26). getcontext is a C-level function from the _decimal module. Its type is builtin_function_or_method. Same for setcontext and localcontext. No prior decimal spec checks __class__.__name__ for any of these functions. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal and decimal.Context __class__.__name__/__qualname__
#
# Decimal and Context are C-extension types from the _decimal module.
# Their metaclass is the standard 'type':
#
#   Decimal.__class__.__name__     == 'type'   -> len 4
#   Decimal.__class__.__qualname__ == 'type'   (same as __name__ for builtins)
#   Context.__class__.__name__     == 'type'   -> len 4
#   Context.__class__.__qualname__ == 'type'
#
# decimal_extra29 covers Decimal.__class__.__name__.__eq__('type').
# No prior decimal spec checks __class__.__name__.__len__() for Decimal
# or __class__.__qualname__ for either class.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra43.Decimal_class_name_len:
  description: "decimal.Decimal.__class__.__name__.__len__() == 4 — 'type' has 4 characters; Decimal is a C-extension type with standard 'type' metaclass; decimal_extra29 checks Decimal.__class__.__name__.__eq__('type') but no prior decimal spec checks __class__.__name__.__len__(); novel length anchor in decimal_extra43 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__class__.__name__.__len__
  args: []
  expected: 4

invariant decimal_extra43.Decimal_class_qualname_eq:
  description: "decimal.Decimal.__class__.__qualname__ == 'type' — for top-level builtin/C-extension types, __qualname__==__name__; no prior decimal spec accesses Decimal.__class__.__qualname__; novel __qualname__ path anchor in decimal_extra43 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra43.Context_class_name_len:
  description: "decimal.Context.__class__.__name__.__len__() == 4 — 'type' has 4 characters; Context is a C-extension type with standard 'type' metaclass; no prior decimal spec checks Context.__class__.__name__.__len__(); novel length anchor in decimal_extra43 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Context.__class__.__name__.__len__
  args: []
  expected: 4

invariant decimal_extra43.Context_class_qualname_eq:
  description: "decimal.Context.__class__.__qualname__ == 'type' — for top-level C-extension types, __qualname__==__name__=='type'; no prior decimal spec checks Context.__class__.__qualname__; novel __qualname__ path anchor in decimal_extra43 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Context.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# decimal.DecimalException.__class__.__name__ length
#
# DecimalException is the base exception class for decimal errors.
# As a regular exception class, its metaclass is the standard 'type':
#
#   DecimalException.__class__.__name__  == 'type'  -> len 4
#
# decimal_extra17 covers DecimalException.__name__/__qualname__/__module__/
# __mro__/__bases__ identity attributes, but does NOT check
# DecimalException.__class__.__name__.__len__().
# Novel length anchor in the decimal_extra43 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra43.DecimalException_class_name_len:
  description: "decimal.DecimalException.__class__.__name__.__len__() == 4 — 'type' has 4 characters; DecimalException is a regular exception class with standard 'type' metaclass; decimal_extra17 covers DecimalException identity attributes but not __class__.__name__.__len__(); novel length anchor in decimal_extra43 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# decimal.getcontext / setcontext / localcontext __class__.__name__
#
# getcontext, setcontext, and localcontext are C-level functions from the
# _decimal module. Their type is builtin_function_or_method:
#
#   getcontext.__class__.__name__   == 'builtin_function_or_method'  -> len 26
#   setcontext.__class__.__name__   == 'builtin_function_or_method'  -> len 26
#   localcontext.__class__.__name__ == 'builtin_function_or_method'  -> len 26
#
# decimal_extra6 covers getcontext/__name__/__qualname__/__module__ equality.
# No prior decimal spec checks __class__.__name__ for any of these functions.
# All three equality anchors are novel in the decimal_extra43 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra43.context_functions_class_names:
  description: "decimal context function __class__.__name__.__eq__('builtin_function_or_method') for getcontext/setcontext/localcontext — all are C-level functions from _decimal module; no prior decimal spec checks __class__.__name__ for any of these functions; all three novel equality anchors in decimal_extra43 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: dcfcn43

  columns: [id, function, args, expected]
  rows:
    - [getcontext_class_name,   getcontext.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [setcontext_class_name,   setcontext.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [localcontext_class_name, localcontext.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
