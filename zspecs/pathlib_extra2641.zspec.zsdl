spec: pathlib_extra2641
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2626.zspec.zsdl — covers __length_hint__/__missing__/__reversed__ dict-presence"
  notes:
    - "Wave 623 (pathlib_extra2641) theme: __copy__, __deepcopy__, and __sizeof__ dict-presence checks."
    - "None of the pathlib classes define __copy__, __deepcopy__, or __sizeof__ in their own __dict__."
    - "__copy__ and __deepcopy__ are copy-protocol hooks; pathlib path objects rely on inherited copy semantics."
    - "__sizeof__ is not overridden in any pathlib path class; memory sizing falls through to the base object implementation."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __copy__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2641.no_copy_in_pathlib_classes:
  description: "__copy__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the copy-protocol __copy__ hook"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2641

  columns: [id, function, args, expected]
  rows:
    - ["pp2641001", "pathlib.PurePath.__dict__.__contains__",        ["__copy__"], false]
    - ["pp2641002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__copy__"], false]
    - ["pp2641003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__copy__"], false]
    - ["pp2641004", "pathlib.Path.__dict__.__contains__",            ["__copy__"], false]

# ---------------------------------------------------------------------------
# __deepcopy__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2641.no_deepcopy_in_pathlib_classes:
  description: "__deepcopy__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the copy-protocol __deepcopy__ hook"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2641

  columns: [id, function, args, expected]
  rows:
    - ["pp2641005", "pathlib.PurePath.__dict__.__contains__",        ["__deepcopy__"], false]
    - ["pp2641006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__deepcopy__"], false]
    - ["pp2641007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__deepcopy__"], false]
    - ["pp2641008", "pathlib.Path.__dict__.__contains__",            ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# __sizeof__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2641.no_sizeof_in_pathlib_classes:
  description: "__sizeof__ is absent from all pathlib class __dict__s — pathlib path classes do not override memory sizing"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2641

  columns: [id, function, args, expected]
  rows:
    - ["pp2641009",  "pathlib.PurePath.__dict__.__contains__",        ["__sizeof__"], false]
    - ["pp2641010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__sizeof__"], false]
    - ["pp2641011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__sizeof__"], false]
    - ["pp2641012", "pathlib.Path.__dict__.__contains__",            ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib classes have path-manipulation methods but not copy-protocol hooks
# Confirms that path objects are domain-specific types, not copy-aware or sized-override types
# ---------------------------------------------------------------------------

table pathlib_extra2641.pathlib_has_path_methods_not_copy_hooks:
  description: "pathlib classes define __str__/parts/name/parent/stat/exists but NOT __copy__/__deepcopy__/__sizeof__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2641

  columns: [id, function, args, expected]
  rows:
    - ["pp2641013", "pathlib.PurePath.__dict__.__contains__", ["__str__"],      true]
    - ["pp2641014", "pathlib.PurePath.__dict__.__contains__", ["parts"],        true]
    - ["pp2641015", "pathlib.PurePath.__dict__.__contains__", ["name"],         true]
    - ["pp2641016", "pathlib.PurePath.__dict__.__contains__", ["parent"],       true]
    - ["pp2641017", "pathlib.PurePath.__dict__.__contains__", ["__copy__"],     false]
    - ["pp2641018", "pathlib.PurePath.__dict__.__contains__", ["__deepcopy__"], false]
    - ["pp2641019", "pathlib.PurePath.__dict__.__contains__", ["__sizeof__"],   false]
    - ["pp2641020", "pathlib.Path.__dict__.__contains__",     ["stat"],         true]
    - ["pp2641021", "pathlib.Path.__dict__.__contains__",     ["exists"],       true]
    - ["pp2641022", "pathlib.Path.__dict__.__contains__",     ["open"],         true]
    - ["pp2641023", "pathlib.Path.__dict__.__contains__",     ["mkdir"],        true]
    - ["pp2641024", "pathlib.Path.__dict__.__contains__",     ["__copy__"],     false]
    - ["pp2641025", "pathlib.Path.__dict__.__contains__",     ["__deepcopy__"], false]
    - ["pp2641026", "pathlib.Path.__dict__.__contains__",     ["__sizeof__"],   false]
