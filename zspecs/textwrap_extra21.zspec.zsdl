spec: textwrap_extra21
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra20.zspec.zsdl."
    - "textwrap_extra20 covers: TextWrapper.__qualname__.__len__()==11; wrap/fill/dedent/indent/shorten __qualname__.__len__() checks; function_qualname_lengths table."
    - "textwrap_extra17 covers: TextWrapper.__name__/'TextWrapper'; TextWrapper.__module__=='textwrap'; TextWrapper.__bases__[0].__name__=='object'; wrap/fill/shorten/indent/dedent __qualname__ values."
    - "textwrap_extra19 covers: TextWrapper.__mro__/__name__/__qualname__/__module__ extra19 anchors; function __name__ table."
    - "No prior spec verifies TextWrapper.__init__.__qualname__, TextWrapper.wrap.__qualname__, or TextWrapper.fill.__qualname__ as standalone invariants."
    - "No prior spec verifies TextWrapper.wrap.__qualname__.__len__() or TextWrapper.fill.__qualname__.__len__() as standalone invariants."
    - "This spec covers: TextWrapper.__init__.__qualname__=='TextWrapper.__init__'; TextWrapper.__init__.__name__=='__init__'; TextWrapper.wrap.__qualname__=='TextWrapper.wrap'; TextWrapper.fill.__qualname__=='TextWrapper.fill'; TextWrapper.wrap.__qualname__.__len__()==16; TextWrapper.fill.__qualname__.__len__()==16; TextWrapper.__init__.__qualname__.__len__()==20."
    - "textwrap.TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__' — method qualname includes the owning class. Verified at runtime."
    - "textwrap.TextWrapper.wrap.__qualname__ == 'TextWrapper.wrap' — method qualname for the wrap method. Verified at runtime."
    - "textwrap.TextWrapper.fill.__qualname__ == 'TextWrapper.fill' — method qualname for the fill method. Verified at runtime."
    - "len('TextWrapper.wrap') == 16; len('TextWrapper.fill') == 16; len('TextWrapper.__init__') == 20. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TextWrapper.__init__ method identity — __qualname__ and __name__
#
# No prior spec verifies TextWrapper.__init__.__qualname__ as a standalone
# invariant. For a method defined in class TextWrapper, __qualname__ takes
# the form 'TextWrapper.__init__'. Verified at runtime.
# ---------------------------------------------------------------------------

invariant textwrap_extra21.TextWrapper.init_qualname:
  description: "textwrap.TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.__init__.__qualname__.__eq__
  args: ["TextWrapper.__init__"]
  expected: true

invariant textwrap_extra21.TextWrapper.init_name:
  description: "textwrap.TextWrapper.__init__.__name__ == '__init__' — constructor method simple name"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper.wrap and TextWrapper.fill method __qualname__
#
# textwrap_extra17 covers the module-level wrap.__qualname__ == 'wrap' and
# fill.__qualname__ == 'fill'. No prior spec verifies TextWrapper.wrap.__qualname__
# or TextWrapper.fill.__qualname__ (the method attribute form), which take the
# form 'TextWrapper.wrap' and 'TextWrapper.fill' respectively.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant textwrap_extra21.TextWrapper.wrap_qualname:
  description: "textwrap.TextWrapper.wrap.__qualname__ == 'TextWrapper.wrap' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.wrap.__qualname__.__eq__
  args: ["TextWrapper.wrap"]
  expected: true

invariant textwrap_extra21.TextWrapper.fill_qualname:
  description: "textwrap.TextWrapper.fill.__qualname__ == 'TextWrapper.fill' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.fill.__qualname__.__eq__
  args: ["TextWrapper.fill"]
  expected: true

# ---------------------------------------------------------------------------
# TextWrapper method __qualname__ string lengths
#
# textwrap_extra20 covers module-level function __qualname__ lengths.
# No prior spec verifies TextWrapper method __qualname__ string lengths.
# 'TextWrapper.wrap' has 16 characters; 'TextWrapper.fill' has 16 characters;
# 'TextWrapper.__init__' has 20 characters. Verified at runtime.
# ---------------------------------------------------------------------------

invariant textwrap_extra21.TextWrapper.wrap_qualname_len:
  description: "textwrap.TextWrapper.wrap.__qualname__.__len__() == 16 — len('TextWrapper.wrap') == 16"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.wrap.__qualname__.__len__
  args: []
  expected: 16

invariant textwrap_extra21.TextWrapper.fill_qualname_len:
  description: "textwrap.TextWrapper.fill.__qualname__.__len__() == 16 — len('TextWrapper.fill') == 16"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.fill.__qualname__.__len__
  args: []
  expected: 16

invariant textwrap_extra21.TextWrapper.init_qualname_len:
  description: "textwrap.TextWrapper.__init__.__qualname__.__len__() == 20 — len('TextWrapper.__init__') == 20"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.__init__.__qualname__.__len__
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# Table: TextWrapper method __qualname__ values
#
# Groups the __qualname__ checks for TextWrapper.__init__, wrap, and fill.
# ---------------------------------------------------------------------------

table textwrap_extra21.TextWrapper_method_qualnames:
  description: "textwrap.TextWrapper method __qualname__ values — __init__, wrap, fill"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [textwrap_extra21.TextWrapper_method_qualnames.init,
       TextWrapper.__init__.__qualname__.__eq__,
       ["TextWrapper.__init__"],
       true,
       "TextWrapper.__init__.__qualname__ == 'TextWrapper.__init__'"]
    - [textwrap_extra21.TextWrapper_method_qualnames.wrap,
       TextWrapper.wrap.__qualname__.__eq__,
       ["TextWrapper.wrap"],
       true,
       "TextWrapper.wrap.__qualname__ == 'TextWrapper.wrap'"]
    - [textwrap_extra21.TextWrapper_method_qualnames.fill,
       TextWrapper.fill.__qualname__.__eq__,
       ["TextWrapper.fill"],
       true,
       "TextWrapper.fill.__qualname__ == 'TextWrapper.fill'"]

# ---------------------------------------------------------------------------
# Table: TextWrapper method __qualname__ string lengths
#
# Groups the string-length checks for TextWrapper method __qualname__ values.
# ---------------------------------------------------------------------------

table textwrap_extra21.TextWrapper_method_qualname_lengths:
  description: "textwrap.TextWrapper method __qualname__ string lengths — __init__(20), wrap(16), fill(16)"
  kind: python_call_eq
  category: function_identity
  id_prefix: tw21mql

  columns: [id, function, args, expected]
  rows:
    - [init_len,  TextWrapper.__init__.__qualname__.__len__,  [], 20]
    - [wrap_len,  TextWrapper.wrap.__qualname__.__len__,      [], 16]
    - [fill_len,  TextWrapper.fill.__qualname__.__len__,      [], 16]
