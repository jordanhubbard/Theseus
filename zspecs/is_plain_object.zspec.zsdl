spec: is_plain_object
version: ">=2.0.0"
backend: node(is-plain-object)

docs: https://github.com/jonschlinkert/is-plain-object#readme

provenance:
  derived_from:
    - "is-plain-object README — https://github.com/jonschlinkert/is-plain-object#readme"
    - "Test vectors verified with is-plain-object@2.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-plain-object source"
  notes:
    - "is-plain-object@2 (CJS) exports the function directly as module.exports."
    - "Returns true if the value is a plain object (created by Object or with null prototype)."
    - "Returns false for arrays, null, class instances, and other non-plain objects."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean. No errors."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_plain_object.check:
  kind: node_module_call_eq
  function: ~
  category: check
  id_prefix: ispo

  columns: [id, args, expected]
  rows:
    - [empty_obj,  [{}],        true]
    - [with_data,  [{"a": 1}],  true]
    - [array,      [[1, 2]],    false]
    - [null_val,   [null],      false]
    - [number,     [42],        false]
