spec: struct_extra167
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra166.zspec.zsdl — covers struct.Struct.__name__/__module__ via __eq__ calls and Struct.__dict__.__sizeof__ membership (table + invariants)."
    - "struct_extra165.zspec.zsdl — covers struct.Struct.__dict__.__contains__ for __init__/__new__ (novel) and struct.error class identity via __eq__ calls (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__=='struct' and struct.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra166."
    - "Wave 353 theme: struct module-level identity attributes — __name__, __package__, __spec__.__class__.__name__, __loader__.__class__.__name__, __doc__.__class__.__name__, Struct.__dict__.__contains__('__doc__') (True), and Struct.__dict__.__contains__('__repr__') (True — verified). struct.zspec / early extras anchor struct.__name__ and struct.__package__ as string values. struct_extra166 anchors Struct.__name__/__module__ via __eq__; Struct.__dict__ __sizeof__ membership. This spec provides module-level meta-attributes (__spec__, __loader__, __doc__) and Struct.__dict__ membership for __doc__ and __repr__ as primary novel content."
    - "struct.__name__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__package__ == ''. Verified Python 3.14.3 macOS/Darwin 25.4.0. (empty string — struct is a top-level module)"
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0. struct.py is a pure Python wrapper in Lib/struct.py that wraps the _struct C extension."
    - "struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__doc__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. Struct has its own __doc__ string in Struct.__dict__."
    - "struct.Struct.__dict__.__contains__('__repr__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0. Struct defines __repr__ in its __dict__ (one of the 9 dunders in Struct.__dict__)."
    - "Note: struct.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars). struct.py (Lib/struct.py) is a thin Python wrapper around the _struct C extension. The module itself is loaded by SourceFileLoader because it is a .py file. 'SourceFileLoader'(16) > 'ModuleSpec'(10) > 'struct'(6) > 'str'(3) in class name lengths."
    - "Note: struct.Struct.__dict__.__contains__('__repr__') == True. '__repr__' is one of the 9 dunders in struct.Struct.__dict__ (along with __delattr__/__doc__/__getattribute__/__init__/__module__/__new__/__setattr__/__sizeof__). struct_extra166 anchors __sizeof__, struct_extra165 anchors __init__/__new__ — this spec adds __repr__ and __doc__ as the remaining novel dunder members."
    - "Note: struct.Struct.__dict__.__contains__('__doc__') == True. Struct has a dedicated docstring in its __dict__. '__doc__'(7 chars) = '__'=2 + 'doc'=3 + '__'=2. 'doc'(3 chars) inner name equals 'new'(3 chars) in length — both are 3-char inner names among Struct dunders."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__name__.__eq__('struct')
# struct.__package__.__eq__('')
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec')
# struct.__loader__.__class__.__name__.__eq__('SourceFileLoader')
#
# Wave 353 theme: struct module-level identity — __name__, __package__, __spec__, __loader__.
#
# struct.__name__ == 'struct' (6 chars; struct.zspec anchors as string value).
# struct.__package__ == '' (empty string; top-level module).
# struct.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; novel anchor).
# struct.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; novel anchor).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra167.module_name_package_spec_loader:
  description: "struct.__name__.__eq__('struct')==True / struct.__package__.__eq__('')==True / struct.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / struct.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True — struct.__name__ is 'struct' (6 chars; struct.zspec / early extras anchor __name__ as a string value; struct_extra166 anchors Struct.__name__.__eq__('Struct') for the class — this spec anchors the module-level __name__.__eq__('struct') via __eq__ call under structmod167; 'struct'(6 chars) = 's'+'t'+'r'+'u'+'c'+'t'; 6 chars); struct.__package__ is '' (empty string; struct is a top-level module not inside any package; __package__=='' for top-level modules; struct.zspec anchors struct.__package__; this spec confirms via __eq__ call; ''.__len__()==0 — empty); struct.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars; importlib.machinery.ModuleSpec is the standard module import descriptor; 'ModuleSpec'(10 chars) = 'Module'=6 + 'Spec'=4; novel anchor: no prior struct spec anchors __spec__.__class__.__name__ under structmod167); struct.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars; struct.py in Lib/struct.py is a pure Python wrapper file loaded by importlib.machinery.SourceFileLoader; even though struct wraps the _struct C extension, struct.py itself is a .py file; 'SourceFileLoader'(16) > 'ModuleSpec'(10) > 'struct'(6) > ''(0) in length ordering; novel anchor; first structmod167 anchor for module name/package/spec/loader)"
  kind: python_call_eq
  category: identity
  id_prefix: structmod167

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,         "__name__.__eq__",                      ["struct"],          true, "struct.__name__ == 'struct' (6 chars; struct.zspec anchors as string; module-level __name__, distinct from Struct.__name__; first structmod167 anchor via __eq__)"]
    - [mod_pkg_eq_empty,    "__package__.__eq__",                   [""],                true, "struct.__package__ == '' (empty string; top-level module not in package; struct.zspec anchors; confirmed via __eq__)"]
    - [spec_class_ms,       "__spec__.__class__.__name__.__eq__",   ["ModuleSpec"],      true, "struct.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; importlib.machinery.ModuleSpec; novel anchor under structmod167)"]
    - [loader_class_sfl,    "__loader__.__class__.__name__.__eq__", ["SourceFileLoader"], true, "struct.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; struct.py is a .py wrapper; novel anchor; 'SourceFileLoader'(16)>'ModuleSpec'(10))"]

# ---------------------------------------------------------------------------
# struct.__doc__.__class__.__name__.__eq__('str')
# struct.Struct.__dict__.__contains__('__doc__')
# struct.Struct.__dict__.__contains__('__repr__')
#
# Wave 353 theme: struct module doc class and Struct.__dict__ dunder membership for __doc__/__repr__.
#
# struct.__doc__.__class__.__name__ == 'str' (3 chars; module docstring is a str).
# Struct.__dict__.__contains__('__doc__') == True (novel anchor; struct_extra166 does not anchor).
# Struct.__dict__.__contains__('__repr__') == True (novel anchor; struct_extra166 does not anchor).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra167.module_doc_class_and_Struct_dict_doc_repr:
  description: "struct.__doc__.__class__.__name__.__eq__('str')==True / Struct.__dict__.__contains__('__doc__')==True / Struct.__dict__.__contains__('__repr__')==True / Struct.__dict__.__len__()==16 — struct.__doc__.__class__.__name__ is 'str' (3 chars; struct module has a module-level docstring which is a Python str object; 'str'(3 chars) is the built-in string type name; novel anchor: no prior struct spec anchors __doc__.__class__.__name__=='str' under structmod167); Struct.__dict__.__contains__('__doc__') is True ('__doc__' is a key in struct.Struct.__dict__; Struct has its own class-level docstring (distinct from the module-level docstring); '__doc__'(7 chars) = '__'=2 + 'doc'=3 + '__'=2; 'doc'(3 chars) is the inner name — same inner length as '__new__'('new'=3) and '__del...'('del'=3); novel anchor: struct_extra166 anchors __sizeof__(10)/__init__(8)/__new__(7) via __contains__ but not __doc__(7); struct_extra165 anchors __init__/__new__ but not __doc__); Struct.__dict__.__contains__('__repr__') is True ('__repr__' is a key in struct.Struct.__dict__; Struct defines __repr__ to provide a string representation of the compiled format; '__repr__'(8 chars) = '__'=2 + 'repr'=4 + '__'=2; 'repr'(4) inner name: 'repr'(4)=='init'(4) in inner name length; '__repr__'(8)=='__init__'(8) in total dunder name length; novel anchor: struct_extra166 and struct_extra165 do not anchor __repr__ membership via __contains__); Struct.__dict__.__len__() is 16 (confirmed; struct_extra160 and struct_extra163 anchor __len__()==16; 9 dunders + 7 non-dunders = 16; first structmod167 anchor for __doc__/__repr__ Struct dict membership)"
  kind: python_call_eq
  category: identity
  id_prefix: structmod167

  columns: [id, function, args, expected, description]
  rows:
    - [mod_doc_class_str,   "__doc__.__class__.__name__.__eq__",    ["str"],     true, "struct.__doc__.__class__.__name__ == 'str' (3 chars; module docstring is a Python str; novel anchor under structmod167)"]
    - [sdict_has_doc,       "Struct.__dict__.__contains__",         ["__doc__"], true, "struct.Struct.__dict__.__contains__('__doc__') == True ('__doc__'=7 chars; Struct class docstring; 'doc'(3) inner name; novel anchor; struct_extra165/166 do not anchor __doc__)"]
    - [sdict_has_repr,      "Struct.__dict__.__contains__",         ["__repr__"], true, "struct.Struct.__dict__.__contains__('__repr__') == True ('__repr__'=8 chars; Struct representation method; 'repr'(4)=='init'(4) inner length; novel anchor; struct_extra165/166 do not anchor __repr__)"]
    - [sdict_len_16,        "Struct.__dict__.__len__",              [],          16,   "struct.Struct.__dict__.__len__() is 16 (confirmed; 9 dunders + 7 non-dunders = 16; struct_extra160 anchors __len__()==16)"]

