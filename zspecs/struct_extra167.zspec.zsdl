#
# Wave 353 theme: dunder name lengths for Struct.__dict__ — __doc__, __repr__, __sizeof__.
#
# Struct.__dict__.__contains__('__doc__') == True (confirmed; '__doc__'=7 chars).
# Struct.__dict__.__contains__('__repr__') == True (confirmed; '__repr__'=8 chars).
# Struct.__dict__.__contains__('__sizeof__') == True (confirmed; struct_extra166 anchors).
# Length ordering: '__doc__'(7) < '__repr__'(8) < '__sizeof__'(10).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra167.Struct_dict_dunder_lengths_doc_repr_sizeof:
  description: "struct.Struct.__dict__.__contains__('__doc__')==True / Struct.__dict__.__contains__('__repr__')==True / Struct.__dict__.__contains__('__sizeof__')==True / Struct.__dict__.__len__()==16 — Struct.__dict__.__contains__('__doc__') is True (confirmed; '__doc__'=7 chars = '__'=2 + 'doc'=3 + '__'=2; 'doc'(3 chars) inner name; '__doc__'(7) < '__repr__'(8) < '__sizeof__'(10) — dunder name length ordering for these three Struct dict members; 'doc'(3)=='new'(3) in inner name length — struct_extra165 anchors __new__(7) as novel; '__doc__'(7)=='__new__'(7) — tied at 7 chars; novel anchor under structmod167); Struct.__dict__.__contains__('__repr__') is True (confirmed; '__repr__'=8 chars = '__'=2 + 'repr'=4 + '__'=2; 'repr'(4)==init'(4) in inner name length; '__repr__'(8)=='__init__'(8) — tied at 8 chars; struct_extra165 anchors __init__(8) as novel but not __repr__(8) — novel anchor here); Struct.__dict__.__contains__('__sizeof__') is True (confirmed; struct_extra166 anchors __sizeof__ as novel; '__sizeof__'=10 chars = '__'=2 + 'sizeof'=6 + '__'=2; '__sizeof__'(10) > '__repr__'(8) > '__doc__'(7) — longest among the three; 'sizeof'(6) inner name is longer than 'repr'(4) and 'doc'(3)); Struct.__dict__.__len__() is 16 (confirmed; complete dunder name length ordering for Struct dict: '__new__'(7)=='__doc__'(7) < '__repr__'(8)=='__init__'(8) < '__sizeof__'(10); first structmod167 anchor for __doc__/__repr__/__sizeof__ dunder length ordering)"
  kind: python_call_eq
  category: identity
  id_prefix: structmod167

  columns: [id, function, args, expected, description]
  rows:
    - [sdict_has_doc_b,    "Struct.__dict__.__contains__", ["__doc__"],    true, "struct.Struct.__dict__.__contains__('__doc__') == True (confirmed; '__doc__'=7 chars; 'doc'(3)=='new'(3) inner; '__doc__'(7)=='__new__'(7) tied; novel under structmod167)"]
    - [sdict_has_repr_b,   "Struct.__dict__.__contains__", ["__repr__"],   true, "struct.Struct.__dict__.__contains__('__repr__') == True (confirmed; '__repr__'=8 chars; 'repr'(4)=='init'(4) inner; '__repr__'(8)=='__init__'(8) tied; novel under structmod167)"]
    - [sdict_has_sizeof_b, "Struct.__dict__.__contains__", ["__sizeof__"], true, "struct.Struct.__dict__.__contains__('__sizeof__') == True (confirmed; struct_extra166 anchors; '__sizeof__'=10 chars; longest dunder name: '__sizeof__'(10)>'__repr__'(8)>'__doc__'(7))"]
    - [sdict_len_16_g,     "Struct.__dict__.__len__",      [],             16,   "struct.Struct.__dict__.__len__() is 16 (confirmed; struct_extra160 anchors; ordering: '__doc__'(7)=='__new__'(7)<'__repr__'(8)=='__init__'(8)<'__sizeof__'(10))"]

# ---------------------------------------------------------------------------
# struct.__name__.__eq__('struct') — standalone
#
# struct.__name__ is 'struct' (6 chars). struct is the Python module providing functions
# to convert between Python values and C structs. 'struct' (6 chars) = 's'+'t'+'r'+'u'+'c'+'t'.
# struct.zspec / early extras anchor __name__ as a string value; this standalone anchors
# the module-level __name__ via __eq__ call under structmod167 (distinct from struct_extra166
# which anchors Struct.__name__.__eq__('Struct') — the class-level attribute).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra167.mod_name_eq_struct:
  description: "struct.__name__.__eq__('struct') == True — 'struct' (6 chars; the struct module provides pack/unpack/calcsize/pack_into/unpack_from/iter_unpack for binary data conversion between Python values and C structs; struct.zspec anchors module __name__ as a string value; struct_extra166 anchors Struct.__name__.__eq__('Struct') for the class (capital S) — this spec anchors the module-level __name__.__eq__('struct') (lowercase s) as a fresh anchor under structmod167; 'struct'(6) == struct.Struct.__name__.__len__()==6 — module name length equals class name length: both are 6-char strings; first structmod167 standalone for struct.__name__.__eq__('struct')"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__package__.__eq__('') — standalone
#
# struct.__package__ is '' (empty string). struct is a top-level module not in any package.
# For top-level modules, Python sets __package__ to the empty string ''. struct.zspec /
# early extras anchor struct.__package__; this standalone anchors via __eq__ call under
# structmod167. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra167.mod_package_eq_empty:
  description: "struct.__package__.__eq__('') == True — '' (empty string; struct is a top-level module not in any package; __package__=='' for top-level modules; struct.zspec anchors struct.__package__; confirmed via __eq__ here; struct.__name__(6) >> struct.__package__(0): module name is 6 chars longer than the empty package string; first structmod167 standalone for struct.__package__.__eq__('')"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# struct.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars). Every imported Python module
# has a .__spec__ attribute of type importlib.machinery.ModuleSpec. 'ModuleSpec' (10 chars) =
# 'Module'=6 + 'Spec'=4. Novel: no prior struct spec anchors __spec__.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra167.spec_class_modulespec:
  description: "struct.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — 'ModuleSpec' (10 chars = 'Module'=6 + 'Spec'=4; importlib.machinery.ModuleSpec is the standard descriptor for Python module imports; 'ModuleSpec'(10) > 'struct'(6) by 4 chars; novel anchor: no prior struct spec anchors __spec__.__class__.__name__ under structmod167; first structmod167 standalone for struct.__spec__.__class__.__name__.__eq__('ModuleSpec')"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# struct.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars). struct.py is a
# pure Python source file in Lib/struct.py that wraps the _struct C extension. The module
# itself is loaded by importlib.machinery.SourceFileLoader. 'SourceFileLoader' (16 chars) =
# 'Source'=6 + 'File'=4 + 'Loader'=6. Novel anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra167.loader_class_sourcefileloader:
  description: "struct.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — 'SourceFileLoader' (16 chars = 'Source'=6 + 'File'=4 + 'Loader'=6; struct.py in Lib/struct.py is a thin Python wrapper around the _struct C extension; the struct module itself is a .py source file and is loaded by importlib.machinery.SourceFileLoader; 'SourceFileLoader'(16) > 'ModuleSpec'(10) > 'struct'(6) > 'str'(3) in class name length ordering; novel anchor: no prior struct spec anchors __loader__.__class__.__name__ under structmod167; first structmod167 standalone for struct.__loader__.__class__.__name__.__eq__('SourceFileLoader')"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__doc__.__class__.__name__.__eq__('str') — standalone
#
# struct.__doc__.__class__.__name__ is 'str' (3 chars). The struct module has a module-level
# docstring which is a Python str object. struct.__doc__ begins: 'Functions to convert between
# Python values and C structs.' 'str' (3 chars) is the built-in Python string type name.
# Novel: no prior struct spec anchors __doc__.__class__.__name__ under structmod167.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra167.doc_class_str:
  description: "struct.__doc__.__class__.__name__.__eq__('str') == True — 'str' (3 chars; struct module docstring is a Python str object; module docstrings are always str; 'str'(3) < 'struct'(6) < 'ModuleSpec'(10) < 'SourceFileLoader'(16) in length ordering; struct.__doc__ begins: 'Functions to convert between Python values and C structs.' — references C structs as the primary use case; novel anchor: no prior struct spec anchors __doc__.__class__.__name__ under structmod167; first structmod167 standalone for struct.__doc__.__class__.__name__.__eq__('str')"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__doc__') — standalone
#
# struct.Struct.__dict__.__contains__('__doc__') is True. '__doc__' is one of the 9 dunder
# methods/attributes in struct.Struct's mappingproxy. Struct has its own class-level docstring
# stored in Struct.__dict__['__doc__']. '__doc__' (7 chars) = '__'=2 + 'doc'=3 + '__'=2.
# Novel anchor: struct_extra166 anchors __sizeof__(10), struct_extra165 anchors __init__(8)/
# __new__(7) — this spec adds __doc__(7) as an additional Struct.__dict__ dunder.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra167.Struct_dict_contains_doc:
  description: "struct.Struct.__dict__.__contains__('__doc__') == True — '__doc__' (7 chars = '__'=2 + 'doc'=3 + '__'=2; Struct has its own class-level docstring stored in Struct.__dict__; this is distinct from struct.__doc__ (the module-level docstring); '__doc__'(7)=='__new__'(7) — tied with __new__ in dunder name length (struct_extra165 anchors __new__); 'doc'(3) inner name: 'doc'(3)=='new'(3) — both 3-char inner names; struct_extra166 anchors __sizeof__(10)/__init__(8)/__new__(7) — this spec adds __doc__(7) as a novel Struct dict dunder; Struct.__dict__.__len__()==16; first structmod167 standalone for Struct.__dict__.__contains__('__doc__')"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__doc__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('__repr__') — standalone
#
# struct.Struct.__dict__.__contains__('__repr__') is True. '__repr__' is one of the 9 dunder
# methods in struct.Struct's mappingproxy. Struct.__repr__ provides a string representation
# of the compiled format. '__repr__' (8 chars) = '__'=2 + 'repr'=4 + '__'=2.
# Novel anchor: struct_extra166 anchors __sizeof__(10), struct_extra165 anchors __init__(8)/
# __new__(7) — this spec adds __repr__(8) as an additional Struct.__dict__ dunder.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra167.Struct_dict_contains_repr:
  description: "struct.Struct.__dict__.__contains__('__repr__') == True — '__repr__' (8 chars = '__'=2 + 'repr'=4 + '__'=2; Struct defines __repr__ in its __dict__ to provide a string representation of the compiled format (e.g., Struct('!I')); '__repr__'(8)=='__init__'(8) — tied with __init__ in dunder name length (struct_extra165 anchors __init__ as novel); 'repr'(4) inner name: 'repr'(4)=='init'(4) — both 4-char inner names; struct_extra166 anchors __sizeof__(10) and struct_extra165 anchors __init__(8)/__new__(7) — this spec adds __repr__(8) as a novel Struct dict dunder; Struct.__dict__.__len__()==16; first structmod167 standalone for Struct.__dict__.__contains__('__repr__')"
  category: identity
  kind: python_call_eq
  function: Struct.__dict__.__contains__
  args: ["__repr__"]
  expected: true
