spec: socket_extra43
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra42.zspec.zsdl — covers socket.socket shutdown/sendall/recvfrom/sendto/connect_ex/dup/makefile/detach __qualname__.__eq__ string values."
    - "socket_extra41.zspec.zsdl — covers socket.socket setblocking/getpeername/getsockname/makefile/detach/dup __name__.__eq__; socket.gethostname __name__/__module__.__eq__."
    - "socket_extra40.zspec.zsdl — covers socket.socket setsockopt/getsockopt __name__.__eq__; getdefaulttimeout/__qualname__.__eq__."
    - "socket_extra39.zspec.zsdl — covers socket.socket connect/bind/accept/listen/send/recv __name__.__eq__ string values."
    - "socket_extra34.zspec.zsdl — covers socket.socket close/setblocking/getsockname/fileno/detach/shutdown/sendall __name__.__len__() (length checks only)."
    - "socket_extra29.zspec.zsdl — covers socket.socket setsockopt/getsockopt/settimeout/getpeername __name__.__len__()."
  notes:
    - "This spec extends socket through socket_extra42; it does NOT duplicate invariants present in those files."
    - "Coverage gap: socket_extra39 covers connect/bind/accept/listen/send/recv __name__.__eq__. socket_extra40 covers setsockopt/getsockopt __name__.__eq__. socket_extra41 covers setblocking/getpeername/getsockname/makefile/detach/dup __name__.__eq__. But NO prior spec checks socket.socket.settimeout/__name__.__eq__('settimeout') or socket.socket.gettimeout/__name__.__eq__('gettimeout') as string eq values. Similarly, NO prior spec checks socket.socket.shutdown/__name__.__eq__('shutdown') or socket.socket.sendall/__name__.__eq__('sendall'). socket_extra34 covers shutdown/__name__.__len__()==8 and sendall/__name__.__len__()==7 (length only); socket_extra29 covers settimeout/__name__.__len__()==10 (length only). The __name__.__eq__ string values for these four methods are novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__name__ == 'settimeout'. extra29 covers __name__.__len__()==10 (length only). No prior spec checks settimeout/__name__.__eq__('settimeout') as a string eq value. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__name__ == 'gettimeout'. No prior spec checks gettimeout/__name__.__eq__('gettimeout'). extra29 does not cover gettimeout __name__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.shutdown.__name__ == 'shutdown'. extra34 covers shutdown/__name__.__len__()==8 (length only). extra42 covers shutdown/__qualname__.__eq__('socket.shutdown') (__qualname__ axis). No prior spec checks shutdown/__name__.__eq__('shutdown') (__name__ axis). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.sendall.__name__ == 'sendall'. extra34 covers sendall/__name__.__len__()==7 (length only). extra42 covers sendall/__qualname__.__eq__('socket.sendall') (__qualname__ axis). No prior spec checks sendall/__name__.__eq__('sendall') (__name__ axis). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __name__.__eq__ string values:
# settimeout, gettimeout, shutdown, sendall
#
# socket_extra39 covers connect/bind/accept/listen/send/recv __name__.__eq__.
# socket_extra40 covers setsockopt/getsockopt __name__.__eq__.
# socket_extra41 covers setblocking/getpeername/getsockname/makefile/detach/dup __name__.__eq__.
# socket_extra29 covers settimeout/__name__.__len__()==10 (length only, NOT __eq__).
# socket_extra34 covers shutdown/__name__.__len__()==8 and sendall/__name__.__len__()==7
#   (length only, NOT __eq__).
# socket_extra42 covers shutdown/sendall __qualname__.__eq__ (__qualname__ axis, NOT __name__).
# No prior spec checks __name__.__eq__ for settimeout, gettimeout, shutdown, or sendall.
# ---------------------------------------------------------------------------

table socket_extra43.socket_method_name_eqs:
  description: "socket.socket settimeout/gettimeout/shutdown/sendall __name__.__eq__ string values — novel: extra29 covers settimeout __name__.__len__ only; extra34 covers shutdown/sendall __name__.__len__ only; extra42 covers shutdown/sendall __qualname__.__eq__ (different axis); no prior spec checks __name__.__eq__ for any of these four methods"
  kind: python_call_eq
  category: function_names
  id_prefix: ssmne43

  columns: [id, function, args, expected]
  rows:
    - [settimeout_name_eq, "socket.settimeout.__name__.__eq__", ["settimeout"], true]
    - [gettimeout_name_eq, "socket.gettimeout.__name__.__eq__", ["gettimeout"], true]
    - [shutdown_name_eq,   "socket.shutdown.__name__.__eq__",   ["shutdown"],   true]
    - [sendall_name_eq,    "socket.sendall.__name__.__eq__",    ["sendall"],    true]
