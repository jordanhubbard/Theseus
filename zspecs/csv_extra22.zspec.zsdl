spec: csv_extra22
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra21.zspec.zsdl."
    - "csv_extra21 covers: unix_dialect/__module__; unix_dialect/__bases__[0].__name__; QUOTE_NONNUMERIC/__class__/__qualname__; QUOTE_NONE/__class__/__qualname__; Dialect.delimiter/__class__/__name__."
    - "csv_extra19 covers: reader/writer/DictReader/DictWriter/Dialect/Sniffer/Error __qualname__.__class__.__name__ type axis; QUOTE_ALL/__class__.__qualname__; QUOTE_MINIMAL/__class__.__qualname__."
    - "csv_extra17 covers: DictReader/__bases__[0].__name__; DictWriter/__bases__[0].__name__; Error/__module__; Dialect/__module__; class __module__ table."
    - "csv_extra16 covers: reader/__module__; writer/__module__; Dialect/Error/excel/excel_tab __bases__[0].__name__ table; QUOTE_* __class__.__name__."
    - "csv_extra14 covers: DictReader/__module__; DictWriter/__module__; Error/__qualname__."
    - "csv_extra13 covers: Dialect/__bases__[0].__name__; Error/__bases__[0].__name__."
    - "Focus: __bases__[0].__qualname__ for Dialect, DictReader, and Error; type-axis for __module__ strings on DictReader/DictWriter/Error/Dialect."
    - "No prior csv spec checks Dialect.__bases__[0].__qualname__."
    - "No prior csv spec checks DictReader.__bases__[0].__qualname__."
    - "No prior csv spec checks Error.__bases__[0].__qualname__."
    - "No prior csv spec checks DictReader.__module__.__class__.__name__."
    - "No prior csv spec checks DictWriter.__module__.__class__.__name__."
    - "No prior csv spec checks Error.__module__.__class__.__name__."
    - "No prior csv spec checks Dialect.__module__.__class__.__name__."
    - "csv.Dialect.__bases__[0].__qualname__ == 'object' — base class qualname equals its name."
    - "csv.DictReader.__bases__[0].__qualname__ == 'object' — base class qualname equals its name."
    - "csv.Error.__bases__[0].__qualname__ == 'Exception' — base class qualname equals its name."
    - "csv.DictReader.__module__.__class__.__name__ == 'str' — __module__ attribute is always a string."
    - "csv.DictWriter.__module__.__class__.__name__ == 'str' — __module__ attribute is always a string."
    - "csv.Error.__module__.__class__.__name__ == 'str' — __module__ attribute is always a string."
    - "csv.Dialect.__module__.__class__.__name__ == 'str' — __module__ attribute is always a string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__qualname__ for Dialect, DictReader, and Error
#
# csv_extra13 and csv_extra16 check Dialect.__bases__[0].__name__ == 'object'.
# csv_extra17 checks DictReader/DictWriter __bases__[0].__name__ == 'object'.
# csv_extra13 checks Error.__bases__[0].__name__ == 'Exception'.
# No prior csv spec checks __qualname__ (rather than __name__) for any base class.
# For top-level built-in classes, __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant csv_extra22.Dialect.base_qualname:
  description: "csv.Dialect.__bases__[0].__qualname__ == 'object' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "Dialect.__bases__[0].__qualname__.__eq__"
  args: ["object"]
  expected: true

invariant csv_extra22.DictReader.base_qualname:
  description: "csv.DictReader.__bases__[0].__qualname__ == 'object' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "DictReader.__bases__[0].__qualname__.__eq__"
  args: ["object"]
  expected: true

invariant csv_extra22.Error.base_qualname:
  description: "csv.Error.__bases__[0].__qualname__ == 'Exception' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "Error.__bases__[0].__qualname__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# Type axis for class __module__ strings
#
# Multiple prior specs verify the values of DictReader/__module__,
# DictWriter/__module__, Error/__module__, and Dialect/__module__.
# No prior csv spec checks the type (__class__.__name__) of those __module__
# attributes.  A class's __module__ is always a plain str.
# ---------------------------------------------------------------------------

invariant csv_extra22.DictReader.module.class_name:
  description: "csv.DictReader.__module__.__class__.__name__ == 'str' — __module__ is a string"
  category: type_attrs
  kind: python_call_eq
  function: DictReader.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant csv_extra22.DictWriter.module.class_name:
  description: "csv.DictWriter.__module__.__class__.__name__ == 'str' — __module__ is a string"
  category: type_attrs
  kind: python_call_eq
  function: DictWriter.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant csv_extra22.Error.module.class_name:
  description: "csv.Error.__module__.__class__.__name__ == 'str' — __module__ is a string"
  category: type_attrs
  kind: python_call_eq
  function: Error.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant csv_extra22.Dialect.module.class_name:
  description: "csv.Dialect.__module__.__class__.__name__ == 'str' — __module__ is a string"
  category: type_attrs
  kind: python_call_eq
  function: Dialect.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all seven new invariants
#
# All seven are first covered in this spec (csv_extra22).
# ---------------------------------------------------------------------------

table csv_extra22.base_qualnames_and_module_types:
  description: "csv class base __qualname__ and __module__ type axis"
  kind: python_call_eq
  category: class_attrs
  id_prefix: cbq22

  columns: [id, function, args, expected]
  rows:
    - [Dialect_base_qn,         "Dialect.__bases__[0].__qualname__.__eq__",           ["object"],    true]
    - [DictReader_base_qn,      "DictReader.__bases__[0].__qualname__.__eq__",         ["object"],    true]
    - [Error_base_qn,           "Error.__bases__[0].__qualname__.__eq__",              ["Exception"], true]
    - [DictReader_mod_type,     DictReader.__module__.__class__.__name__.__eq__,       ["str"],       true]
    - [DictWriter_mod_type,     DictWriter.__module__.__class__.__name__.__eq__,       ["str"],       true]
    - [Error_mod_type,          Error.__module__.__class__.__name__.__eq__,            ["str"],       true]
    - [Dialect_mod_type,        Dialect.__module__.__class__.__name__.__eq__,          ["str"],       true]
