spec: wcwidth
version: ">=1.0.0"
backend: node(wcwidth)

docs: https://github.com/mycoboco/wcwidth.js#readme

provenance:
  derived_from:
    - "wcwidth.js README — https://github.com/mycoboco/wcwidth.js#readme"
    - "POSIX wcwidth(3) function definition"
    - "Test vectors verified with wcwidth via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "wcwidth source"
  notes:
    - "wcwidth returns the column width of a string when displayed in a fixed-width terminal."
    - "Install: npm install wcwidth"
    - "ASCII characters are width 1; East Asian wide characters (CJK, fullwidth) are width 2; combining marks and most control characters (incl. tab) are 0."
    - "Module export IS the function."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table wcwidth.column_width:
  kind: node_module_call_eq
  category: column_width
  function: ~
  id_prefix: width

  columns: [id, args, expected]
  rows:
    - [empty,         [""],         0]
    - [single_ascii,  ["a"],        1]
    - [ascii_5_chars, ["hello"],    5]
    - [cjk_3_chars,   ["日本語"],     6]
    - [single_cjk,    ["日"],        2]
    - [emoji_basic,   ["🎉"],        2]
    - [mixed_ascii_cjk, ["hi 日"],   5]
    - [space_only,    [" "],         1]
    - [tab_treated_as_zero, ["\t"], 0]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:24:31Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
