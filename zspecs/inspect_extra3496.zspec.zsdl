spec: in3496
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 680 (in3496): __aenter__, __aexit__, __await__ dict-presence checks for inspect types."
    - "Theme: __aenter__/__aexit__/__await__ dict-presence (async with x, await x)."
    - "All values False — functools/itertools/inspect/threading types are synchronous and do not implement the async context manager or awaitable protocols."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "None of these types implement async context manager or awaitable protocols directly in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3496.aenter:
  description: "inspect types __aenter__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3496
  columns: [id, function, args, expected]
  rows:
    - ["in3496001", operator.contains, [inspect.Parameter.__dict__,           "__aenter__"], false]
    - ["in3496002", operator.contains, [inspect.Signature.__dict__,           "__aenter__"], false]
    - ["in3496003", operator.contains, [inspect.BoundArguments.__dict__,      "__aenter__"], false]
    - ["in3496004", operator.contains, [inspect.FrameInfo.__dict__,           "__aenter__"], false]
    - ["in3496005", operator.contains, [inspect.ArgInfo.__dict__,             "__aenter__"], false]
    - ["in3496006", operator.contains, [inspect.FullArgSpec.__dict__,         "__aenter__"], false]
    - ["in3496007", operator.contains, [inspect.Attribute.__dict__,           "__aenter__"], false]
    - ["in3496008", operator.contains, [inspect.ClassFoundException.__dict__, "__aenter__"], false]
    - ["in3496009", operator.contains, [inspect.EndOfBlock.__dict__,          "__aenter__"], false]

