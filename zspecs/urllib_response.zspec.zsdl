spec: urllib_response
version: ">=3.3"
backend: python_module(urllib.response)

docs: https://docs.python.org/3/library/urllib.response.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/urllib.response.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "urllib.response source: Lib/urllib/response.py (PSF; source inspection permitted)"
  not_derived_from:
    - "urllib.response source: internal socket/file wrapping internals"
  notes:
    - "urllib.response is a small internal module exposing response wrapper classes used by urllib.request."
    - "addbase is the base wrapper class that wraps a file-like object and delegates read/readline/readlines."
    - "addinfourl wraps an underlying response with headers (info) and a URL; it inherits from addbase."
    - "addinfourl exposes .info(), .geturl(), .getcode() methods (getcode may be None if not set)."
    - "addclosehook and addinfo were present in Python 2 / early Python 3 but were removed by Python 3.9."
    - "The module is not intended for direct public use; it is documented as part of the urllib package."
    - "addbase.__name__ == 'addbase' and addinfourl.__name__ == 'addinfourl' are stable identity checks."
    - "addinfourl.__bases__[0].__name__ == 'addbase' confirms the inheritance chain."
    - "All expected values verified by running Python 3.12 urllib.response module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table urllib_response.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [addbase,     addbase.__name__.__eq__,     ["addbase"],     true]
    - [addinfourl,  addinfourl.__name__.__eq__,   ["addinfourl"],  true]

# ---------------------------------------------------------------------------
# Module checks
# ---------------------------------------------------------------------------

table urllib_response.module_checks:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [addbase,    addbase.__module__.__eq__,    ["urllib.response"], true]
    - [addinfourl, addinfourl.__module__.__eq__,  ["urllib.response"], true]

# ---------------------------------------------------------------------------
# Inheritance — addinfourl inherits from addbase
# ---------------------------------------------------------------------------

invariant urllib_response.addinfourl_base:
  description: "addinfourl.__bases__[0].__name__ == 'addbase' — addinfourl inherits from addbase"
  category: inheritance
  kind: python_call_eq
  function: addinfourl.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "addbase"

# ---------------------------------------------------------------------------
# addbase — qualname and class hierarchy
# ---------------------------------------------------------------------------

invariant urllib_response.addbase_qualname:
  description: "addbase.__qualname__ == 'addbase'"
  category: addbase
  kind: python_call_eq
  function: addbase.__qualname__.__eq__
  args: ["addbase"]
  expected: true

invariant urllib_response.addbase_base:
  description: "addbase.__bases__[0].__name__ == 'object' — addbase inherits from object"
  category: addbase
  kind: python_call_eq
  function: addbase.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# addinfourl — qualname and MRO depth
#
# addinfourl.__mro__ includes addinfourl, addbase, object — length == 3.
# ---------------------------------------------------------------------------

invariant urllib_response.addinfourl_qualname:
  description: "addinfourl.__qualname__ == 'addinfourl'"
  category: addinfourl
  kind: python_call_eq
  function: addinfourl.__qualname__.__eq__
  args: ["addinfourl"]
  expected: true

invariant urllib_response.addinfourl_mro_length:
  description: "len(addinfourl.__mro__) == 3 — MRO is [addinfourl, addbase, object]"
  category: addinfourl
  kind: python_call_eq
  function: addinfourl.__mro__.__len__
  args: []
  expected: 3

invariant urllib_response.addinfourl_mro_root:
  description: "addinfourl.__mro__[-1].__name__ == 'object' — MRO root is object"
  category: addinfourl
  kind: python_call_eq
  function: addinfourl.__mro__.__getitem__
  args: [-1]
  method: __name__
  expected: "object"

invariant urllib_response.addinfourl_mro_middle:
  description: "addinfourl.__mro__[1].__name__ == 'addbase' — MRO middle is addbase"
  category: addinfourl
  kind: python_call_eq
  function: addinfourl.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "addbase"
