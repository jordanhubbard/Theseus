spec: multiprocessing_extra148
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "This spec covers: wave 255 theme — multiprocessing.__dict__.__contains__ membership checks. NEW in extra148: multiprocessing.__dict__.__contains__('Process')==True; multiprocessing.__dict__.__contains__('Pool')==True; multiprocessing.__dict__.__contains__('Queue')==True; multiprocessing.__dict__.__contains__('Pipe')==True; multiprocessing.__dict__.__contains__('Manager')==True; multiprocessing.__dict__.__contains__('Lock')==True; multiprocessing.__dict__.__contains__('Event')==True; multiprocessing.__dict__.__contains__('Value')==True; multiprocessing.__dict__.__contains__('Array')==True; multiprocessing.__dict__.__contains__('cpu_count')==True; multiprocessing.__dict__.__contains__('foobar')==False; multiprocessing.__dict__.__contains__('Thread')==False; multiprocessing.__dict__.__contains__('subprocess')==False. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.__dict__.__contains__('Process') == True. Process is re-exported through multiprocessing/__init__.py from multiprocessing.context; it appears in multiprocessing.__dict__ under the key 'Process'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.__dict__.__contains__('Pool') == True. Pool is re-exported from multiprocessing.pool; it appears in multiprocessing.__dict__ under the key 'Pool'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.__dict__.__contains__('Thread') == False. 'Thread' is a threading module class, not a multiprocessing class; it does not appear in multiprocessing.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.__dict__ has 53 entries. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.__dict__.__contains__ membership — True cases — extra148
#
# Wave 255 theme: multiprocessing.__dict__.__contains__ membership checks.
#
# multiprocessing.__dict__.__contains__('Process')   == True
# multiprocessing.__dict__.__contains__('Pool')      == True
# multiprocessing.__dict__.__contains__('Queue')     == True
# multiprocessing.__dict__.__contains__('Pipe')      == True
# multiprocessing.__dict__.__contains__('Manager')   == True
# multiprocessing.__dict__.__contains__('Lock')      == True
# multiprocessing.__dict__.__contains__('Event')     == True
# multiprocessing.__dict__.__contains__('Value')     == True
# multiprocessing.__dict__.__contains__('Array')     == True
# multiprocessing.__dict__.__contains__('cpu_count') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra148.mp_dict_contains_true:
  description: "multiprocessing.__dict__.__contains__ membership checks (True cases) in mpdictcontains148 namespace — wave 255 theme: multiprocessing.__dict__ has 53 entries; all public multiprocessing classes and functions are re-exported through multiprocessing/__init__.py from the context and context-specific submodules; Process, Pool, Queue, Pipe, Manager, Lock, Event, Value, Array, and cpu_count are all in multiprocessing.__dict__; multiprocessing.__dict__.__contains__('Process')==True (Process class from multiprocessing.context, module='multiprocessing.context'); multiprocessing.__dict__.__contains__('Pool')==True (Pool class from multiprocessing.pool, module='multiprocessing.pool'); multiprocessing.__dict__.__contains__('Queue')==True (Queue factory function for IPC queues); multiprocessing.__dict__.__contains__('Pipe')==True (Pipe creates a pair of Connection objects); multiprocessing.__dict__.__contains__('Manager')==True (Manager creates a SyncManager for shared state); multiprocessing.__dict__.__contains__('Lock')==True (Lock for mutual exclusion); multiprocessing.__dict__.__contains__('Event')==True (Event for inter-process signaling); multiprocessing.__dict__.__contains__('Value')==True (Value for shared memory values); multiprocessing.__dict__.__contains__('Array')==True (Array for shared memory arrays); multiprocessing.__dict__.__contains__('cpu_count')==True (function returning number of CPUs); verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: mpdictcontains148

  columns: [id, function, args, expected, description]
  rows:
    - [process_in,   multiprocessing.__dict__.__contains__,  ["Process"],   true, "multiprocessing.__dict__.__contains__('Process') == True — from multiprocessing.context; verified with Python 3.14.3"]
    - [pool_in,      multiprocessing.__dict__.__contains__,  ["Pool"],      true, "multiprocessing.__dict__.__contains__('Pool') == True — from multiprocessing.pool; verified with Python 3.14.3"]
    - [queue_in,     multiprocessing.__dict__.__contains__,  ["Queue"],     true, "multiprocessing.__dict__.__contains__('Queue') == True — IPC queue factory; verified with Python 3.14.3"]
    - [pipe_in,      multiprocessing.__dict__.__contains__,  ["Pipe"],      true, "multiprocessing.__dict__.__contains__('Pipe') == True — creates Connection pair; verified with Python 3.14.3"]
    - [manager_in,   multiprocessing.__dict__.__contains__,  ["Manager"],   true, "multiprocessing.__dict__.__contains__('Manager') == True — creates SyncManager; verified with Python 3.14.3"]
    - [lock_in,      multiprocessing.__dict__.__contains__,  ["Lock"],      true, "multiprocessing.__dict__.__contains__('Lock') == True — mutual exclusion lock; verified with Python 3.14.3"]
    - [event_in,     multiprocessing.__dict__.__contains__,  ["Event"],     true, "multiprocessing.__dict__.__contains__('Event') == True — inter-process event; verified with Python 3.14.3"]
    - [value_in,     multiprocessing.__dict__.__contains__,  ["Value"],     true, "multiprocessing.__dict__.__contains__('Value') == True — shared memory value; verified with Python 3.14.3"]
    - [array_in,     multiprocessing.__dict__.__contains__,  ["Array"],     true, "multiprocessing.__dict__.__contains__('Array') == True — shared memory array; verified with Python 3.14.3"]
    - [cpu_count_in, multiprocessing.__dict__.__contains__,  ["cpu_count"], true, "multiprocessing.__dict__.__contains__('cpu_count') == True — function returning CPU count; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.__dict__.__contains__ membership — False cases — extra148
#
# multiprocessing.__dict__.__contains__('foobar')    == False
# multiprocessing.__dict__.__contains__('Thread')    == False
# multiprocessing.__dict__.__contains__('subprocess') == False
# ---------------------------------------------------------------------------

table multiprocessing_extra148.mp_dict_contains_false:
  description: "multiprocessing.__dict__.__contains__ membership checks (False cases) in mpdictcontains148 namespace — wave 255 theme: multiprocessing.__dict__.__contains__ returns False for names not in multiprocessing's 53-entry namespace; 'Thread' is a threading.Thread class, not a multiprocessing class — multiprocessing uses Process not Thread; 'subprocess' is a separate stdlib module, not re-exported into multiprocessing; 'foobar' is an arbitrary non-existent name; multiprocessing.__dict__.__contains__('Thread')==False; multiprocessing.__dict__.__contains__('subprocess')==False; multiprocessing.__dict__.__contains__('foobar')==False; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: mpdictcontains148a

  columns: [id, function, args, expected, description]
  rows:
    - [thread_out,    multiprocessing.__dict__.__contains__,  ["Thread"],     false, "multiprocessing.__dict__.__contains__('Thread') == False — Thread is in threading, not multiprocessing; verified with Python 3.14.3"]
    - [subproc_out,   multiprocessing.__dict__.__contains__,  ["subprocess"], false, "multiprocessing.__dict__.__contains__('subprocess') == False — subprocess is a separate stdlib module; verified with Python 3.14.3"]
    - [foobar_out,    multiprocessing.__dict__.__contains__,  ["foobar"],     false, "multiprocessing.__dict__.__contains__('foobar') == False — not in namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra148
# ---------------------------------------------------------------------------

invariant multiprocessing_extra148.mp_dict_contains_Process:
  description: "multiprocessing.__dict__.__contains__('Process') returns True — multiprocessing.Process is re-exported from multiprocessing.context (Process.__module__=='multiprocessing.context') through multiprocessing/__init__.py; it appears in multiprocessing.__dict__ under the key 'Process'; multiprocessing.Process.__mro__.__len__() is 3 (MRO=[Process, BaseProcess, object]); multiprocessing.__dict__ has 53 entries; both Process and Pool are in __dict__: multiprocessing.__dict__.__contains__('Process')==True and multiprocessing.__dict__.__contains__('Pool')==True; Pool is in multiprocessing.pool (module='multiprocessing.pool') and also re-exported; NEW in extra148: first standalone multiprocessing.__dict__.__contains__('Process') invariant in mpdictcontains148 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: multiprocessing.__dict__.__contains__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra148.mp_dict_contains_Pool:
  description: "multiprocessing.__dict__.__contains__('Pool') returns True — multiprocessing.Pool is re-exported from multiprocessing.pool (Pool.__module__=='multiprocessing.pool') through multiprocessing/__init__.py; Pool appears in multiprocessing.__dict__ under the key 'Pool'; Pool.__mro__.__len__() is 2 (MRO=[Pool, object], direct subclass of object); multiprocessing.__dict__.__contains__('Pool')==True and multiprocessing.__dict__.__contains__('Process')==True — both the pool-based and process-based concurrency classes are in multiprocessing.__dict__; Pool.map, Pool.apply, Pool.apply_async, Pool.starmap, Pool.close, Pool.terminate, Pool.join are all Pool methods (class='function'); NEW in extra148: first standalone multiprocessing.__dict__.__contains__('Pool') invariant in mpdictcontains148 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: multiprocessing.__dict__.__contains__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra148.mp_dict_contains_Queue:
  description: "multiprocessing.__dict__.__contains__('Queue') returns True — multiprocessing.Queue is a factory function or class for IPC (inter-process communication) queues; it appears in multiprocessing.__dict__ under the key 'Queue'; multiprocessing.__dict__.__contains__('Queue')==True; multiprocessing.__dict__.__contains__('Pipe')==True — both Queue and Pipe are the primary IPC mechanisms in multiprocessing; Queue provides a FIFO queue for safe inter-process data exchange while Pipe creates a pair of Connection objects for bidirectional communication; multiprocessing.__dict__ has 53 entries; NEW in extra148: first standalone multiprocessing.__dict__.__contains__('Queue') invariant in mpdictcontains148 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: multiprocessing.__dict__.__contains__
  args: ["Queue"]
  expected: true

invariant multiprocessing_extra148.mp_dict_contains_Lock:
  description: "multiprocessing.__dict__.__contains__('Lock') returns True — multiprocessing.Lock is a mutual exclusion lock for inter-process synchronization; it appears in multiprocessing.__dict__ under the key 'Lock'; multiprocessing.__dict__.__contains__('Lock')==True and multiprocessing.__dict__.__contains__('Event')==True — both synchronization primitives are in multiprocessing.__dict__; compare: asyncio.__dict__.__contains__('Lock')==True (asyncio.Lock from asyncio.locks), multiprocessing.__dict__.__contains__('Lock')==True — both concurrency frameworks expose Lock in their top-level namespace; multiprocessing.__dict__ has 53 entries; NEW in extra148: first standalone multiprocessing.__dict__.__contains__('Lock') invariant in mpdictcontains148 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: multiprocessing.__dict__.__contains__
  args: ["Lock"]
  expected: true

invariant multiprocessing_extra148.mp_dict_not_contains_Thread:
  description: "multiprocessing.__dict__.__contains__('Thread') returns False — 'Thread' is threading.Thread from the threading module; multiprocessing uses Process (not Thread) as its primary unit of concurrent execution; multiprocessing.__dict__.__contains__('Thread')==False confirms that Thread is not re-exported into the multiprocessing namespace; multiprocessing.__dict__.__contains__('Process')==True (the multiprocessing equivalent), multiprocessing.__dict__.__contains__('subprocess')==False (subprocess is a separate stdlib module); multiprocessing.__dict__ has 53 entries, none of which is 'Thread'; NEW in extra148: first standalone multiprocessing.__dict__.__contains__('Thread') False invariant in mpdictcontains148 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: multiprocessing.__dict__.__contains__
  args: ["Thread"]
  expected: false

