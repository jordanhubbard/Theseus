spec: just_flatten
version: ">=1.0.1"
backend: node(just-flatten)

docs: https://www.npmjs.com/package/just-flatten

provenance:
  derived_from:
    - "just-flatten README — https://www.npmjs.com/package/just-flatten"
    - "Test vectors verified with just-flatten via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-flatten source"
  notes:
    - "just-flatten is an npm package. Install: npm install just-flatten"
    - "The module exports a single function that deeply flattens a nested array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new flattened array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_flatten.flatten:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: jfltn

  columns: [id, args, expected]
  rows:
    - [nested, [[1, [2, [3]]]], [1, 2, 3]]
    - [flat,   [[1, 2, 3]],    [1, 2, 3]]
