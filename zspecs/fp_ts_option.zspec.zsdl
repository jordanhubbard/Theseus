spec: fp_ts_option
version: ">=2.0.0"
backend: node(fp-ts/Option)

docs: https://gcanti.github.io/fp-ts/modules/Option.ts.html

provenance:
  derived_from:
    - "fp-ts Option module documentation — https://gcanti.github.io/fp-ts/modules/Option.ts.html"
    - "Inspired by Haskell/Rust Option types"
    - "Test vectors verified with fp-ts via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "fp-ts source"
  notes:
    - "fp-ts is a TypeScript functional programming library; Option is its discriminated union for nullable values."
    - "Install: npm install fp-ts"
    - "Spec targets the Option submodule via backend: node(fp-ts/Option)."
    - "Some(x) = {_tag: 'Some', value: x}; None = {_tag: 'None'}."
    - "The discriminated tag is observable JSON; we test construction and predicates that don't require currying functions."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure constructors and predicates."
  stderr: "null"
  stickiness: "N/A — values are immutable."
  codes: {}

# Some(x) construction
table fp_ts_option.some:
  kind: node_module_call_eq
  category: some
  function: some
  id_prefix: some

  columns: [id, args, expected]
  rows:
    - [int,         [42],         {_tag: "Some", value: 42}]
    - [string,      ["hi"],       {_tag: "Some", value: "hi"}]
    - [object,      [{a: 1}],     {_tag: "Some", value: {a: 1}}]
    - [array,       [[1, 2]],     {_tag: "Some", value: [1, 2]}]
    - [null_in_some, [~],          {_tag: "Some", value: ~}]

# none — singleton
invariant fp_ts_option.none_singleton:
  description: "none has _tag: 'None'"
  category: none
  kind: node_property_eq
  entry: bare
  property: none
  expected: {_tag: "None"}

# isSome / isNone predicates
table fp_ts_option.isSome:
  kind: node_module_call_eq
  category: isSome
  function: isSome
  id_prefix: isSome

  columns: [id, args, expected]
  rows:
    - [some_42,     [{_tag: "Some", value: 42}],   true]
    - [none_value,  [{_tag: "None"}],               false]

table fp_ts_option.isNone:
  kind: node_module_call_eq
  category: isNone
  function: isNone
  id_prefix: isNone

  columns: [id, args, expected]
  rows:
    - [some_42,     [{_tag: "Some", value: 42}],   false]
    - [none_value,  [{_tag: "None"}],               true]

# fromNullable — null/undefined → None, anything else → Some
table fp_ts_option.fromNullable:
  kind: node_module_call_eq
  category: fromNullable
  function: fromNullable
  id_prefix: fromNullable

  columns: [id, args, expected]
  rows:
    - [null_value,    [~],     {_tag: "None"}]
    - [int_value,     [42],    {_tag: "Some", value: 42}]
    - [string_value,  ["hi"],  {_tag: "Some", value: "hi"}]
    - [empty_string,  [""],    {_tag: "Some", value: ""}]
    - [zero,          [0],     {_tag: "Some", value: 0}]
