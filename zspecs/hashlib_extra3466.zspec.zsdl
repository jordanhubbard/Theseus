spec: hl3466
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 678 (hl3466): __iter__, __next__, __len__ dict-presence checks for hashlib types."
    - "Theme: __iter__/__next__/__len__ dict-presence (iter(x), next(x), len(x))."
    - "All values False — hashlib/uuid/struct/socket types do not implement iterator or sizing protocols."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __iter__, __next__, or __len__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3466.iter:
  description: "hashlib types __iter__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3466
  columns: [id, function, args, expected]
  rows:
    - ["hl3466001", operator.contains, [type(hashlib.md5()).__dict__,        "__iter__"], false]
    - ["hl3466002", operator.contains, [type(hashlib.sha1()).__dict__,       "__iter__"], false]
    - ["hl3466003", operator.contains, [type(hashlib.sha256()).__dict__,     "__iter__"], false]
    - ["hl3466004", operator.contains, [type(hashlib.sha512()).__dict__,     "__iter__"], false]
    - ["hl3466005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__iter__"], false]

