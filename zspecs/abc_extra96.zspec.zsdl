spec: abc_extra96
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra95

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra95.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc.ABCMeta additional method qualnames and abc.abstractproperty identity. NEW in extra96: ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25); ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25, tied); ABCMeta.__instancecheck__.__class__.__name__=='function' (Python function, unlike __subclasshook__ which is builtin); ABCMeta._abc_caches_clear.__qualname__=='ABCMeta._abc_caches_clear' (len=25); ABCMeta._abc_registry_clear.__qualname__=='ABCMeta._abc_registry_clear' (len=27, longest ABCMeta method qualname); ABCMeta.mro.__qualname__=='type.mro' (len=8, inherited from type); abc.abstractproperty.__qualname__=='abstractproperty' (len=16); abc.abstractproperty.__bases__[0].__name__=='property'; abc.abstractproperty.__mro__.__len__()==3; abc.abstractproperty.getter.__qualname__=='property.getter' (len=15, inherited from property); abc.abstractproperty.setter.__qualname__=='property.setter' (len=15, tied); abc.abstractproperty.deleter.__qualname__=='property.deleter' (len=16). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__instancecheck__.__class__.__name__ == 'function'. ABCMeta.__instancecheck__ and __subclasscheck__ are Python functions defined in Lib/abc.py, unlike ABCMeta.__subclasshook__ which is a C-level builtin from Modules/_abc.c. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.mro.__qualname__ == 'type.mro'. ABCMeta.mro is inherited from its base class 'type' (qualname reflects defining class); ABCMeta.mro.__class__.__name__=='method_descriptor' (C-level). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.getter.__qualname__ == 'property.getter'. abstractproperty inherits getter/setter/deleter from property (its base class); all three have class='method_descriptor' (C-level, defined in property). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta __instancecheck__, __subclasscheck__, and internal methods — extra96
#
# Wave 254 theme: ABCMeta additional method qualnames.
#
# ABCMeta.__instancecheck__.__qualname__   == 'ABCMeta.__instancecheck__'   (len=25)
# ABCMeta.__subclasscheck__.__qualname__   == 'ABCMeta.__subclasscheck__'   (len=25)
# ABCMeta.__instancecheck__.__class__.__name__ == 'function'  (Python, not C-level)
# ABCMeta._abc_caches_clear.__qualname__   == 'ABCMeta._abc_caches_clear'   (len=25)
# ABCMeta._abc_registry_clear.__qualname__ == 'ABCMeta._abc_registry_clear' (len=27)
# ABCMeta.mro.__qualname__                 == 'type.mro'                    (len=8, inherited)
# ---------------------------------------------------------------------------

table abc_extra96.abc_abcmeta_extra_qualnames:
  description: "abc.ABCMeta additional method __qualname__ checks in abcabcmetaqn96 namespace — wave 254 theme: ABCMeta methods beyond register and _dump_registry; ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')==True (len=25: 'ABCMeta.'=8 + '__instancecheck__'=17); ABCMeta.__instancecheck__.__class__.__name__.__eq__('function')==True (Python function in Lib/abc.py, unlike __subclasshook__ which is builtin); ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__')==True (len=25: tied with __instancecheck__; 'ABCMeta.'=8 + '__subclasscheck__'=17); ABCMeta.__subclasscheck__.__class__.__name__.__eq__('function')==True (Python function); ABCMeta._abc_caches_clear.__qualname__.__eq__('ABCMeta._abc_caches_clear')==True (len=25: 'ABCMeta.'=8 + '_abc_caches_clear'=17; also 25 chars, tied with __instancecheck__); ABCMeta._abc_registry_clear.__qualname__.__eq__('ABCMeta._abc_registry_clear')==True (len=27: 'ABCMeta.'=8 + '_abc_registry_clear'=19, the longest ABCMeta method qualname); ABCMeta.mro.__qualname__.__eq__('type.mro')==True (len=8: inherited from type base class; class='method_descriptor' — C-level); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmetaqn96

  columns: [id, function, args, expected, description]
  rows:
    - [ick_qeq,      "ABCMeta.__instancecheck__.__qualname__.__eq__",       ["ABCMeta.__instancecheck__"],   true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25); verified with Python 3.14.3"]
    - [ick_qlen,     "ABCMeta.__instancecheck__.__qualname__.__len__",      [],                              25,   "ABCMeta.__instancecheck__.__qualname__.__len__() == 25; verified with Python 3.14.3"]
    - [ick_cls,      "ABCMeta.__instancecheck__.__class__.__name__.__eq__", ["function"],                    true, "ABCMeta.__instancecheck__.__class__.__name__ == 'function' — Python function (not C-level); verified with Python 3.14.3"]
    - [sck_qeq,      "ABCMeta.__subclasscheck__.__qualname__.__eq__",       ["ABCMeta.__subclasscheck__"],   true, "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25, tied with __instancecheck__); verified with Python 3.14.3"]
    - [sck_qlen,     "ABCMeta.__subclasscheck__.__qualname__.__len__",      [],                              25,   "ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 (tied with __instancecheck__); verified with Python 3.14.3"]
    - [sck_cls,      "ABCMeta.__subclasscheck__.__class__.__name__.__eq__", ["function"],                    true, "ABCMeta.__subclasscheck__.__class__.__name__ == 'function' — Python function; verified with Python 3.14.3"]
    - [acc_qeq,      "ABCMeta._abc_caches_clear.__qualname__.__eq__",       ["ABCMeta._abc_caches_clear"],   true, "ABCMeta._abc_caches_clear.__qualname__ == 'ABCMeta._abc_caches_clear' (len=25); verified with Python 3.14.3"]
    - [acc_qlen,     "ABCMeta._abc_caches_clear.__qualname__.__len__",      [],                              25,   "ABCMeta._abc_caches_clear.__qualname__.__len__() == 25 (tied with __instancecheck__); verified with Python 3.14.3"]
    - [arc_qeq,      "ABCMeta._abc_registry_clear.__qualname__.__eq__",     ["ABCMeta._abc_registry_clear"], true, "ABCMeta._abc_registry_clear.__qualname__ == 'ABCMeta._abc_registry_clear' (len=27, longest ABCMeta method); verified with Python 3.14.3"]
    - [arc_qlen,     "ABCMeta._abc_registry_clear.__qualname__.__len__",    [],                              27,   "ABCMeta._abc_registry_clear.__qualname__.__len__() == 27 (longest ABCMeta method qualname); verified with Python 3.14.3"]
    - [mro_qeq,      "ABCMeta.mro.__qualname__.__eq__",                     ["type.mro"],                   true, "ABCMeta.mro.__qualname__ == 'type.mro' (len=8, inherited from type base class); verified with Python 3.14.3"]
    - [mro_qlen,     "ABCMeta.mro.__qualname__.__len__",                    [],                              8,    "ABCMeta.mro.__qualname__.__len__() == 8 (reflects type as defining class); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractproperty class identity and inherited qualnames — extra96
#
# abstractproperty.__qualname__       == 'abstractproperty'  (len=16)
# abstractproperty.__bases__[0].__name__ == 'property'
# abstractproperty.__mro__.__len__()  == 3  [abstractproperty, property, object]
# abstractproperty.getter.__qualname__ == 'property.getter'  (len=15, inherited)
# abstractproperty.setter.__qualname__ == 'property.setter'  (len=15, tied)
# abstractproperty.deleter.__qualname__ == 'property.deleter' (len=16)
# abstractproperty.getter.__class__.__name__ == 'method_descriptor'
# ---------------------------------------------------------------------------

table abc_extra96.abc_abstractproperty_qualnames:
  description: "abc.abstractproperty class identity and method __qualname__ checks in abcabcmetaqn96 namespace — wave 254 theme: abc.abstractproperty is a deprecated subclass of property; abstractproperty.__qualname__.__eq__('abstractproperty')==True (len=16: module-level class so qualname equals name); abstractproperty.__bases__[0].__name__.__eq__('property')==True (inherits from the built-in property descriptor); abstractproperty.__mro__.__len__()==3 ([abstractproperty, property, object]); abstractproperty.getter.__qualname__.__eq__('property.getter')==True (len=15: 'property.'=9 + 'getter'=6; inherited from property, qualname reflects defining class); abstractproperty.setter.__qualname__.__eq__('property.setter')==True (len=15: tied with getter; 'property.'=9 + 'setter'=6); abstractproperty.deleter.__qualname__.__eq__('property.deleter')==True (len=16: 'property.'=9 + 'deleter'=7, one more than getter/setter); all three descriptors have class='method_descriptor' (C-level, defined in property); abstractproperty.__class__.__name__.__eq__('type')==True (abstractproperty is a class); abstractproperty.__module__.__eq__('abc')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmetaqn96a

  columns: [id, function, args, expected, description]
  rows:
    - [ap_qeq,       "abc.abstractproperty.__qualname__.__eq__",              ["abstractproperty"],   true, "abc.abstractproperty.__qualname__ == 'abstractproperty' (len=16); verified with Python 3.14.3"]
    - [ap_qlen,      "abc.abstractproperty.__qualname__.__len__",             [],                     16,   "abc.abstractproperty.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [ap_base0,     "abc.abstractproperty.__bases__[0].__name__.__eq__",     ["property"],           true, "abc.abstractproperty.__bases__[0].__name__ == 'property' — inherits from built-in property; verified with Python 3.14.3"]
    - [ap_mro_len,   "abc.abstractproperty.__mro__.__len__",                  [],                     3,    "abc.abstractproperty.__mro__.__len__() == 3 — [abstractproperty, property, object]; verified with Python 3.14.3"]
    - [ap_get_qeq,   "abc.abstractproperty.getter.__qualname__.__eq__",       ["property.getter"],    true, "abc.abstractproperty.getter.__qualname__ == 'property.getter' (len=15, inherited from property); verified with Python 3.14.3"]
    - [ap_get_qlen,  "abc.abstractproperty.getter.__qualname__.__len__",      [],                     15,   "abc.abstractproperty.getter.__qualname__.__len__() == 15 (inherited, reflects property as defining class); verified with Python 3.14.3"]
    - [ap_get_cls,   "abc.abstractproperty.getter.__class__.__name__.__eq__", ["method_descriptor"],  true, "abc.abstractproperty.getter.__class__.__name__ == 'method_descriptor' — C-level inherited from property; verified with Python 3.14.3"]
    - [ap_set_qeq,   "abc.abstractproperty.setter.__qualname__.__eq__",       ["property.setter"],    true, "abc.abstractproperty.setter.__qualname__ == 'property.setter' (len=15, tied with getter); verified with Python 3.14.3"]
    - [ap_set_qlen,  "abc.abstractproperty.setter.__qualname__.__len__",      [],                     15,   "abc.abstractproperty.setter.__qualname__.__len__() == 15 (tied with getter); verified with Python 3.14.3"]
    - [ap_del_qeq,   "abc.abstractproperty.deleter.__qualname__.__eq__",      ["property.deleter"],   true, "abc.abstractproperty.deleter.__qualname__ == 'property.deleter' (len=16, one more than getter/setter); verified with Python 3.14.3"]
    - [ap_del_qlen,  "abc.abstractproperty.deleter.__qualname__.__len__",     [],                     16,   "abc.abstractproperty.deleter.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [ap_module,    "abc.abstractproperty.__module__.__eq__",                ["abc"],                true, "abc.abstractproperty.__module__ == 'abc'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta class name identity — extra96
#
# ABCMeta.__name__ == 'ABCMeta'  (len=7)
# ABCMeta.__qualname__ == 'ABCMeta'  (len=7)
# ABCMeta.__bases__[0].__name__ == 'type'
# ABC.__class__.__name__ == 'ABCMeta'  (its metaclass)
# ABC.__name__ == 'ABC'  (len=3)
# ABC.__qualname__ == 'ABC'  (len=3)
# ---------------------------------------------------------------------------

table abc_extra96.abc_class_names:
  description: "abc.ABCMeta and abc.ABC class name and metaclass identity checks in abcabcmetaqn96 namespace — wave 254 theme: ABC class name and metaclass relationships; ABCMeta.__name__.__eq__('ABCMeta')==True (len=7: 'ABCMeta' is 7 chars, module-level class so qualname equals name); ABCMeta.__qualname__.__eq__('ABCMeta')==True (len=7); ABCMeta.__qualname__.__len__()==7; ABCMeta.__bases__[0].__name__.__eq__('type')==True (ABCMeta inherits from type; ABCMeta is a metaclass); ABC.__name__.__eq__('ABC')==True (len=3: the shortest name in the abc module); ABC.__qualname__.__eq__('ABC')==True (len=3); ABC.__class__.__name__.__eq__('ABCMeta')==True (ABC's metaclass is ABCMeta — this is how ABC gains its abstract method tracking without explicit use of metaclass=ABCMeta); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcmetaqn96b

  columns: [id, function, args, expected, description]
  rows:
    - [abcm_name_qeq,   "ABCMeta.__name__.__eq__",                ["ABCMeta"],  true, "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [abcm_name_qlen,  "ABCMeta.__name__.__len__",               [],           7,    "abc.ABCMeta.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [abcm_qn_qeq,     "ABCMeta.__qualname__.__eq__",            ["ABCMeta"],  true, "abc.ABCMeta.__qualname__ == 'ABCMeta' (len=7, qualname equals name for module-level class); verified with Python 3.14.3"]
    - [abcm_base0,      "ABCMeta.__bases__[0].__name__.__eq__",   ["type"],     true, "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta inherits from type (it is a metaclass); verified with Python 3.14.3"]
    - [abc_name_qeq,    "ABC.__name__.__eq__",                    ["ABC"],      true, "abc.ABC.__name__ == 'ABC' (len=3, shortest class name in abc module); verified with Python 3.14.3"]
    - [abc_name_qlen,   "ABC.__name__.__len__",                   [],           3,    "abc.ABC.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [abc_qn_qeq,      "ABC.__qualname__.__eq__",                ["ABC"],      true, "abc.ABC.__qualname__ == 'ABC' (len=3, qualname equals name for module-level class); verified with Python 3.14.3"]
    - [abc_metacls,     "ABC.__class__.__name__.__eq__",          ["ABCMeta"],  true, "abc.ABC.__class__.__name__ == 'ABCMeta' — ABC's metaclass is ABCMeta; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra96
# ---------------------------------------------------------------------------

invariant abc_extra96.ABCMeta_registry_clear_qualname_longest:
  description: "abc.ABCMeta._abc_registry_clear.__qualname__.__len__() == 27 — ABCMeta._abc_registry_clear.__qualname__ is 'ABCMeta._abc_registry_clear' (27 chars: 'ABCMeta.'=8 + '_abc_registry_clear'=19); this is the longest qualname among all ABCMeta methods: register=16, _dump_registry=22, __subclasshook__=24, __instancecheck__=25, __subclasscheck__=25, _abc_caches_clear=25, _abc_registry_clear=27; ABCMeta._abc_registry_clear.__class__.__name__ is 'function' (Python function in Lib/abc.py); _abc_registry_clear clears the ABC's virtual subclass registry (registered via ABCMeta.register); compare with ABCMeta._abc_caches_clear (len=25) which clears the __instancecheck__ and __subclasscheck__ caches; NEW in extra96: first standalone ABCMeta._abc_registry_clear qualname length invariant in abcabcmetaqn96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta._abc_registry_clear.__qualname__.__len__"
  args: []
  expected: 27

invariant abc_extra96.ABCMeta_instancecheck_is_function:
  description: "abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__('function') returns True — ABCMeta.__instancecheck__ is a Python function defined in Lib/abc.py; this contrasts with ABCMeta.__subclasshook__ which is a C-level 'builtin_function_or_method' from Modules/_abc.c; ABCMeta.__instancecheck__ is called when isinstance() is used with an ABC instance; it delegates to ABCMeta.__subclasshook__ for the virtual subclass check; ABCMeta.__instancecheck__.__qualname__ is 'ABCMeta.__instancecheck__' (len=25); ABCMeta.__subclasscheck__.__class__.__name__ is also 'function' (both instance and subclass checks are Python functions, only __subclasshook__ is C-level); NEW in extra96: first standalone ABCMeta.__instancecheck__ class name invariant in abcabcmetaqn96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__instancecheck__.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

invariant abc_extra96.abstractproperty_base_is_property:
  description: "abc.abstractproperty.__bases__[0].__name__.__eq__('property') returns True — abstractproperty inherits directly from the built-in property descriptor (MRO=[abstractproperty, property, object], depth=3); abstractproperty.getter, setter, and deleter are all inherited from property and their qualnames use 'property.' prefix (NOT 'abstractproperty.'); abstractproperty.getter.__qualname__.__len__()==15 ('property.getter'), setter.__qualname__.__len__()==15 ('property.setter'), deleter.__qualname__.__len__()==16 ('property.deleter'); all three have class='method_descriptor' (C-level, from the built-in property type); abstractproperty is deprecated since Python 3.3 in favor of combining @property with @abstractmethod; abstractproperty.__module__ is 'abc'; NEW in extra96: first standalone abstractproperty base class invariant in abcabcmetaqn96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abc.abstractproperty.__bases__[0].__name__.__eq__"
  args: ["property"]
  expected: true

invariant abc_extra96.ABCMeta_mro_qualname_inherited_from_type:
  description: "abc.ABCMeta.mro.__qualname__.__eq__('type.mro') returns True — ABCMeta.mro.__qualname__ is 'type.mro' (len=8: 'type.'=5 + 'mro'=3); this reveals that ABCMeta.mro is inherited from its base class 'type' (ABCMeta.__bases__[0].__name__=='type'); the qualname 'type.mro' reflects the defining class (type), not the accessing class (ABCMeta); this parallels asyncio.BoundedSemaphore.acquire.__qualname__=='Semaphore.acquire' and multiprocessing.Process.start.__qualname__=='BaseProcess.start' — in all cases the __qualname__ attribute reveals the actual defining class; ABCMeta.mro.__class__.__name__ is 'method_descriptor' (C-level, inherited from type); ABCMeta.__mro__.__len__() is 3 ([ABCMeta, type, object]); NEW in extra96: first standalone ABCMeta.mro qualname inherited invariant in abcabcmetaqn96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.mro.__qualname__.__eq__"
  args: ["type.mro"]
  expected: true

invariant abc_extra96.ABC_metaclass_is_ABCMeta:
  description: "abc.ABC.__class__.__name__.__eq__('ABCMeta') returns True — ABC's metaclass is ABCMeta; this is the key mechanism behind abc.ABC: by setting metaclass=ABCMeta in ABC's definition, all subclasses of ABC automatically have ABCMeta as their metaclass, enabling abstract method enforcement via __abstractmethods__; ABC.__class__.__name__ is 'ABCMeta' while ABCMeta.__class__.__name__ is 'type' (ABCMeta's metaclass is type, not itself); ABC.__name__.__len__() is 3 (the shortest class name in abc), while ABCMeta.__name__.__len__() is 7; ABC.__mro__.__len__() is 2 ([ABC, object]) while ABCMeta.__mro__.__len__() is 3 ([ABCMeta, type, object]); NEW in extra96: first standalone ABC.__class__.__name__ invariant in abcabcmetaqn96 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABC.__class__.__name__.__eq__"
  args: ["ABCMeta"]
  expected: true
