spec: struct_extra197
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.__name__ == 'struct' — the module's own name."
    - "struct.__package__ == '' — top-level module, empty string package."
    - "struct.__spec__.name == 'struct' — the ModuleSpec name matches the module name."
    - "struct.__loader__.__class__.__name__ == 'SourceFileLoader' — the visible 'struct' module is a thin Python shim (Lib/struct.py) that re-exports from _struct; its loader is SourceFileLoader."
    - "struct.__doc__.__class__.__name__ == 'str' — the module docstring is a str object."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module-level dunder identity attributes — __name__ and __package__
# ---------------------------------------------------------------------------

table struct_extra197.module_name_attrs:
  description: "struct module __name__ and __package__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: structmod197name

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        __name__.__eq__,    ["struct"], true, "struct.__name__ == 'struct'"]
    - [package_eq,     __package__.__eq__, [""],       true, "struct.__package__ == '' — top-level module has empty package string"]
    - [name_is_str,    __name__.__class__.__name__.__eq__,    ["str"], true, "struct.__name__ is a str object"]
    - [package_is_str, __package__.__class__.__name__.__eq__, ["str"], true, "struct.__package__ is a str object"]

# ---------------------------------------------------------------------------
# struct module-level dunder spec attributes — __spec__.name
# ---------------------------------------------------------------------------

table struct_extra197.module_spec_attrs:
  description: "struct module __spec__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: structmod197spec

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,       __spec__.name.__eq__,               ["struct"],    true, "struct.__spec__.name == 'struct'"]
    - [spec_name_is_str,   __spec__.name.__class__.__name__.__eq__, ["str"],   true, "struct.__spec__.name is a str object"]
    - [spec_name_matches,  __spec__.name.__eq__,               ["struct"],    true, "struct.__spec__.name equals struct.__name__"]
    - [spec_class_eq,      __spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "struct.__spec__ is a ModuleSpec object"]

# ---------------------------------------------------------------------------
# struct module-level dunder loader and doc attributes
# ---------------------------------------------------------------------------

table struct_extra197.module_loader_doc_attrs:
  description: "struct module __loader__ and __doc__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: structmod197loader

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_eq,  __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "struct.__loader__.__class__.__name__ == 'SourceFileLoader' — visible struct module is a Python shim in Lib/struct.py"]
    - [doc_class_eq,     __doc__.__class__.__name__.__eq__,    ["str"],              true, "struct.__doc__.__class__.__name__ == 'str' — module docstring is a str"]
    - [doc_is_str,       __doc__.__class__.__name__.__eq__,    ["str"],              true, "struct.__doc__ is a str object (module has a docstring)"]
    - [loader_is_obj,    __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "struct.__loader__ is a SourceFileLoader instance"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant struct_extra197.name_eq:
  description: "struct.__name__ == 'struct'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra197.package_eq:
  description: "struct.__package__ == '' — top-level module, empty package"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant struct_extra197.spec_name_eq:
  description: "struct.__spec__.name == 'struct'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra197.loader_class_name_eq:
  description: "struct.__loader__.__class__.__name__ == 'SourceFileLoader' — the visible struct module is a Python shim; _struct is the underlying C extension"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant struct_extra197.doc_class_name_eq:
  description: "struct.__doc__.__class__.__name__ == 'str' — the module docstring is a str"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra197.name_is_str:
  description: "struct.__name__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra197.package_is_str:
  description: "struct.__package__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __package__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant struct_extra197.spec_name_is_str:
  description: "struct.__spec__.name.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true
