spec: threading_extra2326
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 602 (_extra2326): numeric constants and fixed-size attribute checks."
    - "threading.TIMEOUT_MAX is 9223372036.0 on CPython — a float, not an integer."
    - "threading.active_count is a regular Python function (not a builtin_function_or_method)."
    - "threading defines no integer flag constants; checks focus on module and class name attributes."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: TIMEOUT_MAX constant value and type
# ---------------------------------------------------------------------------

table threading_extra2326.timeout_max:
  description: "threading.TIMEOUT_MAX value and type checks"
  kind: python_call_eq
  category: constants
  id_prefix: th2326

  columns: [id, function, args, expected]
  rows:
    - ["th2326001", "threading.TIMEOUT_MAX",                    [], 9223372036.0]
    - ["th2326002", "threading.TIMEOUT_MAX.__class__.__name__", [], "float"]

# ---------------------------------------------------------------------------
# Table 2: module identity attributes
# ---------------------------------------------------------------------------

table threading_extra2326.module_identity:
  description: "threading module-level __name__ and __spec__ class name"
  kind: python_call_eq
  category: constants
  id_prefix: th2326

  columns: [id, function, args, expected]
  rows:
    - ["th2326003", "threading.__name__",                    [], "threading"]
    - ["th2326004", "threading.__spec__.__class__.__name__", [], "ModuleSpec"]

# ---------------------------------------------------------------------------
# Table 3: threading function and class __name__ attributes
#
# active_count is a Python-level function (not a C builtin).
# The synchronization primitives are Python classes.
# ---------------------------------------------------------------------------

table threading_extra2326.class_names:
  description: "threading synchronization class and function __name__ attributes"
  kind: python_call_eq
  category: constants
  id_prefix: th2326

  columns: [id, function, args, expected]
  rows:
    - ["th2326005", "threading.active_count.__class__.__name__", [], "function"]
    - ["th2326006", "threading.Thread.__name__",                 [], "Thread"]
    - ["th2326007", "threading.Event.__name__",                  [], "Event"]
    - ["th2326008", "threading.Semaphore.__name__",              [], "Semaphore"]
    - ["th2326009", "threading.Barrier.__name__",                [], "Barrier"]
    - ["th2326010", "threading.Timer.__name__",                  [], "Timer"]
    - ["th2326011", "threading.Condition.__name__",              [], "Condition"]

# ---------------------------------------------------------------------------
# Table 4: TIMEOUT_MAX numeric comparisons
#
# Confirms the constant is a large positive float via __gt__ and __lt__.
# ---------------------------------------------------------------------------

table threading_extra2326.timeout_max_comparisons:
  description: "threading.TIMEOUT_MAX numeric comparison checks"
  kind: python_call_eq
  category: constants
  id_prefix: th2326

  columns: [id, function, args, expected]
  rows:
    - ["th2326012", "threading.TIMEOUT_MAX.__gt__", [1000000000.0], true]
    - ["th2326013", "threading.TIMEOUT_MAX.__lt__", [9999999999.0], true]
    - ["th2326014", "threading.TIMEOUT_MAX.__eq__", [9223372036.0], true]
    - ["th2326015", "threading.TIMEOUT_MAX.__gt__", [9223372037.0], false]

# ---------------------------------------------------------------------------
# Table 5: threading class __module__ attributes
#
# Each synchronization class is defined in the threading module itself.
# ---------------------------------------------------------------------------

table threading_extra2326.class_modules:
  description: "threading class __module__ attributes — all equal 'threading'"
  kind: python_call_eq
  category: constants
  id_prefix: th2326

  columns: [id, function, args, expected]
  rows:
    - ["th2326016", "threading.Thread.__module__",    [], "threading"]
    - ["th2326017", "threading.Event.__module__",     [], "threading"]
    - ["th2326018", "threading.Semaphore.__module__", [], "threading"]
    - ["th2326019", "threading.Barrier.__module__",   [], "threading"]
    - ["th2326020", "threading.Timer.__module__",     [], "threading"]
    - ["th2326021", "threading.Condition.__module__", [], "threading"]
