spec: inspect_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "inspect module CPython documentation"
    - "Python 3.9+ standard library"
  not_derived_from:
    - "any third-party inspect extension"
  notes:
    - "Covers FrameInfo, ArgInfo, Traceback named tuple qualnames and module identity"
    - "Also covers ismethoddescriptor, isdatadescriptor, isgetsetdescriptor predicate qualnames"
    - "All rows verify identity properties via __eq__ chains"
  created_at: "2026-04-12"

table inspect_extra826.namedtuple_identity:
  description: "Verify inspect FrameInfo, ArgInfo, and Traceback qualname and module identity"
  kind: python_call_eq
  category: identity
  id_prefix: in826nt
  columns: [id, function, args, expected]
  rows:
    - [in826nt001, "inspect.FrameInfo.__qualname__.__eq__", ["FrameInfo"], true]
    - [in826nt002, "inspect.FrameInfo.__module__.__eq__", ["inspect"], true]
    - [in826nt003, "inspect.ArgInfo.__qualname__.__eq__", ["ArgInfo"], true]
    - [in826nt004, "inspect.ArgInfo.__module__.__eq__", ["inspect"], true]
    - [in826nt005, "inspect.Traceback.__qualname__.__eq__", ["Traceback"], true]
    - [in826nt006, "inspect.Traceback.__module__.__eq__", ["inspect"], true]

table inspect_extra826.predicate_identity:
  description: "Verify inspect predicate function qualnames and module identity"
  kind: python_call_eq
  category: identity
  id_prefix: in826pr
  columns: [id, function, args, expected]
  rows:
    - [in826pr001, "inspect.ismethoddescriptor.__qualname__.__eq__", ["ismethoddescriptor"], true]
    - [in826pr002, "inspect.ismethoddescriptor.__module__.__eq__", ["inspect"], true]
    - [in826pr003, "inspect.isdatadescriptor.__qualname__.__eq__", ["isdatadescriptor"], true]
    - [in826pr004, "inspect.isdatadescriptor.__module__.__eq__", ["inspect"], true]
    - [in826pr005, "inspect.isgetsetdescriptor.__qualname__.__eq__", ["isgetsetdescriptor"], true]
    - [in826pr006, "inspect.isgetsetdescriptor.__module__.__eq__", ["inspect"], true]
