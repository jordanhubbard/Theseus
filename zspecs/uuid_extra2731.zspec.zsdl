spec: uuid_extra2731
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/uuid.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 629 theme: __trunc__, __floor__, and __ceil__ dict-presence checks (numeric rounding protocol)."
    - "uuid.UUID is a value-object class representing a universally unique identifier; it does not implement numeric rounding protocols."
    - "uuid.SafeUUID is an IntEnum subclass representing whether a UUID was generated safely; IntEnum provides rounding via the int MRO, but SafeUUID itself does NOT define __trunc__, __floor__, or __ceil__ in its own __dict__."
    - "None of the uuid public classes define __trunc__, __floor__, or __ceil__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — absent from all uuid classes
# ---------------------------------------------------------------------------

table uuid_extra2731.trunc_protocol:
  description: "__trunc__ is absent from all uuid class __dict__s — none implement numeric truncation in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2731

  columns: [id, function, args, expected]
  rows:
    - ["uu2731001", "uuid.UUID.__dict__.__contains__",     ["__trunc__"], false]
    - ["uu2731002", "uuid.SafeUUID.__dict__.__contains__", ["__trunc__"], false]

# ---------------------------------------------------------------------------
# __floor__ dict-presence — absent from all uuid classes
# ---------------------------------------------------------------------------

table uuid_extra2731.floor_protocol:
  description: "__floor__ is absent from all uuid class __dict__s — none implement floor rounding in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2731

  columns: [id, function, args, expected]
  rows:
    - ["uu2731003", "uuid.UUID.__dict__.__contains__",     ["__floor__"], false]
    - ["uu2731004", "uuid.SafeUUID.__dict__.__contains__", ["__floor__"], false]

# ---------------------------------------------------------------------------
# __ceil__ dict-presence — absent from all uuid classes
# ---------------------------------------------------------------------------

table uuid_extra2731.ceil_protocol:
  description: "__ceil__ is absent from all uuid class __dict__s — none implement ceiling rounding in their own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2731

  columns: [id, function, args, expected]
  rows:
    - ["uu2731005", "uuid.UUID.__dict__.__contains__",     ["__ceil__"], false]
    - ["uu2731006", "uuid.SafeUUID.__dict__.__contains__", ["__ceil__"], false]

# ---------------------------------------------------------------------------
# Combined view — UUID and SafeUUID vs. all three rounding protocols
# ---------------------------------------------------------------------------

table uuid_extra2731.uuid_rounding_combined:
  description: "uuid.UUID and uuid.SafeUUID define none of __trunc__, __floor__, __ceil__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2731

  columns: [id, function, args, expected]
  rows:
    - ["uu2731007", "uuid.UUID.__dict__.__contains__",     ["__trunc__"], false]
    - ["uu2731008", "uuid.UUID.__dict__.__contains__",     ["__floor__"], false]
    - ["uu2731009", "uuid.UUID.__dict__.__contains__",     ["__ceil__"],  false]
    - ["uu2731010", "uuid.SafeUUID.__dict__.__contains__", ["__trunc__"], false]
    - ["uu2731011", "uuid.SafeUUID.__dict__.__contains__", ["__floor__"], false]
    - ["uu2731012", "uuid.SafeUUID.__dict__.__contains__", ["__ceil__"],  false]
