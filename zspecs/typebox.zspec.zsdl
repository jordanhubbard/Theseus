spec: typebox
version: ">=0.34.0"
backend: node(@sinclair/typebox)

docs: https://github.com/sinclairzx81/typebox#readme

provenance:
  derived_from:
    - "TypeBox README — https://github.com/sinclairzx81/typebox#readme"
    - "JSON Schema 2020-12 (draft-bhutton-json-schema)"
    - "Test vectors verified with @sinclair/typebox via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "TypeBox source"
  notes:
    - "JSON Schema builder with TypeScript type inference — schemas are plain JSON Schema objects."
    - "Install: npm install @sinclair/typebox"
    - "v0.34 CJS; named export Type with .String / .Number / .Object / .Array / .Union / .Literal etc."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factories; never throw on valid options."
  stderr: "null"
  stickiness: "N/A — schemas are immutable JSON Schema fragments."
  codes: {}

invariant typebox.string_type:
  description: "Type.String().type is 'string'"
  category: schema
  kind: node_chain_eq
  entry: named
  function: "Type.String"
  entry_args: []
  chain:
    - {get: type}
  expected: "string"

invariant typebox.number_type:
  description: "Type.Number().type is 'number'"
  category: schema
  kind: node_chain_eq
  entry: named
  function: "Type.Number"
  entry_args: []
  chain:
    - {get: type}
  expected: "number"

invariant typebox.boolean_type:
  description: "Type.Boolean().type is 'boolean'"
  category: schema
  kind: node_chain_eq
  entry: named
  function: "Type.Boolean"
  entry_args: []
  chain:
    - {get: type}
  expected: "boolean"

invariant typebox.integer_type:
  description: "Type.Integer().type is 'integer'"
  category: schema
  kind: node_chain_eq
  entry: named
  function: "Type.Integer"
  entry_args: []
  chain:
    - {get: type}
  expected: "integer"

invariant typebox.string_with_min_length:
  description: "Type.String({minLength:3}).minLength is 3 (carried into JSON Schema)"
  category: schema
  kind: node_chain_eq
  entry: named
  function: "Type.String"
  entry_args: [{minLength: 3}]
  chain:
    - {get: minLength}
  expected: 3

invariant typebox.literal_const_value:
  description: "Type.Literal('foo') becomes a string-typed const"
  category: schema
  kind: node_chain_eq
  entry: named
  function: "Type.Literal"
  entry_args: ["foo"]
  chain:
    - {get: const}
  expected: "foo"

invariant typebox.array_items_type:
  description: "Type.Array(Type.Number()).items.type is 'number'"
  category: schema
  kind: node_chain_eq
  entry: named
  function: "Type.Number"
  entry_args: []
  chain:
    - {get: type}
  expected: "number"

invariant typebox.any_type:
  description: "Type.Any() emits {} (no type constraint)"
  category: schema
  kind: node_chain_eq
  entry: named
  function: "Type.Any"
  entry_args: []
  chain:
    - {method: hasOwnProperty, args: ["type"]}
  expected: false

invariant typebox.null_type:
  description: "Type.Null().type is 'null'"
  category: schema
  kind: node_chain_eq
  entry: named
  function: "Type.Null"
  entry_args: []
  chain:
    - {get: type}
  expected: "null"
