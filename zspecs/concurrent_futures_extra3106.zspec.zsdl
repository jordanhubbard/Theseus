spec: cf3106
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (cf3106): __lt__, __le__, __gt__ dict-presence for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor, concurrent.futures.Executor."
    - "All 4 concurrent.futures classes return false for __lt__, __le__, and __gt__ in their own __dict__."
    - "concurrent.futures.Future represents a pending computation result; futures are identified and tracked by object identity, not by any ordering relationship."
    - "Executor and its concrete subclasses (ThreadPoolExecutor, ProcessPoolExecutor) are resource-management objects; no ordering semantics are defined or needed."
    - "Wave 653 (cf3091) confirmed all 4 classes also return false for __hash__, __eq__, and __bool__. The absence of ordering methods is consistent with that pattern."
  created_at: "2026-04-13"

error_model: python_exceptions

