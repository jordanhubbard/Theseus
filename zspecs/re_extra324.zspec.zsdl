spec: re_extra324
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module constants (RegexFlag enum) and RegexFlag class identity
# All test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0.
# re.ASCII == 256; re.LOCALE == 4; re.UNICODE == 32; re.VERBOSE == 64
# re.IGNORECASE == 2; re.MULTILINE == 8; re.DOTALL == 16; re.NOFLAG == 0
# re.RegexFlag.__name__ == 'RegexFlag'; re.RegexFlag.__module__ == 're'
# re.RegexFlag.__bases__[0].__name__ == 'IntFlag'
# re.NOFLAG requires Python 3.11+; version constraint set accordingly.
# ---------------------------------------------------------------------------

invariant re_extra324.ASCII.eq_256:
  description: "re.ASCII.__eq__(256) == True — ASCII flag has integer value 256; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: ASCII.__eq__
  args: [256]
  expected: true

invariant re_extra324.LOCALE.eq_4:
  description: "re.LOCALE.__eq__(4) == True — LOCALE flag has integer value 4; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: LOCALE.__eq__
  args: [4]
  expected: true

invariant re_extra324.UNICODE.eq_32:
  description: "re.UNICODE.__eq__(32) == True — UNICODE flag has integer value 32; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: UNICODE.__eq__
  args: [32]
  expected: true

invariant re_extra324.VERBOSE.eq_64:
  description: "re.VERBOSE.__eq__(64) == True — VERBOSE flag has integer value 64; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: VERBOSE.__eq__
  args: [64]
  expected: true

invariant re_extra324.IGNORECASE.eq_2:
  description: "re.IGNORECASE.__eq__(2) == True — IGNORECASE flag has integer value 2; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: IGNORECASE.__eq__
  args: [2]
  expected: true

invariant re_extra324.MULTILINE.eq_8:
  description: "re.MULTILINE.__eq__(8) == True — MULTILINE flag has integer value 8; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: MULTILINE.__eq__
  args: [8]
  expected: true

invariant re_extra324.DOTALL.eq_16:
  description: "re.DOTALL.__eq__(16) == True — DOTALL flag has integer value 16; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: DOTALL.__eq__
  args: [16]
  expected: true

invariant re_extra324.NOFLAG.eq_0:
  description: "re.NOFLAG.__eq__(0) == True — NOFLAG is the zero-value sentinel introduced in Python 3.11; verified Python 3.14.3"
  category: behavioral
  kind: python_call_eq
  function: NOFLAG.__eq__
  args: [0]
  expected: true

invariant re_extra324.RegexFlag.name:
  description: "re.RegexFlag.__name__ == 'RegexFlag' — the enum class name is 'RegexFlag'; verified Python 3.14.3"
  category: classnames
  kind: python_call_eq
  function: RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra324.RegexFlag.module:
  description: "re.RegexFlag.__module__ == 're' — RegexFlag is defined in the re module; verified Python 3.14.3"
  category: classnames
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra324.RegexFlag.bases_0_name:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from IntFlag; verified Python 3.14.3"
  category: classnames
  kind: python_call_eq
  function: "RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

# ---------------------------------------------------------------------------
# re flag integer values — table form
# ---------------------------------------------------------------------------

table re_extra324.flag_values:
  description: "re module RegexFlag integer values: IGNORECASE (2), LOCALE (4), MULTILINE (8), DOTALL (16), UNICODE (32), VERBOSE (64), ASCII (256), NOFLAG (0)"
  kind: python_call_eq
  category: behavioral
  id_prefix: reflags324

  columns: [id, function, args, expected]
  rows:
    - [ignorecase, IGNORECASE.__eq__, [2],   true]
    - [locale,     LOCALE.__eq__,     [4],   true]
    - [multiline,  MULTILINE.__eq__,  [8],   true]
    - [dotall,     DOTALL.__eq__,     [16],  true]
    - [unicode,    UNICODE.__eq__,    [32],  true]
    - [verbose,    VERBOSE.__eq__,    [64],  true]
    - [ascii,      ASCII.__eq__,      [256], true]
    - [noflag,     NOFLAG.__eq__,     [0],   true]

# ---------------------------------------------------------------------------
# re.RegexFlag class identity — table form
# ---------------------------------------------------------------------------

table re_extra324.RegexFlag_class_identity:
  description: "re.RegexFlag class identity: __name__, __module__, __bases__[0].__name__"
  kind: python_call_eq
  category: classnames
  id_prefix: reflags324

  columns: [id, function, args, expected]
  rows:
    - [class_name,   RegexFlag.__name__.__eq__,              ["RegexFlag"], true]
    - [class_module, RegexFlag.__module__.__eq__,            ["re"],        true]
    - [base_name,    "RegexFlag.__bases__[0].__name__.__eq__", ["IntFlag"], true]
