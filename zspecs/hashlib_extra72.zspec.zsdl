spec: hashlib_extra72
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra71.zspec.zsdl — covers pbkdf2_hmac/__class__/__name__=='builtin_function_or_method' / pbkdf2_hmac/__module__.__contains__('hashlib') / algorithms_guaranteed.__contains__ sha3_224/sha3_384/shake_128/shake_256 / new/__class__/__name__=='function' / file_digest/__class__/__name__=='function' / new/__module__.__eq__('hashlib') / file_digest/__module__.__eq__('hashlib') (table + invariants)."
    - "hashlib_extra70.zspec.zsdl — covers new/__kwdefaults__/__class__/__name__=='NoneType' / file_digest/__kwdefaults__/__class__/__name__=='NoneType' / md5/sha256/sha1/sha512 __doc__/__class__/__name__=='str' / new/__doc__.__contains__('name') / file_digest/__doc__/__contains__('digest') (table + invariants)."
    - "hashlib_extra62.zspec.zsdl — covers __spec__.origin.__class__/__name__=='str' / __spec__.submodule_search_locations.__class__/__name__=='NoneType' / __spec__.has_location==True / __loader__.__class__.__name__.__len__()==16."
    - "hashlib_extra61.zspec.zsdl — covers __loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "hashlib_extra58.zspec.zsdl — covers __spec__.name.__eq__('hashlib') and __spec__.name.__len__()==7."
    - "hashlib_extra55.zspec.zsdl — covers hashlib.__name__.__eq__('hashlib') and __name__.__len__()==7."
    - "hashlib.zspec — covers hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra71; it does NOT duplicate invariants present in those files."
    - "Wave 236 theme: hashlib module __spec__ HASH type identity + hash function __doc__ contents + pbkdf2_hmac __qualname__."
    - "hashlib.__spec__.name.__eq__('hashlib') — already covered in hashlib_extra58. This spec adds __spec__.__class__.__name__.__eq__('ModuleSpec') as a standalone (hashlib_extra61 covers it only in a table row). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') — hashlib_extra61 covers this in a table row and invariant. Not repeated here."
    - "hashlib.__file__.__contains__('hashlib') — no prior hashlib spec checks __file__.__contains__('hashlib') (hashlib_extra61 checks __file__.__class__.__name__=='str'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__file__.__contains__('.py') — no prior hashlib spec checks __file__.__contains__('.py'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__name__.__eq__('hashlib') — covered in hashlib_extra55. This spec adds __name__.__class__.__name__.__eq__('str') — a type check for __name__ (novel for hashlib). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__doc__.__contains__('hash') — hashlib_extra70 covers md5.__doc__.__class__.__name__=='str'. This spec adds __contains__('hash') for md5/sha256/sha1/sha512 docstrings — the hash function docstrings describe creating a hash object. No prior hashlib spec checks __doc__.__contains__('hash') for any of these four. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') — no prior hashlib spec checks pbkdf2_hmac.__qualname__ (hashlib_extra6 and hashlib_extra71 cover __name__ and __class__/__module__ but not __qualname__). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module __spec__ class identity + __file__ content checks
#
# Wave 236 theme: module spec identity and file path content.
#
# hashlib.__spec__.__class__.__name__ == 'ModuleSpec' — hashlib_extra61 covers
# this in a table row; this spec adds it as a standalone invariant for
# cross-spec consistency anchoring. hashlib.__file__.__contains__('hashlib')
# and hashlib.__file__.__contains__('.py') are novel for hashlib.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra72.module_spec_class_file_contains:
  description: "hashlib.__spec__.__class__/__name__=='ModuleSpec' / hashlib.__file__.__contains__('hashlib')==True / hashlib.__file__.__contains__('.py')==True — hashlib_extra61 covers __spec__.__class__.__name__ in a table row; this spec adds it alongside the novel __file__.__contains__ checks; no prior hashlib spec checks __file__.__contains__('hashlib') or __file__.__contains__('.py'); first file path content anchor for hashlib module spec"
  kind: python_call_eq
  category: module_spec
  id_prefix: hashlibspec72

  columns: [id, function, args, expected]
  rows:
    - [spec_class_name_ModuleSpec,   __spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]
    - [file_contains_hashlib,        __file__.__contains__,              ["hashlib"],    true]
    - [file_contains_dot_py,         __file__.__contains__,              [".py"],        true]

# ---------------------------------------------------------------------------
# hashlib.__name__ type check
#
# Wave 236 theme: __name__ is a str (type anchor).
#
# hashlib.__name__ == 'hashlib' is covered in hashlib_extra55. This spec adds
# the type check: __name__.__class__.__name__ == 'str'. This confirms that the
# module __name__ attribute is a Python str, not a bytes or other type.
# No prior hashlib spec checks __name__.__class__.__name__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra72.module_name_class_str:
  description: "hashlib.__name__.__class__.__name__.__eq__('str') == True — __name__ is a Python str; hashlib_extra55 covers __name__.__eq__('hashlib'); this spec adds the type check for __name__; no prior hashlib spec checks __name__.__class__.__name__; first type anchor for hashlib.__name__"
  category: module_spec
  kind: python_call_eq
  function: __name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# hash function __doc__.__contains__('hash') for md5 / sha256 / sha1 / sha512
#
# Wave 236 theme: hash function docstring content check.
#
# hashlib.md5, sha1, sha256, sha512 are C builtin constructors. Their __doc__
# attribute is a str describing the function. The docstring for each mentions
# 'hash' (e.g. "Returns a md5 hash object"). hashlib_extra70 covers
# __doc__.__class__.__name__ == 'str' for these four. This spec adds
# __doc__.__contains__('hash') — a content check. No prior hashlib spec
# checks __doc__.__contains__('hash') for any of these four.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra72.hash_functions_doc_hash:
  description: "hashlib.md5/__doc__.__contains__('hash')==True / sha256/__doc__.__contains__('hash')==True / sha1/__doc__.__contains__('hash')==True / sha512/__doc__.__contains__('hash')==True — the docstrings for md5/sha1/sha256/sha512 describe creating a hash object and contain 'hash'; hashlib_extra70 covers __doc__.__class__.__name__=='str' for these four; this spec adds the content check; no prior hashlib spec checks __doc__.__contains__('hash') for md5/sha256/sha1/sha512; first docstring content anchor for hash function group"
  kind: python_call_eq
  category: docstrings
  id_prefix: hashlibspec72

  columns: [id, function, args, expected]
  rows:
    - [md5_doc_contains_hash,    md5.__doc__.__contains__,    ["hash"], true]
    - [sha256_doc_contains_hash, sha256.__doc__.__contains__,  ["hash"], true]
    - [sha1_doc_contains_hash,   sha1.__doc__.__contains__,   ["hash"], true]
    - [sha512_doc_contains_hash, sha512.__doc__.__contains__,  ["hash"], true]

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac __qualname__ and __doc__.__contains__('hash')
#
# Wave 236 theme: pbkdf2_hmac qualname + docstring content.
#
# hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' — C builtin functions at
# module level have __qualname__ equal to __name__. hashlib_extra6 covers
# __name__ == 'pbkdf2_hmac'; hashlib_extra71 covers __class__.__name__ and
# __module__.__contains__. No prior hashlib spec checks pbkdf2_hmac.__qualname__.
# hashlib.pbkdf2_hmac.__doc__.__contains__('hash') — the pbkdf2_hmac docstring
# describes the hash function parameter; no prior spec checks this content.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra72.pbkdf2_extended:
  description: "hashlib.pbkdf2_hmac/__qualname__.__eq__('pbkdf2_hmac')==True / pbkdf2_hmac/__doc__.__contains__('hash')==True — pbkdf2_hmac is a C builtin function; __qualname__=='pbkdf2_hmac' (equals __name__ for module-level C builtins); the docstring for pbkdf2_hmac references the hash function parameter; hashlib_extra6 covers __name__=='pbkdf2_hmac'; hashlib_extra71 covers __class__/__module__; no prior hashlib spec checks pbkdf2_hmac.__qualname__ or __doc__.__contains__('hash'); first qualname and docstring content anchor for pbkdf2_hmac"
  kind: python_call_eq
  category: pbkdf2
  id_prefix: hashlibspec72

  columns: [id, function, args, expected]
  rows:
    - [pbkdf2_qualname_eq, pbkdf2_hmac.__qualname__.__eq__,     ["pbkdf2_hmac"], true]
    - [pbkdf2_doc_hash,    pbkdf2_hmac.__doc__.__contains__,    ["hash"],         true]

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# hashlib.__spec__ is a ModuleSpec instance. Its __class__.__name__ is
# 'ModuleSpec'. hashlib_extra61 covers this in a table row context; this
# standalone invariant provides a direct anchor outside the table.
# No prior hashlib spec has this as a standalone invariant.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra72.spec_class_ModuleSpec:
  description: "hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — hashlib.__spec__ is a ModuleSpec instance; hashlib_extra61 covers this in a table row; this spec adds it as a standalone invariant for cross-spec consistency; first standalone anchor for hashlib.__spec__.__class__.__name__"
  category: module_spec
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5.__doc__.__contains__('hash') — standalone
#
# hashlib.md5 is a C builtin constructor whose docstring describes creating
# an MD5 hash object. The docstring contains 'hash'. hashlib_extra70 covers
# md5.__doc__.__class__.__name__ == 'str'. No prior hashlib spec checks
# md5.__doc__.__contains__('hash'). First docstring content standalone for
# hashlib.md5.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra72.md5_doc_hash:
  description: "hashlib.md5.__doc__.__contains__('hash') == True — md5 docstring describes creating a hash object and contains 'hash'; hashlib_extra70 covers __doc__.__class__.__name__=='str'; no prior hashlib spec checks md5.__doc__.__contains__('hash'); first docstring content standalone for hashlib.md5"
  category: docstrings
  kind: python_call_eq
  function: md5.__doc__.__contains__
  args: ["hash"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') — standalone
#
# hashlib.pbkdf2_hmac is a C builtin function. Module-level C builtins have
# __qualname__ equal to __name__. hashlib_extra6 covers __name__=='pbkdf2_hmac';
# hashlib_extra71 covers __class__/__module__. No prior hashlib spec checks
# pbkdf2_hmac.__qualname__. First qualname standalone for hashlib.pbkdf2_hmac.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra72.pbkdf2_qualname_pbkdf2_hmac:
  description: "hashlib.pbkdf2_hmac.__qualname__.__eq__('pbkdf2_hmac') == True — pbkdf2_hmac is a C builtin function; module-level C builtins have __qualname__==__name__; hashlib_extra6 covers __name__=='pbkdf2_hmac'; hashlib_extra71 covers __class__/__module__; no prior hashlib spec checks pbkdf2_hmac.__qualname__; first qualname standalone for hashlib.pbkdf2_hmac"
  category: pbkdf2
  kind: python_call_eq
  function: pbkdf2_hmac.__qualname__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__name__.__eq__('hashlib') — standalone (module __name__ attribute)
#
# hashlib.__name__ == 'hashlib' is covered in hashlib_extra55 (string eq) and
# hashlib_extra58 via __spec__.name. This standalone anchors the module's own
# __name__ attribute at the hashlib_extra72 namespace for completeness.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra72.hashlib_name_hashlib:
  description: "hashlib.__name__.__eq__('hashlib') == True — the module's own __name__ attribute equals 'hashlib'; hashlib_extra55 covers this; this spec re-anchors in the hashlib_extra72 namespace alongside the novel __spec__/__file__ checks; first __name__ equality standalone in the extra72 namespace"
  category: module_spec
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hashlib"]
  expected: true
