spec: uuid_extra1561
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "RFC 9562 — Universally Unique IDentifiers (UUIDs)"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for uuid classes."
    - "uuid.UUID defines __int__ in its own __dict__ — confirmed True with Python 3.14.3."
    - "uuid.UUID does NOT define __bool__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, __round__ in its own __dict__."
    - "uuid.SafeUUID is an IntEnum subclass but defines NONE of the numeric protocol methods in its own __dict__."
    - "uuid.SafeUUID.__dict__ contains: _generate_next_value_, safe, unsafe, unknown, and Enum machinery; no numeric dunders."
    - "uuid.UUID.__int__ returns the UUID as a 128-bit integer (the integer attribute); verified with Python 3.14.3."
    - "uuid.UUID.__dict__ dunder keys: __module__, __firstlineno__, __doc__, __slots__, __init__, __getstate__, __setstate__, __eq__, __lt__, __gt__, __le__, __ge__, __hash__, __int__, __repr__, __setattr__, __str__, __static_attributes__, __weakref__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID — numeric conversion protocol dict-presence
#
# uuid.UUID.__dict__.__contains__('__int__')     == True   (UUID defines __int__)
# uuid.UUID.__dict__.__contains__('__bool__')    == False
# uuid.UUID.__dict__.__contains__('__float__')   == False
# uuid.UUID.__dict__.__contains__('__complex__') == False
# uuid.UUID.__dict__.__contains__('__index__')   == False
# uuid.UUID.__dict__.__contains__('__trunc__')   == False
# uuid.UUID.__dict__.__contains__('__floor__')   == False
# uuid.UUID.__dict__.__contains__('__ceil__')    == False
# uuid.UUID.__dict__.__contains__('__round__')   == False
# ---------------------------------------------------------------------------

table uuid_extra1561.uuid_numeric_protocol:
  description: "uuid.UUID numeric conversion protocol dict-presence checks — uu1561un namespace. uuid.UUID defines __int__ (returns the 128-bit integer value of the UUID) but none of the other numeric conversion dunders; UUID is a value type representing a 128-bit identifier, not a general numeric type; __bool__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, __round__ are all absent from uuid.UUID.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: numeric_protocol_presence
  id_prefix: uu1561un

  columns: [id, function, args, expected, description]
  rows:
    - [uu1561un001, uuid.UUID.__dict__.__contains__, ["__int__"],     true,  "uuid.UUID.__dict__.__contains__('__int__')==True — UUID.__int__ IS defined; returns the UUID as a 128-bit integer; verified with Python 3.14.3"]
    - [uu1561un002, uuid.UUID.__dict__.__contains__, ["__bool__"],    false, "uuid.UUID.__dict__.__contains__('__bool__')==False — UUID does not define __bool__ in its own __dict__; verified with Python 3.14.3"]
    - [uu1561un003, uuid.UUID.__dict__.__contains__, ["__float__"],   false, "uuid.UUID.__dict__.__contains__('__float__')==False — UUID cannot be converted to float; no __float__ in UUID.__dict__; verified with Python 3.14.3"]
    - [uu1561un004, uuid.UUID.__dict__.__contains__, ["__complex__"], false, "uuid.UUID.__dict__.__contains__('__complex__')==False — UUID defines no __complex__; verified with Python 3.14.3"]
    - [uu1561un005, uuid.UUID.__dict__.__contains__, ["__index__"],   false, "uuid.UUID.__dict__.__contains__('__index__')==False — UUID cannot be used as a sequence index; no __index__ in UUID.__dict__; verified with Python 3.14.3"]
    - [uu1561un006, uuid.UUID.__dict__.__contains__, ["__trunc__"],   false, "uuid.UUID.__dict__.__contains__('__trunc__')==False — math.trunc() protocol not supported by UUID; verified with Python 3.14.3"]
    - [uu1561un007, uuid.UUID.__dict__.__contains__, ["__floor__"],   false, "uuid.UUID.__dict__.__contains__('__floor__')==False — math.floor() protocol not supported by UUID; verified with Python 3.14.3"]
    - [uu1561un008, uuid.UUID.__dict__.__contains__, ["__ceil__"],    false, "uuid.UUID.__dict__.__contains__('__ceil__')==False — math.ceil() protocol not supported by UUID; verified with Python 3.14.3"]
    - [uu1561un009, uuid.UUID.__dict__.__contains__, ["__round__"],   false, "uuid.UUID.__dict__.__contains__('__round__')==False — round() protocol not supported by UUID; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: uuid.SafeUUID — numeric conversion protocol dict-presence (all False)
#
# uuid.SafeUUID.__dict__.__contains__('__int__')     == False
# uuid.SafeUUID.__dict__.__contains__('__bool__')    == False
# uuid.SafeUUID.__dict__.__contains__('__float__')   == False
# uuid.SafeUUID.__dict__.__contains__('__index__')   == False
# uuid.SafeUUID.__dict__.__contains__('__trunc__')   == False
# uuid.SafeUUID.__dict__.__contains__('__floor__')   == False
# uuid.SafeUUID.__dict__.__contains__('__ceil__')    == False
# uuid.SafeUUID.__dict__.__contains__('__round__')   == False
# ---------------------------------------------------------------------------

table uuid_extra1561.safeuuid_numeric_protocol:
  description: "uuid.SafeUUID numeric conversion protocol dict-presence checks — uu1561sn namespace. SafeUUID is an IntEnum (values: safe=0, unsafe=-1, unknown=None) but defines none of the numeric conversion dunders in its own __dict__; SafeUUID inherits __int__ from int via IntEnum but does not define it in SafeUUID.__dict__ itself; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: numeric_protocol_presence
  id_prefix: uu1561sn

  columns: [id, function, args, expected, description]
  rows:
    - [uu1561sn001, uuid.SafeUUID.__dict__.__contains__, ["__int__"],     false, "uuid.SafeUUID.__dict__.__contains__('__int__')==False — SafeUUID does not define __int__ in its own __dict__; inherits from int via IntEnum; verified with Python 3.14.3"]
    - [uu1561sn002, uuid.SafeUUID.__dict__.__contains__, ["__bool__"],    false, "uuid.SafeUUID.__dict__.__contains__('__bool__')==False — SafeUUID does not define __bool__ in its own __dict__; verified with Python 3.14.3"]
    - [uu1561sn003, uuid.SafeUUID.__dict__.__contains__, ["__float__"],   false, "uuid.SafeUUID.__dict__.__contains__('__float__')==False — SafeUUID defines no __float__ in its own __dict__; verified with Python 3.14.3"]
    - [uu1561sn004, uuid.SafeUUID.__dict__.__contains__, ["__index__"],   false, "uuid.SafeUUID.__dict__.__contains__('__index__')==False — SafeUUID defines no __index__ in its own __dict__; verified with Python 3.14.3"]
    - [uu1561sn005, uuid.SafeUUID.__dict__.__contains__, ["__trunc__"],   false, "uuid.SafeUUID.__dict__.__contains__('__trunc__')==False — math.trunc() protocol not defined in SafeUUID.__dict__; verified with Python 3.14.3"]
    - [uu1561sn006, uuid.SafeUUID.__dict__.__contains__, ["__floor__"],   false, "uuid.SafeUUID.__dict__.__contains__('__floor__')==False — math.floor() protocol not defined in SafeUUID.__dict__; verified with Python 3.14.3"]
    - [uu1561sn007, uuid.SafeUUID.__dict__.__contains__, ["__ceil__"],    false, "uuid.SafeUUID.__dict__.__contains__('__ceil__')==False — math.ceil() protocol not defined in SafeUUID.__dict__; verified with Python 3.14.3"]
    - [uu1561sn008, uuid.SafeUUID.__dict__.__contains__, ["__round__"],   false, "uuid.SafeUUID.__dict__.__contains__('__round__')==False — round() protocol not defined in SafeUUID.__dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID — non-numeric dunder presence (positive checks)
#
# Confirms the dunders that UUID DOES define in its own __dict__:
# __int__, __eq__, __lt__, __gt__, __le__, __ge__, __hash__, __repr__, __str__
# ---------------------------------------------------------------------------

table uuid_extra1561.uuid_dunder_presence:
  description: "uuid.UUID defines ordering, equality, hashing, and string representation dunders in its own __dict__ — uu1561ud namespace. These positive checks confirm the dunders UUID does own: __int__ (128-bit integer value), __eq__, __lt__, __gt__, __le__, __ge__ (lexicographic ordering by integer value), __hash__ (consistent with __eq__), __repr__, __str__ (standard UUID string form); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_presence
  id_prefix: uu1561ud

  columns: [id, function, args, expected, description]
  rows:
    - [uu1561ud001, uuid.UUID.__dict__.__contains__, ["__eq__"],       true,  "uuid.UUID.__dict__.__contains__('__eq__')==True — UUID.__eq__ IS defined; UUIDs compare equal iff their 128-bit integer values match; verified with Python 3.14.3"]
    - [uu1561ud002, uuid.UUID.__dict__.__contains__, ["__lt__"],       true,  "uuid.UUID.__dict__.__contains__('__lt__')==True — UUID.__lt__ IS defined; UUIDs are ordered by their integer value; verified with Python 3.14.3"]
    - [uu1561ud003, uuid.UUID.__dict__.__contains__, ["__hash__"],     true,  "uuid.UUID.__dict__.__contains__('__hash__')==True — UUID.__hash__ IS defined; consistent with __eq__; verified with Python 3.14.3"]
    - [uu1561ud004, uuid.UUID.__dict__.__contains__, ["__repr__"],     true,  "uuid.UUID.__dict__.__contains__('__repr__')==True — UUID.__repr__ IS defined; verified with Python 3.14.3"]
    - [uu1561ud005, uuid.UUID.__dict__.__contains__, ["__str__"],      true,  "uuid.UUID.__dict__.__contains__('__str__')==True — UUID.__str__ IS defined; returns standard 8-4-4-4-12 hex string; verified with Python 3.14.3"]
    - [uu1561ud006, uuid.UUID.__dict__.__contains__, ["__int__"],      true,  "uuid.UUID.__dict__.__contains__('__int__')==True — UUID.__int__ IS defined; returns UUID as 128-bit integer; verified with Python 3.14.3"]
    - [uu1561ud007, uuid.UUID.__dict__.__contains__, ["__slots__"],    true,  "uuid.UUID.__dict__.__contains__('__slots__')==True — UUID uses __slots__ for memory efficiency; verified with Python 3.14.3"]
    - [uu1561ud008, uuid.UUID.__dict__.__contains__, ["__init__"],     true,  "uuid.UUID.__dict__.__contains__('__init__')==True — UUID.__init__ IS defined; accepts hex, bytes, bytes_le, fields, int, version args; verified with Python 3.14.3"]
