spec: socket_extra48
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra47.zspec.zsdl — covers socket/herror/gaierror/timeout __class__.__qualname__.__eq__('type'), gethostname/gethostbyname __class__.__qualname__.__eq__('builtin_function_or_method'), getaddrinfo/getfqdn __class__.__qualname__.__eq__('function'), socket/gethostname/getaddrinfo __class__.__module__.__eq__('builtins')."
    - "socket_extra46.zspec.zsdl — covers socket.socket/__class__.__name__.__eq__('type'), herror/gaierror/timeout/__class__.__name__.__eq__('type'), gethostname/gethostbyname/__class__.__name__.__eq__('builtin_function_or_method'), getaddrinfo/getfqdn/__class__.__name__.__eq__('function')."
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3; socket.error/__mro__.__len__()==4; timeout/herror/gaierror/__mro__.__len__()==5."
    - "socket_extra26.zspec.zsdl — covers timeout/herror/gaierror/__bases__[0].__name__.__eq__('OSError') and socket.socket/__init__.__name__."
    - "socket_extra25.zspec.zsdl — covers herror/gaierror/__module__.__eq__('socket'), timeout/__module__.__eq__('builtins')."
    - "socket_extra17.zspec.zsdl — covers herror/gaierror/timeout/__mro__.__len__()==5 and herror/gaierror/__bases__.__getitem__ forms."
    - "socket_extra3.zspec.zsdl — covers herror/__bases__[0].__name__.__eq__('OSError') and gaierror/__bases__[0].__name__.__eq__('OSError')."
  notes:
    - "This spec extends socket through socket_extra47; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior socket spec checks __bases__[0].__qualname__.__eq__ for herror, gaierror, or timeout. Prior specs (socket_extra3, socket_extra26) cover __bases__[0].__name__.__eq__('OSError') for all three (the __name__ axis). For built-in types like OSError, __qualname__ == __name__, but accessing .__qualname__ is a distinct attribute chain providing an independent regression vector. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.herror.__bases__[0].__qualname__ == 'OSError'. herror inherits from OSError; its base class's __qualname__ is 'OSError'. socket_extra3/socket_extra26 cover __bases__[0].__name__.__eq__('OSError') (different axis). No prior spec checks __bases__[0].__qualname__.__eq__ for herror. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gaierror.__bases__[0].__qualname__ == 'OSError'. gaierror inherits from OSError. No prior spec checks gaierror.__bases__[0].__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.timeout.__bases__[0].__qualname__ == 'OSError'. socket.timeout is an alias for TimeoutError which inherits from OSError. socket_extra26 covers __bases__[0].__name__.__eq__('OSError'); no prior spec checks __qualname__ for this base. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior socket spec checks __doc__.__class__.__name__.__eq__('str') for any socket object. The socket module's exception classes (herror, gaierror, timeout) and socket.socket all expose docstrings as Python str objects. Checking __doc__.__class__.__name__ confirms the docstring type as a structural regression vector independent of content. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.herror.__doc__.__class__.__name__ == 'str'. herror has a docstring exposed as a Python str. No prior socket spec checks herror.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gaierror.__doc__.__class__.__name__ == 'str'. gaierror has a docstring. No prior socket spec checks gaierror.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.timeout.__doc__.__class__.__name__ == 'str'. timeout (TimeoutError) has a docstring. No prior socket spec checks timeout.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.__doc__.__class__.__name__ == 'str'. socket.socket has a C-level docstring. No prior socket spec checks socket.__doc__.__class__.__name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.herror/gaierror/timeout __bases__[0].__qualname__.__eq__('OSError')
#
# socket_extra3 covers herror/__bases__[0].__name__.__eq__('OSError') and
# gaierror/__bases__[0].__name__.__eq__('OSError') (__name__ axis).
# socket_extra26 covers all three via __bases__[0].__name__.__eq__('OSError').
# No prior socket spec checks __bases__[0].__qualname__.__eq__ for any of these.
# For the built-in OSError type, __qualname__ == __name__ == 'OSError', but
# accessing via .__qualname__ is a distinct chain and an independent regression vector.
# Functions containing '[' in the dotted chain MUST be double-quoted.
# ---------------------------------------------------------------------------

table socket_extra48.exception_base_qualnames:
  description: "socket.herror/gaierror/timeout __bases__[0]/__qualname__.__eq__('OSError') — each socket exception inherits from OSError; novel __qualname__ axis; socket_extra3/socket_extra26 cover __bases__[0].__name__.__eq__('OSError') (__name__ axis only); no prior socket spec checks __bases__[0].__qualname__.__eq__ for any socket exception"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketexc48

  columns: [id, function, args, expected]
  rows:
    - [herror_base_qualname_eq,  "herror.__bases__[0].__qualname__.__eq__",  ["OSError"], true]
    - [gaierror_base_qualname_eq, "gaierror.__bases__[0].__qualname__.__eq__", ["OSError"], true]
    - [timeout_base_qualname_eq, "timeout.__bases__[0].__qualname__.__eq__", ["OSError"], true]

# ---------------------------------------------------------------------------
# socket exception and socket.socket __doc__.__class__.__name__.__eq__('str')
#
# No prior socket spec checks __doc__.__class__.__name__ for any socket object.
# herror, gaierror, timeout (all Python exception classes), and socket.socket
# (a Python class wrapping C socket objects) all expose docstrings as Python str.
# This table provides a novel structural regression vector for all four objects.
# ---------------------------------------------------------------------------

table socket_extra48.doc_class_names:
  description: "socket.herror/gaierror/timeout/socket __doc__.__class__.__name__.__eq__('str') — verifies each socket object's docstring is a Python str; novel __doc__.__class__.__name__ axis; no prior socket spec checks __doc__.__class__.__name__ for any socket object"
  kind: python_call_eq
  category: type_structure
  id_prefix: socketexcdoc48

  columns: [id, function, args, expected]
  rows:
    - [herror_doc_class_name_eq,  herror.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [gaierror_doc_class_name_eq, gaierror.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [timeout_doc_class_name_eq, timeout.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [socket_doc_class_name_eq,  socket.__doc__.__class__.__name__.__eq__,  ["str"], true]
