spec: socket_extra262
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra261.zspec.zsdl — covers socket.socket instance attributes family/type/proto/timeout and SHUT_RD/WR/RDWR constant class names and values."
    - "socket_extra259.zspec.zsdl — covers create_connection/create_server/has_dualstack_ipv6 identity and IPPROTO constants."
    - "socket_extra.zspec.zsdl — covers create_connection/create_server/setdefaulttimeout/htons/ntohs function names; htons(0)==0, ntohs(0)==0, ntohl(0)==0, htonl(1)==16777216."
  notes:
    - "socket.socketpair is a pure-Python function defined in Lib/socket.py; __module__ == 'socket', __class__.__name__ == 'function'."
    - "socket.fromfd is a pure-Python function defined in Lib/socket.py; __module__ == 'socket', __class__.__name__ == 'function'."
    - "socket.ntohs is a C builtin from _socket; __module__ == '_socket', __class__.__name__ == 'builtin_function_or_method'."
    - "socket.htons is a C builtin from _socket; __module__ == '_socket', __class__.__name__ == 'builtin_function_or_method'."
    - "socket.ntohl is a C builtin from _socket; __module__ == '_socket', __class__.__name__ == 'builtin_function_or_method'."
    - "socket.htonl is a C builtin from _socket; __module__ == '_socket', __class__.__name__ == 'builtin_function_or_method'."
    - "socket.ntohs(256) == 1 on little-endian (x86_64/arm64): 256 == 0x0100; byte-swapped == 0x0001 == 1."
    - "socket.htons(1) == 256 on little-endian (x86_64/arm64): 1 == 0x0001; byte-swapped == 0x0100 == 256."
    - "socket.ntohs(256) and socket.htons(1) are already covered as value checks in socket_extra.zspec.zsdl for htonl(1)==16777216; the 16-bit conversions are new here."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socketpair function identity
# Pure-Python function in Lib/socket.py — module == 'socket', class == 'function'
# ---------------------------------------------------------------------------

table socket_extra262.socketpair_identity:
  description: "socket.socketpair function identity — pure Python from Lib/socket.py; __module__=='socket', __class__.__name__=='function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: socksp262

  columns: [id, function, args, expected, description]
  rows:
    - [sp_name,     socketpair.__name__.__eq__,           ["socketpair"], true, "socket.socketpair.__name__ == 'socketpair'"]
    - [sp_qualname, socketpair.__qualname__.__eq__,        ["socketpair"], true, "socket.socketpair.__qualname__ == 'socketpair' (module-level function)"]
    - [sp_module,   socketpair.__module__.__eq__,          ["socket"],     true, "socket.socketpair.__module__ == 'socket' (pure Python in Lib/socket.py)"]
    - [sp_class,    socketpair.__class__.__name__.__eq__,  ["function"],   true, "socket.socketpair.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# socket.fromfd function identity
# Pure-Python function in Lib/socket.py — module == 'socket', class == 'function'
# ---------------------------------------------------------------------------

table socket_extra262.fromfd_identity:
  description: "socket.fromfd function identity — pure Python from Lib/socket.py; __module__=='socket', __class__.__name__=='function'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockfd262

  columns: [id, function, args, expected, description]
  rows:
    - [fd_name,     fromfd.__name__.__eq__,           ["fromfd"],  true, "socket.fromfd.__name__ == 'fromfd'"]
    - [fd_qualname, fromfd.__qualname__.__eq__,        ["fromfd"],  true, "socket.fromfd.__qualname__ == 'fromfd' (module-level function)"]
    - [fd_module,   fromfd.__module__.__eq__,          ["socket"],  true, "socket.fromfd.__module__ == 'socket' (pure Python in Lib/socket.py)"]
    - [fd_class,    fromfd.__class__.__name__.__eq__,  ["function"], true, "socket.fromfd.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# socket.ntohs, socket.htons, socket.ntohl, socket.htonl — function identity
# All four are C builtins from _socket; __module__ == '_socket',
# __class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table socket_extra262.byte_order_functions_identity:
  description: "socket.ntohs/htons/ntohl/htonl function identity — C builtins from _socket; __class__.__name__=='builtin_function_or_method'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockbo262

  columns: [id, function, args, expected, description]
  rows:
    - [ntohs_name,   ntohs.__name__.__eq__,              ["ntohs"],                       true, "socket.ntohs.__name__ == 'ntohs'"]
    - [ntohs_qname,  ntohs.__qualname__.__eq__,           ["ntohs"],                       true, "socket.ntohs.__qualname__ == 'ntohs' (module-level builtin)"]
    - [ntohs_class,  ntohs.__class__.__name__.__eq__,     ["builtin_function_or_method"],  true, "socket.ntohs.__class__.__name__ == 'builtin_function_or_method'"]
    - [htons_name,   htons.__name__.__eq__,              ["htons"],                       true, "socket.htons.__name__ == 'htons'"]
    - [ntohl_name,   ntohl.__name__.__eq__,              ["ntohl"],                       true, "socket.ntohl.__name__ == 'ntohl'"]
    - [htonl_name,   htonl.__name__.__eq__,              ["htonl"],                       true, "socket.htonl.__name__ == 'htonl'"]

# ---------------------------------------------------------------------------
# socket.ntohs(256) and socket.htons(1) — byte-order conversion values
# On little-endian (x86_64/arm64) macOS/Darwin:
#   ntohs(256) == 1  (256 == 0x0100 network byte order -> host == 0x0001 == 1)
#   htons(1)   == 256 (1 == 0x0001 host byte order -> network == 0x0100 == 256)
# ---------------------------------------------------------------------------

invariant socket_extra262.ntohs.little_endian_256:
  description: "socket.ntohs(256) == 1 on little-endian (x86_64/arm64): 256==0x0100 byte-swapped to 0x0001==1"
  category: functions
  kind: python_call_eq
  function: ntohs
  args: [256]
  expected: 1

invariant socket_extra262.htons.little_endian_1:
  description: "socket.htons(1) == 256 on little-endian (x86_64/arm64): 1==0x0001 byte-swapped to 0x0100==256"
  category: functions
  kind: python_call_eq
  function: htons
  args: [1]
  expected: 256
