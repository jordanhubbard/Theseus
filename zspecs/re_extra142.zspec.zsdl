spec: re_extra142
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec covers: re.Match method identity (expand, group, start, end, span, groups, groupdict) and re.Match/__repr__ wrapper_descriptor identity, plus re.Match and re.Pattern __doc__ attributes."
    - "re.Match.expand.__qualname__ == 'Match.expand' (12); __class__.__name__ == 'method_descriptor'."
    - "re.Match.__repr__.__qualname__ == 'Match.__repr__' (14); __class__.__name__ == 'wrapper_descriptor'."
    - "re.Match.group, start, end, span, groups, groupdict are all method_descriptor instances."
    - "re.Match.__name__ == 'Match' (5); re.Pattern.__name__ == 'Pattern' (7)."
    - "re.Match.__module__ == 're' (2); re.Pattern.__module__ == 're' (2)."
    - "re.Match.__doc__.__class__.__name__ == 'str'; len(re.Match.__doc__) == 92."
    - "re.Pattern.__doc__.__class__.__name__ == 'str'; len(re.Pattern.__doc__) == 35."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match method_descriptor identity: expand, group, start, end
# All four are method_descriptor instances.
# expand.__qualname__ == 'Match.expand' (12).
# group.__qualname__ == 'Match.group' (11).
# start.__qualname__ == 'Match.start' (11).
# end.__qualname__ == 'Match.end' (9).
# ---------------------------------------------------------------------------

table re_extra142.Match_method_descriptors_expand_group_start_end:
  description: "re.Match method_descriptor identity for expand/group/start/end: all method_descriptor; expand.__qualname__='Match.expand' (12), group='Match.group' (11), start='Match.start' (11), end='Match.end' (9)"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: rematch142

  columns: [id, function, args, expected]
  rows:
    - [expand_cls_eq,    Match.expand.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [group_cls_eq,     Match.group.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [start_cls_eq,     Match.start.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [end_cls_eq,       Match.end.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [expand_qn_eq,     Match.expand.__qualname__.__eq__,         ["Match.expand"],      true]
    - [expand_qn_len,    Match.expand.__qualname__.__len__,        [],                    12]
    - [group_qn_eq,      Match.group.__qualname__.__eq__,          ["Match.group"],       true]
    - [group_qn_len,     Match.group.__qualname__.__len__,         [],                    11]
    - [start_qn_eq,      Match.start.__qualname__.__eq__,          ["Match.start"],       true]
    - [start_qn_len,     Match.start.__qualname__.__len__,         [],                    11]
    - [end_qn_eq,        Match.end.__qualname__.__eq__,            ["Match.end"],         true]
    - [end_qn_len,       Match.end.__qualname__.__len__,           [],                    9]

