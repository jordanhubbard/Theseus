    - [repr_qn_len,  "Match.__repr__.__qualname__.__len__",       [],                     14]

# ---------------------------------------------------------------------------
# re.Match and re.Pattern class identity and __doc__
# Match.__name__ == 'Match' (5), __module__ == 're' (2).
# Pattern.__name__ == 'Pattern' (7), __module__ == 're' (2).
# Match.__doc__.__class__.__name__ == 'str', len == 92.
# Pattern.__doc__.__class__.__name__ == 'str', len == 35.
# ---------------------------------------------------------------------------

table re_extra142.Match_Pattern_identity_and_doc:
  description: "re.Match and re.Pattern class identity: Match.__name__='Match' (5), Pattern.__name__='Pattern' (7), both __module__='re' (2); Match.__doc__ len=92, Pattern.__doc__ len=35"
  kind: python_call_eq
  category: class_identity
  id_prefix: rematch142

  columns: [id, function, args, expected]
  rows:
    - [match_name_eq,    Match.__name__.__eq__,                  ["Match"],   true]
    - [match_name_len,   Match.__name__.__len__,                 [],          5]
    - [match_module_eq,  Match.__module__.__eq__,                ["re"],      true]
    - [match_module_len, Match.__module__.__len__,               [],          2]
    - [pat_name_eq,      Pattern.__name__.__eq__,                ["Pattern"], true]
    - [pat_name_len,     Pattern.__name__.__len__,               [],          7]
    - [pat_module_eq,    Pattern.__module__.__eq__,              ["re"],      true]
    - [match_doc_cls_eq, Match.__doc__.__class__.__name__.__eq__, ["str"],    true]
    - [match_doc_len,    Match.__doc__.__len__,                  [],          92]
    - [pat_doc_cls_eq,   Pattern.__doc__.__class__.__name__.__eq__, ["str"],  true]
    - [pat_doc_len,      Pattern.__doc__.__len__,                [],          35]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra142.Match.expand_is_method_descriptor:
  description: "re.Match.expand.__class__.__name__ == 'method_descriptor' (expand interpolates back-references in a replacement string; implemented as a named C method, distinct from slot wrappers like __repr__ which are wrapper_descriptor)"
  category: method_descriptor
  kind: python_call_eq
  function: Match.expand.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra142.Match.__repr__is_wrapper_descriptor:
  description: "re.Match.__repr__.__class__.__name__ == 'wrapper_descriptor' (not method_descriptor; __repr__ is a slot wrapper generated by the C type machinery, distinct from named methods like expand/group/span)"
  category: wrapper_descriptor
  kind: python_call_eq
  function: "Match.__repr__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant re_extra142.Match.expand_qualname_len_12:
  description: "re.Match.expand.__qualname__.__len__() == 12 ('Match.expand' has 12 characters; 'Match.' prefix is 6 characters, 'expand' is 6 characters)"
  category: method_descriptor
  kind: python_call_eq
  function: Match.expand.__qualname__.__len__
  args: []
  expected: 12

invariant re_extra142.Match.groupdict_qualname_len_15:
  description: "re.Match.groupdict.__qualname__.__len__() == 15 ('Match.groupdict' has 15 characters; the longest qualname among the Match extraction methods — expand=12, group=11, start=11, end=9, span=10, groups=12, groupdict=15)"
  category: method_descriptor
  kind: python_call_eq
  function: Match.groupdict.__qualname__.__len__
  args: []
  expected: 15

invariant re_extra142.Match.doc_len_92:
  description: "re.Match.__doc__.__len__() == 92 (Match has a 92-character docstring; longer than Pattern.__doc__ (35 characters) because Match documents the result object returned by search/match)"
  category: doc_identity
  kind: python_call_eq
  function: Match.__doc__.__len__
  args: []
  expected: 92

invariant re_extra142.Pattern.doc_len_35:
  description: "re.Pattern.__doc__.__len__() == 35 (Pattern has a 35-character docstring; shorter than Match.__doc__ (92) — Pattern is the compiled pattern object, Match is the result of applying it)"
  category: doc_identity
  kind: python_call_eq
  function: Pattern.__doc__.__len__
  args: []
  expected: 35

