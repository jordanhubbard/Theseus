spec: abc_extra261
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc documentation"
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Lib/_collections_abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABC.__module__ == 'abc'; ABC.__bases__[0].__name__ == 'object'."
    - "abc.ABCMeta.__module__ == 'abc'; ABCMeta.__bases__[0].__name__ == 'type' (it is a metaclass)."
    - "collections.abc.Mapping.__module__ == 'collections.abc'; base is Collection."
    - "collections.abc.Sequence.__module__ == 'collections.abc'; base is Reversible."
    - "collections.abc.Iterable.__module__ == 'collections.abc'; base is object."
    - "collections.abc.Iterator.__module__ == 'collections.abc'; base is Iterable."
    - "collections.abc.Callable.__module__ == 'collections.abc'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC and abc.ABCMeta class identity — table
#
# ABC is a simple helper class that uses ABCMeta as its metaclass.
# ABCMeta is a metaclass (inherits from type).
# Both are defined in the abc module.
# ---------------------------------------------------------------------------

table abc_extra261.abc_class_names:
  description: "abc.ABC and abc.ABCMeta report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: abcname

  columns: [id, function, args, expected, description]
  rows:
    - [ABC,     ABC.__name__.__eq__,     ["ABC"],     true, "abc.ABC.__name__ == 'ABC'"]
    - [ABCMeta, ABCMeta.__name__.__eq__, ["ABCMeta"], true, "abc.ABCMeta.__name__ == 'ABCMeta'"]

# ---------------------------------------------------------------------------
# collections.abc class identity — __name__ and __module__ table
#
# Mapping, Sequence, Iterable, Iterator, Callable are five widely-used
# abstract base classes from the collections.abc module.
# ---------------------------------------------------------------------------

table abc_extra261.collections_abc_class_names:
  description: "collections.abc ABCs report the expected __name__ and __module__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: colabcname

  columns: [id, function, args, expected, description]
  rows:
    - [Mapping_name,   collections.abc.Mapping.__name__.__eq__,   ["Mapping"],         true, "collections.abc.Mapping.__name__ == 'Mapping'"]
    - [Mapping_mod,    collections.abc.Mapping.__module__.__eq__,  ["collections.abc"], true, "collections.abc.Mapping.__module__ == 'collections.abc'"]
    - [Sequence_name,  collections.abc.Sequence.__name__.__eq__,  ["Sequence"],        true, "collections.abc.Sequence.__name__ == 'Sequence'"]
    - [Sequence_mod,   collections.abc.Sequence.__module__.__eq__, ["collections.abc"], true, "collections.abc.Sequence.__module__ == 'collections.abc'"]
    - [Iterable_name,  collections.abc.Iterable.__name__.__eq__,  ["Iterable"],        true, "collections.abc.Iterable.__name__ == 'Iterable'"]

# ---------------------------------------------------------------------------
# abc module membership — standalone invariants
# ---------------------------------------------------------------------------

invariant abc_extra261.ABC.module:
  description: "abc.ABC.__module__ == 'abc'"
  category: identity
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra261.ABCMeta.module:
  description: "abc.ABCMeta.__module__ == 'abc'"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra261.ABC.base:
  description: "abc.ABC.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: ABC.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant abc_extra261.ABCMeta.base:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta is a metaclass deriving from type"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "type"

# ---------------------------------------------------------------------------
# collections.abc base classes — standalone invariants
#
# Mapping inherits from Collection; Sequence from Reversible;
# Iterable from object; Iterator from Iterable.
# ---------------------------------------------------------------------------

invariant abc_extra261.Mapping.base:
  description: "collections.abc.Mapping.__bases__[0].__name__ == 'Collection'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Mapping.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Collection"

invariant abc_extra261.Sequence.base:
  description: "collections.abc.Sequence.__bases__[0].__name__ == 'Reversible'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Sequence.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Reversible"

invariant abc_extra261.Iterable.base:
  description: "collections.abc.Iterable.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Iterable.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant abc_extra261.Iterator.base:
  description: "collections.abc.Iterator.__bases__[0].__name__ == 'Iterable'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Iterator.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Iterable"

invariant abc_extra261.Iterator.name:
  description: "collections.abc.Iterator.__name__ == 'Iterator'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Iterator.__name__.__eq__
  args: ["Iterator"]
  expected: true

invariant abc_extra261.Iterator.module:
  description: "collections.abc.Iterator.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Iterator.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra261.Callable.name:
  description: "collections.abc.Callable.__name__ == 'Callable'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Callable.__name__.__eq__
  args: ["Callable"]
  expected: true

invariant abc_extra261.Callable.module:
  description: "collections.abc.Callable.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Callable.__module__.__eq__
  args: ["collections.abc"]
  expected: true
