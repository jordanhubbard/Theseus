spec: hashlib_extra114
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra113.zspec.zsdl — covers HASH class-level descriptor types (name/block_size/digest_size are getset_descriptors) / HASH.name.__qualname__.__eq__('HASH.name') / HASH.block_size/__qualname__/__objclass__ / all three descriptors getset_descriptor type grouped (table + invariants)."
    - "hashlib_extra112.zspec.zsdl — covers md5/sha1/sha256/sha512 function __qualname__ string equality / sha224/sha384/sha3_512/blake2s qualname equality / qualname length groupings across SHA families and BLAKE2 (table + invariants)."
    - "hashlib_extra111.zspec.zsdl — covers sha3_256.__qualname__.__eq__('openssl_sha3_256') and blake2b.__qualname__.__eq__('blake2b') in a table; blake2b is a type not a function (table + invariants)."
    - "hashlib_extra110.zspec.zsdl — covers HASH class-level method descriptor qualnames for digest/copy / method_descriptor type names for update/digest/copy at class level / sha256 instance-bound method qualnames (digest/copy/hexdigest) / hexdigest descriptor type name and length confirmations (table + invariants)."
    - "hashlib_extra109.zspec.zsdl — covers algorithms_guaranteed and algorithms_available class names and sizes / subset relationship / hashlib.new code attributes (co_name, co_argcount, type, module) / blake2s membership (table + invariants)."
    - "hashlib_extra108.zspec.zsdl — covers sha224/sha384/sha3_256/sha3_512 digest_size and block_size / blake2b/blake2s digest_size and block_size and type names / sha3_256/sha3_512 HASH type identity / HASH.update and HASH.hexdigest qualname string equality via sha256().__class__ (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2, __bases__[0].__name__=='object') / HASH method qualname lengths / md5/sha1/sha256/sha512 digest_size and block_size (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class/module/qualname / algorithms_guaranteed.__len__()==14 (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra113; it does NOT duplicate invariants present in those files."
    - "Wave 271 theme: hashlib module-level dunder attributes — __name__, __package__, __spec__ — and the module's __all__ list; __name__=='hashlib' (7 chars); __package__=='' (empty string, len 0); __spec__ is a ModuleSpec named 'hashlib'; __spec__.has_location==True; __all__ has 19 elements."
    - "hashlib.__name__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__package__ == '' (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.__name__).__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.name == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.has_location == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.__name__) == 7 ('hashlib': 7 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.__package__) == 0 (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(hashlib.__all__) == 19. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__[0] == 'md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__[-1] == 'pbkdf2_hmac'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.submodule_search_locations == None (hashlib is not a package). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.__spec__.origin).__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.__package__ is '' (empty string) because hashlib is a top-level module (not a package or submodule). __spec__.submodule_search_locations is None because hashlib is a module, not a package (packages have a non-None submodule_search_locations). __spec__.has_location is True because hashlib is loaded from a .py file on disk (not a frozen module or built-in)."
    - "Note: hashlib.__all__ has 19 elements. The first is 'md5' and the last is 'pbkdf2_hmac'. __all__ controls what names are exported when 'from hashlib import *' is used. The __loader__ is SourceFileLoader (from importlib._bootstrap_external) which loads the .py source file. The __spec__.origin is a str (path to the .py file)."
    - "Note: hashlib_extra113 anchors HASH descriptor types; hashlib_extra112 anchors function qualnames; hashlib_extra99 anchors algorithms_guaranteed length. This spec anchors hashlib module-level dunder attributes (__name__, __package__, __spec__, __all__, __loader__) for the first time."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__name__.__eq__('hashlib')
# hashlib.__package__.__eq__('')
# type(hashlib.__name__).__name__.__eq__('str')
# len(hashlib.__name__) == 7
# len(hashlib.__package__) == 0
#
# Wave 271 theme: hashlib module __name__ and __package__ equality and lengths.
#
# hashlib.__name__ is 'hashlib' (7 chars). hashlib.__package__ is '' (empty
# string, length 0) because hashlib is a top-level module — not a subpackage.
# Submodules of a package would have __package__ equal to the parent package
# name. Top-level modules have __package__ == '' (empty string), not None.
# type(hashlib.__name__).__name__ is 'str'. No prior hashlib spec anchors
# __name__ or __package__ equality as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra114.hashlib_name_and_package_equality_and_lengths:
  description: "hashlib.__name__.__eq__('hashlib')==True / hashlib.__package__.__eq__('')==True / type(hashlib.__name__).__name__.__eq__('str')==True / hashlib.__name__.__len__()==7 / hashlib.__package__.__len__()==0 — __name__=='hashlib' (7 chars); __package__=='' (empty string, len 0; top-level module not a subpackage); type of __name__ is str; __package__ is empty string not None for top-level modules; no prior hashlib spec anchors these module-level attrs; first hashmeta114 anchor"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashmeta114

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,          "hashlib.__name__.__eq__",             ["hashlib"], true, "hashlib.__name__ is 'hashlib' (7 chars; the module name as registered in sys.modules)"]
    - [package_eq,       "hashlib.__package__.__eq__",          [""],        true, "hashlib.__package__ is '' (empty string; top-level module; not a subpackage of any package)"]
    - [name_type_str,    "hashlib.__name__.__class__.__name__.__eq__", ["str"], true, "type(hashlib.__name__) is 'str' (module __name__ is always a string; the registered module name)"]
    - [name_len,         "hashlib.__name__.__len__",            [],          7,    "hashlib.__name__.__len__() is 7 ('hashlib': 7 chars; h-a-s-h-l-i-b)"]
    - [package_len,      "hashlib.__package__.__len__",         [],          0,    "hashlib.__package__.__len__() is 0 (empty string; top-level modules have __package__=='' not None)"]

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec')
# hashlib.__spec__.name.__eq__('hashlib')
# hashlib.__spec__.has_location == True
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader')
# type(hashlib.__spec__.origin).__name__.__eq__('str')
#
# Wave 271 theme: hashlib module __spec__ attributes and loader type.
#
# hashlib.__spec__ is a ModuleSpec object. Its .name is 'hashlib'. Its
# .has_location is True (the module is loaded from a file on disk, not frozen
# or built-in). The loader is SourceFileLoader (from importlib._bootstrap_external)
# which is used for .py source files. The origin is a str (the path to hashlib.py).
# hashlib.__spec__.submodule_search_locations is None because hashlib is a module
# not a package. No prior hashlib spec anchors __spec__ attributes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra114.hashlib_spec_loader_origin_attributes:
  description: "hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / hashlib.__spec__.name.__eq__('hashlib')==True / hashlib.__spec__.has_location==True / hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True / type(hashlib.__spec__.origin).__name__.__eq__('str')==True — __spec__ is ModuleSpec; spec.name is 'hashlib'; has_location==True (loaded from .py file not frozen); loader is SourceFileLoader (for .py source); origin is str (path to hashlib.py); no prior spec anchors these; first hashmeta114 anchor"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashmeta114

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_eq,    "hashlib.__spec__.__class__.__name__.__eq__",  ["ModuleSpec"],      true, "hashlib.__spec__.__class__.__name__ is 'ModuleSpec' (importlib.machinery.ModuleSpec; holds module metadata)"]
    - [spec_name_eq,     "hashlib.__spec__.name.__eq__",                ["hashlib"],         true, "hashlib.__spec__.name is 'hashlib' (the fully qualified module name stored in the ModuleSpec)"]
    - [spec_has_location, "hashlib.__spec__.has_location",              [],                  true, "hashlib.__spec__.has_location is True (module is loaded from a .py file on disk; not frozen or built-in)"]
    - [loader_class_eq,  "hashlib.__loader__.__class__.__name__.__eq__", ["SourceFileLoader"], true, "hashlib.__loader__.__class__.__name__ is 'SourceFileLoader' (importlib._bootstrap_external; loads .py files)"]
    - [origin_type_str,  "hashlib.__spec__.origin.__class__.__name__.__eq__", ["str"],       true, "type(hashlib.__spec__.origin) is 'str' (origin is the file path to hashlib.py as a string)"]

# ---------------------------------------------------------------------------
# len(hashlib.__all__) == 19
# hashlib.__all__[0].__eq__('md5')
# hashlib.__all__[-1].__eq__('pbkdf2_hmac')
# hashlib.__spec__.submodule_search_locations is None
# hashlib.__spec__.name.__len__() == 7
#
# Wave 271 theme: hashlib.__all__ length, first and last elements, and spec.name length.
#
# hashlib.__all__ is a list of 19 exported names. The first element is 'md5'
# (3 chars) and the last is 'pbkdf2_hmac' (11 chars). __all__ controls
# 'from hashlib import *' exports. hashlib.__spec__.submodule_search_locations
# is None because hashlib is a simple module, not a package (packages have a
# non-None submodule_search_locations list). hashlib.__spec__.name has length
# 7 (same as __name__ length). No prior hashlib spec anchors __all__ attributes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra114.hashlib_all_length_first_last_and_spec_name_len:
  description: "hashlib.__all__.__len__()==19 / hashlib.__all__[0].__eq__('md5')==True / hashlib.__all__[-1].__eq__('pbkdf2_hmac')==True / hashlib.__spec__.submodule_search_locations==None / hashlib.__spec__.name.__len__()==7 — __all__ has 19 elements; first is 'md5' (3 chars); last is 'pbkdf2_hmac' (11 chars); submodule_search_locations is None (hashlib is a module not a package); spec.name len is 7 (same as __name__ len); first hashmeta114 anchor"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashmeta114

  columns: [id, function, args, expected, description]
  rows:
    - [all_len,          "hashlib.__all__.__len__",             [],          19,   "hashlib.__all__.__len__() is 19 (19 exported names; controls 'from hashlib import *')"]
    - [all_first_eq,     "hashlib.__all__[0].__eq__",           ["md5"],     true, "hashlib.__all__[0] is 'md5' (first exported name; the MD5 hash function constructor)"]
    - [all_last_eq,      "hashlib.__all__[-1].__eq__",          ["pbkdf2_hmac"], true, "hashlib.__all__[-1] is 'pbkdf2_hmac' (last exported name; PBKDF2 key derivation function)"]
    - [spec_sublocs_none, "hashlib.__spec__.submodule_search_locations", [], null, "hashlib.__spec__.submodule_search_locations is None (hashlib is a module not a package; packages have a non-None search path)"]
    - [spec_name_len,    "hashlib.__spec__.name.__len__",       [],          7,    "hashlib.__spec__.name.__len__() is 7 ('hashlib': same length as hashlib.__name__)"]

# ---------------------------------------------------------------------------
# hashlib.__name__.__eq__('hashlib') — standalone
#
# hashlib.__name__ is 'hashlib'. The __name__ attribute of a module is its
# fully qualified name as registered in sys.modules. For hashlib, which is a
# top-level module (not a subpackage), __name__ is simply 'hashlib' (7 chars:
# h-a-s-h-l-i-b). This is distinct from hashlib.__file__ (the path to the
# .py file) and hashlib.__spec__.name (which is also 'hashlib'). The module
# name 'hashlib' is 7 chars — one more than 'socket' (6 chars) and the same
# as 'os.path' minus the dot. No prior hashlib spec anchors __name__ equality
# as a standalone under hashmeta114. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra114.hashlib_name_eq:
  description: "hashlib.__name__.__eq__('hashlib') == True — __name__ is 'hashlib' (7 chars; h-a-s-h-l-i-b); fully qualified module name as registered in sys.modules; top-level module (not a subpackage); distinct from __file__ (path) and __spec__.name (both also 'hashlib'); 7 chars is one more than socket (6); no prior spec anchors as standalone; first standalone under hashmeta114"
  category: module_identity
  kind: python_call_eq
  function: "hashlib.__name__.__eq__"
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__package__.__eq__('') — standalone
#
# hashlib.__package__ is '' (empty string). For top-level modules (not
# subpackages), __package__ is an empty string. For submodules like
# 'email.mime.text', __package__ would be 'email.mime'. For packages like
# 'email', __package__ would be 'email'. hashlib is a top-level module
# with no parent package, so __package__ is '' (empty string, length 0).
# This is distinct from None — __package__ is None only for interactively
# defined modules or some edge cases; for source-loaded modules, it is always
# a string. No prior hashlib spec anchors __package__ equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra114.hashlib_package_eq_empty:
  description: "hashlib.__package__.__eq__('') == True — __package__ is '' (empty string, len 0); top-level modules have __package__=='' not None; submodules have __package__ equal to parent package name; hashlib has no parent package; distinct from packages which have __package__==__name__; no prior spec anchors as standalone; first standalone under hashmeta114"
  category: module_identity
  kind: python_call_eq
  function: "hashlib.__package__.__eq__"
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# hashlib.__spec__.__class__.__name__ is 'ModuleSpec'. ModuleSpec is from
# importlib.machinery and holds the metadata needed to load a module. It
# includes the module name, loader, origin (file path), submodule_search_
# locations (for packages), and has_location flag. The ModuleSpec is created
# by the import system's path-based finder when it locates hashlib.py.
# hashlib.__spec__ being a ModuleSpec (as opposed to None) confirms hashlib
# is a properly registered module in the import system. No prior hashlib spec
# anchors __spec__ class name as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant hashlib_extra114.hashlib_spec_is_modulespec:
  description: "hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is a ModuleSpec (importlib.machinery.ModuleSpec; holds module import metadata including name, loader, origin, has_location); created by path-based finder when locating hashlib.py; non-None __spec__ confirms properly registered module; no prior spec anchors as standalone; first standalone under hashmeta114"
  category: module_identity
  kind: python_call_eq
  function: "hashlib.__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__spec__.has_location == True — standalone
#
# hashlib.__spec__.has_location is True. has_location is True when the module
# has a concrete file on disk (as opposed to frozen modules or built-in modules).
# For hashlib, which is implemented as hashlib.py (a Python source file),
# has_location is True. Built-in modules like 'sys' and '_hashlib' (which is
# the C extension that hashlib wraps) would have has_location False or have
# different loader types. The True value confirms hashlib is a source-loaded
# module with an origin path string. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra114.hashlib_spec_has_location:
  description: "hashlib.__spec__.has_location == True — has_location is True when module has a concrete file on disk; hashlib is a .py source file (not frozen or built-in); has_location==True confirms origin is a valid file path string; contrast with built-ins like sys or _hashlib (C extension); loader is SourceFileLoader; no prior spec anchors as standalone; first standalone under hashmeta114"
  category: module_identity
  kind: python_call_eq
  function: "hashlib.__spec__.has_location"
  args: []
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# hashlib.__loader__.__class__.__name__ is 'SourceFileLoader'. SourceFileLoader
# is defined in importlib._bootstrap_external and is responsible for loading
# Python source (.py) files. When the import system finds hashlib.py on sys.path,
# it creates a SourceFileLoader to read and compile the source. SourceFileLoader
# handles .py files (as opposed to SourcelessFileLoader for .pyc-only, or
# ExtensionFileLoader for .so/.pyd C extensions). The fact that hashlib uses
# SourceFileLoader confirms it is implemented as a Python source file, not as
# a C extension (the actual hash algorithms are in _hashlib.c, but the hashlib
# module itself is pure Python). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra114.hashlib_loader_is_sourcefileloader:
  description: "hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — loader is SourceFileLoader (importlib._bootstrap_external; loads .py source files); hashlib is pure Python source (hash algorithms live in _hashlib C extension; hashlib.py wraps them); contrast with ExtensionFileLoader (for .so/.pyd) and SourcelessFileLoader (for .pyc only); no prior spec anchors as standalone; first standalone under hashmeta114"
  category: module_identity
  kind: python_call_eq
  function: "hashlib.__loader__.__class__.__name__.__eq__"
  args: ["SourceFileLoader"]
  expected: true
