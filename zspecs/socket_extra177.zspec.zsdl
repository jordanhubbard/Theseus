spec: socket_extra177
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec covers: socket.socket property and method __name__ attribute checks."
    - "socket.socket.family, .type, .proto, .timeout are properties; their .fget.__name__ equals the property name string."
    - "socket.socket.fileno, .getpeername, .getsockname, .makefile are regular methods; their .__name__ equals the method name string."
    - "len('family') == 6, len('type') == 4, len('proto') == 5, len('timeout') == 7."
    - "len('fileno') == 6 (same as 'family'); len('getpeername') == 11; len('getsockname') == 11 (same as 'getpeername'); len('makefile') == 8."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket property fget.__name__ checks
# family, type, proto, timeout are properties on the socket.socket class.
# ---------------------------------------------------------------------------

table socket_extra177.socket_properties.fget_names:
  description: "socket.socket properties have fget.__name__ equal to the property name string"
  kind: python_call_eq
  category: property_names
  id_prefix: socketprops177

  columns: [id, function, args, expected, description]
  rows:
    - [family_name,  "socket.family.fget.__name__.__eq__",  ["family"],  true, "socket.socket.family.fget.__name__ == 'family'"]
    - [type_name,    "socket.type.fget.__name__.__eq__",    ["type"],    true, "socket.socket.type.fget.__name__ == 'type'"]
    - [proto_name,   "socket.proto.fget.__name__.__eq__",   ["proto"],   true, "socket.socket.proto.fget.__name__ == 'proto'"]
    - [timeout_name, "socket.timeout.fget.__name__.__eq__", ["timeout"], true, "socket.socket.timeout.fget.__name__ == 'timeout'"]

# ---------------------------------------------------------------------------
# socket.socket property fget.__name__ string lengths
# ---------------------------------------------------------------------------

table socket_extra177.socket_properties.fget_name_lengths:
  description: "socket.socket property name string lengths"
  kind: python_call_eq
  category: property_names
  id_prefix: socketprops177

  columns: [id, function, args, expected, description]
  rows:
    - [family_len,  "socket.family.fget.__name__.__len__",  [], 6, "len('family') == 6"]
    - [type_len,    "socket.type.fget.__name__.__len__",    [], 4, "len('type') == 4"]
    - [proto_len,   "socket.proto.fget.__name__.__len__",   [], 5, "len('proto') == 5"]
    - [timeout_len, "socket.timeout.fget.__name__.__len__", [], 7, "len('timeout') == 7"]

# ---------------------------------------------------------------------------
# socket.socket method __name__ checks
# fileno, getpeername, getsockname, makefile are regular methods.
# ---------------------------------------------------------------------------

table socket_extra177.socket_methods.names:
  description: "socket.socket methods have __name__ equal to the method name string"
  kind: python_call_eq
  category: method_names
  id_prefix: socketprops177

  columns: [id, function, args, expected, description]
  rows:
    - [fileno_name,      socket.fileno.__name__.__eq__,      ["fileno"],      true, "socket.socket.fileno.__name__ == 'fileno'"]
    - [getpeername_name, socket.getpeername.__name__.__eq__,  ["getpeername"], true, "socket.socket.getpeername.__name__ == 'getpeername'"]
    - [getsockname_name, socket.getsockname.__name__.__eq__,  ["getsockname"], true, "socket.socket.getsockname.__name__ == 'getsockname'"]
    - [makefile_name,    socket.makefile.__name__.__eq__,     ["makefile"],    true, "socket.socket.makefile.__name__ == 'makefile'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket_extra177.family.fget_name:
  description: "socket.socket.family.fget.__name__ == 'family' (len=6)"
  category: property_names
  kind: python_call_eq
  function: "socket.family.fget.__name__.__eq__"
  args: ["family"]
  expected: true

invariant socket_extra177.type.fget_name:
  description: "socket.socket.type.fget.__name__ == 'type' (len=4)"
  category: property_names
  kind: python_call_eq
  function: "socket.type.fget.__name__.__eq__"
  args: ["type"]
  expected: true

invariant socket_extra177.fileno.name:
  description: "socket.socket.fileno.__name__ == 'fileno' (len=6; same length as 'family')"
  category: method_names
  kind: python_call_eq
  function: socket.fileno.__name__.__eq__
  args: ["fileno"]
  expected: true

invariant socket_extra177.getpeername.name:
  description: "socket.socket.getpeername.__name__ == 'getpeername' (len=11)"
  category: method_names
  kind: python_call_eq
  function: socket.getpeername.__name__.__eq__
  args: ["getpeername"]
  expected: true

invariant socket_extra177.getsockname.name:
  description: "socket.socket.getsockname.__name__ == 'getsockname' (len=11; same length as 'getpeername')"
  category: method_names
  kind: python_call_eq
  function: socket.getsockname.__name__.__eq__
  args: ["getsockname"]
  expected: true

invariant socket_extra177.makefile.name:
  description: "socket.socket.makefile.__name__ == 'makefile' (len=8)"
  category: method_names
  kind: python_call_eq
  function: socket.makefile.__name__.__eq__
  args: ["makefile"]
  expected: true

