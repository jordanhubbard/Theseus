spec: functools_extra43
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra42.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps(5)/partial(7)/lru_cache(9)/total_ordering(14)/singledispatch(14)/cached_property(15)/reduce(6)/cmp_to_key(10)/partialmethod(13)/singledispatchmethod(20)/update_wrapper(14); __qualname__.__len__() for update_wrapper(14)/partialmethod(13)/singledispatchmethod(20)/cache(5)/total_ordering(14)/singledispatch(14)/cmp_to_key(10)/cached_property(15)/lru_cache(9)/wraps(5)/reduce(6)/partial(7); WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths and indexed elements [0-9]/-1/-2; partial/__class__.__name__(4)/lru_cache/__class__.__name__(8)/reduce/__class__.__name__(26)/wraps/__class__.__name__(8); __cached__.__class__.__name__(3); cached_property.__set_name__.__qualname__(28); total_ordering.__dict__.__class__.__name__(4); partial/__new__.__qualname__(15); cached_property/__get__.__qualname__(23); class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property (all 12); partial/__doc__(83)/reduce/__doc__(389); reduce with initial value(16); lru_cache(128).__ne__(None)==True."
    - "This spec covers: reduce.__module__.__len__() (10 — '_functools', C-extension module); cmp_to_key.__module__.__len__() (10 — '_functools', C-extension module); lru_cache.__module__.__len__() (9 — 'functools', pure-Python function); wraps.__module__.__len__() (9 — 'functools'); update_wrapper.__module__.__len__() (9 — 'functools'); cached_property.__init__.__qualname__.__len__() (24 — 'cached_property.__init__'); lru_cache(maxsize=2) applied to identity lambda returns 42."
    - "Key findings: functools.reduce.__module__ and functools.cmp_to_key.__module__ are both '_functools' (10 chars) — the C-extension module name — because reduce and cmp_to_key are implemented in Modules/_functoolsmodule.c and exposed through the _functools extension. In contrast, functools.lru_cache.__module__, functools.wraps.__module__, and functools.update_wrapper.__module__ are all 'functools' (9 chars) — they are implemented as pure-Python functions in Lib/functools.py. This __module__ distinction reliably identifies which functools callables originated in C vs Python. functools.cached_property.__init__.__qualname__ is 'cached_property.__init__' (24 chars) — 'cached_property.' is 16 chars and '__init__' is 8 chars. lru_cache(maxsize=2)(lambda x: x)(42) == 42 confirms that lru_cache correctly wraps and delegates to the underlying function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# C-extension vs pure-Python __module__ lengths — extra43 namespace
#
# functools.reduce.__module__ is '_functools' (10 chars) and functools.cmp_to_key.
# __module__ is '_functools' (10 chars) — both are implemented in the C-extension
# _functoolsmodule.c and imported from the _functools extension. All other major
# functools callables (lru_cache, wraps, update_wrapper, singledispatch, etc.) have
# __module__ == 'functools' (9 chars) because they are pure-Python functions in
# Lib/functools.py. This gives a clean structural boundary: 10-char __module__ means
# C-extension origin; 9-char __module__ means pure Python. No prior functools spec
# records __module__.__len__() for any functools attribute in the extra43 namespace.
# ---------------------------------------------------------------------------

table functools_extra43.c_extension_module_name_lengths:
  description: "functools C-extension callables __module__.__len__(): reduce(10) and cmp_to_key(10) are '_functools'; lru_cache(9)/wraps(9)/update_wrapper(9) are 'functools'"
  kind: python_call_eq
  category: module_metadata
  id_prefix: modnamelen43

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_module,
       reduce.__module__.__len__,
       [],
       10,
       "len(functools.reduce.__module__) == 10 — '_functools' (C-extension; reduce is defined in Modules/_functoolsmodule.c)"]
    - [cmp_to_key_module,
       cmp_to_key.__module__.__len__,
       [],
       10,
       "len(functools.cmp_to_key.__module__) == 10 — '_functools' (C-extension; cmp_to_key is defined in Modules/_functoolsmodule.c alongside reduce)"]
    - [lru_cache_module,
       lru_cache.__module__.__len__,
       [],
       9,
       "len(functools.lru_cache.__module__) == 9 — 'functools' (pure-Python decorator function in Lib/functools.py)"]
    - [wraps_module,
       wraps.__module__.__len__,
       [],
       9,
       "len(functools.wraps.__module__) == 9 — 'functools' (pure-Python function; returns partial(update_wrapper, wrapped=wrapped, ...))"]
    - [update_wrapper_module,
       update_wrapper.__module__.__len__,
       [],
       9,
       "len(functools.update_wrapper.__module__) == 9 — 'functools' (pure-Python; the function that wraps copies across WRAPPER_ASSIGNMENTS)"]

# ---------------------------------------------------------------------------
# cached_property.__init__.__qualname__.__len__() — extra43 namespace
#
# functools.cached_property.__init__.__qualname__ is 'cached_property.__init__'
# (24 chars). The class prefix 'cached_property.' is 16 chars (15-char class name
# plus dot) and '__init__' is 8 chars, giving 24. Prior specs recorded qualnames for
# cached_property.__get__ (23) and cached_property.__set_name__ (28), but not for
# cached_property.__init__ (24), which sits between the two. No prior functools spec
# records cached_property.__init__.__qualname__.__len__() in the extra43 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra43.cached_property_init_qualname_len:
  description: "len(functools.cached_property.__init__.__qualname__) == 24 — 'cached_property.__init__' (16-char class prefix + 8-char dunder; between __get__(23) and __set_name__(28))"
  category: string_properties
  kind: python_call_eq
  function: cached_property.__init__.__qualname__.__len__
  args: []
  expected: 24

# ---------------------------------------------------------------------------
# lru_cache(maxsize=2) behavioral — extra43 namespace
#
# functools.lru_cache(maxsize=2)(lambda x: x)(42) == 42. lru_cache(maxsize=2)
# produces a decorator that memoizes up to 2 distinct argument values. Applying
# that decorator to the identity function (lambda x: x) and calling with 42
# returns 42, confirming that lru_cache correctly delegates to the wrapped
# function. This is a straightforward behavioral invariant: the cache does not
# alter return values, only avoids recomputation on repeated calls. No prior
# functools spec records this specific (maxsize=2, arg=42) behavioral case in
# the extra43 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra43.lru_cache_maxsize2_identity:
  description: "functools.lru_cache(maxsize=2)(lambda x: x)(42) == 42 — memoizing wrapper delegates to identity function; cache does not alter return value"
  category: behavioral
  kind: python_call_eq
  function: lru_cache
  args: [2]
  method: __call__
  method_args: [{type: lambda, body: "lambda x: x"}]
  expected: 42
