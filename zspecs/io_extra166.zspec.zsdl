spec: io_extra166
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/stringio.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.StringIO method __qualname__ values for read, readline, write, getvalue, seek, tell."
    - "All StringIO method qualnames use the public class name 'StringIO' (8 characters) as the prefix, plus a dot separator."
    - "The 'StringIO.' prefix is 9 characters (8 chars for 'StringIO' + 1 for '.')."
    - "io.StringIO.read.__qualname__ == 'StringIO.read' (len=13; 'StringIO.' (9) + 'read' (4) = 13; tied with seek and tell at 13)."
    - "io.StringIO.readline.__qualname__ == 'StringIO.readline' (len=17; 'StringIO.' (9) + 'readline' (8) = 17; tied with getvalue at 17)."
    - "io.StringIO.write.__qualname__ == 'StringIO.write' (len=14; 'StringIO.' (9) + 'write' (5) = 14; the sole occupant of length 14)."
    - "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' (len=17; 'StringIO.' (9) + 'getvalue' (8) = 17; tied with readline at 17)."
    - "io.StringIO.seek.__qualname__ == 'StringIO.seek' (len=13; 'StringIO.' (9) + 'seek' (4) = 13; tied with read and tell at 13)."
    - "io.StringIO.tell.__qualname__ == 'StringIO.tell' (len=13; 'StringIO.' (9) + 'tell' (4) = 13; tied with read and seek at 13)."
    - "Three-way tie at 13: read, seek, tell — all 4-character method names."
    - "Two-way tie at 17: readline and getvalue — both 8-character method names."
    - "write stands alone at 14 — the only 5-character method name in this spec."
    - "Length ranking: read=seek=tell=13, write=14, readline=getvalue=17."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.StringIO method __qualname__ values (group 1)
# read, seek, tell — all tied at length 13 (4-character method names).
# write — sole occupant of length 14 (5-character method name).
# All use 'StringIO.' prefix (9 characters).
# ---------------------------------------------------------------------------

table io_extra166.StringIO_method_qualnames_group1:
  description: "io.StringIO method __qualname__ values: read=seek=tell='StringIO.*' (len=13), write='StringIO.write' (len=14); three-way tie at 13 for 4-char method names; write is the sole occupant at 14"
  kind: python_call_eq
  category: qualname
  id_prefix: sioq166

  columns: [id, function, args, expected, description]
  rows:
    - [sio_read_qeq,  StringIO.read.__qualname__.__eq__,  ["StringIO.read"],  true, "io.StringIO.read.__qualname__ == 'StringIO.read' (StringIO.read() reads and returns at most size characters from the in-memory text buffer; with no argument or size=-1 reads all remaining content; returns a str; 'StringIO.read' has 13 characters: 'StringIO.' (9) + 'read' (4) = 13; part of the three-way tie at 13 with seek and tell — all three have 4-character method names; StringIO.read() is the primary way to extract text from a StringIO buffer after writing to it)"]
    - [sio_seek_qeq,  StringIO.seek.__qualname__.__eq__,  ["StringIO.seek"],  true, "io.StringIO.seek.__qualname__ == 'StringIO.seek' (StringIO.seek() sets the stream position within the in-memory buffer; seek(0) rewinds to the beginning for rereading; accepts whence=0 (absolute), 1 (relative), 2 (from end); 'StringIO.seek' has 13 characters: 'StringIO.' (9) + 'seek' (4) = 13; tied with read and tell at length 13; all three share the same 4-character method name length; StringIO.seek() is commonly paired with StringIO.tell() to save and restore position)"]
    - [sio_tell_qeq,  StringIO.tell.__qualname__.__eq__,  ["StringIO.tell"],  true, "io.StringIO.tell.__qualname__ == 'StringIO.tell' (StringIO.tell() returns the current stream position as an integer byte offset from the beginning of the buffer; for StringIO this counts characters since the stream holds text; 'StringIO.tell' has 13 characters: 'StringIO.' (9) + 'tell' (4) = 13; tied with read and seek at length 13; the three-way tie at 13 reflects that 'read', 'seek', and 'tell' all have exactly 4 characters — the minimum useful method name length for StringIO I/O operations)"]
    - [sio_write_qeq, StringIO.write.__qualname__.__eq__,  ["StringIO.write"], true, "io.StringIO.write.__qualname__ == 'StringIO.write' (StringIO.write() writes the given string to the in-memory buffer and returns the number of characters written; unlike file-based TextIOWrapper.write(), StringIO.write() never blocks and never raises IOError related to disk; 'StringIO.write' has 14 characters: 'StringIO.' (9) + 'write' (5) = 14; write is the sole occupant of length 14 in this spec — the only 5-character method name; one character longer than read/seek/tell (13) and three shorter than readline/getvalue (17))"]

# ---------------------------------------------------------------------------
# io.StringIO method __qualname__ values (group 2)
# readline, getvalue — both tied at length 17 (8-character method names).
# The two longest StringIO method qualnames in this spec.
# ---------------------------------------------------------------------------

table io_extra166.StringIO_method_qualnames_group2:
  description: "io.StringIO method __qualname__ values: readline='StringIO.readline' (len=17), getvalue='StringIO.getvalue' (len=17); two-way tie at 17 — both 8-character method names; the longest StringIO method qualnames in this spec"
  kind: python_call_eq
  category: qualname
  id_prefix: sioq166

  columns: [id, function, args, expected, description]
  rows:
    - [sio_readline_qeq,  StringIO.readline.__qualname__.__eq__,  ["StringIO.readline"],  true, "io.StringIO.readline.__qualname__ == 'StringIO.readline' (StringIO.readline() reads one line from the in-memory buffer, up to and including the newline character; if size is specified, reads at most size characters; returns a str; 'StringIO.readline' has 17 characters: 'StringIO.' (9) + 'readline' (8) = 17; tied with 'StringIO.getvalue' (also 17) — both readline and getvalue have 8-character method names; readline() is useful for processing StringIO content line by line as if reading a file)"]
    - [sio_getvalue_qeq,  StringIO.getvalue.__qualname__.__eq__,  ["StringIO.getvalue"],  true, "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' (StringIO.getvalue() returns the entire contents of the in-memory buffer as a string, regardless of the current stream position; unlike read(), getvalue() does not advance the position and always returns all content; 'StringIO.getvalue' has 17 characters: 'StringIO.' (9) + 'getvalue' (8) = 17; tied with 'StringIO.readline' (also 17) — both have 8-character names; getvalue() is the most convenient way to retrieve the full buffer content from a StringIO used as a string builder)"]
    - [sio_readline_qlen, StringIO.readline.__qualname__.__len__, [],                      17,   "io.StringIO.readline.__qualname__.__len__() == 17 ('StringIO.readline' has 17 characters: 'StringIO.' (9) + 'readline' (8) = 17; tied with 'StringIO.getvalue' (also 17); both readline and getvalue have 8-character method names, producing the same qualname length; 17 is the maximum qualname length in this spec; the complete length ranking: read=seek=tell=13, write=14, readline=getvalue=17)"]
    - [sio_getvalue_qlen, StringIO.getvalue.__qualname__.__len__, [],                      17,   "io.StringIO.getvalue.__qualname__.__len__() == 17 ('StringIO.getvalue' has 17 characters: 'StringIO.' (9) + 'getvalue' (8) = 17; tied with 'StringIO.readline' (also 17); 17 is the longest StringIO method qualname in this spec; compare with TextIOWrapper.readline (22) from io_extra164 — TextIOWrapper.readline is 5 characters longer than StringIO.readline because 'TextIOWrapper.' (14 chars) > 'StringIO.' (9 chars) by 5 characters; the shorter 'StringIO.' prefix makes all StringIO qualnames shorter than their TextIOWrapper counterparts)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra166.StringIO_read_seek_tell_three_way_tie_at_13:
  description: "io.StringIO.read.__qualname__.__len__() == 13 — 'StringIO.read' has 13 characters: 'StringIO.' (9) + 'read' (4) = 13; read is part of a three-way tie at 13 with seek (also 13: 'StringIO.' (9) + 'seek' (4) = 13) and tell (also 13: 'StringIO.' (9) + 'tell' (4) = 13); the three-way tie at 13 is because read, seek, and tell are all exactly 4-character method names; the complete length ranking: read=seek=tell=13, write=14, readline=getvalue=17; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: StringIO.read.__qualname__.__len__
  args: []
  expected: 13

invariant io_extra166.StringIO_write_is_sole_at_14:
  description: "io.StringIO.write.__qualname__.__len__() == 14 — 'StringIO.write' has 14 characters: 'StringIO.' (9) + 'write' (5) = 14; write is the sole occupant of length 14 in this spec — the only 5-character method name among the six covered; it falls between the three-way tie at 13 (read, seek, tell) and the two-way tie at 17 (readline, getvalue); StringIO.write() is the method that populates the in-memory text buffer; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: StringIO.write.__qualname__.__len__
  args: []
  expected: 14

invariant io_extra166.StringIO_readline_getvalue_tied_at_17:
  description: "io.StringIO.readline.__qualname__.__len__() == 17 — 'StringIO.readline' has 17 characters: 'StringIO.' (9) + 'readline' (8) = 17; tied with 'StringIO.getvalue' (also 17: 'StringIO.' (9) + 'getvalue' (8) = 17); readline and getvalue are tied because both have 8-character method names; 17 is the maximum qualname length in this spec; the complete ascending order: read=seek=tell=13, write=14, readline=getvalue=17; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: StringIO.readline.__qualname__.__len__
  args: []
  expected: 17

invariant io_extra166.StringIO_getvalue_qualname_eq:
  description: "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' — getvalue() is the distinctive StringIO-only method that has no direct counterpart on TextIOWrapper or BufferedReader; it returns the entire buffer contents regardless of position; its qualname uses the public class name 'StringIO' (8 chars) + '.' (1) + 'getvalue' (8) = 17 characters total; 'StringIO.getvalue' (17) matches 'StringIO.readline' (17) — both are the longest StringIO method qualnames in this spec; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: StringIO.getvalue.__qualname__.__eq__
  args: ["StringIO.getvalue"]
  expected: true
