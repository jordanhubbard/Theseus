spec: hypothesis_rust
version: ">=3.9"
backend: rust_module(hypothesis_rust)

docs: https://hypothesis.readthedocs.io/

provenance:
  derived_from:
    - "https://hypothesis.readthedocs.io/ — Hypothesis testing library"
  notes:
    - "Hypothesis provides property-based testing."
    - "hypothesis.given is a decorator."
    - "hypothesis.strategies.integers() returns a strategy."
    - "hypothesis.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant hypothesis_rust.has_given:
  description: "hypothesis.given is callable"
  category: presence
  kind: python_call_eq
  function: hypothesis_has_given
  args: []
  expected: true

invariant hypothesis_rust.has_strategies:
  description: "hypothesis.strategies.integers is callable"
  category: presence
  kind: python_call_eq
  function: hypothesis_has_strategies
  args: []
  expected: true

invariant hypothesis_rust.version_nonempty:
  description: "hypothesis.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: hypothesis_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T03:57:29Z
  iterations: 2
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 2 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
