spec: typing_extra12
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "PEP 544 — Protocols: Structural subtyping (Protocol)"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra11.zspec.zsdl."
    - "typing_extra11 covers NamedTuple/__module__, TypedDict/__module__, AnyStr/__name__/__module__/__class__.__name__, SupportsInt/__name__/__module__/__qualname__, TypeVar('T').__name__ == 'T', no_type_check_decorator/__qualname__/__module__."
    - "typing_extra10 covers assert_never/__qualname__/__module__, assert_type/__qualname__/__module__, no_type_check/__qualname__/__module__, final/__qualname__/__module__, ParamSpec bases, TypeVarTuple bases, Never/Self/LiteralString __class__.__name__."
    - "NOT yet covered: typing.TypeVar.__name__ == 'TypeVar' as a standalone invariant (the class name, distinct from instance __name__)."
    - "NOT yet covered: typing.TypeVar('T').bound == None — unbound TypeVar has None bound."
    - "NOT yet covered: typing.TypeVar('T').__class__.__name__ == 'TypeVar' — instance class identity."
    - "NOT yet covered: typing.Union.__doc__.__class__.__name__ == 'str' — Union docstring is a string."
    - "NOT yet covered: typing.cast.__name__ == 'cast' as a standalone invariant."
    - "NOT yet covered: typing.cast.__module__ == 'typing' as a standalone invariant."
    - "NOT yet covered: typing.overload.__name__ == 'overload' as a standalone invariant."
    - "NOT yet covered: typing.ClassVar._name == 'ClassVar' — _name attribute of the _SpecialForm."
    - "NOT yet covered: typing.get_type_hints.__name__ == 'get_type_hints' as a standalone invariant."
    - "NOT yet covered: typing.no_type_check.__name__ == 'no_type_check' as a standalone invariant."
    - "typing.TypeVar.__name__ == 'TypeVar' — the class itself, not an instance."
    - "typing.TypeVar('T').bound is None — unbound TypeVar has None as its bound."
    - "typing.TypeVar('T').__class__.__name__ == 'TypeVar' — instance's class name."
    - "typing.Union.__doc__.__class__.__name__ == 'str' — the __doc__ attribute is a str."
    - "typing.cast.__name__ == 'cast'."
    - "typing.cast.__module__ == 'typing'."
    - "typing.overload.__name__ == 'overload'."
    - "typing.ClassVar._name == 'ClassVar'."
    - "typing.get_type_hints.__name__ == 'get_type_hints'."
    - "typing.no_type_check.__name__ == 'no_type_check'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TypeVar class — __name__ (the class, not an instance)
#
# typing_extra11.TypeVar.instance_name covers TypeVar('T').__name__ == 'T'.
# No prior spec records the class's own __name__ attribute as a standalone
# invariant: typing.TypeVar.__name__ == 'TypeVar'.
# ---------------------------------------------------------------------------

invariant typing_extra12.TypeVar.class_name_attr:
  description: "typing.TypeVar.__name__ == 'TypeVar' — class __name__ of the TypeVar class itself"
  category: TypeVar
  kind: python_call_eq
  function: TypeVar.__name__.__eq__
  args: ["TypeVar"]
  expected: true

# ---------------------------------------------------------------------------
# TypeVar('T').bound — unbound TypeVar has None bound
#
# The .bound attribute of a TypeVar is set at construction time. When no
# bound= keyword is given the bound is None. No prior spec checks this.
# ---------------------------------------------------------------------------

invariant typing_extra12.TypeVar.bound_none:
  description: "typing.TypeVar('T').bound is None — unbound TypeVar has no constraint"
  category: TypeVar
  kind: python_call_eq
  function: TypeVar
  args: ["T"]
  method: bound.__eq__
  method_args: [null]
  expected: true

# ---------------------------------------------------------------------------
# TypeVar('T').__class__.__name__ — instance class identity
#
# typing_extra11 verified AnyStr.__class__.__name__ == 'TypeVar' for the
# module-level AnyStr constant. This adds the same check for a freshly
# constructed TypeVar('T') instance, confirming the pattern holds generally.
# ---------------------------------------------------------------------------

invariant typing_extra12.TypeVar.instance_class_name:
  description: "typing.TypeVar('T').__class__.__name__ == 'TypeVar'"
  category: TypeVar
  kind: python_call_eq
  function: TypeVar
  args: ["T"]
  method: __class__.__name__.__eq__
  method_args: ["TypeVar"]
  expected: true

# ---------------------------------------------------------------------------
# typing.Union.__doc__ — docstring is a str
#
# Union is a _SpecialForm whose __doc__ is a plain Python str. No prior spec
# verifies the __class__.__name__ of the Union docstring.
# ---------------------------------------------------------------------------

invariant typing_extra12.Union.doc_class_name:
  description: "typing.Union.__doc__.__class__.__name__ == 'str' — Union docstring is a str"
  category: special_forms
  kind: python_call_eq
  function: Union.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# cast — __name__ and __module__ as standalone invariants
#
# typing_extra8 verified cast.__module__ in a table alongside other functions.
# No prior spec records cast.__name__ or cast.__module__ as a standalone
# invariant. These add both axes explicitly.
# ---------------------------------------------------------------------------

invariant typing_extra12.cast.name:
  description: "typing.cast.__name__ == 'cast'"
  category: function_names
  kind: python_call_eq
  function: cast.__name__.__eq__
  args: ["cast"]
  expected: true

invariant typing_extra12.cast.module:
  description: "typing.cast.__module__ == 'typing'"
  category: function_modules
  kind: python_call_eq
  function: cast.__module__.__eq__
  args: ["typing"]
  expected: true

# ---------------------------------------------------------------------------
# overload — __name__ as a standalone invariant
#
# typing_extra8 and typing_extra9 do not record overload.__name__ as a
# standalone invariant. overload is a plain module-level function.
# ---------------------------------------------------------------------------

invariant typing_extra12.overload.name:
  description: "typing.overload.__name__ == 'overload'"
  category: function_names
  kind: python_call_eq
  function: overload.__name__.__eq__
  args: ["overload"]
  expected: true

# ---------------------------------------------------------------------------
# ClassVar._name — the _SpecialForm's internal name attribute
#
# ClassVar is a _SpecialForm. _SpecialForm instances carry a _name attribute
# that records the public name. No prior spec checks ClassVar._name.
# ---------------------------------------------------------------------------

invariant typing_extra12.ClassVar._name:
  description: "typing.ClassVar._name == 'ClassVar'"
  category: special_forms
  kind: python_call_eq
  function: ClassVar._name.__eq__
  args: ["ClassVar"]
  expected: true

# ---------------------------------------------------------------------------
# get_type_hints — __name__ as a standalone invariant
#
# typing_extra8 verifies get_type_hints.__module__ in a table row. No prior
# spec captures get_type_hints.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant typing_extra12.get_type_hints.name:
  description: "typing.get_type_hints.__name__ == 'get_type_hints'"
  category: function_names
  kind: python_call_eq
  function: get_type_hints.__name__.__eq__
  args: ["get_type_hints"]
  expected: true

# ---------------------------------------------------------------------------
# no_type_check — __name__ as a standalone invariant
#
# typing_extra10 verifies no_type_check.__qualname__ and __module__.
# No prior spec captures no_type_check.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant typing_extra12.no_type_check.name:
  description: "typing.no_type_check.__name__ == 'no_type_check'"
  category: function_names
  kind: python_call_eq
  function: no_type_check.__name__.__eq__
  args: ["no_type_check"]
  expected: true

# ---------------------------------------------------------------------------
# Table: function __name__ for core typing helpers
#
# Bundles __name__ checks for several typing helpers that have not appeared
# as standalone invariants in prior specs, covering get_args, get_origin,
# and is_typeddict for completeness.
# ---------------------------------------------------------------------------

table typing_extra12.helper_names:
  description: "Core typing helper functions have __name__ equal to their plain name"
  kind: python_call_eq
  category: function_names
  id_prefix: hname

  columns: [id, function, args, expected]
  rows:
    - [get_args,      get_args.__name__.__eq__,      ["get_args"],      true]
    - [get_origin,    get_origin.__name__.__eq__,    ["get_origin"],    true]
    - [is_typeddict,  is_typeddict.__name__.__eq__,  ["is_typeddict"],  true]
