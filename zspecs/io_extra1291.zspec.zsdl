spec: io_extra1291
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 533 _extra1291: checks __init__.__qualname__, __init__.__class__.__name__, and __dict__.__contains__('__init__') for io.BytesIO, io.StringIO, io.FileIO, io.TextIOWrapper, io.IOBase, io.UnsupportedOperation."
    - "Also checks __new__.__qualname__ and __new__.__class__.__name__ for io.BytesIO, io.StringIO, io.FileIO."
    - "io.IOBase does not define __init__ in its own __dict__; MRO resolves to object.__init__ (qualname 'object.__init__')."
    - "io.UnsupportedOperation does not define __init__ in its own __dict__; MRO resolves to OSError.__init__."
    - "io.BytesIO, io.StringIO, io.FileIO, io.TextIOWrapper all define __init__ directly; __class__.__name__ == 'wrapper_descriptor' (C extension slot)."
    - "io.BytesIO, io.StringIO, io.FileIO define __new__ directly; __class__.__name__ == 'builtin_function_or_method'."
    - "io.TextIOWrapper does NOT define __new__ in its own __dict__."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1291.init_qualnames:
  description: "__init__.__qualname__ checks for io classes that define __init__ directly"
  kind: python_call_eq
  category: init_qualnames
  id_prefix: io1291iq
  columns: [id, function, args, expected]
  rows:
    - [io1291iq001, io.BytesIO.__init__.__qualname__.__eq__,      ["BytesIO.__init__"],      true]
    - [io1291iq002, io.StringIO.__init__.__qualname__.__eq__,     ["StringIO.__init__"],     true]
    - [io1291iq003, io.FileIO.__init__.__qualname__.__eq__,       ["FileIO.__init__"],       true]
    - [io1291iq004, io.TextIOWrapper.__init__.__qualname__.__eq__, ["TextIOWrapper.__init__"], true]
    - [io1291iq005, io.IOBase.__init__.__qualname__.__eq__,       ["object.__init__"],       true]
    - [io1291iq006, io.UnsupportedOperation.__init__.__qualname__.__eq__, ["OSError.__init__"], true]

table io_extra1291.init_class_names:
  description: "__init__.__class__.__name__ checks — wrapper_descriptor for C-extension slots, function for pure-Python"
  kind: python_call_eq
  category: init_class_names
  id_prefix: io1291ic
  columns: [id, function, args, expected]
  rows:
    - [io1291ic001, io.BytesIO.__init__.__class__.__name__.__eq__,      ["wrapper_descriptor"], true]
    - [io1291ic002, io.StringIO.__init__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true]
    - [io1291ic003, io.FileIO.__init__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]
    - [io1291ic004, io.TextIOWrapper.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [io1291ic005, io.IOBase.__init__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]
    - [io1291ic006, io.UnsupportedOperation.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

table io_extra1291.dict_contains_init:
  description: "__dict__.__contains__('__init__') — True only for classes that explicitly define __init__"
  kind: python_call_eq
  category: dict_contains_init
  id_prefix: io1291dc
  columns: [id, function, args, expected]
  rows:
    - [io1291dc001, io.BytesIO.__dict__.__contains__,           ["__init__"], true]
    - [io1291dc002, io.StringIO.__dict__.__contains__,          ["__init__"], true]
    - [io1291dc003, io.FileIO.__dict__.__contains__,            ["__init__"], true]
    - [io1291dc004, io.TextIOWrapper.__dict__.__contains__,     ["__init__"], true]
    - [io1291dc005, io.IOBase.__dict__.__contains__,            ["__init__"], false]
    - [io1291dc006, io.UnsupportedOperation.__dict__.__contains__, ["__init__"], false]
    - [io1291dc007, io.BytesIO.__dict__.__contains__,           ["__new__"],  true]
    - [io1291dc008, io.StringIO.__dict__.__contains__,          ["__new__"],  true]
    - [io1291dc009, io.FileIO.__dict__.__contains__,            ["__new__"],  true]
    - [io1291dc010, io.TextIOWrapper.__dict__.__contains__,     ["__new__"],  false]
