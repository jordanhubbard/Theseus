spec: concurrent_futures_extra273
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.Future.__module__ == 'concurrent.futures._base' — defined in the private _base submodule."
    - "concurrent.futures.Future.__bases__[0].__name__ == 'object' — direct subclass of object; __mro__.__len__() == 2."
    - "Future.result.__qualname__ == 'Future.result' (len=13); Future.exception.__qualname__ == 'Future.exception' (len=16)."
    - "Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24) — the longest Future method qualname among the four covered here."
    - "Future.set_exception.__qualname__ == 'Future.set_exception' (len=20)."
    - "Future.cancel.__qualname__ == 'Future.cancel' (len=13); tied with Future.result for shortest."
    - "Future.done.__qualname__ == 'Future.done' (len=11) — shortest of all Future method qualnames."
    - "Future.running.__qualname__ == 'Future.running' (len=14)."
    - "All method __name__ values match the method's simple name (no qualification)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future class identity and primary method names — table
#
# Future lives in concurrent.futures._base and is a direct subclass of object.
# result, exception, add_done_callback, and set_exception are the four core
# consumer/producer methods documented in the public API.
# ---------------------------------------------------------------------------

table concurrent_futures_extra273.future_identity:
  description: "concurrent.futures.Future class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: futid

  columns: [id, function, args, expected, description]
  rows:
    - [fut_name,      Future.__name__.__eq__,                    ["Future"],                       true, "concurrent.futures.Future.__name__ == 'Future'"]
    - [fut_module,    Future.__module__.__eq__,                  ["concurrent.futures._base"],     true, "concurrent.futures.Future.__module__ == 'concurrent.futures._base'"]
    - [fut_result,    Future.result.__name__.__eq__,             ["result"],                       true, "concurrent.futures.Future.result.__name__ == 'result'"]
    - [fut_result_qn, Future.result.__qualname__.__eq__,         ["Future.result"],                true, "concurrent.futures.Future.result.__qualname__ == 'Future.result'"]
    - [fut_exc,       Future.exception.__name__.__eq__,          ["exception"],                    true, "concurrent.futures.Future.exception.__name__ == 'exception'"]
    - [fut_exc_qn,    Future.exception.__qualname__.__eq__,      ["Future.exception"],             true, "concurrent.futures.Future.exception.__qualname__ == 'Future.exception'"]
    - [fut_adc,       Future.add_done_callback.__name__.__eq__,  ["add_done_callback"],            true, "concurrent.futures.Future.add_done_callback.__name__ == 'add_done_callback'"]
    - [fut_adc_qn,    Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"],  true, "concurrent.futures.Future.add_done_callback.__qualname__ == 'Future.add_done_callback'"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future secondary method qualnames — table
#
# set_exception, cancel, done, running are the secondary methods.
# done.__qualname__ (len=11) is the shortest; add_done_callback (len=24) longest.
# ---------------------------------------------------------------------------

table concurrent_futures_extra273.future_secondary_qualnames:
  description: "concurrent.futures.Future secondary method __qualname__ values and lengths"
  kind: python_call_eq
  category: identity
  id_prefix: futsec

  columns: [id, function, args, expected, description]
  rows:
    - [set_exc_name,    Future.set_exception.__name__.__eq__,         ["set_exception"],            true,  "Future.set_exception.__name__ == 'set_exception'"]
    - [set_exc_qn,      Future.set_exception.__qualname__.__eq__,     ["Future.set_exception"],     true,  "Future.set_exception.__qualname__ == 'Future.set_exception'"]
    - [set_exc_qlen,    Future.set_exception.__qualname__.__len__,     [],                           20,    "Future.set_exception.__qualname__.__len__() == 20"]
    - [cancel_qn,       Future.cancel.__qualname__.__eq__,            ["Future.cancel"],            true,  "Future.cancel.__qualname__ == 'Future.cancel'"]
    - [cancel_qlen,     Future.cancel.__qualname__.__len__,           [],                           13,    "Future.cancel.__qualname__.__len__() == 13 (tied with result)"]
    - [done_qn,         Future.done.__qualname__.__eq__,              ["Future.done"],              true,  "Future.done.__qualname__ == 'Future.done'"]
    - [done_qlen,       Future.done.__qualname__.__len__,             [],                           11,    "Future.done.__qualname__.__len__() == 11 (shortest Future method qualname)"]
    - [running_qn,      Future.running.__qualname__.__eq__,           ["Future.running"],           true,  "Future.running.__qualname__ == 'Future.running'"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future base class — standalone invariant
#
# Future inherits directly from object; __mro__ has 2 entries.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra273.Future.bases0_name:
  description: "concurrent.futures.Future.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures.Future MRO depth — standalone invariant
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra273.Future.mro_len:
  description: "concurrent.futures.Future.__mro__.__len__() == 2"
  category: identity
  kind: python_call_eq
  function: Future.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# add_done_callback qualname length — standalone invariant
#
# 'Future.add_done_callback' has 24 characters — the longest among all
# Future method qualnames covered in this spec.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra273.Future.add_done_callback_qlen:
  description: "Future.add_done_callback.__qualname__.__len__() == 24 (longest Future method qualname)"
  category: identity
  kind: python_call_eq
  function: Future.add_done_callback.__qualname__.__len__
  args: []
  expected: 24

# ---------------------------------------------------------------------------
# exception qualname length — standalone invariant
#
# 'Future.exception' has 16 characters.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra273.Future.exception_qlen:
  description: "Future.exception.__qualname__.__len__() == 16"
  category: identity
  kind: python_call_eq
  function: Future.exception.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# result qualname length — standalone invariant
#
# 'Future.result' has 13 characters — tied with cancel for shortest
# among the eight methods covered.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra273.Future.result_qlen:
  description: "Future.result.__qualname__.__len__() == 13 (tied with cancel for shortest)"
  category: identity
  kind: python_call_eq
  function: Future.result.__qualname__.__len__
  args: []
  expected: 13
