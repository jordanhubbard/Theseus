spec: theseus_copyreg_cr
version: ">=3.8"
backend: python_cleanroom(theseus_copyreg_cr)
blocks: copyreg

docs: https://docs.python.org/3/library/copyreg.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/copyreg.html"
  not_derived_from:
    - "CPython source: Lib/copyreg.py (internal implementation)"
  notes:
    - "Clean-room copyreg module. Do NOT import copyreg."
    - "dispatch_table: maps types to reduce functions."
    - "pickle(ob_type, reduce_func, constructor=None): register reducer."
    - "constructor(object): register constructor for copy_reg."

error_model: python_exceptions

invariant theseus_copyreg_cr.copyreg2_dispatch_table:
  description: "dispatch_table is a dict of type->reducer mappings"
  category: dispatch_table
  kind: python_call_eq
  function: copyreg2_dispatch_table
  args: []
  expected: true

invariant theseus_copyreg_cr.copyreg2_pickle:
  description: "pickle() registers a custom reducer for a type"
  category: pickle
  kind: python_call_eq
  function: copyreg2_pickle
  args: []
  expected: true

invariant theseus_copyreg_cr.copyreg2_constructor:
  description: "constructor() registers a callable as valid constructor"
  category: constructor
  kind: python_call_eq
  function: copyreg2_constructor
  args: []
  expected: true
