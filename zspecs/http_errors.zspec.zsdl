spec: http_errors
version: ">=2.0.0"
backend: node(http-errors)

docs: https://github.com/jshttp/http-errors#readme

provenance:
  derived_from:
    - "http-errors README — https://github.com/jshttp/http-errors#readme"
    - "RFC 9110 (HTTP/1.1 semantics) status-code registry"
    - "Test vectors verified with http-errors via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "http-errors source"
  notes:
    - "Factory for HTTP error objects — used by Express, Connect, Koa for 4xx/5xx responses."
    - "Install: npm install http-errors"
    - "v2 CJS; default export is the createError factory; named exports for each status (NotFound, BadRequest, ...) and isHttpError."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Factory throws on non-numeric status; produced errors expose status / statusCode / expose / message."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# 404 → Not Found
invariant http_errors.factory_404_status:
  description: "createError(404).status is 404"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [404]
  chain:
    - {get: status}
  expected: 404

invariant http_errors.factory_404_message:
  description: "createError(404).message is 'Not Found' (canonical)"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [404]
  chain:
    - {get: message}
  expected: "Not Found"

invariant http_errors.factory_404_name:
  description: "createError(404).name is 'NotFoundError'"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [404]
  chain:
    - {get: name}
  expected: "NotFoundError"

invariant http_errors.factory_404_expose_true:
  description: "4xx errors set expose=true (safe to send to client)"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [404]
  chain:
    - {get: expose}
  expected: true

invariant http_errors.factory_500_expose_false:
  description: "5xx errors set expose=false (do not leak internals)"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [500]
  chain:
    - {get: expose}
  expected: false

invariant http_errors.factory_500_message:
  description: "createError(500).message is 'Internal Server Error'"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [500]
  chain:
    - {get: message}
  expected: "Internal Server Error"

invariant http_errors.factory_403_message:
  description: "createError(403).message is 'Forbidden'"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [403]
  chain:
    - {get: message}
  expected: "Forbidden"

invariant http_errors.factory_custom_message:
  description: "createError(400, 'Custom message') overrides the canonical text"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [400, "Custom message"]
  chain:
    - {get: message}
  expected: "Custom message"

invariant http_errors.factory_statusCode_alias:
  description: "createError(403).statusCode is also 403 (alias of .status)"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: [403]
  chain:
    - {get: statusCode}
  expected: 403

# Class shortcuts
invariant http_errors.NotFound_class_status:
  description: "new createError.NotFound().status is 404"
  category: classes
  kind: node_chain_eq
  entry: constructor
  class: NotFound
  entry_args: []
  chain:
    - {get: status}
  expected: 404

invariant http_errors.BadRequest_class_status:
  description: "new createError.BadRequest().status is 400"
  category: classes
  kind: node_chain_eq
  entry: constructor
  class: BadRequest
  entry_args: []
  chain:
    - {get: status}
  expected: 400

# isHttpError predicate
invariant http_errors.isHttpError_true:
  description: "isHttpError on a freshly created error is true"
  category: isHttpError
  kind: node_chain_eq
  entry: bare
  chain:
    - {method: isHttpError, args: [{}]}
  expected: false
