spec: decimal_extra85
version: ">=3.9"
backend: python_module(decimal)
extends: decimal_extra84

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra84."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal dunders; Decimal comparison/equality/hash; Context/__dict__ class and membership; getcontext/setcontext __class__.__name__/__module__; Decimal division/power operator; Context arithmetic method __class__.__name__; Decimal arithmetic/string/conversion dunder __qualname__; Decimal comparison operator __qualname__ lengths; Decimal to_*/normalize/quantize/sqrt/compare __qualname__; Decimal.__dict__.__contains__; Decimal/__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); Context/__name__/__module__/__qualname__; ROUND_* constants; Decimal method qualnames; Context class identity and __dict__ membership."
    - "This spec covers: decimal signal exception __name__ and __module__ string equality for InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, DecimalException, Rounded, Subnormal."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation' — exception class bare name."
    - "decimal.InvalidOperation.__module__ == 'decimal' — defined in the decimal module."
    - "decimal.DivisionByZero.__name__ == 'DivisionByZero' — exception class bare name."
    - "decimal.DivisionByZero.__module__ == 'decimal' — defined in the decimal module."
    - "decimal.Overflow.__name__ == 'Overflow' — exception class bare name."
    - "decimal.Overflow.__module__ == 'decimal' — defined in the decimal module."
    - "decimal.Underflow.__name__ == 'Underflow' — exception class bare name."
    - "decimal.Underflow.__module__ == 'decimal' — defined in the decimal module."
    - "decimal.Inexact.__name__ == 'Inexact' — exception class bare name."
    - "decimal.Inexact.__module__ == 'decimal' — defined in the decimal module."
    - "decimal.DecimalException.__name__ == 'DecimalException' — base exception class bare name."
    - "decimal.DecimalException.__module__ == 'decimal' — defined in the decimal module."
    - "decimal.Rounded.__name__ == 'Rounded' — exception class bare name."
    - "decimal.Subnormal.__name__ == 'Subnormal' — exception class bare name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.InvalidOperation and DivisionByZero __name__ and __module__
# Both are signal exception classes defined in the decimal module.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra85.InvalidOperation_DivisionByZero_name_module:
  description: "decimal.InvalidOperation/DivisionByZero __name__ and __module__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalsigname85

  columns: [id, function, args, expected]
  rows:
    - [invalid_op_name,    InvalidOperation.__name__.__eq__,    ["InvalidOperation"], true]
    - [invalid_op_module,  InvalidOperation.__module__.__eq__,  ["decimal"],          true]
    - [divbyzero_name,     DivisionByZero.__name__.__eq__,      ["DivisionByZero"],   true]
    - [divbyzero_module,   DivisionByZero.__module__.__eq__,    ["decimal"],          true]

# ---------------------------------------------------------------------------
# decimal.Overflow and Underflow __name__ and __module__
# Both are signal exception classes defined in the decimal module.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra85.Overflow_Underflow_name_module:
  description: "decimal.Overflow/Underflow __name__ and __module__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalsigname85

  columns: [id, function, args, expected]
  rows:
    - [overflow_name,   Overflow.__name__.__eq__,   ["Overflow"],   true]
    - [overflow_module, Overflow.__module__.__eq__,  ["decimal"],   true]
    - [underflow_name,  Underflow.__name__.__eq__,   ["Underflow"],  true]
    - [underflow_module, Underflow.__module__.__eq__, ["decimal"],   true]

# ---------------------------------------------------------------------------
# decimal.Inexact and DecimalException __name__ and __module__
# Inexact is the abstract base for Overflow/Underflow/Rounded.
# DecimalException is the root of all decimal signal exceptions.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra85.Inexact_DecimalException_name_module:
  description: "decimal.Inexact/DecimalException __name__ and __module__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalsigname85

  columns: [id, function, args, expected]
  rows:
    - [inexact_name,          Inexact.__name__.__eq__,          ["Inexact"],          true]
    - [inexact_module,        Inexact.__module__.__eq__,        ["decimal"],          true]
    - [decimalexc_name,       DecimalException.__name__.__eq__, ["DecimalException"], true]
    - [decimalexc_module,     DecimalException.__module__.__eq__, ["decimal"],        true]

# ---------------------------------------------------------------------------
# decimal.Rounded and Subnormal __name__ + cross-checks
# Rounded and Subnormal are additional signal exception classes.
# Cross-check: DecimalException module matches Overflow module.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra85.Rounded_Subnormal_name_cross_checks:
  description: "decimal.Rounded/Subnormal __name__ string equality; module cross-checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalsigname85

  columns: [id, function, args, expected]
  rows:
    - [rounded_name,          Rounded.__name__.__eq__,         ["Rounded"],   true]
    - [rounded_module,        Rounded.__module__.__eq__,       ["decimal"],   true]
    - [subnormal_name,        Subnormal.__name__.__eq__,       ["Subnormal"], true]
    - [subnormal_module,      Subnormal.__module__.__eq__,     ["decimal"],   true]
    - [overflow_not_underflow, Overflow.__name__.__eq__,       ["Underflow"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra85.InvalidOperation.name:
  description: "decimal.InvalidOperation.__name__ == 'InvalidOperation' (signal exception; bare class name)"
  category: class_identity
  kind: python_call_eq
  function: InvalidOperation.__name__.__eq__
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra85.InvalidOperation.module:
  description: "decimal.InvalidOperation.__module__ == 'decimal' (signal exception; defined in decimal module)"
  category: class_identity
  kind: python_call_eq
  function: InvalidOperation.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra85.DecimalException.name:
  description: "decimal.DecimalException.__name__ == 'DecimalException' (root signal exception; bare class name)"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__name__.__eq__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra85.Overflow.name:
  description: "decimal.Overflow.__name__ == 'Overflow' (signal exception; bare class name)"
  category: class_identity
  kind: python_call_eq
  function: Overflow.__name__.__eq__
  args: ["Overflow"]
  expected: true

invariant decimal_extra85.Subnormal.name:
  description: "decimal.Subnormal.__name__ == 'Subnormal' (signal exception; bare class name)"
  category: class_identity
  kind: python_call_eq
  function: Subnormal.__name__.__eq__
  args: ["Subnormal"]
  expected: true
