spec: threading_extra2071
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "threading.Thread, Event, Lock, Condition, Semaphore, and Barrier are all pure-Python or C-backed synchronization primitives. None define __pos__, __neg__, __getattribute__, __reduce__, __reduce_ex__, __copy__, or __deepcopy__ in their own __dict__."
    - "threading.Lock is the _thread.lock C type (accessible as threading.Lock); its __dict__ contains acquire/release/locked but none of the 7 target dunders."
    - "Threading objects are intentionally not picklable; no __reduce__/__reduce_ex__ overrides are present."
    - "threading.Barrier is a pure-Python class defined in Lib/threading.py; it has no custom pickle or copy support."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __pos__ / __neg__ dict-presence for threading classes
#
# Thread, Event, Lock, Condition, Semaphore, Barrier are all synchronization
# primitives, not numeric types. None define __pos__ or __neg__.
# ---------------------------------------------------------------------------

table threading_extra2071.unary_sign_protocol:
  description: "threading classes __pos__/__neg__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2071

  columns: [id, function, args, expected]
  rows:
    - ["th2071001", "threading.Thread.__dict__.__contains__", ["__pos__"], false]
    - ["th2071002", "threading.Thread.__dict__.__contains__", ["__neg__"], false]
    - ["th2071003", "threading.Event.__dict__.__contains__", ["__pos__"], false]
    - ["th2071004", "threading.Event.__dict__.__contains__", ["__neg__"], false]
    - ["th2071005", "threading.Lock.__dict__.__contains__", ["__pos__"], false]
    - ["th2071006", "threading.Lock.__dict__.__contains__", ["__neg__"], false]
    - ["th2071007", "threading.Condition.__dict__.__contains__", ["__pos__"], false]
    - ["th2071008", "threading.Condition.__dict__.__contains__", ["__neg__"], false]

# ---------------------------------------------------------------------------
# Table 2: __getattribute__ dict-presence for threading classes
#
# None of Thread, Event, Lock, Condition, Semaphore, or Barrier override
# __getattribute__ in their own __dict__. Attribute lookup uses the default
# object.__getattribute__ (or type.__getattribute__ for type objects).
# ---------------------------------------------------------------------------

table threading_extra2071.getattribute_protocol:
  description: "threading classes __getattribute__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2071

  columns: [id, function, args, expected]
  rows:
    - ["th2071009", "threading.Thread.__dict__.__contains__", ["__getattribute__"], false]
    - ["th2071010", "threading.Event.__dict__.__contains__", ["__getattribute__"], false]
    - ["th2071011", "threading.Lock.__dict__.__contains__", ["__getattribute__"], false]
    - ["th2071012", "threading.Condition.__dict__.__contains__", ["__getattribute__"], false]
    - ["th2071013", "threading.Semaphore.__dict__.__contains__", ["__getattribute__"], false]
    - ["th2071014", "threading.Barrier.__dict__.__contains__", ["__getattribute__"], false]

# ---------------------------------------------------------------------------
# Table 3: __reduce__ / __reduce_ex__ dict-presence for threading classes
#
# Threading objects are intentionally NOT picklable. None of Thread, Event,
# Lock, Condition, Semaphore, or Barrier define __reduce__ or __reduce_ex__
# in their own __dict__.
# ---------------------------------------------------------------------------

table threading_extra2071.pickle_protocol:
  description: "threading classes __reduce__/__reduce_ex__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2071

  columns: [id, function, args, expected]
  rows:
    - ["th2071015", "threading.Thread.__dict__.__contains__", ["__reduce__"], false]
    - ["th2071016", "threading.Thread.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["th2071017", "threading.Event.__dict__.__contains__", ["__reduce__"], false]
    - ["th2071018", "threading.Event.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["th2071019", "threading.Lock.__dict__.__contains__", ["__reduce__"], false]
    - ["th2071020", "threading.Lock.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["th2071021", "threading.Condition.__dict__.__contains__", ["__reduce__"], false]
    - ["th2071022", "threading.Condition.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["th2071023", "threading.Semaphore.__dict__.__contains__", ["__reduce__"], false]
    - ["th2071024", "threading.Barrier.__dict__.__contains__", ["__reduce__"], false]

# ---------------------------------------------------------------------------
# Table 4: __copy__ / __deepcopy__ dict-presence for threading classes
#
# None of Thread, Event, Lock, Condition, Semaphore, or Barrier define
# __copy__ or __deepcopy__ in their own __dict__. Threading objects are
# not intended to be copied; they represent live OS-level resources.
# ---------------------------------------------------------------------------

table threading_extra2071.copy_protocol:
  description: "threading classes __copy__/__deepcopy__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2071

  columns: [id, function, args, expected]
  rows:
    - ["th2071025", "threading.Thread.__dict__.__contains__", ["__copy__"], false]
    - ["th2071026", "threading.Thread.__dict__.__contains__", ["__deepcopy__"], false]
    - ["th2071027", "threading.Event.__dict__.__contains__", ["__copy__"], false]
    - ["th2071028", "threading.Event.__dict__.__contains__", ["__deepcopy__"], false]
    - ["th2071029", "threading.Lock.__dict__.__contains__", ["__copy__"], false]
    - ["th2071030", "threading.Lock.__dict__.__contains__", ["__deepcopy__"], false]
    - ["th2071031", "threading.Condition.__dict__.__contains__", ["__copy__"], false]
    - ["th2071032", "threading.Condition.__dict__.__contains__", ["__deepcopy__"], false]
    - ["th2071033", "threading.Semaphore.__dict__.__contains__", ["__copy__"], false]
    - ["th2071034", "threading.Barrier.__dict__.__contains__", ["__deepcopy__"], false]
