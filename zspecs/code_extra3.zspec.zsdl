spec: code_extra3
version: ">=3.9"
backend: python_module(code)

docs: https://docs.python.org/3/library/code.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/code.html — Python code module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/code.py"
  notes:
    - "This spec extends code.zspec.zsdl and prior extras."
    - "code.zspec covers: interact/__name__, compile_command/__name__, InteractiveConsole/__name__, InteractiveInterpreter/__name__, CommandCompiler/__name__, InteractiveConsole/__module__, InteractiveConsole.__bases__[0].__name__; method names on InteractiveInterpreter; behavioral tests."
    - "code_extra covers: InteractiveConsole/__name__/__module__, InteractiveInterpreter/__name__/__module__, InteractiveConsole.__bases__[0].__name__, CommandCompiler/__name__/__module__, compile_command/__name__, interact/__name__; InteractiveInterpreter method names table."
    - "code_extra2 covers: InteractiveInterpreter.__bases__[0].__name__=='object', compile_command/__module__=='codeop', interact/__module__=='code', InteractiveConsole/__qualname__, InteractiveInterpreter/__qualname__."
    - "This spec adds: InteractiveConsole.__bases__.__len__==1, CommandCompiler/__qualname__, interact/__qualname__, compile_command/__qualname__, InteractiveInterpreter.__bases__.__len__==1."
    - "InteractiveConsole.__bases__.__len__() == 1 — single direct inheritance from InteractiveInterpreter."
    - "InteractiveInterpreter.__bases__.__len__() == 1 — single direct inheritance from object."
    - "CommandCompiler.__qualname__ == 'CommandCompiler' — top-level class; qualname equals name."
    - "interact.__qualname__ == 'interact' — top-level function; qualname equals name."
    - "compile_command.__qualname__ == 'compile_command' — top-level function; qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__.__len__ — InteractiveConsole and InteractiveInterpreter
# Confirms single-inheritance structure not verified in any prior code spec.
# ---------------------------------------------------------------------------

invariant code_extra3.InteractiveConsole.bases_len:
  description: "len(code.InteractiveConsole.__bases__) == 1 — single direct base (InteractiveInterpreter)"
  category: class_hierarchy
  kind: python_call_eq
  function: InteractiveConsole.__bases__.__len__
  args: []
  expected: 1

invariant code_extra3.InteractiveInterpreter.bases_len:
  description: "len(code.InteractiveInterpreter.__bases__) == 1 — single direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: InteractiveInterpreter.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# __qualname__ — CommandCompiler, interact, compile_command
# code_extra2 covers InteractiveConsole and InteractiveInterpreter qualnames.
# This spec adds the remaining top-level names.
# ---------------------------------------------------------------------------

invariant code_extra3.CommandCompiler.qualname:
  description: "code.CommandCompiler.__qualname__ == 'CommandCompiler'"
  category: qualnames
  kind: python_call_eq
  function: CommandCompiler.__qualname__.__eq__
  args: ["CommandCompiler"]
  expected: true

invariant code_extra3.interact.qualname:
  description: "code.interact.__qualname__ == 'interact'"
  category: qualnames
  kind: python_call_eq
  function: interact.__qualname__.__eq__
  args: ["interact"]
  expected: true

invariant code_extra3.compile_command.qualname:
  description: "code.compile_command.__qualname__ == 'compile_command'"
  category: qualnames
  kind: python_call_eq
  function: compile_command.__qualname__.__eq__
  args: ["compile_command"]
  expected: true

# ---------------------------------------------------------------------------
# InteractiveConsole.__bases__[0].__name__ — re-verified via __qualname__
# Prior specs check __name__ == 'InteractiveInterpreter'; this confirms the
# base's __qualname__ as well, pinning against class renames.
# ---------------------------------------------------------------------------

invariant code_extra3.InteractiveConsole.base_qualname:
  description: "code.InteractiveConsole.__bases__[0].__qualname__ == 'InteractiveInterpreter'"
  category: class_hierarchy
  kind: python_call_eq
  function: InteractiveConsole.__bases__.__getitem__
  args: [0]
  method: __qualname__
  method_args: []
  expected: "InteractiveInterpreter"
