spec: pathlib_extra1171
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib.__all__ membership checks for Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath, pathlib.__all__.__len__, and pathlib.Path.__bases__.__class__.__name__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.__all__.__contains__ for Path, PurePath, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath and non-members; pathlib.__all__.__len__ sanity; pathlib.Path.__bases__.__class__.__name__; none of these __all__ membership or __bases__ checks were covered in _extra1141 or _extra1156"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1171.all_contains_purepath_family:
  description: "pathlib.__all__.__contains__ membership checks for PurePath, PurePosixPath, PureWindowsPath, and non-members"
  kind: python_call_eq
  category: all_contains_purepath_family
  id_prefix: pl1171pf
  columns: [id, function, args, expected]
  rows:
    - [pl1171pf001, pathlib.__all__.__contains__, ["PurePath"],        true]
    - [pl1171pf002, pathlib.__all__.__contains__, ["PurePosixPath"],   true]
    - [pl1171pf003, pathlib.__all__.__contains__, ["PureWindowsPath"], true]
    - [pl1171pf004, pathlib.__all__.__contains__, ["_PurePath"],       false]
    - [pl1171pf005, pathlib.__all__.__contains__, ["purepath"],        false]
    - [pl1171pf006, pathlib.__all__.__contains__, ["PureWindowsPath"], true]
    - [pl1171pf007, pathlib.__all__.__contains__, ["AbstractPath"],    false]
    - [pl1171pf008, pathlib.__all__.__contains__, ["PurePosixPath"],   true]

table pathlib_extra1171.all_contains_concrete_path_classes:
  description: "pathlib.__all__.__contains__ membership checks for Path, PosixPath, WindowsPath, and non-members"
  kind: python_call_eq
  category: all_contains_concrete_path_classes
  id_prefix: pl1171cp
  columns: [id, function, args, expected]
  rows:
    - [pl1171cp001, pathlib.__all__.__contains__, ["Path"],        true]
    - [pl1171cp002, pathlib.__all__.__contains__, ["PosixPath"],   true]
    - [pl1171cp003, pathlib.__all__.__contains__, ["WindowsPath"], true]
    - [pl1171cp004, pathlib.__all__.__contains__, ["_Path"],       false]
    - [pl1171cp005, pathlib.__all__.__contains__, ["path"],        false]
    - [pl1171cp006, pathlib.__all__.__contains__, ["posixpath"],   false]
    - [pl1171cp007, pathlib.__all__.__contains__, ["WindowsPath"], true]
    - [pl1171cp008, pathlib.__all__.__contains__, ["FilePath"],    false]

table pathlib_extra1171.all_len_and_bases_class_name:
  description: "pathlib.__all__.__len__ sanity and pathlib.Path.__bases__.__class__.__name__ checks"
  kind: python_call_eq
  category: all_len_and_bases_class_name
  id_prefix: pl1171al
  columns: [id, function, args, expected]
  rows:
    - [pl1171al001, pathlib.__all__.__len__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [pl1171al002, pathlib.__all__.__class__.__name__.__eq__,             ["list"],  true]
    - [pl1171al003, pathlib.__all__.__class__.__name__.__eq__,             ["tuple"], false]
    - [pl1171al004, pathlib.Path.__bases__.__class__.__name__.__eq__,      ["tuple"], true]
    - [pl1171al005, pathlib.Path.__bases__.__class__.__name__.__eq__,      ["list"],  false]
    - [pl1171al006, pathlib.PurePath.__bases__.__class__.__name__.__eq__,  ["tuple"], true]
    - [pl1171al007, pathlib.PurePath.__bases__.__class__.__name__.__eq__,  ["list"],  false]
    - [pl1171al008, pathlib.__all__.__len__.__class__.__name__.__eq__,     ["function"], false]
