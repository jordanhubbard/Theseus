spec: struct_extra18
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct.zspec.zsdl — pack/unpack/calcsize core vectors."
    - "struct_extra.zspec.zsdl through struct_extra17.zspec.zsdl — prior extras."
  notes:
    - "This spec extends struct.zspec.zsdl through struct_extra17.zspec.zsdl."
    - "This spec adds NEW axes:"
    - "  (1) struct.Struct.__bases__[0].__name__ == 'object' — base class of Struct."
    - "  (2) struct.Struct.__module__ == '_struct' — Struct is defined in the C extension."
    - "  (3) struct.error.__bases__[0].__name__ == 'Exception' — error inherits from Exception."
    - "  (4) struct.error.__module__ == 'struct' — error is defined at Python struct level."
    - "  (5) Table: __module__ for all callable functions — all are '_struct'."
    - "struct.Struct.__bases__[0].__name__ == 'object' — Verified Python 3.12 macOS."
    - "struct.Struct.__module__ == '_struct' — Struct is implemented in C. Verified."
    - "struct.pack.__module__ == '_struct' — C extension. Verified."
    - "struct.unpack.__module__ == '_struct' — C extension. Verified."
    - "struct.calcsize.__module__ == '_struct' — C extension. Verified."
    - "struct.pack_into.__module__ == '_struct' — C extension. Verified."
    - "struct.unpack_from.__module__ == '_struct' — C extension. Verified."
    - "struct.iter_unpack.__module__ == '_struct' — C extension. Verified."
    - "struct.error.__bases__[0].__name__ == 'Exception' — Verified."
    - "struct.error.__module__ == 'struct' — defined at Python level, not '_struct'. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__bases__[0].__name__ == 'object'
#
# The Struct class (implemented in C) has 'object' as its only direct base.
# No prior struct spec checks this base class relationship.
# ---------------------------------------------------------------------------

invariant struct_extra18.bases.struct_superclass:
  description: "struct.Struct.__bases__[0].__name__ == 'object' — Struct directly inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  "function": "Struct.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__module__ == '_struct'
#
# The Struct class is defined in the C extension _struct, not in the pure-
# Python struct wrapper. struct_extra8 covers __module__ for callable
# functions; this invariant anchors the Struct class itself.
# ---------------------------------------------------------------------------

invariant struct_extra18.module.struct_class:
  description: "struct.Struct.__module__ == '_struct' — Struct is a C-extension class"
  category: class_modules
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error base class
#
# struct.error inherits from Exception (not from OSError or RuntimeError).
# struct_extra17 anchors error.__module__; this spec anchors the base class
# from the extra18 namespace.
# ---------------------------------------------------------------------------

invariant struct_extra18.error.superclass:
  description: "struct.error.__bases__[0].__name__ == 'Exception' — error inherits from Exception"
  category: class_hierarchy
  kind: python_call_eq
  "function": "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__module__ == 'struct'
#
# Unlike Struct and the callable functions (all in '_struct'), the error
# exception is defined at the Python struct level. struct_extra17 covers this
# from the extra17 namespace; this invariant anchors it again from extra18 as
# a cross-spec consistency check.
# ---------------------------------------------------------------------------

invariant struct_extra18.error.module:
  description: "struct.error.__module__ == 'struct' — error exception defined at Python struct level"
  category: class_modules
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# callable() checks for core struct functions
#
# All six struct functions are callable. Anchored from the extra18 namespace.
# ---------------------------------------------------------------------------

invariant struct_extra18.callable.pack:
  description: "callable(struct.pack) == True — pack is callable"
  category: callable
  kind: python_call_eq
  function: pack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant struct_extra18.callable.calcsize:
  description: "callable(struct.calcsize) == True — calcsize is callable"
  category: callable
  kind: python_call_eq
  function: calcsize.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — all 6 callable struct functions
#
# pack, unpack, calcsize, pack_into, unpack_from, and iter_unpack are all
# implemented in _struct.c. Their __module__ is '_struct'. struct_extra8
# covers a subset; this table covers all 6 from the extra18 namespace.
# id_prefix se18 does not conflict with any prior struct spec.
# ---------------------------------------------------------------------------

table struct_extra18.module.all_functions:
  description: "__module__ for all 6 struct callable functions — all are '_struct'"
  kind: python_call_eq
  category: function_modules
  id_prefix: se18

  columns: [id, function, args, expected]
  rows:
    - [pack_mod,        pack.__module__.__eq__,        ["_struct"], true]
    - [unpack_mod,      unpack.__module__.__eq__,      ["_struct"], true]
    - [calcsize_mod,    calcsize.__module__.__eq__,    ["_struct"], true]
    - [pack_into_mod,   pack_into.__module__.__eq__,   ["_struct"], true]
    - [unpack_from_mod, unpack_from.__module__.__eq__, ["_struct"], true]
    - [iter_unpack_mod, iter_unpack.__module__.__eq__, ["_struct"], true]
