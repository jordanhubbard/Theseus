spec: decimal_extra841
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/_pydecimal.py"
    - "cpython/Modules/_decimal/_decimal.c"
  not_derived_from:
    - "any third-party decimal library"
  notes:
    - "Covers __qualname__ invariants for Decimal conversion and math methods"
    - "Qualnames are stable across both the C accelerator and pure-Python fallback"
  created_at: "2026-04-12"

table decimal_extra841.decimal_conversion_qualnames:
  description: "decimal.Decimal string and integral conversion method __qualname__ equality checks"
  kind: python_call_eq
  category: qualname
  id_prefix: dc841cv
  columns: [id, function, args, expected]
  rows:
    - [dc841cv001, decimal.Decimal.to_eng_string.__qualname__.__eq__, ["Decimal.to_eng_string"], true]
    - [dc841cv002, decimal.Decimal.to_integral.__qualname__.__eq__, ["Decimal.to_integral"], true]
    - [dc841cv003, decimal.Decimal.to_integral_exact.__qualname__.__eq__, ["Decimal.to_integral_exact"], true]
    - [dc841cv004, decimal.Decimal.to_integral_value.__qualname__.__eq__, ["Decimal.to_integral_value"], true]
    - [dc841cv005, decimal.Decimal.as_tuple.__qualname__.__eq__, ["Decimal.as_tuple"], true]
    - [dc841cv006, decimal.Decimal.normalize.__qualname__.__eq__, ["Decimal.normalize"], true]
    - [dc841cv007, decimal.Decimal.quantize.__qualname__.__eq__, ["Decimal.quantize"], true]

table decimal_extra841.decimal_math_qualnames:
  description: "decimal.Decimal mathematical method __qualname__ equality checks"
  kind: python_call_eq
  category: qualname
  id_prefix: dc841mt
  columns: [id, function, args, expected]
  rows:
    - [dc841mt001, decimal.Decimal.sqrt.__qualname__.__eq__, ["Decimal.sqrt"], true]
    - [dc841mt002, decimal.Decimal.exp.__qualname__.__eq__, ["Decimal.exp"], true]
    - [dc841mt003, decimal.Decimal.ln.__qualname__.__eq__, ["Decimal.ln"], true]
    - [dc841mt004, decimal.Decimal.log10.__qualname__.__eq__, ["Decimal.log10"], true]
    - [dc841mt005, decimal.Decimal.logb.__qualname__.__eq__, ["Decimal.logb"], true]
