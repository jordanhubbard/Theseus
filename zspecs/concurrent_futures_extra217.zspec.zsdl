spec: concurrent_futures_extra217
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.Executor.__name__ == 'Executor'; __module__ == 'concurrent.futures._base'."
    - "concurrent.futures.Executor.__bases__[0].__name__ == 'object' — Executor inherits directly from object."
    - "concurrent.futures.Executor.submit exists and __name__ == 'submit'."
    - "concurrent.futures.ThreadPoolExecutor(max_workers=0) raises ValueError: max_workers must be greater than 0."
    - "concurrent.futures.ThreadPoolExecutor(max_workers=-1) raises ValueError: max_workers must be greater than 0."
    - "concurrent.futures.ProcessPoolExecutor(max_workers=0) raises ValueError: max_workers must be greater than 0."
    - "concurrent.futures.as_completed.__name__ == 'as_completed'; __module__ == 'concurrent.futures._base'."
    - "concurrent.futures.wait.__name__ == 'wait'; __module__ == 'concurrent.futures._base'."
    - "concurrent.futures.FIRST_COMPLETED is a plain str — not an enum member — value 'FIRST_COMPLETED'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Executor class identity — extra217 namespace
# ---------------------------------------------------------------------------

table concurrent_futures_extra217.executor_class_identity:
  description: "concurrent.futures.Executor class __name__ and __module__ checks in extra217 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf217execident

  columns: [id, function, args, expected, description]
  rows:
    - [executor_name,   Executor.__name__.__eq__,   ["Executor"],                    true, "concurrent.futures.Executor.__name__ == 'Executor'"]
    - [executor_module, Executor.__module__.__eq__, ["concurrent.futures._base"],    true, "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'"]

invariant concurrent_futures_extra217.executor_base_name:
  description: "concurrent.futures.Executor.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "Executor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.futures.Executor.submit method identity — extra217 namespace
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra217.executor_submit_name:
  description: "concurrent.futures.Executor.submit.__name__ == 'submit'"
  category: identity
  kind: python_call_eq
  function: Executor.submit.__name__.__eq__
  args: ["submit"]
  expected: true

# ---------------------------------------------------------------------------
# ThreadPoolExecutor(max_workers=0) raises ValueError — extra217 namespace
#
# max_workers must be > 0; passing 0 or negative raises ValueError.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra217.threadpool_maxworkers_zero_raises:
  description: "concurrent.futures.ThreadPoolExecutor(max_workers=0) raises ValueError — max_workers must be > 0"
  category: errors
  kind: python_call_raises
  function: ThreadPoolExecutor
  args: []
  kwargs: {max_workers: 0}
  expected: ValueError

invariant concurrent_futures_extra217.threadpool_maxworkers_neg_raises:
  description: "concurrent.futures.ThreadPoolExecutor(max_workers=-1) raises ValueError — max_workers must be > 0"
  category: errors
  kind: python_call_raises
  function: ThreadPoolExecutor
  args: []
  kwargs: {max_workers: -1}
  expected: ValueError

# ---------------------------------------------------------------------------
# ProcessPoolExecutor(max_workers=0) raises ValueError — extra217 namespace
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra217.processpool_maxworkers_zero_raises:
  description: "concurrent.futures.ProcessPoolExecutor(max_workers=0) raises ValueError — max_workers must be > 0"
  category: errors
  kind: python_call_raises
  function: ProcessPoolExecutor
  args: []
  kwargs: {max_workers: 0}
  expected: ValueError

