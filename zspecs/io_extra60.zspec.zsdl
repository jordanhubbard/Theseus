spec: io_extra60
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra59.zspec.zsdl — covers DEFAULT_BUFFER_SIZE __class__.__module__/__len__()==8 (NOVEL in extra59); BufferedIOBase/TextIOBase __module__ equality/length."
    - "io_extra58.zspec.zsdl — covers BytesIO/StringIO/BufferedReader/BufferedWriter/open __module__.__len__()==3; class __module__.__eq__() namespace anchors for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/'_io'; IOBase/RawIOBase/'io'; open/'_io'."
    - "io_extra57.zspec.zsdl — covers BytesIO/StringIO method qualname equality for read/write/seek/tell/getvalue."
    - "io_extra56.zspec.zsdl — covers __doc__.__class__.__name__/qualname for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase/RawIOBase/BufferedIOBase/TextIOBase and module."
    - "io_extra37.zspec.zsdl — covers __dict__.__class__.__name__.__len__()==12 for StringIO/BytesIO/IOBase/FileIO/RawIOBase/BufferedReader/TextIOWrapper (len check only, not equality)."
  notes:
    - "This spec extends io_extra59.zspec.zsdl."
    - "Prior specs collectively covered: io_extra37 checks __dict__.__class__.__name__.__len__()==12 for StringIO/BytesIO/IOBase/FileIO/RawIOBase/BufferedReader/TextIOWrapper (length only); no prior io spec checks __dict__.__class__.__name__.__eq__('mappingproxy') as a direct equality invariant for any io class; no prior io spec checks __dict__.__class__.__qualname__ for any io class; no prior io spec checks io module __dict__.__class__.__name__/__qualname__."
    - "This spec covers: io.BytesIO.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL — io_extra37 checks the __len__()==12 variant but no prior spec verifies the string equality directly; novel equality anchor in iodict60 namespace); io.StringIO.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); io.FileIO.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); io.BufferedReader.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); io.BufferedWriter.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); io.TextIOWrapper.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); io.IOBase.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL); io.BytesIO.__dict__.__class__.__qualname__.__eq__('mappingproxy') (NOVEL — no prior io spec checks __dict__.__class__.__qualname__ for any class; the builtin mappingproxy type has __qualname__ == __name__ == 'mappingproxy'); io.FileIO.__dict__.__class__.__qualname__.__eq__('mappingproxy') (NOVEL); io.__dict__.__class__.__name__.__eq__('mappingproxy') (NOVEL — no prior io spec checks the io module's own __dict__.__class__.__name__; the module __dict__ is also a mappingproxy); io.__dict__.__class__.__qualname__.__eq__('mappingproxy') (NOVEL)."
    - "io.BytesIO.__dict__.__class__.__name__ == 'mappingproxy'. Every Python class's __dict__ is a mappingproxy (types.MappingProxyType). The __class__.__name__ of a mappingproxy is 'mappingproxy'. io_extra37 verified __len__()==12 but not the string equality. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.__dict__.__class__.__name__ == 'mappingproxy'. Same reasoning. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.__dict__.__class__.__name__ == 'mappingproxy'. FileIO is the raw file I/O class. Its __dict__ is a mappingproxy. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedReader.__dict__.__class__.__name__ == 'mappingproxy'. BufferedReader wraps a readable RawIOBase object. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.__dict__.__class__.__name__ == 'mappingproxy'. BufferedWriter wraps a writable RawIOBase object. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.__dict__.__class__.__name__ == 'mappingproxy'. TextIOWrapper wraps a buffered binary stream. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.IOBase.__dict__.__class__.__name__ == 'mappingproxy'. IOBase is the abstract base for all I/O classes. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BytesIO.__dict__.__class__.__qualname__ == 'mappingproxy'. For the builtin mappingproxy type (types.MappingProxyType), __qualname__ == __name__ == 'mappingproxy'. No prior io spec checks __dict__.__class__.__qualname__ for any io class. Novel __qualname__ axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.FileIO.__dict__.__class__.__qualname__ == 'mappingproxy'. Same reasoning as BytesIO. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.__dict__.__class__.__name__ == 'mappingproxy'. The module's own __dict__ attribute is also a mappingproxy. No prior io spec checks the io module's __dict__.__class__.__name__. Novel module-level axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.__dict__.__class__.__qualname__ == 'mappingproxy'. Same as __name__ for the builtin mappingproxy type. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __dict__ identity — __class__.__name__ equality (novel equality axis)
#
# Every Python class's __dict__ attribute is a types.MappingProxyType instance.
# The __class__.__name__ of that proxy is 'mappingproxy'.
# io_extra37 verified __dict__.__class__.__name__.__len__()==12 for several io
# classes (checking the 12-character length of 'mappingproxy') but no prior io
# spec verifies the string equality directly with __eq__.
#
#   BytesIO.__dict__.__class__.__name__      == 'mappingproxy'
#   StringIO.__dict__.__class__.__name__     == 'mappingproxy'
#   FileIO.__dict__.__class__.__name__       == 'mappingproxy'
#   BufferedReader.__dict__.__class__.__name__ == 'mappingproxy'
#   BufferedWriter.__dict__.__class__.__name__ == 'mappingproxy'
#   TextIOWrapper.__dict__.__class__.__name__ == 'mappingproxy'
#   IOBase.__dict__.__class__.__name__       == 'mappingproxy'
#
# All seven equality anchors are novel in the iodict60 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra60.class_dict_name_eq:
  description: "io class __dict__.__class__.__name__.__eq__('mappingproxy') for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase — every class __dict__ is a mappingproxy; io_extra37 covers __len__()==12 only; no prior io spec checks __dict__.__class__.__name__.__eq__(); all seven novel equality anchors in iodict60 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iodict60name

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_dict_name,        "BytesIO.__dict__.__class__.__name__.__eq__",        ["mappingproxy"], true]
    - [StringIO_dict_name,       "StringIO.__dict__.__class__.__name__.__eq__",       ["mappingproxy"], true]
    - [FileIO_dict_name,         "FileIO.__dict__.__class__.__name__.__eq__",         ["mappingproxy"], true]
    - [BufferedReader_dict_name, "BufferedReader.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - [BufferedWriter_dict_name, "BufferedWriter.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - [TextIOWrapper_dict_name,  "TextIOWrapper.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true]
    - [IOBase_dict_name,         "IOBase.__dict__.__class__.__name__.__eq__",         ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# io class __dict__ identity — __class__.__qualname__ equality (novel qualname axis)
#
# The builtin mappingproxy type has __qualname__ == __name__ == 'mappingproxy'
# (it is a top-level C builtin with no enclosing class scope). No prior io
# spec checks __dict__.__class__.__qualname__ for any io class.
#
#   BytesIO.__dict__.__class__.__qualname__ == 'mappingproxy'
#   FileIO.__dict__.__class__.__qualname__  == 'mappingproxy'
#
# Two representative __qualname__ anchors are novel in the iodict60 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra60.class_dict_qualname_eq:
  description: "io class __dict__.__class__.__qualname__.__eq__('mappingproxy') for BytesIO/FileIO — mappingproxy is a top-level C builtin so __qualname__==__name__=='mappingproxy'; no prior io spec checks __dict__.__class__.__qualname__ for any io class; two novel __qualname__ anchors in iodict60 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iodict60qualname

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_dict_qualname, "BytesIO.__dict__.__class__.__qualname__.__eq__", ["mappingproxy"], true]
    - [FileIO_dict_qualname,  "FileIO.__dict__.__class__.__qualname__.__eq__",  ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# io module __dict__ identity (novel module-level axis)
#
# The io module's own __dict__ attribute (the module namespace) is also a
# mappingproxy at runtime. No prior io spec checks the io module's
# __dict__.__class__.__name__ or __dict__.__class__.__qualname__.
#
#   io.__dict__.__class__.__name__     == 'mappingproxy'
#   io.__dict__.__class__.__qualname__ == 'mappingproxy'
#
# Both anchors are novel in the iodict60 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra60.module_dict_identity:
  description: "io module __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy') — the io module namespace is itself a mappingproxy; no prior io spec checks io.__dict__.__class__.__name__ or __qualname__; both novel anchors in iodict60 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iodict60mod

  columns: [id, function, args, expected]
  rows:
    - [module_dict_name,     "__dict__.__class__.__name__.__eq__",     ["mappingproxy"], true]
    - [module_dict_qualname, "__dict__.__class__.__qualname__.__eq__", ["mappingproxy"], true]
