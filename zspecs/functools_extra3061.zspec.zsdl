spec: ft3061
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 651 (ft3061): __aexit__, __await__, __anext__ dict-presence checks for functools types."
    - "None of the functools types define __aexit__, __await__, or __anext__ in their own __dict__."
    - "functools.partial is a C-level type; functools.partialmethod is a pure Python class."
    - "functools.cached_property is a pure Python descriptor class."
    - "type(functools.lru_cache(lambda: None)) is functools._lru_cache_wrapper (C-level wrapper)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3061.aexit:
  description: "functools types __aexit__ dict-presence checks; wave 651"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft3061
  columns: [id, function, args, expected]
  rows:
    - ["ft3061001", operator.contains, [functools.partial.__dict__,            "__aexit__"], false]
    - ["ft3061002", operator.contains, [functools.partialmethod.__dict__,      "__aexit__"], false]
    - ["ft3061003", operator.contains, [functools.cached_property.__dict__,    "__aexit__"], false]
    - ["ft3061004", operator.contains, [functools._lru_cache_wrapper.__dict__,  "__aexit__"], false]

