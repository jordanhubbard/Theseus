spec: uuid_extra280
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module identity, variant constants"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid variant string constants (RFC_4122, RESERVED_*) are module-level str attributes"
    - "__package__ is empty string for top-level modules"
    - "__loader__ class is SourceFileLoader because uuid is a pure-Python module"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra280.module_identity:
  description: "uuid module identity via dunder attributes"
  kind: python_call_eq
  category: identity
  id_prefix: ux280

  columns: [id, function, args, expected, description]
  rows:
    - [ux280-001, uuid.__name__.__eq__, ["uuid"], true, "module name is 'uuid'"]
    - [ux280-002, uuid.__package__.__eq__, [""], true, "__package__ is empty string for top-level module"]
    - [ux280-003, uuid.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "__spec__ is a ModuleSpec"]
    - [ux280-004, uuid.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "__loader__ is a SourceFileLoader"]

table uuid_extra280.variant_constants:
  description: "uuid variant string constants class names and values"
  kind: python_call_eq
  category: identity
  id_prefix: ux280

  columns: [id, function, args, expected, description]
  rows:
    - [ux280-005, uuid.RFC_4122.__class__.__name__.__eq__, ["str"], true, "RFC_4122 is a str"]
    - [ux280-006, uuid.RESERVED_NCS.__class__.__name__.__eq__, ["str"], true, "RESERVED_NCS is a str"]
    - [ux280-007, uuid.RESERVED_MICROSOFT.__class__.__name__.__eq__, ["str"], true, "RESERVED_MICROSOFT is a str"]
    - [ux280-008, uuid.RESERVED_FUTURE.__class__.__name__.__eq__, ["str"], true, "RESERVED_FUTURE is a str"]
    - [ux280-009, uuid.RFC_4122.__eq__, ["specified in RFC 4122"], true, "RFC_4122 value is 'specified in RFC 4122'"]
    - [ux280-010, uuid.RESERVED_NCS.__eq__, ["reserved for NCS compatibility"], true, "RESERVED_NCS value"]
    - [ux280-011, uuid.RESERVED_MICROSOFT.__eq__, ["reserved for Microsoft compatibility"], true, "RESERVED_MICROSOFT value"]
    - [ux280-012, uuid.RESERVED_FUTURE.__eq__, ["reserved for future definition"], true, "RESERVED_FUTURE value"]

invariant uuid_extra280.spec_name_eq:
  description: "__spec__.name equals 'uuid'"
  category: identity
  kind: python_call_eq
  function: uuid.__spec__.name.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra280.file_is_str:
  description: "__file__ attribute is a str"
  category: identity
  kind: python_call_eq
  function: uuid.__file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant uuid_extra280.rfc_4122_is_str:
  description: "RFC_4122 constant type is str"
  category: identity
  kind: python_call_eq
  function: uuid.RFC_4122.__class__.__name__.__eq__
  args: ["str"]
  expected: true
