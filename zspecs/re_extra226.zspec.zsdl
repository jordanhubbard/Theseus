spec: re_extra226
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module function __code__.co_argcount and __code__.co_name contracts."
    - "re.compile.__code__.co_argcount == 2: pattern, flags; verified with Python 3.14.3."
    - "re.match.__code__.co_argcount == 3: pattern, string, flags; verified with Python 3.14.3."
    - "re.search.__code__.co_argcount == 3: pattern, string, flags; verified with Python 3.14.3."
    - "re.fullmatch.__code__.co_argcount == 3: pattern, string, flags; verified with Python 3.14.3."
    - "re.findall.__code__.co_argcount == 3: pattern, string, flags; verified with Python 3.14.3."
    - "re.finditer.__code__.co_argcount == 3: pattern, string, flags; verified with Python 3.14.3."
    - "re.sub.__code__.co_argcount == 3: pattern, repl, string (count/flags are keyword-only); verified with Python 3.14.3."
    - "re.subn.__code__.co_argcount == 3: pattern, repl, string (count/flags are keyword-only); verified with Python 3.14.3."
    - "re.split.__code__.co_argcount == 2: pattern, string (maxsplit/flags are keyword-only); verified with Python 3.14.3."
    - "re.escape.__code__.co_argcount == 1: pattern only; verified with Python 3.14.3."
    - "re.compile.__code__.co_name == 'compile'; the code object name matches the function name; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re function __code__.co_argcount values
# co_argcount counts positional + positional-with-default args only.
# Keyword-only args (count, flags, maxsplit) are NOT counted.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table re_extra226.function_co_argcount:
  description: "re function __code__.co_argcount contracts for compile (2), match/search/fullmatch/findall/finditer (3 each), sub/subn (3 each), split (2), escape (1); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_metadata
  id_prefix: remthdargcnt226

  columns: [id, function, args, expected]
  rows:
    - [compile_argcount,   compile.__code__.co_argcount.__eq__,   [2], true]
    - [match_argcount,     match.__code__.co_argcount.__eq__,     [3], true]
    - [search_argcount,    search.__code__.co_argcount.__eq__,    [3], true]
    - [fullmatch_argcount, fullmatch.__code__.co_argcount.__eq__, [3], true]
    - [findall_argcount,   findall.__code__.co_argcount.__eq__,   [3], true]
    - [finditer_argcount,  finditer.__code__.co_argcount.__eq__,  [3], true]
    - [sub_argcount,       sub.__code__.co_argcount.__eq__,       [3], true]
    - [subn_argcount,      subn.__code__.co_argcount.__eq__,      [3], true]
    - [split_argcount,     split.__code__.co_argcount.__eq__,     [2], true]
    - [escape_argcount,    escape.__code__.co_argcount.__eq__,    [1], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant re_extra226.compile.co_argcount:
  description: "re.compile.__code__.co_argcount == 2 — compile takes pattern and flags as positional args; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: compile.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant re_extra226.match.co_argcount:
  description: "re.match.__code__.co_argcount == 3 — match takes pattern, string, flags as positional args; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: match.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra226.search.co_argcount:
  description: "re.search.__code__.co_argcount == 3 — search takes pattern, string, flags as positional args; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: search.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra226.sub.co_argcount:
  description: "re.sub.__code__.co_argcount == 3 — sub takes pattern, repl, string as positional args; count and flags are keyword-only and not counted; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: sub.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra226.subn.co_argcount:
  description: "re.subn.__code__.co_argcount == 3 — subn takes pattern, repl, string as positional args; count and flags are keyword-only and not counted; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: subn.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra226.split.co_argcount:
  description: "re.split.__code__.co_argcount == 2 — split takes pattern and string as positional args; maxsplit and flags are keyword-only and not counted; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: split.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant re_extra226.escape.co_argcount:
  description: "re.escape.__code__.co_argcount == 1 — escape takes only pattern; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: escape.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant re_extra226.compile.co_name:
  description: "re.compile.__code__.co_name == 'compile' — the code object name matches the function name; verified with Python 3.14.3"
  category: code_metadata
  kind: python_call_eq
  function: compile.__code__.co_name.__eq__
  args: ["compile"]
  expected: true
