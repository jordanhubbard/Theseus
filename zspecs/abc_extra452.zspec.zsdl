spec: abc_extra452
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module abstract base classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "abc.update_abstractmethods was added in Python 3.10; these invariants require version >=3.10 to pass"
    - "abc.abstractproperty, abc.abstractclassmethod, and abc.abstractstaticmethod are deprecated since Python 3.3"
    - "abc.ABC.__class__ is ABCMeta (the metaclass), not type"
    - "abc.ABCMeta.__class__ is type (ABCMeta is itself a class whose metaclass is type)"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra452.function_names:
  description: "abc module function __name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: abcfn

  columns: [id, function, args, expected]
  rows:
    - [abcfn001, abc.get_cache_token.__name__.__eq__, ["get_cache_token"], true]
    - [abcfn002, abc.abstractmethod.__name__.__eq__, ["abstractmethod"], true]
    - [abcfn003, abc.abstractclassmethod.__name__.__eq__, ["abstractclassmethod"], true]
    - [abcfn004, abc.abstractstaticmethod.__name__.__eq__, ["abstractstaticmethod"], true]

table abc_extra452.function_modules:
  description: "abc module function __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: abcfm

  columns: [id, function, args, expected]
  rows:
    - [abcfm001, abc.get_cache_token.__module__.__eq__, ["abc"], true]

table abc_extra452.update_abstractmethods_identity:
  description: "abc.update_abstractmethods identity (Python >=3.10)"
  kind: python_call_eq
  category: identity
  id_prefix: abcuam

  columns: [id, function, args, expected]
  rows:
    - [abcuam001, abc.update_abstractmethods.__name__.__eq__, ["update_abstractmethods"], true]
    - [abcuam002, abc.update_abstractmethods.__module__.__eq__, ["abc"], true]

table abc_extra452.metaclass_identity:
  description: "abc class and metaclass __class__.__name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: abcmc

  columns: [id, function, args, expected]
  rows:
    - [abcmc001, abc.ABC.__class__.__name__.__eq__, ["ABCMeta"], true]
    - [abcmc002, abc.ABCMeta.__class__.__name__.__eq__, ["type"], true]
    - [abcmc003, abc.abstractmethod.__class__.__name__.__eq__, ["type"], true]
    - [abcmc004, abc.abstractproperty.__class__.__name__.__eq__, ["type"], true]
