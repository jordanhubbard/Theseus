spec: pathlib_extra243
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.PurePath.match behavioral contracts — pattern matching against path components."
    - "PurePosixPath.match(pattern) returns True if the path matches the given glob-style pattern."
    - "Without a leading slash, the pattern is matched against the rightmost path components only."
    - "pathlib.PurePosixPath('/a/b/c').match('*.c') == False — 'c' has no extension; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/c').match('b/c') == True — last two components match 'b/c'; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/c').match('/a/b/c') == True — full absolute path matches; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/c').match('*.txt') == False — 'c' does not end in .txt; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/foo.py').match('*.py') == True — last component foo.py matches *.py; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/foo.py').match('b/*.py') == True — last two components match 'b/*.py'; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/foo.py').match('a/*.py') == False — second-to-last component is 'b', not 'a'; verified Python 3.14.3 macOS."
    - "pathlib.PurePosixPath('/a/b/c').match('c') == True — single-component pattern matches last component; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.match.__qualname__ == 'PurePath.match' — length 14; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath.match() behavioral contracts
# match(pattern) returns True if this path matches the given pattern.
# Without a leading slash, the pattern anchors to the right (suffix match).
# With a leading slash, the pattern must match the full absolute path.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra243.PurePosixPath.match.star_c_false:
  description: "pathlib.PurePosixPath('/a/b/c').match('*.c') == False — 'c' has no dot extension; verified Python 3.14.3 macOS"
  category: match
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: match
  method_args: ["*.c"]
  expected: false

invariant pathlib_extra243.PurePosixPath.match.b_slash_c_true:
  description: "pathlib.PurePosixPath('/a/b/c').match('b/c') == True — last two components 'b/c' match the pattern; verified Python 3.14.3 macOS"
  category: match
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: match
  method_args: ["b/c"]
  expected: true

invariant pathlib_extra243.PurePosixPath.match.absolute_match_true:
  description: "pathlib.PurePosixPath('/a/b/c').match('/a/b/c') == True — full absolute path pattern matches; verified Python 3.14.3 macOS"
  category: match
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: match
  method_args: ["/a/b/c"]
  expected: true

invariant pathlib_extra243.PurePosixPath.match.star_txt_false:
  description: "pathlib.PurePosixPath('/a/b/c').match('*.txt') == False — last component 'c' does not end in .txt; verified Python 3.14.3 macOS"
  category: match
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: match
  method_args: ["*.txt"]
  expected: false

invariant pathlib_extra243.PurePosixPath.match.star_py_true:
  description: "pathlib.PurePosixPath('/a/b/foo.py').match('*.py') == True — 'foo.py' ends in .py; verified Python 3.14.3 macOS"
  category: match
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/foo.py"]
  method: match
  method_args: ["*.py"]
  expected: true

invariant pathlib_extra243.PurePosixPath.match.b_star_py_true:
  description: "pathlib.PurePosixPath('/a/b/foo.py').match('b/*.py') == True — last two components 'b/foo.py' match 'b/*.py'; verified Python 3.14.3 macOS"
  category: match
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/foo.py"]
  method: match
  method_args: ["b/*.py"]
  expected: true

invariant pathlib_extra243.PurePosixPath.match.a_star_py_false:
  description: "pathlib.PurePosixPath('/a/b/foo.py').match('a/*.py') == False — second-to-last component is 'b' not 'a'; verified Python 3.14.3 macOS"
  category: match
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/foo.py"]
  method: match
  method_args: ["a/*.py"]
  expected: false

invariant pathlib_extra243.PurePosixPath.match.single_component_true:
  description: "pathlib.PurePosixPath('/a/b/c').match('c') == True — single-component pattern matches last component exactly; verified Python 3.14.3 macOS"
  category: match
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: match
  method_args: ["c"]
  expected: true

invariant pathlib_extra243.PurePosixPath.match.a_b_c_no_slash_true:
  description: "pathlib.PurePosixPath('/a/b/c').match('a/b/c') == True — relative pattern with all three components matches right-anchored; verified Python 3.14.3 macOS"
  category: match
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b/c"]
  method: match
  method_args: ["a/b/c"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.PurePath.match method identity contracts
# Verify __name__ and __qualname__ of the match method.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra243.PurePath.match.name_eq:
  description: "pathlib.PurePath.match.__name__ == 'match' — method name is 'match'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: PurePath.match.__name__.__eq__
  args: ["match"]
  expected: true

invariant pathlib_extra243.PurePath.match.qualname_eq:
  description: "pathlib.PurePath.match.__qualname__ == 'PurePath.match' — qualname is 'PurePath.match', length 14; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: PurePath.match.__qualname__.__eq__
  args: ["PurePath.match"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.PurePath.match method name length spot-checks
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra243.match_identity:
  description: "pathlib.PurePath.match name and qualname length identity; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: pathlibmatch243

  columns: [id, function, args, expected]
  rows:
    - [name_len,     PurePath.match.__name__.__len__,     [], 5]
    - [qualname_len, PurePath.match.__qualname__.__len__, [], 14]
