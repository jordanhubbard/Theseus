spec: logging_extra11
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra10.zspec.zsdl."
    - "logging_extra10 covers __name__ for Logger/Handler/Formatter/StreamHandler/FileHandler/NullHandler/LogRecord/Filter as standalone invariants."
    - "logging_extra6 covers __qualname__ for Logger/Handler/Formatter/StreamHandler/FileHandler/NullHandler/getLogger."
    - "logging_extra5 covers __name__/__module__ for Logger/Handler/Formatter in a table."
    - "logging_extra4 covers __name__/__module__ for Filterer; __bases__[0].__name__ for all major classes."
    - "NOT yet covered: logging.StreamHandler.__module__ == 'logging' as a standalone invariant."
    - "NOT yet covered: logging.FileHandler.__module__ == 'logging' as a standalone invariant."
    - "NOT yet covered: logging.Filterer.__qualname__ == 'Filterer' as a standalone invariant."
    - "NOT yet covered: logging class MRO lengths as standalone invariants."
    - "StreamHandler.__module__ == 'logging' — defined in the top-level logging package."
    - "FileHandler.__module__ == 'logging' — defined in the top-level logging package."
    - "Filterer.__qualname__ == 'Filterer' — the common base for Logger and Handler."
    - "Logger.mro() has 3 entries: [Logger, Filterer, object]."
    - "Handler.mro() has 3 entries: [Handler, Filterer, object]."
    - "Formatter.mro() has 2 entries: [Formatter, object]."
    - "StreamHandler.mro() has 4 entries: [StreamHandler, Handler, Filterer, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StreamHandler.__module__ — standalone invariant
#
# logging_extra5 covers Handler.__module__ and Formatter.__module__ standalone.
# logging_extra3 covers Logger.__module__ and NullHandler.__module__ standalone.
# No prior spec records StreamHandler.__module__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant logging_extra11.StreamHandler.module:
  description: "logging.StreamHandler.__module__ == 'logging'"
  category: class_modules
  kind: python_call_eq
  function: StreamHandler.__module__.__eq__
  args: ["logging"]
  expected: true

# ---------------------------------------------------------------------------
# FileHandler.__module__ — standalone invariant
#
# No prior logging spec records FileHandler.__module__ as a standalone invariant.
# FileHandler is defined alongside StreamHandler in the logging package.
# ---------------------------------------------------------------------------

invariant logging_extra11.FileHandler.module:
  description: "logging.FileHandler.__module__ == 'logging'"
  category: class_modules
  kind: python_call_eq
  function: FileHandler.__module__.__eq__
  args: ["logging"]
  expected: true

# ---------------------------------------------------------------------------
# Filterer.__qualname__ — standalone invariant
#
# logging_extra4 covers Filterer.__name__ and Filterer.__module__ as standalone.
# No prior spec records Filterer.__qualname__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant logging_extra11.Filterer.qualname:
  description: "logging.Filterer.__qualname__ == 'Filterer'"
  category: class_qualnames
  kind: python_call_eq
  function: Filterer.__qualname__.__eq__
  args: ["Filterer"]
  expected: true

# ---------------------------------------------------------------------------
# MRO lengths — Logger, Handler, Formatter, StreamHandler
#
# No prior logging spec records the MRO length for any logging class.
# Logger and Handler both inherit from Filterer (MRO length 3).
# Formatter inherits directly from object (MRO length 2).
# StreamHandler inherits from Handler (MRO length 4).
# ---------------------------------------------------------------------------

invariant logging_extra11.Logger.mro_len:
  description: "logging.Logger.mro() has 3 entries: [Logger, Filterer, object]"
  category: mro
  kind: python_call_eq
  function: Logger.mro
  args: []
  method: __len__
  expected: 3

invariant logging_extra11.Handler.mro_len:
  description: "logging.Handler.mro() has 3 entries: [Handler, Filterer, object]"
  category: mro
  kind: python_call_eq
  function: Handler.mro
  args: []
  method: __len__
  expected: 3

invariant logging_extra11.Formatter.mro_len:
  description: "logging.Formatter.mro() has 2 entries: [Formatter, object]"
  category: mro
  kind: python_call_eq
  function: Formatter.mro
  args: []
  method: __len__
  expected: 2

invariant logging_extra11.StreamHandler.mro_len:
  description: "logging.StreamHandler.mro() has 4 entries: [StreamHandler, Handler, Filterer, object]"
  category: mro
  kind: python_call_eq
  function: StreamHandler.mro
  args: []
  method: __len__
  expected: 4

# ---------------------------------------------------------------------------
# Table: __module__ for StreamHandler and FileHandler
#
# Bundles the two new __module__ invariants as table rows for machine indexing.
# These are fresh standalone table rows not present in any prior logging spec.
# ---------------------------------------------------------------------------

table logging_extra11.handler_modules:
  description: "StreamHandler and FileHandler are defined in the 'logging' module"
  kind: python_call_eq
  category: class_modules
  id_prefix: hmod

  columns: [id, function, args, expected]
  rows:
    - [StreamHandler, StreamHandler.__module__.__eq__, ["logging"], true]
    - [FileHandler,   FileHandler.__module__.__eq__,   ["logging"], true]
