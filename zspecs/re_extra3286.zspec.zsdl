spec: re3286
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 666 (re3286): __iadd__, __isub__, __imul__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __iadd__, __isub__, __imul__ dict-presence (in-place augmented assignment)."
    - "No re class defines __iadd__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; arithmetic is not part of their protocol."
    - "No re class defines __isub__ in its own __dict__: re types are not numeric operands; in-place subtraction is not defined on any re type."
    - "No re class defines __imul__ in its own __dict__: in-place multiplication is not defined on any re type."
    - "re.RegexFlag is defined as class RegexFlag(enum.IntFlag): the in-place augmented assignment methods __iadd__, __isub__, __imul__ are not defined in re.RegexFlag.__dict__ itself; flag composition uses | not +=."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iadd__ dict-presence — operator.contains(Cls.__dict__, '__iadd__')
#
# No re class defines __iadd__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but in-place addition is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3286.iadd:
  description: "re types __iadd__ dict-presence checks; wave 666"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3286

  columns: [id, function, args, expected]
  rows:
    - ["re3286001", operator.contains, [re.Pattern.__dict__,   "__iadd__"], false]
    - ["re3286002", operator.contains, [re.Match.__dict__,     "__iadd__"], false]
    - ["re3286003", operator.contains, [re.RegexFlag.__dict__, "__iadd__"], false]

# ---------------------------------------------------------------------------
# __isub__ dict-presence — operator.contains(Cls.__dict__, '__isub__')
#
# No re class defines __isub__ in its own __dict__; all false.
# re types are not numeric operands; in-place subtraction is not part of the
