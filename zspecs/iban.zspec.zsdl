spec: iban
version: ">=0.0.14"
backend: node(iban)

docs: https://www.npmjs.com/package/iban

provenance:
  derived_from:
    - "iban README — https://www.npmjs.com/package/iban"
    - "Test vectors verified with iban via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "iban source"
  notes:
    - "iban is an npm package. Install: npm install iban"
    - "IBAN.isValid(str) validates an International Bank Account Number."
    - "IBAN.electronicFormat(str) converts a human-formatted IBAN to its compact electronic form."
    - "Test IBANs from https://www.iban.com/structure."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean or formatted string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table iban.isValid:
  kind: node_module_call_eq
  function: isValid
  category: isValid
  id_prefix: ibanv

  columns: [id, args, expected]
  rows:
    - [valid_de, ["DE44500105175407324931"], true]
    - [valid_gb, ["GB29NWBK60161331926819"], true]
    - [valid_fr, ["FR7630006000011234567890189"], true]
    - [invalid,  ["INVALID"],                false]
    - [empty,    [""],                        false]

table iban.electronicFormat:
  kind: node_module_call_eq
  function: electronicFormat
  category: electronicFormat
  id_prefix: ibanef

  columns: [id, args, expected]
  rows:
    - [de, ["DE44 5001 0517 5407 3249 31"], "DE44500105175407324931"]
    - [gb, ["GB29 NWBK 6016 1331 9268 19"], "GB29NWBK60161331926819"]
