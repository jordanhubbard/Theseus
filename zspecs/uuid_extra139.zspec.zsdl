spec: uuid_extra139
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra138.zspec.zsdl — covers uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') (all four namespace constants) / NAMESPACE_DNS.version==1 / NAMESPACE_DNS.hex.__len__()==32 / uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / uuid.UUID.__name__.__eq__('UUID') (table + invariants)."
    - "uuid_extra137.zspec.zsdl — covers uuid.UUID.__dict__.__contains__('hex'/'int'/'bytes'/'version'/__slots__/__init__) / UUID.__dict__.__class__.__name__.__eq__('mappingproxy') / uuid.__spec__.name.__eq__('uuid') / uuid.__doc__.__len__()==1948 (table + invariants)."
    - "uuid_extra136.zspec.zsdl — covers uuid.UUID.__lt__/__gt__/__le__/__ge__ comparison operator __qualname__ string equality / UUID.__int__ __qualname__.__eq__('UUID.__int__') / UUID dunder __class__.__name__ values (table + invariants)."
    - "uuid_extra135.zspec.zsdl — covers uuid.UUID property descriptor __class__.__name__ == 'property' for hex/urn/variant/version/bytes/fields / UUID.int/__class__.__name__ == 'member_descriptor' (table + invariants)."
    - "uuid_extra134.zspec.zsdl — covers uuid.UUID.__init__/__str__/__repr__/__hash__/__eq__/__lt__ __qualname__ lengths / UUID.__bases__[0].__name__=='object' (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID method qualname equality and length."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants __class__.__name__, hex values, str() values, version attributes."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__/__bases__[0].__name__=='Enum'."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra138."
    - "Wave 317 theme: uuid.UUID.__dict__ additional entry checks and __doc__ length — UUID.__dict__.__contains__('urn')==True / __dict__.__contains__('bytes_le')==True / __dict__.__contains__('node')==True / __dict__.__contains__('fields')==True / UUID.__dict__.__len__()==37 / UUID.__doc__.__len__()==2787 / uuid.SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') / uuid.__package__.__eq__('')."
    - "uuid.UUID.__dict__.__contains__('urn') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes_le') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('node') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('fields') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__len__() == 37. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__doc__.__len__() == 2787. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__dict__.__class__.__name__ == 'mappingproxy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__package__ == '' (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.__dict__ has 37 entries (verified Python 3.14.3 macOS/Darwin 25.4.0). The entries include property descriptors (hex, bytes, bytes_le, fields, urn, variant, version, node, time, clock_seq, clock_seq_hi_variant, clock_seq_low, time_hi_version, time_low, time_mid), the int member_descriptor slot, the is_safe slot, __slots__, all dunder methods (__init__, __str__, __repr__, __hash__, __eq__, __lt__, __gt__, __le__, __ge__, __int__, __setattr__, __getstate__, __setstate__, __weakref__, _from_int), and various metadata attributes."
    - "Note: uuid.UUID.__doc__.__len__() == 2787. At 2787 chars the UUID class docstring is the longest class docstring in the stdlib module series covered so far, substantially longer than struct.Struct.__doc__ (40 chars). The UUID docstring documents the UUID class attributes, constructor arguments, and the various property views."
    - "Note: uuid.SafeUUID.__dict__.__class__.__name__ == 'mappingproxy'. Like uuid.UUID.__dict__, SafeUUID.__dict__ is also a mappingproxy. SafeUUID is an IntEnum subclass with 19 entries in its __dict__ (including _member_names_, _value2member_map_, safe, unsafe, unknown, and enum infrastructure attributes)."
    - "Note: uuid.__package__ == '' (empty string). This is the standard __package__ value for top-level stdlib modules. It matches hashlib.__package__/struct.__package__/socket.__package__ (all ''), confirming uuid is a top-level module not in a sub-package."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('urn')
# uuid.UUID.__dict__.__contains__('bytes_le')
# uuid.UUID.__dict__.__contains__('node')
# uuid.UUID.__dict__.__contains__('fields')
#
# Wave 317 theme: uuid.UUID class __dict__ contains additional property attribute names.
#
# The UUID class __dict__ contains all property descriptors for the various UUID
# representations and sub-fields. urn (the URN string form), bytes_le (little-endian
# bytes form), node (the 48-bit MAC address component), and fields (the named fields
# tuple) are all present as direct class attributes. extra137 anchors hex/int/bytes/
# version; no prior uuid spec anchors urn/bytes_le/node/fields as a table under uuiddoc139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra139.UUID_dict_contains_additional_properties:
  description: "uuid.UUID.__dict__.__contains__('urn')==True / __dict__.__contains__('bytes_le')==True / __dict__.__contains__('node')==True / __dict__.__contains__('fields')==True — all four are property descriptors in the UUID class namespace; urn returns the URN string form; bytes_le is the little-endian 16-byte form; node is the 48-bit MAC address component; fields is the named fields tuple; extra137 anchors hex/int/bytes/version; first uuiddoc139 anchor for urn/bytes_le/node/fields"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddoc139

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_urn,      UUID.__dict__.__contains__, ["urn"],      true, "uuid.UUID.__dict__.__contains__('urn') == True (property returning 'urn:uuid:<UUID-string>' format)"]
    - [dict_contains_bytes_le, UUID.__dict__.__contains__, ["bytes_le"], true, "uuid.UUID.__dict__.__contains__('bytes_le') == True (property returning 16-byte little-endian form)"]
    - [dict_contains_node,     UUID.__dict__.__contains__, ["node"],     true, "uuid.UUID.__dict__.__contains__('node') == True (property returning 48-bit MAC address component)"]
    - [dict_contains_fields,   UUID.__dict__.__contains__, ["fields"],   true, "uuid.UUID.__dict__.__contains__('fields') == True (property returning named UUID fields as a tuple)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__len__()==37
# uuid.UUID.__doc__.__len__()==2787
# uuid.SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy')
# uuid.__package__.__eq__('')
#
# Wave 317 theme: UUID dict length, UUID doc length, SafeUUID dict type, and module package.
#
# UUID.__dict__ has 37 entries (all properties, slots, dunders, and metadata).
# UUID.__doc__ is 2787 chars — the longest class docstring in the stdlib series.
# SafeUUID.__dict__.__class__.__name__ is 'mappingproxy' (12 chars) — same type as
# UUID.__dict__. uuid.__package__ is '' (empty string). No prior uuid spec anchors
# these together as a table under uuiddoc139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra139.UUID_dict_len_doc_len_and_package:
  description: "uuid.UUID.__dict__.__len__()==37 / UUID.__doc__.__len__()==2787 / SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy')==True / uuid.__package__.__eq__('')==True — __dict__ has 37 entries (properties, slots, dunders, metadata); __doc__ is 2787 chars (longest class docstring in the stdlib series); SafeUUID.__dict__ is also a mappingproxy; __package__ is '' (top-level module); no prior uuid spec anchors these under uuiddoc139"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddoc139

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_dict_len_37,       UUID.__dict__.__len__,                      [],              37,   "uuid.UUID.__dict__.__len__() is 37 (all property descriptors, slots, dunders, and metadata)"]
    - [UUID_doc_len_2787,      UUID.__doc__.__len__,                       [],              2787, "uuid.UUID.__doc__.__len__() is 2787 (longest class docstring in the stdlib module series)"]
    - [SafeUUID_dict_mapping,  SafeUUID.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "uuid.SafeUUID.__dict__.__class__.__name__ == 'mappingproxy' (same type as UUID.__dict__)"]
    - [pkg_empty,              __package__.__eq__,                         [""],             true, "uuid.__package__ == '' (empty string; standard __package__ for top-level stdlib modules)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__str__')
# uuid.UUID.__dict__.__contains__('__repr__')
# uuid.UUID.__dict__.__contains__('__hash__')
# uuid.UUID.__dict__.__contains__('variant')
#
# Wave 317 theme: uuid.UUID class __dict__ contains dunder methods and variant property.
#
# __str__, __repr__, and __hash__ are direct class attributes of UUID (not inherited
# from object in the usual sense; UUID defines its own implementations). 'variant' is
# a property descriptor returning the UUID variant (RFC_4122, RESERVED_NCS, etc.).
# extra136 anchors UUID.__eq__/__lt__/__gt__ qualnames; no prior uuid spec anchors
# __dict__.__contains__('__str__'/'__repr__'/'__hash__'/'variant') as a table under
# uuiddoc139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra139.UUID_dict_contains_dunder_and_variant:
  description: "uuid.UUID.__dict__.__contains__('__str__')==True / __dict__.__contains__('__repr__')==True / __dict__.__contains__('__hash__')==True / __dict__.__contains__('variant')==True — __str__/__repr__/__hash__ are UUID-specific implementations; 'variant' is a property descriptor returning the UUID variant (RFC_4122/RESERVED_NCS/RESERVED_MICROSOFT/RESERVED_FUTURE); extra136 anchors __eq__/__lt__ qualnames; first uuiddoc139 anchor for __str__/__repr__/__hash__/variant __dict__ membership"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddoc139

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_str,     UUID.__dict__.__contains__, ["__str__"],  true, "uuid.UUID.__dict__.__contains__('__str__') == True (UUID.__str__ returns the canonical hyphenated UUID string)"]
    - [dict_contains_repr,    UUID.__dict__.__contains__, ["__repr__"], true, "uuid.UUID.__dict__.__contains__('__repr__') == True (UUID.__repr__ wraps __str__ in UUID string form)"]
    - [dict_contains_hash,    UUID.__dict__.__contains__, ["__hash__"], true, "uuid.UUID.__dict__.__contains__('__hash__') == True (UUID defines its own __hash__ based on the int value)"]
    - [dict_contains_variant, UUID.__dict__.__contains__, ["variant"],  true, "uuid.UUID.__dict__.__contains__('variant') == True (property returning the UUID variant enum value)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('urn') — standalone
#
# uuid.UUID.__dict__.__contains__('urn') is True. The 'urn' attribute is a property
# descriptor that returns the UUID as a URN string in the format
# 'urn:uuid:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'. The URN (Uniform Resource Name)
# representation is defined in RFC 4122 and adds the 'urn:uuid:' prefix (9 chars)
# to the canonical hyphenated UUID string (36 chars), giving a total URN length of
# 45 chars. extra97 anchors UUID.urn as a property descriptor (fget qualname 'UUID.urn',
# 8 chars); no prior uuid spec anchors UUID.__dict__.__contains__('urn') as a
# standalone under uuiddoc139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra139.UUID_dict_contains_urn:
  description: "uuid.UUID.__dict__.__contains__('urn') == True — 'urn' property descriptor returns 'urn:uuid:<hyphenated-UUID>' (45 chars total = 9-char prefix + 36-char canonical form); RFC 4122 URN representation; extra97 anchors fget qualname 'UUID.urn' (8 chars); no prior uuid spec anchors this as a standalone; first standalone under uuiddoc139"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["urn"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('node') — standalone
#
# uuid.UUID.__dict__.__contains__('node') is True. The 'node' attribute is a property
# descriptor that returns the 48-bit hardware address (MAC address) component of
# the UUID. For version 1 UUIDs (time-based), the node field encodes the MAC address
# of the machine that generated the UUID. The 48-bit node can be read as
# (uuid_int >> 0) & 0xffffffffffff. extra97 anchors node property fget qualname
# 'UUID.node' (9 chars); no prior uuid spec anchors UUID.__dict__.__contains__('node')
# as a standalone under uuiddoc139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra139.UUID_dict_contains_node:
  description: "uuid.UUID.__dict__.__contains__('node') == True — 'node' property descriptor returns the 48-bit MAC address component of the UUID; relevant for version 1 (time-based) UUIDs; extra97 anchors fget qualname 'UUID.node' (9 chars); no prior uuid spec anchors this as a standalone; first standalone under uuiddoc139"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["node"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__len__()==37 — standalone
#
# uuid.UUID.__dict__.__len__() is 37. The 37 entries include: 15 property descriptors
# (hex, bytes, bytes_le, fields, urn, variant, version, node, time, clock_seq,
# clock_seq_hi_variant, clock_seq_low, time_hi_version, time_low, time_mid), 2 slot
# descriptors (int, is_safe), 14 dunder methods (__init__, __str__, __repr__, __hash__,
# __eq__, __lt__, __gt__, __le__, __ge__, __int__, __setattr__, __getstate__, __setstate__,
# __weakref__), __slots__, _from_int, and several metadata attributes (__doc__, __module__,
# __firstlineno__, __static_attributes__). No prior uuid spec anchors
# UUID.__dict__.__len__()==37 as a standalone under uuiddoc139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra139.UUID_dict_len_37:
  description: "uuid.UUID.__dict__.__len__() == 37 — 37 entries: 15 property descriptors + 2 slot descriptors (int, is_safe) + 14 dunders + __slots__ + _from_int + metadata (__doc__, __module__, etc.); UUID has a richer class dict than struct.Struct (16 entries) or socket.socket (28 entries); no prior uuid spec anchors this as a standalone; first standalone under uuiddoc139"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__len__
  args: []
  expected: 37

# ---------------------------------------------------------------------------
# uuid.UUID.__doc__.__len__()==2787 — standalone
#
# uuid.UUID.__doc__.__len__() is 2787. At 2787 chars the UUID class docstring is the
# longest class docstring examined in the stdlib module series: struct.Struct.__doc__
# (40 chars) << socket.socket.__doc__ (58 chars) << uuid.UUID.__doc__ (2787 chars).
# The UUID docstring documents the class constructor arguments (hex, bytes, bytes_le,
# fields, int, version, is_safe), the string representations, the is_safe attribute,
# and the various property attributes. No prior uuid spec anchors
# UUID.__doc__.__len__()==2787 as a standalone under uuiddoc139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra139.UUID_doc_len_2787:
  description: "uuid.UUID.__doc__.__len__() == 2787 — 2787-char class docstring documents constructor args (hex/bytes/bytes_le/fields/int/version/is_safe) and properties; longest class docstring in the stdlib series: Struct(40) << socket(58) << UUID(2787); no prior uuid spec anchors this as a standalone; first standalone under uuiddoc139"
  category: doc_lengths
  kind: python_call_eq
  function: UUID.__doc__.__len__
  args: []
  expected: 2787

# ---------------------------------------------------------------------------
# uuid.__package__.__eq__('') — standalone
#
# uuid.__package__ is '' (empty string). An empty-string __package__ is the standard
# value for top-level stdlib modules not contained in a sub-package. This is consistent
# across all four modules covered by this spec series: uuid (''), hashlib (''),
# struct (''), and socket ('') all have empty-string __package__. The empty string
# distinguishes top-level modules from sub-packages (e.g., email.mime would have
# __package__ == 'email.mime'). No prior uuid spec anchors uuid.__package__ == ''
# as a standalone under uuiddoc139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra139.package_empty:
  description: "uuid.__package__.__eq__('') == True — empty string; standard __package__ for top-level stdlib modules; matches hashlib/struct/socket (all ''); contrasts with sub-packages that have non-empty __package__; no prior uuid spec anchors this as a standalone; first standalone under uuiddoc139"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true
