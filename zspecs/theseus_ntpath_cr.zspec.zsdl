spec: theseus_ntpath_cr
version: ">=3.0"
backend: python_cleanroom(theseus_ntpath_cr)
blocks: ntpath

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/os.path.html"
  not_derived_from:
    - "CPython source: Lib/ntpath.py"
  notes:
    - "Clean-room ntpath module. Do NOT import ntpath."

error_model: python_exceptions

invariant theseus_ntpath_cr.ntpath2_split:
  description: "split() splits path into (head, tail)"
  category: behavior
  kind: python_call_eq
  function: ntpath2_split
  args: []
  expected: true

invariant theseus_ntpath_cr.ntpath2_join:
  description: "join() joins path components"
  category: behavior
  kind: python_call_eq
  function: ntpath2_join
  args: []
  expected: true

invariant theseus_ntpath_cr.ntpath2_normpath:
  description: "normpath() normalizes a Windows path"
  category: behavior
  kind: python_call_eq
  function: ntpath2_normpath
  args: []
  expected: true
