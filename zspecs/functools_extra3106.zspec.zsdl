spec: ft3106
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (ft3106): __lt__, __le__, __gt__ dict-presence checks for functools types."
    - "None of the four functools types define __lt__, __le__, or __gt__ in their own __dict__."
    - "functools.partial, functools.partialmethod, functools.cached_property, and functools._lru_cache_wrapper do not define ordering operators; comparisons fall back to object defaults (NotImplemented / TypeError)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3106.lt:
  description: "functools types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft3106
  columns: [id, function, args, expected]
  rows:
    - ["ft3106001", operator.contains, [functools.partial.__dict__,            "__lt__"], false]
    - ["ft3106002", operator.contains, [functools.partialmethod.__dict__,      "__lt__"], false]
    - ["ft3106003", operator.contains, [functools.cached_property.__dict__,    "__lt__"], false]
    - ["ft3106004", operator.contains, [functools._lru_cache_wrapper.__dict__, "__lt__"], false]

