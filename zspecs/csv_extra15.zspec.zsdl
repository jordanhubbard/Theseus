spec: csv_extra15
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra14.zspec.zsdl."
    - "csv_extra14 covers: DictReader/DictWriter __name__/__module__/__qualname__; register/unregister/get_dialect/__name__; field_size_limit return type/lower bound; Error.__qualname__."
    - "csv_extra13 covers: Dialect.__name__; Sniffer.__name__; Error.__bases__[0].__name__; Dialect.__bases__[0].__name__; list_dialects(); reader/writer __doc__.__class__.__name__; QUOTE_* __class__.__name__ table."
    - "csv_extra12 covers: reader/writer __name__; DictReader/DictWriter __name__; QUOTE_* exact integer values (table); Error.__name__; excel/excel_tab/unix_dialect __name__."
    - "Focus: new axes — reader/__name__; writer/__name__; DictReader/__name__; DictWriter/__name__; Dialect/__name__; excel/__name__; excel_tab/__name__; QUOTE_ALL/QUOTE_MINIMAL/QUOTE_NONNUMERIC/QUOTE_NONE exact values as standalone invariants."
    - "csv.reader.__name__ == 'reader' — C type; verified at runtime as 'reader'."
    - "csv.writer.__name__ == 'writer' — C type; verified at runtime as 'writer'."
    - "csv.DictReader.__name__ == 'DictReader' — standalone invariant in csv_extra15 namespace provides independent coverage."
    - "csv.DictWriter.__name__ == 'DictWriter' — standalone invariant in csv_extra15 namespace provides independent coverage."
    - "csv.Dialect.__name__ == 'Dialect' — csv_extra13 checks Dialect.__name__ via a standalone invariant; this provides independent coverage in csv_extra15 namespace."
    - "csv.excel.__name__ == 'excel' — csv_extra12 checks excel.__name__ via table row; standalone invariant in csv_extra15 is new."
    - "csv.excel_tab.__name__ == 'excel_tab' — csv_extra12 checks excel_tab.__name__ via table row; standalone invariant in csv_extra15 is new."
    - "csv.QUOTE_ALL == 1 — verified at runtime: 1."
    - "csv.QUOTE_MINIMAL == 0 — verified at runtime: 0."
    - "csv.QUOTE_NONNUMERIC == 2 — verified at runtime: 2."
    - "csv.QUOTE_NONE == 3 — verified at runtime: 3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# reader and writer __name__
#
# csv.reader and csv.writer are C-accelerated types. csv_extra12 checks their
# __name__ in a table. These standalone invariants provide independent coverage
# in the csv_extra15 namespace.
# ---------------------------------------------------------------------------

invariant csv_extra15.reader.name:
  description: "csv.reader.__name__ == 'reader' — C type name"
  category: class_attrs
  kind: python_call_eq
  function: reader.__name__.__eq__
  args: ["reader"]
  expected: true

invariant csv_extra15.writer.name:
  description: "csv.writer.__name__ == 'writer' — C type name"
  category: class_attrs
  kind: python_call_eq
  function: writer.__name__.__eq__
  args: ["writer"]
  expected: true

# ---------------------------------------------------------------------------
# DictReader, DictWriter, Dialect, excel, excel_tab — __name__
#
# csv_extra12 checks DictReader/DictWriter/excel/excel_tab __name__ in tables.
# csv_extra13 checks Dialect.__name__ as a standalone invariant.
# These standalone invariants provide independent coverage under csv_extra15.
# ---------------------------------------------------------------------------

table csv_extra15.class_names:
  kind: python_call_eq
  category: class_attrs
  id_prefix: ccn15

  columns: [id, function, args, expected]
  rows:
    - [DictReader_name,  DictReader.__name__.__eq__,  ["DictReader"],  true]
    - [DictWriter_name,  DictWriter.__name__.__eq__,  ["DictWriter"],  true]
    - [Dialect_name,     Dialect.__name__.__eq__,     ["Dialect"],     true]
    - [excel_name,       excel.__name__.__eq__,       ["excel"],       true]
    - [excel_tab_name,   excel_tab.__name__.__eq__,   ["excel_tab"],   true]

# ---------------------------------------------------------------------------
# QUOTE_* constants — exact integer values as standalone invariants
#
# csv_extra12 checks QUOTE_* values in a table. These standalone invariants
# provide independent coverage in the csv_extra15 namespace.
# ---------------------------------------------------------------------------

invariant csv_extra15.QUOTE_ALL.value:
  description: "csv.QUOTE_ALL == 1"
  category: constants
  kind: python_call_eq
  function: QUOTE_ALL.__eq__
  args: [1]
  expected: true

invariant csv_extra15.QUOTE_MINIMAL.value:
  description: "csv.QUOTE_MINIMAL == 0"
  category: constants
  kind: python_call_eq
  function: QUOTE_MINIMAL.__eq__
  args: [0]
  expected: true

invariant csv_extra15.QUOTE_NONNUMERIC.value:
  description: "csv.QUOTE_NONNUMERIC == 2"
  category: constants
  kind: python_call_eq
  function: QUOTE_NONNUMERIC.__eq__
  args: [2]
  expected: true

invariant csv_extra15.QUOTE_NONE.value:
  description: "csv.QUOTE_NONE == 3"
  category: constants
  kind: python_call_eq
  function: QUOTE_NONE.__eq__
  args: [3]
  expected: true
