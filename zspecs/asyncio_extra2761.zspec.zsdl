    - ["as2761mx_f_mm",  Future.__dict__.__contains__,    ["__matmul__"],  false]
    - ["as2761mx_f_td",  Future.__dict__.__contains__,    ["__truediv__"], false]
    - ["as2761mx_f_ia",  Future.__dict__.__contains__,    ["__iadd__"],    false]
    - ["as2761mx_l_mm",  Lock.__dict__.__contains__,      ["__matmul__"],  false]
    - ["as2761mx_l_td",  Lock.__dict__.__contains__,      ["__truediv__"], false]
    - ["as2761mx_l_ia",  Lock.__dict__.__contains__,      ["__iadd__"],    false]
    - ["as2761mx_e_mm",  Event.__dict__.__contains__,     ["__matmul__"],  false]
    - ["as2761mx_e_td",  Event.__dict__.__contains__,     ["__truediv__"], false]
