spec: asyncio_extra2761
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronisation primitives documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio task and future documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "asyncio_extra.zspec.zsdl — covers __name__ and __module__ checks for Queue, Task, Future, Lock, Event, Semaphore, Condition"
    - "asyncio_extra2.zspec.zsdl — covers module checks for event loop classes and exception classes"
  notes:
    - "Wave 631 theme: __matmul__, __truediv__, and __iadd__ dict-presence checks."
    - "None of the asyncio synchronisation or task primitives define __matmul__, __truediv__, or __iadd__ in their __dict__."
    - "Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier are async coordination primitives, not numeric types."
    - "asyncio.Barrier was added in Python 3.11; version constraint >=3.9 applies to all other types; Barrier rows are omitted from version-gated invariants."
    - "All eight types checked: Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue, asyncio.Task, asyncio.Future — __matmul__/__truediv__/__iadd__
# dict-presence checks
#
# Queue is an async FIFO queue; Task wraps a coroutine; Future is a low-level
# awaitable. None of them define arithmetic operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2761.queue_task_future_operator_dict:
  description: "asyncio.Queue, Task, Future __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2761qtf

  columns: [id, function, args, expected]
  rows:
    - ["as2761qtf_q_matmul",  Queue.__dict__.__contains__,  ["__matmul__"],  false]
    - ["as2761qtf_q_truediv", Queue.__dict__.__contains__,  ["__truediv__"], false]
    - ["as2761qtf_q_iadd",    Queue.__dict__.__contains__,  ["__iadd__"],    false]
    - ["as2761qtf_t_matmul",  Task.__dict__.__contains__,   ["__matmul__"],  false]
    - ["as2761qtf_t_truediv", Task.__dict__.__contains__,   ["__truediv__"], false]
    - ["as2761qtf_t_iadd",    Task.__dict__.__contains__,   ["__iadd__"],    false]
    - ["as2761qtf_f_matmul",  Future.__dict__.__contains__,  ["__matmul__"],  false]
    - ["as2761qtf_f_truediv", Future.__dict__.__contains__,  ["__truediv__"], false]
    - ["as2761qtf_f_iadd",    Future.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# asyncio.Lock, asyncio.Event, asyncio.Semaphore — __matmul__/__truediv__/__iadd__
# dict-presence checks
#
# Lock, Event, and Semaphore are async synchronisation primitives defined in
# asyncio.locks. They do not implement arithmetic dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2761.lock_event_semaphore_operator_dict:
  description: "asyncio.Lock, Event, Semaphore __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2761les

  columns: [id, function, args, expected]
  rows:
    - ["as2761les_l_matmul",  Lock.__dict__.__contains__,      ["__matmul__"],  false]
    - ["as2761les_l_truediv", Lock.__dict__.__contains__,      ["__truediv__"], false]
    - ["as2761les_l_iadd",    Lock.__dict__.__contains__,      ["__iadd__"],    false]
    - ["as2761les_e_matmul",  Event.__dict__.__contains__,     ["__matmul__"],  false]
    - ["as2761les_e_truediv", Event.__dict__.__contains__,     ["__truediv__"], false]
    - ["as2761les_e_iadd",    Event.__dict__.__contains__,     ["__iadd__"],    false]
    - ["as2761les_s_matmul",  Semaphore.__dict__.__contains__,  ["__matmul__"],  false]
    - ["as2761les_s_truediv", Semaphore.__dict__.__contains__,  ["__truediv__"], false]
    - ["as2761les_s_iadd",    Semaphore.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# asyncio.Condition and asyncio.Barrier — __matmul__/__truediv__/__iadd__
# dict-presence checks
#
# Condition is a combination lock/condition variable. Barrier (added in 3.11)
# is a synchronisation barrier. Neither defines numeric operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2761.condition_barrier_operator_dict:
  description: "asyncio.Condition and Barrier __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: as2761cb

  columns: [id, function, args, expected]
  rows:
    - ["as2761cb_c_matmul",  Condition.__dict__.__contains__, ["__matmul__"],  false]
    - ["as2761cb_c_truediv", Condition.__dict__.__contains__, ["__truediv__"], false]
    - ["as2761cb_c_iadd",    Condition.__dict__.__contains__, ["__iadd__"],    false]
    - ["as2761cb_b_matmul",  Barrier.__dict__.__contains__,   ["__matmul__"],  false]
    - ["as2761cb_b_truediv", Barrier.__dict__.__contains__,   ["__truediv__"], false]
    - ["as2761cb_b_iadd",    Barrier.__dict__.__contains__,   ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Full 8×3 cross-type matrix — all asyncio types, all three operator dunders
#
# Consolidates the full 8×3 dict-presence check in one table.
# Every cell is False: Queue, Task, Future, Lock, Event, Semaphore, Condition,
# and Barrier do not define @, /, or += operator dunders.
# ---------------------------------------------------------------------------

table asyncio_extra2761.all_types_matmul_truediv_iadd_matrix:
  description: "Full 8×3 dict-presence matrix for asyncio types vs __matmul__/__truediv__/__iadd__ — all 24 results are False; verified with Python 3.14.4"
