    - ["as2761mx_s_ia",  Semaphore.__dict__.__contains__,  ["__iadd__"],    false]
    - ["as2761mx_c_mm",  Condition.__dict__.__contains__,  ["__matmul__"],  false]
    - ["as2761mx_c_td",  Condition.__dict__.__contains__,  ["__truediv__"], false]
    - ["as2761mx_c_ia",  Condition.__dict__.__contains__,  ["__iadd__"],    false]
