spec: in3211
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 661 (in3211): __and__, __or__, __xor__ dict-presence checks for inspect types."
    - "Theme: __and__, __or__, __xor__ dict-presence (bitwise logical operators)."
    - "All values False — these types have no bitwise logical protocol."
    - "No inspect type defines __and__, __or__, or __xor__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement bitwise logical protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3211.and_:
  description: "inspect types __and__ dict-presence checks; wave 661"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3211
  columns: [id, function, args, expected]
  rows:
    - ["in3211001", operator.contains, [inspect.Parameter.__dict__,           "__and__"], false]
    - ["in3211002", operator.contains, [inspect.Signature.__dict__,           "__and__"], false]
    - ["in3211003", operator.contains, [inspect.BoundArguments.__dict__,      "__and__"], false]
    - ["in3211004", operator.contains, [inspect.FrameInfo.__dict__,           "__and__"], false]
    - ["in3211005", operator.contains, [inspect.ArgInfo.__dict__,             "__and__"], false]
    - ["in3211006", operator.contains, [inspect.FullArgSpec.__dict__,         "__and__"], false]
    - ["in3211007", operator.contains, [inspect.Attribute.__dict__,           "__and__"], false]
    - ["in3211008", operator.contains, [inspect.ClassFoundException.__dict__, "__and__"], false]
    - ["in3211009", operator.contains, [inspect.EndOfBlock.__dict__,          "__and__"], false]

