spec: uuid_extra91
version: ">=3.9"
backend: python_module(uuid)
extends: uuid_extra90

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra90.zspec.zsdl — covers NAMESPACE_URL/OID/X500 __class__.__name__=='UUID' / NAMESPACE_* version==1 / RFC_4122/RESERVED_* __class__.__name__=='str' and __len__() / UUID.__class__.__name__=='type' (table + invariants)."
    - "uuid_extra89.zspec.zsdl — covers UUID dunder method __module__/__qualname__ equality / UUID property fget details / uuid5/__module__ / getnode/__code__ (table + invariants)."
    - "uuid_extra88.zspec.zsdl — covers UUID.__init__/__str__/__repr__ class names / NAMESPACE_DNS class name / UUID property fget class names (table + invariants)."
    - "uuid_extra87.zspec.zsdl — covers UUID.__setattr__/__delattr__ class names / UUID field property fget details (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode qualname/module/co_argcount (table + invariants)."
    - "uuid_extra84.zspec.zsdl — covers uuid.UUID/__name__/__module__/__qualname__/__class__.__name__ / UUID/__bases__/__mro__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra90; it does NOT duplicate invariants present in those files."
    - "Wave 262 theme: uuid.UUID class method __qualname__.__len__() values — __init__/__str__/__repr__/__eq__/__hash__/__lt__/__int__ __qualname__ lengths / uuid1/uuid4 __qualname__ lengths."
    - "uuid.UUID.__init__.__qualname__.__len__() == 13 ('UUID.__init__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__.__len__() == 12 ('UUID.__str__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__.__len__() == 13 ('UUID.__repr__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__.__len__() == 11 ('UUID.__eq__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__.__len__() == 13 ('UUID.__hash__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__qualname__.__len__() == 11 ('UUID.__lt__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__qualname__.__len__() == 12 ('UUID.__int__'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__qualname__.__len__() == 5 ('uuid1'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__qualname__.__len__() == 5 ('uuid4'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID dunder methods follow the pattern 'UUID.<dunder>' where 'UUID.' is 5 chars, giving total lengths of 11-13 depending on the dunder name."
    - "Note: uuid1/uuid4 are module-level functions with simple __qualname__ equal to their name (5 chars each)."
    - "Note: UUID.__str__ and UUID.__int__ both have 12-char qualnames: 'UUID.__str__' and 'UUID.__int__'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__len__()==13
# uuid.UUID.__str__.__qualname__.__len__()==12
# uuid.UUID.__repr__.__qualname__.__len__()==13
# uuid.UUID.__eq__.__qualname__.__len__()==11
# uuid.UUID.__hash__.__qualname__.__len__()==13
#
# Wave 262 theme: UUID special method __qualname__.__len__() — core dunders.
#
# UUID dunder methods follow the pattern 'UUID.<dunder>' where 'UUID.' is 5 chars.
# __init__ ('UUID.__init__', 5+8=13), __str__ ('UUID.__str__', 5+7=12),
# __repr__ ('UUID.__repr__', 5+8=13), __eq__ ('UUID.__eq__', 5+6=11),
# __hash__ ('UUID.__hash__', 5+8=13). Prior specs (extra86/extra88/extra89)
# anchor __qualname__.__eq__; this table first anchors __qualname__.__len__()
# for core dunders under uuidqlen91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra91.uuid_UUID_core_dunder_qualname_lengths:
  description: "uuid.UUID.__init__/__qualname__/__len__()==13 / __str__/__qualname__/__len__()==12 / __repr__/__qualname__/__len__()==13 / __eq__/__qualname__/__len__()==11 / __hash__/__qualname__/__len__()==13 — all follow 'UUID.<dunder>' pattern where 'UUID.' is 5 chars; __init__/repr__/hash__ share 13, __str__ is 12, __eq__ is 11; extra86/extra88/extra89 anchor qualname equality; first uuidqlen91 anchor for UUID core dunder qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidqlen91

  columns: [id, function, args, expected, description]
  rows:
    - [init_qlen,   "UUID.__init__.__qualname__.__len__",   [], 13, "'UUID.__init__' is 5 + 8 = 13 chars"]
    - [str_qlen,    "UUID.__str__.__qualname__.__len__",    [], 12, "'UUID.__str__' is 5 + 7 = 12 chars"]
    - [repr_qlen,   "UUID.__repr__.__qualname__.__len__",   [], 13, "'UUID.__repr__' is 5 + 8 = 13 chars"]
    - [eq_qlen,     "UUID.__eq__.__qualname__.__len__",     [], 11, "'UUID.__eq__' is 5 + 6 = 11 chars"]
    - [hash_qlen,   "UUID.__hash__.__qualname__.__len__",   [], 13, "'UUID.__hash__' is 5 + 8 = 13 chars"]

# ---------------------------------------------------------------------------
# uuid.UUID.__lt__.__qualname__.__len__()==11
# uuid.UUID.__int__.__qualname__.__len__()==12
# uuid.uuid1.__qualname__.__len__()==5
# uuid.uuid4.__qualname__.__len__()==5
#
# Wave 262 theme: UUID comparison/conversion method and module-level function qualname lengths.
#
# __lt__ ('UUID.__lt__', 5+6=11), __int__ ('UUID.__int__', 5+7=12).
# Module-level functions uuid1 and uuid4 have simple __qualname__ equal to their
# name (5 chars each), with no class prefix. Prior specs anchor these function
# __qualname__.__eq__; this table first anchors __qualname__.__len__() values
# under uuidqlen91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra91.uuid_lt_int_uuid1_uuid4_qualname_lengths:
  description: "uuid.UUID.__lt__/__qualname__/__len__()==11 / UUID.__int__/__qualname__/__len__()==12 / uuid1/__qualname__/__len__()==5 / uuid4/__qualname__/__len__()==5 — __lt__ is 'UUID.__lt__' (11), __int__ is 'UUID.__int__' (12); uuid1/uuid4 are module-level functions with simple qualname (5 chars each, no class prefix); prior specs anchor qualname equality; first uuidqlen91 anchor"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidqlen91

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qlen,    "UUID.__lt__.__qualname__.__len__",  [], 11, "'UUID.__lt__' is 5 + 6 = 11 chars"]
    - [int_qlen,   "UUID.__int__.__qualname__.__len__", [], 12, "'UUID.__int__' is 5 + 7 = 12 chars"]
    - [uuid1_qlen, uuid1.__qualname__.__len__,         [], 5,  "'uuid1' is 5 chars, simple module-level function name"]
    - [uuid4_qlen, uuid4.__qualname__.__len__,         [], 5,  "'uuid4' is 5 chars, simple module-level function name"]

# ---------------------------------------------------------------------------
# qualname equality cross-checks for new ids
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__')
# uuid.UUID.__eq__.__qualname__.__eq__('UUID.__eq__')
# uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__')
# uuid.UUID.__lt__.__qualname__.__eq__('UUID.__lt__')
# uuid.UUID.__int__.__qualname__.__eq__('UUID.__int__')
# uuid.uuid1.__qualname__.__eq__('uuid1')
# uuid.uuid4.__qualname__.__eq__('uuid4')
#
# Wave 262 supplemental: qualname equality anchors for new uuidqlen91 ids.
#
# These equality anchors cross-check the qualname strings corresponding to
# the length anchors above. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra91.uuid_dunder_qualname_equality:
  description: "uuid.UUID.__init__/__qualname__/__eq__('UUID.__init__')==True / __eq__/__qualname__/__eq__('UUID.__eq__')==True / __hash__/__qualname__/__eq__('UUID.__hash__')==True / __lt__/__qualname__/__eq__('UUID.__lt__')==True / __int__/__qualname__/__eq__('UUID.__int__')==True / uuid1/__qualname__/__eq__('uuid1')==True / uuid4/__qualname__/__eq__('uuid4')==True — equality anchors cross-checking the qualname strings for the length anchors in this spec; first uuidqlen91 equality anchor for these ids"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: uuidqlen91

  columns: [id, function, args, expected, description]
  rows:
    - [init_qeq,  "UUID.__init__.__qualname__.__eq__",  ["UUID.__init__"],  true, "UUID.__init__.__qualname__ is 'UUID.__init__'"]
    - [eq_qeq,    "UUID.__eq__.__qualname__.__eq__",    ["UUID.__eq__"],    true, "UUID.__eq__.__qualname__ is 'UUID.__eq__'"]
    - [hash_qeq,  "UUID.__hash__.__qualname__.__eq__",  ["UUID.__hash__"],  true, "UUID.__hash__.__qualname__ is 'UUID.__hash__'"]
    - [lt_qeq,    "UUID.__lt__.__qualname__.__eq__",    ["UUID.__lt__"],    true, "UUID.__lt__.__qualname__ is 'UUID.__lt__'"]
    - [int_qeq,   "UUID.__int__.__qualname__.__eq__",   ["UUID.__int__"],   true, "UUID.__int__.__qualname__ is 'UUID.__int__'"]
    - [uuid1_qeq, uuid1.__qualname__.__eq__,            ["uuid1"],          true, "uuid1.__qualname__ is 'uuid1', simple function name"]
    - [uuid4_qeq, uuid4.__qualname__.__eq__,            ["uuid4"],          true, "uuid4.__qualname__ is 'uuid4', simple function name"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__len__()==13 — standalone
#
# uuid.UUID.__init__.__qualname__.__len__() is 13. UUID.__init__.__qualname__
# is 'UUID.__init__': 'UUID.' (5 chars) + '__init__' (8 chars) = 13. UUID.__init__
# is a pure-Python function defined in Lib/uuid.py that accepts optional arguments
# for constructing a UUID from hex string, bytes, fields, or integer. Extra86/extra88
# anchor its __qualname__.__eq__ and __class__.__name__; no prior spec anchors
# UUID.__init__.__qualname__.__len__()==13 as a standalone under uuidqlen91.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra91.uuid_init_qualname_len_13:
  description: "uuid.UUID.__init__.__qualname__.__len__() == 13 — UUID.__init__.__qualname__ is 'UUID.__init__': 'UUID.' (5) + '__init__' (8) = 13; UUID.__init__ is a pure-Python function accepting hex/bytes/fields/int arguments; extra86/extra88 anchor __qualname__.__eq__ and __class__.__name__; first standalone for UUID.__init__.__qualname__.__len__() under uuidqlen91"
  category: qualname_lengths
  kind: python_call_eq
  function: "UUID.__init__.__qualname__.__len__"
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__qualname__.__len__()==11 — standalone
#
# uuid.UUID.__eq__.__qualname__.__len__() is 11. UUID.__eq__.__qualname__ is
# 'UUID.__eq__': 'UUID.' (5 chars) + '__eq__' (6 chars) = 11. This is the
# shortest dunder qualname in the UUID class (tied with __lt__), because
# '__eq__' has only 6 chars. UUID.__eq__ enables value-equality comparison
# of two UUID objects based on their integer representation. Extra89 anchors
# its __module__; no prior spec anchors UUID.__eq__.__qualname__.__len__()==11
# as a standalone under uuidqlen91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra91.uuid_eq_qualname_len_11:
  description: "uuid.UUID.__eq__.__qualname__.__len__() == 11 — UUID.__eq__.__qualname__ is 'UUID.__eq__': 'UUID.' (5) + '__eq__' (6) = 11; tied with __lt__ for shortest UUID dunder qualname; UUID.__eq__ compares UUIDs by integer representation; extra89 anchors __module__; first standalone for UUID.__eq__.__qualname__.__len__() under uuidqlen91"
  category: qualname_lengths
  kind: python_call_eq
  function: "UUID.__eq__.__qualname__.__len__"
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# uuid.uuid1.__qualname__.__len__()==5 — standalone
#
# uuid.uuid1.__qualname__.__len__() is 5. uuid1.__qualname__ is 'uuid1' (5 chars),
# the same as the function name — there is no class prefix because uuid1 is a
# module-level function, not a method. uuid1 generates a version-1 UUID based on
# the host's MAC address and current time. As a module-level function, its
# __qualname__ equals its simple name. Extra86 anchors uuid1.__qualname__.__eq__;
# no prior spec anchors uuid1.__qualname__.__len__()==5 as a standalone under
# uuidqlen91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra91.uuid1_qualname_len_5:
  description: "uuid.uuid1.__qualname__.__len__() == 5 — uuid1.__qualname__ is 'uuid1' (5 chars); module-level function qualname equals the simple function name (no class prefix); uuid1 generates version-1 UUIDs from MAC address and current time; extra86 anchors uuid1.__qualname__.__eq__; first standalone for uuid1.__qualname__.__len__() under uuidqlen91"
  category: qualname_lengths
  kind: python_call_eq
  function: uuid1.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__.__qualname__.__len__()==13 — standalone
#
# uuid.UUID.__hash__.__qualname__.__len__() is 13. UUID.__hash__.__qualname__
# is 'UUID.__hash__': 'UUID.' (5 chars) + '__hash__' (8 chars) = 13. UUID.__hash__
# makes UUID instances hashable, enabling their use as dictionary keys or set
# members. The hash is derived from the UUID's integer value. Extra89 anchors
# its __module__; no prior spec anchors UUID.__hash__.__qualname__.__len__()==13
# as a standalone under uuidqlen91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra91.uuid_hash_qualname_len_13:
  description: "uuid.UUID.__hash__.__qualname__.__len__() == 13 — UUID.__hash__.__qualname__ is 'UUID.__hash__': 'UUID.' (5) + '__hash__' (8) = 13; UUID.__hash__ makes UUID instances usable as dict keys/set members; extra89 anchors __module__; first standalone for UUID.__hash__.__qualname__.__len__() under uuidqlen91"
  category: qualname_lengths
  kind: python_call_eq
  function: "UUID.__hash__.__qualname__.__len__"
  args: []
  expected: 13
