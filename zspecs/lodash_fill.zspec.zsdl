spec: lodash_fill
version: ">=4.0.0"
backend: node(lodash.fill)

docs: https://lodash.com/docs/#fill

provenance:
  derived_from:
    - "lodash.fill README — https://www.npmjs.com/package/lodash.fill"
    - "Test vectors verified with lodash.fill@3.2.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.fill exports the _.fill function directly as module.exports."
    - "fill(array, value, start, end) fills elements of array with value from start up to (not including) end."
    - "Mutates and returns the array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the mutated array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_fill.fill:
  kind: node_module_call_eq
  function: ~
  category: fill
  id_prefix: lfill

  columns: [id, args, expected]
  rows:
    - [middle,   [[1, 2, 3, 4], 0, 1, 3],   [1, 0, 0, 4]]
    - [all,      [[1, 2, 3], "x"],           ["x", "x", "x"]]
    - [from_end, [["a", "b", "c", "d"], "z", 2], ["a", "b", "z", "z"]]
