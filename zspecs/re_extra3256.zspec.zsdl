    - ["re3256011", operator.contains, [re.Pattern.__dict__,   "__rlshift__"], false]
    - ["re3256012", operator.contains, [re.Pattern.__dict__,   "__rrshift__"], false]
    - ["re3256013", operator.contains, [re.Match.__dict__,     "__rpow__"],    false]
    - ["re3256014", operator.contains, [re.Match.__dict__,     "__rlshift__"], false]
