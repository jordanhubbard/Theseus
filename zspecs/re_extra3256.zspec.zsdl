spec: re3256
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 664 (re3256): __rpow__, __rlshift__, __rrshift__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __rpow__, __rlshift__, __rrshift__ dict-presence (reflected power/shift)."
    - "No re class defines __rpow__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; exponentiation is not part of their protocol."
    - "No re class defines __rlshift__ in its own __dict__: re types are not numeric operands; reflected left-shift is not defined on any re type."
    - "No re class defines __rrshift__ in its own __dict__: reflected right-shift is not defined on any re type."
    - "re.RegexFlag is defined as class RegexFlag(enum.IntFlag): the reflected power/shift methods __rpow__, __rlshift__, __rrshift__ are not defined on IntFlag; these are not flag-composition operations."
    - "operator.contains(re.RegexFlag.__dict__, '__rlshift__') = False and operator.contains(re.RegexFlag.__dict__, '__rrshift__') = False: bitwise shift is not part of the IntFlag protocol."
    - "Key finding: decimal.Decimal.__rpow__ = true (consistent with wave 660 __pow__ = true); __rlshift__/__rrshift__ = false (no bitwise shift on Decimal)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rpow__ dict-presence — operator.contains(Cls.__dict__, '__rpow__')
#
# No re class defines __rpow__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but reflected exponentiation is not part of the flag protocol.
# ---------------------------------------------------------------------------

table re3256.rpow:
  description: "re types __rpow__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3256

  columns: [id, function, args, expected]
  rows:
    - ["re3256001", operator.contains, [re.Pattern.__dict__,   "__rpow__"], false]
    - ["re3256002", operator.contains, [re.Match.__dict__,     "__rpow__"], false]
    - ["re3256003", operator.contains, [re.RegexFlag.__dict__, "__rpow__"], false]

# ---------------------------------------------------------------------------
# __rlshift__ dict-presence — operator.contains(Cls.__dict__, '__rlshift__')
#
# No re class defines __rlshift__ in its own __dict__; all false.
# re types are not numeric operands; reflected left-shift is not part of
# the re type protocol. re.RegexFlag (IntFlag) does not define __rlshift__.
# ---------------------------------------------------------------------------

table re3256.rlshift:
  description: "re types __rlshift__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3256

  columns: [id, function, args, expected]
  rows:
    - ["re3256004", operator.contains, [re.Pattern.__dict__,   "__rlshift__"], false]
    - ["re3256005", operator.contains, [re.Match.__dict__,     "__rlshift__"], false]
    - ["re3256006", operator.contains, [re.RegexFlag.__dict__, "__rlshift__"], false]

# ---------------------------------------------------------------------------
# __rrshift__ dict-presence — operator.contains(Cls.__dict__, '__rrshift__')
#
# No re class defines __rrshift__ in its own __dict__; all false.
# re types are not numeric operands; reflected right-shift is not part of
# the re type protocol. re.RegexFlag (IntFlag) does not define __rrshift__.
# ---------------------------------------------------------------------------

table re3256.rrshift:
  description: "re types __rrshift__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3256

  columns: [id, function, args, expected]
  rows:
    - ["re3256007", operator.contains, [re.Pattern.__dict__,   "__rrshift__"], false]
    - ["re3256008", operator.contains, [re.Match.__dict__,     "__rrshift__"], false]
    - ["re3256009", operator.contains, [re.RegexFlag.__dict__, "__rrshift__"], false]

# ---------------------------------------------------------------------------
# combined — __rpow__, __rlshift__, __rrshift__ across all 3 re subjects
#
# 3 classes x 3 methods = 9 rows.
# All nine values are false; re types do not implement reflected power or shift.
# re.RegexFlag is an IntFlag subclass; reflected power/shift operators are not
# defined on IntFlag and are not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3256.combined:
