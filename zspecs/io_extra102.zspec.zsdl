spec: io_extra102
version: ">=3.9"
backend: python_module(io)
extends: io_extra101

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec extends io_extra101.zspec.zsdl."
    - "This spec covers: io.BufferedReader and io.BufferedWriter method class names."
    - "io.BufferedReader and io.BufferedWriter are C extension types from _io."
    - "Their regular methods (read, write, seek, flush, etc.) are 'method_descriptor' when accessed on the class."
    - "io.BufferedReader.__init__ and __repr__ are 'wrapper_descriptor' (slot wrappers on C extension types)."
    - "io.BufferedWriter.__init__ and __repr__ are 'wrapper_descriptor' (slot wrappers on C extension types)."
    - "io.BufferedReader.write is present as method_descriptor (inherited from BufferedIOBase via C)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

