spec: itertools_extra2851
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 637 (_extra2851): __rlshift__, __rrshift__, __rpow__ dict-presence checks for itertools C-types."
    - "All itertools types are C-level iterator types — none define reflected shift or power operators."
    - "Verified types: chain, cycle, count, islice, product, permutations, combinations, groupby, starmap, zip_longest, takewhile, dropwhile, filterfalse, compress, accumulate, repeat, combinations_with_replacement, pairwise."
    - "itertools.pairwise was added in Python 3.10; spec requires >=3.9 but pairwise rows are guarded by version comment."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

