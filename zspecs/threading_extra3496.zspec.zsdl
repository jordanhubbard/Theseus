spec: th3496
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 680 (th3496): __aenter__, __aexit__, __await__ dict-presence checks for threading types."
    - "Theme: __aenter__/__aexit__/__await__ dict-presence (async with x, await x)."
    - "All values False — functools/itertools/inspect/threading types are synchronous and do not implement the async context manager or awaitable protocols."
    - "threading.Condition, Semaphore, Lock, RLock, Barrier define synchronous __enter__/__exit__ but NOT the async variants __aenter__/__aexit__."
    - "No threading type defines __await__ — none are awaitables."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3496.aenter:
  description: "threading types __aenter__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3496
  columns: [id, function, args, expected]
  rows:
    - ["th3496001", operator.contains, [threading.Thread.__dict__,           "__aenter__"], false]
    - ["th3496002", operator.contains, [threading.Event.__dict__,            "__aenter__"], false]
    - ["th3496003", operator.contains, [threading.Condition.__dict__,        "__aenter__"], false]
    - ["th3496004", operator.contains, [threading.Semaphore.__dict__,        "__aenter__"], false]
    - ["th3496005", operator.contains, [threading.BoundedSemaphore.__dict__, "__aenter__"], false]
    - ["th3496006", operator.contains, [threading.Timer.__dict__,            "__aenter__"], false]
    - ["th3496007", operator.contains, [threading.Barrier.__dict__,          "__aenter__"], false]
    - ["th3496008", operator.contains, [threading.local.__dict__,            "__aenter__"], false]
    - ["th3496009", operator.contains, [type(threading.Lock()).__dict__,     "__aenter__"], false]
    - ["th3496010", operator.contains, [type(threading.RLock()).__dict__,    "__aenter__"], false]

