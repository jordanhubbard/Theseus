spec: itertools_extra616
version: ">=3.9"
backend: python_module(itertools)
docs: "Behavioral spec for itertools class qualname and type identity checks."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers qualname identity for starmap, accumulate, filterfalse, zip_longest, combinations_with_replacement, takewhile, dropwhile, and pairwise."
  created_at: "2026-04-12T00:00:00Z"

table itertools_extra616.qualname_checks:
  description: "itertools class __qualname__ identity checks"
  kind: python_call_eq
  category: itertools_identity
  id_prefix: it616dc
  columns: [id, function, args, expected]
  rows:
    - [it616dc001, itertools.starmap.__qualname__.__eq__, ["starmap"], true]
    - [it616dc002, itertools.accumulate.__qualname__.__eq__, ["accumulate"], true]
    - [it616dc003, itertools.filterfalse.__qualname__.__eq__, ["filterfalse"], true]
    - [it616dc004, itertools.zip_longest.__qualname__.__eq__, ["zip_longest"], true]
    - [it616dc005, itertools.combinations_with_replacement.__qualname__.__eq__, ["combinations_with_replacement"], true]
    - [it616dc006, itertools.takewhile.__qualname__.__eq__, ["takewhile"], true]
    - [it616dc007, itertools.dropwhile.__qualname__.__eq__, ["dropwhile"], true]
    - [it616dc008, itertools.pairwise.__qualname__.__eq__, ["pairwise"], true]

table itertools_extra616.class_type_checks:
  description: "itertools class __class__.__name__ type identity checks"
  kind: python_call_eq
  category: itertools_identity
  id_prefix: it616qn
  columns: [id, function, args, expected]
  rows:
    - [it616qn001, itertools.combinations_with_replacement.__class__.__name__.__eq__, ["type"], true]
    - [it616qn002, itertools.takewhile.__class__.__name__.__eq__, ["type"], true]
    - [it616qn003, itertools.dropwhile.__class__.__name__.__eq__, ["type"], true]
    - [it616qn004, itertools.pairwise.__class__.__name__.__eq__, ["type"], true]
