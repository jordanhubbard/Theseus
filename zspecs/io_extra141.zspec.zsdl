spec: io_extra141
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/fileio.c"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io.FileIO class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__) and method descriptor identity (__class__.__name__ and __qualname__) for __init__, read, write, readinto, seek, tell, truncate, close."
    - "io.FileIO.__name__ == 'FileIO' (length 6)."
    - "io.FileIO.__module__ == '_io' — FileIO is a C extension type from the _io internal module, not the pure Python io wrapper."
    - "io.FileIO.__qualname__ == 'FileIO' (length 6) — qualname equals __name__ for module-level C types."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' (length 10) — FileIO directly extends the private C base _RawIOBase."
    - "io.FileIO.__mro__.__len__() == 4 — MRO is [FileIO, _RawIOBase, _IOBase, object]."
    - "io.FileIO.__class__.__name__ == 'type' — FileIO is a C extension type whose metaclass is the built-in 'type'."
    - "io.FileIO.__init__.__class__.__name__ == 'wrapper_descriptor' — __init__ is a slot wrapper, not a method_descriptor."
    - "io.FileIO.__init__.__qualname__ == 'FileIO.__init__' (length 15)."
    - "io.FileIO.read.__class__.__name__ == 'method_descriptor' (length 17); qualname 'FileIO.read' (11)."
    - "io.FileIO.write.__class__.__name__ == 'method_descriptor'; qualname 'FileIO.write' (12)."
    - "io.FileIO.readinto.__class__.__name__ == 'method_descriptor'; qualname 'FileIO.readinto' (15)."
    - "io.FileIO.seek.__qualname__ == 'FileIO.seek' (11)."
    - "io.FileIO.tell.__qualname__ == 'FileIO.tell' (11)."
    - "io.FileIO.truncate.__qualname__ == 'FileIO.truncate' (15)."
    - "io.FileIO.close.__qualname__ == 'FileIO.close' (12)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.FileIO class identity
# FileIO is a C extension type from _io. __name__ == 'FileIO' (6),
# __module__ == '_io' (3), __qualname__ == 'FileIO' (6).
# __bases__[0].__name__ == '_RawIOBase' (10). MRO length == 4.
# __class__.__name__ == 'type' (C extension type metaclass).
# ---------------------------------------------------------------------------

table io_extra141.FileIO_class_identity:
  description: "io.FileIO class identity: __name__='FileIO' (6), __module__='_io' (3), __qualname__='FileIO' (6), __bases__[0].__name__='_RawIOBase' (10), __mro__.__len__()==4, __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: iofio141

  columns: [id, function, args, expected]
  rows:
    - [fio_name_eq,      FileIO.__name__.__eq__,                   ["FileIO"],     true]
    - [fio_name_len,     FileIO.__name__.__len__,                  [],             6]
    - [fio_module_eq,    FileIO.__module__.__eq__,                 ["_io"],        true]
    - [fio_module_not,   FileIO.__module__.__eq__,                 ["io"],         false]
    - [fio_module_len,   FileIO.__module__.__len__,                [],             3]
    - [fio_qualname_eq,  FileIO.__qualname__.__eq__,               ["FileIO"],     true]
    - [fio_qualname_len, FileIO.__qualname__.__len__,              [],             6]
    - [fio_base_eq,      "FileIO.__bases__[0].__name__.__eq__",    ["_RawIOBase"], true]
    - [fio_base_len,     "FileIO.__bases__[0].__name__.__len__",   [],             10]
    - [fio_mro_len,      FileIO.__mro__.__len__,                   [],             4]
    - [fio_cls_eq,       FileIO.__class__.__name__.__eq__,         ["type"],       true]

# ---------------------------------------------------------------------------
# io.FileIO method descriptor __class__.__name__
# __init__ is a wrapper_descriptor; read, write, readinto, seek, tell,
# truncate, close are all method_descriptor instances.
# ---------------------------------------------------------------------------

table io_extra141.FileIO_method_descriptor_classes:
  description: "io.FileIO method descriptor __class__.__name__: __init__='wrapper_descriptor', read/write/readinto/seek/tell/truncate/close='method_descriptor'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iofio141

  columns: [id, function, args, expected]
  rows:
    - [init_cls_eq,      FileIO.__init__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true]
    - [init_cls_not_md,  FileIO.__init__.__class__.__name__.__eq__,     ["method_descriptor"],  false]
    - [read_cls_eq,      FileIO.read.__class__.__name__.__eq__,         ["method_descriptor"],  true]
    - [write_cls_eq,     FileIO.write.__class__.__name__.__eq__,        ["method_descriptor"],  true]
    - [readinto_cls_eq,  FileIO.readinto.__class__.__name__.__eq__,     ["method_descriptor"],  true]
    - [seek_cls_eq,      FileIO.seek.__class__.__name__.__eq__,         ["method_descriptor"],  true]
    - [tell_cls_eq,      FileIO.tell.__class__.__name__.__eq__,         ["method_descriptor"],  true]
    - [truncate_cls_eq,  FileIO.truncate.__class__.__name__.__eq__,     ["method_descriptor"],  true]
    - [close_cls_eq,     FileIO.close.__class__.__name__.__eq__,        ["method_descriptor"],  true]

# ---------------------------------------------------------------------------
# io.FileIO method __qualname__ string equality and lengths
# __init__: 'FileIO.__init__' (14), read: 'FileIO.read' (11),
# write: 'FileIO.write' (12), readinto: 'FileIO.readinto' (15),
# seek: 'FileIO.seek' (11), tell: 'FileIO.tell' (11),
# truncate: 'FileIO.truncate' (15), close: 'FileIO.close' (12).
# ---------------------------------------------------------------------------

table io_extra141.FileIO_method_qualnames:
  description: "io.FileIO method __qualname__ string equality and lengths: __init__=14, read=11, write=12, readinto=15, seek=11, tell=11, truncate=15, close=12"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iofio141

  columns: [id, function, args, expected]
  rows:
    - [init_qn_eq,      FileIO.__init__.__qualname__.__eq__,      ["FileIO.__init__"],    true]
    - [init_qn_len,     FileIO.__init__.__qualname__.__len__,     [],                     15]
    - [read_qn_eq,      FileIO.read.__qualname__.__eq__,          ["FileIO.read"],        true]
    - [read_qn_len,     FileIO.read.__qualname__.__len__,         [],                     11]
    - [write_qn_eq,     FileIO.write.__qualname__.__eq__,         ["FileIO.write"],       true]
    - [write_qn_len,    FileIO.write.__qualname__.__len__,        [],                     12]
    - [readinto_qn_eq,  FileIO.readinto.__qualname__.__eq__,      ["FileIO.readinto"],    true]
    - [readinto_qn_len, FileIO.readinto.__qualname__.__len__,     [],                     15]
    - [seek_qn_eq,      FileIO.seek.__qualname__.__eq__,          ["FileIO.seek"],        true]
    - [seek_qn_len,     FileIO.seek.__qualname__.__len__,         [],                     11]
    - [tell_qn_eq,      FileIO.tell.__qualname__.__eq__,          ["FileIO.tell"],        true]
    - [tell_qn_len,     FileIO.tell.__qualname__.__len__,         [],                     11]

# ---------------------------------------------------------------------------
# io.FileIO remaining method __qualname__ lengths
# truncate: 'FileIO.truncate' (15), close: 'FileIO.close' (12).
# Also confirm __name__ != '__qualname__' (no, they are equal for FileIO).
# ---------------------------------------------------------------------------

table io_extra141.FileIO_method_qualnames_part2:
  description: "io.FileIO method __qualname__ string equality and lengths (continued): truncate=15, close=12; and qualname==name equality for the class"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: iofio141

  columns: [id, function, args, expected]
  rows:
    - [truncate_qn_eq,  FileIO.truncate.__qualname__.__eq__,     ["FileIO.truncate"],    true]
    - [truncate_qn_len, FileIO.truncate.__qualname__.__len__,    [],                     15]
    - [close_qn_eq,     FileIO.close.__qualname__.__eq__,        ["FileIO.close"],       true]
    - [close_qn_len,    FileIO.close.__qualname__.__len__,       [],                     12]
    - [name_eq_qual,    FileIO.__name__.__eq__,                  ["FileIO"],             true]
    - [qual_eq_name,    FileIO.__qualname__.__eq__,              ["FileIO"],             true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra141.FileIO.name_is_FileIO:
  description: "io.FileIO.__name__ == 'FileIO' (length 6; the class name as defined in the _io C extension)"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__name__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra141.FileIO.module_is_underscore_io:
  description: "io.FileIO.__module__ == '_io' (length 3; FileIO is a C extension type from the _io internal module, not the pure Python io wrapper)"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra141.FileIO.mro_len_4:
  description: "io.FileIO.__mro__.__len__() == 4 (MRO is [FileIO, _RawIOBase, _IOBase, object])"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__mro__.__len__
  args: []
  expected: 4

invariant io_extra141.FileIO.init_is_wrapper_descriptor:
  description: "io.FileIO.__init__.__class__.__name__ == 'wrapper_descriptor' (__init__ is a slot wrapper, distinct from the method_descriptor used by read, write, readinto, etc.)"
  category: method_descriptor
  kind: python_call_eq
  function: FileIO.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant io_extra141.FileIO.init_qualname_len_15:
  description: "io.FileIO.__init__.__qualname__.__len__() == 15 ('FileIO.__init__' is 15 chars: 'FileIO' (6) + '.' (1) + '__init__' (8))"
  category: method_descriptor
  kind: python_call_eq
  function: FileIO.__init__.__qualname__.__len__
  args: []
  expected: 15

invariant io_extra141.FileIO.readinto_qualname_len_15:
  description: "io.FileIO.readinto.__qualname__.__len__() == 15 ('FileIO.readinto' is 15 chars: 'FileIO' (6) + '.' (1) + 'readinto' (8))"
  category: method_descriptor
  kind: python_call_eq
  function: FileIO.readinto.__qualname__.__len__
  args: []
  expected: 15
