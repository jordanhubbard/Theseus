spec: th3226
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 662 (th3226): __radd__, __rsub__, __rmul__ dict-presence checks for threading types."
    - "Theme: __radd__, __rsub__, __rmul__ dict-presence (reflected arithmetic operators)."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — these types have no reflected arithmetic protocol."
    - "None of the threading types define __radd__, __rsub__, or __rmul__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3226.radd:
  description: "threading types __radd__ dict-presence checks; wave 662"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3226
  columns: [id, function, args, expected]
  rows:
    - ["th3226001", operator.contains, [threading.Thread.__dict__,           "__radd__"], false]
    - ["th3226002", operator.contains, [type(threading.Lock()).__dict__,     "__radd__"], false]
    - ["th3226003", operator.contains, [type(threading.RLock()).__dict__,    "__radd__"], false]
    - ["th3226004", operator.contains, [threading.Event.__dict__,            "__radd__"], false]
    - ["th3226005", operator.contains, [threading.Condition.__dict__,        "__radd__"], false]
    - ["th3226006", operator.contains, [threading.Semaphore.__dict__,        "__radd__"], false]
    - ["th3226007", operator.contains, [threading.BoundedSemaphore.__dict__, "__radd__"], false]
    - ["th3226008", operator.contains, [threading.Timer.__dict__,            "__radd__"], false]
    - ["th3226009", operator.contains, [threading.Barrier.__dict__,          "__radd__"], false]
    - ["th3226010", operator.contains, [threading.local.__dict__,            "__radd__"], false]

