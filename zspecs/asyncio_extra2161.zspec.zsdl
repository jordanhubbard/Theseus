spec: asyncio_extra2161
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Theme: descriptor protocol dict-presence — checks for __get__, __set__, __delete__, __set_name__, fget, fset, fdel, __objclass__, __func__ in class __dict__."
    - "asyncio.Task does not define any descriptor protocol methods in its own __dict__."
    - "asyncio.Future does not define any descriptor protocol methods in its own __dict__."
    - "asyncio.Event does not define any descriptor protocol methods in its own __dict__."
    - "asyncio.Lock does not define any descriptor protocol methods in its own __dict__."
    - "asyncio.Queue does not define descriptor protocol methods; it has a 'maxsize' property but that is a property *instance*, not __get__ etc. on Queue itself."
    - "asyncio.Semaphore does not define any descriptor protocol methods in its own __dict__."
    - "asyncio.Condition does not define any descriptor protocol methods in its own __dict__."
    - "asyncio.StreamReader does not define any descriptor protocol methods in its own __dict__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Task — descriptor protocol dict-presence
# ---------------------------------------------------------------------------

table asyncio_extra2161.Task_descriptor_presence:
  kind: python_call_eq
  category: descriptor_presence
  columns: [id, function, args, expected]
  rows:
    - ["as2161001", "asyncio.Task.__dict__.__contains__", ["__get__"], false]
    - ["as2161002", "asyncio.Task.__dict__.__contains__", ["__set__"], false]
    - ["as2161003", "asyncio.Task.__dict__.__contains__", ["__delete__"], false]
    - ["as2161004", "asyncio.Task.__dict__.__contains__", ["__set_name__"], false]
    - ["as2161005", "asyncio.Task.__dict__.__contains__", ["fget"], false]
    - ["as2161006", "asyncio.Task.__dict__.__contains__", ["fset"], false]
    - ["as2161007", "asyncio.Task.__dict__.__contains__", ["fdel"], false]
    - ["as2161008", "asyncio.Task.__dict__.__contains__", ["__objclass__"], false]
    - ["as2161009", "asyncio.Task.__dict__.__contains__", ["__func__"], false]

