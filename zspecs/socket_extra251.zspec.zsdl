spec: socket_extra251
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "Wave 251 theme: socket module AddressFamily and SocketKind enum class identity and member values."
    - "socket.AddressFamily.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum'. AddressFamily inherits from IntEnum (members are usable as ints). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__bases__[0].__name__ == 'IntEnum'. SocketKind inherits from IntEnum. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.AF_INET.value == 2. AF_INET is address family 2 on POSIX systems. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.AF_INET6.value == 30. AF_INET6 is address family 30 on macOS/Darwin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.AF_UNIX.value == 1. AF_UNIX is address family 1 (Unix domain sockets). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.SOCK_STREAM.value == 1. SOCK_STREAM is socket type 1 (TCP-style reliable stream). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.SOCK_DGRAM.value == 2. SOCK_DGRAM is socket type 2 (UDP-style datagram). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.SOCK_RAW.value == 3. SOCK_RAW is socket type 3 (raw protocol access). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.has_ipv6 == True on macOS/Darwin. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: AF_INET6.value == 30 is macOS/Darwin-specific. On Linux, AF_INET6 == 10. This spec records the macOS value."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.AddressFamily enum class identity
#
# Wave 251 theme: socket.AddressFamily class metadata.
#
# socket.AddressFamily is an IntEnum subclass. It enumerates POSIX address
# family constants (AF_INET, AF_INET6, AF_UNIX, etc.). As an IntEnum, its
# members can be used directly as integers — useful when passing to C APIs.
# AF_INET (IPv4) == 2, AF_UNIX (Unix domain) == 1, AF_INET6 (IPv6) == 30 on
# macOS/Darwin (differs from Linux where AF_INET6 == 10).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra251.AddressFamily_class_identity:
  description: "socket.AddressFamily class identity — AddressFamily.__name__=='AddressFamily'; AddressFamily.__module__=='socket'; AddressFamily.__bases__[0].__name__=='IntEnum' (members are ints; usable directly in C socket API calls); AF_INET.value==2 (IPv4, POSIX standard); AF_UNIX.value==1 (Unix domain sockets); AF_INET6.value==30 (IPv6; macOS/Darwin-specific; Linux uses 10); wave 251 theme: AddressFamily enum identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: sockaddrf251

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,          AddressFamily.__name__.__eq__,               ["AddressFamily"], true, "socket.AddressFamily.__name__ == 'AddressFamily'"]
    - [module_eq,        AddressFamily.__module__.__eq__,             ["socket"],        true, "socket.AddressFamily.__module__ == 'socket'; defined in Lib/socket.py"]
    - [base_name_eq,     "AddressFamily.__bases__[0].__name__.__eq__", ["IntEnum"],       true, "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum'; members are usable as ints"]
    - [af_inet_value_eq, AddressFamily.AF_INET.value.__eq__,          [2],               true, "socket.AddressFamily.AF_INET.value == 2; IPv4 address family; standard POSIX value"]
    - [af_unix_value_eq, AddressFamily.AF_UNIX.value.__eq__,          [1],               true, "socket.AddressFamily.AF_UNIX.value == 1; Unix domain socket address family"]
    - [af_inet6_val_eq,  AddressFamily.AF_INET6.value.__eq__,         [30],              true, "socket.AddressFamily.AF_INET6.value == 30; IPv6; macOS/Darwin-specific (Linux uses 10)"]

# ---------------------------------------------------------------------------
# socket.SocketKind enum class identity
#
# Wave 251 theme: socket.SocketKind class metadata and member values.
#
# socket.SocketKind is an IntEnum subclass enumerating socket type constants.
# SOCK_STREAM (1) is for reliable ordered streams (TCP). SOCK_DGRAM (2) is
# for datagrams (UDP). SOCK_RAW (3) is for raw protocol access.
# As IntEnum, SocketKind members are directly usable as integer socket type
# arguments. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra251.SocketKind_class_identity:
  description: "socket.SocketKind class identity — SocketKind.__name__=='SocketKind'; SocketKind.__module__=='socket'; SocketKind.__bases__[0].__name__=='IntEnum' (members usable as ints in socket() syscall); SOCK_STREAM.value==1 (reliable ordered byte stream; used for TCP); SOCK_DGRAM.value==2 (unreliable datagrams; used for UDP); SOCK_RAW.value==3 (raw protocol access; requires elevated privileges); wave 251 theme: SocketKind enum identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: sockkind251

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,              SocketKind.__name__.__eq__,               ["SocketKind"], true, "socket.SocketKind.__name__ == 'SocketKind'"]
    - [module_eq,            SocketKind.__module__.__eq__,             ["socket"],     true, "socket.SocketKind.__module__ == 'socket'; defined in Lib/socket.py"]
    - [base_name_eq,         "SocketKind.__bases__[0].__name__.__eq__", ["IntEnum"],    true, "socket.SocketKind.__bases__[0].__name__ == 'IntEnum'; members are usable as ints"]
    - [stream_value_eq,      SocketKind.SOCK_STREAM.value.__eq__,      [1],            true, "socket.SocketKind.SOCK_STREAM.value == 1; reliable ordered stream (TCP-style)"]
    - [dgram_value_eq,       SocketKind.SOCK_DGRAM.value.__eq__,       [2],            true, "socket.SocketKind.SOCK_DGRAM.value == 2; unreliable datagrams (UDP-style)"]
    - [raw_value_eq,         SocketKind.SOCK_RAW.value.__eq__,         [3],            true, "socket.SocketKind.SOCK_RAW.value == 3; raw protocol access (requires privileges)"]

# ---------------------------------------------------------------------------
# Standalone invariants — socket enum identity and has_ipv6
# ---------------------------------------------------------------------------

invariant socket_extra251.AddressFamily_base_is_IntEnum:
  description: "socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum') == True — AddressFamily inherits from IntEnum, meaning its members (AF_INET, AF_INET6, AF_UNIX, etc.) can be used directly as integer arguments in system calls and C API calls without explicit conversion; this contrasts with plain Enum where .value access is required; both AddressFamily and SocketKind are IntEnum subclasses; wave 251; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "AddressFamily.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

invariant socket_extra251.SocketKind_base_is_IntEnum:
  description: "socket.SocketKind.__bases__[0].__name__.__eq__('IntEnum') == True — SocketKind inherits from IntEnum; members SOCK_STREAM (1), SOCK_DGRAM (2), SOCK_RAW (3) are usable as integer socket type arguments; both AddressFamily and SocketKind use IntEnum for direct interoperability with the POSIX socket() and other C-level socket system calls; wave 251; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "SocketKind.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

invariant socket_extra251.AF_INET_value_is_2:
  description: "socket.AddressFamily.AF_INET.value.__eq__(2) == True — AF_INET is the IPv4 address family with POSIX-standard value 2; this is consistent across macOS, Linux, and BSD systems; the value 2 is also the historic socket() AF_INET constant before the AddressFamily IntEnum was introduced in Python 3.4; socket.AF_INET (the module-level alias) equals AddressFamily.AF_INET; wave 251; verified with Python 3.14.3"
  category: enum_values
  kind: python_call_eq
  function: AddressFamily.AF_INET.value.__eq__
  args: [2]
  expected: true

invariant socket_extra251.SOCK_STREAM_value_is_1:
  description: "socket.SocketKind.SOCK_STREAM.value.__eq__(1) == True — SOCK_STREAM is the socket kind for reliable, connection-oriented byte streams; value 1 is consistent across POSIX platforms (macOS, Linux, BSD); SOCK_STREAM is used for TCP sockets; socket.SOCK_STREAM (the module-level alias) equals SocketKind.SOCK_STREAM; wave 251; verified with Python 3.14.3"
  category: enum_values
  kind: python_call_eq
  function: SocketKind.SOCK_STREAM.value.__eq__
  args: [1]
  expected: true
