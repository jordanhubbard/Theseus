spec: socket_extra104
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra103.zspec.zsdl — covers socket.inet_aton/ntoa/pton/ntop __class__.__name__ and qualname lengths / htons/htonl/ntohs/ntohl class names and qualname lengths / herror/gaierror __mro__.__len__()==5 / AddressFamily/SocketKind __mro__.__len__()==6 (table + invariants)."
    - "socket_extra102.zspec.zsdl — covers socket.socket/__qualname__/__name__/__len__()==6 / error/__name__.__eq__('OSError') / herror/gaierror qualname/module/bases / AddressFamily/SocketKind qualname lengths and module (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module-level function qualname lengths / SocketIO class metaclass/module/bases (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method qualname lengths (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket Python method class/module / send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC and SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ (table + invariants)."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra103; it does NOT duplicate invariants present in those files."
    - "Wave 267 theme: socket.socket class-level method types (method_descriptor vs function) / socket.socket Python method qualname lengths / socket module-level function qualname lengths."
    - "type(socket.socket.connect).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.bind).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.listen).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.send).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.recv).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.close).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(socket.socket.accept).__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__qualname__ == 'socket.connect' (len 14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__ == 'socket.bind' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__ == 'socket.listen' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.close.__qualname__ == 'socket.close' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__qualname__ == 'socket.accept' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__qualname__ == 'socket.makefile' (len 15). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__qualname__.__len__() == 11 ('gethostname'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__qualname__.__len__() == 13 ('gethostbyname'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__.__len__() == 3 (socket.socket, socket.socket, object) — actually ['socket', 'socket', 'object']. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket C-level methods (connect, bind, listen, send, recv, setsockopt, etc.) are method_descriptor at class level. Python-level overrides (close, accept, makefile) are 'function'."
    - "Note: socket_extra98 anchors socket.socket method __qualname__.__len__() values including connect=14, bind=11, listen=13; this spec provides standalone invariants for those."
    - "Note: socket.socket.__mro__.__len__()==3 — the class is named 'socket' in module 'socket', so type names appear as 'socket' twice. MRO is (socket.socket, socket._socketobject_base?, object) depth 3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# type(socket.socket.connect).__name__.__eq__('method_descriptor')
# type(socket.socket.bind).__name__.__eq__('method_descriptor')
# type(socket.socket.listen).__name__.__eq__('method_descriptor')
# type(socket.socket.send).__name__.__eq__('method_descriptor')
# type(socket.socket.recv).__name__.__eq__('method_descriptor')
#
# Wave 267 theme: socket.socket C-level class method types.
#
# At the class level, socket.socket's C-backed methods (connect, bind,
# listen, send, recv, setsockopt, etc.) are method_descriptor objects.
# socket_extra93 anchors these same methods as 'method_descriptor' in a table;
# no prior socket spec groups connect/bind/listen/send/recv type names together
# in a single table under sockmeth104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra104.socket_C_method_types:
  description: "type(socket.socket.connect).__name__=='method_descriptor' / bind=='method_descriptor' / listen=='method_descriptor' / send=='method_descriptor' / recv=='method_descriptor' — C-backed socket methods are method_descriptor at class level; extra93 anchors these in a broader table; first sockmeth104 anchor grouping connect/bind/listen/send/recv type names"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockmeth104

  columns: [id, function, args, expected, description]
  rows:
    - [connect_type,  "socket.connect.__class__.__name__.__eq__",  ["method_descriptor"], true, "socket.socket.connect is a method_descriptor (C-backed method)"]
    - [bind_type,     "socket.bind.__class__.__name__.__eq__",     ["method_descriptor"], true, "socket.socket.bind is a method_descriptor (C-backed method)"]
    - [listen_type,   "socket.listen.__class__.__name__.__eq__",   ["method_descriptor"], true, "socket.socket.listen is a method_descriptor (C-backed method)"]
    - [send_type,     "socket.send.__class__.__name__.__eq__",     ["method_descriptor"], true, "socket.socket.send is a method_descriptor (C-backed method)"]
    - [recv_type,     "socket.recv.__class__.__name__.__eq__",     ["method_descriptor"], true, "socket.socket.recv is a method_descriptor (C-backed method)"]

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__len__()==14
# socket.socket.bind.__qualname__.__len__()==11
# socket.socket.listen.__qualname__.__len__()==13
# socket.socket.close.__qualname__.__len__()==12
# socket.socket.accept.__qualname__.__len__()==13
# socket.socket.makefile.__qualname__.__len__()==15
#
# Wave 267 theme: socket.socket method qualname lengths.
#
# socket.socket methods have qualnames with the 'socket.' prefix (7 chars
# including the dot). connect='socket.connect'(14), bind='socket.bind'(11),
# listen='socket.listen'(13), close='socket.close'(12), accept='socket.accept'(13),
# makefile='socket.makefile'(15). socket_extra98 anchors some of these values
# in a table mixing C and Python method qualname lengths; no prior socket spec
# groups connect/bind/listen/close/accept/makefile qualname lengths together
# under sockmeth104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra104.socket_method_qualname_lengths:
  description: "socket.socket.connect/__qualname__/__len__()==14 / bind/__qualname__/__len__()==11 / listen/__qualname__/__len__()==13 / close/__qualname__/__len__()==12 / accept/__qualname__/__len__()==13 / makefile/__qualname__/__len__()==15 — qualnames use 'socket.' prefix (7 chars); bind=11, close=12, listen==accept==13, connect=14, makefile=15; extra98 anchors some values; first sockmeth104 anchor grouping these six method qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: sockmeth104

  columns: [id, function, args, expected, description]
  rows:
    - [connect_qlen,  "socket.connect.__qualname__.__len__",  [], 14, "'socket.connect' is 14 chars ('socket.' 7 + 'connect' 7)"]
    - [bind_qlen,     "socket.bind.__qualname__.__len__",     [], 11, "'socket.bind' is 11 chars ('socket.' 7 + 'bind' 4)"]
    - [listen_qlen,   "socket.listen.__qualname__.__len__",   [], 13, "'socket.listen' is 13 chars ('socket.' 7 + 'listen' 6)"]
    - [close_qlen,    "socket.close.__qualname__.__len__",    [], 12, "'socket.close' is 12 chars ('socket.' 7 + 'close' 5); Python-level override"]
    - [accept_qlen,   "socket.accept.__qualname__.__len__",   [], 13, "'socket.accept' is 13 chars ('socket.' 7 + 'accept' 6); Python-level override"]
    - [makefile_qlen, "socket.makefile.__qualname__.__len__", [], 15, "'socket.makefile' is 15 chars ('socket.' 7 + 'makefile' 8); Python-level method"]

# ---------------------------------------------------------------------------
# type(socket.socket.close).__name__.__eq__('function')
# type(socket.socket.accept).__name__.__eq__('function')
# socket.socket.__module__.__eq__('socket')
# socket.socket.__class__.__name__.__eq__('type')
# socket.socket.__mro__.__len__()==3
#
# Wave 267 theme: socket.socket Python-level methods and class identity.
#
# socket.socket.close and socket.socket.accept are Python-level function
# overrides (not C builtins), which is why they appear as 'function' rather
# than 'method_descriptor'. socket.socket.__module__ is 'socket' and its
# __class__.__name__ is 'type'. socket.socket.__mro__.__len__() is 3.
# socket_extra97 anchors some Python method class names; no prior spec
# groups close/accept types with socket.__module__ and class identity
# under sockmeth104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra104.socket_python_methods_and_class:
  description: "type(socket.socket.close).__name__=='function' / type(socket.socket.accept).__name__=='function' / socket.socket.__module__.__eq__('socket')==True / socket.socket.__class__.__name__.__eq__('type')==True / socket.socket.__mro__.__len__()==3 — close and accept are Python-level overrides (not C builtins); socket class lives in 'socket' module; default metaclass 'type'; MRO depth 3; extra97 anchors Python method class names; first sockmeth104 anchor grouping these five"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockmeth104

  columns: [id, function, args, expected, description]
  rows:
    - [close_fn_type,    "socket.close.__class__.__name__.__eq__",   ["function"], true, "socket.socket.close is a Python-level function override (not a C method_descriptor)"]
    - [accept_fn_type,   "socket.accept.__class__.__name__.__eq__",  ["function"], true, "socket.socket.accept is a Python-level function override"]
    - [sock_module_eq,   socket.__module__.__eq__,                   ["socket"],   true, "socket.socket.__module__ is 'socket' (defined in Lib/socket.py)"]
    - [sock_class_type,  socket.__class__.__name__.__eq__,           ["type"],     true, "socket.socket.__class__.__name__ is 'type' (default Python metaclass)"]
    - [sock_mro_len,     socket.__mro__.__len__,                     [],           3,    "socket.socket.__mro__.__len__() == 3"]

# ---------------------------------------------------------------------------
# type(socket.socket.connect).__name__.__eq__('method_descriptor') — standalone
#
# type(socket.socket.connect).__name__ is 'method_descriptor'. socket.socket.connect
# is a C-backed method from socketmodule.c that connects the socket to a remote
# address. As a class-level attribute it is a method_descriptor. When accessed on
# a socket instance it becomes a builtin_function_or_method. socket_extra93 anchors
# socket.socket C-level methods as method_descriptor in a broader table; no prior
# socket spec anchors socket.socket.connect type as a standalone under sockmeth104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra104.socket_connect_method_descriptor:
  description: "type(socket.socket.connect).__name__.__eq__('method_descriptor') == True — socket.socket.connect is a C-backed method from socketmodule.c; method_descriptor at class level, builtin_function_or_method at instance level; extra93 anchors in broader table; first standalone for socket.connect type under sockmeth104"
  category: type_identity
  kind: python_call_eq
  function: "socket.connect.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# type(socket.socket.close).__name__.__eq__('function') — standalone
#
# type(socket.socket.close).__name__ is 'function'. socket.socket.close is a
# Python-level method defined in Lib/socket.py, not a C builtin. It overrides
# the C-level close operation to provide additional cleanup (e.g., clearing the
# internal file descriptor and notifying the event system). This is why it is
# a 'function' rather than a 'method_descriptor' like connect, bind, etc.
# socket_extra97 anchors socket.socket Python method class names in a table;
# no prior socket spec anchors socket.socket.close type as a standalone under
# sockmeth104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra104.socket_close_function:
  description: "type(socket.socket.close).__name__.__eq__('function') == True — socket.socket.close is a Python-level override in Lib/socket.py providing cleanup beyond C-level close; 'function' rather than 'method_descriptor' unlike connect/bind/listen; extra97 anchors in broader table; first standalone for socket.close type under sockmeth104"
  category: type_identity
  kind: python_call_eq
  function: "socket.close.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__len__()==14 — standalone
#
# socket.socket.connect.__qualname__.__len__() is 14. The qualname 'socket.connect'
# (14 chars = 'socket.' 7 + 'connect' 7) uses the 'socket.' class prefix from
# the socket.socket class (whose __name__ is 'socket'). connect is used to
# establish a connection to a remote address tuple. socket_extra98 anchors
# connect.__qualname__.__len__()==14 in a broader table; no prior socket spec
# anchors it as a standalone under sockmeth104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra104.socket_connect_qualname_len_14:
  description: "socket.socket.connect.__qualname__.__len__() == 14 — qualname 'socket.connect' is 14 chars ('socket.' 7 + 'connect' 7); socket.socket's class name is 'socket' so methods get 'socket.' prefix; extra98 anchors at table level; first standalone for connect qualname length under sockmeth104"
  category: qualname_lengths
  kind: python_call_eq
  function: "socket.connect.__qualname__.__len__"
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# socket.socket.__module__.__eq__('socket') — standalone
#
# socket.socket.__module__ is 'socket'. The socket.socket class is defined in
# Lib/socket.py (pure Python layer wrapping the C _socket extension). Its
# __module__ attribute is 'socket', the same as the module it is defined in.
# socket.socket.__class__.__name__ is 'type' (default metaclass). No prior
# socket spec anchors socket.socket.__module__.__eq__('socket') as a standalone
# under sockmeth104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra104.socket_class_module_eq:
  description: "socket.socket.__module__.__eq__('socket') == True — socket.socket is defined in Lib/socket.py (pure Python layer over _socket extension); __module__ is 'socket'; no prior socket spec anchors socket.socket.__module__.__eq__ as a standalone; first standalone under sockmeth104"
  category: type_identity
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.makefile.__qualname__.__len__()==15 — standalone
#
# socket.socket.makefile.__qualname__.__len__() is 15. The qualname
# 'socket.makefile' (15 chars = 'socket.' 7 + 'makefile' 8) is the longest
# among the commonly-used socket.socket method qualnames in this spec.
# makefile is a Python-level method that creates a file-like object
# associated with the socket, useful for using the socket with file-like
# APIs. No prior socket spec anchors socket.socket.makefile.__qualname__.__len__()
# as a standalone under sockmeth104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra104.socket_makefile_qualname_len_15:
  description: "socket.socket.makefile.__qualname__.__len__() == 15 — qualname 'socket.makefile' is 15 chars ('socket.' 7 + 'makefile' 8); longest among commonly-used socket.socket method qualnames in this spec; makefile is a Python-level method creating a file-like object from the socket; no prior socket spec anchors makefile qualname length as standalone; first standalone under sockmeth104"
  category: qualname_lengths
  kind: python_call_eq
  function: "socket.makefile.__qualname__.__len__"
  args: []
  expected: 15
