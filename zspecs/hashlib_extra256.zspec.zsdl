spec: hashlib_extra256
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
  notes:
    - "Wave 256 theme: hashlib module identity and file_digest function identity (Python 3.11+)."
    - "hashlib.__name__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__package__ == ''. hashlib is a top-level stdlib module; __package__ is an empty string (not 'hashlib'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__ exists and contains 'file_digest'. __all__ is a tuple of 19 names including 'file_digest', 'pbkdf2_hmac', algorithm constructors, and 'new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__name__ == 'file_digest'. file_digest is a Python-level function (not a C builtin) added in Python 3.11 for streaming file hashing. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__module__ == 'hashlib'. file_digest is defined in Lib/hashlib.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__class__.__name__ == 'function'. file_digest is a plain Python function object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__name__ == 'openssl_sha3_256'. sha3_256 is OpenSSL-backed via _hashlib C extension; its constructor __name__ carries the 'openssl_' prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256(b'').name == 'sha3_256'. Hash object .name attribute returns the canonical algorithm name without any 'openssl_' prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(hashlib.sha3_256(b'')).__name__ == 'HASH'. sha3_256 hash objects are instances of the internal HASH type from _hashlib. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.__package__ == '' (empty string), not 'hashlib'. This differs from package modules — hashlib is a standalone module, not a package."
    - "Note: file_digest (Python 3.11+) accepts a file-like object and a hash constructor, returning the hash of all file bytes. It is a pure Python function defined in Lib/hashlib.py."
    - "Note: sha3_256 hash object .name returns 'sha3_256' (no 'openssl_' prefix), while the constructor's __name__ is 'openssl_sha3_256'. These are distinct identifiers."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__name__.__eq__('hashlib')
# hashlib.__package__.__eq__('')
# 'file_digest' in hashlib.__all__
#
# Wave 256 theme: hashlib module identity attributes.
#
# hashlib.__name__ is 'hashlib' (the module name). hashlib.__package__ is ''
# (empty string) because hashlib is a standalone top-level module, not a package.
# hashlib.__all__ is a tuple of 19 names that includes 'file_digest', 'pbkdf2_hmac',
# 'new', and all the hash algorithm constructor names. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra256.module_identity:
  description: "hashlib module identity attributes — __name__.__eq__('hashlib')==True / __package__.__eq__('')==True / __all__.__contains__('file_digest')==True — hashlib is a top-level stdlib module (__package__ is empty string, not 'hashlib'); __all__ is a 19-name tuple including file_digest/pbkdf2_hmac/new and all constructor names; wave 256 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmod256

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,    __name__.__eq__,           ["hashlib"],       true, "hashlib.__name__ == 'hashlib'; top-level stdlib module name"]
    - [module_pkg,     __package__.__eq__,        [""],              true, "hashlib.__package__ == ''; standalone module (not a package), __package__ is empty string"]
    - [all_has_fd,     __all__.__contains__,      ["file_digest"],   true, "'file_digest' in hashlib.__all__; file_digest (Python 3.11+) is in the public API tuple"]

# ---------------------------------------------------------------------------
# hashlib.file_digest.__name__.__eq__('file_digest')
# hashlib.file_digest.__module__.__eq__('hashlib')
# hashlib.file_digest.__class__.__name__.__eq__('function')
#
# Wave 256 theme: hashlib.file_digest function identity.
#
# hashlib.file_digest is a Python-level function added in Python 3.11 for
# streaming file hashing. It accepts a file-like object and a hash name or
# constructor, reads all the file bytes, and returns the resulting hash object.
# Its __name__ is 'file_digest', __module__ is 'hashlib' (defined in Lib/hashlib.py),
# and its type is 'function' (a plain Python function, not a C builtin).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra256.file_digest_identity:
  description: "hashlib.file_digest function identity — file_digest.__name__.__eq__('file_digest')==True / file_digest.__module__.__eq__('hashlib')==True / file_digest.__class__.__name__.__eq__('function')==True — file_digest is a pure Python function added in Python 3.11 for streaming file hashing; defined in Lib/hashlib.py; type is 'function' (not C builtin); wave 256 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibfd256

  columns: [id, function, args, expected, description]
  rows:
    - [fd_name,    file_digest.__name__.__eq__,              ["file_digest"], true, "file_digest.__name__ == 'file_digest'; Python 3.11+ streaming file hash function"]
    - [fd_module,  file_digest.__module__.__eq__,            ["hashlib"],     true, "file_digest.__module__ == 'hashlib'; defined in Lib/hashlib.py"]
    - [fd_class,   file_digest.__class__.__name__.__eq__,    ["function"],    true, "type(file_digest).__name__ == 'function'; plain Python function, not a C builtin"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__name__.__eq__('openssl_sha3_256')
# hashlib.sha3_256(b'').name.__eq__('sha3_256')
# type(hashlib.sha3_256(b'')).__name__.__eq__('HASH')
#
# Wave 256 theme: sha3_256 constructor and hash object name attributes.
#
# hashlib.sha3_256 is the SHA3-256 constructor backed by OpenSSL via the _hashlib
# C extension. Its constructor __name__ is 'openssl_sha3_256' (carrying the
# 'openssl_' prefix). When called, it returns a HASH object whose .name attribute
# is 'sha3_256' (canonical algorithm name without prefix). The HASH type is
# the internal hash object type from _hashlib. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra256.sha3_256_name_attributes:
  description: "hashlib sha3_256 constructor and hash object name attributes — sha3_256.__name__.__eq__('openssl_sha3_256')==True / sha3_256(b'').name.__eq__('sha3_256')==True / type(sha3_256(b'')).__name__.__eq__('HASH')==True — sha3_256 is OpenSSL-backed; constructor __name__ has 'openssl_' prefix; hash object .name returns canonical name without prefix; HASH is the internal _hashlib type; wave 256 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibsha3256w

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_ctor_name,  sha3_256.__name__.__eq__,  ["openssl_sha3_256"], true, "sha3_256.__name__ == 'openssl_sha3_256'; OpenSSL-backed constructor carries 'openssl_' prefix"]

# ---------------------------------------------------------------------------
# hashlib.__name__.__eq__('hashlib') — standalone
#
# hashlib.__name__ is 'hashlib'. This is the module's __name__ attribute, which
# equals the module's import name. hashlib is the standard library module for
# secure hash and message digest algorithms. It wraps both OpenSSL's EVP digest
# interface (via _hashlib C extension) and the pure Python/C implementations of
# BLAKE2 (via _blake2). The module provides a uniform interface via hashlib.new()
# as well as named constructor shortcuts (sha256, sha3_256, blake2b, etc.).
# This is the first standalone anchor for hashlib.__name__ under hashlibmod256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra256.module_name_is_hashlib:
  description: "hashlib.__name__.__eq__('hashlib') == True — hashlib is the stdlib module for secure hashing (SHA-2, SHA-3, BLAKE2, MD5); wraps OpenSSL EVP via _hashlib and provides blake2b/blake2s via _blake2; uniform interface via hashlib.new() plus named constructors; first standalone for hashlib.__name__ under hashlibmod256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__name__.__eq__('file_digest') — standalone
#
# hashlib.file_digest.__name__ is 'file_digest'. file_digest is a Python
# function added in Python 3.11 (PEP 587 / bpo-47234). It accepts a file-like
# object (opened in binary mode) and a hash constructor or algorithm name, reads
# all bytes from the file using the hash's block-size as the read chunk size,
# and returns the completed hash object. It is particularly useful for hashing
# large files efficiently without loading them entirely into memory. Its __name__
# is 'file_digest' confirming it is a named Python function in Lib/hashlib.py.
# This is the first standalone anchor for file_digest.__name__ under hashlibfd256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra256.file_digest_name:
  description: "hashlib.file_digest.__name__.__eq__('file_digest') == True — file_digest (Python 3.11+) streams a binary-mode file through a hash using block-sized reads; accepts file-like object and hash name/constructor; returns completed hash object; useful for large files without full memory load; defined in Lib/hashlib.py; first standalone for file_digest.__name__ under hashlibfd256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: file_digest.__name__.__eq__
  args: ["file_digest"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__module__.__eq__('hashlib') — standalone
#
# hashlib.file_digest.__module__ is 'hashlib'. The __module__ attribute on a
# Python function stores the name of the module in which the function was
# defined. Since file_digest is defined in Lib/hashlib.py, its __module__ is
# 'hashlib'. This distinguishes it from C-extension functions (like the OpenSSL
# hash constructors) whose __module__ may be '_hashlib'. file_digest's __module__
# being 'hashlib' confirms it is a pure Python function, not a C builtin.
# This is the first standalone anchor for file_digest.__module__ under hashlibfd256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra256.file_digest_module:
  description: "hashlib.file_digest.__module__.__eq__('hashlib') == True — file_digest is defined in Lib/hashlib.py so __module__=='hashlib'; contrasts with OpenSSL-backed constructors whose __module__ is '_hashlib'; __module__=='hashlib' confirms pure Python function (not C extension builtin); first standalone for file_digest.__module__ under hashlibfd256; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: file_digest.__module__.__eq__
  args: ["hashlib"]
  expected: true
