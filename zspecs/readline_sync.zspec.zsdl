invariant readline_sync.has_questionFloat:
  description: "questionFloat() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "questionFloat.constructor.name"}
  expected: "Function"

invariant readline_sync.has_questionEMail:
  description: "questionEMail() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "questionEMail.constructor.name"}
  expected: "Function"

invariant readline_sync.has_setDefaultOptions:
  description: "setDefaultOptions() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "setDefaultOptions.constructor.name"}
