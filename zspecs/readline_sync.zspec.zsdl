spec: readline_sync
version: ">=1.4.0"
backend: node(readline-sync)

docs: https://github.com/anseki/readline-sync#readme

provenance:
  derived_from:
    - "readline-sync README — https://github.com/anseki/readline-sync#readme"
    - "Test vectors verified with readline-sync via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "readline-sync source"
  notes:
    - "Synchronous prompts for CLI scripts — runs the user prompt in a blocking child shell."
    - "Install: npm install readline-sync"
    - "v1 CJS; module export is an object with question / prompt / keyIn / keyInYN / questionInt / questionFloat / questionPath / questionEMail / questionNewPassword / promptCL / promptLoop / setDefaultOptions."
    - "Spec covers the function-shape only — interactive I/O is out of scope for unit tests."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws if no TTY is available or the prompt is canceled."
  stderr: "null"
  stickiness: "Process-wide setDefaultOptions persists between calls."
  codes: {}

invariant readline_sync.has_question:
  description: "question() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "question.constructor.name"}
  expected: "Function"

invariant readline_sync.has_prompt:
  description: "prompt() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prompt.constructor.name"}
  expected: "Function"

