spec: multiprocessing_extra219
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.managers.html — multiprocessing.managers documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "multiprocessing.managers.BaseManager.__name__ == 'BaseManager' — 11 characters; module is multiprocessing.managers; verified with Python 3.14.3."
    - "multiprocessing.managers.SyncManager.__name__ == 'SyncManager' — 11 characters; module is multiprocessing.managers; verified with Python 3.14.3."
    - "multiprocessing.managers.BaseProxy.__name__ == 'BaseProxy' — 9 characters; module is multiprocessing.managers; verified with Python 3.14.3."
    - "multiprocessing.managers.Token.__name__ == 'Token' — 5 characters; module is multiprocessing.managers; verified with Python 3.14.3."
    - "multiprocessing.managers.Server.__name__ == 'Server' — 6 characters; module is multiprocessing.managers; verified with Python 3.14.3."
    - "multiprocessing.managers.NamespaceProxy.__name__ == 'NamespaceProxy' — 14 characters; module is multiprocessing.managers; verified with Python 3.14.3."
    - "All classes in multiprocessing.managers use 'multiprocessing.managers' as their __module__; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.managers BaseManager/SyncManager identity — extra219 namespace
#
# Both have __module__ == 'multiprocessing.managers'; __qualname__ == __name__.
# ---------------------------------------------------------------------------

table multiprocessing_extra219.manager_class_identity:
  description: "multiprocessing.managers BaseManager and SyncManager __name__, __module__, __qualname__ contracts in mp219mgr namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp219mgr

  columns: [id, function, args, expected, description]
  rows:
    - [base_manager_name_eq,      managers.BaseManager.__name__.__eq__,      ["BaseManager"],               true, "multiprocessing.managers.BaseManager.__name__ == 'BaseManager'; verified with Python 3.14.3"]
    - [base_manager_name_len_11,  managers.BaseManager.__name__.__len__,     [],                            11,   "multiprocessing.managers.BaseManager.__name__.__len__() == 11 — 'BaseManager' has 11 characters; verified with Python 3.14.3"]
    - [base_manager_module_eq,    managers.BaseManager.__module__.__eq__,    ["multiprocessing.managers"],  true, "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [base_manager_qualname_eq,  managers.BaseManager.__qualname__.__eq__,  ["BaseManager"],               true, "multiprocessing.managers.BaseManager.__qualname__ == 'BaseManager'; verified with Python 3.14.3"]
    - [sync_manager_name_eq,      managers.SyncManager.__name__.__eq__,      ["SyncManager"],               true, "multiprocessing.managers.SyncManager.__name__ == 'SyncManager'; verified with Python 3.14.3"]
    - [sync_manager_name_len_11,  managers.SyncManager.__name__.__len__,     [],                            11,   "multiprocessing.managers.SyncManager.__name__.__len__() == 11 — 'SyncManager' has 11 characters; verified with Python 3.14.3"]
    - [sync_manager_module_eq,    managers.SyncManager.__module__.__eq__,    ["multiprocessing.managers"],  true, "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [sync_manager_qualname_eq,  managers.SyncManager.__qualname__.__eq__,  ["SyncManager"],               true, "multiprocessing.managers.SyncManager.__qualname__ == 'SyncManager'; verified with Python 3.14.3"]

