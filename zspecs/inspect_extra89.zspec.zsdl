spec: inspect_extra89
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra88

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra88.zspec.zsdl."
    - "This spec covers: inspect.Parameter enum kind values — _ParameterKind enum member .name attributes and values (Wave 250)."
    - "inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY' — enum .name attribute returns the member name string. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD' — enum member name. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL' — enum member name. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY' — enum member name. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD' — enum member name. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' — the enum class is _ParameterKind (IntEnum). Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__qualname__ == '_ParameterKind' — module-level class; __qualname__ equals __name__. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is itself a class (type), not an instance. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__qualname__ == 'type' — Parameter.empty is a bare class object whose metaclass is type. Verified with Python 3.14.3."
    - "inspect.Parameter.__doc__.__class__.__name__ == 'str' — the docstring is a str instance. Verified with Python 3.14.3."
    - "POSITIONAL_ONLY.value == 0, POSITIONAL_OR_KEYWORD.value == 1, VAR_POSITIONAL.value == 2, KEYWORD_ONLY.value == 3, VAR_KEYWORD.value == 4. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: POSITIONAL_ONLY and POSITIONAL_OR_KEYWORD .name strings
#
# Wave 250 theme: inspect.Parameter enum kind .name attribute equality — group 1.
#
# inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY')           == True
# inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True
# inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_OR_KEYWORD')     == False (cross-check)
# inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_ONLY')     == False (cross-check)
#
# Prior spec extra87 checked Parameter class identity. This spec (extra89) checks enum kind .name. New to extra89.
# ---------------------------------------------------------------------------

table inspect_extra89.param_kind_names_group1:
  description: "POSITIONAL_ONLY/POSITIONAL_OR_KEYWORD .name strings + cross-checks; _ParameterKind IntEnum members; wave 250; new to extra89"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamkind89

  columns: [id, function, args, expected, description]
  rows:
    - [POSITIONAL_ONLY_name_eq_POSITIONAL_ONLY,
       Parameter.POSITIONAL_ONLY.name.__eq__,
       ["POSITIONAL_ONLY"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True — POSITIONAL_ONLY is a member of _ParameterKind (IntEnum) with value 0; the .name attribute of an IntEnum member returns the member's declared name as a string; __eq__('POSITIONAL_ONLY') returns True; prior spec extra87 checked Parameter.__name__.__eq__; this spec (extra89) checks enum kind .name; new to extra89"]
    - [POSITIONAL_OR_KEYWORD_name_eq_POSITIONAL_OR_KEYWORD,
       Parameter.POSITIONAL_OR_KEYWORD.name.__eq__,
       ["POSITIONAL_OR_KEYWORD"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True — POSITIONAL_OR_KEYWORD is a member of _ParameterKind with value 1; .name returns the member's declared name string; __eq__('POSITIONAL_OR_KEYWORD') returns True; new to extra89"]
    - [POSITIONAL_ONLY_name_ne_POSITIONAL_OR_KEYWORD,
       Parameter.POSITIONAL_ONLY.name.__eq__,
       ["POSITIONAL_OR_KEYWORD"],
       false,
       "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_OR_KEYWORD') == False — POSITIONAL_ONLY.name is 'POSITIONAL_ONLY', not 'POSITIONAL_OR_KEYWORD'; each enum member has a unique name; str.__eq__('POSITIONAL_OR_KEYWORD') returns False; confirms .name distinguishes POSITIONAL_ONLY from POSITIONAL_OR_KEYWORD; new to extra89"]
    - [POSITIONAL_OR_KEYWORD_name_ne_POSITIONAL_ONLY,
       Parameter.POSITIONAL_OR_KEYWORD.name.__eq__,
       ["POSITIONAL_ONLY"],
       false,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_ONLY') == False — POSITIONAL_OR_KEYWORD.name is 'POSITIONAL_OR_KEYWORD', not 'POSITIONAL_ONLY'; str.__eq__('POSITIONAL_ONLY') returns False; new to extra89"]

# ---------------------------------------------------------------------------
# Table 2: VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD .name strings
#
# Wave 250 theme: inspect.Parameter enum kind .name attribute equality — group 2.
#
# inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True
# inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY')     == True
# inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD')       == True
# inspect.Parameter.VAR_KEYWORD.name.__eq__('KEYWORD_ONLY')      == False (cross-check)
#
# No prior inspect spec checks VAR_POSITIONAL/KEYWORD_ONLY/VAR_KEYWORD .name via inspectparamkind89. New to extra89.
# ---------------------------------------------------------------------------

table inspect_extra89.param_kind_names_group2:
  description: "VAR_POSITIONAL/KEYWORD_ONLY/VAR_KEYWORD .name strings + cross-check; _ParameterKind IntEnum members; wave 250; new to extra89"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamkind89

  columns: [id, function, args, expected, description]
  rows:
    - [VAR_POSITIONAL_name_eq_VAR_POSITIONAL,
       Parameter.VAR_POSITIONAL.name.__eq__,
       ["VAR_POSITIONAL"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True — VAR_POSITIONAL is a member of _ParameterKind with value 2; it represents *args-style variadic positional parameters; .name returns the declared name string 'VAR_POSITIONAL'; __eq__('VAR_POSITIONAL') returns True; new to extra89"]
    - [KEYWORD_ONLY_name_eq_KEYWORD_ONLY,
       Parameter.KEYWORD_ONLY.name.__eq__,
       ["KEYWORD_ONLY"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True — KEYWORD_ONLY is a member of _ParameterKind with value 3; it represents parameters that must be passed as keyword arguments (after *args); .name returns 'KEYWORD_ONLY'; __eq__('KEYWORD_ONLY') returns True; new to extra89"]
    - [VAR_KEYWORD_name_eq_VAR_KEYWORD,
       Parameter.VAR_KEYWORD.name.__eq__,
       ["VAR_KEYWORD"],
       true,
       "inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True — VAR_KEYWORD is a member of _ParameterKind with value 4; it represents **kwargs-style variadic keyword parameters; .name returns 'VAR_KEYWORD'; __eq__('VAR_KEYWORD') returns True; new to extra89"]
    - [VAR_KEYWORD_name_ne_KEYWORD_ONLY,
       Parameter.VAR_KEYWORD.name.__eq__,
       ["KEYWORD_ONLY"],
       false,
       "inspect.Parameter.VAR_KEYWORD.name.__eq__('KEYWORD_ONLY') == False — VAR_KEYWORD.name is 'VAR_KEYWORD', not 'KEYWORD_ONLY'; each enum member has a unique name; str.__eq__('KEYWORD_ONLY') returns False; confirms .name distinguishes VAR_KEYWORD from KEYWORD_ONLY; new to extra89"]

# ---------------------------------------------------------------------------
# Table 3: _ParameterKind class identity checks
#
# Wave 250 theme: inspect._ParameterKind class __name__ and __qualname__ strings.
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind')     == True
# inspect.Parameter.POSITIONAL_ONLY.__class__.__qualname__.__eq__('_ParameterKind') == True
# inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind')         == True
# inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind')        == True
#
# No prior inspect spec checks _ParameterKind class identity via inspectparamkind89. New to extra89.
# ---------------------------------------------------------------------------

table inspect_extra89.parameter_kind_class_identity:
  description: "_ParameterKind __name__/_qualname__ strings for multiple enum members; wave 250; new to extra89"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamkind89

  columns: [id, function, args, expected, description]
  rows:
    - [POSITIONAL_ONLY_class_name_eq_ParameterKind,
       Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — the enum class of all _ParameterKind members is _ParameterKind (an IntEnum subclass defined in Lib/inspect.py); __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra89"]
    - [POSITIONAL_ONLY_class_qualname_eq_ParameterKind,
       Parameter.POSITIONAL_ONLY.__class__.__qualname__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__qualname__.__eq__('_ParameterKind') == True — _ParameterKind is a module-level class in Lib/inspect.py; __qualname__ equals __name__ for module-level classes; __class__.__qualname__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra89"]
    - [VAR_KEYWORD_class_name_eq_ParameterKind,
       Parameter.VAR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — all five _ParameterKind enum members share the same class _ParameterKind; VAR_KEYWORD.__class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra89"]
    - [KEYWORD_ONLY_class_name_eq_ParameterKind,
       Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY is a member of _ParameterKind IntEnum; __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra89"]

# ---------------------------------------------------------------------------
# Table 4: Parameter.empty class identity + Parameter doc class
#
# Wave 250 theme: inspect.Parameter.empty class identity and Parameter docstring class.
#
# inspect.Parameter.empty.__class__.__name__.__eq__('type')     == True
# inspect.Parameter.empty.__class__.__qualname__.__eq__('type') == True
# inspect.Parameter.__doc__.__class__.__name__.__eq__('str')    == True
# inspect.Parameter.empty.__name__.__eq__('_empty')             == True
#
# No prior inspect spec checks Parameter.empty.__class__ via inspectparamkind89. New to extra89.
# ---------------------------------------------------------------------------

table inspect_extra89.parameter_empty_and_doc:
  description: "Parameter.empty __class__ identity + Parameter __doc__ class; wave 250; new to extra89"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectparamkind89

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_empty_class_name_eq_type,
       Parameter.empty.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is a sentinel class object (not an instance) defined in Lib/inspect.py; its __class__ is type (the metaclass); __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra89"]
    - [Parameter_empty_class_qualname_eq_type,
       Parameter.empty.__class__.__qualname__.__eq__,
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__qualname__.__eq__('type') == True — Parameter.empty is a class object whose metaclass is type; type is the root metaclass; __class__.__qualname__ is 'type'; str.__eq__('type') returns True; new to extra89"]
    - [Parameter_doc_class_name_eq_str,
       Parameter.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.Parameter.__doc__.__class__.__name__.__eq__('str') == True — Parameter.__doc__ is the docstring for the Parameter class, which is a str instance; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra89"]
    - [Parameter_empty_name_eq_empty,
       Parameter.empty.__name__.__eq__,
       ["_empty"],
       true,
       "inspect.Parameter.empty.__name__.__eq__('_empty') == True — Parameter.empty is a sentinel class named '_empty' in Lib/inspect.py; its __name__ attribute is '_empty'; str.__eq__('_empty') returns True; new to extra89"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra89
# ---------------------------------------------------------------------------

invariant inspect_extra89.POSITIONAL_ONLY_name_eq_POSITIONAL_ONLY:
  description: "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True — POSITIONAL_ONLY enum member .name is 'POSITIONAL_ONLY'; wave 250; new to extra89"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.name.__eq__
  args: ["POSITIONAL_ONLY"]
  expected: true

invariant inspect_extra89.VAR_POSITIONAL_name_eq_VAR_POSITIONAL:
  description: "inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True — VAR_POSITIONAL enum member .name is 'VAR_POSITIONAL'; wave 250; new to extra89"
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.name.__eq__
  args: ["VAR_POSITIONAL"]
  expected: true

invariant inspect_extra89.VAR_KEYWORD_name_eq_VAR_KEYWORD:
  description: "inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True — VAR_KEYWORD enum member .name is 'VAR_KEYWORD'; wave 250; new to extra89"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.name.__eq__
  args: ["VAR_KEYWORD"]
  expected: true

invariant inspect_extra89.POSITIONAL_ONLY_class_name_eq_ParameterKind:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — enum member class is _ParameterKind; wave 250; new to extra89"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra89.Parameter_empty_class_name_eq_type:
  description: "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is a class whose metaclass is type; wave 250; new to extra89"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true
