spec: itertools_extra55
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra54.zspec.zsdl."
    - "Prior specs covered __class__.__module__.__eq__('builtins') for: groupby/chain/compress/islice/zip_longest/product (extra48). Not yet covered: count/cycle/repeat/accumulate/combinations/permutations/starmap/dropwhile/takewhile/filterfalse/combinations_with_replacement."
    - "Prior specs covered __doc__.__class__.__qualname__.__eq__('str') for: accumulate/combinations and itertools module (extra50); chain.from_iterable (extra51). Not yet covered: groupby/chain/count/product/cycle/repeat __doc__.__class__.__qualname__."
    - "No prior itertools spec records itertools.__loader__.__name__.__eq__('BuiltinImporter') or itertools.__loader__.__class__.__name__.__eq__('type') or itertools.__loader__.__class__.__module__.__eq__('builtins')."
    - "This spec covers: itertools.count/__class__.__module__.__eq__('builtins')==true; itertools.cycle/__class__.__module__.__eq__('builtins')==true; itertools.repeat/__class__.__module__.__eq__('builtins')==true; itertools.accumulate/__class__.__module__.__eq__('builtins')==true; itertools.combinations/__class__.__module__.__eq__('builtins')==true; itertools.permutations/__class__.__module__.__eq__('builtins')==true; itertools.__loader__.__name__.__eq__('BuiltinImporter')==true; itertools.__loader__.__class__.__name__.__eq__('type')==true; itertools.__loader__.__class__.__module__.__eq__('builtins')==true; itertools.groupby.__doc__.__class__.__qualname__.__eq__('str')==true; itertools.chain.__doc__.__class__.__qualname__.__eq__('str')==true; itertools.count.__doc__.__class__.__qualname__.__eq__('str')==true; itertools.product.__doc__.__class__.__qualname__.__eq__('str')==true."
    - "Key findings: All itertools C-extension types have their metaclass as the built-in 'type'; type.__module__ == 'builtins' (8 chars). count/cycle/repeat/accumulate/combinations/permutations complete the set started in extra48 for __class__.__module__=='builtins'. The itertools module is a C-extension loaded by _frozen_importlib.BuiltinImporter (not SourceFileLoader like pure-Python modules); itertools.__loader__.__name__ == 'BuiltinImporter' (15 chars) and the loader itself is a class so its __class__ is 'type' from builtins. itertools C-type docstrings are str objects; str.__qualname__ == 'str' extends the __class__.__name__ == 'str' coverage from extra49 with the qualname dimension for groupby/chain/count/product. All fourteen invariants are new to extra55."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools type __class__.__module__ == 'builtins' — extra55
#
# All itertools types are C-level types defined in Modules/itertoolsmodule.c.
# Their metaclass is the built-in 'type' (the universal Python metaclass).
# type.__module__ == 'builtins' (8 chars) because 'type' is defined in the
# C runtime builtins module. Prior extra48 covered groupby/chain/compress/
# islice/zip_longest/product but not count/cycle/repeat/accumulate/combinations/
# permutations. All six checks below are new to extra55.
# ---------------------------------------------------------------------------

table itertools_extra55.class_module_builtins:
  description: "itertools type __class__.__module__ == 'builtins' — C-level types have metaclass 'type'; type.__module__ == 'builtins' (8 chars); extra48 covered groupby/chain/compress/islice/zip_longest/product; count/cycle/repeat/accumulate/combinations/permutations are new to extra55"
  kind: python_call_eq
  category: class_identity
  id_prefix: itertmod55

  columns: [id, function, args, expected, description]
  rows:
    - [count_class_module,
       count.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.count.__class__.__module__ == 'builtins' — count is a C-level type in Modules/itertoolsmodule.c that counts up from a start value with an optional step; its metaclass is the built-in 'type'; type.__module__ == 'builtins' (8 chars); prior extra48 established this pattern for groupby/chain/compress/islice/zip_longest/product but not count; new to extra55"]
    - [cycle_class_module,
       cycle.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.cycle.__class__.__module__ == 'builtins' — cycle is a C-level type in Modules/itertoolsmodule.c that cycles indefinitely through an iterable; its metaclass is the built-in 'type'; type.__module__ == 'builtins' (8 chars); prior extra48 established this pattern for six types but not cycle; new to extra55"]
    - [repeat_class_module,
       repeat.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.repeat.__class__.__module__ == 'builtins' — repeat is a C-level type in Modules/itertoolsmodule.c that repeats an object a specified number of times (or indefinitely); its metaclass is the built-in 'type'; type.__module__ == 'builtins' (8 chars); prior extra48 established this pattern for six types but not repeat; new to extra55"]
    - [accumulate_class_module,
       accumulate.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.accumulate.__class__.__module__ == 'builtins' — accumulate is a C-level type in Modules/itertoolsmodule.c that yields accumulated sums (or other binary function results) from an iterable; its metaclass is the built-in 'type'; type.__module__ == 'builtins' (8 chars); prior extra48 established this pattern for six types but not accumulate; new to extra55"]
    - [combinations_class_module,
       combinations.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.combinations.__class__.__module__ == 'builtins' — combinations is a C-level type in Modules/itertoolsmodule.c that yields r-length subsequences of elements without replacement; its metaclass is the built-in 'type'; type.__module__ == 'builtins' (8 chars); prior extra48 established this pattern for six types but not combinations; new to extra55"]
    - [permutations_class_module,
       permutations.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.permutations.__class__.__module__ == 'builtins' — permutations is a C-level type in Modules/itertoolsmodule.c that yields successive r-length permutations of elements; its metaclass is the built-in 'type'; type.__module__ == 'builtins' (8 chars); prior extra48 established this pattern for six types but not permutations; new to extra55"]

# ---------------------------------------------------------------------------
# itertools.__loader__ class identity — extra55
#
# itertools is a C-extension module loaded by _frozen_importlib.BuiltinImporter,
# not by the SourceFileLoader used for pure-Python modules. itertools.__loader__
# is the BuiltinImporter class itself (not an instance — the class is its own
# loader). Its __name__ attribute (the class name) is 'BuiltinImporter' (15 chars).
# Since BuiltinImporter is a class, its __class__ is the built-in 'type'
# metaclass; type.__module__ == 'builtins' (8 chars) and type.__name__ == 'type'
# (4 chars). No prior itertools spec records __loader__.__name__,
# __loader__.__class__.__name__, or __loader__.__class__.__module__. New to extra55.
# ---------------------------------------------------------------------------

table itertools_extra55.loader_class_identity:
  description: "itertools.__loader__ is BuiltinImporter — a C-extension module loader; __loader__.__name__=='BuiltinImporter'; __loader__.__class__.__name__=='type'; __loader__.__class__.__module__=='builtins'; not recorded in any prior itertools spec; new to extra55"
  kind: python_call_eq
  category: class_identity
  id_prefix: itertmod55

  columns: [id, function, args, expected, description]
  rows:
    - [loader_name,
       __loader__.__name__.__eq__,
       ["BuiltinImporter"],
       true,
       "itertools.__loader__.__name__ == 'BuiltinImporter' — itertools is a C-extension module loaded by _frozen_importlib.BuiltinImporter; the loader object is the BuiltinImporter class itself; its __name__ attribute (the class name) is 'BuiltinImporter' (15 chars); this distinguishes itertools from pure-Python modules whose __loader__.__class__.__name__ is 'SourceFileLoader'; no prior itertools spec records __loader__.__name__; new to extra55"]
    - [loader_class_name,
       __loader__.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__ == 'type' — itertools.__loader__ is the BuiltinImporter class object; since it is a class, its __class__ is the built-in 'type' metaclass (the class of all classes in Python); type.__name__ == 'type' (4 chars); no prior itertools spec records __loader__.__class__.__name__; new to extra55"]
    - [loader_class_module,
       __loader__.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "itertools.__loader__.__class__.__module__ == 'builtins' — itertools.__loader__ is the BuiltinImporter class; its __class__ is 'type'; type is a C runtime built-in so type.__module__ == 'builtins' (8 chars); no prior itertools spec records __loader__.__class__.__module__; new to extra55"]

# ---------------------------------------------------------------------------
# itertools type __doc__.__class__.__qualname__ == 'str' — extra55
#
# itertools C-extension type docstrings are Python str objects created from
# C-level tp_doc slots. Since __doc__ is a Python str, its __class__ is the
# str built-in type. str is a top-level type with no enclosing class scope,
# so str.__qualname__ == str.__name__ == 'str' (3 chars). Prior extra50 covered
# accumulate and combinations for this __qualname__ dimension. Prior extra51
# covered chain.from_iterable. No prior spec records __doc__.__class__.__qualname__
# for groupby, chain, count, or product. All four checks below are new to extra55.
# ---------------------------------------------------------------------------

table itertools_extra55.doc_class_qualname_eq:
  description: "itertools type __doc__.__class__.__qualname__ == 'str' — C-extension type docstrings are str objects; str.__qualname__ == 'str' (3 chars; top-level type); extra50 covered accumulate/combinations; groupby/chain/count/product are new to extra55"
  kind: python_call_eq
  category: class_identity
  id_prefix: itertmod55

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_doc_class_qualname,
       groupby.__doc__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "itertools.groupby.__doc__.__class__.__qualname__ == 'str' — groupby is a C-level type whose __doc__ is a Python str object (created from the C-level tp_doc slot); the str built-in type is a top-level type with no enclosing class scope so __qualname__ == __name__ == 'str' (3 chars); prior extra50 established this pattern for accumulate and combinations but not groupby; new to extra55"]
    - [chain_doc_class_qualname,
       chain.__doc__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__qualname__ == 'str' — chain is a C-level type whose __doc__ is a Python str object; the str built-in type has __qualname__ == 'str' (3 chars; top-level type, no dotted prefix); prior extra50 established this pattern for accumulate and combinations but not chain; new to extra55"]
    - [count_doc_class_qualname,
       count.__doc__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "itertools.count.__doc__.__class__.__qualname__ == 'str' — count is a C-level type that counts up from a start value; its __doc__ is a Python str object; str.__qualname__ == 'str' (3 chars; top-level built-in type); prior extra50 established this pattern for accumulate and combinations but not count; new to extra55"]
    - [product_doc_class_qualname,
       product.__doc__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "itertools.product.__doc__.__class__.__qualname__ == 'str' — product is a C-level type that yields the Cartesian product of input iterables; its __doc__ is a Python str object; str.__qualname__ == 'str' (3 chars; top-level built-in type); prior extra50 established this pattern for accumulate and combinations but not product; new to extra55"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra55
# ---------------------------------------------------------------------------

invariant itertools_extra55.count_metaclass_builtins:
  description: "count metaclass is 'type' from builtins — C-level type; type.__module__ == 'builtins'; completes the set begun in extra48 for __class__.__module__"
  kind: python_call_eq
  function: count.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant itertools_extra55.loader_is_BuiltinImporter:
  description: "itertools module loader is BuiltinImporter — distinguishes C-extension modules from pure-Python (SourceFileLoader) modules; __loader__.__name__ == 'BuiltinImporter'"
  kind: python_call_eq
  function: __loader__.__name__.__eq__
  args: ["BuiltinImporter"]
  expected: true

invariant itertools_extra55.groupby_doc_qualname_str:
  description: "groupby docstring type qualname is 'str' — str is a top-level built-in type; __qualname__ == __name__ == 'str' (3 chars); extends extra50's accumulate/combinations coverage"
  kind: python_call_eq
  function: groupby.__doc__.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true
