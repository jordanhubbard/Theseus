    - ["cf3136010", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__getitem__"], false]
    - ["cf3136011", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__getitem__"], false]
    - ["cf3136012", operator.contains, [concurrent.futures.Executor.__dict__,            "__getitem__"], false]

# ---------------------------------------------------------------------------
# combined — __call__, __len__, __getitem__ across all 4 concurrent.futures subjects
#
# Covers the full matrix: 4 classes x 3 methods = 12 rows.
# __call__:    false for all 4 — no callable protocol defined anywhere.
# __len__:     false for all 4 — no sized protocol defined anywhere.
# __getitem__: false for all 4 — no subscript protocol defined anywhere.
# All 12 values in this matrix are false.
# concurrent.futures is a minimal concurrency API: submit work, await results.
# None of the three Python data-model protocols tested here (callable, sized,
# subscriptable) are part of that API.
# Cross-wave summary for cf subjects:
#   Wave 652 (cf3076): __get__/__set__/__delete__ — all false for all 4.
#   Wave 653 (cf3091): __hash__/__eq__/__bool__ — all false for all 4.
#   Wave 654 (cf3106): __lt__/__le__/__gt__ — all false for all 4.
#   Wave 655 (cf3121): __ge__ false; __repr__ true only for Future; __str__ false.
#   Wave 656 (cf3136): __call__/__len__/__getitem__ — all false for all 4.
# ---------------------------------------------------------------------------

