spec: threading_extra721
version: ">=3.9"
backend: python_module(threading)
docs: "Behavioral specs for threading.Lock, RLock, and synchronization primitive identity"
error_model: python_exceptions
provenance:
  derived_from: "python stdlib threading module"
  not_derived_from: "any third-party library"
  notes: "Covers threading.Lock and RLock class identity, Semaphore, BoundedSemaphore, Barrier, Condition, and Event qualname/module identity"
  created_at: "2026-04-12"

table threading_extra721.lock_identity:
  description: "Identity checks for threading.Lock and RLock class types"
  kind: python_call_eq
  category: identity
  id_prefix: th721lk
  columns: [id, function, args, expected]
  rows:
    - [th721lk001, threading.Lock.__class__.__name__.__eq__, ["type"], true]
    - [th721lk002, threading.RLock.__class__.__name__.__eq__, ["type"], true]

table threading_extra721.semaphore_identity:
  description: "Identity checks for threading.Semaphore and BoundedSemaphore"
  kind: python_call_eq
  category: identity
  id_prefix: th721sm
  columns: [id, function, args, expected]
  rows:
    - [th721sm001, threading.Semaphore.__qualname__.__eq__, ["Semaphore"], true]
    - [th721sm002, threading.Semaphore.__module__.__eq__, ["threading"], true]
    - [th721sm003, threading.BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"], true]
    - [th721sm004, threading.BoundedSemaphore.__module__.__eq__, ["threading"], true]

table threading_extra721.sync_primitives:
  description: "Identity checks for threading.Barrier, Condition, and Event"
  kind: python_call_eq
  category: identity
  id_prefix: th721sy
  columns: [id, function, args, expected]
  rows:
    - [th721sy001, threading.Barrier.__qualname__.__eq__, ["Barrier"], true]
    - [th721sy002, threading.Barrier.__module__.__eq__, ["threading"], true]
    - [th721sy003, threading.Barrier.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [th721sy004, threading.Condition.__qualname__.__eq__, ["Condition"], true]
    - [th721sy005, threading.Condition.__module__.__eq__, ["threading"], true]
    - [th721sy006, threading.Event.__qualname__.__eq__, ["Event"], true]
