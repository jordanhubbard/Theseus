spec: io3316
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 668 (io3316): __ipow__, __ilshift__, __irshift__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __ipow__, __ilshift__, __irshift__ dict-presence (in-place **=, <<=, >>=)."
    - "No io class defines __ipow__ in its own __dict__: stream I/O classes are sequential I/O abstractions, not numeric types, and do not implement in-place exponentiation."
    - "No io class defines __ilshift__ in its own __dict__: stream I/O classes do not implement in-place left-shift; bitwise shift operators have no meaning for I/O streams."
    - "No io class defines __irshift__ in its own __dict__: stream I/O classes do not implement in-place right-shift; augmented assignment operators have no meaning for I/O streams."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with waves 666/667 pattern: all in-place arithmetic/bitwise operators absent from io class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ipow__ dict-presence — operator.contains(Cls.__dict__, '__ipow__')
#
# No io class defines __ipow__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not numeric types,
# and do not implement the in-place exponentiation operator (**=).
# ---------------------------------------------------------------------------

table io3316.ipow:
  description: "io types __ipow__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3316

  columns: [id, function, args, expected]
  rows:
    - ["io3316001", operator.contains, [io.RawIOBase.__dict__,       "__ipow__"], false]
    - ["io3316002", operator.contains, [io.BufferedIOBase.__dict__,  "__ipow__"], false]
    - ["io3316003", operator.contains, [io.TextIOBase.__dict__,      "__ipow__"], false]
    - ["io3316004", operator.contains, [io.FileIO.__dict__,          "__ipow__"], false]
