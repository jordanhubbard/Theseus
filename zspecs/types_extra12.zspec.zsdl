spec: types_extra12
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types.zspec.zsdl — covers __name__ for FunctionType/MethodType/ModuleType/NoneType/GeneratorType/MappingProxyType/SimpleNamespace/LambdaType/CoroutineType/AsyncGeneratorType/UnionType"
    - "types_extra.zspec.zsdl — covers __name__ for CodeType/BuiltinFunctionType/TracebackType/FrameType"
    - "types_extra2.zspec.zsdl — covers __module__ and __bases__[0].__name__ for major types"
    - "types_extra4.zspec.zsdl — covers __name__/__module__ table for FunctionType/CodeType/MethodType"
    - "types_extra5.zspec.zsdl — covers __qualname__ for FunctionType/MethodType/GeneratorType/CoroutineType/ModuleType; BuiltinFunctionType/AsyncGeneratorType/LambdaType/SimpleNamespace/MappingProxyType/DynamicClassAttribute"
    - "types_extra6.zspec.zsdl — covers __qualname__ for CellType/CodeType/FrameType/TracebackType/NoneType/EllipsisType/NotImplementedType; __bases__[0] for BuiltinFunctionType/LambdaType/MappingProxyType/CellType"
    - "types_extra7.zspec.zsdl — covers GenericAlias/UnionType/descriptor types __name__/__qualname__/__module__"
    - "types_extra8.zspec.zsdl — covers descriptor types __module__/__bases__[0]; CapsuleType; DynamicClassAttribute/__name__/__module__; SimpleNamespace/__bases__[0]; UnionType/__bases__[0]"
    - "types_extra9.zspec.zsdl — covers __name__.__eq__ for FunctionType/LambdaType/CodeType/MethodType as individual invariants"
    - "types_extra10.zspec.zsdl — covers __bases__.__len__ == 1 for FunctionType/LambdaType/CodeType/MethodType"
    - "types_extra11.zspec.zsdl — covers __name__.__len__ for FunctionType/MethodType/ModuleType/GeneratorType/CoroutineType/SimpleNamespace/MappingProxyType; MRO[0] self-identity for FunctionType/ModuleType/SimpleNamespace; MappingProxyType/NoneType standalone __module__"
  notes:
    - "This spec covers MRO[0] self-identity for additional types not checked in types_extra11."
    - "types_extra11 covers FunctionType/ModuleType/SimpleNamespace MRO[0].__name__; no spec covers MethodType/GeneratorType/CoroutineType MRO[0]."
    - "NOT yet covered: types.MethodType.__mro__[0].__name__ == 'method' — MRO[0] is the class itself."
    - "NOT yet covered: types.GeneratorType.__mro__[0].__name__ == 'generator' — MRO[0] is the class itself."
    - "NOT yet covered: types.CoroutineType.__mro__[0].__name__ == 'coroutine' — MRO[0] is the class itself."
    - "NOT yet covered: types.AsyncGeneratorType.__mro__[0].__name__ == 'async_generator' — MRO[0] self-identity."
    - "NOT yet covered: types.CodeType.__mro__[0].__name__ == 'code' — MRO[0] self-identity."
    - "NOT yet covered: types.TracebackType.__mro__[0].__name__ == 'traceback' — MRO[0] self-identity."
    - "NOT yet covered: types.FrameType.__mro__[0].__name__ == 'frame' — MRO[0] self-identity."
    - "NOT yet covered: types.NoneType.__mro__[0].__name__ == 'NoneType' — MRO[0] self-identity."
    - "NOT yet covered: types.GeneratorType.__name__.__len__() == 9 (via __len__ method, not just __eq__)."
    - "NOT yet covered: types.AsyncGeneratorType.__name__.__len__() == 15 — 'async_generator' is 15 chars."
    - "NOT yet covered: types.BuiltinFunctionType.__name__.__len__() == 17 — 'builtin_function_or_method' ... wait, that is 26."
    - "types.AsyncGeneratorType.__name__ == 'async_generator' (15 characters)."
    - "types.BuiltinFunctionType.__name__ == 'builtin_function_or_method' (26 characters)."
    - "types.TracebackType.__name__ == 'traceback' (9 characters)."
    - "types.FrameType.__name__ == 'frame' (5 characters)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO[0] self-identity — MethodType, GeneratorType, CoroutineType
#
# types_extra11 covers MRO[0] for FunctionType/ModuleType/SimpleNamespace.
# No prior types spec checks MRO[0] for MethodType, GeneratorType, or CoroutineType.
# ---------------------------------------------------------------------------

invariant types_extra12.MethodType.mro_first:
  description: "types.MethodType.__mro__[0].__name__ == 'method' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: MethodType.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "method"

invariant types_extra12.GeneratorType.mro_first:
  description: "types.GeneratorType.__mro__[0].__name__ == 'generator' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: GeneratorType.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "generator"

invariant types_extra12.CoroutineType.mro_first:
  description: "types.CoroutineType.__mro__[0].__name__ == 'coroutine' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: CoroutineType.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "coroutine"

invariant types_extra12.AsyncGeneratorType.mro_first:
  description: "types.AsyncGeneratorType.__mro__[0].__name__ == 'async_generator' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: AsyncGeneratorType.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "async_generator"

invariant types_extra12.CodeType.mro_first:
  description: "types.CodeType.__mro__[0].__name__ == 'code' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: CodeType.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "code"

invariant types_extra12.TracebackType.mro_first:
  description: "types.TracebackType.__mro__[0].__name__ == 'traceback' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: TracebackType.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "traceback"

invariant types_extra12.FrameType.mro_first:
  description: "types.FrameType.__mro__[0].__name__ == 'frame' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: FrameType.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "frame"

invariant types_extra12.NoneType.mro_first:
  description: "types.NoneType.__mro__[0].__name__ == 'NoneType' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: NoneType.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "NoneType"

# ---------------------------------------------------------------------------
# __name__ string lengths — additional types not covered in types_extra11
#
# types_extra11 covers FunctionType/MethodType/ModuleType/GeneratorType/CoroutineType/
# SimpleNamespace/MappingProxyType name lengths.
# New here: AsyncGeneratorType, TracebackType, FrameType, BuiltinFunctionType.
# ---------------------------------------------------------------------------

table types_extra12.class_name_lengths:
  kind: python_call_eq
  category: class_names
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [AsyncGeneratorType,    AsyncGeneratorType.__name__.__len__,    [], 15]
    - [TracebackType,         TracebackType.__name__.__len__,         [], 9]
    - [FrameType,             FrameType.__name__.__len__,             [], 5]
    - [BuiltinFunctionType,   BuiltinFunctionType.__name__.__len__,   [], 26]
