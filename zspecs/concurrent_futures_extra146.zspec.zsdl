spec: concurrent_futures_extra146
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec covers concurrent.futures module loader and package attributes, and __dict__ sizes for Future, ThreadPoolExecutor, and ProcessPoolExecutor. concurrent.futures.__loader__.__class__.__name__=='SourceFileLoader' (len=16: concurrent.futures is loaded from a .py file, unlike abc which is frozen). concurrent.futures.__package__=='concurrent.futures' (len=18). concurrent.futures.__spec__.parent=='concurrent.futures' (len=18: the parent is the package itself since concurrent.futures is a sub-package). concurrent.futures.Future.__dict__.__len__()==21 (mappingproxy). concurrent.futures.ThreadPoolExecutor.__dict__.__len__()==12 (mappingproxy). concurrent.futures.ProcessPoolExecutor.__dict__.__len__()==15 (mappingproxy). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__spec__.parent is 'concurrent.futures' (same as __package__ and __name__) because concurrent.futures is itself a package (has __init__.py) under the namespace package 'concurrent'. The __spec__.parent attribute holds the parent package name for subpackages. concurrent.futures.Future.__dict__.__len__()==21 (more entries than ThreadPoolExecutor at 12, fewer than ProcessPoolExecutor at 15). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures module loader and package — extra146
#
# concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16)
# concurrent.futures.__package__.__eq__('concurrent.futures') == True (len=18)
# concurrent.futures.__spec__.parent.__eq__('concurrent.futures') == True (len=18)
# concurrent.futures.__spec__.parent.__len__() == 18
# ---------------------------------------------------------------------------

table concurrent_futures_extra146.cf_loader_and_package:
  description: "concurrent.futures module loader and package attribute checks in cf_ldr146 namespace — concurrent.futures.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True (len=16: 'SourceFileLoader'=16 chars; concurrent.futures is loaded from a .py source file, unlike abc which is a frozen module with a FrozenImporter; SourceFileLoader reads and compiles the source file on import); concurrent.futures.__loader__.__class__.__name__.__len__()==16; concurrent.futures.__package__.__eq__('concurrent.futures')==True (len=18: 'concurrent.futures' is 18 chars; the __package__ equals the full sub-package name); concurrent.futures.__spec__.parent.__eq__('concurrent.futures')==True (len=18: for a package, __spec__.parent equals the package name itself — compare to submodules where parent is the containing package); concurrent.futures.__spec__.parent.__len__()==18; verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: cf_ldr146

  columns: [id, function, args, expected, description]
  rows:
    - [ldr_cls_eq,     "concurrent.futures.__loader__.__class__.__name__.__eq__",  ["SourceFileLoader"],    true,  "concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader' (len=16); verified with Python 3.14.3"]
    - [ldr_cls_len,    "concurrent.futures.__loader__.__class__.__name__.__len__",  [],                      16,    "concurrent.futures.__loader__.__class__.__name__.__len__() == 16 ('SourceFileLoader'); verified with Python 3.14.3"]
    - [pkg_eq,         "concurrent.futures.__package__.__eq__",                    ["concurrent.futures"],  true,  "concurrent.futures.__package__ == 'concurrent.futures' (len=18); verified with Python 3.14.3"]
    - [pkg_len,        "concurrent.futures.__package__.__len__",                    [],                      18,    "concurrent.futures.__package__.__len__() == 18; verified with Python 3.14.3"]
    - [spec_par_eq,    "concurrent.futures.__spec__.parent.__eq__",                ["concurrent.futures"],  true,  "concurrent.futures.__spec__.parent == 'concurrent.futures' (len=18); verified with Python 3.14.3"]
    - [spec_par_len,   "concurrent.futures.__spec__.parent.__len__",                [],                      18,    "concurrent.futures.__spec__.parent.__len__() == 18; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures class __dict__ sizes — extra146
#
# concurrent.futures.Future.__dict__.__len__()             == 21
# concurrent.futures.Future.__dict__.__class__.__name__    == 'mappingproxy'
# concurrent.futures.ThreadPoolExecutor.__dict__.__len__() == 12
# concurrent.futures.ProcessPoolExecutor.__dict__.__len__() == 15
# ---------------------------------------------------------------------------

table concurrent_futures_extra146.cf_class_dict_sizes:
  description: "concurrent.futures class __dict__ size checks in cf_ldr146 namespace — concurrent.futures.Future.__dict__.__len__()==21 (21 entries in the Future class namespace mappingproxy; Future is defined in concurrent.futures._base and has the most entries: result, exception, cancel, cancelled, running, done, add_done_callback, set_result, set_exception, set_running_or_notify_cancel, and others); concurrent.futures.Future.__dict__.__class__.__name__.__eq__('mappingproxy')==True; concurrent.futures.ThreadPoolExecutor.__dict__.__len__()==12 (12 entries; the fewest of the three executor classes; TPE defines submit, map, shutdown, __init__, __enter__, __exit__, and a few more); concurrent.futures.ThreadPoolExecutor.__dict__.__class__.__name__.__eq__('mappingproxy')==True; concurrent.futures.ProcessPoolExecutor.__dict__.__len__()==15 (15 entries; 3 more than ThreadPoolExecutor; PPE overrides map, submit, shutdown, and adds process-specific methods); concurrent.futures.ProcessPoolExecutor.__dict__.__class__.__name__.__eq__('mappingproxy')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cf_dict146

  columns: [id, function, args, expected, description]
  rows:
    - [fut_dict_len,   "concurrent.futures.Future.__dict__.__len__",                          [],              21,    "concurrent.futures.Future.__dict__.__len__() == 21; verified with Python 3.14.3"]
    - [fut_dict_cls,   "concurrent.futures.Future.__dict__.__class__.__name__.__eq__",        ["mappingproxy"], true,  "concurrent.futures.Future.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [tpe_dict_len,   "concurrent.futures.ThreadPoolExecutor.__dict__.__len__",              [],              12,    "concurrent.futures.ThreadPoolExecutor.__dict__.__len__() == 12; verified with Python 3.14.3"]
    - [tpe_dict_cls,   "concurrent.futures.ThreadPoolExecutor.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true, "concurrent.futures.ThreadPoolExecutor.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [ppe_dict_len,   "concurrent.futures.ProcessPoolExecutor.__dict__.__len__",             [],              15,    "concurrent.futures.ProcessPoolExecutor.__dict__.__len__() == 15; verified with Python 3.14.3"]
    - [ppe_dict_cls,   "concurrent.futures.ProcessPoolExecutor.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true, "concurrent.futures.ProcessPoolExecutor.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra146
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra146.cf_loader_is_sourcefileloader:
  description: "concurrent.futures.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — concurrent.futures.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars); concurrent.futures is loaded from a Python source file (Lib/concurrent/futures/__init__.py) using SourceFileLoader, which is the standard file-based loader for .py files; this contrasts with abc.__loader__.__class__.__name__=='type' (FrozenImporter for frozen modules); concurrent.futures.__loader__.__class__.__name__.__len__()==16; concurrent.futures.__package__=='concurrent.futures' (len=18); concurrent.futures.__spec__.parent=='concurrent.futures' (len=18); NEW in extra146: first standalone concurrent.futures loader class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__loader__.__class__.__name__.__eq__"
  args: ["SourceFileLoader"]
  expected: true

invariant concurrent_futures_extra146.cf_loader_class_name_len_16:
  description: "concurrent.futures.__loader__.__class__.__name__.__len__() == 16 — concurrent.futures.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars: 'Source'=6+'File'=4+'Loader'=6=16); this is the same loader class name length as multiprocessing.__loader__.__class__.__name__.__len__()==16 (also 'SourceFileLoader'); both modules are loaded from .py files; abc is unique in this batch using a FrozenImporter; concurrent.futures.__package__.__len__()==18; concurrent.futures.__spec__.parent.__len__()==18; NEW in extra146: first standalone concurrent.futures loader class name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__loader__.__class__.__name__.__len__"
  args: []
  expected: 16

invariant concurrent_futures_extra146.cf_spec_parent_len_18:
  description: "concurrent.futures.__spec__.parent.__len__() == 18 — concurrent.futures.__spec__.parent is 'concurrent.futures' (18 chars: 'concurrent'=10+'.'=1+'futures'=7=18); for a package, __spec__.parent equals the package's own fully-qualified name (not the name of an enclosing package); concurrent.futures.__package__.__len__()==18 also; concurrent.futures is a sub-package of the 'concurrent' namespace package, but __spec__.parent reflects its own full name; concurrent.futures.__spec__.name.__len__()==18 (same as parent); NEW in extra146: first standalone concurrent.futures __spec__.parent length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__spec__.parent.__len__"
  args: []
  expected: 18

invariant concurrent_futures_extra146.cf_future_dict_len_21:
  description: "concurrent.futures.Future.__dict__.__len__() == 21 — concurrent.futures.Future.__dict__ has 21 entries (a mappingproxy of the Future class namespace); Future is the central class of the concurrent.futures API and defines the most methods: result(), exception(), cancel(), cancelled(), running(), done(), add_done_callback(), remove_done_callback(), set_result(), set_exception(), set_running_or_notify_cancel(), and class-level attributes; concurrent.futures.Future.__dict__.__class__.__name__=='mappingproxy'; concurrent.futures.Future.__module__=='concurrent.futures._base' (the implementation file); compared to ThreadPoolExecutor at 12 and ProcessPoolExecutor at 15, Future has the most __dict__ entries; NEW in extra146: first standalone concurrent.futures.Future __dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.__dict__.__len__"
  args: []
  expected: 21

invariant concurrent_futures_extra146.cf_tpe_dict_len_12:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__len__() == 12 — concurrent.futures.ThreadPoolExecutor.__dict__ has 12 entries (a mappingproxy of the TPE class namespace); ThreadPoolExecutor defines: __init__, submit, map (inherited from Executor but shown as 'Executor.map' in qualname), __enter__, __exit__, shutdown, and several private helper methods; concurrent.futures.ThreadPoolExecutor.__dict__.__class__.__name__=='mappingproxy'; this is the fewest entries among the three classes in this spec (Future=21, TPE=12, PPE=15); concurrent.futures.ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25); NEW in extra146: first standalone concurrent.futures.ThreadPoolExecutor __dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__dict__.__len__"
  args: []
  expected: 12

invariant concurrent_futures_extra146.cf_ppe_dict_len_15:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__len__() == 15 — concurrent.futures.ProcessPoolExecutor.__dict__ has 15 entries (a mappingproxy of the PPE class namespace); ProcessPoolExecutor has more __dict__ entries than ThreadPoolExecutor (15 vs 12) because PPE overrides map() directly (unlike TPE which inherits Executor.map) and includes additional process-specific methods and attributes; concurrent.futures.ProcessPoolExecutor.__dict__.__class__.__name__=='mappingproxy'; concurrent.futures.ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26); Future.__dict__.__len__()==21 (most entries); TPE.__dict__.__len__()==12 (fewest); NEW in extra146: first standalone concurrent.futures.ProcessPoolExecutor __dict__ length invariant in this namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__dict__.__len__"
  args: []
  expected: 15
