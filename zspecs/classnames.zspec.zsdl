spec: classnames
version: ">=2.0.0"
backend: node(classnames)

docs: https://www.npmjs.com/package/classnames

provenance:
  derived_from:
    - "classnames README — https://www.npmjs.com/package/classnames"
    - "Test vectors verified with classnames via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "classnames source"
  notes:
    - "classnames is an npm package. Install: npm install classnames"
    - "cx(args) joins CSS class names; strings are included, objects include keys where value is truthy."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns joined class name string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table classnames.cx:
  kind: node_module_call_eq
  function: ~
  category: format
  id_prefix: cx

  columns: [id, args, expected]
  rows:
    - [strings, ["foo", "bar"],                           "foo bar"]
    - [object,  [{"foo": true, "bar": false, "baz": true}], "foo baz"]
    - [mixed,   ["foo", {"bar": true}],                    "foo bar"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:16:17Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
