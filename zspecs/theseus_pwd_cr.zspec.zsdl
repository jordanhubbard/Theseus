spec: theseus_pwd_cr
version: ">=3.8"
backend: python_cleanroom(theseus_pwd_cr)
blocks: pwd

docs: https://docs.python.org/3/library/pwd.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pwd.html"
  not_derived_from:
    - "CPython source: Modules/pwdmodule.c"
  notes:
    - "Clean-room pwd module. Do NOT import pwd."

error_model: python_exceptions

invariant theseus_pwd_cr.pwd2_getpwuid:
  description: "getpwuid(os.getuid()) returns a passwd entry"
  category: behavior
  kind: python_call_eq
  function: pwd2_getpwuid
  args: []
  expected: true

invariant theseus_pwd_cr.pwd2_struct_passwd:
  description: "struct_passwd has pw_name and pw_uid fields"
  category: behavior
  kind: python_call_eq
  function: pwd2_struct_passwd
  args: []
  expected: true

invariant theseus_pwd_cr.pwd2_getpwall:
  description: "getpwall() returns a non-empty list"
  category: behavior
  kind: python_call_eq
  function: pwd2_getpwall
  args: []
  expected: true
