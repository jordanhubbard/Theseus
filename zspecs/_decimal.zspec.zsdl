spec: _decimal
version: ">=3.3"
backend: python_module(_decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic Specification, Version 1.72"
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "_decimal is the C accelerator for the decimal module; when available it replaces the pure-Python _pydecimal."
    - "Decimal.__module__ == '_decimal' on CPython when the C accelerator is active."
    - "Context.__module__ == '_decimal' likewise."
    - "DecimalException is the root exception for all decimal-arithmetic errors; it inherits from ArithmeticError."
    - "Decimal('0').is_zero() == True and Decimal('1').is_finite() == True are foundational predicate invariants."
    - "Decimal('Infinity').is_infinite() == True tests the special-value predicate path."
    - "Context() with no arguments creates a default context; __class__.__name__ confirms the C type is used."
    - "All expected values verified by running Python 3.12 _decimal on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant _decimal.Decimal.class_name:
  description: "_decimal.Decimal.__name__ == 'Decimal'"
  category: classnames
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant _decimal.Context.class_name:
  description: "_decimal.Context.__name__ == 'Context'"
  category: classnames
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant _decimal.DecimalException.class_name:
  description: "_decimal.DecimalException.__name__ == 'DecimalException'"
  category: classnames
  kind: python_call_eq
  function: DecimalException.__name__.__eq__
  args: ["DecimalException"]
  expected: true

# ---------------------------------------------------------------------------
# Module checks — classes are defined in _decimal (C extension)
# ---------------------------------------------------------------------------

invariant _decimal.Decimal.module:
  description: "_decimal.Decimal.__module__ == '_decimal'"
  category: classnames
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["_decimal"]
  expected: true

invariant _decimal.Context.module:
  description: "_decimal.Context.__module__ == '_decimal'"
  category: classnames
  kind: python_call_eq
  function: Context.__module__.__eq__
  args: ["_decimal"]
  expected: true

# ---------------------------------------------------------------------------
# Base class check — DecimalException inherits from ArithmeticError
# ---------------------------------------------------------------------------

invariant _decimal.DecimalException.base:
  description: "_decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError'"
  category: classnames
  kind: python_call_eq
  function: DecimalException.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "ArithmeticError"

# ---------------------------------------------------------------------------
# Decimal instance — class name via constructor
# ---------------------------------------------------------------------------

invariant _decimal.Decimal.instance_class_name:
  description: "Decimal('3.14').__class__.__name__ == 'Decimal'"
  category: construction
  kind: python_call_eq
  function: Decimal
  args: ["3.14"]
  method: __class__.__name__.__eq__
  method_args: ["Decimal"]
  expected: true

# ---------------------------------------------------------------------------
# Context instance — class name via constructor
# ---------------------------------------------------------------------------

invariant _decimal.Context.instance_class_name:
  description: "Context().__class__.__name__ == 'Context'"
  category: construction
  kind: python_call_eq
  function: Context
  args: []
  method: __class__.__name__.__eq__
  method_args: ["Context"]
  expected: true

# ---------------------------------------------------------------------------
# Predicate methods — is_zero, is_finite, is_infinite
# ---------------------------------------------------------------------------

invariant _decimal.Decimal.is_zero.zero:
  description: "Decimal('0').is_zero() == True"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_zero
  expected: true

invariant _decimal.Decimal.is_zero.nonzero:
  description: "Decimal('1').is_zero() == False"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_zero
  expected: false

invariant _decimal.Decimal.is_finite.finite:
  description: "Decimal('1').is_finite() == True — a regular number is finite"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_finite
  expected: true

invariant _decimal.Decimal.is_infinite.true:
  description: "Decimal('Infinity').is_infinite() == True"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["Infinity"]
  method: is_infinite
  expected: true

invariant _decimal.Decimal.is_infinite.false:
  description: "Decimal('1').is_infinite() == False — a regular number is not infinite"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_infinite
  expected: false

# ---------------------------------------------------------------------------
# String representation
# ---------------------------------------------------------------------------

invariant _decimal.Decimal.str_repr:
  description: "str(Decimal('3.14')) == '3.14' — string form preserves exact decimal encoding"
  category: string_repr
  kind: python_call_eq
  function: Decimal
  args: ["3.14"]
  method: __str__
  expected: "3.14"
