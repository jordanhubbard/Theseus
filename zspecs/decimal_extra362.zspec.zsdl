spec: decimal_extra362
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "decimal.Decimal.__bases__[0].__name__ == 'object' — Decimal is a root class"
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context is a root class"
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError'"
    - "decimal.getcontext().__class__.__name__ == 'Context' — the thread-local default context is always a Context instance"
    - "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' and decimal.ROUND_UP == 'ROUND_UP' — rounding mode constants are plain strings"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal core class identity — class names
# ---------------------------------------------------------------------------

table decimal_extra362.core_class_names:
  description: "decimal core class __name__ identity checks — Decimal, Context, DecimalException; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: deccorename362

  columns: [id, function, args, expected]
  rows:
    - [decimal_name,          decimal.Decimal.__name__.__eq__,          ["Decimal"],          true]
    - [context_name,          decimal.Context.__name__.__eq__,          ["Context"],          true]
    - [decimalexc_name,       decimal.DecimalException.__name__.__eq__, ["DecimalException"], true]

# ---------------------------------------------------------------------------
# decimal core class identity — module attributes
# ---------------------------------------------------------------------------

table decimal_extra362.core_class_modules:
  description: "decimal core class __module__ identity checks — Decimal, Context, and DecimalException all report __module__ as 'decimal'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: deccoremod362

  columns: [id, function, args, expected]
  rows:
    - [decimal_module,    decimal.Decimal.__module__.__eq__,          ["decimal"], true]
    - [context_module,    decimal.Context.__module__.__eq__,          ["decimal"], true]
    - [decimalexc_module, decimal.DecimalException.__module__.__eq__, ["decimal"], true]

# ---------------------------------------------------------------------------
# decimal core class identity — base class names
# ---------------------------------------------------------------------------

table decimal_extra362.core_class_bases:
  description: "decimal core class __bases__[0].__name__ identity checks — Decimal and Context extend object (root classes); DecimalException extends ArithmeticError; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: deccorebase362

  columns: [id, function, args, expected]
  rows:
    - [decimal_base,    "decimal.Decimal.__bases__[0].__name__.__eq__",          ["object"],         true]
    - [context_base,    "decimal.Context.__bases__[0].__name__.__eq__",          ["object"],         true]
    - [decimalexc_base, "decimal.DecimalException.__bases__[0].__name__.__eq__", ["ArithmeticError"], true]

# ---------------------------------------------------------------------------
# decimal.getcontext() class identity
# ---------------------------------------------------------------------------

invariant decimal_extra362.getcontext_class_name:
  description: "decimal.getcontext().__class__.__name__ == 'Context' — the thread-local default arithmetic context is always an instance of decimal.Context; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: decimal.getcontext().__class__.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra362.getcontext_class_module:
  description: "decimal.getcontext().__class__.__module__ == 'decimal' — the thread-local default context's class reports __module__ as 'decimal'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: decimal.getcontext().__class__.__module__.__eq__
  args: ["decimal"]
  expected: true

# ---------------------------------------------------------------------------
# decimal rounding mode constants
# ---------------------------------------------------------------------------

invariant decimal_extra362.round_half_even_value:
  description: "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — rounding mode constants are plain strings; ROUND_HALF_EVEN rounds to the nearest even digit (banker's rounding); verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra362.round_up_value:
  description: "decimal.ROUND_UP == 'ROUND_UP' — rounding mode constants are plain strings; ROUND_UP rounds away from zero; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true
