spec: hashlib_extra706
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers module-level function qualnames for hashlib"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra706.qualnames:
  description: "hashlib module-level function qualname and module attribute checks"
  kind: python_call_eq
  category: qualnames
  id_prefix: hl706qn
  columns: [id, function, args, expected]
  rows:
    - [hl706qn001, hashlib.new.__qualname__.__eq__, ["new"], true]
    - [hl706qn002, hashlib.new.__module__.__eq__, ["hashlib"], true]
    - [hl706qn003, hashlib.md5.__qualname__.__eq__, ["openssl_md5"], true]
    - [hl706qn004, hashlib.sha1.__qualname__.__eq__, ["openssl_sha1"], true]
    - [hl706qn005, hashlib.sha256.__qualname__.__eq__, ["openssl_sha256"], true]
    - [hl706qn006, hashlib.sha512.__qualname__.__eq__, ["openssl_sha512"], true]
    - [hl706qn007, hashlib.blake2b.__qualname__.__eq__, ["blake2b"], true]
    - [hl706qn008, hashlib.blake2b.__module__.__eq__, ["_blake2"], true]
    - [hl706qn009, hashlib.blake2s.__qualname__.__eq__, ["blake2s"], true]
    - [hl706qn010, hashlib.blake2s.__module__.__eq__, ["_blake2"], true]
    - [hl706qn011, hashlib.sha3_256.__qualname__.__eq__, ["sha3_256"], true]
    - [hl706qn012, hashlib.sha3_512.__qualname__.__eq__, ["sha3_512"], true]
