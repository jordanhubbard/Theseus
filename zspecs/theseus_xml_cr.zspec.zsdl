spec: theseus_xml_cr
version: ">=3.0"
backend: python_cleanroom(theseus_xml_cr)
blocks: xml

docs: https://docs.python.org/3/library/xml.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/xml.html"
  not_derived_from:
    - "CPython source: Lib/xml/__init__.py"
  notes:
    - "Clean-room xml namespace package. Do NOT import xml."

error_model: python_exceptions

invariant theseus_xml_cr.xml2_package:
  description: "xml package is importable as a namespace"
  category: behavior
  kind: python_call_eq
  function: xml2_package
  args: []
  expected: true

invariant theseus_xml_cr.xml2_name:
  description: "xml package has correct __name__"
  category: behavior
  kind: python_call_eq
  function: xml2_name
  args: []
  expected: true

invariant theseus_xml_cr.xml2_path:
  description: "xml package has __path__ (is a package)"
  category: behavior
  kind: python_call_eq
  function: xml2_path
  args: []
  expected: true
