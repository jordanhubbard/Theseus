spec: email_message_extra
version: ">=3.6"
backend: python_module(email.message)

docs: https://docs.python.org/3/library/email.message.html

provenance:
  derived_from:
    - "Python 3 email.message documentation — https://docs.python.org/3/library/email.message.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/email/message.py"
    - "email_message.zspec.zsdl — covers Message.__name__, MIMEPart.__name__, EmailMessage.__name__; Message behavior (missing header, keys, len, content_type, is_multipart, charset, defects); EmailMessage content_type; issubclass check"
    - "email_extra.zspec.zsdl — covers email top-level function __name__ checks (message_from_string/bytes/file/binary_file), email.__name__, message_from_string/bytes behavior"
    - "email_extra2.zspec.zsdl — covers email.policy, email.errors, email.contentmanager, email.generator via email backend"
  notes:
    - "This spec extends email_message.zspec.zsdl."
    - "Focus: __qualname__ and __module__ attributes for email.message classes not yet in any spec."
    - "email.message.Message.__qualname__ == 'Message' — top-level class."
    - "email.message.MIMEPart.__qualname__ == 'MIMEPart' — introduced in Python 3.6."
    - "email.message.EmailMessage.__qualname__ == 'EmailMessage' — introduced in Python 3.6."
    - "email.message.Message.__module__ == 'email.message' — exact module string."
    - "email.message.EmailMessage.__module__ == 'email.message' — same module as Message."
    - "email.message.Message.__bases__[0].__name__ == 'object' — Message inherits directly from object."
    - "Message().__class__.__name__ == 'Message' — instance class name round-trip."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — not in any prior email spec
# ---------------------------------------------------------------------------

table email_message_extra.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Message,      Message.__qualname__.__eq__,      ["Message"],      true]
    - [MIMEPart,     MIMEPart.__qualname__.__eq__,     ["MIMEPart"],     true]
    - [EmailMessage, EmailMessage.__qualname__.__eq__,  ["EmailMessage"], true]

# ---------------------------------------------------------------------------
# __module__ checks — not in any prior email.message spec
# (email_errors.zspec.zsdl covers module for error classes only)
# ---------------------------------------------------------------------------

table email_message_extra.class_modules:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Message,      Message.__module__.__eq__,      ["email.message"], true]
    - [EmailMessage, EmailMessage.__module__.__eq__,  ["email.message"], true]
    - [MIMEPart,     MIMEPart.__module__.__eq__,     ["email.message"], true]

# ---------------------------------------------------------------------------
# Message.__bases__ — base class is object
# (email_message.zspec.zsdl does not check Message.__bases__)
# ---------------------------------------------------------------------------

invariant email_message_extra.Message.base_is_object:
  description: "email.message.Message.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Message.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Message().__class__.__name__ — instance reflects class name
# (email_message.zspec.zsdl tests class __name__ via __name__.__eq__;
#  this tests the same through an instance's __class__.__name__)
# ---------------------------------------------------------------------------

invariant email_message_extra.Message.instance_class_name:
  description: "email.message.Message().__class__.__name__ == 'Message'"
  category: behavior
  kind: python_call_eq
  function: Message
  args: []
  method: __class__.__name__.__eq__
  method_args: ["Message"]
  expected: true

# ---------------------------------------------------------------------------
# EmailMessage().__class__.__name__ — instance reflects class name
# ---------------------------------------------------------------------------

invariant email_message_extra.EmailMessage.instance_class_name:
  description: "email.message.EmailMessage().__class__.__name__ == 'EmailMessage'"
  category: behavior
  kind: python_call_eq
  function: EmailMessage
  args: []
  method: __class__.__name__.__eq__
  method_args: ["EmailMessage"]
  expected: true

# ---------------------------------------------------------------------------
# Message — is_type check (class object is itself an instance of type)
# ---------------------------------------------------------------------------

invariant email_message_extra.Message.is_type:
  description: "email.message.Message.__class__.__name__ == 'type'"
  category: identity
  kind: python_call_eq
  function: Message.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# EmailMessage — subclass hierarchy: EmailMessage is a subclass of MIMEPart
# (email_message checks issubclass(EmailMessage, Message);
#  the MIMEPart -> EmailMessage chain is not tested there)
# ---------------------------------------------------------------------------

invariant email_message_extra.EmailMessage.bases_first:
  description: "email.message.EmailMessage.__bases__[0].__name__ == 'MIMEPart'"
  category: hierarchy
  kind: python_call_eq
  function: EmailMessage.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "MIMEPart"
