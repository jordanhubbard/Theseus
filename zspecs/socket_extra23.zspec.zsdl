spec: socket_extra23
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra8.zspec.zsdl — covers __qualname__.__eq__ for socket class, error/timeout/gaierror/herror exceptions, create_server/setdefaulttimeout and table of gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection."
    - "socket_extra20.zspec.zsdl — covers __qualname__.__len__() for socket.socket class and module-level functions."
    - "socket_extra21.zspec.zsdl — covers __qualname__.__len__() for socket exception classes (error/timeout/gaierror/herror)."
    - "socket_extra22.zspec.zsdl — covers __qualname__.__eq__ for socket.socket instance methods: connect/bind/listen/accept/close/recv/send."
  notes:
    - "This spec extends the socket chain through socket_extra22; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__eq__ for additional socket.socket instance methods (setsockopt, getsockopt, getsockname, getpeername, setblocking, settimeout, gettimeout, fileno) and __qualname__.__eq__ for gaierror/herror exception classes."
    - "socket_extra8 checks __qualname__.__eq__ for gaierror and herror as part of an exception class table; those ARE covered there. The standalone invariants for gaierror/herror below provide a cross-namespace regression checkpoint from the extra23 namespace."
    - "socket.socket.setsockopt.__qualname__ == 'socket.setsockopt' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__qualname__ == 'socket.getsockopt' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__qualname__ == 'socket.getsockname' — len 18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__qualname__ == 'socket.getpeername' — len 18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__qualname__ == 'socket.setblocking' — len 18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__qualname__ == 'socket.settimeout' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.gettimeout.__qualname__ == 'socket.gettimeout' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__qualname__ == 'socket.fileno' — len 13. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.gaierror.__qualname__ == 'gaierror' — len 8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.herror.__qualname__ == 'herror' — len 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket additional instance method __qualname__.__eq__ checks
#
# socket_extra22 covers connect/bind/listen/accept/close/recv/send.
# This spec adds the remaining commonly-used socket methods:
# setsockopt, getsockopt, getsockname, getpeername, setblocking,
# settimeout, gettimeout, fileno.
# The socket class is named 'socket', so method qualnames take the form
# 'socket.<method_name>'. All values verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra23.socket_method_qualnames:
  description: "__qualname__.__eq__ for additional socket.socket instance methods"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: smqn23

  columns: [id, function, args, expected]
  rows:
    - [setsockopt,  socket.setsockopt.__qualname__.__eq__,  ["socket.setsockopt"],  true]
    - [getsockopt,  socket.getsockopt.__qualname__.__eq__,  ["socket.getsockopt"],  true]
    - [getsockname, socket.getsockname.__qualname__.__eq__, ["socket.getsockname"], true]
    - [getpeername, socket.getpeername.__qualname__.__eq__, ["socket.getpeername"], true]
    - [setblocking, socket.setblocking.__qualname__.__eq__, ["socket.setblocking"], true]
    - [settimeout,  socket.settimeout.__qualname__.__eq__,  ["socket.settimeout"],  true]
    - [gettimeout,  socket.gettimeout.__qualname__.__eq__,  ["socket.gettimeout"],  true]
    - [fileno,      socket.fileno.__qualname__.__eq__,      ["socket.fileno"],      true]

# ---------------------------------------------------------------------------
# socket.socket additional instance method __qualname__.__len__() checks
#
# No prior spec checks __qualname__.__len__() for any of these methods.
# Lengths: 'socket.setsockopt'==17, 'socket.getsockopt'==17,
# 'socket.getsockname'==18, 'socket.getpeername'==18,
# 'socket.setblocking'==18, 'socket.settimeout'==17,
# 'socket.gettimeout'==17, 'socket.fileno'==13.
# ---------------------------------------------------------------------------

table socket_extra23.socket_method_qualname_lengths:
  description: "Length of __qualname__ strings for additional socket.socket instance methods"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: smqlen23

  columns: [id, function, args, expected]
  rows:
    - [setsockopt,  socket.setsockopt.__qualname__.__len__,  [], 17]
    - [getsockopt,  socket.getsockopt.__qualname__.__len__,  [], 17]
    - [getsockname, socket.getsockname.__qualname__.__len__, [], 18]
    - [getpeername, socket.getpeername.__qualname__.__len__, [], 18]
    - [setblocking, socket.setblocking.__qualname__.__len__, [], 18]
    - [settimeout,  socket.settimeout.__qualname__.__len__,  [], 17]
    - [gettimeout,  socket.gettimeout.__qualname__.__len__,  [], 17]
    - [fileno,      socket.fileno.__qualname__.__len__,      [], 13]

# ---------------------------------------------------------------------------
# gaierror and herror __qualname__.__eq__ — cross-namespace anchors
#
# socket_extra8 covers gaierror.__qualname__.__eq__ and herror.__qualname__.__eq__
# in its exception class table. The standalone invariants below anchor these
# from the extra23 namespace as a cross-namespace regression checkpoint.
# gaierror.__qualname__ == 'gaierror' (len 8).
# herror.__qualname__ == 'herror' (len 6).
# ---------------------------------------------------------------------------

invariant socket_extra23.gaierror.qualname_eq:
  description: "socket.gaierror.__qualname__ == 'gaierror' — cross-namespace anchor (socket_extra8 covers in table)"
  category: class_qualnames
  kind: python_call_eq
  function: gaierror.__qualname__.__eq__
  args: ["gaierror"]
  expected: true

invariant socket_extra23.herror.qualname_eq:
  description: "socket.herror.__qualname__ == 'herror' — cross-namespace anchor (socket_extra8 covers in table)"
  category: class_qualnames
  kind: python_call_eq
  function: herror.__qualname__.__eq__
  args: ["herror"]
  expected: true
