spec: json_merge_patch
version: ">=1.0.2"
backend: node(json-merge-patch)

docs: https://www.npmjs.com/package/json-merge-patch

provenance:
  derived_from:
    - "json-merge-patch README — https://www.npmjs.com/package/json-merge-patch"
    - "Test vectors verified with json-merge-patch via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "json-merge-patch source"
  notes:
    - "json-merge-patch is an npm package. Install: npm install json-merge-patch"
    - "Applies a JSON Merge Patch (RFC 7396) to a target object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the patched object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table json_merge_patch.apply:
  kind: node_module_call_eq
  function: apply
  category: object
  id_prefix: jmpa

  columns: [id, args, expected]
  rows:
    - [override,  [{"a": 1, "b": 2}, {"a": 3}],        {"a": 3, "b": 2}]
    - [add_key,   [{"a": 1}, {"b": 2}],                 {"a": 1, "b": 2}]
    - [identity,  [{"a": 1}, {}],                       {"a": 1}]

