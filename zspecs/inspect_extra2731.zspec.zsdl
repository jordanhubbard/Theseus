  rows:
    - ["in2731005", "inspect.Parameter.__dict__.__contains__",       ["__floor__"], false]
    - ["in2731006", "inspect.BoundArguments.__dict__.__contains__",  ["__floor__"], false]
    - ["in2731007", "inspect.Signature.__dict__.__contains__",       ["__floor__"], false]
    - ["in2731008", "inspect.FullArgSpec.__dict__.__contains__",     ["__floor__"], false]

# ---------------------------------------------------------------------------
# __ceil__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2731.ceil_protocol:
  description: "__ceil__ is absent from all inspect type __dict__s — none define numeric ceiling directly"
