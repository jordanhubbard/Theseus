spec: inspect_extra2731
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 629 theme: __trunc__, __floor__, and __ceil__ dict-presence checks (numeric rounding protocol — used by math.trunc(), math.floor(), math.ceil())."
    - "inspect.Parameter is an introspection value object; it does not implement numeric rounding protocols."
    - "inspect.BoundArguments wraps a signature binding; it exposes .args and .kwargs but does not define __trunc__, __floor__, or __ceil__ itself."
    - "inspect.Signature is a callable signature descriptor; it defines __eq__ and __hash__ but not __trunc__, __floor__, or __ceil__."
    - "inspect.FullArgSpec is a namedtuple subclass; namedtuples inherit tuple methods but do not define __trunc__, __floor__, or __ceil__ in their own __dict__."
    - "None of these four inspect types define __trunc__, __floor__, or __ceil__ in their own class __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2731.trunc_protocol:
  description: "__trunc__ is absent from all inspect type __dict__s — none define numeric truncation directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2731

  columns: [id, function, args, expected]
  rows:
    - ["in2731001", "inspect.Parameter.__dict__.__contains__",       ["__trunc__"], false]
    - ["in2731002", "inspect.BoundArguments.__dict__.__contains__",  ["__trunc__"], false]
    - ["in2731003", "inspect.Signature.__dict__.__contains__",       ["__trunc__"], false]
    - ["in2731004", "inspect.FullArgSpec.__dict__.__contains__",     ["__trunc__"], false]

