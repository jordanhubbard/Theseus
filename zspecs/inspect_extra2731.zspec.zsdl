  columns: [id, function, args, expected]
  rows:
    - ["in2731009",  "inspect.Parameter.__dict__.__contains__",       ["__ceil__"], false]
    - ["in2731010",  "inspect.BoundArguments.__dict__.__contains__",  ["__ceil__"], false]
    - ["in2731011",  "inspect.Signature.__dict__.__contains__",       ["__ceil__"], false]
    - ["in2731012",  "inspect.FullArgSpec.__dict__.__contains__",     ["__ceil__"], false]

# ---------------------------------------------------------------------------
# Combined per-type view — all four inspect types vs. all three rounding protocols
# ---------------------------------------------------------------------------

table inspect_extra2731.signature_combined:
  description: "inspect.Parameter, inspect.Signature, inspect.BoundArguments, and inspect.FullArgSpec define none of __trunc__, __floor__, __ceil__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2731

  columns: [id, function, args, expected]
  rows:
    - ["in2731013", "inspect.Parameter.__dict__.__contains__",       ["__trunc__"],  false]
    - ["in2731014", "inspect.Parameter.__dict__.__contains__",       ["__floor__"],  false]
    - ["in2731015", "inspect.Parameter.__dict__.__contains__",       ["__ceil__"],   false]
    - ["in2731016", "inspect.Signature.__dict__.__contains__",       ["__trunc__"],  false]
    - ["in2731017", "inspect.Signature.__dict__.__contains__",       ["__floor__"],  false]
    - ["in2731018", "inspect.Signature.__dict__.__contains__",       ["__ceil__"],   false]
    - ["in2731019", "inspect.BoundArguments.__dict__.__contains__",  ["__trunc__"],  false]
    - ["in2731020", "inspect.BoundArguments.__dict__.__contains__",  ["__floor__"],  false]
    - ["in2731021", "inspect.BoundArguments.__dict__.__contains__",  ["__ceil__"],   false]
    - ["in2731022", "inspect.FullArgSpec.__dict__.__contains__",     ["__trunc__"],  false]
    - ["in2731023", "inspect.FullArgSpec.__dict__.__contains__",     ["__floor__"],  false]
    - ["in2731024", "inspect.FullArgSpec.__dict__.__contains__",     ["__ceil__"],   false]
