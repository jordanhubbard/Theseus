spec: base_64
version: ">=1.0.0"
backend: node(base-64)

docs: https://github.com/nicktindall/cycjimmy-compare-versions#readme

provenance:
  derived_from:
    - "base-64 README — https://github.com/mathiasbynens/base64#readme"
    - "Test vectors verified with base-64@1.1.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "base-64 source: base64.js"
  notes:
    - "base-64 exports an object with encode() and decode() methods."
    - "encode(str) converts a string to base64."
    - "decode(b64) converts base64 back to the original string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table base_64.encode:
  kind: node_module_call_eq
  function: encode
  category: encode
  id_prefix: b64_enc

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello"],     "aGVsbG8="]
    - [empty,  [""],          ""]

table base_64.decode:
  kind: node_module_call_eq
  function: decode
  category: decode
  id_prefix: b64_dec

  columns: [id, args, expected]
  rows:
    - [hello,  ["aGVsbG8="],  "hello"]
    - [empty,  [""],          ""]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:45:40Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
