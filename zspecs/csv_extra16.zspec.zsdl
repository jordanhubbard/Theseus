spec: csv_extra16
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
    - "csv_extra15.zspec.zsdl — covers reader/writer __name__; DictReader/DictWriter/Dialect/excel/excel_tab __name__ table; QUOTE_* exact integer values as standalone invariants"
    - "csv_extra13.zspec.zsdl — covers Dialect.__bases__[0].__name__ and QUOTE_* __class__.__name__ table"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra15.zspec.zsdl."
    - "csv.Dialect.__bases__[0].__name__ == 'object' — Dialect directly subclasses object; verified at runtime."
    - "csv.Error.__bases__[0].__name__ == 'Exception' — csv.Error subclasses Exception; verified at runtime."
    - "csv.excel.__bases__[0].__name__ == 'Dialect' — excel inherits from Dialect; verified at runtime."
    - "csv.excel_tab.__bases__[0].__name__ == 'excel' — excel_tab inherits from excel, not Dialect; verified at runtime."
    - "csv.reader.__module__ == '_csv' — reader is implemented in C extension _csv; verified at runtime."
    - "csv.writer.__module__ == '_csv' — writer is implemented in C extension _csv; verified at runtime."
    - "QUOTE_* __class__.__name__ == 'int' — all four QUOTE constants are plain Python ints; verified at runtime."
    - "csv_extra13 covers QUOTE_* __class__.__name__ in a table; this spec re-anchors reader/writer __module__ and class base names as new coverage axes in the extra16 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# reader and writer __module__
#
# csv.reader and csv.writer are implemented in the C extension module _csv,
# so their __module__ is '_csv', not 'csv'. No prior csv spec covers
# reader.__module__ or writer.__module__ as standalone named invariants
# in the extra16 namespace.
# ---------------------------------------------------------------------------

invariant csv_extra16.reader.module:
  description: "csv.reader.__module__ == '_csv' — reader is a C type from the _csv extension"
  category: module_identity
  kind: python_call_eq
  function: reader.__module__.__eq__
  args: ["_csv"]
  expected: true

invariant csv_extra16.writer.module:
  description: "csv.writer.__module__ == '_csv' — writer is a C type from the _csv extension"
  category: module_identity
  kind: python_call_eq
  function: writer.__module__.__eq__
  args: ["_csv"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy — __bases__[0].__name__ for Dialect, Error, excel, excel_tab
#
# csv.Dialect subclasses object; csv.Error subclasses Exception;
# csv.excel subclasses Dialect; csv.excel_tab subclasses excel.
# These form the full inheritance chain of the csv class hierarchy.
# Verified at runtime. No prior csv spec covers all four in a single table
# under the extra16 namespace.
# ---------------------------------------------------------------------------

table csv_extra16.class_base_names:
  description: "__bases__[0].__name__ for Dialect, Error, excel, excel_tab"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: cbase16

  columns: [id, function, args, expected]
  rows:
    - [Dialect_base,    "Dialect.__bases__[0].__name__.__eq__",    ["object"],    true]
    - [Error_base,      "Error.__bases__[0].__name__.__eq__",      ["Exception"], true]
    - [excel_base,      "excel.__bases__[0].__name__.__eq__",      ["Dialect"],   true]
    - [excel_tab_base,  "excel_tab.__bases__[0].__name__.__eq__",  ["excel"],     true]

# ---------------------------------------------------------------------------
# QUOTE_* constants — __class__.__name__ as standalone invariants
#
# All four QUOTE_* constants are plain Python ints. csv_extra13 covers them
# in a table; these standalone invariants re-anchor the same facts in the
# extra16 namespace for independent cross-checking.
# ---------------------------------------------------------------------------

invariant csv_extra16.QUOTE_ALL.class_name:
  description: "csv.QUOTE_ALL.__class__.__name__ == 'int' — QUOTE_ALL is a plain int constant"
  category: constants
  kind: python_call_eq
  function: QUOTE_ALL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant csv_extra16.QUOTE_MINIMAL.class_name:
  description: "csv.QUOTE_MINIMAL.__class__.__name__ == 'int' — QUOTE_MINIMAL is a plain int constant"
  category: constants
  kind: python_call_eq
  function: QUOTE_MINIMAL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant csv_extra16.QUOTE_NONNUMERIC.class_name:
  description: "csv.QUOTE_NONNUMERIC.__class__.__name__ == 'int' — QUOTE_NONNUMERIC is a plain int constant"
  category: constants
  kind: python_call_eq
  function: QUOTE_NONNUMERIC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant csv_extra16.QUOTE_NONE.class_name:
  description: "csv.QUOTE_NONE.__class__.__name__ == 'int' — QUOTE_NONE is a plain int constant"
  category: constants
  kind: python_call_eq
  function: QUOTE_NONE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
