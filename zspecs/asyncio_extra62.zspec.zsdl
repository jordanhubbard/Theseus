spec: asyncio_extra62
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#annotations — Python __annotations__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio_extra61.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__() tables, InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__/__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ and Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ (extra56), class __weakref__.__class__.__name__ (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56), asyncio.__all__.__class__.__name__.__eq__('tuple') (extra57), class __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra57), class __subclasshook__.__class__.__name__ (extra57), asyncio.__all__.__contains__ membership checks (extra58), asyncio.__package__.__eq__('asyncio') (extra58), Queue/Lock __doc__.__class__.__name__.__eq__('str') (extra58), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra59), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra60), Queue/Lock __init__ and put/get/empty/full/qsize/acquire/release __qualname__.__eq__ (extra61)."
    - "This spec covers (asyncioann62 namespace): wave 228 theme — __annotations__ class identity + __globals__ dict keys + __doc__.__contains__ content checks. NEW in extra62: gather/__annotations__.__class__.__name__.__eq__('dict'), sleep/__annotations__.__class__.__name__.__eq__('dict'), wait/__annotations__.__class__.__name__.__eq__('dict') — no prior asyncio spec has checked the __class__.__name__ of __annotations__ via __eq__ for these functions; gather/__globals__.__class__.__name__.__eq__('dict') — no prior asyncio spec has checked the __globals__ dict class name via __eq__; gather/__globals__.__contains__('gather') — no prior asyncio spec has checked if 'gather' is a key in gather.__globals__; Queue.__doc__.__contains__('Queue') — no prior asyncio spec has used __contains__ to check docstring content."
    - "asyncio.gather.__annotations__.__class__.__name__ == 'dict'. gather is a pure-Python coroutine function defined in Lib/asyncio/tasks.py. Its __annotations__ attribute is an empty dict ({}). The __class__.__name__ of that dict is 'dict'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__annotations__.__class__.__name__ == 'dict'. sleep is a pure-Python coroutine function defined in Lib/asyncio/tasks.py. Its __annotations__ is an empty dict ({}). The __class__.__name__ of that dict is 'dict'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.wait.__annotations__.__class__.__name__ == 'dict'. wait is a pure-Python coroutine function defined in Lib/asyncio/tasks.py. Its __annotations__ is an empty dict ({}). The __class__.__name__ of that dict is 'dict'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__globals__.__class__.__name__ == 'dict'. The __globals__ of any pure-Python function is the module-level dict of the module in which it is defined. Its type is dict, so __class__.__name__ == 'dict'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__globals__.__contains__('gather') returns True. 'gather' is a key in gather's module globals (Lib/asyncio/tasks.py), since gather is defined at module level in that file. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__doc__.__contains__('Queue') returns True. Queue.__doc__ begins 'A queue, useful for coordinating producer and consumer coroutines.' and contains the word 'Queue' (capital Q) multiple times throughout the docstring. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio function __annotations__ class identity — extra62
#
# Wave 228 theme: __annotations__ class identity checks.
#
# gather/sleep/wait are pure-Python coroutine functions. Their __annotations__
# attribute is always an empty dict ({}). The __class__.__name__ of that dict
# is 'dict'.
#
# NEW: no prior asyncio spec has used __eq__ to verify the __class__.__name__
# of any function's __annotations__.
# ---------------------------------------------------------------------------

table asyncio_extra62.function_annotations_class_name:
  description: "asyncio function __annotations__.__class__.__name__.__eq__('dict') checks in asyncioann62 namespace — wave 228 theme: __annotations__ class identity; gather/sleep/wait are pure-Python coroutine functions; their __annotations__ attribute is an empty dict ({}); __class__.__name__ of that dict is 'dict'; NEW in extra62: no prior asyncio spec has verified __annotations__.__class__.__name__ via __eq__ for any of these functions; verified with Python 3.14.3"
  kind: python_call_eq
  category: annotations
  id_prefix: asyncioann62

  columns: [id, function, args, expected, description]
  rows:
    - [gather_ann_class, gather.__annotations__.__class__.__name__.__eq__, ["dict"], true, "gather.__annotations__.__class__.__name__ == 'dict' — gather is a pure-Python coroutine function (Lib/asyncio/tasks.py); its __annotations__ attribute is an empty dict ({}); the type of any dict is dict itself, so __class__.__name__ is 'dict'; NEW in extra62: first __annotations__.__class__.__name__.__eq__ check for gather in any asyncio spec; verified with Python 3.14.3"]
    - [sleep_ann_class,  sleep.__annotations__.__class__.__name__.__eq__,  ["dict"], true, "sleep.__annotations__.__class__.__name__ == 'dict' — sleep is a pure-Python coroutine function (Lib/asyncio/tasks.py); its __annotations__ attribute is an empty dict ({}); __class__.__name__ is 'dict'; NEW in extra62: first __annotations__.__class__.__name__.__eq__ check for sleep in any asyncio spec; verified with Python 3.14.3"]
    - [wait_ann_class,   wait.__annotations__.__class__.__name__.__eq__,   ["dict"], true, "wait.__annotations__.__class__.__name__ == 'dict' — wait is a pure-Python coroutine function (Lib/asyncio/tasks.py); its __annotations__ attribute is an empty dict ({}); __class__.__name__ is 'dict'; NEW in extra62: first __annotations__.__class__.__name__.__eq__ check for wait in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio gather.__globals__ class identity and key membership — extra62
#
# Wave 228 theme: __globals__ dict keys.
#
# gather.__globals__ is the module-level namespace dict of Lib/asyncio/tasks.py.
# Its type is dict (__class__.__name__ == 'dict').
# 'gather' is a key in that dict because gather is defined at module level.
# ---------------------------------------------------------------------------

table asyncio_extra62.globals_class_and_contains:
  description: "asyncio gather.__globals__ class identity and key membership checks in asyncioann62 namespace — wave 228 theme: __globals__ dict keys; gather.__globals__ is the module-level namespace dict of Lib/asyncio/tasks.py; its __class__.__name__ is 'dict' and it contains 'gather' as a key since gather is defined at module level; NEW in extra62: no prior asyncio spec has checked gather.__globals__.__class__.__name__ via __eq__ or used __contains__ on gather.__globals__; verified with Python 3.14.3"
  kind: python_call_eq
  category: globals
  id_prefix: asyncioann62g

  columns: [id, function, args, expected, description]
  rows:
    - [gather_globals_class,    gather.__globals__.__class__.__name__.__eq__, ["dict"],    true, "gather.__globals__.__class__.__name__ == 'dict' — the __globals__ of any pure-Python function is the module-level namespace dict of its defining module (Lib/asyncio/tasks.py); the type of that namespace is dict, so __class__.__name__ is 'dict'; NEW in extra62: first __globals__.__class__.__name__.__eq__ check for any asyncio function in any asyncio spec; verified with Python 3.14.3"]
    - [gather_globals_contains, gather.__globals__.__contains__,              ["gather"], true, "gather.__globals__.__contains__('gather') returns True — 'gather' is a key in gather's module globals (Lib/asyncio/tasks.py) since gather is defined at module level in that file; dict.__contains__ checks key membership; NEW in extra62: first __globals__.__contains__ check for gather in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Queue.__doc__ content check — extra62
#
# Wave 228 theme: __doc__.__contains__ content checks.
#
# Queue.__doc__ starts 'A queue, useful for coordinating producer and consumer
# coroutines.' and mentions 'Queue' multiple times throughout.
# __doc__.__contains__('Queue') returns True.
# ---------------------------------------------------------------------------

table asyncio_extra62.queue_doc_contains:
  description: "asyncio Queue.__doc__.__contains__ content check in asyncioann62 namespace — wave 228 theme: __doc__.__contains__ content checks; Queue.__doc__ is a str describing the asyncio Queue class; it contains the word 'Queue' (capital Q) multiple times; str.__contains__ returns True when the substring is present; NEW in extra62: no prior asyncio spec has used __contains__ to test docstring content for Queue; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: asyncioann62d

  columns: [id, function, args, expected, description]
  rows:
    - [queue_doc_contains_queue, Queue.__doc__.__contains__, ["Queue"], true, "Queue.__doc__.__contains__('Queue') returns True — asyncio.Queue.__doc__ is a non-empty str beginning 'A queue, useful for coordinating producer and consumer coroutines.' and mentioning 'Queue' (capital Q) multiple times; str.__contains__ returns True when the substring appears in the string; NEW in extra62: first __doc__.__contains__ content check for asyncio.Queue in any asyncio spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra62
# ---------------------------------------------------------------------------

invariant asyncio_extra62.gather_annotations_class_name_eq:
  description: "asyncio.gather.__annotations__.__class__.__name__.__eq__('dict') returns True — gather is a pure-Python coroutine function defined in Lib/asyncio/tasks.py; its __annotations__ attribute is an empty dict ({}); the __class__.__name__ of that dict is 'dict'; NEW in extra62: no prior asyncio spec has verified gather.__annotations__.__class__.__name__ via __eq__; wave 228 first __annotations__ class identity invariant for gather in any asyncio spec; verified with Python 3.14.3"
  category: annotations
  kind: python_call_eq
  function: gather.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant asyncio_extra62.sleep_annotations_class_name_eq:
  description: "asyncio.sleep.__annotations__.__class__.__name__.__eq__('dict') returns True — sleep is a pure-Python coroutine function defined in Lib/asyncio/tasks.py; its __annotations__ attribute is an empty dict ({}); the __class__.__name__ of that dict is 'dict'; NEW in extra62: no prior asyncio spec has verified sleep.__annotations__.__class__.__name__ via __eq__; wave 228 invariant alongside gather annotation check; verified with Python 3.14.3"
  category: annotations
  kind: python_call_eq
  function: sleep.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant asyncio_extra62.gather_globals_class_name_eq:
  description: "asyncio.gather.__globals__.__class__.__name__.__eq__('dict') returns True — gather.__globals__ is the module-level namespace dict of Lib/asyncio/tasks.py; the type of any module namespace is dict, so __class__.__name__ is 'dict'; NEW in extra62: no prior asyncio spec has checked gather.__globals__.__class__.__name__ via __eq__; wave 228 first __globals__ class identity invariant for any asyncio function; verified with Python 3.14.3"
  category: globals
  kind: python_call_eq
  function: gather.__globals__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant asyncio_extra62.gather_globals_contains_gather:
  description: "asyncio.gather.__globals__.__contains__('gather') returns True — 'gather' is a key in the module-level namespace dict of Lib/asyncio/tasks.py where gather is defined; dict.__contains__ checks for key membership; NEW in extra62: no prior asyncio spec has used __contains__ on gather.__globals__; wave 228 first __globals__.__contains__ invariant for gather; verified with Python 3.14.3"
  category: globals
  kind: python_call_eq
  function: gather.__globals__.__contains__
  args: ["gather"]
  expected: true

invariant asyncio_extra62.queue_doc_contains_queue:
  description: "asyncio.Queue.__doc__.__contains__('Queue') returns True — asyncio.Queue.__doc__ is a non-empty str beginning 'A queue, useful for coordinating producer and consumer coroutines.' and mentioning 'Queue' (capital Q) multiple times; str.__contains__ returns True; NEW in extra62: no prior asyncio spec has used __contains__ on Queue.__doc__; wave 228 first __doc__.__contains__ content invariant for asyncio.Queue; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: Queue.__doc__.__contains__
  args: ["Queue"]
  expected: true
