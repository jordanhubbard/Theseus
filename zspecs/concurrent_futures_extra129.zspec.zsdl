invariant concurrent_futures_extra129.cf_spec_class_ModuleSpec:
  description: "concurrent.futures.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — concurrent.futures.__spec__ is an importlib.machinery.ModuleSpec instance; ModuleSpec is the universal spec class used by CPython's import system for all regular packages; the spec object stores module metadata including name, origin, submodule_search_locations, and has_location; concurrent.futures.__spec__.__class__.__name__.__len__() is 10 ('ModuleSpec'=10); concurrent.futures.__loader__.__class__.__name__ is 'SourceFileLoader' (len=16, indicating a filesystem-based package); contrast with the 'concurrent' namespace package which has a NamespaceLoader and no submodule_search_locations list; NEW in extra129: first standalone concurrent.futures __spec__ class name invariant in cfspecattr129 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

invariant concurrent_futures_extra129.cf_loader_SourceFileLoader:
  description: "concurrent.futures.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — concurrent.futures is a regular file-based package loaded from Lib/concurrent/futures/__init__.py; its loader is a SourceFileLoader instance (len=16); this contrasts with frozen modules (which use FrozenImporter) and C extension modules (which use ExtensionFileLoader); concurrent.futures.__spec__.has_location is True (confirming filesystem origin); concurrent.futures.__spec__.submodule_search_locations.__class__.__name__ is 'list' (a directory package with search paths); SourceFileLoader.__class__.__name__.__len__() is 16; NEW in extra129: first standalone concurrent.futures __loader__ class name invariant in cfspecattr129 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__loader__.__class__.__name__.__eq__"
  args: ["SourceFileLoader"]
  expected: true

invariant concurrent_futures_extra129.cf_package_len_18:
  description: "concurrent.futures.__package__.__len__() == 18 — concurrent.futures.__package__ is 'concurrent.futures' (18 chars: 'concurrent'=10 + '.'=1 + 'futures'=7 = 18); for packages (not submodules), __package__ equals __name__; concurrent.futures.__name__ and concurrent.futures.__spec__.name are also 'concurrent.futures' (len=18), establishing a three-way equality; 'concurrent.futures' at 18 chars is the longest module name in this spec series (compare: asyncio=7, multiprocessing=15, abc=3); concurrent.futures.__package__.__class__.__name__ is 'str'; NEW in extra129: first standalone concurrent.futures __package__ length invariant in cfspecattr129 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__package__.__len__"
  args: []
  expected: 18

invariant concurrent_futures_extra129.cf_spec_name_len_18:
  description: "concurrent.futures.__spec__.name.__len__() == 18 — concurrent.futures.__spec__.name is 'concurrent.futures' (18 characters); this is the same value as concurrent.futures.__name__ and concurrent.futures.__package__, all three being equal to 'concurrent.futures'; __spec__.name is a plain str (class='str'); the ModuleSpec.name attribute stores the fully-qualified module name used by the import system; concurrent.futures.__spec__.__class__.__name__ is 'ModuleSpec'; concurrent.futures.__spec__.submodule_search_locations.__class__.__name__ is 'list'; NEW in extra129: first standalone concurrent.futures __spec__.name length invariant in cfspecattr129 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__spec__.name.__len__"
  args: []
  expected: 18

invariant concurrent_futures_extra129.cf_submodule_search_locations_list:
  description: "concurrent.futures.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') returns True — concurrent.futures is a directory package (Lib/concurrent/futures/__init__.py exists); its submodule_search_locations is a plain Python list (class='list') containing the package directory path; this is 'list' rather than '_NamespacePath' because concurrent.futures has an __init__.py file (making it a regular package, not a namespace package); the parent 'concurrent' is a namespace package (no __init__.py) but concurrent.futures itself is a regular package; compare: abc.__spec__.submodule_search_locations is None (abc is a single module, not a package); NEW in extra129: first standalone concurrent.futures submodule_search_locations class name invariant in cfspecattr129 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.__spec__.submodule_search_locations.__class__.__name__.__eq__"
  args: ["list"]
  expected: true

