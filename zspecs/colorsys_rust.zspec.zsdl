spec: colorsys_rust
version: ">=3.9"
backend: rust_module(colorsys_rust)

docs: https://docs.python.org/3/library/colorsys.html

provenance:
  derived_from:
    - "Python colorsys documentation — https://docs.python.org/3/library/colorsys.html"
  not_derived_from:
    - "CPython source: Lib/colorsys.py"
  notes:
    - "Clean-room Rust reimplementation of Python colorsys module, exposed via PyO3."
    - "All color components are floats in the range [0.0, 1.0]; YIQ I and Q may be negative."
    - "rgb_to_yiq uses coefficients: Y = 0.30*R + 0.59*G + 0.11*B."
    - "rgb_to_hsv(1.0, 0.0, 0.0) returns tuple (0.0, 1.0, 1.0): hue=0 (red), sat=1, val=1."
    - "hsv_to_rgb(0.0, 1.0, 1.0) returns (1.0, 0.0, 0.0): exact inverse for pure red."
    - "rgb_to_hls(1.0, 0.0, 0.0) returns (0.0, 0.5, 1.0): hue=0, lightness=0.5, sat=1."
    - "rgb_to_hls(1.0, 1.0, 1.0) returns (0.0, 1.0, 0.0): white has lightness=1, sat=0."
    - "Functions return Python tuples; __getitem__ accesses individual components."
    - "All test vectors verified against Python 3.14.3 colorsys module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# rgb_to_hsv — HSV components of pure primary colors
invariant colorsys_rust.rgb_to_hsv.red_hue:
  description: "rgb_to_hsv(1.0, 0.0, 0.0)[0] == 0.0 — hue of red is 0.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

invariant colorsys_rust.rgb_to_hsv.red_saturation:
  description: "rgb_to_hsv(1.0, 0.0, 0.0)[1] == 1.0 — saturation of red is 1.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [1]
  expected: 1.0

invariant colorsys_rust.rgb_to_hsv.red_value:
  description: "rgb_to_hsv(1.0, 0.0, 0.0)[2] == 1.0 — value of red is 1.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [2]
  expected: 1.0

invariant colorsys_rust.rgb_to_hsv.black_value:
  description: "rgb_to_hsv(0.0, 0.0, 0.0)[2] == 0.0 — value of black is 0.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [2]
  expected: 0.0

invariant colorsys_rust.rgb_to_hsv.white_saturation:
  description: "rgb_to_hsv(1.0, 1.0, 1.0)[1] == 0.0 — saturation of white is 0.0"
  category: hsv
  kind: python_call_eq
  function: rgb_to_hsv
  args: [1.0, 1.0, 1.0]
  method: __getitem__
  method_args: [1]
  expected: 0.0

# hsv_to_rgb — inverse for pure red
invariant colorsys_rust.hsv_to_rgb.red_r:
  description: "hsv_to_rgb(0.0, 1.0, 1.0)[0] == 1.0 — red channel is 1.0"
  category: hsv
  kind: python_call_eq
  function: hsv_to_rgb
  args: [0.0, 1.0, 1.0]
  method: __getitem__
  method_args: [0]
  expected: 1.0

invariant colorsys_rust.hsv_to_rgb.red_g:
  description: "hsv_to_rgb(0.0, 1.0, 1.0)[1] == 0.0 — green channel of pure red is 0.0"
  category: hsv
  kind: python_call_eq
  function: hsv_to_rgb
  args: [0.0, 1.0, 1.0]
  method: __getitem__
  method_args: [1]
  expected: 0.0

invariant colorsys_rust.hsv_to_rgb.black:
  description: "hsv_to_rgb(0.0, 0.0, 0.0)[0] == 0.0 — black has zero red channel"
  category: hsv
  kind: python_call_eq
  function: hsv_to_rgb
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

# rgb_to_hls — HLS components
invariant colorsys_rust.rgb_to_hls.red_hue:
  description: "rgb_to_hls(1.0, 0.0, 0.0)[0] == 0.0 — hue of red in HLS is 0.0"
  category: hls
  kind: python_call_eq
  function: rgb_to_hls
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

invariant colorsys_rust.rgb_to_hls.white_lightness:
  description: "rgb_to_hls(1.0, 1.0, 1.0)[1] == 1.0 — white has lightness 1.0"
  category: hls
  kind: python_call_eq
  function: rgb_to_hls
  args: [1.0, 1.0, 1.0]
  method: __getitem__
  method_args: [1]
  expected: 1.0

invariant colorsys_rust.rgb_to_hls.black_lightness:
  description: "rgb_to_hls(0.0, 0.0, 0.0)[1] == 0.0 — black has lightness 0.0"
  category: hls
  kind: python_call_eq
  function: rgb_to_hls
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [1]
  expected: 0.0

# hls_to_rgb — inverse for white and black
invariant colorsys_rust.hls_to_rgb.white_r:
  description: "hls_to_rgb(0.0, 1.0, 0.0)[0] == 1.0 — white has red channel 1.0"
  category: hls
  kind: python_call_eq
  function: hls_to_rgb
  args: [0.0, 1.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 1.0

invariant colorsys_rust.hls_to_rgb.black_r:
  description: "hls_to_rgb(0.0, 0.0, 0.0)[0] == 0.0 — black has red channel 0.0"
  category: hls
  kind: python_call_eq
  function: hls_to_rgb
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

# rgb_to_yiq — Y (luma) components
invariant colorsys_rust.rgb_to_yiq.red_y:
  description: "rgb_to_yiq(1.0, 0.0, 0.0)[0] == 0.3 — luma of red using 0.30 coefficient"
  category: yiq
  kind: python_call_eq
  function: rgb_to_yiq
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.3

invariant colorsys_rust.rgb_to_yiq.black_y:
  description: "rgb_to_yiq(0.0, 0.0, 0.0)[0] == 0.0 — luma of black is 0.0"
  category: yiq
  kind: python_call_eq
  function: rgb_to_yiq
  args: [0.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
  expected: 0.0

# yiq_to_rgb — inverse: pure white roundtrip
invariant colorsys_rust.yiq_to_rgb.white_r:
  description: "yiq_to_rgb(1.0, 0.0, 0.0)[0] == 1.0 — white R channel"
  category: yiq
  kind: python_call_eq
  function: yiq_to_rgb
  args: [1.0, 0.0, 0.0]
  method: __getitem__
  method_args: [0]
