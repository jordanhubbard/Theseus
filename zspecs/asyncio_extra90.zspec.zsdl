table asyncio_extra90.Event_Queue_name_module:
  description: "asyncio Event and Queue __name__ and __module__ checks in asynciolocknames90 namespace — wave 250 theme: asyncio sync primitive class __name__ and __module__ string equality; Event.__name__.__eq__('Event')==True; Event.__module__.__eq__('asyncio.locks')==True (Python class in asyncio/locks.py); Queue.__name__.__eq__('Queue')==True; Queue.__module__.__eq__('asyncio.queues')==True (Python class in asyncio/queues.py); verified with Python 3.14.3"
  kind: python_call_eq
