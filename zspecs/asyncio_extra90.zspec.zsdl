  id_prefix: asynciolocknames90b

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,   Event.__name__.__eq__,   ["Event"],          true, "Event.__name__ == 'Event' — verified with Python 3.14.3"]
    - [event_module_eq, Event.__module__.__eq__, ["asyncio.locks"],  true, "Event.__module__ == 'asyncio.locks' — Python class in asyncio/locks.py; verified with Python 3.14.3"]
