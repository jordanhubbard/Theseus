spec: asyncio_extra90
version: ">=3.9"
backend: python_module(asyncio)
extends: asyncio_extra89

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec extends asyncio_extra89.zspec.zsdl."
    - "This spec covers: wave 250 theme — asyncio sync primitive class __name__ and __module__ string equality. NEW in extra90: Lock.__name__.__eq__('Lock')==True; Lock.__module__.__eq__('asyncio.locks')==True; Semaphore.__name__.__eq__('Semaphore')==True; Semaphore.__module__.__eq__('asyncio.locks')==True; BoundedSemaphore.__name__.__eq__('BoundedSemaphore')==True; BoundedSemaphore.__module__.__eq__('asyncio.locks')==True; Condition.__name__.__eq__('Condition')==True; Condition.__module__.__eq__('asyncio.locks')==True; Event.__name__.__eq__('Event')==True; Event.__module__.__eq__('asyncio.locks')==True; Queue.__name__.__eq__('Queue')==True; Queue.__module__.__eq__('asyncio.queues')==True; PriorityQueue.__name__.__eq__('PriorityQueue')==True; PriorityQueue.__module__.__eq__('asyncio.queues')==True; LifoQueue.__name__.__eq__('LifoQueue')==True; LifoQueue.__module__.__eq__('asyncio.queues')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__name__ == 'Lock'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__module__ == 'asyncio.locks'. Lock is a Python class defined in asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__name__ == 'Semaphore'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__module__ == 'asyncio.locks'. Semaphore is a Python class defined in asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks'. BoundedSemaphore is a Python class defined in asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__name__ == 'Condition'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__module__ == 'asyncio.locks'. Condition is a Python class defined in asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__name__ == 'Event'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__module__ == 'asyncio.locks'. Event is a Python class defined in asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__name__ == 'Queue'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__module__ == 'asyncio.queues'. Queue is a Python class defined in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.PriorityQueue.__name__ == 'PriorityQueue'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.PriorityQueue.__module__ == 'asyncio.queues'. PriorityQueue is a Python class defined in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.LifoQueue.__name__ == 'LifoQueue'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.LifoQueue.__module__ == 'asyncio.queues'. LifoQueue is a Python class defined in asyncio/queues.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Lock and Semaphore name + module — extra90
#
# Wave 250 theme: asyncio sync primitive class __name__ and __module__.
#
# Lock.__name__ == 'Lock'
# Lock.__module__ == 'asyncio.locks'
# Semaphore.__name__ == 'Semaphore'
# Semaphore.__module__ == 'asyncio.locks'
# ---------------------------------------------------------------------------

table asyncio_extra90.Lock_Semaphore_name_module:
  description: "asyncio Lock and Semaphore __name__ and __module__ checks in asynciolocknames90 namespace — wave 250 theme: asyncio sync primitive class __name__ and __module__ string equality; Lock.__name__.__eq__('Lock')==True; Lock.__module__.__eq__('asyncio.locks')==True (Python class in asyncio/locks.py); Semaphore.__name__.__eq__('Semaphore')==True; Semaphore.__module__.__eq__('asyncio.locks')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolocknames90

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,       Lock.__name__.__eq__,       ["Lock"],          true, "Lock.__name__ == 'Lock' — verified with Python 3.14.3"]
    - [lock_module_eq,     Lock.__module__.__eq__,     ["asyncio.locks"], true, "Lock.__module__ == 'asyncio.locks' — Python class in asyncio/locks.py; verified with Python 3.14.3"]
    - [sem_name_eq,        Semaphore.__name__.__eq__,  ["Semaphore"],     true, "Semaphore.__name__ == 'Semaphore' — verified with Python 3.14.3"]
    - [sem_module_eq,      Semaphore.__module__.__eq__, ["asyncio.locks"], true, "Semaphore.__module__ == 'asyncio.locks' — Python class in asyncio/locks.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
