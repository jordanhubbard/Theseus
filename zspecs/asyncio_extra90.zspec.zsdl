#
# BoundedSemaphore.__name__ == 'BoundedSemaphore'
# BoundedSemaphore.__module__ == 'asyncio.locks'
# Condition.__name__ == 'Condition'
# Condition.__module__ == 'asyncio.locks'
# ---------------------------------------------------------------------------

table asyncio_extra90.BoundedSemaphore_Condition_name_module:
  description: "asyncio BoundedSemaphore and Condition __name__ and __module__ checks in asynciolocknames90 namespace — wave 250 theme: asyncio sync primitive class __name__ and __module__ string equality; BoundedSemaphore.__name__.__eq__('BoundedSemaphore')==True; BoundedSemaphore.__module__.__eq__('asyncio.locks')==True (Python class in asyncio/locks.py); Condition.__name__.__eq__('Condition')==True; Condition.__module__.__eq__('asyncio.locks')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolocknames90a

  columns: [id, function, args, expected, description]
  rows:
    - [bsem_name_eq,   BoundedSemaphore.__name__.__eq__,   ["BoundedSemaphore"], true, "BoundedSemaphore.__name__ == 'BoundedSemaphore' — verified with Python 3.14.3"]
    - [bsem_module_eq, BoundedSemaphore.__module__.__eq__, ["asyncio.locks"],    true, "BoundedSemaphore.__module__ == 'asyncio.locks' — Python class in asyncio/locks.py; verified with Python 3.14.3"]
    - [cond_name_eq,   Condition.__name__.__eq__,          ["Condition"],        true, "Condition.__name__ == 'Condition' — verified with Python 3.14.3"]
    - [cond_module_eq, Condition.__module__.__eq__,        ["asyncio.locks"],    true, "Condition.__module__ == 'asyncio.locks' — Python class in asyncio/locks.py; verified with Python 3.14.3"]

