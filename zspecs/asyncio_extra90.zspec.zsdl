    - [queue_module_eq, Queue.__module__.__eq__, ["asyncio.queues"], true, "Queue.__module__ == 'asyncio.queues' — Python class in asyncio/queues.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio PriorityQueue and LifoQueue name + module, plus cross-checks — extra90
#
# PriorityQueue.__name__ == 'PriorityQueue'
# PriorityQueue.__module__ == 'asyncio.queues'
# LifoQueue.__name__ == 'LifoQueue'
# LifoQueue.__module__ == 'asyncio.queues'
# Cross-checks: Lock/Semaphore/Event modules are all asyncio.locks
# ---------------------------------------------------------------------------

table asyncio_extra90.PriorityQueue_LifoQueue_cross_checks:
  description: "asyncio PriorityQueue and LifoQueue __name__ and __module__ plus cross-checks in asynciolocknames90 namespace — wave 250 theme: asyncio sync primitive class __name__ and __module__ string equality; PriorityQueue.__name__.__eq__('PriorityQueue')==True; PriorityQueue.__module__.__eq__('asyncio.queues')==True; LifoQueue.__name__.__eq__('LifoQueue')==True; LifoQueue.__module__.__eq__('asyncio.queues')==True; Lock.__module__.__eq__('asyncio.locks')==True (cross-check); Semaphore.__module__.__eq__('asyncio.locks')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolocknames90c

  columns: [id, function, args, expected, description]
  rows:
    - [pq_name_eq,         PriorityQueue.__name__.__eq__,   ["PriorityQueue"],   true, "PriorityQueue.__name__ == 'PriorityQueue' — verified with Python 3.14.3"]
    - [pq_module_eq,       PriorityQueue.__module__.__eq__, ["asyncio.queues"],  true, "PriorityQueue.__module__ == 'asyncio.queues' — Python class in asyncio/queues.py; verified with Python 3.14.3"]
    - [lq_name_eq,         LifoQueue.__name__.__eq__,       ["LifoQueue"],       true, "LifoQueue.__name__ == 'LifoQueue' — verified with Python 3.14.3"]
    - [lq_module_eq,       LifoQueue.__module__.__eq__,     ["asyncio.queues"],  true, "LifoQueue.__module__ == 'asyncio.queues' — Python class in asyncio/queues.py; verified with Python 3.14.3"]
    - [lock_module_cross,  Lock.__module__.__eq__,          ["asyncio.locks"],   true, "Lock.__module__ == 'asyncio.locks' — cross-check; verified with Python 3.14.3"]
    - [sem_module_cross,   Semaphore.__module__.__eq__,     ["asyncio.locks"],   true, "Semaphore.__module__ == 'asyncio.locks' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra90
# ---------------------------------------------------------------------------

invariant asyncio_extra90.Lock_name:
  description: "asyncio.Lock.__name__.__eq__('Lock') returns True — Lock is a Python class defined in asyncio/locks.py; its __name__ is the bare class name 'Lock'; NEW in extra90: first standalone __name__ equality invariant for Lock in asynciolocknames90 namespace; wave 250; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant asyncio_extra90.Lock_module:
  description: "asyncio.Lock.__module__.__eq__('asyncio.locks') returns True — Lock is a Python class defined in asyncio/locks.py; the __module__ attribute reflects the submodule where the class is defined; NEW in extra90: first standalone __module__ equality invariant for Lock in asynciolocknames90 namespace; wave 250; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra90.Queue_name:
  description: "asyncio.Queue.__name__.__eq__('Queue') returns True — Queue is a Python class defined in asyncio/queues.py; its __name__ is the bare class name 'Queue'; NEW in extra90: first standalone __name__ equality invariant for Queue in asynciolocknames90 namespace; wave 250; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Queue.__name__.__eq__
  args: ["Queue"]
  expected: true

invariant asyncio_extra90.Queue_module:
  description: "asyncio.Queue.__module__.__eq__('asyncio.queues') returns True — Queue is a Python class defined in asyncio/queues.py; the queues submodule is separate from locks.py; NEW in extra90: first standalone __module__ equality invariant for Queue in asynciolocknames90 namespace; wave 250; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Queue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra90.Event_module:
  description: "asyncio.Event.__module__.__eq__('asyncio.locks') returns True — Event is a Python class defined in asyncio/locks.py alongside Lock, Semaphore, BoundedSemaphore, and Condition; NEW in extra90: first standalone __module__ equality invariant for Event in asynciolocknames90 namespace; wave 250; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true
