spec: sysconfig_extra10
version: ">=3.9"
backend: python_module(sysconfig)

docs: https://docs.python.org/3/library/sysconfig.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sysconfig.html — Python sysconfig module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sysconfig.py"
    - "sysconfig_extra3.zspec.zsdl — covers __qualname__ for 8 public functions (table); __module__ for get_python_version/get_platform; get_default_scheme __name__/__qualname__."
    - "sysconfig_extra4.zspec.zsdl — covers __module__ for get_config_var/parse_config_h/get_path/get_paths."
    - "sysconfig_extra8.zspec.zsdl — covers __module__ for get_scheme_names/get_path/get_path_names; __qualname__ for get_scheme_names/get_path_names."
    - "sysconfig_extra9.zspec.zsdl — covers __module__ for get_config_vars/get_paths/is_python_build; __qualname__ for get_config_var/parse_config_h; module __name__/__package__."
  notes:
    - "This spec extends sysconfig.zspec.zsdl through sysconfig_extra9.zspec.zsdl."
    - "Focus: __class__.__name__ and __class__.__qualname__ for the sysconfig module object (both 'module', not yet covered); get_default_scheme.__module__ == 'sysconfig' (not covered in any prior sysconfig spec)."
    - "sysconfig.__class__.__name__ == 'module' — the sysconfig object is a types.ModuleType; verified at runtime."
    - "sysconfig.__class__.__qualname__ == 'module' — the module object's class qualname; verified at runtime."
    - "sysconfig.get_default_scheme.__module__ == 'sysconfig' — function is defined in the sysconfig module; verified at runtime."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sysconfig module object — __class__.__name__ and __class__.__qualname__
#
# No prior sysconfig spec checks sysconfig.__class__.__name__ or
# sysconfig.__class__.__qualname__. The sysconfig module object is a
# types.ModuleType, so both its class name and class qualname are 'module'.
# ---------------------------------------------------------------------------

table sysconfig_extra10.module_class_attrs:
  description: "__class__.__name__ and __class__.__qualname__ for the sysconfig module object"
  kind: python_call_eq
  category: module_attrs

  columns: [id, function, args, expected]
  rows:
    - [class_name,     __class__.__name__.__eq__,     ["module"], true]
    - [class_qualname, __class__.__qualname__.__eq__, ["module"], true]

# ---------------------------------------------------------------------------
# sysconfig.get_default_scheme — __module__ standalone
#
# sysconfig_extra3 covers get_default_scheme.__name__ and __qualname__.
# No prior sysconfig spec checks get_default_scheme.__module__. The function
# is defined in the sysconfig module so its __module__ is 'sysconfig'.
# ---------------------------------------------------------------------------

invariant sysconfig_extra10.get_default_scheme.module:
  description: "sysconfig.get_default_scheme.__module__ == 'sysconfig'"
  category: function_attrs
  kind: python_call_eq
  function: get_default_scheme.__module__.__eq__
  args: ["sysconfig"]
  expected: true

# ---------------------------------------------------------------------------
# sysconfig module object — __class__.__name__ standalone
#
# The table above covers __class__.__name__ in a row. This invariant
# re-anchors it as a standalone in the extra10 namespace for direct
# single-axis lookup.
# ---------------------------------------------------------------------------

invariant sysconfig_extra10.module.class_name:
  description: "sysconfig.__class__.__name__ == 'module' — sysconfig is a types.ModuleType"
  category: module_attrs
  kind: python_call_eq
  function: __class__.__name__.__eq__
  args: ["module"]
  expected: true

# ---------------------------------------------------------------------------
# sysconfig module object — __class__.__qualname__ standalone
#
# The table above covers __class__.__qualname__ in a row. This invariant
# re-anchors it as a standalone in the extra10 namespace.
# ---------------------------------------------------------------------------

invariant sysconfig_extra10.module.class_qualname:
  description: "sysconfig.__class__.__qualname__ == 'module' — module object's class qualname"
  category: module_attrs
  kind: python_call_eq
  function: __class__.__qualname__.__eq__
  args: ["module"]
  expected: true
