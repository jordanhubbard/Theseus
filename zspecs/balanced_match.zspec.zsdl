spec: balanced_match
version: ">=1.0.0"
backend: node(balanced-match)

docs: https://github.com/juliangruber/balanced-match#readme

provenance:
  derived_from:
    - "balanced-match README — https://github.com/juliangruber/balanced-match#readme"
    - "Test vectors verified with balanced-match@1.0.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "balanced-match source: index.js"
  notes:
    - "balanced-match exports an object with balanced() and range() methods."
    - "balanced(open, close, str) returns {start, end, pre, body, post} or null."
    - "range(open, close, str) returns [start, end] indices or undefined."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns result object or null. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table balanced_match.balanced:
  kind: node_module_call_eq
  function: balanced
  category: balanced
  id_prefix: bm

  columns: [id, args, expected]
  rows:
    - [simple,  ["{", "}", "{abc}"],   {"start": 0, "end": 4, "pre": "", "body": "abc", "post": ""}]

table balanced_match.range:
  kind: node_module_call_eq
  function: range
  category: range
  id_prefix: bm_range

  columns: [id, args, expected]
  rows:
    - [simple,  ["{", "}", "{abc}"],  [0, 4]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:44:41Z
  iterations: 2
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 2 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
