spec: humanize_plus
version: ">=1.8.2"
backend: node(humanize-plus)

docs: https://www.npmjs.com/package/humanize-plus

provenance:
  derived_from:
    - "humanize-plus README — https://www.npmjs.com/package/humanize-plus"
    - "Test vectors verified with humanize-plus via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "humanize-plus source"
  notes:
    - "humanize-plus is an npm package. Install: npm install humanize-plus"
    - "Provides humanization helpers: intComma, ordinal, fileSize, and more."
    - "intComma adds comma separators to numbers."
    - "ordinal returns the ordinal string for a number (1st, 2nd, 3rd, etc.)."
    - "fileSize formats bytes as a human-readable string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table humanize_plus.int_comma:
  kind: node_module_call_eq
  function: intComma
  category: numbers
  id_prefix: hpic

  columns: [id, args, expected]
  rows:
    - [thousands,  [1000],    "1,000"]
    - [millions,   [1000000], "1,000,000"]
    - [small,      [100],     "100"]

table humanize_plus.ordinal:
  kind: node_module_call_eq
  function: ordinal
  category: numbers
  id_prefix: hpord

  columns: [id, args, expected]
  rows:
    - [first,        [1],  "1st"]
    - [second,       [2],  "2nd"]
    - [third,        [3],  "3rd"]
    - [twenty_first, [21], "21st"]

table humanize_plus.file_size:
  kind: node_module_call_eq
  function: fileSize
  category: numbers
  id_prefix: hpfs

  columns: [id, args, expected]
  rows:
    - [kilobyte,  [1024],    "1 KB"]
    - [megabyte,  [1048576], "1.00 MB"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:10:10Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
