spec: theseus_codecs_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_codecs_cr2)
blocks: codecs

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html"
    - "Unicode standard codec registry"
  notes:
    - "Clean-room extended codecs utilities. Do NOT import codecs."
    - "lookup(encoding): return CodecInfo object with .name attribute."
    - "encode(obj, encoding='utf-8', errors='strict'): encode string to bytes."
    - "decode(obj, encoding='utf-8', errors='strict'): decode bytes to string."
    - "codecs2_lookup(): codecs.lookup('utf-8').name == 'utf-8'."
    - "codecs2_encode(): encode('hello', 'utf-8') == (b'hello', 5)."
    - "codecs2_decode(): decode(b'hello', 'utf-8') == ('hello', 5)."
    - "Zero-arg invariant signatures — def codecs2_lookup(): return hardcoded_result"
    - "Support utf-8, ascii, latin-1 encodings."
    - "encode returns (bytes, length_consumed) tuple; decode returns (str, length_consumed) tuple."
    - "CodecInfo.name is the canonical normalized name (e.g. 'utf-8' not 'UTF-8')."
    - "Export: lookup(encoding), encode(obj, encoding), decode(obj, encoding), CodecInfo."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_codecs_cr2.lookup:
  description: "lookup('utf-8').name == 'utf-8'"
  category: lookup
  kind: python_call_eq
  function: codecs2_lookup
  args: []
  expected: "utf-8"

invariant theseus_codecs_cr2.encode:
  description: "encode('hello', 'utf-8') length component == 5"
  category: encode
  kind: python_call_eq
  function: codecs2_encode
  args: []
  expected: 5

invariant theseus_codecs_cr2.decode:
  description: "decode(b'hello', 'utf-8') string component == 'hello'"
  category: decode
  kind: python_call_eq
  function: codecs2_decode
  args: []
  expected: "hello"
