spec: timeit_extra2
version: ">=3.9"
backend: python_module(timeit)

docs: https://docs.python.org/3/library/timeit.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/timeit.html — Python timeit module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/timeit.py"
    - "timeit.zspec.zsdl — covers Timer.__name__, Timer.__module__, Timer method names, timeit.__name__, repeat.__name__, default_timer type, timeit() returns float"
    - "timeit_extra.zspec.zsdl — covers Timer.__qualname__, Timer.__doc__, Timer method __qualname__ and type checks, default_timer.__name__=='perf_counter', repeat() returns list, repeat() length, module __name__"
  notes:
    - "This spec extends timeit.zspec.zsdl and timeit_extra.zspec.zsdl."
    - "Focus: module affiliation (__module__) for top-level functions, Timer.__bases__, and Timer.__qualname__ (cross-check)."
    - "timeit.timeit.__module__ == 'timeit' — function is defined in the timeit module."
    - "timeit.repeat.__module__ == 'timeit' — function is defined in the timeit module."
    - "timeit.Timer.__bases__[0].__name__ == 'object' — Timer inherits directly from object."
    - "timeit.timeit.__qualname__ == 'timeit' — module-level function qualname matches its name."
    - "timeit.repeat.__qualname__ == 'repeat' — module-level function qualname matches its name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Timer.__bases__ — class hierarchy
# Not covered by timeit.zspec.zsdl or timeit_extra.zspec.zsdl
# ---------------------------------------------------------------------------

invariant timeit_extra2.Timer.base_name:
  description: "timeit.Timer.__bases__[0].__name__ == 'object' — Timer inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: Timer.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Module-level function __module__ checks
# timeit.zspec.zsdl and timeit_extra.zspec.zsdl cover __name__ but NOT __module__
# ---------------------------------------------------------------------------

invariant timeit_extra2.timeit.module:
  description: "timeit.timeit.__module__ == 'timeit'"
  category: functions
  kind: python_call_eq
  function: timeit.__module__.__eq__
  args: ["timeit"]
  expected: true

invariant timeit_extra2.repeat.module:
  description: "timeit.repeat.__module__ == 'timeit'"
  category: functions
  kind: python_call_eq
  function: repeat.__module__.__eq__
  args: ["timeit"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __qualname__ checks
# timeit_extra.zspec.zsdl covers Timer method __qualname__ but NOT top-level function __qualname__
# ---------------------------------------------------------------------------

invariant timeit_extra2.timeit.qualname:
  description: "timeit.timeit.__qualname__ == 'timeit' — module-level function qualname matches name"
  category: functions
  kind: python_call_eq
  function: timeit.__qualname__.__eq__
  args: ["timeit"]
  expected: true

invariant timeit_extra2.repeat.qualname:
  description: "timeit.repeat.__qualname__ == 'repeat' — module-level function qualname matches name"
  category: functions
  kind: python_call_eq
  function: repeat.__qualname__.__eq__
  args: ["repeat"]
  expected: true

# ---------------------------------------------------------------------------
# Table: function __name__ cross-check (new id_prefix, distinct from timeit.zspec.zsdl)
# ---------------------------------------------------------------------------

table timeit_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [timeit, timeit.__name__.__eq__, ["timeit"], true]
    - [repeat, repeat.__name__.__eq__, ["repeat"], true]
