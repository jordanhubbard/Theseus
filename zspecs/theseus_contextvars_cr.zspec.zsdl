spec: theseus_contextvars_cr
version: ">=3.7"
backend: python_cleanroom(theseus_contextvars_cr)
blocks: contextvars

docs: https://docs.python.org/3/library/contextvars.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/contextvars.html"
  not_derived_from:
    - "CPython source: Lib/contextvars.py, Modules/_contextvars.c"
  notes:
    - "Clean-room contextvars module. Do NOT import contextvars."

error_model: python_exceptions

invariant theseus_contextvars_cr.ctxvars2_contextvar:
  description: "ContextVar get/set works correctly"
  category: behavior
  kind: python_call_eq
  function: ctxvars2_contextvar
  args: []
  expected: true

invariant theseus_contextvars_cr.ctxvars2_copy_context:
  description: "copy_context() creates an isolated context copy"
  category: behavior
  kind: python_call_eq
  function: ctxvars2_copy_context
  args: []
  expected: true

invariant theseus_contextvars_cr.ctxvars2_token:
  description: "Token from ContextVar.set() allows var.reset()"
  category: behavior
  kind: python_call_eq
  function: ctxvars2_token
  args: []
  expected: true
