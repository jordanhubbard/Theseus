spec: threading_extra1441
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra1426.zspec.zsdl — covers __format__ and __dir__ checks for threading classes"
  notes:
    - "Wave 543 (_extra1441): focuses on __subclasshook__, __instancecheck__, and __subclasscheck__ ABC-machinery checks for threading classes."
    - "threading.Thread.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — Thread is a pure Python class with metaclass=type; __subclasshook__ inherited from object. Verified Python 3.14.3."
    - "threading.Semaphore.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "threading.Barrier.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "threading.Condition.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "None of Thread, Semaphore, Barrier, Condition define '__subclasshook__', '__instancecheck__', or '__subclasscheck__' in their own __dict__. Verified Python 3.14.3."
    - "threading.Thread.__subclasscheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "threading.Semaphore.__subclasscheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "threading.Barrier.__subclasscheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "threading.Condition.__subclasscheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading class __subclasshook__ method type checks
#
# Wave 543 theme: __subclasshook__.__class__.__name__ checks for threading
# classes. Thread, Semaphore, Barrier, Condition are all pure-Python classes
# with metaclass=type. __subclasshook__ inherited from object resolves as
# 'builtin_function_or_method'. None override it.
# ---------------------------------------------------------------------------

table threading_extra1441.subclasshook_class_name:
  description: "threading classes: __subclasshook__.__class__.__name__ == 'builtin_function_or_method' for Thread, Semaphore, Barrier, Condition; wave 543; new to extra1441"
  kind: python_call_eq
  category: subclasshook_class_name
  id_prefix: th1441sc

  columns: [id, function, args, expected, description]
  rows:
    - [th1441sc001,
       "Thread.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.Thread.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — Thread is a pure Python class with metaclass=type; __subclasshook__ inherited from object, not ABCMeta; new to extra1441"]
    - [th1441sc002,
       "Semaphore.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.Semaphore.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — Semaphore inherits __subclasshook__ from object; new to extra1441"]
    - [th1441sc003,
       "Barrier.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.Barrier.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — Barrier inherits __subclasshook__ from object; new to extra1441"]
    - [th1441sc004,
       "Condition.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.Condition.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — Condition inherits __subclasshook__ from object; new to extra1441"]
    - [th1441sc005,
       "Thread.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.Thread.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — Thread inherits __subclasscheck__ from object; new to extra1441"]
    - [th1441sc006,
       "Semaphore.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.Semaphore.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — Semaphore inherits __subclasscheck__ from object; new to extra1441"]
    - [th1441sc007,
       "Barrier.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.Barrier.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — Barrier inherits __subclasscheck__ from object; new to extra1441"]
    - [th1441sc008,
       "Condition.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "threading.Condition.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — Condition inherits __subclasscheck__ from object; new to extra1441"]

# ---------------------------------------------------------------------------
# Table 2: threading class __subclasshook__ dict absence
#
# Wave 543 theme: '__subclasshook__' not in own __dict__ for threading classes.
# Thread, Semaphore, Barrier, Condition are plain Python classes with no
# ABC-hook overrides in their own namespaces.
# ---------------------------------------------------------------------------

table threading_extra1441.subclasshook_dict_membership:
  description: "threading classes: '__subclasshook__' not in own __dict__ for Thread, Semaphore, Barrier, Condition; wave 543; new to extra1441"
  kind: python_call_eq
  category: subclasshook_dict_membership
  id_prefix: th1441dm

  columns: [id, function, args, expected, description]
  rows:
    - [th1441dm001,
       "Thread.__dict__.__contains__",
       ["__subclasshook__"],
       false,
       "threading.Thread.__dict__.__contains__('__subclasshook__') == False — Thread does not define __subclasshook__ in its own class __dict__; not an ABC subclass; new to extra1441"]
    - [th1441dm002,
       "Semaphore.__dict__.__contains__",
       ["__subclasshook__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__subclasshook__') == False — Semaphore does not define __subclasshook__ in its own class __dict__; not an ABC subclass; new to extra1441"]
    - [th1441dm003,
       "Barrier.__dict__.__contains__",
       ["__subclasshook__"],
       false,
       "threading.Barrier.__dict__.__contains__('__subclasshook__') == False — Barrier does not define __subclasshook__ in its own class __dict__; not an ABC subclass; new to extra1441"]
    - [th1441dm004,
       "Condition.__dict__.__contains__",
       ["__subclasshook__"],
       false,
       "threading.Condition.__dict__.__contains__('__subclasshook__') == False — Condition does not define __subclasshook__ in its own class __dict__; not an ABC subclass; new to extra1441"]
    - [th1441dm005,
       "Thread.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "threading.Thread.__dict__.__contains__('__instancecheck__') == False — Thread does not define __instancecheck__ in its own class __dict__; new to extra1441"]
    - [th1441dm006,
       "Semaphore.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__instancecheck__') == False — Semaphore does not define __instancecheck__ in its own class __dict__; new to extra1441"]
    - [th1441dm007,
       "Barrier.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "threading.Barrier.__dict__.__contains__('__instancecheck__') == False — Barrier does not define __instancecheck__ in its own class __dict__; new to extra1441"]
    - [th1441dm008,
       "Condition.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "threading.Condition.__dict__.__contains__('__instancecheck__') == False — Condition does not define __instancecheck__ in its own class __dict__; new to extra1441"]

