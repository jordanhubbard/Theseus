# ---------------------------------------------------------------------------
# Standalone invariants — extra1441
# ---------------------------------------------------------------------------

invariant threading_extra1441.Thread_subclasshook_is_builtin:
  description: "threading.Thread.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — inherited from object; wave 543; new to extra1441"
  kind: python_call_eq
  function: Thread.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra1441.Thread_subclasshook_not_in_dict:
  description: "'__subclasshook__' not in threading.Thread.__dict__ — Thread does not override __subclasshook__; wave 543; new to extra1441"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__subclasshook__"]
  expected: false

invariant threading_extra1441.Thread_instancecheck_not_in_dict:
  description: "'__instancecheck__' not in threading.Thread.__dict__ — Thread does not define __instancecheck__; wave 543; new to extra1441"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__instancecheck__"]
  expected: false

invariant threading_extra1441.Condition_subclasscheck_not_in_dict:
  description: "'__subclasscheck__' not in threading.Condition.__dict__ — Condition does not define __subclasscheck__; wave 543; new to extra1441"
