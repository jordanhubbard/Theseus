spec: this_extra2
version: ">=3.9"
backend: python_module(this)

docs: https://docs.python.org/3/library/this.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/this.html — Python this module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/this.py"
  notes:
    - "This spec extends this.zspec.zsdl and prior extras."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "No public functions; all invariants are attribute accesses on module-level data."
  stderr: "null"
  stickiness: "N/A — module-level attribute reads are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Module name check
# ---------------------------------------------------------------------------

invariant this_extra2.module_name:
  description: "this.__name__ == 'this'"
  category: module_meta
  kind: python_call_eq
  function: __name__.__eq__
  args: ["this"]
  expected: true

# ---------------------------------------------------------------------------
# this.i type check — loop counter left in module namespace
# ---------------------------------------------------------------------------

invariant this_extra2.i.is_int:
  description: "this.i.__class__.__name__ == 'int' — the loop counter is an int"
  category: types
  kind: python_call_eq
  function: i.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# this.d exact size — 52 entries (26 lower + 26 upper ROT-13 pairs)
# ---------------------------------------------------------------------------

invariant this_extra2.d.len:
  description: "this.d has 52 entries (26 lower + 26 upper ROT-13 pairs)"
  category: decode_dict
  kind: python_call_eq
  function: d.__len__
  args: []
  expected: 52

# ---------------------------------------------------------------------------
# this.s length — the encoded Zen of Python text
# ---------------------------------------------------------------------------

invariant this_extra2.s.len:
  description: "this.s.__len__() == 856 — the encoded text has 856 characters"
  category: contents
  kind: python_call_eq
  function: s.__len__
  args: []
  expected: 856

# ---------------------------------------------------------------------------
# Additional ROT-13 uppercase spot-checks not in prior specs
# ---------------------------------------------------------------------------

table this_extra2.d.uppercase_cipher_mappings:
  kind: python_call_eq
  category: cipher
  id_prefix: upper_cipher2

  columns: [id, function, args, expected]
  rows:
    - [B_to_O, d.__getitem__, ["B"], "O"]
    - [O_to_B, d.__getitem__, ["O"], "B"]
    - [C_to_P, d.__getitem__, ["C"], "P"]
    - [P_to_C, d.__getitem__, ["P"], "C"]
    - [M_to_Z, d.__getitem__, ["M"], "Z"]

# ---------------------------------------------------------------------------
# this.d value class check for a lowercase key
# ---------------------------------------------------------------------------

invariant this_extra2.d.lowercase_value_type_is_str:
  description: "this.d['g'] is a str (the decoded lowercase character)"
  category: types
  kind: python_call_eq
  function: d.__getitem__
  args: ["g"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true
