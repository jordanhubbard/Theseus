spec: socket_extra281
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl through socket_extra280.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket_extra280.zspec.zsdl covers: socket.socket method __qualname__ values (setsockopt/getsockopt/fileno/settimeout/gettimeout/bind); method __class__.__name__ == 'method_descriptor'; socket.__name__ == 'socket'; socket.__module__ == 'socket'; MRO length == 3."
    - "This spec focuses on: socket.socket() instance error cases and runtime properties — getpeername() on an unconnected socket raises OSError; fileno() returns an int >= 0; .type == SOCK_STREAM or SOCK_DGRAM; gettimeout() returns None by default; settimeout/gettimeout round-trip; socket.error is OSError; socket.timeout is TimeoutError."
    - "socket.socket(AF_INET, SOCK_STREAM).getpeername() raises OSError [Errno 57] on macOS (not connected). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket(AF_INET, SOCK_STREAM).fileno() returns an int >= 0 — the file descriptor assigned by the OS. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket(AF_INET, SOCK_STREAM).type == socket.SOCK_STREAM == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket(AF_INET, SOCK_DGRAM).type == socket.SOCK_DGRAM == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket(AF_INET, SOCK_STREAM).gettimeout() returns None by default — blocking mode. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.error is OSError — socket.error is a direct alias for OSError in Python 3. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.timeout is TimeoutError — socket.timeout is an alias for TimeoutError in Python 3. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "socket.socket() instances raise OSError for network-state errors (not connected, already bound, etc.). socket.error is OSError; socket.timeout is TimeoutError."
  stderr: "null"
  stickiness: "socket.socket() instances carry OS-level state; each test must create its own fresh instance."
  codes:
    57: "ENOTCONN — socket is not connected (macOS/Darwin)"

# ---------------------------------------------------------------------------
# socket module-level constants — AF_INET, SOCK_STREAM, SOCK_DGRAM integer values
# These integer values are stable across platforms for AF_INET and the stream/
# datagram socket types.  SOCK_STREAM == 1, SOCK_DGRAM == 2, AF_INET == 2
# on macOS/Darwin.
# ---------------------------------------------------------------------------

table socket_extra281.socket_constants:
  description: "socket.AF_INET, socket.SOCK_STREAM, socket.SOCK_DGRAM integer values on macOS/Darwin; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: constant_value
  id_prefix: sco281

  columns: [id, function, args, expected, description]
  rows:
    - [AF_INET_value,     "AF_INET.__eq__",     [2], true, "socket.AF_INET == 2 on macOS/Darwin"]
    - [SOCK_STREAM_value, "SOCK_STREAM.__eq__", [1], true, "socket.SOCK_STREAM == 1"]
    - [SOCK_DGRAM_value,  "SOCK_DGRAM.__eq__",  [2], true, "socket.SOCK_DGRAM == 2"]

# ---------------------------------------------------------------------------
# socket.socket() instance — .type attribute
# The .type attribute of a freshly created socket equals the socket type
# constant passed to the constructor.  SOCK_STREAM → 1; SOCK_DGRAM → 2.
# ---------------------------------------------------------------------------

table socket_extra281.socket_instance_type:
  description: "socket.socket(AF_INET, SOCK_x).type == SOCK_x — .type attribute reflects the constructor argument; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: instance_attribute
  id_prefix: sit281

  columns: [id, function, args, expected, description]
  rows:
    - [stream_type_eq, "socket.__call__.type.__eq__", [{address_family: AF_INET, socket_type: SOCK_STREAM}, 1], true, "socket(AF_INET, SOCK_STREAM).type == 1 (SOCK_STREAM)"]
    - [dgram_type_eq,  "socket.__call__.type.__eq__", [{address_family: AF_INET, socket_type: SOCK_DGRAM},  2], true, "socket(AF_INET, SOCK_DGRAM).type == 2 (SOCK_DGRAM)"]

# ---------------------------------------------------------------------------
# socket.socket() — getpeername() raises OSError on unconnected socket
# Calling getpeername() before connect() raises OSError [Errno 57] on macOS.
# This is a fundamental invariant: the socket has no peer until connected.
# ---------------------------------------------------------------------------

invariant socket_extra281.instance.getpeername_raises_oserror:
  description: "socket.socket(AF_INET, SOCK_STREAM).getpeername() raises OSError — socket has no peer before connect(); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: error
  kind: python_call_raises
  function: socket.__call__.getpeername
  args: [{address_family: AF_INET, socket_type: SOCK_STREAM}]
  raises: OSError

# ---------------------------------------------------------------------------
# socket.socket() — fileno() returns a non-negative int
# fileno() returns the OS-level file descriptor integer.  The value is
# assigned by the OS and varies per run, but is always an int >= 0.
# ---------------------------------------------------------------------------

invariant socket_extra281.instance.fileno_returns_int:
  description: "socket.socket(AF_INET, SOCK_STREAM).fileno().__class__.__name__ == 'int' — fileno() returns an integer file descriptor; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: instance_method
  kind: python_call_eq
  function: socket.__call__.fileno.__class__.__name__.__eq__
  args: [{address_family: AF_INET, socket_type: SOCK_STREAM}, "int"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket() — gettimeout() returns None in default blocking mode
# A freshly created socket is in blocking mode; gettimeout() returns None.
# After settimeout(5.0) it returns 5.0; after settimeout(None) it resets.
# ---------------------------------------------------------------------------

invariant socket_extra281.instance.gettimeout_default_none:
  description: "socket.socket(AF_INET, SOCK_STREAM).gettimeout() == None — new sockets start in blocking mode with no timeout; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: instance_method
  kind: python_call_eq
  function: socket.__call__.gettimeout
  args: [{address_family: AF_INET, socket_type: SOCK_STREAM}]
  expected: null

# ---------------------------------------------------------------------------
# socket module exception aliases
# In Python 3 socket.error is OSError and socket.timeout is TimeoutError.
# These aliases are guaranteed by the Python docs and are stable across 3.x.
# ---------------------------------------------------------------------------

invariant socket_extra281.aliases.error_is_oserror:
  description: "socket.error is OSError — socket.error is a direct alias for OSError in Python 3; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: exception_alias
  kind: python_call_eq
  function: error.__eq__
  args: [{builtin: OSError}]
  expected: true

invariant socket_extra281.aliases.timeout_is_timeouterror:
  description: "socket.timeout is TimeoutError — socket.timeout is an alias for the built-in TimeoutError in Python 3; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: exception_alias
  kind: python_call_eq
  function: timeout.__eq__
  args: [{builtin: TimeoutError}]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket() — getsockname() returns ('0.0.0.0', 0) before bind
# An unbound TCP socket has no local address; getsockname() returns the
# wildcard address with port 0 on macOS/Darwin.
# ---------------------------------------------------------------------------

invariant socket_extra281.instance.getsockname_unbound:
  description: "socket.socket(AF_INET, SOCK_STREAM).getsockname() == ('0.0.0.0', 0) — unbound socket reports wildcard address and port 0; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: instance_method
  kind: python_call_eq
  function: socket.__call__.getsockname
  args: [{address_family: AF_INET, socket_type: SOCK_STREAM}]
  expected: ["0.0.0.0", 0]
