spec: dataclasses_extra15
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra14.zspec.zsdl."
    - "dataclasses_extra14 covers: Field.__bases__ len/[0]; FrozenInstanceError.__bases__[0].__name__; module.__name__.__eq__; dataclass.__qualname__; replace.__name__/__name__.__len__; is_dataclass.__name__.__len__; table function_name_lengths2."
    - "dataclasses_extra13 covers: function __name__.__len__ for field/asdict/astuple/make_dataclass; function __qualname__ table for fields/asdict/astuple/replace/is_dataclass; Field/__qualname__ and InitVar/__qualname__; __loader__.__class__.__name__; FrozenInstanceError.__qualname__.__len__."
    - "NOT yet covered: dataclasses.Field.__name__.__len__() == 5 — 'Field' has 5 characters."
    - "NOT yet covered: dataclasses.InitVar.__name__.__len__() == 7 — 'InitVar' has 7 characters."
    - "NOT yet covered: dataclasses.FrozenInstanceError.__name__.__len__() == 19 — 'FrozenInstanceError' has 19 characters."
    - "NOT yet covered: dataclasses.Field.__qualname__.__len__() == 5 — qualname length for Field."
    - "NOT yet covered: dataclasses.InitVar.__qualname__.__len__() == 7 — qualname length for InitVar."
    - "NOT yet covered: dataclasses.is_dataclass.__qualname__.__len__() == 12 — 'is_dataclass' has 12 characters."
    - "NOT yet covered: dataclasses.make_dataclass.__qualname__.__len__() == 14 — 'make_dataclass' has 14 characters."
    - "NOT yet covered: dataclasses.dataclass.__module__ == 'dataclasses' — standalone invariant."
    - "NOT yet covered: dataclasses.field.__module__ == 'dataclasses' — standalone invariant."
    - "dataclasses.Field.__name__.__len__() == 5."
    - "dataclasses.InitVar.__name__.__len__() == 7."
    - "dataclasses.FrozenInstanceError.__name__.__len__() == 19."
    - "dataclasses.Field.__qualname__.__len__() == 5."
    - "dataclasses.InitVar.__qualname__.__len__() == 7."
    - "dataclasses.is_dataclass.__qualname__.__len__() == 12."
    - "dataclasses.make_dataclass.__qualname__.__len__() == 14."
    - "dataclasses.dataclass.__module__ == 'dataclasses' — standalone invariant distinct from extra8 table."
    - "dataclasses.field.__module__ == 'dataclasses' — standalone invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ string lengths — Field, InitVar, FrozenInstanceError
#
# dataclasses_extra13 covers __name__.__len__() for field/asdict/astuple/
# make_dataclass (functions). No prior spec checks __name__.__len__() for
# the dataclasses class types: Field, InitVar, or FrozenInstanceError.
# ---------------------------------------------------------------------------

table dataclasses_extra15.class_name_lengths:
  kind: python_call_eq
  category: class_names
  id_prefix: classnamelen

  columns: [id, function, args, expected]
  rows:
    - [Field,               Field.__name__.__len__,               [], 5]
    - [InitVar,             InitVar.__name__.__len__,             [], 7]
    - [FrozenInstanceError, FrozenInstanceError.__name__.__len__, [], 19]

# ---------------------------------------------------------------------------
# Class __qualname__ string lengths — Field, InitVar
#
# dataclasses_extra13 covers Field.__qualname__.__eq__ and
# InitVar.__qualname__.__eq__ as standalone boolean invariants.
# No prior spec checks the string length of those qualnames.
# For top-level classes __qualname__ == __name__, so the lengths match.
# ---------------------------------------------------------------------------

invariant dataclasses_extra15.Field.qualname_len:
  description: "dataclasses.Field.__qualname__.__len__() == 5 — 'Field' is 5 characters"
  category: qualnames
  kind: python_call_eq
  function: Field.__qualname__.__len__
  args: []
  expected: 5

invariant dataclasses_extra15.InitVar.qualname_len:
  description: "dataclasses.InitVar.__qualname__.__len__() == 7 — 'InitVar' is 7 characters"
  category: qualnames
  kind: python_call_eq
  function: InitVar.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Function __qualname__ string lengths — is_dataclass, make_dataclass
#
# dataclasses_extra13 covers __qualname__.__eq__ for these functions via table.
# No prior spec checks __qualname__.__len__() for is_dataclass or
# make_dataclass. For top-level functions qualname equals name.
# ---------------------------------------------------------------------------

invariant dataclasses_extra15.is_dataclass.qualname_len:
  description: "dataclasses.is_dataclass.__qualname__.__len__() == 12 — 'is_dataclass' is 12 characters"
  category: qualnames
  kind: python_call_eq
  function: is_dataclass.__qualname__.__len__
  args: []
  expected: 12

invariant dataclasses_extra15.make_dataclass.qualname_len:
  description: "dataclasses.make_dataclass.__qualname__.__len__() == 14 — 'make_dataclass' is 14 characters"
  category: qualnames
  kind: python_call_eq
  function: make_dataclass.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# dataclass and field __module__ — standalone invariants
#
# dataclasses_extra8 covers __module__ for several functions in a table, but
# no prior spec verifies dataclass.__module__ or field.__module__ as a
# standalone __eq__ boolean invariant on its own.
# ---------------------------------------------------------------------------

invariant dataclasses_extra15.dataclass.module:
  description: "dataclasses.dataclass.__module__ == 'dataclasses' — standalone __eq__ invariant"
  category: module_attrs
  kind: python_call_eq
  function: dataclass.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra15.field.module:
  description: "dataclasses.field.__module__ == 'dataclasses' — standalone __eq__ invariant"
  category: module_attrs
  kind: python_call_eq
  function: field.__module__.__eq__
  args: ["dataclasses"]
  expected: true
