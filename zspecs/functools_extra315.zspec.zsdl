spec: functools_extra315
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.partial(int, '10', base=2).__class__.__name__ == 'partial' — instance of the partial C-type."
    - "functools.partial(int, '10', base=2).func.__name__ == 'int' — .func holds the wrapped callable."
    - "functools.partial(int, '10', base=2).args == ('10',) — positional args frozen at construction."
    - "functools.partial(int, '10', base=2).keywords == {'base': 2} — keyword args frozen at construction."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — docstring is a str."
    - "functools.partialmethod.__name__ == 'partialmethod' — partialmethod is a Python class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partial instance identity — class name and frozen callable
#
# functools.partial(int, '10', base=2) creates a partial object whose
# __class__.__name__ is 'partial' and whose .func is the int builtin.
# ---------------------------------------------------------------------------

invariant functools_extra315.partial_instance_class_name:
  description: "functools.partial(int, '10', base=2).__class__.__name__ == 'partial'"
  category: partial_identity
  kind: python_call_eq
  function: "partial(int, '10', base=2).__class__.__name__.__eq__"
  args: ["partial"]
  expected: true

invariant functools_extra315.partial_func_name:
  description: "functools.partial(int, '10', base=2).func.__name__ == 'int'"
  category: partial_identity
  kind: python_call_eq
  function: "partial(int, '10', base=2).func.__name__.__eq__"
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# partial .args — frozen positional arguments tuple
#
# .args is ('10',). Verified via __len__ and __eq__ on the tuple.
# ---------------------------------------------------------------------------

invariant functools_extra315.partial_args_len:
  description: "functools.partial(int, '10', base=2).args.__len__() == 1 — one positional arg frozen"
  category: partial_args
  kind: python_call_eq
  function: "partial(int, '10', base=2).args.__len__"
  args: []
  expected: 1

invariant functools_extra315.partial_args_eq:
  description: "functools.partial(int, '10', base=2).args.__eq__(('10',)) == True"
  category: partial_args
  kind: python_call_eq
  function: "partial(int, '10', base=2).args.__eq__"
  args: [["10"]]
  expected: true

# ---------------------------------------------------------------------------
# partial .keywords — frozen keyword arguments dict
#
# .keywords is {'base': 2}. Verified via __len__ and __eq__ on the dict.
# ---------------------------------------------------------------------------

invariant functools_extra315.partial_keywords_len:
  description: "functools.partial(int, '10', base=2).keywords.__len__() == 1 — one keyword arg frozen"
  category: partial_keywords
  kind: python_call_eq
  function: "partial(int, '10', base=2).keywords.__len__"
  args: []
  expected: 1

invariant functools_extra315.partial_keywords_eq:
  description: "functools.partial(int, '10', base=2).keywords.__eq__({'base': 2}) == True"
  category: partial_keywords
  kind: python_call_eq
  function: "partial(int, '10', base=2).keywords.__eq__"
  args: [{"base": 2}]
  expected: true

# ---------------------------------------------------------------------------
# partial.__doc__ type and partialmethod.__name__
#
# partial.__doc__ is a str (the class docstring, not None).
# partialmethod.__name__ == 'partialmethod'.
# ---------------------------------------------------------------------------

invariant functools_extra315.partial_doc_class_name:
  description: "functools.partial.__doc__.__class__.__name__ == 'str' — class docstring is a str"
  category: partial_identity
  kind: python_call_eq
  function: partial.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra315.partialmethod_name:
  description: "functools.partialmethod.__name__ == 'partialmethod'"
  category: partial_identity
  kind: python_call_eq
  function: partialmethod.__name__.__eq__
  args: ["partialmethod"]
  expected: true
