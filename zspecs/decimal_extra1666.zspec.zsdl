spec: decimal_extra1666
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers Decimal construction, predicates, as_tuple, class_name, context.prec, error cases"
    - "decimal_extra.zspec.zsdl — covers predicates, to_eng_string, Context/BasicContext/ExtendedContext names, DefaultContext, rounding modes"
    - "_decimal_extra.zspec.zsdl — covers _decimal C module class names, modules, and exception hierarchy"
  notes:
    - "Theme: __new__ object construction protocol — which decimal classes define custom __new__."
    - "decimal.Decimal is a C extension type that defines its own __new__ (tp_new slot). It does NOT define __init__; all construction happens in __new__. Decimal is immutable."
    - "decimal.Context is also a C extension type. It defines BOTH __new__ and __init__. __new__ allocates the Context object; __init__ sets default values for prec, rounding, Emin, Emax, capitals, clamp, flags, traps."
    - "All decimal exception classes (DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, Clamped, Inexact, Rounded, Subnormal, FloatOperation) define neither __new__ nor __init__ in their own __dict__. They rely on BaseException.__new__ and BaseException.__init__."
    - "decimal.Decimal.__new__ and decimal.Context.__new__ are builtin_function_or_method (C extension slots), unlike pathlib and enum where __new__ is a Python function."
    - "Context has prec, rounding, Emin, Emax, capitals, clamp as member descriptors in its __dict__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table decimal_extra1666.decimal_new_init
# Decimal defines __new__ but NOT __init__; all construction is in __new__.
# This is the canonical pattern for immutable C extension types.
# ---------------------------------------------------------------------------

table decimal_extra1666.decimal_new_init:
  kind: python_call_eq
  category: construction_protocol
  id_prefix: dc1666

  columns: [id, function, args, expected]
  rows:
    - ["dc1666.Decimal.has_new",            Decimal.__dict__.__contains__,          ["__new__"],  true  ]
    - ["dc1666.Decimal.has_init",           Decimal.__dict__.__contains__,          ["__init__"], false ]
    - ["dc1666.Decimal.new_is_builtin",     Decimal.__new__.__class__.__name__.__eq__, ["builtin_function_or_method"], true ]
    - ["dc1666.Decimal.name",               Decimal.__name__.__eq__,                ["Decimal"],  true  ]
    - ["dc1666.Decimal.module",             Decimal.__module__.__eq__,              ["decimal"],  true  ]
    - ["dc1666.Decimal.is_type",            Decimal.__class__.__name__.__eq__,      ["type"],     true  ]

# ---------------------------------------------------------------------------
# Table decimal_extra1666.context_new_init
# Context defines both __new__ and __init__; the type is mutable so
# initialisation via __init__ sets up defaults after allocation.
# Context also exposes prec, rounding, Emin, Emax, capitals, clamp as
# descriptors in its own __dict__.
# ---------------------------------------------------------------------------

table decimal_extra1666.context_new_init:
  kind: python_call_eq
  category: construction_protocol
  id_prefix: dc1666

  columns: [id, function, args, expected]
  rows:
    - ["dc1666.Context.has_new",         Context.__dict__.__contains__,    ["__new__"],    true  ]
    - ["dc1666.Context.has_init",        Context.__dict__.__contains__,    ["__init__"],   true  ]
    - ["dc1666.Context.new_is_builtin",  Context.__new__.__class__.__name__.__eq__, ["builtin_function_or_method"], true ]
    - ["dc1666.Context.has_prec",        Context.__dict__.__contains__,    ["prec"],       true  ]
    - ["dc1666.Context.has_rounding",    Context.__dict__.__contains__,    ["rounding"],   true  ]
    - ["dc1666.Context.has_Emin",        Context.__dict__.__contains__,    ["Emin"],       true  ]
    - ["dc1666.Context.has_Emax",        Context.__dict__.__contains__,    ["Emax"],       true  ]
    - ["dc1666.Context.has_capitals",    Context.__dict__.__contains__,    ["capitals"],   true  ]
    - ["dc1666.Context.has_clamp",       Context.__dict__.__contains__,    ["clamp"],      true  ]
    - ["dc1666.Context.name",            Context.__name__.__eq__,          ["Context"],    true  ]
    - ["dc1666.Context.module",          Context.__module__.__eq__,        ["decimal"],    true  ]
    - ["dc1666.Context.is_type",         Context.__class__.__name__.__eq__, ["type"],      true  ]

# ---------------------------------------------------------------------------
# Table decimal_extra1666.exception_new_init
# All decimal exception classes define neither __new__ nor __init__ in their
# own __dict__. They delegate to the BaseException construction protocol
# inherited via ArithmeticError -> Exception -> BaseException.
# ---------------------------------------------------------------------------

table decimal_extra1666.exception_new_init:
  kind: python_call_eq
  category: construction_protocol
  id_prefix: dc1666

  columns: [id, function, args, expected]
  rows:
    - ["dc1666.DecimalException.has_new",    DecimalException.__dict__.__contains__,  ["__new__"],  false ]
    - ["dc1666.DecimalException.has_init",   DecimalException.__dict__.__contains__,  ["__init__"], false ]
    - ["dc1666.InvalidOperation.has_new",    InvalidOperation.__dict__.__contains__,  ["__new__"],  false ]
    - ["dc1666.InvalidOperation.has_init",   InvalidOperation.__dict__.__contains__,  ["__init__"], false ]
    - ["dc1666.DivisionByZero.has_new",      DivisionByZero.__dict__.__contains__,    ["__new__"],  false ]
    - ["dc1666.DivisionByZero.has_init",     DivisionByZero.__dict__.__contains__,    ["__init__"], false ]
    - ["dc1666.Overflow.has_new",            Overflow.__dict__.__contains__,          ["__new__"],  false ]
    - ["dc1666.Overflow.has_init",           Overflow.__dict__.__contains__,          ["__init__"], false ]
    - ["dc1666.Underflow.has_new",           Underflow.__dict__.__contains__,         ["__new__"],  false ]
    - ["dc1666.Underflow.has_init",          Underflow.__dict__.__contains__,         ["__init__"], false ]
    - ["dc1666.Clamped.has_new",             Clamped.__dict__.__contains__,           ["__new__"],  false ]
    - ["dc1666.Clamped.has_init",            Clamped.__dict__.__contains__,           ["__init__"], false ]
    - ["dc1666.Inexact.has_new",             Inexact.__dict__.__contains__,           ["__new__"],  false ]
    - ["dc1666.Inexact.has_init",            Inexact.__dict__.__contains__,           ["__init__"], false ]
    - ["dc1666.Rounded.has_new",             Rounded.__dict__.__contains__,           ["__new__"],  false ]
    - ["dc1666.Rounded.has_init",            Rounded.__dict__.__contains__,           ["__init__"], false ]
    - ["dc1666.Subnormal.has_new",           Subnormal.__dict__.__contains__,         ["__new__"],  false ]
    - ["dc1666.Subnormal.has_init",          Subnormal.__dict__.__contains__,         ["__init__"], false ]
    - ["dc1666.FloatOperation.has_new",      FloatOperation.__dict__.__contains__,    ["__new__"],  false ]
    - ["dc1666.FloatOperation.has_init",     FloatOperation.__dict__.__contains__,    ["__init__"], false ]
