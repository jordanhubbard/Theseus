spec: asyncio_extra244
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py (internal implementation)"
  notes:
    - "This spec covers asyncio.sleep and asyncio.gather function identity."
    - "asyncio.sleep.__module__ == 'asyncio.tasks' — sleep is defined in Lib/asyncio/tasks.py."
    - "asyncio.gather.__module__ == 'asyncio.tasks' — gather is defined in Lib/asyncio/tasks.py."
    - "asyncio.sleep.__class__.__name__ == 'function' — sleep is a Python coroutine function."
    - "asyncio.gather.__class__.__name__ == 'function' — gather is a Python coroutine function."
    - "asyncio.sleep.__qualname__ == 'sleep' (len=5) — module-level function, qualname equals name."
    - "asyncio.gather.__qualname__ == 'gather' (len=6) — module-level function, qualname equals name."
    - "asyncio.sleep.__name__.__len__() == 5; asyncio.gather.__name__.__len__() == 6."
    - "asyncio.sleep.__module__.__len__() == 13 ('asyncio.tasks' is 13 chars)."
    - "asyncio.gather.__module__.__len__() == 13 ('asyncio.tasks' is 13 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.sleep function identity
#
# asyncio.sleep is a Python coroutine function defined in asyncio.tasks.
# __name__ == 'sleep' (len=5)
# __module__ == 'asyncio.tasks' (len=13)
# __qualname__ == 'sleep' (len=5)
# __class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table asyncio_extra244.sleep_identity:
  description: "asyncio.sleep function identity checks — sleep is a Python coroutine function defined in asyncio.tasks; sleep.__name__.__eq__('sleep')==True (len=5); sleep.__module__.__eq__('asyncio.tasks')==True (len=13); sleep.__qualname__.__eq__('sleep')==True (len=5, module-level function so qualname equals name); sleep.__class__.__name__.__eq__('function')==True (Python coroutine function); sleep.__name__.__len__()==5; sleep.__module__.__len__()==13; verified with Python 3.14.3"
  kind: python_call_eq
  category: sleep_identity
  id_prefix: aiosleep244

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    sleep.__name__.__eq__,         ["sleep"],          true, "asyncio.sleep.__name__ == 'sleep'; verified with Python 3.14.3"]
    - [name_len,   sleep.__name__.__len__,         [],                 5,    "asyncio.sleep.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [module_eq,  sleep.__module__.__eq__,        ["asyncio.tasks"],  true, "asyncio.sleep.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [module_len, sleep.__module__.__len__,       [],                 13,   "asyncio.sleep.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [qname_eq,   sleep.__qualname__.__eq__,      ["sleep"],          true, "asyncio.sleep.__qualname__ == 'sleep' (len=5, qualname equals name); verified with Python 3.14.3"]
    - [qname_len,  sleep.__qualname__.__len__,     [],                 5,    "asyncio.sleep.__qualname__.__len__() == 5; verified with Python 3.14.3"]
    - [cls_nm,     sleep.__class__.__name__.__eq__, ["function"],      true, "asyncio.sleep.__class__.__name__ == 'function' (Python coroutine function); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.gather function identity
#
# asyncio.gather is a Python coroutine function defined in asyncio.tasks.
# __name__ == 'gather' (len=6)
# __module__ == 'asyncio.tasks' (len=13)
# __qualname__ == 'gather' (len=6)
# __class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table asyncio_extra244.gather_identity:
  description: "asyncio.gather function identity checks — gather is a Python coroutine function defined in asyncio.tasks; gather.__name__.__eq__('gather')==True (len=6); gather.__module__.__eq__('asyncio.tasks')==True (len=13, same module as sleep); gather.__qualname__.__eq__('gather')==True (len=6, module-level function so qualname equals name); gather.__class__.__name__.__eq__('function')==True (Python coroutine function, same class as sleep); gather.__name__.__len__()==6 (one more than sleep.__name__.__len__()==5); gather.__module__.__len__()==13 (same as sleep); verified with Python 3.14.3"
  kind: python_call_eq
  category: gather_identity
  id_prefix: aiogather244

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    gather.__name__.__eq__,          ["gather"],         true, "asyncio.gather.__name__ == 'gather'; verified with Python 3.14.3"]
    - [name_len,   gather.__name__.__len__,          [],                 6,    "asyncio.gather.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [module_eq,  gather.__module__.__eq__,         ["asyncio.tasks"],  true, "asyncio.gather.__module__ == 'asyncio.tasks'; verified with Python 3.14.3"]
    - [module_len, gather.__module__.__len__,        [],                 13,   "asyncio.gather.__module__.__len__() == 13; verified with Python 3.14.3"]
    - [qname_eq,   gather.__qualname__.__eq__,       ["gather"],         true, "asyncio.gather.__qualname__ == 'gather' (len=6, qualname equals name); verified with Python 3.14.3"]
    - [qname_len,  gather.__qualname__.__len__,      [],                 6,    "asyncio.gather.__qualname__.__len__() == 6; verified with Python 3.14.3"]
    - [cls_nm,     gather.__class__.__name__.__eq__, ["function"],       true, "asyncio.gather.__class__.__name__ == 'function' (Python coroutine function); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra244
# ---------------------------------------------------------------------------

invariant asyncio_extra244.sleep_module_is_asyncio_tasks:
  description: "asyncio.sleep.__module__.__eq__('asyncio.tasks') returns True — asyncio.sleep is defined in Lib/asyncio/tasks.py (the Python source file for the asyncio.tasks submodule); the module name 'asyncio.tasks' is 13 chars (len=13); this is the same module as asyncio.gather; sleep is a Python coroutine function (class='function'), not a C extension like asyncio.Task (class='type'); NEW in extra244: first standalone sleep module invariant in aiosleep244 namespace; verified with Python 3.14.3"
  category: sleep_identity
  kind: python_call_eq
  function: sleep.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra244.sleep_qualname_eq_name:
  description: "asyncio.sleep.__qualname__.__eq__('sleep') returns True — asyncio.sleep.__qualname__ is 'sleep' (len=5), which is identical to __name__; this is because sleep is a module-level function (not nested in a class or another function), so its qualname equals its simple name; compare: a method's qualname would be 'ClassName.method_name'; sleep.__name__.__len__()==5 and sleep.__qualname__.__len__()==5 both equal 5; sleep.__class__.__name__ is 'function'; NEW in extra244: first standalone sleep qualname invariant in aiosleep244 namespace; verified with Python 3.14.3"
  category: sleep_identity
  kind: python_call_eq
  function: sleep.__qualname__.__eq__
  args: ["sleep"]
  expected: true

invariant asyncio_extra244.gather_module_is_asyncio_tasks:
  description: "asyncio.gather.__module__.__eq__('asyncio.tasks') returns True — asyncio.gather is defined in Lib/asyncio/tasks.py alongside asyncio.sleep; both share the same __module__ value 'asyncio.tasks' (len=13); gather is a Python coroutine function (class='function'); gather.__name__ is 'gather' (len=6) and gather.__qualname__ is 'gather' (len=6), both one char longer than sleep's corresponding attributes; NEW in extra244: first standalone gather module invariant in aiogather244 namespace; verified with Python 3.14.3"
  category: gather_identity
  kind: python_call_eq
  function: gather.__module__.__eq__
  args: ["asyncio.tasks"]
  expected: true

invariant asyncio_extra244.gather_qualname_eq_name:
  description: "asyncio.gather.__qualname__.__eq__('gather') returns True — asyncio.gather.__qualname__ is 'gather' (len=6), identical to __name__; gather is a module-level function so qualname equals name; gather.__name__.__len__()==6 (one more than sleep.__name__.__len__()==5); gather.__qualname__.__len__()==6 (one more than sleep.__qualname__.__len__()==5); both gather and sleep have the same __module__ ('asyncio.tasks', len=13); NEW in extra244: first standalone gather qualname invariant in aiogather244 namespace; verified with Python 3.14.3"
  category: gather_identity
  kind: python_call_eq
  function: gather.__qualname__.__eq__
  args: ["gather"]
  expected: true

invariant asyncio_extra244.sleep_class_is_function:
  description: "asyncio.sleep.__class__.__name__.__eq__('function') returns True — asyncio.sleep is a Python coroutine function (class='function'); this distinguishes it from C extension methods (class='method_descriptor') such as asyncio.Task.cancel; sleep.__class__.__name__ is 'function'; sleep.__module__ is 'asyncio.tasks'; sleep.__name__ is 'sleep' (len=5); sleep.__qualname__ is 'sleep' (len=5); NEW in extra244: first standalone sleep class name invariant in aiosleep244 namespace; verified with Python 3.14.3"
  category: sleep_identity
  kind: python_call_eq
  function: sleep.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra244.gather_class_is_function:
  description: "asyncio.gather.__class__.__name__.__eq__('function') returns True — asyncio.gather is a Python coroutine function (class='function'); same class as asyncio.sleep; both gather and sleep are module-level coroutine functions defined in asyncio.tasks, contrasted with C extension classes like asyncio.Task and asyncio.Future (class='type'); gather.__name__ is 'gather' (len=6); gather.__qualname__ is 'gather' (len=6); gather.__module__ is 'asyncio.tasks' (len=13); NEW in extra244: first standalone gather class name invariant in aiogather244 namespace; verified with Python 3.14.3"
  category: gather_identity
  kind: python_call_eq
  function: gather.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra244.sleep_name_len_5:
  description: "asyncio.sleep.__name__.__len__() == 5 — asyncio.sleep.__name__ is 'sleep' (5 chars: s-l-e-e-p); compare gather.__name__.__len__()==6 ('gather' is 6 chars); sleep.__module__.__len__()==13 ('asyncio.tasks'); sleep.__qualname__.__len__()==5 (same as __name__); the length of 5 distinguishes sleep from gather (6) and from other asyncio functions like 'run' (3), 'wait' (4), 'create_task' (11); NEW in extra244: first standalone sleep name length invariant in aiosleep244 namespace; verified with Python 3.14.3"
  category: sleep_identity
  kind: python_call_eq
  function: sleep.__name__.__len__
  args: []
  expected: 5

invariant asyncio_extra244.gather_name_len_6:
  description: "asyncio.gather.__name__.__len__() == 6 — asyncio.gather.__name__ is 'gather' (6 chars: g-a-t-h-e-r); compare sleep.__name__.__len__()==5 ('sleep' is 5 chars); gather.__module__.__len__()==13 ('asyncio.tasks'); gather.__qualname__.__len__()==6 (same as __name__); gather.__name__ is one char longer than sleep.__name__; both share the same __module__ ('asyncio.tasks', len=13) and same __class__.__name__ ('function'); NEW in extra244: first standalone gather name length invariant in aiogather244 namespace; verified with Python 3.14.3"
  category: gather_identity
  kind: python_call_eq
  function: gather.__name__.__len__
  args: []
  expected: 6
