spec: asyncio_extra1591
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for descriptor protocol"
    - "asyncio classes do not implement __get__, __set__, or __delete__ in their own __dict__"
    - "Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

table asyncio_extra1591.future_task_no_descriptor:
  description: "asyncio.Future and asyncio.Task do not define descriptor protocol methods in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1591ft

  columns: [id, function, args, expected]
  rows:
    - ["as1591ft001", "asyncio.Future.__dict__.__contains__", ["__get__"],    false]
    - ["as1591ft002", "asyncio.Future.__dict__.__contains__", ["__set__"],    false]
    - ["as1591ft003", "asyncio.Future.__dict__.__contains__", ["__delete__"], false]
    - ["as1591ft004", "asyncio.Task.__dict__.__contains__",   ["__get__"],    false]
    - ["as1591ft005", "asyncio.Task.__dict__.__contains__",   ["__set__"],    false]
    - ["as1591ft006", "asyncio.Task.__dict__.__contains__",   ["__delete__"], false]
    - ["as1591ft007", "asyncio.Future.__dict__.__contains__", ["cancel"],     true]
    - ["as1591ft008", "asyncio.Future.__dict__.__contains__", ["result"],     true]
    - ["as1591ft009", "asyncio.Future.__dict__.__contains__", ["done"],       true]
    - ["as1591ft010", "asyncio.Future.__dict__.__contains__", ["add_done_callback"], true]
    - ["as1591ft011", "asyncio.Task.__dict__.__contains__",   ["cancel"],     true]
    - ["as1591ft012", "asyncio.Future.__dict__.__contains__", ["exception"],  true]
    - ["as1591ft013", "asyncio.Future.__dict__.__contains__", ["cancelled"],  true]
    - ["as1591ft014", "asyncio.Future.__dict__.__contains__", ["set_result"], true]
    - ["as1591ft015", "asyncio.Future.__dict__.__contains__", ["set_exception"], true]
    - ["as1591ft016", "asyncio.Future.__dict__.__contains__", ["__doc__"],    true]
    - ["as1591ft017", "asyncio.Future.__dict__.__contains__", ["__module__"], true]
    - ["as1591ft018", "asyncio.Future.__dict__.__contains__", ["running"],    true]
    - ["as1591ft019", "asyncio.Task.__dict__.__contains__",   ["__module__"], true]
    - ["as1591ft020", "asyncio.Task.__dict__.__contains__",   ["__doc__"],    true]
    - ["as1591ft021", "asyncio.Future.__dict__.__contains__", ["__set_name__"],    false]
    - ["as1591ft022", "asyncio.Future.__dict__.__contains__", ["__set_attr__"],    false]
    - ["as1591ft023", "asyncio.Task.__dict__.__contains__",   ["__set_name__"],    false]

table asyncio_extra1591.sync_primitives_no_descriptor:
  description: "asyncio sync primitives (Lock, Event, Semaphore, Queue, Condition, StreamReader, StreamWriter) do not define descriptor protocol methods"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1591sp

  columns: [id, function, args, expected]
  rows:
    - ["as1591sp001", "asyncio.Lock.__dict__.__contains__",        ["__get__"],    false]
    - ["as1591sp002", "asyncio.Lock.__dict__.__contains__",        ["__set__"],    false]
    - ["as1591sp003", "asyncio.Lock.__dict__.__contains__",        ["__delete__"], false]
    - ["as1591sp004", "asyncio.Event.__dict__.__contains__",       ["__get__"],    false]
    - ["as1591sp005", "asyncio.Event.__dict__.__contains__",       ["__set__"],    false]
    - ["as1591sp006", "asyncio.Event.__dict__.__contains__",       ["__delete__"], false]
    - ["as1591sp007", "asyncio.Semaphore.__dict__.__contains__",   ["__get__"],    false]
    - ["as1591sp008", "asyncio.Semaphore.__dict__.__contains__",   ["__set__"],    false]
    - ["as1591sp009", "asyncio.Semaphore.__dict__.__contains__",   ["__delete__"], false]
    - ["as1591sp010", "asyncio.Queue.__dict__.__contains__",       ["__get__"],    false]
