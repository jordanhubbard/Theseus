    - ["as1591sp012", "asyncio.Queue.__dict__.__contains__",       ["__delete__"], false]
    - ["as1591sp013", "asyncio.Condition.__dict__.__contains__",   ["__get__"],    false]
    - ["as1591sp014", "asyncio.Condition.__dict__.__contains__",   ["__set__"],    false]
    - ["as1591sp015", "asyncio.Condition.__dict__.__contains__",   ["__delete__"], false]
    - ["as1591sp016", "asyncio.StreamReader.__dict__.__contains__", ["__get__"],   false]
    - ["as1591sp017", "asyncio.StreamReader.__dict__.__contains__", ["__set__"],   false]
    - ["as1591sp018", "asyncio.StreamReader.__dict__.__contains__", ["__delete__"], false]
    - ["as1591sp019", "asyncio.StreamWriter.__dict__.__contains__", ["__get__"],   false]
    - ["as1591sp020", "asyncio.StreamWriter.__dict__.__contains__", ["__set__"],   false]
    - ["as1591sp021", "asyncio.StreamWriter.__dict__.__contains__", ["__delete__"], false]
    - ["as1591sp022", "asyncio.Lock.__dict__.__contains__",        ["acquire"],    true]
    - ["as1591sp023", "asyncio.Event.__dict__.__contains__",       ["set"],        true]
    - ["as1591sp024", "asyncio.Queue.__dict__.__contains__",       ["put"],        true]
    - ["as1591sp025", "asyncio.Semaphore.__dict__.__contains__",   ["acquire"],    true]
    - ["as1591sp026", "asyncio.Condition.__dict__.__contains__",   ["wait"],       true]
    - ["as1591sp027", "asyncio.StreamReader.__dict__.__contains__", ["read"],      true]
    - ["as1591sp028", "asyncio.StreamWriter.__dict__.__contains__", ["write"],     true]

table asyncio_extra1591.exceptions_no_descriptor:
  description: "asyncio exception classes do not define descriptor protocol methods in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1591ex

  columns: [id, function, args, expected]
  rows:
    - ["as1591ex001", "asyncio.CancelledError.__dict__.__contains__",    ["__get__"],    false]
    - ["as1591ex002", "asyncio.CancelledError.__dict__.__contains__",    ["__set__"],    false]
    - ["as1591ex003", "asyncio.CancelledError.__dict__.__contains__",    ["__delete__"], false]
    - ["as1591ex004", "asyncio.TimeoutError.__dict__.__contains__",      ["__get__"],    false]
    - ["as1591ex005", "asyncio.TimeoutError.__dict__.__contains__",      ["__set__"],    false]
    - ["as1591ex006", "asyncio.TimeoutError.__dict__.__contains__",      ["__delete__"], false]
    - ["as1591ex007", "asyncio.InvalidStateError.__dict__.__contains__", ["__get__"],    false]
    - ["as1591ex008", "asyncio.InvalidStateError.__dict__.__contains__", ["__set__"],    false]
    - ["as1591ex009", "asyncio.InvalidStateError.__dict__.__contains__", ["__delete__"], false]
    - ["as1591ex010", "asyncio.CancelledError.__dict__.__contains__",    ["__module__"], true]
    - ["as1591ex011", "asyncio.CancelledError.__dict__.__contains__",    ["__doc__"],    true]
    - ["as1591ex012", "asyncio.InvalidStateError.__dict__.__contains__", ["__module__"], true]
    - ["as1591ex013", "asyncio.InvalidStateError.__dict__.__contains__", ["__doc__"],    true]
    - ["as1591ex014", "asyncio.TimeoutError.__dict__.__contains__",      ["__doc__"],    true]
    - ["as1591ex015", "asyncio.CancelledError.__dict__.__contains__",    ["__set_name__"], false]
    - ["as1591ex016", "asyncio.TimeoutError.__dict__.__contains__",      ["__set_name__"], false]
    - ["as1591ex017", "asyncio.InvalidStateError.__dict__.__contains__", ["__set_name__"], false]
    - ["as1591ex018", "asyncio.CancelledError.__dict__.__contains__",    ["__init__"],   false]
    - ["as1591ex019", "asyncio.TimeoutError.__dict__.__contains__",      ["__init__"],   false]
    - ["as1591ex020", "asyncio.InvalidStateError.__dict__.__contains__", ["__init__"],   false]
