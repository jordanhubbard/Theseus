spec: io_extra16
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl through io_extra15.zspec.zsdl."
    - "io_extra15 covers __qualname__ for BytesIO, StringIO, FileIO, BufferedReader."
    - "io_extra14 covers __module__ for IOBase/RawIOBase/BufferedIOBase/TextIOBase/FileIO/BytesIO/StringIO/BufferedReader/BufferedWriter/BufferedRandom/TextIOWrapper/IncrementalNewlineDecoder/UnsupportedOperation."
    - "io_extra11 covers DEFAULT_BUFFER_SIZE == 8192; BufferedReader/Writer/Random/TextIOWrapper __bases__[0].__name__."
    - "No prior io spec covers __qualname__ for BufferedWriter, BufferedRandom, TextIOWrapper, IncrementalNewlineDecoder, or UnsupportedOperation."
    - "No prior io spec covers the SEEK_SET / SEEK_CUR / SEEK_END module-level integer constants."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' — C-implemented top-level class; qualname equals name."
    - "io.BufferedRandom.__qualname__ == 'BufferedRandom' — C-implemented top-level class; qualname equals name."
    - "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — C-implemented top-level class; qualname equals name."
    - "io.IncrementalNewlineDecoder.__qualname__ == 'IncrementalNewlineDecoder' — C-implemented; qualname equals name."
    - "io.UnsupportedOperation.__qualname__ == 'UnsupportedOperation' — pure-Python class; qualname equals name."
    - "io.SEEK_SET == 0 — seek from start of stream."
    - "io.SEEK_CUR == 1 — seek from current position."
    - "io.SEEK_END == 2 — seek from end of stream."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ — BufferedWriter, BufferedRandom, TextIOWrapper,
#                IncrementalNewlineDecoder, UnsupportedOperation
#
# io_extra15 covers __qualname__ for BytesIO, StringIO, FileIO, BufferedReader.
# No prior io spec covers __qualname__ for the five classes listed here.
# For top-level (non-nested) classes, __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant io_extra16.BufferedWriter.qualname:
  description: "io.BufferedWriter.__qualname__ == 'BufferedWriter' — top-level C class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: BufferedWriter.__qualname__.__eq__
  args: ["BufferedWriter"]
  expected: true

invariant io_extra16.BufferedRandom.qualname:
  description: "io.BufferedRandom.__qualname__ == 'BufferedRandom' — top-level C class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: BufferedRandom.__qualname__.__eq__
  args: ["BufferedRandom"]
  expected: true

invariant io_extra16.TextIOWrapper.qualname:
  description: "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — top-level C class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: TextIOWrapper.__qualname__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra16.IncrementalNewlineDecoder.qualname:
  description: "io.IncrementalNewlineDecoder.__qualname__ == 'IncrementalNewlineDecoder' — top-level C class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__qualname__.__eq__
  args: ["IncrementalNewlineDecoder"]
  expected: true

invariant io_extra16.UnsupportedOperation.qualname:
  description: "io.UnsupportedOperation.__qualname__ == 'UnsupportedOperation' — top-level pure-Python class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: UnsupportedOperation.__qualname__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

# ---------------------------------------------------------------------------
# SEEK_SET, SEEK_CUR, SEEK_END — module-level integer seek constants
#
# No prior io spec covers these three module-level integer constants.
# SEEK_SET == 0, SEEK_CUR == 1, SEEK_END == 2 are defined in POSIX and
# exposed by the io module. They are used as the 'whence' argument to seek().
# ---------------------------------------------------------------------------

invariant io_extra16.SEEK_SET.value:
  description: "io.SEEK_SET == 0 — seek from start of stream"
  category: constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra16.SEEK_CUR.value:
  description: "io.SEEK_CUR == 1 — seek from current position"
  category: constants
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant io_extra16.SEEK_END.value:
  description: "io.SEEK_END == 2 — seek from end of stream"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra16.SEEK_SET.class_name:
  description: "io.SEEK_SET.__class__.__name__ == 'int' — SEEK_SET is a plain integer constant"
  category: constants
  kind: python_call_eq
  function: SEEK_SET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra16.SEEK_CUR.class_name:
  description: "io.SEEK_CUR.__class__.__name__ == 'int' — SEEK_CUR is a plain integer constant"
  category: constants
  kind: python_call_eq
  function: SEEK_CUR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra16.SEEK_END.class_name:
  description: "io.SEEK_END.__class__.__name__ == 'int' — SEEK_END is a plain integer constant"
  category: constants
  kind: python_call_eq
  function: SEEK_END.__class__.__name__.__eq__
  args: ["int"]
  expected: true
