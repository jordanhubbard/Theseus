spec: multiprocessing_extra206
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "multiprocessing.pool.Pool.__name__ == 'Pool'; __module__ == 'multiprocessing.pool'."
    - "Pool methods have qualnames like 'Pool.map', 'Pool.apply', etc."
    - "multiprocessing.Process.start.__qualname__ == 'BaseProcess.start' (defined on BaseProcess)."
    - "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues'."
    - "verified with Python 3.14.3."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Pool method __name__ checks — extra206 namespace
#
# Pool is defined in multiprocessing.pool.  Its methods — map, apply,
# starmap, imap, close, terminate, join — have predictable __name__ values.
# ---------------------------------------------------------------------------

table multiprocessing_extra206.pool_method_names:
  description: "multiprocessing.pool.Pool method __name__ checks in extra206 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp206poolname

  columns: [id, function, args, expected, description]
  rows:
    - [map_name,       pool.Pool.map.__name__.__eq__,       ["map"],       true, "Pool.map.__name__ == 'map'"]
    - [apply_name,     pool.Pool.apply.__name__.__eq__,     ["apply"],     true, "Pool.apply.__name__ == 'apply'"]
    - [starmap_name,   pool.Pool.starmap.__name__.__eq__,   ["starmap"],   true, "Pool.starmap.__name__ == 'starmap'"]
    - [imap_name,      pool.Pool.imap.__name__.__eq__,      ["imap"],      true, "Pool.imap.__name__ == 'imap'"]
    - [close_name,     pool.Pool.close.__name__.__eq__,     ["close"],     true, "Pool.close.__name__ == 'close'"]
    - [terminate_name, pool.Pool.terminate.__name__.__eq__, ["terminate"], true, "Pool.terminate.__name__ == 'terminate'"]
    - [join_name,      pool.Pool.join.__name__.__eq__,      ["join"],      true, "Pool.join.__name__ == 'join'"]

# ---------------------------------------------------------------------------
# multiprocessing Pool method __qualname__ checks — extra206 namespace
# ---------------------------------------------------------------------------

table multiprocessing_extra206.pool_method_qualnames:
  description: "multiprocessing.pool.Pool method __qualname__ checks in extra206 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp206poolqual

  columns: [id, function, args, expected, description]
  rows:
    - [map_qualname,     pool.Pool.map.__qualname__.__eq__,     ["Pool.map"],     true, "Pool.map.__qualname__ == 'Pool.map'"]
    - [apply_qualname,   pool.Pool.apply.__qualname__.__eq__,   ["Pool.apply"],   true, "Pool.apply.__qualname__ == 'Pool.apply'"]
    - [starmap_qualname, pool.Pool.starmap.__qualname__.__eq__, ["Pool.starmap"], true, "Pool.starmap.__qualname__ == 'Pool.starmap'"]
    - [imap_qualname,    pool.Pool.imap.__qualname__.__eq__,    ["Pool.imap"],    true, "Pool.imap.__qualname__ == 'Pool.imap'"]

# ---------------------------------------------------------------------------
# multiprocessing Pool class identity — extra206 namespace
# ---------------------------------------------------------------------------

table multiprocessing_extra206.pool_class_identity:
  description: "multiprocessing.pool.Pool class __name__ and __module__ checks in extra206 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp206poolident

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name,   pool.Pool.__name__.__eq__,   ["Pool"],                true, "multiprocessing.pool.Pool.__name__ == 'Pool'"]
    - [pool_module, pool.Pool.__module__.__eq__, ["multiprocessing.pool"], true, "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool'"]
    - [init_qualname, pool.Pool.__init__.__qualname__.__eq__, ["Pool.__init__"], true, "Pool.__init__.__qualname__ == 'Pool.__init__'"]

# ---------------------------------------------------------------------------
# multiprocessing Queue class identity — extra206 namespace
#
# multiprocessing.queues.Queue and SimpleQueue live in multiprocessing.queues.
# ---------------------------------------------------------------------------

table multiprocessing_extra206.queue_class_identity:
  description: "multiprocessing.queues.Queue and SimpleQueue __name__ checks in extra206 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp206queueident

  columns: [id, function, args, expected, description]
  rows:
    - [queue_name,         queues.Queue.__name__.__eq__,         ["Queue"],       true, "multiprocessing.queues.Queue.__name__ == 'Queue'"]
    - [queue_module,       queues.Queue.__module__.__eq__,       ["multiprocessing.queues"], true, "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues'"]
    - [simplequeue_name,   queues.SimpleQueue.__name__.__eq__,   ["SimpleQueue"], true, "multiprocessing.queues.SimpleQueue.__name__ == 'SimpleQueue'"]
    - [simplequeue_module, queues.SimpleQueue.__module__.__eq__, ["multiprocessing.queues"], true, "multiprocessing.queues.SimpleQueue.__module__ == 'multiprocessing.queues'"]

# ---------------------------------------------------------------------------
# multiprocessing Process method __qualname__ checks — extra206 namespace
#
# Process inherits start, run, join, terminate from BaseProcess; qualnames
# therefore carry the BaseProcess prefix.
# ---------------------------------------------------------------------------

table multiprocessing_extra206.process_method_qualnames:
  description: "multiprocessing.Process method __qualname__ checks in extra206 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp206procqual

  columns: [id, function, args, expected, description]
  rows:
    - [start_qualname,     Process.start.__qualname__.__eq__,     ["BaseProcess.start"],     true, "Process.start.__qualname__ == 'BaseProcess.start'"]
    - [run_qualname,       Process.run.__qualname__.__eq__,       ["BaseProcess.run"],       true, "Process.run.__qualname__ == 'BaseProcess.run'"]
    - [join_qualname,      Process.join.__qualname__.__eq__,      ["BaseProcess.join"],      true, "Process.join.__qualname__ == 'BaseProcess.join'"]
    - [terminate_qualname, Process.terminate.__qualname__.__eq__, ["BaseProcess.terminate"], true, "Process.terminate.__qualname__ == 'BaseProcess.terminate'"]

# ---------------------------------------------------------------------------
# multiprocessing Pool.map __name__ standalone — extra206 namespace
# ---------------------------------------------------------------------------

invariant multiprocessing_extra206.pool_map_name:
  description: "multiprocessing.pool.Pool.map.__name__ == 'map'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.map.__name__.__eq__
  args: ["map"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing Pool.starmap __qualname__ standalone — extra206 namespace
# ---------------------------------------------------------------------------

invariant multiprocessing_extra206.pool_starmap_qualname:
  description: "multiprocessing.pool.Pool.starmap.__qualname__ == 'Pool.starmap'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.starmap.__qualname__.__eq__
  args: ["Pool.starmap"]
  expected: true

# ---------------------------------------------------------------------------
# multiprocessing.Process.__name__ standalone — extra206 namespace
# ---------------------------------------------------------------------------

invariant multiprocessing_extra206.process_name:
  description: "multiprocessing.Process.__name__ == 'Process'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__name__.__eq__
  args: ["Process"]
  expected: true

