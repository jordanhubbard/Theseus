spec: math_extra8
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra7.zspec.zsdl."
    - "math_extra6 covers __qualname__ for sqrt/floor/ceil/trunc/fabs/factorial/gcd/lcm/isnan/isinf/isfinite/isclose/log/log2/log10/exp/pow/sin/cos/tan."
    - "math_extra7 covers __module__ for the same function sets."
    - "No prior spec covers __name__ for atan/asin/acos/sinh/cosh/tanh/fsum."
    - "No prior spec covers value vectors for sin(0), cos(0), asin(0), or acos(1)."
    - "No prior spec covers log(1)==0 or log(e)==1 (math_extra has log vectors but not these specific inputs)."
    - "No prior spec covers exp(0)==1 (math_extra4 covers exp only for __module__)."
    - "No prior spec covers hypot(3,4)==5.0 (math_extra5 covers dist([0,0],[3,4])==5.0, but hypot is different)."
    - "math.sin(0) == 0.0 — sin of zero is zero."
    - "math.cos(0) == 1.0 — cos of zero is one."
    - "math.asin(0) == 0.0 — arcsine of zero is zero."
    - "math.acos(1) == 0.0 — arccosine of one is zero."
    - "math.log(1) == 0.0 — natural log of 1 is 0."
    - "math.log(math.e) == 1.0 — natural log of e is 1."
    - "math.exp(0) == 1.0 — e^0 == 1."
    - "math.hypot(3, 4) == 5.0 — Pythagorean theorem: sqrt(9+16) == 5."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — inverse trig and hyperbolic functions
#
# math_extra6/7 cover qualname/module for sin/cos/tan/log/exp etc., but
# atan/asin/acos/fsum do not appear in any prior spec's __name__ table.
# ---------------------------------------------------------------------------

table math_extra8.function_names_trig_extra:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [atan,  atan.__name__.__eq__,  ["atan"],  true]
    - [asin,  asin.__name__.__eq__,  ["asin"],  true]
    - [acos,  acos.__name__.__eq__,  ["acos"],  true]
    - [fsum,  fsum.__name__.__eq__,  ["fsum"],  true]

# ---------------------------------------------------------------------------
# Trig function values at zero
#
# No prior spec covers sin(0), cos(0), asin(0), or acos(1).
# These are the canonical identity-point checks.
# ---------------------------------------------------------------------------

invariant math_extra8.sin.zero:
  description: "math.sin(0) == 0.0 — sin of zero is zero"
  category: trig
  kind: python_call_eq
  function: sin
  args: [0]
  expected: 0.0

invariant math_extra8.cos.zero:
  description: "math.cos(0) == 1.0 — cos of zero is one"
  category: trig
  kind: python_call_eq
  function: cos
  args: [0]
  expected: 1.0

invariant math_extra8.asin.zero:
  description: "math.asin(0) == 0.0 — arcsine of zero is zero radians"
  category: inverse_trig
  kind: python_call_eq
  function: asin
  args: [0]
  expected: 0.0

invariant math_extra8.acos.one:
  description: "math.acos(1) == 0.0 — arccosine of one is zero radians"
  category: inverse_trig
  kind: python_call_eq
  function: acos
  args: [1]
  expected: 0.0

# ---------------------------------------------------------------------------
# log — identity inputs
#
# math_extra4 covers log.__module__; math_extra7 covers log.__module__ again.
# No prior spec checks log(1) or log(e) as value vectors.
# ---------------------------------------------------------------------------

invariant math_extra8.log.one:
  description: "math.log(1) == 0.0 — natural log of 1 is 0"
  category: logarithm
  kind: python_call_eq
  function: log
  args: [1]
  expected: 0.0

invariant math_extra8.log.e:
  description: "math.log(math.e) == 1.0 — natural log of e is 1"
  category: logarithm
  kind: python_call_eq
  function: log
  args: [e]
  expected: 1.0

# ---------------------------------------------------------------------------
# exp — identity input
#
# math_extra7 covers exp.__module__; no prior spec covers exp(0) == 1.0.
# ---------------------------------------------------------------------------

invariant math_extra8.exp.zero:
  description: "math.exp(0) == 1.0 — e^0 == 1"
  category: exponential
  kind: python_call_eq
  function: exp
  args: [0]
  expected: 1.0

# ---------------------------------------------------------------------------
# hypot — Pythagorean triple
#
# math_extra5 covers dist([0,0],[3,4])==5.0 via the dist() function.
# hypot() is a different function: hypot(3,4) == 5.0 is NOT covered anywhere.
# ---------------------------------------------------------------------------

invariant math_extra8.hypot.three_four_five:
  description: "math.hypot(3, 4) == 5.0 — classic 3-4-5 Pythagorean triple"
  category: hypot
  kind: python_call_eq
  function: hypot
  args: [3, 4]
  expected: 5.0
