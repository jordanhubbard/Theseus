spec: codecs_extra6
version: ">=3.9"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html — Python codecs documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
    - "codecs.zspec.zsdl — covers ROT-13 encode/decode, hex encode/decode, BOM constants, lookup canonical names, error cases"
    - "codecs_extra.zspec.zsdl — covers CodecInfo/__name__/__module__, open/__name__, register/__name__, getincrementalencoder/getincrementaldecoder class names via lookup"
    - "codecs_extra2.zspec.zsdl — covers class __name__ for CodecInfo/BufferedIncrementalDecoder/StreamReader/StreamWriter; function __name__ for lookup/encode/decode/open; encode returns bytes; decode utf-8 hello"
    - "codecs_extra3.zspec.zsdl — covers __qualname__ for encode/decode/open/lookup/register (table); open/__module__, register/__module__; Codec/__name__/__qualname__/__module__; IncrementalEncoder/__name__/__qualname__/__module__; IncrementalDecoder/__name__/__qualname__/__module__; StreamReader/__qualname__/__module__; StreamWriter/__qualname__/__module__; CodecInfo/__qualname__; BOM lengths; lookup utf-32/utf-8-sig; encode ascii"
    - "codecs_extra4.zspec.zsdl — covers function __name__ table for encode/decode/lookup/register/open; encode/decode type checks; lookup codec_info_class; lookup utf-8/ascii name; CodecInfo/__name__/__module__"
    - "codecs_extra5.zspec.zsdl — covers open/__qualname__, register/__qualname__, BufferedIncrementalDecoder/__qualname__/__module__, StreamReaderWriter/__name__/__module__/__qualname__, StreamRecoder/__name__/__module__/__qualname__; class_names_anchor table"
  notes:
    - "This spec adds new axes: getreader/__name__/__qualname__/__module__; getwriter/__name__/__qualname__/__module__; getincrementalencoder/__name__/__qualname__/__module__; getincrementaldecoder/__name__/__qualname__/__module__; inheritance checks for StreamReader/StreamWriter (base is Codec) and BufferedIncrementalDecoder (base is IncrementalDecoder); CodecInfo base is tuple."
    - "codecs.getreader.__name__ == 'getreader' — factory that returns a StreamReader subclass. Not covered in any prior spec."
    - "codecs.getwriter.__name__ == 'getwriter' — factory that returns a StreamWriter subclass. Not covered in any prior spec."
    - "codecs.getincrementalencoder.__name__ == 'getincrementalencoder' — only checked via result class name in codecs_extra; not checked as __name__/__qualname__/__module__."
    - "codecs.getincrementaldecoder.__name__ == 'getincrementaldecoder' — same gap."
    - "codecs.StreamReader.__bases__[0].__name__ == 'Codec' — StreamReader inherits from Codec."
    - "codecs.StreamWriter.__bases__[0].__name__ == 'Codec' — StreamWriter inherits from Codec."
    - "codecs.BufferedIncrementalDecoder.__bases__[0].__name__ == 'IncrementalDecoder' — BufferedIncrementalDecoder subclasses IncrementalDecoder."
    - "codecs.CodecInfo.__bases__[0].__name__ == 'tuple' — CodecInfo is a named-tuple subclass."
    - "codecs.Codec.__bases__[0].__name__ == 'object' — Codec is a top-level class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getreader — __name__, __qualname__, __module__
# No prior spec covers getreader (only its return value's __name__).
# ---------------------------------------------------------------------------

invariant codecs_extra6.getreader.name:
  description: "codecs.getreader.__name__ == 'getreader'"
  category: function_names
  kind: python_call_eq
  function: getreader.__name__.__eq__
  args: ["getreader"]
  expected: true

invariant codecs_extra6.getreader.qualname:
  description: "codecs.getreader.__qualname__ == 'getreader'"
  category: qualnames
  kind: python_call_eq
  function: getreader.__qualname__.__eq__
  args: ["getreader"]
  expected: true

invariant codecs_extra6.getreader.module:
  description: "codecs.getreader.__module__ == 'codecs'"
  category: module_attrs
  kind: python_call_eq
  function: getreader.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# getwriter — __name__, __qualname__, __module__
# No prior spec covers getwriter (only its return value's __name__).
# ---------------------------------------------------------------------------

invariant codecs_extra6.getwriter.name:
  description: "codecs.getwriter.__name__ == 'getwriter'"
  category: function_names
  kind: python_call_eq
  function: getwriter.__name__.__eq__
  args: ["getwriter"]
  expected: true

invariant codecs_extra6.getwriter.qualname:
  description: "codecs.getwriter.__qualname__ == 'getwriter'"
  category: qualnames
  kind: python_call_eq
  function: getwriter.__qualname__.__eq__
  args: ["getwriter"]
  expected: true

invariant codecs_extra6.getwriter.module:
  description: "codecs.getwriter.__module__ == 'codecs'"
  category: module_attrs
  kind: python_call_eq
  function: getwriter.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# getincrementalencoder — __name__, __qualname__, __module__
# codecs_extra checked the result class name but not the function itself.
# ---------------------------------------------------------------------------

invariant codecs_extra6.getincrementalencoder.name:
  description: "codecs.getincrementalencoder.__name__ == 'getincrementalencoder'"
  category: function_names
  kind: python_call_eq
  function: getincrementalencoder.__name__.__eq__
  args: ["getincrementalencoder"]
  expected: true

invariant codecs_extra6.getincrementalencoder.qualname:
  description: "codecs.getincrementalencoder.__qualname__ == 'getincrementalencoder'"
  category: qualnames
  kind: python_call_eq
  function: getincrementalencoder.__qualname__.__eq__
  args: ["getincrementalencoder"]
  expected: true

invariant codecs_extra6.getincrementalencoder.module:
  description: "codecs.getincrementalencoder.__module__ == 'codecs'"
  category: module_attrs
  kind: python_call_eq
  function: getincrementalencoder.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# getincrementaldecoder — __name__, __qualname__, __module__
# Same gap as getincrementalencoder.
# ---------------------------------------------------------------------------

invariant codecs_extra6.getincrementaldecoder.name:
  description: "codecs.getincrementaldecoder.__name__ == 'getincrementaldecoder'"
  category: function_names
  kind: python_call_eq
  function: getincrementaldecoder.__name__.__eq__
  args: ["getincrementaldecoder"]
  expected: true

invariant codecs_extra6.getincrementaldecoder.qualname:
  description: "codecs.getincrementaldecoder.__qualname__ == 'getincrementaldecoder'"
  category: qualnames
  kind: python_call_eq
  function: getincrementaldecoder.__qualname__.__eq__
  args: ["getincrementaldecoder"]
  expected: true

invariant codecs_extra6.getincrementaldecoder.module:
  description: "codecs.getincrementaldecoder.__module__ == 'codecs'"
  category: module_attrs
  kind: python_call_eq
  function: getincrementaldecoder.__module__.__eq__
  args: ["codecs"]
  expected: true

# ---------------------------------------------------------------------------
# Inheritance hierarchy checks — not covered in any prior spec
# codecs_extra3 covers __qualname__ and __module__ for StreamReader/StreamWriter
# but not their base classes. No prior spec checks CodecInfo's tuple base.
# ---------------------------------------------------------------------------

invariant codecs_extra6.StreamReader.base_is_Codec:
  description: "codecs.StreamReader.__bases__[0].__name__ == 'Codec'"
  category: hierarchy
  kind: python_call_eq
  function: StreamReader.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Codec"]
  expected: true

invariant codecs_extra6.StreamWriter.base_is_Codec:
  description: "codecs.StreamWriter.__bases__[0].__name__ == 'Codec'"
  category: hierarchy
  kind: python_call_eq
  function: StreamWriter.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Codec"]
  expected: true

invariant codecs_extra6.BufferedIncrementalDecoder.base_is_IncrementalDecoder:
  description: "codecs.BufferedIncrementalDecoder.__bases__[0].__name__ == 'IncrementalDecoder'"
  category: hierarchy
  kind: python_call_eq
  function: BufferedIncrementalDecoder.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["IncrementalDecoder"]
  expected: true

invariant codecs_extra6.CodecInfo.base_is_tuple:
  description: "codecs.CodecInfo.__bases__[0].__name__ == 'tuple' — CodecInfo is a namedtuple subclass"
  category: hierarchy
  kind: python_call_eq
  function: CodecInfo.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["tuple"]
  expected: true

invariant codecs_extra6.Codec.base_is_object:
  description: "codecs.Codec.__bases__[0].__name__ == 'object' — Codec is a top-level class"
  category: hierarchy
  kind: python_call_eq
  function: Codec.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true
