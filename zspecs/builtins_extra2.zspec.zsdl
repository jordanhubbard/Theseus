spec: builtins_extra2
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/builtins.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/builtins.html — Python builtins module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins.zspec.zsdl — covers exception/type/function __name__ checks and basic function calls"
    - "builtins_extra.zspec.zsdl — covers abs, all, any, bin, chr, ord, divmod, hex, oct, pow, round, sorted, sum, max, min, len, isinstance, issubclass"
  notes:
    - "This spec covers exception class hierarchies not addressed in builtins.zspec.zsdl or builtins_extra.zspec.zsdl."
    - "NotImplementedError inherits from RuntimeError, which inherits from Exception."
    - "RecursionError inherits from RuntimeError."
    - "StopIteration inherits directly from Exception."
    - "GeneratorExit inherits from BaseException (not Exception) — it is not a regular exception."
    - "SystemExit inherits from BaseException (not Exception) — sys.exit() raises SystemExit."
    - "ArithmeticError inherits from Exception; ZeroDivisionError and OverflowError both inherit from ArithmeticError."
    - "All hierarchy invariants verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# NotImplementedError — class name and hierarchy
# ---------------------------------------------------------------------------

invariant builtins_extra2.NotImplementedError.name:
  description: "builtins.NotImplementedError.__name__ == 'NotImplementedError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: NotImplementedError.__name__.__eq__
  args: ["NotImplementedError"]
  expected: true

invariant builtins_extra2.NotImplementedError.base_is_RuntimeError:
  description: "builtins.NotImplementedError.__bases__[0].__name__ == 'RuntimeError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: NotImplementedError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["RuntimeError"]
  expected: true

# ---------------------------------------------------------------------------
# RecursionError — class name and hierarchy
# ---------------------------------------------------------------------------

invariant builtins_extra2.RecursionError.name:
  description: "builtins.RecursionError.__name__ == 'RecursionError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: RecursionError.__name__.__eq__
  args: ["RecursionError"]
  expected: true

invariant builtins_extra2.RecursionError.base_is_RuntimeError:
  description: "builtins.RecursionError.__bases__[0].__name__ == 'RuntimeError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: RecursionError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["RuntimeError"]
  expected: true

# ---------------------------------------------------------------------------
# StopIteration — class name and hierarchy
# ---------------------------------------------------------------------------

invariant builtins_extra2.StopIteration.name:
  description: "builtins.StopIteration.__name__ == 'StopIteration'"
  category: exception_hierarchy
  kind: python_call_eq
  function: StopIteration.__name__.__eq__
  args: ["StopIteration"]
  expected: true

invariant builtins_extra2.StopIteration.base_is_Exception:
  description: "builtins.StopIteration.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: StopIteration.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# GeneratorExit — class name and hierarchy (BaseException, not Exception)
# ---------------------------------------------------------------------------

invariant builtins_extra2.GeneratorExit.name:
  description: "builtins.GeneratorExit.__name__ == 'GeneratorExit'"
  category: exception_hierarchy
  kind: python_call_eq
  function: GeneratorExit.__name__.__eq__
  args: ["GeneratorExit"]
  expected: true

invariant builtins_extra2.GeneratorExit.base_is_BaseException:
  description: "builtins.GeneratorExit.__bases__[0].__name__ == 'BaseException'"
  category: exception_hierarchy
  kind: python_call_eq
  function: GeneratorExit.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["BaseException"]
  expected: true

# ---------------------------------------------------------------------------
# SystemExit — class name and hierarchy (BaseException, not Exception)
# ---------------------------------------------------------------------------

invariant builtins_extra2.SystemExit.name:
  description: "builtins.SystemExit.__name__ == 'SystemExit'"
  category: exception_hierarchy
  kind: python_call_eq
  function: SystemExit.__name__.__eq__
  args: ["SystemExit"]
  expected: true

invariant builtins_extra2.SystemExit.base_is_BaseException:
  description: "builtins.SystemExit.__bases__[0].__name__ == 'BaseException'"
  category: exception_hierarchy
  kind: python_call_eq
  function: SystemExit.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["BaseException"]
  expected: true

# ---------------------------------------------------------------------------
# ArithmeticError — hierarchy
# ---------------------------------------------------------------------------

invariant builtins_extra2.ArithmeticError.base_is_Exception:
  description: "builtins.ArithmeticError.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: ArithmeticError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# ZeroDivisionError — inherits from ArithmeticError
# ---------------------------------------------------------------------------

invariant builtins_extra2.ZeroDivisionError.base_is_ArithmeticError:
  description: "builtins.ZeroDivisionError.__bases__[0].__name__ == 'ArithmeticError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: ZeroDivisionError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["ArithmeticError"]
  expected: true

# ---------------------------------------------------------------------------
# OverflowError — inherits from ArithmeticError
# ---------------------------------------------------------------------------

invariant builtins_extra2.OverflowError.base_is_ArithmeticError:
  description: "builtins.OverflowError.__bases__[0].__name__ == 'ArithmeticError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: OverflowError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["ArithmeticError"]
  expected: true

# ---------------------------------------------------------------------------
# BaseException — the root of the entire exception hierarchy
# ---------------------------------------------------------------------------

invariant builtins_extra2.BaseException.name:
  description: "builtins.BaseException.__name__ == 'BaseException'"
  category: exception_hierarchy
  kind: python_call_eq
  function: BaseException.__name__.__eq__
  args: ["BaseException"]
  expected: true

invariant builtins_extra2.Exception.base_is_BaseException:
  description: "builtins.Exception.__bases__[0].__name__ == 'BaseException'"
  category: exception_hierarchy
  kind: python_call_eq
  function: Exception.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["BaseException"]
  expected: true
