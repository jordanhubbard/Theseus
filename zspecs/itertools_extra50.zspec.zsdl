spec: itertools_extra50
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra49.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement/count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 for all types; __name__/__qualname__ string equality for all major types; __bases__[0].__name__=='object' for all major types; __bases__[0].__qualname__=='object' for all major types; __class__.__name__=='type' for groupby/chain/compress/islice/zip_longest/product/count/cycle/repeat; __class__.__qualname__=='type' for all seventeen major types; __class__.__module__=='builtins' for groupby/chain/compress/islice/zip_longest/product; __doc__.__class__.__name__=='str' for groupby/chain/compress/islice/zip_longest/product/count/cycle/repeat and the itertools module itself."
    - "This spec covers: itertools.accumulate/__doc__.__class__.__name__=='str'; itertools.starmap/__doc__.__class__.__name__=='str'; itertools.dropwhile/__doc__.__class__.__name__=='str'; itertools.takewhile/__doc__.__class__.__name__=='str'; itertools.filterfalse/__doc__.__class__.__name__=='str'; itertools.combinations/__doc__.__class__.__name__=='str'; itertools.permutations/__doc__.__class__.__name__=='str'; itertools.combinations_with_replacement/__doc__.__class__.__name__=='str'; itertools.accumulate/__doc__.__class__.__qualname__=='str'; itertools.combinations/__doc__.__class__.__qualname__=='str'; itertools.__doc__.__class__.__qualname__=='str'."
    - "Key findings: The eight itertools types covered in this spec (accumulate, starmap, dropwhile, takewhile, filterfalse, combinations, permutations, combinations_with_replacement) are all C-extension types defined in Modules/itertoolsmodule.c. Like those covered in extra49, their __doc__ is a Python str object created from the C-level tp_doc slot. Therefore __doc__.__class__.__name__ == 'str' (3 chars) for all of them. The str built-in type has __qualname__ == __name__ == 'str' (3 chars), so __doc__.__class__.__qualname__ == 'str' as well. This also applies to the itertools module docstring (itertools.__doc__), which was shown to have __class__.__name__ == 'str' in extra49; this spec confirms __class__.__qualname__ == 'str' for that module docstring. All eleven invariants are new to extra50."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools additional type docstring class names — extra50 namespace
#
# accumulate, starmap, dropwhile, takewhile, filterfalse, combinations,
# permutations, and combinations_with_replacement are C-extension types in
# Modules/itertoolsmodule.c. Their __doc__ is a Python str object created
# from the tp_doc slot. Therefore for each type T:
#   T.__doc__.__class__.__name__ == 'str' (3 chars).
# extra49 already covered groupby/chain/compress/islice/zip_longest/product/
# count/cycle/repeat. The eight types here are the remaining major itertools
# types not covered by extra49. All eight are new to extra50.
# ---------------------------------------------------------------------------

table itertools_extra50.additional_type_docstring_class_names:
  description: "itertools additional type __doc__.__class__.__name__ == 'str' — accumulate/starmap/dropwhile/takewhile/filterfalse/combinations/permutations/combinations_with_replacement are C-extension types; docstrings are str objects from tp_doc slots; 3-char class name"
  kind: python_call_eq
  category: identity
  id_prefix: itertdoc50

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_doc_class_name,
       accumulate.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.accumulate.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; yields running totals (or other accumulated results) of a binary function applied to consecutive pairs; docstring created from tp_doc and exposed as a Python str; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [starmap_doc_class_name,
       starmap.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.starmap.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; applies a function to each tuple of arguments drawn from an iterable using argument unpacking (equivalent to map with *args); docstring from tp_doc is a Python str; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [dropwhile_doc_class_name,
       dropwhile.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.dropwhile.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; drops leading elements while a predicate is true then yields all remaining elements; docstring from tp_doc is a Python str; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [takewhile_doc_class_name,
       takewhile.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.takewhile.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; yields elements while a predicate is true then stops; complement of dropwhile; docstring from tp_doc is a Python str; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [filterfalse_doc_class_name,
       filterfalse.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.filterfalse.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; yields elements for which a predicate returns false (complement of built-in filter); docstring from tp_doc is a Python str; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [combinations_doc_class_name,
       combinations.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.combinations.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; yields r-length subsequences of elements from an input iterable in sorted order without replacement; docstring from tp_doc is a Python str; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [permutations_doc_class_name,
       permutations.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.permutations.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; yields successive r-length permutations of elements from an input iterable; docstring from tp_doc is a Python str; __doc__.__class__.__name__ == 'str' (3 chars)"]
    - [combinations_with_replacement_doc_class_name,
       combinations_with_replacement.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.combinations_with_replacement.__doc__.__class__.__name__ == 'str' — C-extension type in Modules/itertoolsmodule.c; yields r-length subsequences allowing individual elements to be repeated more than once; docstring from tp_doc is a Python str; __doc__.__class__.__name__ == 'str' (3 chars)"]

# ---------------------------------------------------------------------------
# itertools type docstring class qualnames — extra50 namespace
#
# The str built-in type has __qualname__ == __name__ == 'str' (3 chars) because
# it is a top-level built-in type (not nested inside another class). Therefore
# for any itertools type T whose __doc__ is a str:
#   T.__doc__.__class__.__qualname__ == 'str'.
# Two type entries (accumulate, combinations) are chosen to cover different
# length types among the extra50 set. The module docstring entry for itertools
# extends extra49 (which recorded __class__.__name__ for the module) by now
# recording __class__.__qualname__. All three are new to extra50.
# ---------------------------------------------------------------------------

table itertools_extra50.type_docstring_class_qualnames:
  description: "itertools type __doc__.__class__.__qualname__ == 'str' — str is a top-level built-in type with __qualname__ == __name__ == 'str' (3 chars); holds for C-extension types (accumulate, combinations) and the itertools module docstring"
  kind: python_call_eq
  category: identity
  id_prefix: itertdoc50

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_doc_class_qualname,
       accumulate.__doc__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "itertools.accumulate.__doc__.__class__.__qualname__ == 'str' — C-extension type; docstring is a str object; the str built-in type is top-level so __qualname__ == __name__ == 'str' (3 chars); no dotted prefix because str is not a nested class; contrasts with nested classes whose __qualname__ contains dots"]
    - [combinations_doc_class_qualname,
       combinations.__doc__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "itertools.combinations.__doc__.__class__.__qualname__ == 'str' — C-extension type; docstring is a str object; the str built-in type has __qualname__ == 'str' (3 chars); same result as accumulate because both docstrings are instances of the same str class"]

# ---------------------------------------------------------------------------
# itertools module docstring class qualname — extra50 namespace
#
# extra49 recorded itertools.__doc__.__class__.__name__ == 'str'. This entry
# extends that by verifying __doc__.__class__.__qualname__ == 'str' for the
# module-level docstring. The module object is accessed via the backend binding
# as the module root. New to extra50.
# ---------------------------------------------------------------------------

invariant itertools_extra50.module_doc_class_qualname:
  description: "itertools.__doc__.__class__.__qualname__ == 'str' — C-extension module; module docstring is a str object created from PyModuleDef.m_doc; the str type is a top-level built-in with __qualname__ == 'str' (3 chars); extends extra49 which confirmed __class__.__name__ == 'str' for the module docstring"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__qualname__.__eq__
  args: ["str"]
  expected: true
