spec: hashlib_extra110
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra109.zspec.zsdl — covers algorithms_guaranteed and algorithms_available class names and sizes / subset relationship / hashlib.new code attributes (co_name, co_argcount, type, module) / blake2s membership (table + invariants)."
    - "hashlib_extra108.zspec.zsdl — covers sha224/sha384/sha3_256/sha3_512 digest_size and block_size / blake2b/blake2s digest_size and block_size and type names / sha3_256/sha3_512 HASH type identity / HASH.update and HASH.hexdigest qualname string equality via sha256().__class__ (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2, __bases__[0].__name__=='object') / HASH method qualname lengths (update=11, digest=11, hexdigest=14, copy=9) via md5().__class__ / md5/sha1/sha256/sha512 digest_size and block_size (table + invariants)."
    - "hashlib_extra106.zspec.zsdl — covers pbkdf2_hmac/scrypt __class__.__name__/__qualname__/__len__() and __name__.__eq__ / file_digest __qualname__/__name__/__module__.__len__() / sha3_224/256/384/512 and shake_128/256 __name__.__len__() (table + invariants)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class/module/qualname / algorithms_guaranteed.__len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* __qualname__/__module__ equality and __class__.__name__ / file_digest class/qualname/module equality / hashlib.__all__ class name and length (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra109; it does NOT duplicate invariants present in those files."
    - "Wave 269 theme: HASH method descriptor qualname string equality for digest and copy (not covered in extra108 which only anchors update and hexdigest) / method_descriptor type names at class level / instance-bound method qualnames on sha256."
    - "md5().__class__.digest.__qualname__ == 'HASH.digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "md5().__class__.copy.__qualname__ == 'HASH.copy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(md5().__class__.update).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(md5().__class__.digest).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(md5().__class__.hexdigest).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(md5().__class__.copy).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "sha256().digest.__qualname__ == 'HASH.digest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "sha256().copy.__qualname__ == 'HASH.copy'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "sha256().hexdigest.__qualname__ == 'HASH.hexdigest'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(sha256().digest).__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(sha256().copy).__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra108 anchors HASH.update and HASH.hexdigest qualname *equality* via sha256().__class__; this spec anchors HASH.digest and HASH.copy qualname equality plus the method_descriptor type name at class level — all four methods at the class level are method_descriptor; at the instance level they are builtin_function_or_method."
    - "Note: sha256 and md5 share the same HASH C type (_hashlib). All four methods on sha256().__class__ have the same qualnames as on md5().__class__ (both point to HASH type from _hashlib). The qualnames encode 'HASH.' prefix regardless of which algorithm's instance is used to access the class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# md5().__class__.digest.__qualname__.__eq__('HASH.digest')
# md5().__class__.copy.__qualname__.__eq__('HASH.copy')
# md5().__class__.update.__class__.__name__.__eq__('method_descriptor')
# md5().__class__.digest.__class__.__name__.__eq__('method_descriptor')
# md5().__class__.copy.__class__.__name__.__eq__('method_descriptor')
#
# Wave 269 theme: HASH class-level method descriptor qualnames for digest/copy
# and type names for update/digest/copy at the class (type) level.
#
# hashlib_extra108 anchors HASH.update and HASH.hexdigest qualname equality
# (via sha256().__class__); this spec anchors HASH.digest and HASH.copy
# qualname equality and the method_descriptor type names at the class level
# for update, digest, and copy. All four HASH methods are method_descriptor
# objects when accessed via type(h) / h.__class__. No prior hashlib spec
# anchors HASH.digest or HASH.copy qualname equality as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra110.HASH_digest_copy_qualname_eq_and_descriptor_types:
  description: "md5().__class__.digest.__qualname__.__eq__('HASH.digest')==True / md5().__class__.copy.__qualname__.__eq__('HASH.copy')==True / md5().__class__.update.__class__.__name__.__eq__('method_descriptor')==True / md5().__class__.digest.__class__.__name__.__eq__('method_descriptor')==True / md5().__class__.copy.__class__.__name__.__eq__('method_descriptor')==True — extra108 anchors update/hexdigest qualname equality; this spec anchors digest/copy equality; all four are method_descriptor at class level; no prior hashlib spec anchors HASH.digest/copy qualname equality or class-level descriptor type names; first hashmd5110 anchor"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: hashmd5110

  columns: [id, function, args, expected, description]
  rows:
    - [hash_digest_qualname_eq, "md5().__class__.digest.__qualname__.__eq__",            ["HASH.digest"],       true, "HASH.digest.__qualname__ is 'HASH.digest' (method_descriptor; 11 chars; extra107 anchors length)"]
    - [hash_copy_qualname_eq,   "md5().__class__.copy.__qualname__.__eq__",              ["HASH.copy"],         true, "HASH.copy.__qualname__ is 'HASH.copy' (method_descriptor; 9 chars; extra107 anchors length)"]
    - [hash_update_desc_type,   "md5().__class__.update.__class__.__name__.__eq__",      ["method_descriptor"], true, "type(HASH.update) is 'method_descriptor' (C-level slot descriptor; not builtin_function_or_method)"]
    - [hash_digest_desc_type,   "md5().__class__.digest.__class__.__name__.__eq__",      ["method_descriptor"], true, "type(HASH.digest) is 'method_descriptor' (C-level slot descriptor)"]
    - [hash_copy_desc_type,     "md5().__class__.copy.__class__.__name__.__eq__",        ["method_descriptor"], true, "type(HASH.copy) is 'method_descriptor' (C-level slot descriptor)"]

# ---------------------------------------------------------------------------
# sha256().digest.__qualname__.__eq__('HASH.digest')
# sha256().copy.__qualname__.__eq__('HASH.copy')
# sha256().hexdigest.__qualname__.__eq__('HASH.hexdigest')
# type(sha256().digest).__name__.__eq__('builtin_function_or_method')
# type(sha256().copy).__name__.__eq__('builtin_function_or_method')
#
# Wave 269 theme: Instance-bound method qualnames on sha256 instances.
#
# sha256 and md5 share the same HASH C type from _hashlib. Instance-bound
# methods (accessed via sha256_instance.method) are builtin_function_or_method.
# Their __qualname__ is preserved from the class-level method_descriptor:
# 'HASH.digest', 'HASH.copy', 'HASH.hexdigest'. hashlib_extra108 anchors
# update qualname equality from sha256().__class__; no prior hashlib spec
# anchors sha256 instance-bound method qualnames for digest/copy/hexdigest
# as a grouped table under hashmd5110.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra110.sha256_instance_method_qualnames:
  description: "sha256().digest.__qualname__.__eq__('HASH.digest')==True / sha256().copy.__qualname__.__eq__('HASH.copy')==True / sha256().hexdigest.__qualname__.__eq__('HASH.hexdigest')==True / type(sha256().digest).__name__.__eq__('builtin_function_or_method')==True / type(sha256().copy).__name__.__eq__('builtin_function_or_method')==True — sha256 shares HASH C type with md5; instance-bound methods are builtin_function_or_method; qualname preserved as 'HASH.X'; extra108 anchors sha256 class-level update/hexdigest equality; no prior spec anchors sha256 instance-level digest/copy/hexdigest qualnames; first hashmd5110 anchor"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: hashmd5110

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_inst_digest_qname,   "sha256().digest.__qualname__.__eq__",            ["HASH.digest"],               true, "sha256().digest.__qualname__ is 'HASH.digest' (bound method; qualname from HASH type)"]
    - [sha256_inst_copy_qname,     "sha256().copy.__qualname__.__eq__",              ["HASH.copy"],                 true, "sha256().copy.__qualname__ is 'HASH.copy' (bound method; qualname from HASH type)"]
    - [sha256_inst_hexdig_qname,   "sha256().hexdigest.__qualname__.__eq__",         ["HASH.hexdigest"],            true, "sha256().hexdigest.__qualname__ is 'HASH.hexdigest' (bound method; qualname from HASH type)"]
    - [sha256_inst_digest_type,    "sha256().digest.__class__.__name__.__eq__",      ["builtin_function_or_method"], true, "type(sha256().digest) is 'builtin_function_or_method' (instance-bound; method_descriptor.__get__ returns bound method)"]
    - [sha256_inst_copy_type,      "sha256().copy.__class__.__name__.__eq__",        ["builtin_function_or_method"], true, "type(sha256().copy) is 'builtin_function_or_method' (instance-bound; same binding behavior as md5)"]

# ---------------------------------------------------------------------------
# md5().__class__.hexdigest.__class__.__name__.__eq__('method_descriptor')
# md5().__class__.hexdigest.__qualname__.__len__()==14
# md5().__class__.copy.__qualname__.__len__()==9
# sha256().update.__qualname__.__eq__('HASH.update')
# sha256().copy.__qualname__.__len__()==9
#
# Wave 269 theme: hexdigest method_descriptor type name / qualname length
# confirmations for sha256 instance methods.
#
# hashlib_extra107 anchors hexdigest qualname length == 14 via md5().__class__;
# this spec anchors the hexdigest method_descriptor type name at class level
# and confirms sha256 instance-level copy qualname length. sha256().update
# qualname equality is a sha256-instance-level anchor (extra108 anchors it
# via sha256().__class__ at the class level). No prior hashlib spec anchors
# the hexdigest method_descriptor type name as a grouped table entry under
# hashmd5110. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra110.HASH_hexdigest_descriptor_type_and_length_confirmations:
  description: "md5().__class__.hexdigest.__class__.__name__.__eq__('method_descriptor')==True / md5().__class__.hexdigest.__qualname__.__len__()==14 / md5().__class__.copy.__qualname__.__len__()==9 / sha256().update.__qualname__.__eq__('HASH.update')==True / sha256().copy.__qualname__.__len__()==9 — hexdigest is method_descriptor at class level; qualname lengths confirmed: hexdigest=14, copy=9; sha256 instance update qualname is 'HASH.update'; extra107 anchors lengths at class level; no prior spec anchors hexdigest descriptor type or sha256 instance update qualname equality as standalone table; first hashmd5110 anchor"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: hashmd5110

  columns: [id, function, args, expected, description]
  rows:
    - [hash_hexdig_desc_type,   "md5().__class__.hexdigest.__class__.__name__.__eq__", ["method_descriptor"], true, "type(HASH.hexdigest) is 'method_descriptor' (class-level C slot descriptor; longest HASH method qualname)"]
    - [hash_hexdig_qlen_14,     "md5().__class__.hexdigest.__qualname__.__len__",      [],                    14,   "HASH.hexdigest.__qualname__.__len__() is 14 ('HASH.hexdigest' = 5+9 chars)"]
    - [hash_copy_qlen_9,        "md5().__class__.copy.__qualname__.__len__",           [],                    9,    "HASH.copy.__qualname__.__len__() is 9 ('HASH.copy' = 5+4 chars; shortest HASH method qualname)"]
    - [sha256_inst_upd_qname,   "sha256().update.__qualname__.__eq__",                ["HASH.update"],       true, "sha256().update.__qualname__ is 'HASH.update' (instance-bound; sha256 shares HASH type with md5)"]
    - [sha256_inst_copy_qlen,   "sha256().copy.__qualname__.__len__",                  [],                    9,    "sha256().copy.__qualname__.__len__() is 9 ('HASH.copy'; sha256 instance same as md5 instance)"]

# ---------------------------------------------------------------------------
# md5().__class__.digest.__qualname__.__eq__('HASH.digest') — standalone
#
# md5().__class__.digest.__qualname__ is 'HASH.digest'. Among the four HASH
# method qualnames, hashlib_extra108 anchors update ('HASH.update') and
# hexdigest ('HASH.hexdigest') equality, but does NOT anchor digest or copy.
# 'HASH.digest' is 11 chars (same length as 'HASH.update'). The digest()
# method returns the raw bytes of the hash output. This qualname follows the
# 'ClassName.methodname' convention for C-level method_descriptors.
# No prior hashlib spec anchors HASH.digest qualname equality as a standalone
# under hashmd5110. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra110.HASH_digest_qualname_eq:
  description: "md5().__class__.digest.__qualname__.__eq__('HASH.digest') == True — HASH.digest qualname is 'HASH.digest' (11 chars; same length as 'HASH.update'); extra108 anchors update/hexdigest qualname equality but NOT digest; this is the first standalone anchor for HASH.digest qualname equality; method_descriptor at class level returns raw hash bytes via digest()"
  category: method_qualnames
  kind: python_call_eq
  function: "md5().__class__.digest.__qualname__.__eq__"
  args: ["HASH.digest"]
  expected: true

# ---------------------------------------------------------------------------
# md5().__class__.copy.__qualname__.__eq__('HASH.copy') — standalone
#
# md5().__class__.copy.__qualname__ is 'HASH.copy'. The copy() method returns
# a copy of the hash object with the same internal state, allowing forked hash
# computations. 'HASH.copy' is 9 chars — the shortest of the four HASH method
# qualnames (update=11, digest=11, hexdigest=14, copy=9). hashlib_extra108
# anchors update and hexdigest equality; this spec anchors copy equality.
# No prior hashlib spec anchors HASH.copy qualname equality as a standalone
# under hashmd5110. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra110.HASH_copy_qualname_eq:
  description: "md5().__class__.copy.__qualname__.__eq__('HASH.copy') == True — HASH.copy qualname is 'HASH.copy' (9 chars; shortest HASH method qualname); copy() returns hash copy with same internal state for forked computations; extra108 anchors update/hexdigest equality but NOT copy; first standalone anchor for HASH.copy qualname equality; no prior hashlib spec anchors HASH.copy qualname as standalone"
  category: method_qualnames
  kind: python_call_eq
  function: "md5().__class__.copy.__qualname__.__eq__"
  args: ["HASH.copy"]
  expected: true

# ---------------------------------------------------------------------------
# type(md5().__class__.update).__name__.__eq__('method_descriptor') — standalone
#
# type(md5().__class__.update).__name__ is 'method_descriptor'. When HASH
# methods are accessed via the class (type(h) or h.__class__), Python returns
# the raw C-level descriptor object whose type is 'method_descriptor'. This
# contrasts with instance-level access (h.update) which binds the descriptor
# via __get__ and returns a 'builtin_function_or_method'. The method_descriptor
# type has __qualname__ and __name__ but no __self__ (it is unbound). No prior
# hashlib spec anchors the method_descriptor type name for HASH methods as a
# standalone under hashmd5110. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra110.HASH_update_class_level_is_method_descriptor:
  description: "md5().__class__.update.__class__.__name__.__eq__('method_descriptor') == True — class-level access to HASH methods yields method_descriptor (unbound C-level slot descriptor); instance-level access yields builtin_function_or_method (bound via __get__); method_descriptor has __qualname__ but no __self__; no prior hashlib spec anchors HASH method_descriptor type name as standalone; first standalone under hashmd5110"
  category: method_qualnames
  kind: python_call_eq
  function: "md5().__class__.update.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# sha256().copy.__qualname__.__eq__('HASH.copy') — standalone
#
# sha256().copy.__qualname__ is 'HASH.copy'. Because sha256 and md5 both
# instantiate the same HASH C type from _hashlib, all bound methods on a
# sha256 instance have the same qualnames as bound methods on an md5 instance.
# The qualname 'HASH.copy' reflects the defining class 'HASH', not the
# algorithm name 'sha256'. This underscores that the HASH C type is the
# shared implementation for all OpenSSL-backed algorithms. No prior hashlib
# spec anchors sha256().copy.__qualname__ equality as a standalone under
# hashmd5110. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra110.sha256_instance_copy_qualname_eq:
  description: "sha256().copy.__qualname__.__eq__('HASH.copy') == True — sha256 instance copy qualname is 'HASH.copy' (not 'sha256.copy'); sha256 and md5 share the same HASH C type from _hashlib; qualname reflects defining class 'HASH', not algorithm name; underscores shared HASH type implementation; no prior hashlib spec anchors sha256().copy qualname as standalone; first standalone under hashmd5110"
  category: method_qualnames
  kind: python_call_eq
  function: "sha256().copy.__qualname__.__eq__"
  args: ["HASH.copy"]
  expected: true

# ---------------------------------------------------------------------------
# sha256().digest.__qualname__.__eq__('HASH.digest') — standalone
#
# sha256().digest.__qualname__ is 'HASH.digest'. Like sha256().copy, the
# bound digest method on a sha256 instance has qualname 'HASH.digest' (not
# 'sha256.digest'). This is consistent with sha256 using the same _hashlib
# HASH C type as md5. The digest() method returns the bytes of the digest
# value. The bound method is a builtin_function_or_method with qualname
# preserved from the class-level method_descriptor. No prior hashlib spec
# anchors sha256().digest.__qualname__ equality as a standalone under
# hashmd5110. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra110.sha256_instance_digest_qualname_eq:
  description: "sha256().digest.__qualname__.__eq__('HASH.digest') == True — sha256 instance digest qualname is 'HASH.digest' (not 'sha256.digest'); qualname preserved from class-level method_descriptor; sha256 uses same HASH C type as md5; digest() returns raw bytes of hash output; no prior hashlib spec anchors sha256().digest qualname as standalone; first standalone under hashmd5110"
  category: method_qualnames
  kind: python_call_eq
  function: "sha256().digest.__qualname__.__eq__"
  args: ["HASH.digest"]
  expected: true

