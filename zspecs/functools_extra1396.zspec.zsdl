spec: functools_extra1396
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method presence for functools classes."
    - "functools.partial defines __class_getitem__ as a classmethod_descriptor in its __dict__; it is a C extension type."
    - "functools.cached_property and functools.partialmethod define __class_getitem__ as a classmethod in their __dict__; they are pure Python classes."
    - "functools.singledispatchmethod does NOT define __class_getitem__ in its __dict__; it is a pure Python class without generic alias support."
    - "No functools class defines __init_subclass__ in its __dict__; all inherit it from object as a builtin_function_or_method."
    - "functools.partial.__class_getitem__ resolves to a builtin_function_or_method when accessed on the class (classmethod_descriptor bound)."
    - "functools.cached_property.__class_getitem__ and functools.partialmethod.__class_getitem__ resolve to a bound method when accessed on the class."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table functools_extra1396.class_getitem_in_dict:
  description: "functools classes that define __class_getitem__ in their __dict__: partial (C type), cached_property and partialmethod (Python classes); singledispatchmethod does not"
  kind: python_call_eq
  category: class_getitem_init_subclass_checks
  id_prefix: fu1396cg
  columns: [id, function, args, expected]
  rows:
    - [fu1396cg001, functools.partial.__dict__.__contains__,              ["__class_getitem__"], true]
    - [fu1396cg002, functools.cached_property.__dict__.__contains__,      ["__class_getitem__"], true]
    - [fu1396cg003, functools.partialmethod.__dict__.__contains__,        ["__class_getitem__"], true]
    - [fu1396cg004, functools.singledispatchmethod.__dict__.__contains__,  ["__class_getitem__"], false]
    - [fu1396cg005, functools.partial.__class_getitem__.__class__.__name__.__eq__,         ["builtin_function_or_method"], true]
    - [fu1396cg006, functools.cached_property.__class_getitem__.__class__.__name__.__eq__, ["method"],                    true]
    - [fu1396cg007, functools.partialmethod.__class_getitem__.__class__.__name__.__eq__,   ["method"],                    true]

table functools_extra1396.init_subclass_not_in_dict:
  description: "No functools class defines __init_subclass__ in its __dict__; all inherit it from object; when accessed on the class it resolves to builtin_function_or_method"
  kind: python_call_eq
  category: class_getitem_init_subclass_checks
  id_prefix: fu1396is
  columns: [id, function, args, expected]
  rows:
    - [fu1396is001, functools.partial.__dict__.__contains__,              ["__init_subclass__"], false]
    - [fu1396is002, functools.cached_property.__dict__.__contains__,      ["__init_subclass__"], false]
    - [fu1396is003, functools.singledispatchmethod.__dict__.__contains__,  ["__init_subclass__"], false]
    - [fu1396is004, functools.partialmethod.__dict__.__contains__,         ["__init_subclass__"], false]
    - [fu1396is005, functools.partial.__init_subclass__.__class__.__name__.__eq__,             ["builtin_function_or_method"], true]
    - [fu1396is006, functools.cached_property.__init_subclass__.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [fu1396is007, functools.singledispatchmethod.__init_subclass__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [fu1396is008, functools.partialmethod.__init_subclass__.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]

table functools_extra1396.class_getitem_dict_descriptor_type:
  description: "The __class_getitem__ descriptor stored in __dict__ has type classmethod_descriptor for the C extension type (partial) and classmethod for pure Python types (cached_property, partialmethod)"
  kind: python_call_eq
  category: class_getitem_init_subclass_checks
  id_prefix: fu1396dt
  columns: [id, function, args, expected]
  rows:
    - [fu1396dt001, functools.partial.__dict__.__getitem__("__class_getitem__").__class__.__name__.__eq__,         ["classmethod_descriptor"], true]
    - [fu1396dt002, functools.cached_property.__dict__.__getitem__("__class_getitem__").__class__.__name__.__eq__, ["classmethod"],            true]
    - [fu1396dt003, functools.partialmethod.__dict__.__getitem__("__class_getitem__").__class__.__name__.__eq__,   ["classmethod"],            true]
    - [fu1396dt004, functools.partial.__dict__.__class__.__name__.__eq__,              ["mappingproxy"], true]
    - [fu1396dt005, functools.cached_property.__dict__.__class__.__name__.__eq__,      ["mappingproxy"], true]
    - [fu1396dt006, functools.singledispatchmethod.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [fu1396dt007, functools.partialmethod.__dict__.__class__.__name__.__eq__,        ["mappingproxy"], true]
