spec: sunau_extra2
version: ">=3.9,<3.13"
backend: python_module(sunau)

docs: https://docs.python.org/3/library/sunau.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sunau.html — Python sunau module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sunau.py"
    - "sunau.zspec.zsdl — covers Au_read/__name__, Au_write/__name__, Error/__name__, Error base, open/__name__, AUDIO_FILE_MAGIC, encoding constants"
    - "sunau_extra.zspec.zsdl — covers open/__name__/__module__, Error/__name__/__module__/base/bases_len, Au_read/__name__/__module__, Au_write/__name__/__module__, AUDIO_FILE_MAGIC value/type, openfp class name"
  notes:
    - "This spec extends sunau.zspec.zsdl and sunau_extra.zspec.zsdl."
    - "Deprecated since Python 3.11; removed in Python 3.13. Version constraint: >=3.9,<3.13."
    - "Focus: __qualname__ checks for sunau.open, sunau.Au_read, sunau.Au_write, and sunau.Error."
    - "All four are top-level names in the module, so __qualname__ == __name__ for each."
    - "sunau_extra already covers __name__ and __module__ for all four; __qualname__ is a distinct attribute not yet tested."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for sunau public exports
# sunau_extra covers __name__ and __module__ for each of these.
# __qualname__ is a distinct attribute; for top-level names it equals __name__.
# ---------------------------------------------------------------------------

table sunau_extra2.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [open,     open.__qualname__.__eq__,     ["open"],     true]
    - [Au_read,  Au_read.__qualname__.__eq__,  ["Au_read"],  true]
    - [Au_write, Au_write.__qualname__.__eq__, ["Au_write"], true]
    - [Error,    Error.__qualname__.__eq__,    ["Error"],    true]
