spec: functools_extra262
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools._lru_cache_wrapper identity and functools.cached_property class identity contracts."
    - "functools._lru_cache_wrapper.__name__ == '_lru_cache_wrapper' — the C-level wrapper type name. Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__module__ == 'functools' — defined in functools. Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.__class__.__name__ == 'type' — it is a class; metaclass is type. Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.cache_info.__qualname__ == '_lru_cache_wrapper.cache_info' — cache_info method qualname. Verified with Python 3.14.3."
    - "functools._lru_cache_wrapper.cache_clear.__qualname__ == '_lru_cache_wrapper.cache_clear' — cache_clear method qualname. Verified with Python 3.14.3."
    - "functools.cached_property.__name__ == 'cached_property' — class name. Verified with Python 3.14.3."
    - "functools.cached_property.__module__ == 'functools' — defined in functools. Verified with Python 3.14.3."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "functools.cached_property.__class__.__name__ == 'type' — it is a class; metaclass is type. Verified with Python 3.14.3."
    - "functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__' — descriptor protocol method. Verified with Python 3.14.3."
    - "functools.cached_property.__get__.__qualname__ == 'cached_property.__get__' — descriptor protocol method. Verified with Python 3.14.3."
    - "functools.cached_property.__init__.__qualname__ == 'cached_property.__init__' — initializer qualname. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools._lru_cache_wrapper class identity contracts
#
# functools._lru_cache_wrapper.__name__              == '_lru_cache_wrapper'
# functools._lru_cache_wrapper.__module__            == 'functools'
# functools._lru_cache_wrapper.__bases__[0].__name__ == 'object'
# functools._lru_cache_wrapper.__class__.__name__    == 'type'
# functools._lru_cache_wrapper.cache_info.__qualname__ == '_lru_cache_wrapper.cache_info'
#
# _lru_cache_wrapper is the C-level type returned by lru_cache. New to extra262.
# ---------------------------------------------------------------------------

table functools_extra262.lru_cache_wrapper_identity:
  description: "functools._lru_cache_wrapper name, module, base, class, cache_info qualname contracts; new to extra262"
  kind: python_call_eq
  category: identity
  id_prefix: ftlcw262

  columns: [id, function, args, expected, description]
  rows:
    - [lcw_name_eq,
       _lru_cache_wrapper.__name__.__eq__,
       ["_lru_cache_wrapper"],
       true,
       "functools._lru_cache_wrapper.__name__.__eq__('_lru_cache_wrapper') == True — C-level wrapper type name; new to extra262"]
    - [lcw_module_eq,
       _lru_cache_wrapper.__module__.__eq__,
       ["functools"],
       true,
       "functools._lru_cache_wrapper.__module__.__eq__('functools') == True — defined in functools; new to extra262"]
    - [lcw_base_name_eq,
       "_lru_cache_wrapper.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools._lru_cache_wrapper.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra262"]
    - [lcw_class_name_eq,
       _lru_cache_wrapper.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools._lru_cache_wrapper.__class__.__name__.__eq__('type') == True — it is a class; metaclass is type; new to extra262"]
    - [lcw_cache_info_qualname_eq,
       _lru_cache_wrapper.cache_info.__qualname__.__eq__,
       ["_lru_cache_wrapper.cache_info"],
       true,
       "functools._lru_cache_wrapper.cache_info.__qualname__.__eq__('_lru_cache_wrapper.cache_info') == True — cache_info method qualname; new to extra262"]

# ---------------------------------------------------------------------------
# Table 2: functools._lru_cache_wrapper cache_clear and class attribute contracts
#
# functools._lru_cache_wrapper.cache_clear.__qualname__ == '_lru_cache_wrapper.cache_clear'
# functools._lru_cache_wrapper.__qualname__             == '_lru_cache_wrapper'
# functools._lru_cache_wrapper.cache_info.__name__      == 'cache_info'
# functools._lru_cache_wrapper.cache_clear.__name__     == 'cache_clear'
# functools._lru_cache_wrapper.__name__.__class__.__name__ == 'str'
#
# New to extra262.
# ---------------------------------------------------------------------------

table functools_extra262.lru_cache_wrapper_methods:
  description: "functools._lru_cache_wrapper cache_clear qualname, qualname, cache_info/cache_clear name contracts; new to extra262"
  kind: python_call_eq
  category: identity
  id_prefix: ftlcwm262

  columns: [id, function, args, expected, description]
  rows:
    - [lcw_cache_clear_qualname_eq,
       _lru_cache_wrapper.cache_clear.__qualname__.__eq__,
       ["_lru_cache_wrapper.cache_clear"],
       true,
       "functools._lru_cache_wrapper.cache_clear.__qualname__.__eq__('_lru_cache_wrapper.cache_clear') == True — cache_clear method qualname; new to extra262"]
    - [lcw_qualname_eq,
       _lru_cache_wrapper.__qualname__.__eq__,
       ["_lru_cache_wrapper"],
       true,
       "functools._lru_cache_wrapper.__qualname__.__eq__('_lru_cache_wrapper') == True — top-level class; qualname equals name; new to extra262"]
    - [lcw_cache_info_name_eq,
       _lru_cache_wrapper.cache_info.__name__.__eq__,
       ["cache_info"],
       true,
       "functools._lru_cache_wrapper.cache_info.__name__.__eq__('cache_info') == True — cache_info method name; new to extra262"]
    - [lcw_cache_clear_name_eq,
       _lru_cache_wrapper.cache_clear.__name__.__eq__,
       ["cache_clear"],
       true,
       "functools._lru_cache_wrapper.cache_clear.__name__.__eq__('cache_clear') == True — cache_clear method name; new to extra262"]
    - [lcw_name_class_eq,
       _lru_cache_wrapper.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools._lru_cache_wrapper.__name__.__class__.__name__.__eq__('str') == True — __name__ is a str; new to extra262"]

# ---------------------------------------------------------------------------
# Table 3: functools.cached_property class identity contracts
#
# functools.cached_property.__name__              == 'cached_property'
# functools.cached_property.__module__            == 'functools'
# functools.cached_property.__bases__[0].__name__ == 'object'
# functools.cached_property.__class__.__name__    == 'type'
# functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__'
#
# cached_property is a Python descriptor class. New to extra262.
# ---------------------------------------------------------------------------

table functools_extra262.cached_property_identity:
  description: "functools.cached_property name, module, base, class, __set_name__ qualname contracts; new to extra262"
  kind: python_call_eq
  category: identity
  id_prefix: ftcp262

  columns: [id, function, args, expected, description]
  rows:
    - [cp_name_eq,
       cached_property.__name__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — class name; new to extra262"]
    - [cp_module_eq,
       cached_property.__module__.__eq__,
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — defined in functools; new to extra262"]
    - [cp_base_name_eq,
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra262"]
    - [cp_class_name_eq,
       cached_property.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — it is a class; metaclass is type; new to extra262"]
    - [cp_set_name_qualname_eq,
       cached_property.__set_name__.__qualname__.__eq__,
       ["cached_property.__set_name__"],
       true,
       "functools.cached_property.__set_name__.__qualname__.__eq__('cached_property.__set_name__') == True — descriptor __set_name__ qualname; new to extra262"]

# ---------------------------------------------------------------------------
# Table 4: functools.cached_property __get__ and __init__ qualname contracts
#
# functools.cached_property.__get__.__qualname__    == 'cached_property.__get__'
# functools.cached_property.__init__.__qualname__   == 'cached_property.__init__'
# functools.cached_property.__set_name__.__name__   == '__set_name__'
# functools.cached_property.__get__.__name__        == '__get__'
# functools.cached_property.__init__.__name__       == '__init__'
#
# New to extra262.
# ---------------------------------------------------------------------------

table functools_extra262.cached_property_methods:
  description: "functools.cached_property __get__, __init__ qualname, __set_name__, __get__, __init__ name contracts; new to extra262"
  kind: python_call_eq
  category: identity
  id_prefix: ftcpm262

  columns: [id, function, args, expected, description]
  rows:
    - [cp_get_qualname_eq,
       cached_property.__get__.__qualname__.__eq__,
       ["cached_property.__get__"],
       true,
       "functools.cached_property.__get__.__qualname__.__eq__('cached_property.__get__') == True — descriptor __get__ qualname; new to extra262"]
    - [cp_init_qualname_eq,
       cached_property.__init__.__qualname__.__eq__,
       ["cached_property.__init__"],
       true,
       "functools.cached_property.__init__.__qualname__.__eq__('cached_property.__init__') == True — initializer qualname; new to extra262"]
    - [cp_set_name_name_eq,
       cached_property.__set_name__.__name__.__eq__,
       ["__set_name__"],
       true,
       "functools.cached_property.__set_name__.__name__.__eq__('__set_name__') == True — __set_name__ method name; new to extra262"]
    - [cp_get_name_eq,
       cached_property.__get__.__name__.__eq__,
       ["__get__"],
       true,
       "functools.cached_property.__get__.__name__.__eq__('__get__') == True — __get__ method name; new to extra262"]
    - [cp_init_name_eq,
       cached_property.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "functools.cached_property.__init__.__name__.__eq__('__init__') == True — initializer method name; new to extra262"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra262
# ---------------------------------------------------------------------------

invariant functools_extra262.lru_cache_wrapper.name_eq:
  description: "functools._lru_cache_wrapper.__name__ == '_lru_cache_wrapper' — C-level wrapper type name; new to extra262"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__name__.__eq__
  args: ["_lru_cache_wrapper"]
  expected: true

invariant functools_extra262.lru_cache_wrapper.module_eq:
  description: "functools._lru_cache_wrapper.__module__ == 'functools' — defined in functools; new to extra262"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra262.lru_cache_wrapper.base_is_object:
  description: "functools._lru_cache_wrapper.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra262"
  category: identity
  kind: python_call_eq
  function: "_lru_cache_wrapper.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra262.lru_cache_wrapper.class_is_type:
  description: "functools._lru_cache_wrapper.__class__.__name__ == 'type' — it is a class; metaclass is type; new to extra262"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra262.lru_cache_wrapper.cache_info_qualname:
  description: "functools._lru_cache_wrapper.cache_info.__qualname__ == '_lru_cache_wrapper.cache_info'; new to extra262"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.cache_info.__qualname__.__eq__
  args: ["_lru_cache_wrapper.cache_info"]
  expected: true

invariant functools_extra262.lru_cache_wrapper.cache_clear_qualname:
  description: "functools._lru_cache_wrapper.cache_clear.__qualname__ == '_lru_cache_wrapper.cache_clear'; new to extra262"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.cache_clear.__qualname__.__eq__
  args: ["_lru_cache_wrapper.cache_clear"]
  expected: true

invariant functools_extra262.cached_property.name_eq:
  description: "functools.cached_property.__name__ == 'cached_property' — class name; new to extra262"
  category: identity
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra262.cached_property.module_eq:
  description: "functools.cached_property.__module__ == 'functools' — defined in functools; new to extra262"
  category: identity
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra262.cached_property.base_is_object:
  description: "functools.cached_property.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra262"
  category: identity
  kind: python_call_eq
  function: "cached_property.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra262.cached_property.class_is_type:
  description: "functools.cached_property.__class__.__name__ == 'type' — it is a class; metaclass is type; new to extra262"
  category: identity
  kind: python_call_eq
  function: cached_property.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra262.cached_property.set_name_qualname:
  description: "functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__' — descriptor __set_name__; new to extra262"
  category: identity
  kind: python_call_eq
  function: cached_property.__set_name__.__qualname__.__eq__
  args: ["cached_property.__set_name__"]
  expected: true

invariant functools_extra262.cached_property.get_qualname:
  description: "functools.cached_property.__get__.__qualname__ == 'cached_property.__get__' — descriptor __get__; new to extra262"
  category: identity
  kind: python_call_eq
  function: cached_property.__get__.__qualname__.__eq__
  args: ["cached_property.__get__"]
  expected: true

invariant functools_extra262.cached_property.init_qualname:
  description: "functools.cached_property.__init__.__qualname__ == 'cached_property.__init__' — initializer qualname; new to extra262"
  category: identity
  kind: python_call_eq
  function: cached_property.__init__.__qualname__.__eq__
  args: ["cached_property.__init__"]
  expected: true
