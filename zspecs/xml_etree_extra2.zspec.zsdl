spec: xml_etree_extra2
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "Python 3 xml.etree.ElementTree documentation — https://docs.python.org/3/library/xml.etree.elementtree.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py"
    - "elementtree.zspec.zsdl — covers fromstring tag/text/attrib/get/findtext, Element constructor, tostring, SubElement, ParseError raise behavior"
    - "xml_extra.zspec.zsdl — covers class/function __name__ table (Element, ElementTree, SubElement, ParseError, parse, fromstring, tostring)"
    - "xml_extra2.zspec.zsdl — covers fromstring('<root/>').tag == 'root', Element tag/attrib, tostring result class, ParseError class_name, SubElement.__name__, ParseError base"
    - "xml_extra3.zspec.zsdl — covers Element/__qualname__, ElementTree/__qualname__, XMLParser/__qualname__, ParseError/__qualname__, tostring/indent/iterparse/parse __qualname__, Element.__module__, XMLParser.__module__, Element.__bases__[0].__name__"
    - "xml_etree_extra.zspec.zsdl — covers Element.__name__, SubElement.__name__, parse/fromstring/tostring/indent/iterparse/__name__, ParseError name/base, fromstring result class, Element.__module__ is str"
    - "xml_parse.zspec.zsdl — covers ElementTree/XMLParser/ParseError __module__ exact value, ParseError base, XMLParser feed/close"
  notes:
    - "This spec extends all prior xml.etree.ElementTree specs."
    - "Focus: SubElement.__qualname__ and fromstring.__qualname__ (omitted from xml_extra3 table despite being mentioned in its notes); function __module__ checks for SubElement, fromstring, tostring, parse, indent, iterparse."
    - "xml_extra3 notes claim SubElement.__qualname__ was added but the actual table rows do not include it — this spec adds it."
    - "SubElement.__qualname__ == 'SubElement' — top-level factory function, qualname equals name."
    - "fromstring.__qualname__ == 'fromstring' — top-level function, qualname equals name."
    - "SubElement.__module__ == 'xml.etree.ElementTree' — defined in the main ElementTree module."
    - "fromstring.__module__ == 'xml.etree.ElementTree'."
    - "tostring.__module__ == 'xml.etree.ElementTree'."
    - "parse.__module__ == 'xml.etree.ElementTree'."
    - "indent.__module__ == 'xml.etree.ElementTree'."
    - "iterparse.__module__ == 'xml.etree.ElementTree'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Missing __qualname__ checks — SubElement and fromstring
#
# xml_extra3 covers Element/ElementTree/XMLParser/ParseError/tostring/indent/
# iterparse/parse qualnames. SubElement and fromstring were listed in notes
# but omitted from the actual table rows.
# ---------------------------------------------------------------------------

invariant xml_etree_extra2.SubElement.qualname:
  description: "xml.etree.ElementTree.SubElement.__qualname__ == 'SubElement'"
  category: qualnames
  kind: python_call_eq
  function: SubElement.__qualname__.__eq__
  args: ["SubElement"]
  expected: true

invariant xml_etree_extra2.fromstring.qualname:
  description: "xml.etree.ElementTree.fromstring.__qualname__ == 'fromstring'"
  category: qualnames
  kind: python_call_eq
  function: fromstring.__qualname__.__eq__
  args: ["fromstring"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ checks — not covered in any prior xml.etree spec
#
# xml_extra3 covers Element.__module__ and XMLParser.__module__;
# xml_parse covers ElementTree/XMLParser/ParseError __module__.
# No prior spec checks __module__ for the module-level functions.
# ---------------------------------------------------------------------------

table xml_etree_extra2.function_modules:
  kind: python_call_eq
  category: modules
  id_prefix: fnmod

  columns: [id, function, args, expected]
  rows:
    - [SubElement, SubElement.__module__.__eq__, ["xml.etree.ElementTree"], true]
    - [fromstring,  fromstring.__module__.__eq__,  ["xml.etree.ElementTree"], true]
    - [tostring,    tostring.__module__.__eq__,    ["xml.etree.ElementTree"], true]
    - [parse,       parse.__module__.__eq__,       ["xml.etree.ElementTree"], true]
    - [indent,      indent.__module__.__eq__,      ["xml.etree.ElementTree"], true]
    - [iterparse,   iterparse.__module__.__eq__,   ["xml.etree.ElementTree"], true]

# ---------------------------------------------------------------------------
# ParseError.__module__ — confirm from xml.etree.ElementTree backend
#
# xml_parse.zspec.zsdl verifies this from the xml.etree.ElementTree backend;
# this is a cross-spec corroboration from the same backend.
# ---------------------------------------------------------------------------

invariant xml_etree_extra2.ParseError.module:
  description: "xml.etree.ElementTree.ParseError.__module__ == 'xml.etree.ElementTree'"
  category: modules
  kind: python_call_eq
  function: ParseError.__module__.__eq__
  args: ["xml.etree.ElementTree"]
  expected: true

# ---------------------------------------------------------------------------
# SubElement — callable check
# (xml_etree_extra covers Comment/ProcessingInstruction; SubElement is new here)
# ---------------------------------------------------------------------------

invariant xml_etree_extra2.SubElement.is_callable:
  description: "xml.etree.ElementTree.SubElement.__class__.__name__ — SubElement is a builtin_function_or_method or function"
  category: types
  kind: python_call_eq
  function: SubElement.__module__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
