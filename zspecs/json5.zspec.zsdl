spec: json5
version: ">=2.0.0"
backend: node(json5)

docs: https://spec.json5.org/

rfcs:
  - "JSON5 Specification — https://spec.json5.org/"

provenance:
  derived_from:
    - "JSON5 Specification — https://spec.json5.org/"
    - "json5 README — https://github.com/json5/json5#readme"
    - "Test vectors verified with json5@2.2.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "json5 source: lib/parse.js, lib/stringify.js"
  notes:
    - "JSON5 is a superset of JSON that allows: unquoted keys, single-quoted strings, trailing commas, comments, hex numbers, and multi-line strings."
    - "JSON5.parse() accepts both JSON and JSON5 input; returns native JS values."
    - "JSON5.stringify() produces JSON5 format with unquoted keys (no quotes around simple identifiers)."
    - "JSON5.stringify() of objects with identifier-safe keys omits quotes; non-identifier keys get quoted."
    - "The module exports an object with parse and stringify methods."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "parse() throws SyntaxError for invalid JSON5. stringify() throws for circular structures."
  stderr: "null for valid inputs"
  stickiness: "N/A — stateless."
  codes: {}

# ---------------------------------------------------------------------------
# JSON5.parse — accepts JSON5 extensions
# ---------------------------------------------------------------------------

table json5.parse.json_compat:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: parse

  columns: [id, args, expected]
  rows:
    - [std_obj,       ["{\"a\":1}"],          {"a": 1}]
    - [std_array,     ["[1,2,3]"],            [1, 2, 3]]
    - [std_string,    ["\"hello\""],          "hello"]
    - [std_number,    ["42"],                 42]
    - [std_bool,      ["true"],               true]
    - [std_null,      ["null"],               null]

table json5.parse.extensions:
  kind: node_module_call_eq
  function: parse
  category: parse_extensions
  id_prefix: parse_ext

  columns: [id, args, expected]
  rows:
    - [unquoted_key,   ["{a:1}"],             {"a": 1}]
    - [single_quote,   ["{'key':'val'}"],     {"key": "val"}]
    - [trailing_comma, ["{a:1,}"],            {"a": 1}]
    - [arr_trail,      ["[1,2,3,]"],          [1, 2, 3]]

# ---------------------------------------------------------------------------
# JSON5.stringify — produces JSON5 format
# ---------------------------------------------------------------------------

table json5.stringify:
  kind: node_module_call_eq
  function: stringify
  category: stringify
  id_prefix: stringify

  columns: [id, args, expected]
  rows:
    - [simple_obj,     [{"a": 1}],            "{a:1}"]
    - [two_keys,       [{"a": 1, "b": 2}],    "{a:1,b:2}"]
    - [nested,         [{"a": {"b": 1}}],     "{a:{b:1}}"]
    - [array,          [[1, 2, 3]],           "[1,2,3]"]
    - [string_val,     ["hello"],             "'hello'"]
    - [number_val,     [42],                  "42"]
    - [bool_val,       [true],                "true"]
    - [null_val,       [null],                "null"]
