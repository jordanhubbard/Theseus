spec: json5
version: ">=2.0.0"
backend: node(json5)

docs: https://www.npmjs.com/package/json5

provenance:
  derived_from:
    - "json5 README — https://www.npmjs.com/package/json5"
    - "Test vectors verified with json5 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "json5 source"
  notes:
    - "json5 is an npm package. Install: npm install json5"
    - "JSON5.parse(str) parses a JSON5 string (allows unquoted keys, single-quoted strings, comments)."
    - "JSON5.stringify(obj) serializes an object to JSON5 format with single-quoted strings."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns parsed object or JSON5 string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table json5.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: j5parse

  columns: [id, args, expected]
  rows:
    - [unquoted_keys, ["{a: 1, b: \"hello\"}"],  {"a": 1, "b": "hello"}]
    - [trailing_comma,["{x: [1, 2, 3,]}"],         {"x": [1, 2, 3]}]

table json5.stringify:
  kind: node_module_call_eq
  function: stringify
  category: format
  id_prefix: j5str

  columns: [id, args, expected]
  rows:
    - [simple, [{"a": 1, "b": "hello"}],  "{a:1,b:'hello'}"]
