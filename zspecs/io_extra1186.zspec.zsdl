spec: io_extra1186
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io class __dict__.__class__.__name__ (mappingproxy), __mro__.__class__.__name__ (tuple), and __subclasses__.__qualname__ checks for IOBase, RawIOBase, FileIO, BytesIO, StringIO, TextIOWrapper, UnsupportedOperation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.IOBase.__dict__.__class__.__name__, io.RawIOBase.__dict__.__class__.__name__, io.FileIO.__dict__.__class__.__name__, io.BytesIO.__dict__.__class__.__name__, io.StringIO.__dict__.__class__.__name__, io.TextIOWrapper.__dict__.__class__.__name__ (all mappingproxy); io.IOBase.__mro__.__class__.__name__, io.UnsupportedOperation.__mro__.__class__.__name__ (tuple); io.IOBase.__subclasses__.__qualname__, io.RawIOBase.__subclasses__.__qualname__; none of these __dict__.__class__.__name__, __mro__.__class__.__name__, or __subclasses__.__qualname__ checks were covered in _extra1156 or _extra1171"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1186.class_dict_class_names:
  description: "io class __dict__.__class__.__name__ checks — IOBase, RawIOBase, FileIO, BytesIO, StringIO, TextIOWrapper all expose mappingproxy"
  kind: python_call_eq
  category: class_dict_class_names
  id_prefix: io1186dc
  columns: [id, function, args, expected]
  rows:
    - [io1186dc001, io.IOBase.__dict__.__class__.__name__.__eq__,        ["mappingproxy"], true]
    - [io1186dc002, io.RawIOBase.__dict__.__class__.__name__.__eq__,     ["mappingproxy"], true]
    - [io1186dc003, io.FileIO.__dict__.__class__.__name__.__eq__,        ["mappingproxy"], true]
    - [io1186dc004, io.BytesIO.__dict__.__class__.__name__.__eq__,       ["mappingproxy"], true]
    - [io1186dc005, io.StringIO.__dict__.__class__.__name__.__eq__,      ["mappingproxy"], true]
    - [io1186dc006, io.TextIOWrapper.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [io1186dc007, io.IOBase.__dict__.__class__.__name__.__eq__,        ["dict"],         false]
    - [io1186dc008, io.RawIOBase.__dict__.__class__.__name__.__eq__,     ["dict"],         false]
    - [io1186dc009, io.FileIO.__dict__.__class__.__name__.__eq__,        ["dict"],         false]
    - [io1186dc010, io.BytesIO.__dict__.__class__.__name__.__eq__,       ["getset_descriptor"], false]

