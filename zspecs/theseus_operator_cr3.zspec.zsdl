spec: theseus_operator_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_operator_cr3)
blocks: operator

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html"
  notes:
    - "Clean-room extended operator utilities. Do NOT import operator."
    - "truth(obj): return True if obj is truthy, False otherwise."
    - "not_(obj): return not obj — logical negation."
    - "contains(a, b): return b in a (equivalent to __contains__)."
    - "operator3_truth(): truth([1, 2]) == True."
    - "operator3_not_(): not_('') == True (empty string is falsy)."
    - "operator3_contains(): contains([1, 2, 3], 2) == True."
    - "Zero-arg invariant signatures — def operator3_truth(): return hardcoded_result"
    - "truth(obj): equivalent to bool(obj)."
    - "not_(obj): equivalent to not obj."
    - "contains(a, b): equivalent to b in a."
    - "Export: truth, not_, contains, add, sub, mul, truediv, floordiv, mod, pow, neg, pos, abs, and_, or_, xor, lshift, rshift, eq, ne, lt, le, gt, ge, getitem, setitem, delitem, attrgetter, itemgetter, methodcaller."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_operator_cr3.truth:
  description: "truth([1, 2]) == True"
  category: truth
  kind: python_call_eq
  function: operator3_truth
  args: []
  expected: true

invariant theseus_operator_cr3.not_:
  description: "not_('') == True"
  category: not_
  kind: python_call_eq
  function: operator3_not_
  args: []
  expected: true

invariant theseus_operator_cr3.contains:
  description: "contains([1, 2, 3], 2) == True"
  category: contains
  kind: python_call_eq
  function: operator3_contains
  args: []
  expected: true
