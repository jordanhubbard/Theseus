spec: concurrent_futures_extra117
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra116.zspec.zsdl."
    - "This spec covers: wave 260 theme — concurrent.futures.ThreadPoolExecutor class method co_varnames element equality not previously covered. Prior specs covered: extra68 covered ThreadPoolExecutor.__init__.__code__.co_varnames.__class__.__name__=='tuple' and co_argcount==5; extra70 covered ThreadPoolExecutor.__init__.__code__.co_varnames.__len__()==6 and submit.__code__.co_argcount==2. NOT previously covered: ThreadPoolExecutor.__init__.__code__.co_varnames[1].__eq__('max_workers'); co_varnames[2].__eq__('thread_name_prefix'); co_varnames[3].__eq__('initializer'); ThreadPoolExecutor.submit.__code__.co_varnames[1].__eq__('fn'); submit co_varnames.__len__()==7; ThreadPoolExecutor.shutdown.__code__.co_varnames[2].__eq__('cancel_futures'); shutdown co_varnames.__len__()==5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames == ('self','max_workers','thread_name_prefix','initializer','initargs','ctxkwargs'): len=6 (covered in extra70). co_argcount==5 (self + max_workers + thread_name_prefix + initializer + initargs; ctxkwargs is VAR_KEYWORD not counted in co_argcount). co_qualname=='ThreadPoolExecutor.__init__' (len=27). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames == ('self','fn','args','kwargs','f','task','w'): len=7 (most co_varnames among the three methods in this spec). co_argcount==2 (self + fn; args and kwargs are VAR_POSITIONAL/VAR_KEYWORD; f, task, w are locals). co_qualname=='ThreadPoolExecutor.submit' (len=25). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_varnames == ('self','wait','cancel_futures','work_item','t'): len=5. co_qualname=='ThreadPoolExecutor.shutdown' (len=27; tied with __init__ co_qualname len=27). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.__init__ co_varnames element equality — extra117
#
# Wave 260 theme: ThreadPoolExecutor.__init__ co_varnames[1], [2], [3] equality.
#
# ThreadPoolExecutor.__init__.__code__.co_varnames[0] == 'self'               (len=4)
# ThreadPoolExecutor.__init__.__code__.co_varnames[1] == 'max_workers'        (len=11)
# ThreadPoolExecutor.__init__.__code__.co_varnames[2] == 'thread_name_prefix' (len=18)
# ThreadPoolExecutor.__init__.__code__.co_varnames[3] == 'initializer'        (len=11)
# ThreadPoolExecutor.__init__.__code__.co_varnames[4] == 'initargs'           (len=8)
# ThreadPoolExecutor.__init__.__code__.co_varnames[5] == 'ctxkwargs'          (len=9)
# ---------------------------------------------------------------------------

table concurrent_futures_extra117.cf_tpe_init_co_varnames:
  description: "concurrent.futures.ThreadPoolExecutor.__init__ co_varnames element equality checks in cftpe117 namespace — wave 260 theme: first element-level coverage of ThreadPoolExecutor.__init__ co_varnames; co_varnames==('self','max_workers','thread_name_prefix','initializer','initargs','ctxkwargs') len=6 (covered in extra70); co_varnames[1].__eq__('max_workers')==True (len=11: max_workers controls how many worker threads are created; None means use os.cpu_count()*5 as default; first non-self parameter); co_varnames[2].__eq__('thread_name_prefix')==True (len=18: thread_name_prefix is an optional string prepended to thread names for easier debugging; longest parameter name in __init__ at 18 chars); co_varnames[3].__eq__('initializer')==True (len=11: initializer is an optional callable invoked at thread startup in each worker thread; tied with max_workers len=11); co_varnames[4].__eq__('initargs')==True (len=8: initargs is the tuple of arguments passed to initializer; 3 shorter than 'initializer'=11); co_varnames[5].__eq__('ctxkwargs')==True (len=9: ctxkwargs is the VAR_KEYWORD parameter capturing extra keyword args for context; not counted in co_argcount; 1 more than 'initargs'=8); element length ordering: fn=2 (submit) < self=4 < initargs=8 < ctxkwargs=9 < max_workers==initializer=11 (tied) < thread_name_prefix=18 (longest __init__ param); co_argcount==5 (self, max_workers, thread_name_prefix, initializer, initargs — all except ctxkwargs which is VAR_KEYWORD); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cftpe117

  columns: [id, function, args, expected, description]
  rows:
    - [v1_eq,   "ThreadPoolExecutor.__init__.__code__.co_varnames[1].__eq__", ["max_workers"],        true, "ThreadPoolExecutor.__init__ co_varnames[1] == 'max_workers' (len=11; first non-self param); verified with Python 3.14.3"]
    - [v1_len,  "ThreadPoolExecutor.__init__.__code__.co_varnames[1].__len__", [],                    11,   "ThreadPoolExecutor.__init__ co_varnames[1].__len__() == 11 ('max_workers'=11); verified with Python 3.14.3"]
    - [v2_eq,   "ThreadPoolExecutor.__init__.__code__.co_varnames[2].__eq__", ["thread_name_prefix"], true, "ThreadPoolExecutor.__init__ co_varnames[2] == 'thread_name_prefix' (len=18, longest param); verified with Python 3.14.3"]
    - [v2_len,  "ThreadPoolExecutor.__init__.__code__.co_varnames[2].__len__", [],                    18,   "ThreadPoolExecutor.__init__ co_varnames[2].__len__() == 18 ('thread_name_prefix'=18, longest in spec); verified with Python 3.14.3"]
    - [v3_eq,   "ThreadPoolExecutor.__init__.__code__.co_varnames[3].__eq__", ["initializer"],        true, "ThreadPoolExecutor.__init__ co_varnames[3] == 'initializer' (len=11, tied with max_workers=11); verified with Python 3.14.3"]
    - [v3_len,  "ThreadPoolExecutor.__init__.__code__.co_varnames[3].__len__", [],                    11,   "ThreadPoolExecutor.__init__ co_varnames[3].__len__() == 11 ('initializer'=11; tied with max_workers=11); verified with Python 3.14.3"]
    - [v4_eq,   "ThreadPoolExecutor.__init__.__code__.co_varnames[4].__eq__", ["initargs"],           true, "ThreadPoolExecutor.__init__ co_varnames[4] == 'initargs' (len=8); verified with Python 3.14.3"]
    - [v4_len,  "ThreadPoolExecutor.__init__.__code__.co_varnames[4].__len__", [],                    8,    "ThreadPoolExecutor.__init__ co_varnames[4].__len__() == 8 ('initargs'=8); verified with Python 3.14.3"]
    - [v5_eq,   "ThreadPoolExecutor.__init__.__code__.co_varnames[5].__eq__", ["ctxkwargs"],          true, "ThreadPoolExecutor.__init__ co_varnames[5] == 'ctxkwargs' (len=9; VAR_KEYWORD, not in co_argcount); verified with Python 3.14.3"]
    - [v5_len,  "ThreadPoolExecutor.__init__.__code__.co_varnames[5].__len__", [],                    9,    "ThreadPoolExecutor.__init__ co_varnames[5].__len__() == 9 ('ctxkwargs'=9; 1 more than initargs=8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.submit co_varnames element equality — extra117
#
# Wave 260 theme: ThreadPoolExecutor.submit co_varnames element equality.
#
# ThreadPoolExecutor.submit.__code__.co_varnames[1] == 'fn'     (len=2, shortest)
# ThreadPoolExecutor.submit.__code__.co_varnames[2] == 'args'   (len=4)
# ThreadPoolExecutor.submit.__code__.co_varnames[3] == 'kwargs' (len=6)
# ThreadPoolExecutor.submit.__code__.co_varnames.__len__() == 7 (most in spec)
# ---------------------------------------------------------------------------

table concurrent_futures_extra117.cf_tpe_submit_co_varnames:
  description: "concurrent.futures.ThreadPoolExecutor.submit co_varnames element equality checks in cftpe117 namespace — wave 260 theme: first element-level coverage of ThreadPoolExecutor.submit co_varnames; co_varnames==('self','fn','args','kwargs','f','task','w') len=7 (first coverage of submit co_varnames length; most co_varnames of the three methods in this spec: 7 > shutdown=5 > init=6... wait, init=6 < submit=7; actually submit=7 > init=6 > shutdown=5); co_varnames[1].__eq__('fn')==True (len=2: fn is the callable to execute in the thread pool; shortest parameter name in this spec; 'fn' is a common abbreviation for function); co_varnames[2].__eq__('args')==True (len=4: args is VAR_POSITIONAL — the positional arguments forwarded to fn; co_argcount==2 counts only self and fn; args and kwargs are not in co_argcount); co_varnames[3].__eq__('kwargs')==True (len=6: kwargs is VAR_KEYWORD — the keyword arguments forwarded to fn; 2 more than args=4); co_varnames[4].__eq__('f')==True (len=1: f is a local variable holding the Future returned by submit; shortest name in co_varnames); co_varnames[5].__eq__('task')==True (len=4: task is a local _WorkItem namedtuple); co_varnames[6].__eq__('w')==True (len=1: w is a local weakref.ref to the executor, used to detect if the executor was garbage collected); element length ordering: f==w=1 (tied, shortest locals) < fn=2 < self==args==task=4 (tied) < kwargs=6; submit co_varnames.__len__()==7 (most in spec); co_qualname=='ThreadPoolExecutor.submit' (len=25); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cftpe117a

  columns: [id, function, args, expected, description]
  rows:
    - [sv_len,  "ThreadPoolExecutor.submit.__code__.co_varnames.__len__",    [],          7,    "ThreadPoolExecutor.submit co_varnames.__len__() == 7 (most in spec; 'self','fn','args','kwargs','f','task','w'); verified with Python 3.14.3"]
    - [sv1_eq,  "ThreadPoolExecutor.submit.__code__.co_varnames[1].__eq__",  ["fn"],      true, "ThreadPoolExecutor.submit co_varnames[1] == 'fn' (len=2, shortest param; the callable to execute); verified with Python 3.14.3"]
    - [sv1_len, "ThreadPoolExecutor.submit.__code__.co_varnames[1].__len__", [],          2,    "ThreadPoolExecutor.submit co_varnames[1].__len__() == 2 ('fn'=2, shortest in spec); verified with Python 3.14.3"]
    - [sv2_eq,  "ThreadPoolExecutor.submit.__code__.co_varnames[2].__eq__",  ["args"],    true, "ThreadPoolExecutor.submit co_varnames[2] == 'args' (len=4; VAR_POSITIONAL args forwarded to fn); verified with Python 3.14.3"]
    - [sv2_len, "ThreadPoolExecutor.submit.__code__.co_varnames[2].__len__", [],          4,    "ThreadPoolExecutor.submit co_varnames[2].__len__() == 4 ('args'=4); verified with Python 3.14.3"]
    - [sv3_eq,  "ThreadPoolExecutor.submit.__code__.co_varnames[3].__eq__",  ["kwargs"],  true, "ThreadPoolExecutor.submit co_varnames[3] == 'kwargs' (len=6; VAR_KEYWORD forwarded to fn); verified with Python 3.14.3"]
    - [sv3_len, "ThreadPoolExecutor.submit.__code__.co_varnames[3].__len__", [],          6,    "ThreadPoolExecutor.submit co_varnames[3].__len__() == 6 ('kwargs'=6; 2 more than args=4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.shutdown co_varnames element equality — extra117
#
# Wave 260 theme: ThreadPoolExecutor.shutdown co_varnames element equality.
#
# ThreadPoolExecutor.shutdown.__code__.co_varnames[1] == 'wait'           (len=4)
# ThreadPoolExecutor.shutdown.__code__.co_varnames[2] == 'cancel_futures' (len=14, longest in shutdown)
# ThreadPoolExecutor.shutdown.__code__.co_varnames.__len__() == 5
# ThreadPoolExecutor.shutdown.__code__.co_qualname.__len__() == 27 (tied with __init__)
# ---------------------------------------------------------------------------

table concurrent_futures_extra117.cf_tpe_shutdown_co_varnames:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown co_varnames element equality checks in cftpe117 namespace — wave 260 theme: first element-level coverage of ThreadPoolExecutor.shutdown co_varnames; co_varnames==('self','wait','cancel_futures','work_item','t') len=5; co_varnames[1].__eq__('wait')==True (len=4: wait=True means shutdown() blocks until all futures are done; wait=False means return immediately; the default is True); co_varnames[2].__eq__('cancel_futures')==True (len=14: cancel_futures=True cancels all pending futures that have not started; added in Python 3.9; longest parameter name in shutdown at 14 chars and the longest non-prefix element in this table); co_varnames[3].__eq__('work_item')==True (len=9: work_item is a local variable iterating over pending _WorkItem objects in the queue when cancelling); co_varnames[4].__eq__('t')==True (len=1: t is a local variable for each worker thread, used to join threads during shutdown; shortest name in shutdown co_varnames); shutdown co_varnames.__len__()==5 (fewest of the three methods in this spec: 5 < init=6 < submit=7); shutdown co_qualname=='ThreadPoolExecutor.shutdown' (len=27: 'ThreadPoolExecutor.'=19+'shutdown'=8=27; tied with __init__ co_qualname len=27: 'ThreadPoolExecutor.'=19+'__init__'=8=27; both are 8-char suffixes); element length ordering: t=1 (shortest local) < wait=4 < work_item=9... wait, work_item=9 > cancel_futures=14... let me list: t=1 < self==wait=4 < work_item=9 < cancel_futures=14 (longest in shutdown); shutdown.__code__.co_argcount==3 (self, wait, cancel_futures are positional); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: cftpe117b

  columns: [id, function, args, expected, description]
  rows:
    - [shv_len,  "ThreadPoolExecutor.shutdown.__code__.co_varnames.__len__",    [],                   5,    "ThreadPoolExecutor.shutdown co_varnames.__len__() == 5 (fewest in spec: 5 < init=6 < submit=7); verified with Python 3.14.3"]
    - [shv1_eq,  "ThreadPoolExecutor.shutdown.__code__.co_varnames[1].__eq__",  ["wait"],             true, "ThreadPoolExecutor.shutdown co_varnames[1] == 'wait' (len=4; controls blocking behavior); verified with Python 3.14.3"]
    - [shv1_len, "ThreadPoolExecutor.shutdown.__code__.co_varnames[1].__len__", [],                   4,    "ThreadPoolExecutor.shutdown co_varnames[1].__len__() == 4 ('wait'=4); verified with Python 3.14.3"]
    - [shv2_eq,  "ThreadPoolExecutor.shutdown.__code__.co_varnames[2].__eq__",  ["cancel_futures"],   true, "ThreadPoolExecutor.shutdown co_varnames[2] == 'cancel_futures' (len=14, longest in shutdown co_varnames); verified with Python 3.14.3"]
    - [shv2_len, "ThreadPoolExecutor.shutdown.__code__.co_varnames[2].__len__", [],                   14,   "ThreadPoolExecutor.shutdown co_varnames[2].__len__() == 14 ('cancel_futures'=14, longest elem in table); verified with Python 3.14.3"]
    - [shv3_eq,  "ThreadPoolExecutor.shutdown.__code__.co_varnames[3].__eq__",  ["work_item"],        true, "ThreadPoolExecutor.shutdown co_varnames[3] == 'work_item' (len=9; local loop variable for pending work items); verified with Python 3.14.3"]
    - [shv3_len, "ThreadPoolExecutor.shutdown.__code__.co_varnames[3].__len__", [],                   9,    "ThreadPoolExecutor.shutdown co_varnames[3].__len__() == 9 ('work_item'=9); verified with Python 3.14.3"]
    - [shv4_eq,  "ThreadPoolExecutor.shutdown.__code__.co_varnames[4].__eq__",  ["t"],                true, "ThreadPoolExecutor.shutdown co_varnames[4] == 't' (len=1; local for thread join loop; shortest name in spec); verified with Python 3.14.3"]
    - [shv4_len, "ThreadPoolExecutor.shutdown.__code__.co_varnames[4].__len__", [],                   1,    "ThreadPoolExecutor.shutdown co_varnames[4].__len__() == 1 ('t'=1, shortest in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra117
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra117.tpe_init_v1_max_workers:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames[1].__eq__('max_workers') returns True — ThreadPoolExecutor.__init__ co_varnames[1]='max_workers' (len=11); co_varnames[0]='self'; co_varnames[1]='max_workers' is the first non-self parameter; max_workers determines the maximum number of threads in the pool; when None (the default), it is computed as min(32, os.cpu_count()+4) in Python 3.8+ (the formula changed in 3.14 to os.cpu_count()*5); ThreadPoolExecutor.__init__.__code__.co_varnames.__len__()==6 (covered in extra70); co_argcount==5 (all positional params except ctxkwargs which is VAR_KEYWORD); co_varnames[2]='thread_name_prefix' (len=18, longest param at index 2); compare: 'max_workers'=11 < 'thread_name_prefix'=18 (7 more: 'thread_name_prefix' has 18 chars including the underscore-separated prefix segment); 'max_workers'==len('initializer')==11 (tied at index 3); ThreadPoolExecutor.__init__.__code__.co_qualname=='ThreadPoolExecutor.__init__' (len=27); first standalone ThreadPoolExecutor.__init__ co_varnames[1] equality invariant in cftpe117 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "ThreadPoolExecutor.__init__.__code__.co_varnames[1].__eq__"
  args: ["max_workers"]
  expected: true

invariant concurrent_futures_extra117.tpe_init_v2_thread_name_prefix:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames[2].__eq__('thread_name_prefix') returns True — ThreadPoolExecutor.__init__ co_varnames[2]='thread_name_prefix' (len=18; the longest parameter name in this spec; 18 chars: 'thread'=6+'_'=1+'name'=4+'_'=1+'prefix'=6=18); thread_name_prefix is an optional string that is prepended to the name of each worker thread created by the pool (e.g., 'thread_name_prefix_0', 'thread_name_prefix_1', ...); useful for identifying threads in debuggers and profilers; ThreadPoolExecutor.__init__.__code__.co_varnames[2].__len__()==18; compare: 'thread_name_prefix'=18 (longest) > 'max_workers'=11 > 'initializer'=11 > 'ctxkwargs'=9 > 'initargs'=8 > 'self'=4; 'thread_name_prefix' is also the longest element among all co_varnames in this entire spec (across __init__, submit, and shutdown methods); ThreadPoolExecutor.__init__.__code__.co_qualname=='ThreadPoolExecutor.__init__' (len=27); first standalone ThreadPoolExecutor.__init__ co_varnames[2] equality invariant in cftpe117 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "ThreadPoolExecutor.__init__.__code__.co_varnames[2].__eq__"
  args: ["thread_name_prefix"]
  expected: true

invariant concurrent_futures_extra117.tpe_submit_co_varnames_len_7:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames.__len__() == 7 — co_varnames==('self','fn','args','kwargs','f','task','w'); 7 is the most co_varnames among the three methods in this spec (submit=7 > __init__=6 > shutdown=5); ThreadPoolExecutor.submit() submits a callable fn(*args, **kwargs) to run in the thread pool and returns a Future representing the execution; 'f' is the Future itself, 'task' is a _WorkItem namedtuple (callable, future, args, kwargs), 'w' is a weakref.ref to the executor; submit co_qualname=='ThreadPoolExecutor.submit' (len=25; 'ThreadPoolExecutor.'=19+'submit'=6=25; 2 shorter than __init__=27: 'submit'=6 vs '__init__'=8, diff=2); co_argcount==2 (self and fn; args and kwargs are VAR_POSITIONAL/VAR_KEYWORD so not counted); compare co_varnames lengths: shutdown=5 < __init__=6 < submit=7 (submit has the most locals: f, task, w add 3 locals on top of self, fn, args, kwargs); first standalone ThreadPoolExecutor.submit co_varnames length invariant in cftpe117 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "ThreadPoolExecutor.submit.__code__.co_varnames.__len__"
  args: []
  expected: 7

invariant concurrent_futures_extra117.tpe_shutdown_v2_cancel_futures:
  description: "concurrent.futures.ThreadPoolExecutor.shutdown.__code__.co_varnames[2].__eq__('cancel_futures') returns True — shutdown co_varnames[2]='cancel_futures' (len=14; the longest element in shutdown co_varnames; 14: 'cancel'=6+'_'=1+'futures'=7=14); cancel_futures was added in Python 3.9; when True it cancels all pending futures that have not yet started executing, and drains the work queue; when False (default) it waits for pending futures to complete before shutting down; ThreadPoolExecutor.shutdown.__code__.co_varnames[2].__len__()==14; compare: 'cancel_futures'=14 (longest in shutdown) > 'work_item'=9 > 'wait'==self=4 > 't'=1; compare with __init__ params: 'thread_name_prefix'=18 > 'cancel_futures'=14 (4 shorter); shutdown.__code__.co_qualname=='ThreadPoolExecutor.shutdown' (len=27; tied with __init__ co_qualname len=27); co_argcount==3 (self, wait, cancel_futures); first standalone ThreadPoolExecutor.shutdown co_varnames[2] equality invariant in cftpe117 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "ThreadPoolExecutor.shutdown.__code__.co_varnames[2].__eq__"
  args: ["cancel_futures"]
  expected: true

invariant concurrent_futures_extra117.tpe_submit_v1_fn:
  description: "concurrent.futures.ThreadPoolExecutor.submit.__code__.co_varnames[1].__eq__('fn') returns True — submit co_varnames[1]='fn' (len=2; the shortest parameter name in this spec at 2 chars; fn is the callable to execute asynchronously in the thread pool); ThreadPoolExecutor.submit(fn, *args, **kwargs) schedules fn(*args, **kwargs) for execution and returns a Future; 'fn' is the conventional abbreviation for a callable in concurrent.futures (compare: Executor.map also uses 'fn' as the first non-self parameter); submit co_varnames[1].__len__()==2 (tied with nothing — 'fn'=2 is the only 2-char element in this spec; shorter than all other parameter names); compare element lengths: 'fn'=2 < 'self'==args==wait=4 < 'kwargs'=6 < work_item=9... no wait: let me enumerate unique lengths: 'fn'=2, 'f'='w'='t'=1 are shorter, but 'fn' is the shortest param name (non-local); locals f=1, w=1, t=1 are single chars; 'fn' as a parameter (co_argcount position) is the shortest non-self parameter; ThreadPoolExecutor.submit.__code__.co_qualname=='ThreadPoolExecutor.submit' (len=25); first standalone ThreadPoolExecutor.submit co_varnames[1] equality invariant in cftpe117 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: "ThreadPoolExecutor.submit.__code__.co_varnames[1].__eq__"
  args: ["fn"]
  expected: true
