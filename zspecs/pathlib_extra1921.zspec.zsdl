spec: pathlib_extra1921
version: ">=3.9"
backend: python_module(pathlib)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "Wave 575 (_extra1921): __slots__, __abstractmethods__, __subclasshook__, __init_subclass__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "pathlib.PurePath defines __slots__ with a tuple of field names; all subclasses define __slots__ = () to participate in the slot layout without adding new slots."
    - "pathlib.Path.__slots__ == ('_info',) — one additional slot for the OS-specific path info object."
    - "pathlib.PurePosixPath.__slots__ == () — inherits all slots from PurePath."
    - "pathlib.PureWindowsPath.__slots__ == () — inherits all slots from PurePath."
    - "pathlib.PosixPath.__slots__ == () — inherits all slots from Path and PurePath."
    - "pathlib.WindowsPath.__slots__ == () — inherits all slots from Path and PurePath."
    - "None of the pathlib classes are abstract; __abstractmethods__ is absent from all their __dict__s."
    - "None of the pathlib classes define __subclasshook__ in their own __dict__."
    - "None of the pathlib classes define __init_subclass__ in their own __dict__."
    - "pathlib.WindowsPath exists as a class on macOS/Darwin but cannot be instantiated (raises NotImplementedError); its __dict__ is still introspectable."
  created_at: "2026-04-12"

error_model: python_exceptions

table pathlib_extra1921.slots_protocol:
  description: "pathlib types __slots__ dict-presence checks — all True, pathlib uses __slots__ throughout"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1921

  columns: [id, function, args, expected]
  rows:
    - ["pl1921001", "pathlib.PurePath.__dict__.__contains__", ["__slots__"], true]
    - ["pl1921002", "pathlib.PurePosixPath.__dict__.__contains__", ["__slots__"], true]
    - ["pl1921003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__slots__"], true]
    - ["pl1921004", "pathlib.Path.__dict__.__contains__", ["__slots__"], true]
    - ["pl1921005", "pathlib.PosixPath.__dict__.__contains__", ["__slots__"], true]
    - ["pl1921006", "pathlib.WindowsPath.__dict__.__contains__", ["__slots__"], true]

