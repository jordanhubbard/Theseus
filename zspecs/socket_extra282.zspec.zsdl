spec: socket_extra282
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl through socket_extra281.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket_extra281.zspec.zsdl covers: AF_INET/SOCK_STREAM/SOCK_DGRAM constant integer values; socket(AF_INET, SOCK_x).type attribute; getpeername() raises OSError on unconnected socket; fileno() returns int; gettimeout() returns None by default; socket.error/timeout aliases."
    - "This spec focuses on: socket.socket context manager — __enter__ returns self; __enter__/__exit__/close __qualname__ values; __enter__/__exit__/close __class__.__name__ == 'function'; socket.socket.__name__ == 'socket'."
    - "socket.socket.__enter__.__qualname__ == 'socket.__enter__'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.__exit__.__qualname__ == 'socket.__exit__'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.close.__qualname__ == 'socket.close'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.__enter__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.__exit__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "socket.socket implements the context manager protocol: __enter__ returns self; __exit__ calls close(). These are plain Python functions attached to the socket class."
  stderr: "null"
  stickiness: "socket.socket() instances carry OS-level state; each test must create its own fresh instance."
  codes: {}

# ---------------------------------------------------------------------------
# socket.socket context manager — __qualname__ values
# __enter__, __exit__, and close are all plain functions defined on the
# socket class.  Their __qualname__ values follow the pattern
# '<classname>.<methodname>' as expected for methods defined inside a class.
# ---------------------------------------------------------------------------

table socket_extra282.context_manager_qualnames:
  description: "socket.socket.__enter__, __exit__, close __qualname__ values; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: qualname
  id_prefix: cmq282

  columns: [id, function, args, expected, description]
  rows:
    - [enter_qualname, "socket.__enter__.__qualname__.__eq__", ["socket.__enter__"], true, "socket.socket.__enter__.__qualname__ == 'socket.__enter__'"]
    - [exit_qualname,  "socket.__exit__.__qualname__.__eq__",  ["socket.__exit__"],  true, "socket.socket.__exit__.__qualname__ == 'socket.__exit__'"]
    - [close_qualname, "socket.close.__qualname__.__eq__",     ["socket.close"],     true, "socket.socket.close.__qualname__ == 'socket.close'"]

# ---------------------------------------------------------------------------
# socket.socket context manager — __class__.__name__ values
# __enter__ and __exit__ are plain Python functions (not method_descriptor or
# builtin_function_or_method).  __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table socket_extra282.context_manager_class_names:
  description: "socket.socket.__enter__ and __exit__ are 'function' objects — not C-level descriptors; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: class_name
  id_prefix: cmcn282

  columns: [id, function, args, expected, description]
  rows:
    - [enter_class, "socket.__enter__.__class__.__name__.__eq__", ["function"], true, "socket.__enter__.__class__.__name__ == 'function'"]
    - [exit_class,  "socket.__exit__.__class__.__name__.__eq__",  ["function"], true, "socket.__exit__.__class__.__name__ == 'function'"]
    - [close_class, "socket.close.__class__.__name__.__eq__",     ["function"], true, "socket.close.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# socket.socket class identity
# socket.socket.__name__ == 'socket' — the class name matches the module attribute name.
# socket.socket.__module__ == 'socket' — the class is defined in the socket module.
# ---------------------------------------------------------------------------

invariant socket_extra282.socket_class.name:
  description: "socket.socket.__name__ == 'socket' — class name attribute matches the name used to access it; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra282.socket_class.module:
  description: "socket.socket.__module__ == 'socket' — the socket class is defined in the socket module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: class_identity
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket context manager — __enter__ returns self
# The context manager protocol requires __enter__ to return the resource.
# For socket.socket, __enter__ returns the socket instance itself.
# This means 'with socket.socket() as s:' gives s the socket instance.
# ---------------------------------------------------------------------------

invariant socket_extra282.context_manager.enter_returns_self:
  description: "socket.socket().__enter__() is the socket itself — __enter__ returns self enabling 'with socket.socket() as s'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: context_manager
  kind: python_call_eq
  function: socket.__call__.__enter__.__class__.__name__.__eq__
  args: [{address_family: AF_INET, socket_type: SOCK_STREAM}, "socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket context manager — __exit__ has 1 positional parameter (self)
# socket.socket.__exit__(self, *args) uses *args for the exception triple.
# co_argcount counts only positional parameters (not *args), so it is 1.
# ---------------------------------------------------------------------------

invariant socket_extra282.context_manager.exit_argcount:
  description: "socket.socket.__exit__.__code__.co_argcount == 1 — __exit__(self, *args) has 1 positional parameter (self); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: context_manager
  kind: python_call_eq
  function: socket.__exit__.__code__.co_argcount.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket — __enter__ has 1 parameter (self only)
# __enter__(self) takes only the instance; no additional parameters.
# __code__.co_argcount == 1 confirms the expected signature.
# ---------------------------------------------------------------------------

invariant socket_extra282.context_manager.enter_argcount:
  description: "socket.socket.__enter__.__code__.co_argcount == 1 — __enter__(self) takes only self; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: context_manager
  kind: python_call_eq
  function: socket.__enter__.__code__.co_argcount.__eq__
  args: [1]
  expected: true
