  function: name.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra3.category.module:
  description: "unicodedata.category.__module__ == 'unicodedata'"
  category: module_identity
  kind: python_call_eq
  function: category.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra3.normalize.module:
  description: "unicodedata.normalize.__module__ == 'unicodedata'"
  category: module_identity
  kind: python_call_eq
  function: normalize.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra3.decomposition.module:
  description: "unicodedata.decomposition.__module__ == 'unicodedata'"
  category: module_identity
  kind: python_call_eq
  function: decomposition.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra3.bidirectional.module:
  description: "unicodedata.bidirectional.__module__ == 'unicodedata'"
  category: module_identity
  kind: python_call_eq
  function: bidirectional.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra3.combining.module:
  description: "unicodedata.combining.__module__ == 'unicodedata'"
  category: module_identity
  kind: python_call_eq
  function: combining.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra3.east_asian_width.module:
  description: "unicodedata.east_asian_width.__module__ == 'unicodedata'"
  category: module_identity
  kind: python_call_eq
  function: east_asian_width.__module__.__eq__
  args: ["unicodedata"]
  expected: true

# ---------------------------------------------------------------------------
# unidata_version — module-level string attribute type check (new ID)
# unicodedata_extra already covers this; new ID adds coverage under extra3 namespace
# ---------------------------------------------------------------------------

invariant unicodedata_extra3.unidata_version.class_name:
  description: "unicodedata.unidata_version.__class__.__name__ == 'str'"
  category: version
  kind: python_call_eq
  function: unidata_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# ucd_3_2_0 — module-level UCD object providing Unicode 3.2.0 compatibility data
# unicodedata.ucd_3_2_0 is an instance of the internal UCD class
# ---------------------------------------------------------------------------

invariant unicodedata_extra3.ucd_3_2_0.class_name:
  description: "unicodedata.ucd_3_2_0.__class__.__name__ == 'UCD'"
  category: ucd_object
  kind: python_call_eq
  function: ucd_3_2_0.__class__.__name__.__eq__
  args: ["UCD"]
  expected: true

# ---------------------------------------------------------------------------
# name('A') — confirmed with unique ID; orthogonal to unicodedata_extra invariant
# ---------------------------------------------------------------------------

invariant unicodedata_extra3.name.capital_a:
  description: "unicodedata.name('A') == 'LATIN CAPITAL LETTER A'"
  category: name
  kind: python_call_eq
  function: name
  args: ["A"]
  expected: "LATIN CAPITAL LETTER A"
