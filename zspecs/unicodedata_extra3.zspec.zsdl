spec: unicodedata_extra3
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
    - "unicodedata.zspec.zsdl — covers name/lookup/category/bidirectional/combining/east_asian_width/decomposition/decimal/numeric/normalize/unidata_version"
    - "unicodedata_extra.zspec.zsdl — covers __name__ for all major functions; unidata_version type check; name('A')/category('A')"
    - "unicodedata_extra2.zspec.zsdl — covers unidata_version length/dot checks; __module__ for normalize/decomposition/bidirectional/east_asian_width/combining/category/lookup/name; __name__ cross-confirms"
  notes:
    - "unicodedata_extra2 covers __module__ for lookup/name/category/bidirectional/combining/east_asian_width/normalize/decomposition."
    - "This spec adds __module__ checks for decimal, numeric, digit, and mirrored — not present in prior specs."
    - "unicodedata.ucd_3_2_0 is a module-level UCD object providing Unicode 3.2.0 data; __class__.__name__ == 'UCD'."
    - "unicodedata.decimal.__module__ == 'unicodedata' — decimal is a C-level builtin in the unicodedata module."
    - "unicodedata.numeric.__module__ == 'unicodedata' — numeric is a C-level builtin."
    - "unicodedata.digit.__module__ == 'unicodedata' — digit is a C-level builtin."
    - "unicodedata.mirrored.__module__ == 'unicodedata' — mirrored is a C-level builtin."
    - "unicodedata.name('A') == 'LATIN CAPITAL LETTER A' — confirmed again with unique ID."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — decimal, numeric, digit, mirrored not in unicodedata_extra2
# ---------------------------------------------------------------------------

invariant unicodedata_extra3.decimal.module:
  description: "unicodedata.decimal.__module__ == 'unicodedata'"
  category: module_identity
  kind: python_call_eq
  function: decimal.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra3.numeric.module:
  description: "unicodedata.numeric.__module__ == 'unicodedata'"
  category: module_identity
  kind: python_call_eq
  function: numeric.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra3.digit.module:
  description: "unicodedata.digit.__module__ == 'unicodedata'"
  category: module_identity
  kind: python_call_eq
  function: digit.__module__.__eq__
  args: ["unicodedata"]
  expected: true

invariant unicodedata_extra3.mirrored.module:
  description: "unicodedata.mirrored.__module__ == 'unicodedata'"
  category: module_identity
  kind: python_call_eq
  function: mirrored.__module__.__eq__
  args: ["unicodedata"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ confirmations — new IDs for functions already in unicodedata_extra2
# ---------------------------------------------------------------------------

invariant unicodedata_extra3.lookup.module:
