spec: decimal_extra282
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Decimal class arithmetic and comparison dunder methods"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c, Lib/_pydecimal.py"
  notes:
    - "Decimal is implemented in C via _decimal extension; __qualname__ of dunder methods follows 'Decimal.__method__' pattern"
    - "decimal.Decimal.__bases__[0].__name__ == 'object'"
    - "decimal.Decimal.__doc__ is a non-empty str"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table decimal_extra282.arithmetic_qualnames:
  description: "Decimal arithmetic dunder method qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: dec282a

  columns: [id, function, args, expected, description]
  rows:
    - [dec282a001, decimal.Decimal.__add__.__qualname__, [], "Decimal.__add__", "Decimal.__add__ qualname"]
    - [dec282a002, decimal.Decimal.__sub__.__qualname__, [], "Decimal.__sub__", "Decimal.__sub__ qualname"]
    - [dec282a003, decimal.Decimal.__mul__.__qualname__, [], "Decimal.__mul__", "Decimal.__mul__ qualname"]
    - [dec282a004, decimal.Decimal.__truediv__.__qualname__, [], "Decimal.__truediv__", "Decimal.__truediv__ qualname"]
    - [dec282a005, decimal.Decimal.__neg__.__qualname__, [], "Decimal.__neg__", "Decimal.__neg__ qualname"]
    - [dec282a006, decimal.Decimal.__abs__.__qualname__, [], "Decimal.__abs__", "Decimal.__abs__ qualname"]
    - [dec282a007, decimal.Decimal.__bool__.__qualname__, [], "Decimal.__bool__", "Decimal.__bool__ qualname"]

table decimal_extra282.comparison_qualnames:
  description: "Decimal comparison dunder method qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: dec282b

  columns: [id, function, args, expected, description]
  rows:
    - [dec282b001, decimal.Decimal.__eq__.__qualname__, [], "Decimal.__eq__", "Decimal.__eq__ qualname"]
    - [dec282b002, decimal.Decimal.__lt__.__qualname__, [], "Decimal.__lt__", "Decimal.__lt__ qualname"]
    - [dec282b003, decimal.Decimal.__le__.__qualname__, [], "Decimal.__le__", "Decimal.__le__ qualname"]
    - [dec282b004, decimal.Decimal.__gt__.__qualname__, [], "Decimal.__gt__", "Decimal.__gt__ qualname"]
    - [dec282b005, decimal.Decimal.__ge__.__qualname__, [], "Decimal.__ge__", "Decimal.__ge__ qualname"]

invariant decimal_extra282.decimal_name:
  description: "decimal.Decimal.__name__ is 'Decimal'"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra282.decimal_module:
  description: "decimal.Decimal.__module__ is 'decimal'"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra282.decimal_base_class:
  description: "decimal.Decimal base class is object"
  category: identity
  kind: python_call_eq
  function: "decimal.Decimal.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra282.decimal_doc_class:
  description: "decimal.Decimal.__doc__ is a str"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
