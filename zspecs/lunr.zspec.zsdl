spec: lunr
version: ">=2.0.0"
backend: node(lunr)

docs: https://lunrjs.com/

provenance:
  derived_from:
    - "Lunr documentation — https://lunrjs.com/"
    - "Test vectors verified with lunr via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "lunr source"
  notes:
    - "Lunr is a small full-text search index for JS — used by docs sites, mkdocs-mit, etc."
    - "Install: npm install lunr"
    - "Building an index requires a builder callback (function arg), which the chain primitive can't pass; we test the pipeline-stage helpers (tokenizer, stemmer, trimmer) and version metadata that DON'T need a builder."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# Version metadata
invariant lunr.version_starts_with_2:
  description: "lunr.version starts with '2.' (current major)"
  category: version
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: version}
    - {method: startsWith, args: ["2."]}
  expected: true

# tokenizer(string) returns array of Token objects
invariant lunr.tokenizer_two_words:
  description: "tokenizer('hello world') yields 2 tokens"
  category: tokenizer
  kind: node_chain_eq
  entry: named
  function: tokenizer
  entry_args: ["hello world"]
  chain:
    - {get: length}
  expected: 2

invariant lunr.tokenizer_first_value:
  description: "First token's string form is 'hello'"
  category: tokenizer
  kind: node_chain_eq
  entry: named
  function: tokenizer
  entry_args: ["hello world"]
  chain:
    - {method: at, args: [0]}
    - {method: toString, args: []}
  expected: "hello"

invariant lunr.tokenizer_second_value:
  description: "Second token's string form is 'world'"
  category: tokenizer
  kind: node_chain_eq
  entry: named
  function: tokenizer
  entry_args: ["hello world"]
  chain:
    - {method: at, args: [1]}
    - {method: toString, args: []}
  expected: "world"

invariant lunr.tokenizer_empty_string_zero_tokens:
  description: "tokenizer('') yields 0 tokens"
  category: tokenizer
  kind: node_chain_eq
  entry: named
  function: tokenizer
  entry_args: [""]
  chain:
    - {get: length}
  expected: 0

invariant lunr.tokenizer_lowercases:
  description: "tokenizer('Hello World') normalises tokens to lowercase"
  category: tokenizer
  kind: node_chain_eq
  entry: named
  function: tokenizer
  entry_args: ["Hello World"]
  chain:
    - {method: at, args: [0]}
    - {method: toString, args: []}
  expected: "hello"

invariant lunr.tokenizer_keeps_punctuation_in_token:
  description: "tokenizer('foo,bar') treats punctuation as part of one token (only whitespace splits)"
  category: tokenizer
  kind: node_chain_eq
  entry: named
  function: tokenizer
  entry_args: ["foo,bar"]
  chain:
    - {get: length}
  expected: 1

# Note: stemmer/trimmer pipeline stages take lunr.Token instances, which
# can't be constructed from JSON spec args; they are exercised through the
# tokenizer chain above and not directly.

