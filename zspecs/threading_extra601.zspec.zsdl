spec: threading_extra601
version: ">=3.9"
backend: python_module(threading)
docs: "threading.Thread property descriptors and method qualname identity, plus threading.Barrier method and property identity"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers Thread property descriptor class names, Thread method qualnames, and Barrier method/property identity"
  created_at: "2026-04-12T00:00:00Z"

table threading_extra601.th601th:
  id_prefix: th601th

  columns: [id, function, args, expected]
  rows:
    - [th601th01, threading.Thread.name.__class__.__name__.__eq__, ["property"], true]
    - [th601th02, threading.Thread.daemon.__class__.__name__.__eq__, ["property"], true]
    - [th601th03, threading.Thread.ident.__class__.__name__.__eq__, ["property"], true]
    - [th601th04, threading.Thread.native_id.__class__.__name__.__eq__, ["property"], true]
    - [th601th05, threading.Thread.is_alive.__qualname__.__eq__, ["Thread.is_alive"], true]
    - [th601th06, threading.Thread.start.__qualname__.__eq__, ["Thread.start"], true]
    - [th601th07, threading.Thread.run.__qualname__.__eq__, ["Thread.run"], true]
    - [th601th08, threading.Thread.join.__qualname__.__eq__, ["Thread.join"], true]

table threading_extra601.th601br:
  id_prefix: th601br

  columns: [id, function, args, expected]
  rows:
    - [th601br01, threading.Barrier.wait.__qualname__.__eq__, ["Barrier.wait"], true]
    - [th601br02, threading.Barrier.reset.__qualname__.__eq__, ["Barrier.reset"], true]
    - [th601br03, threading.Barrier.abort.__qualname__.__eq__, ["Barrier.abort"], true]
    - [th601br04, threading.Barrier.parties.__class__.__name__.__eq__, ["property"], true]
    - [th601br05, threading.Barrier.n_waiting.__class__.__name__.__eq__, ["property"], true]
    - [th601br06, threading.Barrier.broken.__class__.__name__.__eq__, ["property"], true]
