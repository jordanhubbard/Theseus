spec: nntplib
version: ">=3.9,<3.13"
backend: python_module(nntplib)

docs: https://docs.python.org/3.11/library/nntplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3.11/library/nntplib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "nntplib source: Lib/nntplib.py (PSF; source inspection permitted)"
  not_derived_from:
    - "nntplib source: internal socket/SSL connection details"
  notes:
    - "nntplib was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13."
    - "nntplib.NNTP is the primary client class for the NNTP protocol (RFC 3977)."
    - "NNTP.port == 119 is the well-known NNTP port."
    - "NNTPError is the base exception; all other NNTP exceptions derive from it."
    - "NNTPReplyError: unexpected reply code; NNTPTemporaryError: 4xx codes; NNTPPermanentError: 5xx codes."
    - "NNTPProtocolError: response not conforming to spec; NNTPDataError: error in data received."
    - "GroupInfo and ArticleInfo are named tuples used for group and article metadata."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "NNTPError is the base class for all nntplib exceptions. NNTPReplyError, NNTPTemporaryError, NNTPPermanentError, NNTPProtocolError, and NNTPDataError all inherit from NNTPError. NNTPError itself inherits from Exception."
  stderr: "null"
  stickiness: "N/A — each NNTP connection instance is independent."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks — core classes and named tuples
# ---------------------------------------------------------------------------

table nntplib.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [NNTP,                NNTP.__name__.__eq__,                ["NNTP"],                true]
    - [NNTPError,           NNTPError.__name__.__eq__,           ["NNTPError"],           true]
    - [NNTPReplyError,      NNTPReplyError.__name__.__eq__,      ["NNTPReplyError"],      true]
    - [NNTPTemporaryError,  NNTPTemporaryError.__name__.__eq__,  ["NNTPTemporaryError"],  true]
    - [NNTPPermanentError,  NNTPPermanentError.__name__.__eq__,  ["NNTPPermanentError"],  true]
    - [NNTPProtocolError,   NNTPProtocolError.__name__.__eq__,   ["NNTPProtocolError"],   true]
    - [NNTPDataError,       NNTPDataError.__name__.__eq__,       ["NNTPDataError"],       true]
    - [GroupInfo,           GroupInfo.__name__.__eq__,           ["GroupInfo"],           true]
    - [ArticleInfo,         ArticleInfo.__name__.__eq__,         ["ArticleInfo"],         true]

# ---------------------------------------------------------------------------
# Module check — NNTP class lives in nntplib
# ---------------------------------------------------------------------------

invariant nntplib.NNTP.module:
  description: "nntplib.NNTP.__module__ == 'nntplib'"
  category: modules
  kind: python_call_eq
  function: NNTP.__module__.__eq__
  args: ["nntplib"]
  expected: true

# ---------------------------------------------------------------------------
# Port constant — NNTP.port == 119
# ---------------------------------------------------------------------------

invariant nntplib.NNTP.port:
  description: "nntplib.NNTP.port == 119 — well-known NNTP port"
  category: constants
  kind: python_call_eq
  function: NNTP.port.__eq__
  args: [119]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — inheritance chain
# ---------------------------------------------------------------------------

invariant nntplib.NNTPError.base_is_Exception:
  description: "nntplib.NNTPError.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: NNTPError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

invariant nntplib.NNTPReplyError.base_is_NNTPError:
  description: "nntplib.NNTPReplyError.__bases__[0].__name__ == 'NNTPError'"
  category: exceptions
  kind: python_call_eq
  function: NNTPReplyError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "NNTPError"

invariant nntplib.NNTPTemporaryError.base_is_NNTPError:
  description: "nntplib.NNTPTemporaryError.__bases__[0].__name__ == 'NNTPError'"
  category: exceptions
  kind: python_call_eq
  function: NNTPTemporaryError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "NNTPError"

invariant nntplib.NNTPPermanentError.base_is_NNTPError:
  description: "nntplib.NNTPPermanentError.__bases__[0].__name__ == 'NNTPError'"
  category: exceptions
  kind: python_call_eq
  function: NNTPPermanentError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "NNTPError"

invariant nntplib.NNTPProtocolError.base_is_NNTPError:
  description: "nntplib.NNTPProtocolError.__bases__[0].__name__ == 'NNTPError'"
  category: exceptions
  kind: python_call_eq
  function: NNTPProtocolError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "NNTPError"

invariant nntplib.NNTPDataError.base_is_NNTPError:
  description: "nntplib.NNTPDataError.__bases__[0].__name__ == 'NNTPError'"
  category: exceptions
  kind: python_call_eq
  function: NNTPDataError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "NNTPError"
