spec: dis_extra20
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "dis_extra19.zspec.zsdl — covers stack_effect/pretty_flags/print_instructions __qualname__; Positions/ArgResolver/Formatter __qualname__ and __bases__; get_instructions/__qualname__.__len__()=16; Bytecode/__qualname__.__len__()=8; Instruction/__qualname__.__len__()=11"
    - "dis_extra18.zspec.zsdl — covers distb/code_info/show_code __qualname__ and __module__; Bytecode/__name__; Instruction __bases__[0].__name__"
    - "dis_extra17.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/findlabels __name__ and __module__; Instruction/__name__"
    - "dis_extra16.zspec.zsdl — covers Bytecode/__module__; Instruction/__module__; class_qualnames table"
    - "dis_extra15.zspec.zsdl — covers Bytecode/__qualname__; Instruction/__qualname__; function_modules table"
  notes:
    - "This spec extends dis_extra19.zspec.zsdl."
    - "Focus: __qualname__.__len__() for dis functions not yet measured: dis, disassemble, findlinestarts, findlabels, stack_effect, pretty_flags."
    - "dis.dis.__qualname__.__len__() == 3; dis.disassemble.__qualname__.__len__() == 11."
    - "dis.findlinestarts.__qualname__.__len__() == 14; dis.findlabels.__qualname__.__len__() == 10."
    - "dis.stack_effect.__qualname__.__len__() == 12; dis.pretty_flags.__qualname__.__len__() == 12."
    - "dis_extra19 covers get_instructions.__qualname__.__len__()=16, Bytecode.__qualname__.__len__()=8, Instruction.__qualname__.__len__()=11 — those are not repeated here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__.__len__() — dis, disassemble, findlinestarts, findlabels
# (dis_extra20 namespace)
#
# dis_extra17 covers dis/disassemble/get_instructions/findlinestarts/findlabels
# __name__ (via table); dis_extra19 covers get_instructions.__qualname__.__len__().
# The remaining core functions — dis, disassemble, findlinestarts, findlabels —
# have not had their __qualname__.__len__() measured in any prior dis spec.
# ---------------------------------------------------------------------------

table dis_extra20.core_function_qualname_lens:
  description: "__qualname__.__len__() for core dis module functions"
  kind: python_call_eq
  category: function_qualname_lengths
  id_prefix: corefqlen

  columns: [id, function, args, expected]
  rows:
    - [dis,           dis.__qualname__.__len__,           [], 3]
    - [disassemble,   disassemble.__qualname__.__len__,   [], 11]
    - [findlinestarts, findlinestarts.__qualname__.__len__, [], 14]
    - [findlabels,    findlabels.__qualname__.__len__,    [], 10]

# ---------------------------------------------------------------------------
# Function __qualname__.__len__() — stack_effect, pretty_flags
# (dis_extra20 namespace)
#
# dis_extra19 covers stack_effect/__qualname__.__eq__ and pretty_flags/__qualname__.__eq__
# in a table. No prior dis spec measures their __qualname__.__len__() individually.
# Both qualnames happen to be 12 characters long.
# ---------------------------------------------------------------------------

invariant dis_extra20.stack_effect.qualname_len:
  description: "dis.stack_effect.__qualname__.__len__() == 12 — qualname 'stack_effect' has 12 characters"
  category: function_qualname_lengths
  kind: python_call_eq
  function: stack_effect.__qualname__.__len__
  args: []
  expected: 12

invariant dis_extra20.pretty_flags.qualname_len:
  description: "dis.pretty_flags.__qualname__.__len__() == 12 — qualname 'pretty_flags' has 12 characters"
  category: function_qualname_lengths
  kind: python_call_eq
  function: pretty_flags.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# print_instructions __qualname__.__len__()
# (dis_extra20 namespace)
#
# dis_extra19 covers print_instructions/__qualname__.__eq__; no prior dis spec
# covers its length. 'print_instructions' has 18 characters.
# ---------------------------------------------------------------------------

invariant dis_extra20.print_instructions.qualname_len:
  description: "dis.print_instructions.__qualname__.__len__() == 18 — qualname 'print_instructions' has 18 characters"
  category: function_qualname_lengths
  kind: python_call_eq
  function: print_instructions.__qualname__.__len__
  args: []
  expected: 18
