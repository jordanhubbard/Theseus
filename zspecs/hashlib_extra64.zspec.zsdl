spec: hashlib_extra64
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra63.zspec.zsdl — covers blake2b/blake2s method descriptor __qualname__.__eq__ string values for update/digest/hexdigest/copy (blake2b) and update/digest/hexdigest (blake2s)."
    - "hashlib_extra62.zspec.zsdl — covers hashlib.__spec__.origin.__class__.__name__.__eq__('str') / __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') / __spec__.has_location==True / __loader__.__class__.__name__.__len__()==16 (table + invariants)."
    - "hashlib_extra61.zspec.zsdl — covers hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "hashlib_extra60.zspec.zsdl — covers hashlib.__all__.__contains__ for sha256/sha1/sha512/sha3_256 (table); blake2b/blake2s/md5/sha1 __doc__.__class__.__qualname__.__eq__('str'); __all__.__contains__('algorithms_guaranteed') (invariant)."
    - "hashlib_extra52.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __doc__.__class__.__name__.__eq__('str'); sha256/new/module __doc__.__class__.__qualname__.__eq__('str')."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra63; it does NOT duplicate invariants present in those files."
    - "Wave 228 theme: __annotations__ class identity + __globals__ dict keys + __doc__.__contains__ content checks."
    - "hashlib.new is a pure Python function defined in Lib/hashlib.py. As such it has __annotations__ (an empty dict) and __globals__ (the hashlib module namespace). No prior hashlib spec checks new.__annotations__ or new.__globals__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__annotations__ == {} (empty dict). hashlib.new is defined in Python without type annotations. The __annotations__ attribute exists and is a dict, but contains no entries. No prior hashlib spec checks new.__annotations__.__class__.__name__.__eq__('dict') or new.__annotations__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest is also a pure Python function in Lib/hashlib.py with empty __annotations__. hashlib.pbkdf2_hmac is a C builtin_function_or_method with NO __annotations__ attribute (AttributeError). No prior hashlib spec checks file_digest.__annotations__.__class__.__name__.__eq__('dict'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__globals__ is the hashlib module's global namespace dict. It contains 'new' (the function itself), 'pbkdf2_hmac', 'file_digest', 'algorithms_guaranteed', and many other hashlib module-level names. No prior hashlib spec checks new.__globals__.__class__.__name__.__eq__('dict') or new.__globals__.__contains__('new'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__doc__ == 'Return a new BLAKE2b hash object.' (a short C extension type docstring). The string contains 'BLAKE2b' — specifically the uppercase BLAKE2 prefix with lowercase b suffix. hashlib_extra52/extra60 check blake2b.__doc__.__class__.__name__.__eq__('str') and __doc__.__class__.__qualname__.__eq__('str') respectively, but no prior hashlib spec checks blake2b.__doc__.__contains__('BLAKE2b'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new and file_digest __annotations__ class identity
#
# Wave 228 theme: __annotations__ class identity checks.
#
# hashlib.new and hashlib.file_digest are pure Python functions defined in
# Lib/hashlib.py. Both have __annotations__ attributes that are empty dicts.
# hashlib.pbkdf2_hmac is a C builtin_function_or_method and does NOT have
# __annotations__ — it is omitted from this table.
#
# No prior hashlib spec checks __annotations__.__class__.__name__.__eq__('dict')
# or __annotations__.__len__() for any hashlib function. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra64.python_func_annotations_class_name:
  description: "hashlib.new and file_digest __annotations__.__class__.__name__.__eq__('dict') — both are pure Python functions in Lib/hashlib.py with empty dict annotations; pbkdf2_hmac is C and excluded; no prior hashlib spec checks __annotations__.__class__.__name__.__eq__('dict') for any hashlib function"
  kind: python_call_eq
  category: annotations
  id_prefix: hashlibann64

  columns: [id, function, args, expected]
  rows:
    - [new_annotations_class_name_eq,          new.__annotations__.__class__.__name__.__eq__,          ["dict"], true]
    - [file_digest_annotations_class_name_eq,   file_digest.__annotations__.__class__.__name__.__eq__,  ["dict"], true]

# ---------------------------------------------------------------------------
# hashlib.new __annotations__ emptiness
#
# Both hashlib.new and hashlib.file_digest have zero-entry __annotations__
# dicts — no parameter or return annotations. The __len__() == 0 confirms the
# dict is empty (no type annotations present). No prior hashlib spec checks
# __annotations__.__len__() for any hashlib function. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table hashlib_extra64.python_func_annotations_len:
  description: "hashlib.new and file_digest __annotations__.__len__()==0 — empty annotation dicts; Python functions in Lib/hashlib.py define no type annotations; no prior hashlib spec checks __annotations__.__len__() for any hashlib function"
  kind: python_call_eq
  category: annotations
  id_prefix: hashlibann64

  columns: [id, function, args, expected]
  rows:
    - [new_annotations_len,         new.__annotations__.__len__,         [], 0]
    - [file_digest_annotations_len, file_digest.__annotations__.__len__, [], 0]

# ---------------------------------------------------------------------------
# hashlib.new __globals__ class identity and key membership
#
# Wave 228 theme: __globals__ dict keys.
#
# hashlib.new.__globals__ is the hashlib module's global namespace dict.
# It is a dict (class name 'dict') and contains the key 'new' (the function
# binds its own name in the module namespace). No prior hashlib spec checks
# new.__globals__.__class__.__name__.__eq__('dict') or
# new.__globals__.__contains__('new'). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra64.new_globals_class_and_contains:
  description: "hashlib.new.__globals__.__class__.__name__.__eq__('dict') and __contains__('new') — new.__globals__ is the hashlib module namespace dict; 'new' is present as a top-level name; no prior hashlib spec checks new.__globals__ in any form"
  kind: python_call_eq
  category: globals
  id_prefix: hashlibann64

  columns: [id, function, args, expected]
  rows:
    - [new_globals_class_name_eq, new.__globals__.__class__.__name__.__eq__, ["dict"], true]
    - [new_globals_contains_new,  new.__globals__.__contains__,              ["new"],  true]

# ---------------------------------------------------------------------------
# hashlib.blake2b __doc__ content check
#
# Wave 228 theme: __doc__.__contains__ content checks.
#
# hashlib.blake2b.__doc__ == 'Return a new BLAKE2b hash object.' The string
# 'BLAKE2b' appears in the docstring (with uppercase BLAKE2 and lowercase b).
# hashlib_extra52 checks blake2b.__doc__.__class__.__name__.__eq__('str')
# (type identity axis); hashlib_extra60 checks __doc__.__class__.__qualname__.__eq__('str')
# (qualname axis). No prior hashlib spec checks blake2b.__doc__.__contains__
# for any keyword. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra64.blake2b_doc_contains:
  description: "hashlib.blake2b.__doc__.__contains__('BLAKE2b') — C extension type docstring is 'Return a new BLAKE2b hash object.'; hashlib_extra52/extra60 check __doc__ class identity axes; no prior hashlib spec checks blake2b.__doc__.__contains__ for any keyword; first doc content check for blake2b"
  kind: python_call_eq
  category: docstrings
  id_prefix: hashlibann64

  columns: [id, function, args, expected]
  rows:
    - [blake2b_doc_contains_BLAKE2b, blake2b.__doc__.__contains__, ["BLAKE2b"], true]

# ---------------------------------------------------------------------------
# hashlib.new.__annotations__.__class__.__name__.__eq__('dict') — standalone
#
# hashlib.new is the primary Python wrapper for creating new hash objects in
# Lib/hashlib.py. Its __annotations__ attribute is an empty dict — the function
# defines no type annotations. The attribute chain
# __annotations__.__class__.__name__.__eq__('dict') confirms the dict type
# identity of the annotations object. No prior hashlib spec checks new.__annotations__
# in any form (neither __class__.__name__ nor __len__). First annotations anchor
# for any hashlib function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra64.new_annotations_class_name_dict:
  description: "hashlib.new.__annotations__.__class__.__name__.__eq__('dict') == True — hashlib.new is a pure Python function in Lib/hashlib.py; __annotations__ is an empty dict with no type annotations; no prior hashlib spec checks new.__annotations__.__class__.__name__.__eq__('dict'); first __annotations__ class identity anchor for any hashlib function"
  category: annotations
  kind: python_call_eq
  function: new.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__globals__.__contains__('new') — standalone
#
# hashlib.new.__globals__ is the hashlib module's global namespace dict.
# The key 'new' is present in that namespace (the function is bound there).
# This is the first check confirming a specific key membership in
# hashlib.new.__globals__. No prior hashlib spec checks __globals__.__contains__
# for any hashlib function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra64.new_globals_contains_new_key:
  description: "hashlib.new.__globals__.__contains__('new') == True — hashlib.new.__globals__ is the hashlib module namespace dict; 'new' is present as a top-level name confirming the function is bound in its defining module; no prior hashlib spec checks __globals__.__contains__ for any hashlib function; first globals membership anchor for hashlib"
  category: globals
  kind: python_call_eq
  function: new.__globals__.__contains__
  args: ["new"]
  expected: true
