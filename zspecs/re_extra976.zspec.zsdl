spec: re_extra976
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module Pattern and Match documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.Pattern and re.Match method __qualname__ identity for core regex interface methods"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra976.pattern_match_qualnames:
  description: "re.Pattern match-family method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: re976p
  columns: [id, function, args, expected]
  rows:
    - [re976p001, re.Pattern.match.__qualname__.__eq__,      ["Pattern.match"],      true]
    - [re976p002, re.Pattern.search.__qualname__.__eq__,     ["Pattern.search"],     true]
    - [re976p003, re.Pattern.fullmatch.__qualname__.__eq__,  ["Pattern.fullmatch"],  true]
    - [re976p004, re.Pattern.findall.__qualname__.__eq__,    ["Pattern.findall"],    true]
    - [re976p005, re.Pattern.finditer.__qualname__.__eq__,   ["Pattern.finditer"],   true]

table re_extra976.pattern_sub_qualnames:
  description: "re.Pattern substitution and split method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: re976s
  columns: [id, function, args, expected]
  rows:
    - [re976s001, re.Pattern.sub.__qualname__.__eq__,   ["Pattern.sub"],   true]
    - [re976s002, re.Pattern.subn.__qualname__.__eq__,  ["Pattern.subn"],  true]
    - [re976s003, re.Pattern.split.__qualname__.__eq__, ["Pattern.split"], true]

table re_extra976.match_group_qualnames:
  description: "re.Match group-extraction method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: re976g
  columns: [id, function, args, expected]
  rows:
    - [re976g001, re.Match.group.__qualname__.__eq__,   ["Match.group"],   true]
    - [re976g002, re.Match.groups.__qualname__.__eq__,  ["Match.groups"],  true]
    - [re976g003, re.Match.groupdict.__qualname__.__eq__, ["Match.groupdict"], true]
    - [re976g004, re.Match.start.__qualname__.__eq__,   ["Match.start"],   true]
    - [re976g005, re.Match.end.__qualname__.__eq__,     ["Match.end"],     true]
    - [re976g006, re.Match.span.__qualname__.__eq__,    ["Match.span"],    true]

table re_extra976.pattern_module_identity:
  description: "re.Pattern and re.Match class-level module identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: re976m
  columns: [id, function, args, expected]
  rows:
    - [re976m001, re.Pattern.__class__.__name__.__eq__, ["type"],    true]
    - [re976m002, re.Match.__class__.__name__.__eq__,   ["type"],    true]
    - [re976m003, re.Pattern.__name__.__eq__,           ["Pattern"], true]
    - [re976m004, re.Match.__name__.__eq__,             ["Match"],   true]
