spec: struct_extra241
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 struct module on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl, struct_extra.zspec.zsdl, struct_extra2.zspec.zsdl, and struct_extra3.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "struct.zspec.zsdl covers: pack/unpack vectors for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize for H/I/Q/HI/HIQ/q/h/b/?/e; roundtrip and error cases."
    - "struct_extra.zspec.zsdl covers: Struct format/size attrs, calcsize for f/d/B/4s/>BHI, pack_into name, unpack_from with offset, iter_unpack, error class name/bases."
    - "struct_extra2.zspec.zsdl covers: pack/unpack for >I/>H/<I/>4B; calcsize for !IHH."
    - "struct_extra3.zspec.zsdl covers: pack/unpack network byte order float/double/bool; calcsize for !5s/!3p/!x/!5x."
    - "The 's' format character packs a fixed-width byte string; shorter inputs are zero-padded to the field width."
    - "pack('4s', b'abcd') == b'abcd' — exact-length input is preserved without padding."
    - "pack('4s', b'ab') == b'ab\\x00\\x00' — shorter input is zero-padded on the right to fill the field."
    - "pack('10s', b'hello') == b'hello\\x00\\x00\\x00\\x00\\x00' — 5 bytes padded to 10 bytes."
    - "unpack('4s', b'abcd') == (b'abcd',) — returns a one-element tuple."
    - "unpack returns a tuple even when there is only one field."
    - "pack.__module__ == '_struct' and unpack.__module__ == '_struct' on CPython (C extension)."
    - "calcsize('4s') == 4; calcsize('10s') == 10; calcsize('8s') == 8 — size equals the count in the format."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings. It is a subclass of Exception."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; Struct objects are immutable after construction."
  codes: {}

# ---------------------------------------------------------------------------
# pack() — string format ('s') vectors
# The 's' format packs bytes into a fixed-width field, zero-padding on the right.
# ---------------------------------------------------------------------------

invariant struct241str.pack.exact_4s:
  description: "struct.pack('4s', b'abcd') == b'abcd' (exact-length input)"
  category: pack
  kind: python_call_eq
  function: pack
  args: ["4s", !ascii "abcd"]
  expected: !ascii "abcd"

invariant struct241str.pack.short_4s:
  description: "struct.pack('4s', b'ab') == b'ab\\x00\\x00' (shorter input zero-padded)"
  category: pack
  kind: python_call_eq
  function: pack
  args: ["4s", !ascii "ab"]
  expected: !hex 61620000

invariant struct241str.pack.hello_10s:
  description: "struct.pack('10s', b'hello') == b'hello\\x00\\x00\\x00\\x00\\x00' (5 bytes padded to 10)"
  category: pack
  kind: python_call_eq
  function: pack
  args: ["10s", !ascii "hello"]
  expected: !hex 68656c6c6f0000000000

invariant struct241str.pack.hello_8s:
  description: "struct.pack('8s', b'hello') == b'hello\\x00\\x00\\x00' (5 bytes padded to 8)"
  category: pack
  kind: python_call_eq
  function: pack
  args: ["8s", !ascii "hello"]
  expected: !hex 68656c6c6f000000

invariant struct241str.pack.abc_3s:
  description: "struct.pack('3s', b'abc') == b'abc' (exact 3-byte input)"
  category: pack
  kind: python_call_eq
  function: pack
  args: ["3s", !ascii "abc"]
  expected: !ascii "abc"

# ---------------------------------------------------------------------------
# unpack() — string format ('s') vectors
# unpack returns a one-element tuple for a single field.
# ---------------------------------------------------------------------------

invariant struct241str.unpack.abcd_4s:
  description: "struct.unpack('4s', b'abcd') == (b'abcd',)"
  category: unpack
  kind: python_call_eq
  function: unpack
  args: ["4s", !ascii "abcd"]
  expected: [!ascii "abcd"]

invariant struct241str.unpack.padded_10s:
  description: "struct.unpack('10s', b'hello\\x00\\x00\\x00\\x00\\x00') == (b'hello\\x00\\x00\\x00\\x00\\x00',)"
  category: unpack
  kind: python_call_eq
  function: unpack
  args: ["10s", !hex 68656c6c6f0000000000]
  expected: [!hex 68656c6c6f0000000000]

invariant struct241str.unpack.abc_3s:
  description: "struct.unpack('3s', b'abc') == (b'abc',)"
  category: unpack
  kind: python_call_eq
  function: unpack
  args: ["3s", !ascii "abc"]
  expected: [!ascii "abc"]

# ---------------------------------------------------------------------------
# calcsize() — string format sizes
# calcsize('Ns') == N because the 's' format occupies exactly N bytes.
# ---------------------------------------------------------------------------

table struct241str.calcsize.string_formats:
  description: "calcsize for string ('s') formats equals the count prefix"
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: struct241str

  columns: [id, args, expected]
  rows:
    - [four_s,  ["4s"],  4]
    - [ten_s,   ["10s"], 10]
    - [eight_s, ["8s"],  8]
    - [three_s, ["3s"],  3]
    - [one_s,   ["1s"],  1]

# ---------------------------------------------------------------------------
# pack() and unpack() function identity
# pack/__module__ == '_struct' on CPython (C extension module).
# ---------------------------------------------------------------------------

invariant struct241str.pack.module:
  description: "struct.pack.__module__ == '_struct' (C extension)"
  category: function_identity
  kind: python_call_eq
  function: pack.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct241str.unpack.module:
  description: "struct.unpack.__module__ == '_struct' (C extension)"
  category: function_identity
  kind: python_call_eq
  function: unpack.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# pack/unpack roundtrip — string formats
# Packing then unpacking should recover the original (possibly padded) bytes.
# ---------------------------------------------------------------------------

invariant struct241str.roundtrip.4s:
  description: "struct.unpack('4s', struct.pack('4s', b'abcd')) == (b'abcd',)"
  category: roundtrip
  kind: python_call_eq
  function: pack
  args: ["4s", !ascii "abcd"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true
