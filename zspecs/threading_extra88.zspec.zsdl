spec: threading_extra88
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra87

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra87.zspec.zsdl."
    - "This spec covers: threading class hierarchy — __bases__[0].__name__ and __mro__.__len__() for Thread, Timer, Semaphore, BoundedSemaphore, Condition, Event, Barrier (Wave 250)."
    - "threading.Thread.__bases__[0].__name__ == 'object' — Thread inherits directly from object. Verified with Python 3.14.3."
    - "threading.Thread.__mro__.__len__() == 2 — MRO is [Thread, object]. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer is a subclass of Thread for delayed execution. Verified with Python 3.14.3."
    - "threading.Timer.__mro__.__len__() == 3 — MRO is [Timer, Thread, object]. Verified with Python 3.14.3."
    - "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits directly from object. Verified with Python 3.14.3."
    - "threading.Semaphore.__mro__.__len__() == 2 — MRO is [Semaphore, object]. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore is a subclass of Semaphore. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__mro__.__len__() == 3 — MRO is [BoundedSemaphore, Semaphore, object]. Verified with Python 3.14.3."
    - "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits directly from object. Verified with Python 3.14.3."
    - "threading.Condition.__mro__.__len__() == 2 — MRO is [Condition, object]. Verified with Python 3.14.3."
    - "threading.Event.__bases__[0].__name__ == 'object' — Event inherits directly from object. Verified with Python 3.14.3."
    - "threading.Event.__mro__.__len__() == 2 — MRO is [Event, object]. Verified with Python 3.14.3."
    - "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits directly from object. Verified with Python 3.14.3."
    - "threading.Barrier.__mro__.__len__() == 2 — MRO is [Barrier, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Base class names: Thread, Semaphore, Condition, Event
# Thread/Semaphore/Condition/Event all inherit directly from object.
#
# Wave 250 theme: threading class hierarchy — direct base class names.
#
# threading.Thread.__bases__[0].__name__    == 'object'
# threading.Semaphore.__bases__[0].__name__ == 'object'
# threading.Condition.__bases__[0].__name__ == 'object'
# threading.Event.__bases__[0].__name__     == 'object'
#
# No prior threading spec checks __bases__[0].__name__ via threadingclshier88. New to extra88.
# ---------------------------------------------------------------------------

table threading_extra88.base_names_flat:
  description: "Thread/Semaphore/Condition/Event __bases__[0].__name__==object; direct inheritance from object; wave 250; new to extra88"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingclshier88

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_base_name_eq_object,
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — Thread is the base threading class defined in Lib/threading.py; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior threading spec checks Thread.__bases__[0].__name__ via threadingclshier88; new to extra88"]
    - [Semaphore_base_name_eq_object,
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — Semaphore is a pure-Python synchronization class defined in Lib/threading.py; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior threading spec checks Semaphore.__bases__[0].__name__ via threadingclshier88; new to extra88"]
    - [Condition_base_name_eq_object,
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — Condition is a pure-Python synchronization class defined in Lib/threading.py; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior threading spec checks Condition.__bases__[0].__name__ via threadingclshier88; new to extra88"]
    - [Event_base_name_eq_object,
       "Event.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__name__.__eq__('object') == True — Event is a pure-Python synchronization class defined in Lib/threading.py; it inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior threading spec checks Event.__bases__[0].__name__ via threadingclshier88; new to extra88"]

# ---------------------------------------------------------------------------
# MRO depths: Thread, Semaphore, Condition, Barrier
# Thread/Semaphore/Condition/Barrier all have MRO depth 2 ([class, object]).
#
# Wave 250 theme: threading class hierarchy — flat MRO depths.
#
# threading.Thread.__mro__.__len__()    == 2
# threading.Semaphore.__mro__.__len__() == 2
# threading.Condition.__mro__.__len__() == 2
# threading.Barrier.__mro__.__len__()   == 2
#
# No prior threading spec checks __mro__.__len__() for these classes via threadingclshier88. New to extra88.
# ---------------------------------------------------------------------------

table threading_extra88.mro_depths_flat:
  description: "Thread/Semaphore/Condition/Barrier __mro__.__len__()==2; direct inheritance from object; wave 250; new to extra88"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingclshier88

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_mro_len_eq_2,
       Thread.__mro__.__len__,
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — Thread is the base threading class; its MRO is [Thread, object] (depth 2); Thread inherits from no intermediate class; tuple.__len__() returns 2; no prior threading spec checks Thread.__mro__.__len__ via threadingclshier88; new to extra88"]
    - [Semaphore_mro_len_eq_2,
       Semaphore.__mro__.__len__,
       [],
       2,
       "threading.Semaphore.__mro__.__len__() == 2 — Semaphore is a threading synchronization class; its MRO is [Semaphore, object] (depth 2); Semaphore inherits from no intermediate class; tuple.__len__() returns 2; no prior threading spec checks Semaphore.__mro__.__len__ via threadingclshier88; new to extra88"]
    - [Condition_mro_len_eq_2,
       Condition.__mro__.__len__,
       [],
       2,
       "threading.Condition.__mro__.__len__() == 2 — Condition is a threading synchronization class; its MRO is [Condition, object] (depth 2); Condition inherits from no intermediate class; tuple.__len__() returns 2; no prior threading spec checks Condition.__mro__.__len__ via threadingclshier88; new to extra88"]
    - [Barrier_mro_len_eq_2,
       Barrier.__mro__.__len__,
       [],
       2,
       "threading.Barrier.__mro__.__len__() == 2 — Barrier is a threading synchronization class; its MRO is [Barrier, object] (depth 2); Barrier inherits from no intermediate class; tuple.__len__() returns 2; no prior threading spec checks Barrier.__mro__.__len__ via threadingclshier88; new to extra88"]

# ---------------------------------------------------------------------------
# Timer/BoundedSemaphore subclass hierarchy
# Timer inherits from Thread (MRO depth 3); BoundedSemaphore inherits from Semaphore (MRO depth 3).
#
# Wave 250 theme: threading class hierarchy — subclass relationships.
#
# threading.Timer.__bases__[0].__name__             == 'Thread'
# threading.Timer.__mro__.__len__()                 == 3
# threading.BoundedSemaphore.__bases__[0].__name__  == 'Semaphore'
# threading.BoundedSemaphore.__mro__.__len__()      == 3
#
# No prior threading spec checks Timer/BoundedSemaphore subclass hierarchy via threadingclshier88. New to extra88.
# ---------------------------------------------------------------------------

table threading_extra88.subclass_hierarchy:
  description: "Timer base==Thread (MRO depth 3); BoundedSemaphore base==Semaphore (MRO depth 3); subclass relationships; wave 250; new to extra88"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingclshier88

  columns: [id, function, args, expected, description]
  rows:
    - [Timer_base_name_eq_Thread,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer is a subclass of Thread defined in Lib/threading.py; it represents a thread that runs a function after a specified delay; __bases__[0].__name__ is 'Thread'; str.__eq__('Thread') returns True; no prior threading spec checks Timer.__bases__[0].__name__ via threadingclshier88; new to extra88"]
    - [Timer_mro_len_eq_3,
       Timer.__mro__.__len__,
       [],
       3,
       "threading.Timer.__mro__.__len__() == 3 — Timer inherits from Thread which inherits from object; its MRO is [Timer, Thread, object] (depth 3); tuple.__len__() returns 3; no prior threading spec checks Timer.__mro__.__len__ via threadingclshier88; new to extra88"]
    - [BoundedSemaphore_base_name_eq_Semaphore,
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore is a subclass of Semaphore defined in Lib/threading.py; it adds an upper bound to the semaphore counter; __bases__[0].__name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; no prior threading spec checks BoundedSemaphore.__bases__[0].__name__ via threadingclshier88; new to extra88"]
    - [BoundedSemaphore_mro_len_eq_3,
       BoundedSemaphore.__mro__.__len__,
       [],
       3,
       "threading.BoundedSemaphore.__mro__.__len__() == 3 — BoundedSemaphore inherits from Semaphore which inherits from object; its MRO is [BoundedSemaphore, Semaphore, object] (depth 3); tuple.__len__() returns 3; no prior threading spec checks BoundedSemaphore.__mro__.__len__ via threadingclshier88; new to extra88"]

# ---------------------------------------------------------------------------
# Cross-check: Event/Barrier base names + Timer/BoundedSemaphore depth confirms
#
# Wave 250 theme: threading class hierarchy cross-checks.
#
# threading.Event.__bases__[0].__name__        == 'object'  (double-confirm)
# threading.Barrier.__bases__[0].__name__      == 'object'  (double-confirm)
# threading.Timer.__mro__.__len__()            == 3  (double-confirm)
# threading.BoundedSemaphore.__mro__.__len__() == 3  (double-confirm)
#
# New to extra88.
# ---------------------------------------------------------------------------

table threading_extra88.cross_check_hierarchy:
  description: "Event/Barrier base==object cross-checks; Timer/BoundedSemaphore MRO depth 3 cross-checks; wave 250; new to extra88"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingclshier88

  columns: [id, function, args, expected, description]
  rows:
    - [Event_base_name_eq_object_confirm,
       "Event.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Event.__bases__[0].__name__.__eq__('object') == True — double-confirms Event inherits directly from object; Event is not a subclass of any threading class; __bases__[0].__name__ is 'object'; new to extra88"]
    - [Barrier_base_name_eq_object_confirm,
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — double-confirms Barrier inherits directly from object; Barrier is not a subclass of any threading class; __bases__[0].__name__ is 'object'; new to extra88"]
    - [Timer_mro_len_eq_3_confirm,
       Timer.__mro__.__len__,
       [],
       3,
       "threading.Timer.__mro__.__len__() == 3 — double-confirms Timer MRO depth is 3; MRO is [Timer, Thread, object]; Timer extends Thread for delayed execution; new to extra88"]
    - [BoundedSemaphore_mro_len_eq_3_confirm,
       BoundedSemaphore.__mro__.__len__,
       [],
       3,
       "threading.BoundedSemaphore.__mro__.__len__() == 3 — double-confirms BoundedSemaphore MRO depth is 3; MRO is [BoundedSemaphore, Semaphore, object]; BoundedSemaphore extends Semaphore with an upper bound; new to extra88"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra88
# ---------------------------------------------------------------------------

invariant threading_extra88.Thread_base_name_eq_object:
  description: "threading.Thread.__bases__[0].__name__.__eq__('object') == True — Thread inherits directly from object; wave 250; new to extra88"
  kind: python_call_eq
  function: "Thread.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra88.Timer_base_name_eq_Thread:
  description: "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer is a subclass of Thread; wave 250; new to extra88"
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

invariant threading_extra88.BoundedSemaphore_base_name_eq_Semaphore:
  description: "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore inherits from Semaphore; wave 250; new to extra88"
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant threading_extra88.Timer_mro_len_eq_3:
  description: "threading.Timer.__mro__.__len__() == 3 — Timer MRO is [Timer, Thread, object]; wave 250; new to extra88"
  kind: python_call_eq
  function: Timer.__mro__.__len__
  args: []
  expected: 3

invariant threading_extra88.BoundedSemaphore_mro_len_eq_3:
  description: "threading.BoundedSemaphore.__mro__.__len__() == 3 — BoundedSemaphore MRO is [BoundedSemaphore, Semaphore, object]; wave 250; new to extra88"
  kind: python_call_eq
  function: BoundedSemaphore.__mro__.__len__
  args: []
  expected: 3
