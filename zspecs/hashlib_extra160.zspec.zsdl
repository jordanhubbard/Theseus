spec: hashlib_extra160
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra159.zspec.zsdl — covers hashlib.scrypt/__class__.__name__/__module__/__name__ / pbkdf2_hmac/__class__.__name__/__name__ / file_digest/__module__/__code__.co_name (table + invariants)."
    - "hashlib_extra158.zspec.zsdl — covers hashlib.sha256/__doc__/__class__.__name__.__eq__('str') / md5/__doc__/__class__.__name__.__eq__('str') / sha256/__qualname__.__len__()==14 / md5/__qualname__.__len__()==11 / sha1/__qualname__.__len__()==12 / sha512/__qualname__.__len__()==14 / sha3_256/__qualname__.__len__()==16 (table + invariants)."
    - "hashlib_extra157.zspec.zsdl — covers hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('hashlib') / __all__.__class__.__name__.__eq__('tuple') / __all__.__contains__('md5'/'sha256'/'sha512') / new.__module__.__eq__('hashlib') / new.__class__.__name__.__eq__('function') (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra159."
    - "Wave 339 theme: hashlib.__loader__/__spec__ and hashlib.new identity — __loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.origin string (ends with hashlib.py) / __spec__.submodule_search_locations (None for leaf module) / new.__qualname__.__eq__('__hash_new') / new.__class__.__name__.__eq__('function') / new.__module__.__eq__('hashlib') / algorithms_guaranteed.__class__.__name__.__eq__('set')."
    - "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.origin ends with 'hashlib.py' (full path is platform-specific). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.submodule_search_locations is None (hashlib is a leaf module, not a package). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__ == '__hash_new'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.__loader__.__class__.__name__ == 'SourceFileLoader'. hashlib is a pure Python module (Lib/hashlib.py) loaded by the SourceFileLoader, which is part of importlib._bootstrap_external. The SourceFileLoader is the standard loader for .py source files. This contrasts with C extension modules (like _hashlib) which use ExtensionFileLoader. hashlib.__spec__.origin gives the full filesystem path to hashlib.py."
    - "Note: hashlib.__spec__.submodule_search_locations is None. For a regular module (not a package), submodule_search_locations is None. Only packages (directories with __init__.py, or namespace packages) have a non-None submodule_search_locations. hashlib is a leaf module, not a package, so this attribute is None."
    - "Note: hashlib.new.__qualname__ == '__hash_new'. The hashlib.new() function is actually an internal helper named __hash_new internally (its def statement uses the name __hash_new, which is then exposed as hashlib.new). extra157 anchors new.__class__.__name__=='function' and new.__module__=='hashlib'. This spec anchors the surprising qualname value '__hash_new' (10 chars), which reveals the internal implementation name."
    - "Note: hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. algorithms_guaranteed is a set of strings naming the hash algorithms guaranteed to be available on all Python implementations. It is a plain Python set (not frozenset). algorithms_guaranteed is a subset of algorithms_available."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader')
# hashlib.__spec__.submodule_search_locations (None)
# hashlib.new.__qualname__.__eq__('__hash_new')
# hashlib.new.__class__.__name__.__eq__('function')
#
# Wave 339 theme: hashlib loader identity and new() function qualname.
#
# __loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; Python source loader).
# __spec__.submodule_search_locations is None (leaf module, not a package).
# new.__qualname__ == '__hash_new' (10 chars; internal name from def statement).
# new.__class__.__name__ == 'function' (8 chars; pure Python function; extra157 anchors this).
# No prior hashlib spec anchors __loader__.__class__.__name__ or new.__qualname__ as a
# combined table under hashld160. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra160.loader_and_new_qualname_identity:
  description: "hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader')==True / new.__qualname__.__eq__('__hash_new')==True / new.__class__.__name__.__eq__('function')==True / new.__module__.__eq__('hashlib')==True — __loader__ is SourceFileLoader (16 chars; importlib._bootstrap_external; loads pure Python .py files; contrasts with ExtensionFileLoader for C extensions); new.__qualname__ is '__hash_new' (10 chars; internal def name exposed as hashlib.new; reveals implementation detail); new.__class__.__name__ is 'function' (8 chars; extra157 anchors this); new.__module__ is 'hashlib' (7 chars; extra157 anchors this); first hashld160 anchor for __loader__ class name and new.__qualname__"
  kind: python_call_eq
  category: identity
  id_prefix: hashld160

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_SourceFileLoader, "__loader__.__class__.__name__.__eq__", ["SourceFileLoader"], true, "hashlib.__loader__.__class__.__name__ == 'SourceFileLoader' (16 chars; Python .py source loader from importlib._bootstrap_external)"]
    - [new_qualname_hash_new,         "new.__qualname__.__eq__",              ["__hash_new"],      true, "hashlib.new.__qualname__ == '__hash_new' (10 chars; internal def-statement name; exposed publicly as hashlib.new)"]
    - [new_class_function,            "new.__class__.__name__.__eq__",        ["function"],        true, "hashlib.new.__class__.__name__ == 'function' (8 chars; pure Python function; extra157 anchors this; confirmed in hashld160)"]
    - [new_module_hashlib,            "new.__module__.__eq__",                ["hashlib"],         true, "hashlib.new.__module__ == 'hashlib' (7 chars; defined in Lib/hashlib.py; extra157 anchors this; confirmed in hashld160)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')
# hashlib.new.__qualname__.__len__()==10
# hashlib.__loader__.__class__.__name__.__len__()==16
#
# Wave 339 theme: algorithms_guaranteed is a set, qualname/loader class name lengths.
#
# algorithms_guaranteed.__class__.__name__ == 'set' (3 chars; plain Python set, not frozenset).
# new.__qualname__.__len__() == 10 ('__hash_new' = 10 chars).
# __loader__.__class__.__name__.__len__() == 16 ('SourceFileLoader' = 16 chars).
# No prior hashlib spec anchors algorithms_guaranteed class name or these length values
# as a table under hashld160. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra160.algorithms_guaranteed_and_name_lengths:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set')==True / new.__qualname__.__len__()==10 / __loader__.__class__.__name__.__len__()==16 / new.__module__.__len__()==7 — algorithms_guaranteed is a 'set' (3 chars; plain set, not frozenset; subset of algorithms_available; contains hash names guaranteed on all Python implementations); new.__qualname__ is 10 chars ('__hash_new'); __loader__.__class__.__name__ is 16 chars ('SourceFileLoader'); new.__module__ is 7 chars ('hashlib'); first hashld160 anchor for algorithms_guaranteed class name and these length values"
  kind: python_call_eq
  category: identity
  id_prefix: hashld160

  columns: [id, function, args, expected, description]
  rows:
    - [algorithms_guaranteed_set,    "algorithms_guaranteed.__class__.__name__.__eq__", ["set"], true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' (3 chars; plain Python set; not frozenset; hash names always available)"]
    - [new_qualname_len_10,          "new.__qualname__.__len__",                       [],      10,   "hashlib.new.__qualname__.__len__() is 10 ('__hash_new' = 10 chars; double underscore prefix + 'hash_new' = 8 chars + 2 = 10)"]
    - [loader_class_name_len_16,     "__loader__.__class__.__name__.__len__",          [],      16,   "hashlib.__loader__.__class__.__name__.__len__() is 16 ('SourceFileLoader' = 16 chars; longest class name in this spec)"]
    - [new_module_len_7,             "new.__module__.__len__",                         [],      7,    "hashlib.new.__module__.__len__() is 7 ('hashlib' = 7 chars; public module name; same length as '_hashlib' minus underscore)"]

# ---------------------------------------------------------------------------
# hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# hashlib.__loader__.__class__.__name__ is 'SourceFileLoader' (16 chars). The
# SourceFileLoader is the standard loader for Python source files (.py files). It is
# part of importlib._bootstrap_external and handles reading and compiling .py source
# files. hashlib is a pure Python module defined in Lib/hashlib.py, so its loader
# is a SourceFileLoader (not an ExtensionFileLoader, which is used for C extension
# modules like _hashlib). The loader's class name 'SourceFileLoader' has 16 chars:
# 'Source'(6) + 'File'(4) + 'Loader'(6) = 16. This contrasts with the underlying
# C extension _hashlib which would have an ExtensionFileLoader.
# No prior hashlib spec anchors __loader__.__class__.__name__ as a standalone under
# hashld160. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra160.loader_class_SourceFileLoader:
  description: "hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — 16 chars ('Source'=6 + 'File'=4 + 'Loader'=6); importlib._bootstrap_external loader for pure Python .py files; hashlib is a pure Python module (Lib/hashlib.py); contrasts with ExtensionFileLoader (used for _hashlib C extension); __spec__.origin gives the full path to hashlib.py; __spec__.submodule_search_locations is None (leaf module); no prior hashlib spec anchors this as a standalone; first standalone under hashld160"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__.__eq__('__hash_new') — standalone
#
# hashlib.new.__qualname__ is '__hash_new' (10 chars). hashlib.new() is a function
# used to create new hash objects by name (e.g., hashlib.new('sha256')). Internally,
# it is defined with the name __hash_new in Lib/hashlib.py — the function definition
# reads `def __hash_new(name, data=b'', **kwargs)`. Python then exposes it as
# hashlib.new via module-level assignment. The __qualname__ reflects the def-statement
# name '__hash_new', not the public attribute name 'new'. This is unusual: for most
# functions, __qualname__ matches the attribute name. The double underscore prefix
# signals an implementation-private name. '__hash_new' = '__' + 'hash' + '_' + 'new'.
# extra157 anchors new.__class__.__name__ and new.__module__; no prior hashlib spec
# anchors new.__qualname__ as a standalone under hashld160.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra160.new_qualname_hash_new:
  description: "hashlib.new.__qualname__.__eq__('__hash_new') == True — 10 chars; internal def-statement name: def __hash_new(name, data=b'', **kwargs) in Lib/hashlib.py; exposed publicly as hashlib.new via module assignment; __qualname__ reflects def name, not attribute name; double underscore prefix signals implementation-private; '__' + 'hash_new'(8) = 10 chars; extra157 anchors new.__class__.__name__=='function' and new.__module__=='hashlib'; no prior hashlib spec anchors this as a standalone; first standalone under hashld160"
  category: identity
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') — standalone
#
# hashlib.algorithms_guaranteed.__class__.__name__ is 'set' (3 chars). The
# algorithms_guaranteed attribute is a frozenset-like collection (actually a plain set)
# containing the names of hash algorithms that are guaranteed to be available on all
# Python implementations. It includes algorithms like 'sha256', 'sha512', 'sha1',
# 'md5', 'sha224', 'sha384', 'sha3_256', etc. algorithms_guaranteed is a subset of
# algorithms_available (which includes additional algorithms available on the current
# platform). The type is 'set' (3 chars; plain mutable set) rather than 'frozenset'
# (9 chars). algorithms_available is also a set. No prior hashlib spec anchors
# algorithms_guaranteed.__class__.__name__ as a standalone under hashld160.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra160.algorithms_guaranteed_class_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__.__eq__('set') == True — 'set' (3 chars); plain mutable Python set (not 'frozenset'=9 chars); contains hash algorithm names guaranteed on all Python implementations (sha256/sha512/sha1/md5/sha224/sha384/sha3_256 etc.); subset of algorithms_available (which includes platform-specific algorithms); both algorithms_guaranteed and algorithms_available are plain sets; no prior hashlib spec anchors this as a standalone; first standalone under hashld160"
  category: identity
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true
