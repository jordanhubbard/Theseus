spec: es6_error
version: ">=4.0.0"
backend: node(es6-error)

docs: https://github.com/bjyoungblood/es6-error#readme

provenance:
  derived_from:
    - "es6-error README — https://github.com/bjyoungblood/es6-error#readme"
    - "Test vectors verified with es6-error via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "es6-error source"
  notes:
    - "Extendable Error class that fixes the inheritance issue with Error in older JS."
    - "Install: npm install es6-error"
    - "Constructor exposed under .default; new ExtendableError(msg) gives a proper Error subclass."
    - "Subclasses preserve their .name property (matching constructor.name)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Constructor; never throws on string input."
  stderr: "null"
  stickiness: "Each invariant constructs a fresh error."
  codes: {}

invariant es6_error.message_preserved:
  description: "Constructor message is preserved on .message"
  category: basic
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: ["oops"]
  chain:
    - {get: message}
  expected: "oops"

invariant es6_error.name_is_ExtendableError:
  description: "Default class .name is 'ExtendableError'"
  category: basic
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: ["oops"]
  chain:
    - {get: name}
  expected: "ExtendableError"

invariant es6_error.has_stack:
  description: ".stack property exists (string)"
  category: basic
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: ["oops"]
  chain:
    - {get: stack}
    - {method: startsWith, args: ["ExtendableError"]}
  expected: true

invariant es6_error.empty_message:
  description: "No-arg construction yields empty message"
  category: basic
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {get: message}
  expected: ""

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:40:29Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
