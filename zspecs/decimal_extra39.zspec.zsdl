spec: decimal_extra39
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra38.zspec.zsdl — covers Rounded/Subnormal/Clamped/FloatOperation __module__=='decimal'; Decimal.__bases__[0].__name__=='object'; Decimal.__mro__.__len__()==2; Context.__name__/__module__/__bases__[0].__name__."
    - "decimal_extra37.zspec.zsdl — covers Rounded/Subnormal/Clamped/FloatOperation __name__; InvalidOperation/DivisionByZero/Overflow/Underflow/Inexact __module__=='decimal'."
    - "decimal_extra36.zspec.zsdl — covers DecimalException/__name__/__module__; InvalidOperation/__name__/__bases__[0].__name__; DivisionByZero/Overflow/Underflow/Inexact __name__."
    - "decimal_extra33.zspec.zsdl — covers Decimal dunder method __qualname__.__len__()."
    - "decimal_extra24.zspec.zsdl — covers Decimal.__module__.__eq__('decimal')/__module__.__len__()==7."
    - "decimal_extra13.zspec.zsdl — covers Decimal.__name__.__eq__('Decimal')."
    - "decimal_extra.zspec.zsdl — covers DefaultContext.__class__.__name__.__eq__('Context')."
  notes:
    - "This spec extends decimal_extra38.zspec.zsdl."
    - "Prior specs collectively covered: Decimal.__name__/__module__ equality (decimal_extra13/decimal_extra24); all exception class __name__ equality (decimal_extra36/decimal_extra37); all exception __module__ equality (decimal_extra37/decimal_extra38); Decimal dunder method __qualname__.__len__() (decimal_extra33); Context identity via DefaultContext (decimal_extra); Context.__name__/__module__/__bases__[0].__name__ (decimal_extra38). No prior decimal spec covers any decimal class __qualname__ attribute."
    - "This spec covers: decimal.Context.__qualname__=='Context' (NOVEL — decimal_extra38 covers Context.__name__/__module__/__bases__[0].__name__; no prior decimal spec checks Context.__qualname__; novel equality anchor in decimal_extra39 namespace); decimal.Decimal.__qualname__=='Decimal' (NOVEL — decimal_extra13 covers Decimal.__name__; no prior spec checks Decimal.__qualname__; novel); decimal.DecimalException.__qualname__=='DecimalException' (NOVEL — decimal_extra36 covers DecimalException.__name__; no prior spec checks __qualname__; novel); decimal.InvalidOperation.__qualname__=='InvalidOperation' (NOVEL); decimal.DivisionByZero.__qualname__=='DivisionByZero' (NOVEL); decimal.Overflow.__qualname__=='Overflow' (NOVEL); decimal.Underflow.__qualname__=='Underflow' (NOVEL); decimal.Inexact.__qualname__=='Inexact' (NOVEL); decimal.Rounded.__qualname__=='Rounded' (NOVEL)."
    - "decimal.Context.__qualname__ == 'Context'. decimal_extra38 covers Context.__name__=='Context' and Context.__module__=='decimal'. __qualname__ equals __name__ for top-level classes. No prior decimal spec checks Context.__qualname__. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Decimal.__qualname__ == 'Decimal'. decimal_extra13 covers Decimal.__name__=='Decimal'. No prior decimal spec checks Decimal.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DecimalException.__qualname__ == 'DecimalException'. decimal_extra36 covers DecimalException.__name__=='DecimalException'. No prior decimal spec checks DecimalException.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.InvalidOperation.__qualname__ == 'InvalidOperation'. decimal_extra36 covers InvalidOperation.__name__=='InvalidOperation'. No prior decimal spec checks InvalidOperation.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DivisionByZero.__qualname__ == 'DivisionByZero'. decimal_extra36 covers DivisionByZero.__name__=='DivisionByZero'. No prior decimal spec checks DivisionByZero.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Overflow.__qualname__ == 'Overflow'. decimal_extra36 covers Overflow.__name__=='Overflow'. No prior decimal spec checks Overflow.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Underflow.__qualname__ == 'Underflow'. decimal_extra36 covers Underflow.__name__=='Underflow'. No prior decimal spec checks Underflow.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Inexact.__qualname__ == 'Inexact'. decimal_extra36 covers Inexact.__name__=='Inexact'. No prior decimal spec checks Inexact.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Rounded.__qualname__ == 'Rounded'. decimal_extra37 covers Rounded.__name__=='Rounded'. No prior decimal spec checks Rounded.__qualname__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal class __qualname__ attributes
#
# All public classes in the decimal module are defined at module scope, so
# their __qualname__ is equal to their bare class name (no prefix).
#
# The decimal public class hierarchy:
#   Decimal              — the main numeric type
#   Context              — arithmetic configuration class
#   DecimalException     — base exception (subclass of ArithmeticError)
#     InvalidOperation   — invalid operation signal
#     DivisionByZero     — division by zero signal
#     Overflow           — overflow signal
#     Underflow          — underflow signal
#     Inexact            — inexact result signal
#     Rounded            — rounding occurred signal
#
# __qualname__ values (all verified Python 3.14 macOS/Darwin 25.4.0):
#   Context.__qualname__          == 'Context'
#   Decimal.__qualname__          == 'Decimal'
#   DecimalException.__qualname__ == 'DecimalException'
#   InvalidOperation.__qualname__ == 'InvalidOperation'
#   DivisionByZero.__qualname__   == 'DivisionByZero'
#   Overflow.__qualname__         == 'Overflow'
#   Underflow.__qualname__        == 'Underflow'
#   Inexact.__qualname__          == 'Inexact'
#   Rounded.__qualname__          == 'Rounded'
#
# No prior decimal spec covers any decimal class __qualname__ attribute.
# All nine are novel equality anchors in the decimal_extra39 namespace.
# ---------------------------------------------------------------------------

table decimal_extra39.class_qualnames:
  description: "decimal class __qualname__ attributes: Context/Decimal/DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Inexact/Rounded — __qualname__ equals bare class name for all top-level decimal classes; no prior decimal spec checks any decimal class __qualname__; all nine novel equality anchors in decimal_extra39 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: dcq39

  columns: [id, function, args, expected]
  rows:
    - [Context_qualname,          Context.__qualname__.__eq__,          ["Context"],          true]
    - [Decimal_qualname,          Decimal.__qualname__.__eq__,          ["Decimal"],          true]
    - [DecimalException_qualname, DecimalException.__qualname__.__eq__, ["DecimalException"],  true]
    - [InvalidOperation_qualname, InvalidOperation.__qualname__.__eq__, ["InvalidOperation"],  true]
    - [DivisionByZero_qualname,   DivisionByZero.__qualname__.__eq__,   ["DivisionByZero"],   true]
    - [Overflow_qualname,         Overflow.__qualname__.__eq__,         ["Overflow"],         true]
    - [Underflow_qualname,        Underflow.__qualname__.__eq__,        ["Underflow"],        true]
    - [Inexact_qualname,          Inexact.__qualname__.__eq__,          ["Inexact"],          true]
    - [Rounded_qualname,          Rounded.__qualname__.__eq__,          ["Rounded"],          true]
