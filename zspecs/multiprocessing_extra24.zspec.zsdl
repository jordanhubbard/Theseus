spec: multiprocessing_extra24
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/synchronize.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra23.zspec.zsdl."
    - "multiprocessing_extra22 covers: context-bound callable __qualname__ LENGTH tables (Queue/Pool/Lock/Event/Semaphore/etc)."
    - "multiprocessing_extra23 covers: cpu_count/active_children/current_process qualnames and modules; Process property fget qualnames."
    - "NOT yet covered in any prior spec: multiprocessing.Process.__module__ in extra24 namespace."
    - "NOT yet covered: multiprocessing.Process.__bases__[0].__name__ in extra24 namespace."
    - "NOT yet covered: multiprocessing.Pool.__qualname__ and __module__ in extra24 namespace."
    - "NOT yet covered: multiprocessing.Queue.__module__ in extra24 namespace."
    - "NOT yet covered: multiprocessing.Lock.__module__ in extra24 namespace."
    - "NOT yet covered: multiprocessing.Event.__module__ in extra24 namespace."
    - "NOT yet covered: multiprocessing.Value.__module__ and Array.__module__ in extra24 namespace."
    - "Process.__module__ == 'multiprocessing.context' — Process class is defined in context.py (length 23)."
    - "Process.__bases__[0].__name__ == 'BaseProcess' — Process inherits from BaseProcess (length 11)."
    - "Pool.__qualname__ == 'BaseContext.Pool' — Pool is a context-bound method (length 16)."
    - "Pool.__module__ == 'multiprocessing.context' — length 23."
    - "Queue.__module__ == 'multiprocessing.context' — Queue is a context-bound factory (length 23)."
    - "Lock.__module__ == 'multiprocessing.context' — Lock is a context-bound factory (length 23)."
    - "Event.__module__ == 'multiprocessing.context' — Event is a context-bound factory (length 23)."
    - "Value.__module__ == 'multiprocessing.context' — Value is a context-bound factory (length 23)."
    - "Array.__module__ == 'multiprocessing.context' — Array is a context-bound factory (length 23)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context-bound callable __module__ table — extra24 namespace
#
# In multiprocessing, Queue/Lock/Event/Value/Array/Pool are all context-bound
# methods (bound methods of the default context object). Their __module__
# is 'multiprocessing.context' (length 23). No prior spec checks these
# __module__ values — extra22 checked only __qualname__ lengths.
# ---------------------------------------------------------------------------

table multiprocessing_extra24.context_callable_modules:
  description: "multiprocessing context-bound callable __module__ values in extra24 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: ctxmod24

  columns: [id, function, args, expected]
  rows:
    - [Queue, Queue.__module__.__eq__, ["multiprocessing.context"], true]
    - [Lock,  Lock.__module__.__eq__,  ["multiprocessing.context"], true]
    - [Event, Event.__module__.__eq__, ["multiprocessing.context"], true]
    - [Value, Value.__module__.__eq__, ["multiprocessing.context"], true]
    - [Array, Array.__module__.__eq__, ["multiprocessing.context"], true]
    - [Pool,  Pool.__module__.__eq__,  ["multiprocessing.context"], true]

# ---------------------------------------------------------------------------
# Context-bound callable __module__ length table — extra24 namespace
#
# All have __module__ == 'multiprocessing.context' (length 23).
# ---------------------------------------------------------------------------

table multiprocessing_extra24.context_callable_module_lengths:
  description: "multiprocessing context-bound callable __module__ lengths in extra24 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: ctxmodlen24

  columns: [id, function, args, expected]
  rows:
    - [Queue, Queue.__module__.__len__, [], 23]
    - [Lock,  Lock.__module__.__len__,  [], 23]
    - [Event, Event.__module__.__len__, [], 23]
    - [Value, Value.__module__.__len__, [], 23]
    - [Array, Array.__module__.__len__, [], 23]
    - [Pool,  Pool.__module__.__len__,  [], 23]

# ---------------------------------------------------------------------------
# Pool.__qualname__ — standalone extra24 invariant
#
# multiprocessing.Pool is a bound method of the default context, so its
# __qualname__ is 'BaseContext.Pool' (length 16), not 'Pool'. This is the
# same pattern as cpu_count (extra23: 'BaseContext.cpu_count'). No prior
# spec checks Pool.__qualname__ (extra22 checked only its length).
# ---------------------------------------------------------------------------

invariant multiprocessing_extra24.Pool.qualname_eq:
  description: "multiprocessing.Pool.__qualname__ == 'BaseContext.Pool' — context-bound method qualname"
  category: method_names
  kind: python_call_eq
  function: Pool.__qualname__.__eq__
  args: ["BaseContext.Pool"]
  expected: true

# ---------------------------------------------------------------------------
# Process.__module__ — standalone extra24 invariant
#
# multiprocessing.Process is defined in multiprocessing/context.py (it is
# imported from there into the public namespace). Process.__module__ ==
# 'multiprocessing.context' (length 23). No prior spec checks this value.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra24.Process.module:
  description: "multiprocessing.Process.__module__ == 'multiprocessing.context'"
  category: method_names
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

# ---------------------------------------------------------------------------
# Process.__bases__[0].__name__ — standalone extra24 invariant
#
# multiprocessing.Process inherits from BaseProcess (defined in process.py).
# Process.__bases__[0].__name__ == 'BaseProcess' (length 11). This is the
# same base that all Process property fget qualnames use (extra23 covers
# those). No prior spec checks the base class name directly.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra24.Process.bases_name:
  description: "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess' — Process inherits from BaseProcess"
  category: method_names
  kind: python_call_eq
  function: "Process.__bases__[0].__name__.__eq__"
  args: ["BaseProcess"]
  expected: true
