spec: decimal_extra146
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.__dict__.__contains__ membership for the core classes, rounding constants, exception types, and context functions."
    - "decimal.__dict__ is a plain dict (len==49 on Python 3.14.3)."
    - "decimal.__dict__.__contains__('Decimal') == True, decimal.__dict__.__contains__('Context') == True — the two primary classes."
    - "Rounding constants ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR, ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_HALF_EVEN, ROUND_05UP are all True."
    - "Exception types: DecimalException, InvalidOperation, DivisionByZero, Overflow, Underflow, Inexact, Rounded, Subnormal, FloatOperation are all in decimal.__dict__."
    - "Context functions: getcontext, setcontext, localcontext are all True."
    - "decimal.__dict__.__contains__('MAX_PREC') == True — a module-level constant for the maximum precision supported by the C decimal implementation."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.__dict__.__contains__ — core classes and context functions
# Decimal, Context, getcontext, setcontext, localcontext all True.
# ---------------------------------------------------------------------------

table decimal_extra146.dict_contains_core:
  description: "decimal.__dict__.__contains__: core classes Decimal/Context and context functions getcontext/setcontext/localcontext are all True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decdict146

  columns: [id, function, args, expected, description]
  rows:
    - [has_Decimal,      __dict__.__contains__, ["Decimal"],      true, "decimal.__dict__.__contains__('Decimal') == True (decimal.Decimal is the primary fixed-point numeric type; it represents decimal numbers exactly using a coefficient and exponent, avoiding binary floating-point rounding errors)"]
    - [has_Context,      __dict__.__contains__, ["Context"],      true, "decimal.__dict__.__contains__('Context') == True (decimal.Context configures the decimal arithmetic environment: precision, rounding mode, and which signals to trap as exceptions)"]
    - [has_getcontext,   __dict__.__contains__, ["getcontext"],   true, "decimal.__dict__.__contains__('getcontext') == True (decimal.getcontext() returns the active Context for the current thread; each thread has its own Context copy initialized from DefaultContext)"]
    - [has_setcontext,   __dict__.__contains__, ["setcontext"],   true, "decimal.__dict__.__contains__('setcontext') == True (decimal.setcontext() replaces the active Context for the current thread; accepts a Context instance and makes it the new thread-local context)"]
    - [has_localcontext, __dict__.__contains__, ["localcontext"], true, "decimal.__dict__.__contains__('localcontext') == True (decimal.localcontext() is a context manager that temporarily switches to a copy of the given Context and restores the original on exit; useful for isolated precision changes)"]

# ---------------------------------------------------------------------------
# decimal.__dict__.__contains__ — rounding constants
# ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR, ROUND_HALF_UP,
# ROUND_HALF_DOWN, ROUND_HALF_EVEN, ROUND_05UP all True.
# ---------------------------------------------------------------------------

table decimal_extra146.dict_contains_rounding_constants:
  description: "decimal.__dict__.__contains__: rounding constants ROUND_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_HALF_EVEN/ROUND_05UP are all True"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decdict146

  columns: [id, function, args, expected, description]
  rows:
    - [has_ROUND_UP,        __dict__.__contains__, ["ROUND_UP"],        true, "decimal.__dict__.__contains__('ROUND_UP') == True (decimal.ROUND_UP rounds away from zero; 1.1 rounds to 2 and -1.1 rounds to -2; the opposite of ROUND_DOWN)"]
    - [has_ROUND_DOWN,      __dict__.__contains__, ["ROUND_DOWN"],      true, "decimal.__dict__.__contains__('ROUND_DOWN') == True (decimal.ROUND_DOWN truncates toward zero; 1.9 rounds to 1 and -1.9 rounds to -1; also known as truncation)"]
    - [has_ROUND_CEILING,   __dict__.__contains__, ["ROUND_CEILING"],   true, "decimal.__dict__.__contains__('ROUND_CEILING') == True (decimal.ROUND_CEILING rounds toward positive infinity; 1.1 rounds to 2 and -1.9 rounds to -1)"]
    - [has_ROUND_FLOOR,     __dict__.__contains__, ["ROUND_FLOOR"],     true, "decimal.__dict__.__contains__('ROUND_FLOOR') == True (decimal.ROUND_FLOOR rounds toward negative infinity; 1.9 rounds to 1 and -1.1 rounds to -2)"]
    - [has_ROUND_HALF_UP,   __dict__.__contains__, ["ROUND_HALF_UP"],   true, "decimal.__dict__.__contains__('ROUND_HALF_UP') == True (decimal.ROUND_HALF_UP rounds to nearest with ties going away from zero; 2.5 rounds to 3; the rounding most people learn in school)"]
    - [has_ROUND_HALF_DOWN, __dict__.__contains__, ["ROUND_HALF_DOWN"], true, "decimal.__dict__.__contains__('ROUND_HALF_DOWN') == True (decimal.ROUND_HALF_DOWN rounds to nearest with ties going toward zero; 2.5 rounds to 2)"]
    - [has_ROUND_HALF_EVEN, __dict__.__contains__, ["ROUND_HALF_EVEN"], true, "decimal.__dict__.__contains__('ROUND_HALF_EVEN') == True (decimal.ROUND_HALF_EVEN rounds to nearest with ties going to nearest even digit; 2.5 rounds to 2 and 3.5 rounds to 4; also called banker rounding)"]
    - [has_ROUND_05UP,      __dict__.__contains__, ["ROUND_05UP"],      true, "decimal.__dict__.__contains__('ROUND_05UP') == True (decimal.ROUND_05UP rounds toward zero unless the last significant digit would be 0 or 5; rarely used in practice but defined for IEEE 854 compliance)"]

# ---------------------------------------------------------------------------
# decimal.__dict__.__contains__ — exception type membership
# DecimalException, InvalidOperation, Overflow, Underflow, Inexact,
# Rounded, Subnormal, FloatOperation all True.
# decimal.__dict__.__len__() == 49.
# decimal.__dict__.__class__.__name__ == 'dict'.
# ---------------------------------------------------------------------------

table decimal_extra146.dict_contains_exceptions:
  description: "decimal.__dict__.__contains__: exception types DecimalException/InvalidOperation/Overflow/Underflow/Inexact/Rounded/Subnormal are all True; __len__()==49"
  kind: python_call_eq
  category: dict_membership
  id_prefix: decdict146

  columns: [id, function, args, expected, description]
  rows:
    - [has_DecimalException,  __dict__.__contains__, ["DecimalException"],  true, "decimal.__dict__.__contains__('DecimalException') == True (decimal.DecimalException is the base exception class for all decimal arithmetic signals; subclasses can be trapped in Context.traps to raise exceptions on exceptional conditions)"]
    - [has_InvalidOperation,  __dict__.__contains__, ["InvalidOperation"],  true, "decimal.__dict__.__contains__('InvalidOperation') == True (decimal.InvalidOperation is raised for operations that are undefined or impossible, such as Decimal('inf') - Decimal('inf') or sqrt of a negative number)"]
    - [has_Overflow,          __dict__.__contains__, ["Overflow"],          true, "decimal.__dict__.__contains__('Overflow') == True (decimal.Overflow is raised when the result exceeds the context precision's Emax; the result is rounded to infinity or the largest finite value depending on the rounding mode)"]
    - [has_Underflow,         __dict__.__contains__, ["Underflow"],         true, "decimal.__dict__.__contains__('Underflow') == True (decimal.Underflow is raised when the result is subnormal and there is a loss of precision due to underflow)"]
    - [has_Inexact,           __dict__.__contains__, ["Inexact"],           true, "decimal.__dict__.__contains__('Inexact') == True (decimal.Inexact is raised when rounding is applied to the result because it cannot be represented exactly in the current precision)"]
    - [has_Rounded,           __dict__.__contains__, ["Rounded"],           true, "decimal.__dict__.__contains__('Rounded') == True (decimal.Rounded is raised when the result is rounded; unlike Inexact it is raised even when no digits are lost — e.g., when trailing zeros are removed)"]
    - [has_Subnormal,         __dict__.__contains__, ["Subnormal"],         true, "decimal.__dict__.__contains__('Subnormal') == True (decimal.Subnormal is raised when the result is subnormal before rounding, i.e. the exponent is smaller than Emin)"]
    - [dict_len,              __dict__.__len__,      [],                    49,   "decimal.__dict__.__len__() == 49 — the decimal module exports 49 names: 2 core classes (Decimal, Context), 8 rounding constants, 9 exception types, 3 context functions, 3 special Decimal singletons, and standard module dunder attributes"]
    - [dict_cls_eq,           __dict__.__class__.__name__.__eq__, ["dict"], true, "decimal.__dict__.__class__.__name__ == 'dict' (module __dict__ is a plain mutable dict; module-level dicts can be mutated at runtime unlike class __dict__ which is a read-only mappingproxy)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra146.dict.has_Decimal:
  description: "decimal.__dict__.__contains__('Decimal') == True — decimal.Decimal is the core numeric type of the decimal module; it uses decimal floating-point arithmetic to represent numbers exactly; Decimal('0.1') + Decimal('0.2') == Decimal('0.3') exactly, unlike binary float where 0.1 + 0.2 != 0.3"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Decimal"]
  expected: true

invariant decimal_extra146.dict.has_Context:
  description: "decimal.__dict__.__contains__('Context') == True — decimal.Context controls the decimal arithmetic environment for a thread; key attributes include prec (precision), rounding (rounding mode), Emin/Emax (exponent limits), and traps (a dict mapping signal classes to booleans controlling whether signals raise exceptions)"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Context"]
  expected: true

invariant decimal_extra146.dict.has_ROUND_UP:
  description: "decimal.__dict__.__contains__('ROUND_UP') == True — decimal.ROUND_UP is a string constant ('ROUND_UP') used as the rounding argument for Context and quantize(); it rounds away from zero for positive numbers and toward negative infinity for negative numbers"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra146.dict.has_InvalidOperation:
  description: "decimal.__dict__.__contains__('InvalidOperation') == True — decimal.InvalidOperation is the signal/exception for undefined operations; by default Context.traps[InvalidOperation] is True, so operations like Decimal('inf') - Decimal('inf') raise InvalidOperation rather than returning NaN silently"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra146.dict.has_localcontext:
  description: "decimal.__dict__.__contains__('localcontext') == True — decimal.localcontext() is a context manager that provides a copy of the given Context (or the current thread context if none is given) for the duration of the with block; ideal for temporarily changing precision or rounding mode without affecting other code"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["localcontext"]
  expected: true

invariant decimal_extra146.dict.has_ROUND_HALF_EVEN:
  description: "decimal.__dict__.__contains__('ROUND_HALF_EVEN') == True — decimal.ROUND_HALF_EVEN (banker rounding) is the default rounding mode for Python's decimal module; it rounds to nearest with ties going to the nearest even digit (2.5 -> 2, 3.5 -> 4); this minimizes cumulative rounding error across many operations"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra146.dict.len_49:
  description: "decimal.__dict__.__len__() == 49 — the decimal module exports 49 names at module level on Python 3.14.3; this covers 2 core classes (Decimal, Context), 8 rounding mode string constants (ROUND_UP through ROUND_05UP), 9 signal/exception classes, 3 context functions (getcontext, setcontext, localcontext), 3 special value constructors or constants, and standard dunder module attributes"
  category: dict_membership
  kind: python_call_eq
  function: __dict__.__len__
  args: []
  expected: 49
