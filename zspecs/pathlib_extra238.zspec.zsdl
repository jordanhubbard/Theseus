spec: pathlib_extra238
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.PurePath method __name__ contracts."
    - "pathlib.PurePath.__str__.__name__ == '__str__' — PurePath.__str__ method name; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__repr__.__name__ == '__repr__' — PurePath.__repr__ method name; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__truediv__.__name__ == '__truediv__' — PurePath.__truediv__ method name; length 11; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__rtruediv__.__name__ == '__rtruediv__' — PurePath.__rtruediv__ method name; length 12; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__eq__.__name__ == '__eq__' — PurePath.__eq__ method name; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__hash__.__name__ == '__hash__' — PurePath.__hash__ method name; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.is_absolute.__name__ == 'is_absolute' — PurePath.is_absolute method name; length 11; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.with_name.__name__ == 'with_name' — PurePath.with_name method name; length 9; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.with_suffix.__name__ == 'with_suffix' — PurePath.with_suffix method name; length 11; verified Python 3.14.3 macOS."
    - "pathlib.PurePath.__str__.__qualname__ == 'PurePath.__str__' — verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath dunder method __name__ contracts
# __str__, __repr__, __truediv__, __rtruediv__, __eq__, __hash__
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table pathlib_extra238.PurePath_dunder_method_names:
  description: "pathlib.PurePath dunder method __name__ contracts — __str__, __repr__, __truediv__, __rtruediv__, __eq__, __hash__; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_name
  id_prefix: plpuredundermnames238

  columns: [id, function, args, expected]
  rows:
    - [purepath_str_name,       PurePath.__str__.__name__.__eq__,       ["__str__"],       true]
    - [purepath_repr_name,      PurePath.__repr__.__name__.__eq__,      ["__repr__"],      true]
    - [purepath_truediv_name,   PurePath.__truediv__.__name__.__eq__,   ["__truediv__"],   true]
    - [purepath_rtruediv_name,  PurePath.__rtruediv__.__name__.__eq__,  ["__rtruediv__"],  true]
    - [purepath_eq_name,        PurePath.__eq__.__name__.__eq__,        ["__eq__"],        true]
    - [purepath_hash_name,      PurePath.__hash__.__name__.__eq__,      ["__hash__"],      true]

# ---------------------------------------------------------------------------
# pathlib.PurePath regular method __name__ contracts
# is_absolute, with_name, with_suffix carry their plain names.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra238.PurePath.is_absolute.name:
  description: "pathlib.PurePath.is_absolute.__name__ == 'is_absolute' — PurePath.is_absolute method name is 'is_absolute'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: PurePath.is_absolute.__name__.__eq__
  args: ["is_absolute"]
  expected: true

invariant pathlib_extra238.PurePath.with_name.name:
  description: "pathlib.PurePath.with_name.__name__ == 'with_name' — PurePath.with_name method name is 'with_name'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: PurePath.with_name.__name__.__eq__
  args: ["with_name"]
  expected: true

invariant pathlib_extra238.PurePath.with_suffix.name:
  description: "pathlib.PurePath.with_suffix.__name__ == 'with_suffix' — PurePath.with_suffix method name is 'with_suffix'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: PurePath.with_suffix.__name__.__eq__
  args: ["with_suffix"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib.PurePath method name length contracts
# Spot-check selected method name lengths.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant pathlib_extra238.PurePath.is_absolute.name_length:
  description: "pathlib.PurePath.is_absolute.__name__.__len__() == 11 — 'is_absolute' has 11 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: PurePath.is_absolute.__name__.__len__
  args: []
  expected: 11

invariant pathlib_extra238.PurePath.with_suffix.name_length:
  description: "pathlib.PurePath.with_suffix.__name__.__len__() == 11 — 'with_suffix' has 11 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: PurePath.with_suffix.__name__.__len__
  args: []
  expected: 11

invariant pathlib_extra238.PurePath.__str__.qualname:
  description: "pathlib.PurePath.__str__.__qualname__ == 'PurePath.__str__' — verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: PurePath.__str__.__qualname__.__eq__
  args: ["PurePath.__str__"]
  expected: true
