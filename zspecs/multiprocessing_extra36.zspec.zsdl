spec: multiprocessing_extra36
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra35.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() for Pool/Queue/Lock/Event/Semaphore/Barrier, Process method __qualname__.__len__() for start/run/join/terminate/is_alive/kill, Pool method __qualname__.__len__() tables (extra34), Pool method __name__.__len__() tables (extra35), AuthenticationError/ProcessError/BufferTooShort __bases__[0].__name__, Process/Pool/__mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__.__len__() tables, DefaultContext method qualname lengths, BaseProcess class metadata, Process/__init__.__qualname__.__len__()==20, cpu_count/__name__.__len__()==9, current_process/__name__.__len__()==15, active_children/__qualname__.__len__()==15, active_children/__name__.__len__()==15, parent_process/__name__.__len__()==14, get_start_method/__name__.__len__()==16, set_start_method/__name__.__len__()==16, synchronize.Lock/Event/Semaphore identity and hierarchy."
    - "This spec covers: pool.ApplyResult/__name__.__len__()==11; pool.MapResult/__name__.__len__()==9; pool.IMapIterator/__name__.__len__()==12; pool.IMapUnorderedIterator/__name__.__len__()==21; pool.ApplyResult/__qualname__.__len__()==11; pool.MapResult/__qualname__.__len__()==9; pool.IMapIterator/__qualname__.__len__()==12; pool.IMapUnorderedIterator/__qualname__.__len__()==21; pool.ApplyResult/__module__.__len__()==20; pool.MapResult/__module__.__len__()==20; pool.IMapIterator/__module__.__len__()==20; pool.IMapUnorderedIterator/__module__.__len__()==20; pool.ApplyResult/__mro__.__len__()==2; pool.MapResult/__mro__.__len__()==3; pool.IMapIterator/__mro__.__len__()==2; pool.IMapUnorderedIterator/__mro__.__len__()==3."
    - "ApplyResult, MapResult, IMapIterator, and IMapUnorderedIterator are the result and iterator classes returned by Pool's async methods. AsyncResult is an alias for ApplyResult (AsyncResult is ApplyResult == True), so AsyncResult.__name__ == 'ApplyResult'. No prior multiprocessing spec has measured any of these class metadata values as integer invariants."
    - "pool.IMapUnorderedIterator.__name__ == 'IMapUnorderedIterator' (21 chars) — the longest class name in multiprocessing.pool. The 'IMap' prefix (4 chars) indicates an iterator-map, 'Unordered' (9 chars) specifies unordered delivery, and 'Iterator' (8 chars) is the suffix. Total: 4+9+8 = 21."
    - "pool.ApplyResult and pool.IMapIterator both have __mro__.__len__() == 2 (class + object only); pool.MapResult and pool.IMapUnorderedIterator both have __mro__.__len__() == 3 (reflecting an additional base class in the hierarchy)."
    - "All four pool result classes share __module__ == 'multiprocessing.pool' (20 chars). The string 'multiprocessing.pool' has 20 chars: 'multiprocessing' (15) + '.' (1) + 'pool' (4) = 20."
    - "For top-level classes, __qualname__ equals __name__, so pool.ApplyResult/__qualname__.__len__() == pool.ApplyResult/__name__.__len__() == 11. Each result class is top-level in multiprocessing.pool."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool result class __name__.__len__() — extra36 namespace
#
# Pool's async methods return result/iterator objects of these classes:
#   pool.ApplyResult.__name__            == 'ApplyResult'            (11 chars)
#   pool.MapResult.__name__              == 'MapResult'              ( 9 chars)
#   pool.IMapIterator.__name__           == 'IMapIterator'           (12 chars)
#   pool.IMapUnorderedIterator.__name__  == 'IMapUnorderedIterator'  (21 chars)
# IMapUnorderedIterator (21) is by far the longest class name in multiprocessing.pool.
# AsyncResult is just an alias for ApplyResult, so AsyncResult.__name__ == 'ApplyResult' (11).
# No prior multiprocessing spec has measured any of these __name__.__len__() values.
# ---------------------------------------------------------------------------

table multiprocessing_extra36.pool_result_class_name_lengths:
  description: "multiprocessing.pool result class __name__.__len__() in extra36 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: poolresclassnamelen36

  columns: [id, function, args, expected, description]
  rows:
    - [MapResult,              "pool.MapResult.__name__.__len__",             [], 9,  "'MapResult' is 9 characters"]
    - [ApplyResult,            "pool.ApplyResult.__name__.__len__",           [], 11, "'ApplyResult' is 11 characters — AsyncResult is an alias for this class"]
    - [IMapIterator,           "pool.IMapIterator.__name__.__len__",          [], 12, "'IMapIterator' is 12 characters"]
    - [IMapUnorderedIterator,  "pool.IMapUnorderedIterator.__name__.__len__", [], 21, "'IMapUnorderedIterator' is 21 characters — the longest pool class name"]

# ---------------------------------------------------------------------------
# multiprocessing.pool result class __module__.__len__() — extra36 namespace
#
# All four result classes share the same __module__:
#   pool.ApplyResult.__module__           == 'multiprocessing.pool' (20 chars)
#   pool.MapResult.__module__             == 'multiprocessing.pool' (20 chars)
#   pool.IMapIterator.__module__          == 'multiprocessing.pool' (20 chars)
#   pool.IMapUnorderedIterator.__module__ == 'multiprocessing.pool' (20 chars)
# 'multiprocessing.pool' = 'multiprocessing' (15) + '.' (1) + 'pool' (4) = 20 chars.
# This shared module length (20) distinguishes these classes from the public
# multiprocessing.Pool class (which resolves through context, module len 23).
# No prior multiprocessing spec has measured pool result class __module__.__len__().
# ---------------------------------------------------------------------------

table multiprocessing_extra36.pool_result_class_module_lengths:
  description: "multiprocessing.pool result class __module__.__len__() in extra36 namespace — all equal 20"
  kind: python_call_eq
  category: module_names
  id_prefix: poolresclassmodlen36

  columns: [id, function, args, expected, description]
  rows:
    - [ApplyResult,           "pool.ApplyResult.__module__.__len__",           [], 20, "'multiprocessing.pool' is 20 characters"]
    - [MapResult,             "pool.MapResult.__module__.__len__",             [], 20, "'multiprocessing.pool' is 20 characters — same as ApplyResult"]
    - [IMapIterator,          "pool.IMapIterator.__module__.__len__",          [], 20, "'multiprocessing.pool' is 20 characters — same as ApplyResult"]
    - [IMapUnorderedIterator, "pool.IMapUnorderedIterator.__module__.__len__", [], 20, "'multiprocessing.pool' is 20 characters — same as ApplyResult"]

# ---------------------------------------------------------------------------
# multiprocessing.pool result class __mro__.__len__() — extra36 namespace
#
# ApplyResult and IMapIterator have shallower MRO (depth 2 = class + object);
# MapResult and IMapUnorderedIterator have deeper MRO (depth 3, reflecting an
# additional base class in the hierarchy):
#   pool.ApplyResult.__mro__.__len__()           == 2
#   pool.IMapIterator.__mro__.__len__()          == 2
#   pool.MapResult.__mro__.__len__()             == 3
#   pool.IMapUnorderedIterator.__mro__.__len__() == 3
# The MRO depth reveals inheritance structure: MapResult and IMapUnorderedIterator
# each inherit from a base iterator class, while ApplyResult and IMapIterator
# directly subclass object.
# No prior multiprocessing spec has measured pool result class MRO depths.
# ---------------------------------------------------------------------------

table multiprocessing_extra36.pool_result_class_mro_lengths:
  description: "multiprocessing.pool result class __mro__.__len__() in extra36 namespace — MRO depth reveals inheritance structure"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: poolresclassmrolen36

  columns: [id, function, args, expected, description]
  rows:
    - [ApplyResult,           "pool.ApplyResult.__mro__.__len__",           [], 2, "MRO depth 2: ApplyResult -> object"]
    - [IMapIterator,          "pool.IMapIterator.__mro__.__len__",          [], 2, "MRO depth 2: IMapIterator -> object"]
    - [MapResult,             "pool.MapResult.__mro__.__len__",             [], 3, "MRO depth 3: MapResult -> (base class) -> object"]
    - [IMapUnorderedIterator, "pool.IMapUnorderedIterator.__mro__.__len__", [], 3, "MRO depth 3: IMapUnorderedIterator -> IMapIterator -> object"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra36
# ---------------------------------------------------------------------------

invariant multiprocessing_extra36.pool_IMapUnorderedIterator_name_len:
  description: "multiprocessing.pool.IMapUnorderedIterator.__name__.__len__() == 21 — 'IMapUnorderedIterator' has 21 characters; the longest class name in multiprocessing.pool"
  category: class_names
  kind: python_call_eq
  function: "pool.IMapUnorderedIterator.__name__.__len__"
  args: []
  expected: 21

invariant multiprocessing_extra36.pool_ApplyResult_module_len:
  description: "multiprocessing.pool.ApplyResult.__module__.__len__() == 20 — 'multiprocessing.pool' has 20 characters; 3 shorter than the context-bound classes (23)"
  category: module_names
  kind: python_call_eq
  function: "pool.ApplyResult.__module__.__len__"
  args: []
  expected: 20

invariant multiprocessing_extra36.pool_MapResult_mro_len:
  description: "multiprocessing.pool.MapResult.__mro__.__len__() == 3 — MapResult has a depth-3 MRO, unlike ApplyResult and IMapIterator (depth 2)"
  category: class_hierarchy
  kind: python_call_eq
  function: "pool.MapResult.__mro__.__len__"
  args: []
  expected: 3
