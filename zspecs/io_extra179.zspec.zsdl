invariant io_extra179.IOBase_mro_len_is_3:
  description: "io.IOBase.__mro__.__len__() == 3 — io.IOBase.__mro__ is ['IOBase', '_IOBase', 'object']: the root I/O ABC, its C-level implementation, and object; IOBase (3) is the minimum MRO length in this spec; IOBase (3) < TextIOWrapper (4) = BytesIO (4) < RawIOBase (5) = BufferedIOBase (5) = TextIOBase (5); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.IOBase.__mro__.__len__
  args: []
  expected: 3

invariant io_extra179.RawIOBase_mro_len_is_5:
  description: "io.RawIOBase.__mro__.__len__() == 5 — chain: RawIOBase > _RawIOBase > IOBase > _IOBase > object; RawIOBase (5) == BufferedIOBase (5) == TextIOBase (5): three-way tie at 5 for IOBase-derived ABCs; RawIOBase (5) > IOBase (3) by 2: each level adds a Python ABC + C impl pair; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.RawIOBase.__mro__.__len__
  args: []
  expected: 5

invariant io_extra179.BufferedIOBase_mro_len_is_5:
  description: "io.BufferedIOBase.__mro__.__len__() == 5 — chain: BufferedIOBase > _BufferedIOBase > IOBase > _IOBase > object; BufferedIOBase (5) == RawIOBase (5) == TextIOBase (5): three-way tie at 5; BufferedIOBase (5) > BytesIO (4) by 1: the ABC has a longer MRO than the concrete class that implements it; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BufferedIOBase.__mro__.__len__
  args: []
  expected: 5

invariant io_extra179.TextIOBase_mro_len_is_5:
  description: "io.TextIOBase.__mro__.__len__() == 5 — chain: TextIOBase > _TextIOBase > IOBase > _IOBase > object; TextIOBase (5) == RawIOBase (5) == BufferedIOBase (5): three-way tie; TextIOBase (5) > TextIOWrapper (4) by 1: the ABC is longer than its concrete class — inversion because TextIOWrapper bypasses Python-level ABCs; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.TextIOBase.__mro__.__len__
  args: []
  expected: 5

invariant io_extra179.TextIOWrapper_mro_len_is_4:
  description: "io.TextIOWrapper.__mro__.__len__() == 4 — chain: TextIOWrapper > _TextIOBase > _IOBase > object; TextIOWrapper (4) == BytesIO (4): two-way tie at 4 for concrete stream classes; TextIOWrapper inherits from C-level classes only, bypassing Python-level ABCs; TextIOWrapper (4) < TextIOBase (5) by 1: the concrete class has a shorter MRO than the ABC; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.TextIOWrapper.__mro__.__len__
  args: []
  expected: 4

invariant io_extra179.BytesIO_mro_len_is_4:
  description: "io.BytesIO.__mro__.__len__() == 4 — chain: BytesIO > _BufferedIOBase > _IOBase > object; BytesIO (4) == TextIOWrapper (4): two-way tie at 4; BytesIO inherits from '_BufferedIOBase' (C), bypassing the Python-level BufferedIOBase ABC; BytesIO (4) < BufferedIOBase (5) by 1: same inversion as TextIOWrapper vs TextIOBase; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.BytesIO.__mro__.__len__
  args: []
  expected: 4

invariant io_extra179.mro_ordering_IOBase_lt_concrete:
  description: "io.IOBase.__mro__.__len__() == 3 — confirming the MRO ordering: IOBase(3) < TextIOWrapper(4)=BytesIO(4) < RawIOBase(5)=BufferedIOBase(5)=TextIOBase(5); the root ABC (3) is shorter than the concrete classes (4) which are shorter than the derived ABCs (5); this counter-intuitive ordering (ABCs longer than concrete classes) arises because concrete classes bypass Python-level ABCs and inherit C-level classes directly; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.IOBase.__mro__.__len__
  args: []
  expected: 3

