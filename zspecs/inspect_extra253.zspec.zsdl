invariant inspect_extra253.getmodule.module_eq:
  description: "inspect.getmodule.__module__ == 'inspect' — defined in the inspect module; new to extra253"
  category: identity
  kind: python_call_eq
  function: getmodule.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra253.getdoc.name_eq:
  description: "inspect.getdoc.__name__ == 'getdoc' — pure Python function returning the cleaned docstring for an object; new to extra253"
  category: identity
  kind: python_call_eq
  function: getdoc.__name__.__eq__
  args: ["getdoc"]
  expected: true

invariant inspect_extra253.getdoc.module_eq:
  description: "inspect.getdoc.__module__ == 'inspect' — defined in the inspect module; new to extra253"
  category: identity
  kind: python_call_eq
  function: getdoc.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra253.getcomments.name_eq:
  description: "inspect.getcomments.__name__ == 'getcomments' — pure Python function returning comment lines preceding an object definition; new to extra253"
  category: identity
  kind: python_call_eq
  function: getcomments.__name__.__eq__
