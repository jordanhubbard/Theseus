spec: inspect_extra253
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.getsource, inspect.getsourcelines, inspect.getsourcefile, inspect.getfile, inspect.getmodule, inspect.getdoc, inspect.getcomments, inspect.cleandoc function identity behavioral contracts."
    - "inspect.getsource.__name__ == 'getsource' — getsource is a pure Python function returning the source text of an object. Verified with Python 3.14.3."
    - "inspect.getsource.__module__ == 'inspect' — getsource is defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getsource.__class__.__name__ == 'function' — getsource is a regular Python function object. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__name__ == 'getsourcelines' — getsourcelines returns source lines and starting line number. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__module__ == 'inspect' — getsourcelines is defined in the inspect module. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__name__ == 'getsourcefile' — getsourcefile returns the Python source file for an object. Verified with Python 3.14.3."
    - "inspect.getfile.__name__ == 'getfile' — getfile returns the file in which an object was defined. Verified with Python 3.14.3."
    - "inspect.getmodule.__name__ == 'getmodule' — getmodule infers the module from which an object was imported. Verified with Python 3.14.3."
    - "inspect.getdoc.__name__ == 'getdoc' — getdoc returns the cleaned docstring for an object. Verified with Python 3.14.3."
    - "inspect.getcomments.__name__ == 'getcomments' — getcomments returns lines of comments preceding an object definition. Verified with Python 3.14.3."
    - "inspect.cleandoc.__name__ == 'cleandoc' — cleandoc trims indentation from a docstring. Verified with Python 3.14.3."
    - "inspect.cleandoc.__class__.__name__ == 'function' — cleandoc is a regular Python function object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getsource and inspect.getsourcelines function identity
#
# inspect.getsource.__name__ == 'getsource'
# inspect.getsource.__module__ == 'inspect'
# inspect.getsource.__class__.__name__ == 'function'
# inspect.getsourcelines.__name__ == 'getsourcelines'
# inspect.getsourcelines.__module__ == 'inspect'
#
# Both are pure Python functions for retrieving source code from live
# objects. New to extra253.
# ---------------------------------------------------------------------------

table inspect_extra253.getsource_getsourcelines_identity:
  description: "inspect.getsource and inspect.getsourcelines __name__, __module__, __class__.__name__ identity contracts; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsrc253

  columns: [id, function, args, expected, description]
  rows:
    - [getsource_name_eq,
       getsource.__name__.__eq__,
       ["getsource"],
       true,
       "inspect.getsource.__name__.__eq__('getsource') == True — getsource is a pure Python function returning source text of an object; __name__ is 'getsource'; new to extra253"]
    - [getsource_module_eq,
       getsource.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsource.__module__.__eq__('inspect') == True — getsource is defined in the inspect module; __module__ is 'inspect'; new to extra253"]
    - [getsource_class_eq,
       getsource.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getsource.__class__.__name__.__eq__('function') == True — getsource is a regular Python function; __class__.__name__ is 'function'; new to extra253"]
    - [getsourcelines_name_eq,
       getsourcelines.__name__.__eq__,
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__name__.__eq__('getsourcelines') == True — getsourcelines returns source lines and starting line number for an object; __name__ is 'getsourcelines'; new to extra253"]
    - [getsourcelines_module_eq,
       getsourcelines.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsourcelines.__module__.__eq__('inspect') == True — getsourcelines is defined in the inspect module; __module__ is 'inspect'; new to extra253"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getsourcefile, inspect.getfile, inspect.getmodule identity
#
# inspect.getsourcefile.__name__ == 'getsourcefile'
# inspect.getsourcefile.__module__ == 'inspect'
# inspect.getfile.__name__ == 'getfile'
# inspect.getmodule.__name__ == 'getmodule'
# inspect.getfile.__class__.__name__ == 'function'
#
# All three are pure Python functions for locating the source or file
# origin of live objects. New to extra253.
# ---------------------------------------------------------------------------

table inspect_extra253.getsourcefile_getfile_getmodule_identity:
  description: "inspect.getsourcefile, inspect.getfile, inspect.getmodule __name__, __module__, __class__.__name__ identity contracts; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: inspectfile253

  columns: [id, function, args, expected, description]
  rows:
    - [getsourcefile_name_eq,
       getsourcefile.__name__.__eq__,
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__name__.__eq__('getsourcefile') == True — getsourcefile returns the Python source file for an object; __name__ is 'getsourcefile'; new to extra253"]
    - [getsourcefile_module_eq,
       getsourcefile.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsourcefile.__module__.__eq__('inspect') == True — getsourcefile is defined in the inspect module; __module__ is 'inspect'; new to extra253"]
    - [getfile_name_eq,
       getfile.__name__.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__name__.__eq__('getfile') == True — getfile returns the file in which an object was defined; __name__ is 'getfile'; new to extra253"]
    - [getfile_class_eq,
       getfile.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getfile.__class__.__name__.__eq__('function') == True — getfile is a regular Python function; __class__.__name__ is 'function'; new to extra253"]
    - [getmodule_name_eq,
       getmodule.__name__.__eq__,
       ["getmodule"],
       true,
       "inspect.getmodule.__name__.__eq__('getmodule') == True — getmodule infers the module from which an object was imported; __name__ is 'getmodule'; new to extra253"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getdoc, inspect.getcomments, inspect.cleandoc identity
#
# inspect.getdoc.__name__ == 'getdoc'
# inspect.getdoc.__module__ == 'inspect'
# inspect.getcomments.__name__ == 'getcomments'
# inspect.cleandoc.__name__ == 'cleandoc'
# inspect.cleandoc.__class__.__name__ == 'function'
#
# All three are pure Python functions for retrieving and cleaning
# documentation and comments from live objects. New to extra253.
# ---------------------------------------------------------------------------

table inspect_extra253.getdoc_getcomments_cleandoc_identity:
  description: "inspect.getdoc, inspect.getcomments, inspect.cleandoc __name__, __module__, __class__.__name__ identity contracts; new to extra253"
  kind: python_call_eq
  category: identity
  id_prefix: inspectdoc253

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_name_eq,
       getdoc.__name__.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__name__.__eq__('getdoc') == True — getdoc returns the cleaned docstring for an object; __name__ is 'getdoc'; new to extra253"]
    - [getdoc_module_eq,
       getdoc.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getdoc.__module__.__eq__('inspect') == True — getdoc is defined in the inspect module; __module__ is 'inspect'; new to extra253"]
    - [getcomments_name_eq,
       getcomments.__name__.__eq__,
       ["getcomments"],
       true,
       "inspect.getcomments.__name__.__eq__('getcomments') == True — getcomments returns lines of comments preceding an object definition; __name__ is 'getcomments'; new to extra253"]
    - [cleandoc_name_eq,
       cleandoc.__name__.__eq__,
       ["cleandoc"],
       true,
       "inspect.cleandoc.__name__.__eq__('cleandoc') == True — cleandoc trims indentation and leading/trailing blank lines from a docstring; __name__ is 'cleandoc'; new to extra253"]
    - [cleandoc_class_eq,
       cleandoc.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.cleandoc.__class__.__name__.__eq__('function') == True — cleandoc is a regular Python function; __class__.__name__ is 'function'; new to extra253"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra253
# ---------------------------------------------------------------------------

invariant inspect_extra253.getsource.name_eq:
  description: "inspect.getsource.__name__ == 'getsource' — pure Python function returning the source text of a live object; new to extra253"
  category: identity
  kind: python_call_eq
  function: getsource.__name__.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra253.getsource.module_eq:
  description: "inspect.getsource.__module__ == 'inspect' — defined in the inspect module; new to extra253"
  category: identity
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra253.getsource.class_is_function:
  description: "inspect.getsource.__class__.__name__ == 'function' — getsource is a regular Python function object; new to extra253"
  category: identity
  kind: python_call_eq
  function: getsource.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra253.getsourcelines.name_eq:
  description: "inspect.getsourcelines.__name__ == 'getsourcelines' — pure Python function returning source lines and line number for an object; new to extra253"
  category: identity
  kind: python_call_eq
  function: getsourcelines.__name__.__eq__
  args: ["getsourcelines"]
  expected: true

invariant inspect_extra253.getsourcelines.module_eq:
  description: "inspect.getsourcelines.__module__ == 'inspect' — defined in the inspect module; new to extra253"
  category: identity
  kind: python_call_eq
  function: getsourcelines.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra253.getsourcefile.name_eq:
  description: "inspect.getsourcefile.__name__ == 'getsourcefile' — pure Python function returning the source file path for an object; new to extra253"
  category: identity
  kind: python_call_eq
  function: getsourcefile.__name__.__eq__
  args: ["getsourcefile"]
  expected: true

invariant inspect_extra253.getsourcefile.module_eq:
  description: "inspect.getsourcefile.__module__ == 'inspect' — defined in the inspect module; new to extra253"
  category: identity
  kind: python_call_eq
  function: getsourcefile.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra253.getfile.name_eq:
  description: "inspect.getfile.__name__ == 'getfile' — pure Python function returning the file in which an object was defined; new to extra253"
  category: identity
  kind: python_call_eq
  function: getfile.__name__.__eq__
  args: ["getfile"]
  expected: true

invariant inspect_extra253.getfile.module_eq:
  description: "inspect.getfile.__module__ == 'inspect' — defined in the inspect module; new to extra253"
  category: identity
  kind: python_call_eq
  function: getfile.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra253.getmodule.name_eq:
  description: "inspect.getmodule.__name__ == 'getmodule' — pure Python function inferring the module from which an object was imported; new to extra253"
  category: identity
  kind: python_call_eq
  function: getmodule.__name__.__eq__
  args: ["getmodule"]
