spec: re_extra79
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra78."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error.__name__ == 'PatternError'; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ string lengths and values; PatternError hierarchy."
    - "re_extra78 covers Pattern/__dict__ membership for match/search/findall/sub/split; Match/__dict__ membership for group/groups/span; PatternError MRO length and base class; PatternError.__module__."
    - "This spec covers: re.compile/__qualname__ and __module__; re.match/sub/findall/split __qualname__ values; Match.start/__class__.__name__ == 'method_descriptor'; Match.end/__class__.__name__ == 'method_descriptor'; Match.start/__qualname__ == 'Match.start'; Match.end/__qualname__ == 'Match.end'; Match.start/__qualname__.__len__() and Match.end/__qualname__.__len__()."
    - "re.compile.__qualname__ == 'compile' — module-level function; __qualname__ matches __name__."
    - "re.compile.__module__ == 're' — defined in the re package."
    - "re.match.__qualname__ == 'match' — module-level function in re."
    - "re.sub.__qualname__ == 'sub' — module-level function in re."
    - "re.findall.__qualname__ == 'findall' — module-level function in re."
    - "re.split.__qualname__ == 'split' — module-level function in re."
    - "re.Match.start.__class__.__name__ == 'method_descriptor' — Match.start is a C method_descriptor."
    - "re.Match.end.__class__.__name__ == 'method_descriptor' — Match.end is a C method_descriptor."
    - "re.Match.start.__qualname__ == 'Match.start' — qualname length is 11."
    - "re.Match.end.__qualname__ == 'Match.end' — qualname length is 9."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level function __qualname__ and __module__
# re.compile, re.match, re.sub, re.findall, re.split are Python functions
# defined in the re package. Their __qualname__ equals their bare name, and
# __module__ == 're'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra79.module_func_qualname:
  description: "re module function __qualname__ values"
  kind: python_call_eq
  category: func_identity
  id_prefix: remore79

  columns: [id, function, args, expected]
  rows:
    - [compile_qualname, compile.__qualname__.__eq__, ["compile"], true]
    - [match_qualname,   match.__qualname__.__eq__,   ["match"],   true]
    - [sub_qualname,     sub.__qualname__.__eq__,      ["sub"],    true]
    - [findall_qualname, findall.__qualname__.__eq__, ["findall"], true]
    - [split_qualname,   split.__qualname__.__eq__,   ["split"],   true]

# ---------------------------------------------------------------------------
# re.compile __module__
# re.compile is defined in the re package; its __module__ == 're'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra79.compile_module:
  description: "re.compile.__module__ == 're'"
  kind: python_call_eq
  category: func_identity
  id_prefix: remore79

  columns: [id, function, args, expected]
  rows:
    - [compile_module, compile.__module__.__eq__, ["re"], true]

# ---------------------------------------------------------------------------
# Match.start and Match.end class name
# Match.start and Match.end are C method_descriptors in the _sre extension.
# Their __class__.__name__ == 'method_descriptor'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra79.Match_start_end_class:
  description: "Match.start and Match.end __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: class_identity
  id_prefix: remore79

  columns: [id, function, args, expected]
  rows:
    - [start_cls, Match.start.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [end_cls,   Match.end.__class__.__name__.__eq__,   ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# Match.start and Match.end __qualname__ values and lengths
# Match.start.__qualname__ == 'Match.start' (length 11).
# Match.end.__qualname__ == 'Match.end' (length 9).
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra79.Match_start_end_qualname:
  description: "Match.start and Match.end __qualname__ values and lengths"
  kind: python_call_eq
  category: qualname_values
  id_prefix: remore79

  columns: [id, function, args, expected]
  rows:
    - [start_qualname,     Match.start.__qualname__.__eq__,     ["Match.start"], true]
    - [start_qualname_len, Match.start.__qualname__.__len__,    [],              11]
    - [end_qualname,       Match.end.__qualname__.__eq__,       ["Match.end"],   true]
    - [end_qualname_len,   Match.end.__qualname__.__len__,      [],              9]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra79.compile.qualname:
  description: "re.compile.__qualname__ == 'compile'"
  category: func_identity
  kind: python_call_eq
  function: compile.__qualname__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra79.compile.module:
  description: "re.compile.__module__ == 're'"
  category: func_identity
  kind: python_call_eq
  function: compile.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra79.Match_start.class_name:
  description: "re.Match.start.__class__.__name__ == 'method_descriptor'"
  category: class_identity
  kind: python_call_eq
  function: Match.start.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra79.Match_end.qualname:
  description: "re.Match.end.__qualname__ == 'Match.end'"
  category: qualname_values
  kind: python_call_eq
  function: Match.end.__qualname__.__eq__
  args: ["Match.end"]
  expected: true

invariant re_extra79.Match_end.qualname_len:
  description: "re.Match.end.__qualname__.__len__() == 9 ('Match.end' = 9 chars)"
  category: qualname_values
  kind: python_call_eq
  function: Match.end.__qualname__.__len__
  args: []
  expected: 9
