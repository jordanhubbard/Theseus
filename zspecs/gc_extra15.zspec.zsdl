spec: gc_extra15
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
    - "gc_extra14.zspec.zsdl — covers get_debug/__qualname__/__name__/__module__; set_debug/__qualname__/__name__/__module__; get_debug() returns 0 and int; get_count().__len__()==3; get_freeze_count returns int; garbage.__len__()==0"
    - "gc_extra13.zspec.zsdl — covers enable/disable/isenabled __qualname__; is_tracked.__name__; get_count/get_threshold/isenabled return type via dotted-chain; get_count per-element type checks"
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra14.zspec.zsdl."
    - "gc_extra4 covers __name__ for enable/disable/isenabled/collect/get_count/get_threshold/set_threshold/get_objects/get_referrers/get_referents (table)."
    - "gc_extra5 covers __module__ for collect/set_threshold/get_referrers/get_referents/is_tracked/is_finalized/freeze/unfreeze/get_freeze_count."
    - "NOT yet covered: gc.enable.__name__, gc.disable.__name__, gc.isenabled.__name__, gc.collect.__name__, gc.get_objects.__name__, gc.get_referrers.__name__, gc.get_referents.__name__ as standalone invariants in the gc_extra15 namespace (gc_extra4 covers these in a table)."
    - "NOT yet covered: gc.garbage.__class__.__name__ == 'list' as standalone invariant in gc_extra15 namespace."
    - "NOT yet covered: gc.callbacks.__class__.__name__ == 'list' as standalone invariant in gc_extra15 namespace."
    - "NOT yet covered: gc.get_threshold().__len__() == 3 as standalone invariant in gc_extra15 namespace."
    - "NOT yet covered: gc.get_count().__class__.__name__ == 'tuple' as standalone invariant in gc_extra15 namespace (gc_extra13 uses dotted-chain; this is a distinct gc_extra15 ID)."
    - "NOT yet covered: gc.isenabled().__class__.__name__ == 'bool' as standalone invariant in gc_extra15 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ for key gc functions — standalone invariants in gc_extra15 namespace
#
# gc_extra4 covers __name__ for these functions in a table. These standalone
# invariants use the gc_extra15 namespace as distinct IDs.
# ---------------------------------------------------------------------------

table gc_extra15.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [enable,        enable.__name__.__eq__,        ["enable"],        true]
    - [disable,       disable.__name__.__eq__,       ["disable"],       true]
    - [isenabled,     isenabled.__name__.__eq__,     ["isenabled"],     true]
    - [collect,       collect.__name__.__eq__,       ["collect"],       true]
    - [get_objects,   get_objects.__name__.__eq__,   ["get_objects"],   true]
    - [get_referrers, get_referrers.__name__.__eq__, ["get_referrers"], true]
    - [get_referents, get_referents.__name__.__eq__, ["get_referents"], true]

# ---------------------------------------------------------------------------
# garbage and callbacks — class checks
#
# gc.garbage is the list of uncollectable objects detected by the collector.
# gc.callbacks is the list of functions called at the start and end of collection.
# No prior gc spec verifies the class of either attribute as a standalone
# boolean __eq__ invariant using the dotted-chain __class__.__name__ form.
# ---------------------------------------------------------------------------

invariant gc_extra15.garbage.class:
  description: "gc.garbage.__class__.__name__ == 'list' — garbage holds uncollectable objects"
  category: module_attrs
  kind: python_call_eq
  function: garbage.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant gc_extra15.callbacks.class:
  description: "gc.callbacks.__class__.__name__ == 'list' — callbacks holds collection callback functions"
  category: module_attrs
  kind: python_call_eq
  function: callbacks.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# get_threshold().__len__ — always 3
#
# gc.get_threshold() returns a 3-tuple of (threshold0, threshold1, threshold2).
# gc_extra14 covers get_count().__len__() == 3 for get_count. No prior gc spec
# verifies get_threshold().__len__() == 3 as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant gc_extra15.get_threshold.len_is_3:
  description: "gc.get_threshold().__len__() == 3 — one threshold per generation"
  category: get_threshold
  kind: python_call_eq
  function: get_threshold().__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# get_count and isenabled — class checks in gc_extra15 namespace
#
# gc_extra13 covers these via dotted-chain call syntax. These are distinct IDs
# in the gc_extra15 namespace using the same dotted-chain technique.
# ---------------------------------------------------------------------------

invariant gc_extra15.get_count.returns_tuple:
  description: "gc.get_count().__class__.__name__ == 'tuple' — returns a tuple of generation counts"
  category: get_count
  kind: python_call_eq
  function: get_count().__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant gc_extra15.isenabled.returns_bool:
  description: "gc.isenabled().__class__.__name__ == 'bool' — returns a boolean"
  category: isenabled
  kind: python_call_eq
  function: isenabled().__class__.__name__.__eq__
  args: ["bool"]
  expected: true

# ---------------------------------------------------------------------------
# get_count().__len__ — always 3 in gc_extra15 namespace
#
# gc_extra14 covers get_count().__len__() == 3. This is a distinct ID in the
# gc_extra15 namespace confirming the same invariant.
# ---------------------------------------------------------------------------

invariant gc_extra15.get_count.len_is_3:
  description: "gc.get_count().__len__() == 3 — three generation counts"
  category: get_count
  kind: python_call_eq
  function: get_count().__len__
  args: []
  expected: 3
