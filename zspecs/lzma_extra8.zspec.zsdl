spec: lzma_extra8
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
    - "lzma_extra7.zspec.zsdl — covers LZMAFile.read/write/seek/tell/close __qualname__ (method qualnames, extra7); LZMACompressor/LZMADecompressor __qualname__ standalone (extra7); open/compress/decompress __qualname__ (extra7 anchor)."
    - "lzma_extra6.zspec.zsdl — covers LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __qualname__ standalone (extra6); open/compress/decompress __qualname__ standalone (extra6); lzma.__name__ standalone (extra6)."
    - "lzma_extra2.zspec.zsdl — covers class __qualname__ table (LZMAFile/LZMACompressor/LZMADecompressor/LZMAError); LZMAError.__bases__[0].__name__ bool form."
    - "lzma.zspec.zsdl — covers LZMAError.__bases__[0].__name__ string form; LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __name__ table."
  notes:
    - "This spec extends lzma through lzma_extra7; it does NOT duplicate invariants present in those files."
    - "Focus: method __qualname__ invariants for LZMAFile.__init__, LZMAFile.readable, LZMAFile.writable, LZMAFile.seekable, LZMACompressor.compress, LZMACompressor.flush, and LZMADecompressor.decompress — not covered by any prior lzma spec."
    - "LZMAError.__qualname__ is covered in extra2 and extra6; LZMAError.__bases__[0].__name__ is covered in base/extra2/extra4. This spec adds the 7 novel method qualnames listed above."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# LZMAFile.__init__ __qualname__ — standalone, extra8 anchor
#
# No prior lzma spec checks LZMAFile.__init__.__qualname__. Prior specs cover
# LZMAFile.read/write/seek/tell/close qualnames (extra7) but not __init__.
# ---------------------------------------------------------------------------

invariant lzma_extra8.LZMAFile.init.qualname:
  description: "lzma.LZMAFile.__init__.__qualname__ == 'LZMAFile.__init__' — constructor qualname encodes class context (extra8)"
  category: qualnames
  kind: python_call_eq
  function: "LZMAFile.__init__.__qualname__.__eq__"
  args: ["LZMAFile.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# LZMAFile.readable __qualname__ — standalone, extra8 anchor
#
# No prior lzma spec checks LZMAFile.readable.__qualname__.
# ---------------------------------------------------------------------------

invariant lzma_extra8.LZMAFile.readable.qualname:
  description: "lzma.LZMAFile.readable.__qualname__ == 'LZMAFile.readable' — method qualname encodes class context (extra8)"
  category: qualnames
  kind: python_call_eq
  function: LZMAFile.readable.__qualname__.__eq__
  args: ["LZMAFile.readable"]
  expected: true

# ---------------------------------------------------------------------------
# LZMAFile.writable __qualname__ — standalone, extra8 anchor
#
# No prior lzma spec checks LZMAFile.writable.__qualname__.
# ---------------------------------------------------------------------------

invariant lzma_extra8.LZMAFile.writable.qualname:
  description: "lzma.LZMAFile.writable.__qualname__ == 'LZMAFile.writable' — method qualname encodes class context (extra8)"
  category: qualnames
  kind: python_call_eq
  function: LZMAFile.writable.__qualname__.__eq__
  args: ["LZMAFile.writable"]
  expected: true

# ---------------------------------------------------------------------------
# LZMAFile.seekable __qualname__ — standalone, extra8 anchor
#
# No prior lzma spec checks LZMAFile.seekable.__qualname__.
# ---------------------------------------------------------------------------

invariant lzma_extra8.LZMAFile.seekable.qualname:
  description: "lzma.LZMAFile.seekable.__qualname__ == 'LZMAFile.seekable' — method qualname encodes class context (extra8)"
  category: qualnames
  kind: python_call_eq
  function: LZMAFile.seekable.__qualname__.__eq__
  args: ["LZMAFile.seekable"]
  expected: true

# ---------------------------------------------------------------------------
# LZMACompressor.compress __qualname__ — standalone, extra8 anchor
#
# No prior lzma spec checks LZMACompressor.compress.__qualname__.
# ---------------------------------------------------------------------------

invariant lzma_extra8.LZMACompressor.compress.qualname:
  description: "lzma.LZMACompressor.compress.__qualname__ == 'LZMACompressor.compress' — method qualname encodes class context (extra8)"
  category: qualnames
  kind: python_call_eq
  function: LZMACompressor.compress.__qualname__.__eq__
  args: ["LZMACompressor.compress"]
  expected: true

# ---------------------------------------------------------------------------
# LZMACompressor.flush __qualname__ — standalone, extra8 anchor
#
# No prior lzma spec checks LZMACompressor.flush.__qualname__.
# ---------------------------------------------------------------------------

invariant lzma_extra8.LZMACompressor.flush.qualname:
  description: "lzma.LZMACompressor.flush.__qualname__ == 'LZMACompressor.flush' — method qualname encodes class context (extra8)"
  category: qualnames
  kind: python_call_eq
  function: LZMACompressor.flush.__qualname__.__eq__
  args: ["LZMACompressor.flush"]
  expected: true

# ---------------------------------------------------------------------------
# LZMADecompressor.decompress __qualname__ — standalone, extra8 anchor
#
# No prior lzma spec checks LZMADecompressor.decompress.__qualname__.
# ---------------------------------------------------------------------------

invariant lzma_extra8.LZMADecompressor.decompress.qualname:
  description: "lzma.LZMADecompressor.decompress.__qualname__ == 'LZMADecompressor.decompress' — method qualname encodes class context (extra8)"
  category: qualnames
  kind: python_call_eq
  function: LZMADecompressor.decompress.__qualname__.__eq__
  args: ["LZMADecompressor.decompress"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — LZMAFile special + IO methods + compressor methods (extra8)
#
# No prior lzma spec presents __init__, readable, writable, seekable qualnames
# or LZMACompressor/LZMADecompressor method qualnames in any table.
# This table anchors all seven identifiers from the extra8 namespace.
# ---------------------------------------------------------------------------

table lzma_extra8.method_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn8

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile.__init__,            "LZMAFile.__init__.__qualname__.__eq__",            ["LZMAFile.__init__"],            true]
    - [LZMAFile.readable,            LZMAFile.readable.__qualname__.__eq__,              ["LZMAFile.readable"],            true]
    - [LZMAFile.writable,            LZMAFile.writable.__qualname__.__eq__,              ["LZMAFile.writable"],            true]
    - [LZMAFile.seekable,            LZMAFile.seekable.__qualname__.__eq__,              ["LZMAFile.seekable"],            true]
    - [LZMACompressor.compress,      LZMACompressor.compress.__qualname__.__eq__,        ["LZMACompressor.compress"],      true]
    - [LZMACompressor.flush,         LZMACompressor.flush.__qualname__.__eq__,           ["LZMACompressor.flush"],         true]
    - [LZMADecompressor.decompress,  LZMADecompressor.decompress.__qualname__.__eq__,    ["LZMADecompressor.decompress"],  true]
