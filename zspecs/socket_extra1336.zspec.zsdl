spec: socket_extra1336
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c and Lib/socket.py"
  notes:
    - "Wave 536 (_extra1336): focuses on __hash__ and __eq__ method class checks for socket types."
    - "socket.socket does not define its own __hash__ or __eq__; both are inherited from object."
    - "socket.__hash__.__class__.__name__ == 'wrapper_descriptor' — object's C-level slot."
    - "socket.__hash__.__qualname__ == 'object.__hash__' — no override in the socket Python class."
    - "socket.__eq__.__qualname__ == 'object.__eq__' — no custom equality in socket."
    - "socket.error is an alias for OSError; both __hash__ and __eq__ come from object."
    - "socket.timeout is a subclass of OSError; same wrapper_descriptor inheritance pattern."
    - "socket.AddressFamily is an int-based Enum; __hash__ is inherited from int, not Enum."
    - "AddressFamily.__hash__.__qualname__ == 'int.__hash__' — int subclass inherits int's C hash."
    - "AddressFamily.__eq__.__qualname__ == 'int.__eq__' — int subclass inherits int's C equality."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table socket_extra1336.socket_class_hash_eq_checks:
  description: "socket.socket class __hash__ and __eq__ inherited from object as wrapper_descriptors: class name and qualname checks"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: sk1336sh
  columns: [id, function, args, expected]
  rows:
    - [sk1336sh001, socket.socket.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [sk1336sh002, socket.socket.__hash__.__qualname__.__eq__,       ["object.__hash__"],    true]
    - [sk1336sh003, socket.socket.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [sk1336sh004, socket.socket.__eq__.__qualname__.__eq__,         ["object.__eq__"],      true]
    - [sk1336sh005, socket.socket.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [sk1336sh006, socket.socket.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]

