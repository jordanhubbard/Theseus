    - [sk1336eh001, socket.error.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [sk1336eh002, socket.error.__hash__.__qualname__.__eq__,         ["object.__hash__"],    true]
    - [sk1336eh003, socket.error.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true]
    - [sk1336eh004, socket.error.__eq__.__qualname__.__eq__,           ["object.__eq__"],      true]
    - [sk1336eh005, socket.timeout.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [sk1336eh006, socket.timeout.__hash__.__qualname__.__eq__,       ["object.__hash__"],    true]
    - [sk1336eh007, socket.timeout.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [sk1336eh008, socket.timeout.__eq__.__qualname__.__eq__,         ["object.__eq__"],      true]

table socket_extra1336.AddressFamily_int_hash_eq_checks:
