spec: os_path_extra9
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py"
  notes:
    - "This spec extends os_path.zspec.zsdl and os_path_extra through os_path_extra8.zspec.zsdl."
    - "os_path_extra8 covers expanduser/expandvars __name__/__qualname__; commonpath __name__/__qualname__; basename bare filename; dirname two-component; isabs dot-relative; normpath trailing slash; split empty string."
    - "os_path_extra7 covers __name__/__qualname__ for islink/getsize/realpath and splitext behavioral vectors."
    - "os_path_extra6 covers __qualname__ for join/split/basename/dirname/normpath/abspath."
    - "NOT yet covered: os.path.getatime.__name__, os.path.getatime.__qualname__."
    - "NOT yet covered: os.path.getmtime.__name__, os.path.getmtime.__qualname__."
    - "NOT yet covered: os.path.getctime.__name__, os.path.getctime.__qualname__."
    - "NOT yet covered: os.path.lexists.__name__, os.path.lexists.__qualname__."
    - "NOT yet covered: os.path.sameopenfile.__name__, os.path.sameopenfile.__qualname__."
    - "NOT yet covered: os.path.samestat.__name__, os.path.samestat.__qualname__."
    - "NOT yet covered: os.path.relpath.__name__, os.path.relpath.__qualname__."
    - "NOT yet covered: os.path.commonprefix on list with single element."
    - "NOT yet covered: os.path.commonpath on list with a shared parent."
    - "NOT yet covered: os.path.splitext on file with no extension (returns bare name + empty ext)."
    - "os.path.getatime.__name__ == 'getatime'."
    - "os.path.getmtime.__name__ == 'getmtime'."
    - "os.path.getctime.__name__ == 'getctime'."
    - "os.path.lexists.__name__ == 'lexists'."
    - "os.path.sameopenfile.__name__ == 'sameopenfile'."
    - "os.path.samestat.__name__ == 'samestat'."
    - "os.path.relpath.__name__ == 'relpath'."
    - "os.path.commonprefix(['/usr/lib']) == '/usr/lib' — single element is its own prefix."
    - "os.path.commonpath(['/usr/lib', '/usr/local/lib']) == '/usr' — shared parent."
    - "os.path.splitext('file')[1] == '' — file with no extension has empty ext component."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ attributes for time/stat/existence functions not yet covered
#
# os_path_extra7 covers islink/getsize/realpath.
# os_path_extra8 covers expanduser/expandvars/commonpath.
# This table covers getatime, getmtime, getctime, lexists, sameopenfile,
# samestat, relpath — all seven are new axes.
# ---------------------------------------------------------------------------

table os_path_extra9.stat_time_func_names:
  description: "os.path stat/time/existence function __name__ attributes"
  kind: python_call_eq
  category: function_identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [getatime_name,     getatime.__name__.__eq__,     ["getatime"],     true]
    - [getmtime_name,     getmtime.__name__.__eq__,     ["getmtime"],     true]
    - [getctime_name,     getctime.__name__.__eq__,     ["getctime"],     true]
    - [lexists_name,      lexists.__name__.__eq__,      ["lexists"],      true]
    - [sameopenfile_name, sameopenfile.__name__.__eq__,  ["sameopenfile"], true]
    - [samestat_name,     samestat.__name__.__eq__,     ["samestat"],     true]
    - [relpath_name,      relpath.__name__.__eq__,      ["relpath"],      true]

# ---------------------------------------------------------------------------
# __qualname__ attributes for the same seven functions
#
# On POSIX, os.path is posixpath, so __qualname__ == __name__ for all
# module-level functions (no class nesting).
# ---------------------------------------------------------------------------

table os_path_extra9.stat_time_func_qualnames:
  description: "os.path stat/time/existence function __qualname__ attributes"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [getatime_qn,     getatime.__qualname__.__eq__,     ["getatime"],     true]
    - [getmtime_qn,     getmtime.__qualname__.__eq__,     ["getmtime"],     true]
    - [getctime_qn,     getctime.__qualname__.__eq__,     ["getctime"],     true]
    - [lexists_qn,      lexists.__qualname__.__eq__,      ["lexists"],      true]
    - [sameopenfile_qn, sameopenfile.__qualname__.__eq__,  ["sameopenfile"], true]
    - [samestat_qn,     samestat.__qualname__.__eq__,     ["samestat"],     true]
    - [relpath_qn,      relpath.__qualname__.__eq__,      ["relpath"],      true]

# ---------------------------------------------------------------------------
# commonprefix — single-element list
#
# os_path.zspec covers commonprefix('/usr/lib', '/usr/local/lib') == '/usr/l'.
# No prior spec checks the single-element edge case.
# ---------------------------------------------------------------------------

invariant os_path_extra9.commonprefix.single_element:
  description: "os.path.commonprefix(['/usr/lib']) == '/usr/lib' — single element is its own prefix"
  category: commonprefix_values
  kind: python_call_eq
  function: commonprefix
  args: [["/usr/lib"]]
  expected: "/usr/lib"

# ---------------------------------------------------------------------------
# commonpath — shared parent directory
#
# os_path_extra8 records commonpath __name__/__qualname__ but no behavioral vector.
# os.path.commonpath(['/usr/lib', '/usr/local/lib']) == '/usr'.
# ---------------------------------------------------------------------------

invariant os_path_extra9.commonpath.shared_parent:
  description: "os.path.commonpath(['/usr/lib', '/usr/local/lib']) == '/usr'"
  category: commonpath_values
  kind: python_call_eq
  function: commonpath
  args: [["/usr/lib", "/usr/local/lib"]]
  expected: "/usr"

# ---------------------------------------------------------------------------
# splitext — file with no extension
#
# os_path.zspec covers splitext('file.py') and splitext('.hidden').
# os_path_extra7 covers splitext('/path/to/file.tar.gz').
# New: 'file' has no dot — the extension component is the empty string.
# ---------------------------------------------------------------------------

table os_path_extra9.splitext_no_ext:
  description: "os.path.splitext('file') where there is no extension"
  kind: python_call_eq
  category: splitext_values
  id_prefix: no_ext
  function: splitext
  args: ["file"]

  columns: [id, method, method_args, expected]
  rows:
    - [root, __getitem__, [0], "file"]
    - [ext,  __getitem__, [1], ""]
