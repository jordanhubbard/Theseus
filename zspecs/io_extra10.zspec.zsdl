spec: io_extra10
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and prior extras."
    - "io_extra7 covers __name__ and __module__ for RawIOBase, BufferedIOBase, TextIOBase, FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper."
    - "io_extra7 module table omits BufferedWriter.__module__ and BufferedRandom.__module__ — these are added here."
    - "io_extra8 covers IOBase.__name__, IOBase.__module__, and __bases__ hierarchy for ABCs."
    - "io_extra9 covers __qualname__ for all io classes and __mro__ length for IOBase/RawIOBase/FileIO/BytesIO."
    - "NOT yet covered: UnsupportedOperation.__bases__[0].__name__ == 'OSError' and __bases__[1].__name__ == 'ValueError'."
    - "NOT yet covered: BufferedWriter.__module__ and BufferedRandom.__module__ (omitted from io_extra7 table)."
    - "NOT yet covered: io.StringIO.__module__, io.BytesIO.__module__."
    - "io.UnsupportedOperation inherits from both OSError and ValueError (multiple inheritance)."
    - "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — first base."
    - "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError' — second base."
    - "io.UnsupportedOperation.__bases__.__len__() == 2 — exactly two direct base classes."
    - "io.BufferedWriter.__module__ == 'io'."
    - "io.BufferedRandom.__module__ == 'io'."
    - "io.BytesIO.__module__ == 'io'."
    - "io.StringIO.__module__ == 'io'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UnsupportedOperation — multiple inheritance hierarchy
#
# io.UnsupportedOperation inherits from both OSError and ValueError.
# io_extra7 covers __name__ and __module__ for UnsupportedOperation.
# io_extra9 covers __qualname__ for UnsupportedOperation.
# No prior spec checks __bases__ for UnsupportedOperation.
# ---------------------------------------------------------------------------

invariant io_extra10.UnsupportedOperation.bases_len:
  description: "io.UnsupportedOperation.__bases__.__len__() == 2 — inherits from OSError and ValueError"
  category: hierarchy
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__len__
  args: []
  expected: 2

invariant io_extra10.UnsupportedOperation.base0_OSError:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError'"
  category: hierarchy
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

invariant io_extra10.UnsupportedOperation.base1_ValueError:
  description: "io.UnsupportedOperation.__bases__[1].__name__ == 'ValueError'"
  category: hierarchy
  kind: python_call_eq
  function: UnsupportedOperation.__bases__.__getitem__
  args: [1]
  method: __name__
  expected: "ValueError"

# ---------------------------------------------------------------------------
# Module affiliation for concrete classes omitted from io_extra7
#
# io_extra7's class_modules table covered: RawIOBase, BufferedIOBase,
# TextIOBase, FileIO, BufferedReader, TextIOWrapper.
# It omitted: BufferedWriter, BufferedRandom, BytesIO, StringIO.
# These are added here.
# ---------------------------------------------------------------------------

table io_extra10.concrete_class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [BufferedWriter, BufferedWriter.__module__.__eq__,  ["io"], true]
    - [BufferedRandom, BufferedRandom.__module__.__eq__,  ["io"], true]
    - [BytesIO,        BytesIO.__module__.__eq__,         ["io"], true]
    - [StringIO,       StringIO.__module__.__eq__,        ["io"], true]

# ---------------------------------------------------------------------------
# MRO length checks for concrete classes not in io_extra9
#
# io_extra9 checked: IOBase (2), RawIOBase (3), FileIO (4), BytesIO (4).
# NOT yet covered: StringIO, BufferedReader, BufferedWriter, TextIOWrapper.
# StringIO.__mro__ has 4: StringIO, TextIOBase, IOBase, object.
# BufferedReader.__mro__ has 4: BufferedReader, BufferedIOBase, IOBase, object.
# BufferedWriter.__mro__ has 4: BufferedWriter, BufferedIOBase, IOBase, object.
# TextIOWrapper.__mro__ has 4: TextIOWrapper, TextIOBase, IOBase, object.
# ---------------------------------------------------------------------------

invariant io_extra10.StringIO.mro_len:
  description: "io.StringIO.__mro__.__len__() == 4 — StringIO, TextIOBase, IOBase, object"
  category: mro
  kind: python_call_eq
  function: StringIO.__mro__.__len__
  args: []
  expected: 4

invariant io_extra10.BufferedReader.mro_len:
  description: "io.BufferedReader.__mro__.__len__() == 4 — BufferedReader, BufferedIOBase, IOBase, object"
  category: mro
  kind: python_call_eq
  function: BufferedReader.__mro__.__len__
  args: []
  expected: 4

invariant io_extra10.BufferedWriter.mro_len:
  description: "io.BufferedWriter.__mro__.__len__() == 4 — BufferedWriter, BufferedIOBase, IOBase, object"
  category: mro
  kind: python_call_eq
  function: BufferedWriter.__mro__.__len__
  args: []
  expected: 4

invariant io_extra10.TextIOWrapper.mro_len:
  description: "io.TextIOWrapper.__mro__.__len__() == 4 — TextIOWrapper, TextIOBase, IOBase, object"
  category: mro
  kind: python_call_eq
  function: TextIOWrapper.__mro__.__len__
  args: []
  expected: 4
