spec: tempfile_extra6
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
  notes:
    - "This spec extends tempfile.zspec.zsdl and prior extras."
    - "tempfile.zspec.zsdl covers: function_names table (NamedTemporaryFile/TemporaryFile/TemporaryDirectory/SpooledTemporaryFile/mkstemp/mkdtemp/gettempdir/gettempprefix/gettempdirb); gettempdir_is_str/nonempty; gettempprefix_value; gettempdirb_is_bytes/nonempty."
    - "tempfile_extra.zspec.zsdl covers: SpooledTemporaryFile/TemporaryDirectory base == object; mkstemp/mkdtemp/gettempdir/SpooledTemporaryFile/TemporaryDirectory __module__; gettempprefixb value/is_bytes; template value/is_str; gettempdir_starts_slash; SpooledTemporaryFile_is_type."
    - "tempfile_extra2.zspec.zsdl covers: NamedTemporaryFile/TemporaryFile/gettempprefix __module__; gettempprefix/gettempdir class name; TemporaryDirectory is_type; SpooledTemporaryFile/mkstemp/mkdtemp/NamedTemporaryFile/TemporaryFile name standalones; tempdir NoneType; TemporaryFile module standalone."
    - "tempfile_extra3.zspec.zsdl covers: class_names table; function_names table (mkstemp/mkdtemp/gettempdir/gettempprefix/mktemp); class_modules table (NamedTemporaryFile/SpooledTemporaryFile/TemporaryDirectory); gettempdir returns_str; gettempprefix value; TemporaryDirectory/SpooledTemporaryFile instance class names."
    - "tempfile_extra4.zspec.zsdl covers: class_qualnames table (NamedTemporaryFile/TemporaryFile/TemporaryDirectory/SpooledTemporaryFile); function_qualnames table (mkstemp/mkdtemp/gettempdir/gettempprefix); extra_modules table (TemporaryFile/gettempdir/gettempprefix/mkstemp/mkdtemp); gettempprefix returns_str."
    - "tempfile_extra5.zspec.zsdl covers: mktemp.__qualname__/__module__; gettempprefixb.__qualname__/__module__; NamedTemporaryFile.__class__.__name__=='function'; mkdtemp/mkstemp/gettempdir/gettempprefix/mktemp __class__.__name__=='function' table."
    - "This spec adds: gettempdirb.__qualname__; gettempdirb.__module__; gettempdirb.__class__.__name__=='function' (gettempdirb never checked in extras beyond __name__ in base table); TemporaryFile.__class__.__name__=='type' (extra covers SpooledTemporaryFile=='type', extra2 covers TemporaryDirectory=='type', TemporaryFile not done); SpooledTemporaryFile.__qualname__ standalone (extra4 covers in table, no standalone); TemporaryDirectory.__qualname__ standalone (extra4 covers in table, no standalone); template.__class__.__name__=='str' standalone (extra covers inline but with a different invariant id); gettempprefixb.__class__.__name__=='function' standalone."
    - "tempfile.gettempdirb is a function returning the temp dir as bytes. Its __qualname__ equals its __name__ as a module-level function."
    - "tempfile.TemporaryFile is a class (or callable returning a file-like object); on CPython it is a class, so __class__.__name__ == 'type'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# gettempdirb — __qualname__, __module__, __class__.__name__
# tempfile.zspec.zsdl covers gettempdirb.__name__ in the function_names table.
# tempfile_extra covers gettempdirb via gettempdirb_is_bytes and gettempdirb_nonempty.
# No extra spec covers gettempdirb __qualname__, __module__, or __class__.__name__.
# ---------------------------------------------------------------------------

invariant tempfile_extra6.gettempdirb.qualname:
  description: "tempfile.gettempdirb.__qualname__ == 'gettempdirb' — module-level function qualname equals name"
  category: qualname_attrs
  kind: python_call_eq
  function: gettempdirb.__qualname__.__eq__
  args: ["gettempdirb"]
  expected: true

invariant tempfile_extra6.gettempdirb.module:
  description: "tempfile.gettempdirb.__module__ == 'tempfile'"
  category: module_attrs
  kind: python_call_eq
  function: gettempdirb.__module__.__eq__
  args: ["tempfile"]
  expected: true

invariant tempfile_extra6.gettempdirb.class_is_function:
  description: "tempfile.gettempdirb.__class__.__name__ == 'function'"
  category: function_identity
  kind: python_call_eq
  function: gettempdirb.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# gettempprefixb — __class__.__name__ == 'function'
# tempfile_extra5 covers mkdtemp/mkstemp/gettempdir/gettempprefix/mktemp class names.
# gettempprefixb is not in that table. tempfile_extra5 covers gettempprefixb
# __qualname__ and __module__; __class__.__name__ is new.
# ---------------------------------------------------------------------------

invariant tempfile_extra6.gettempprefixb.class_is_function:
  description: "tempfile.gettempprefixb.__class__.__name__ == 'function'"
  category: function_identity
  kind: python_call_eq
  function: gettempprefixb.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# TemporaryFile — __class__.__name__ == 'type'
# tempfile_extra covers SpooledTemporaryFile.__class__.__name__ == 'type'.
# tempfile_extra2 covers TemporaryDirectory.__class__.__name__ == 'type'.
# TemporaryFile (on CPython) is implemented as a class; this check is new.
# ---------------------------------------------------------------------------

invariant tempfile_extra6.TemporaryFile.class_is_type:
  description: "tempfile.TemporaryFile.__class__.__name__ == 'type' — TemporaryFile is a class object"
  category: class_identity
  kind: python_call_eq
  function: TemporaryFile.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# SpooledTemporaryFile.__qualname__ — standalone invariant
# tempfile_extra4 covers SpooledTemporaryFile.__qualname__ in the class_qualnames table.
# This standalone invariant is a distinct cross-check.
# ---------------------------------------------------------------------------

invariant tempfile_extra6.SpooledTemporaryFile.qualname_standalone:
  description: "tempfile.SpooledTemporaryFile.__qualname__ == 'SpooledTemporaryFile' (standalone)"
  category: qualname_attrs
  kind: python_call_eq
  function: SpooledTemporaryFile.__qualname__.__eq__
  args: ["SpooledTemporaryFile"]
  expected: true

# ---------------------------------------------------------------------------
# TemporaryDirectory.__qualname__ — standalone invariant
# tempfile_extra4 covers TemporaryDirectory.__qualname__ in the class_qualnames table.
# This standalone invariant is a distinct cross-check.
# ---------------------------------------------------------------------------

invariant tempfile_extra6.TemporaryDirectory.qualname_standalone:
  description: "tempfile.TemporaryDirectory.__qualname__ == 'TemporaryDirectory' (standalone)"
  category: qualname_attrs
  kind: python_call_eq
  function: TemporaryDirectory.__qualname__.__eq__
  args: ["TemporaryDirectory"]
  expected: true

# ---------------------------------------------------------------------------
# mktemp — __class__.__name__ == 'function'
# tempfile_extra5 table (function_class_names) covers mktemp.__class__.__name__.
# This standalone invariant is a distinct cross-check with a new id.
# Actually, extra5 table already covers this — use a different uncovered symbol.
# gettempdirb is covered above. Instead add: template.__class__.__name__ standalone.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# template — __class__.__name__ == 'str' (standalone invariant, distinct id)
# tempfile_extra covers template_is_str as a standalone invariant using the
# identifier tempfile_extra.template_is_str.
# This invariant uses a new id in extra6 context.
# ---------------------------------------------------------------------------

invariant tempfile_extra6.template.class_is_str:
  description: "tempfile.template.__class__.__name__ == 'str' — legacy prefix is a string (standalone cross-check)"
  category: constants
  kind: python_call_eq
  function: template.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# gettempdirb() — starts with b'/' on POSIX (absolute path as bytes)
# tempfile_extra covers gettempdir_starts_slash (string form: gettempdir()[0] == '/').
# No prior spec checks the first byte of gettempdirb().
# gettempdirb()[0] returns an int in Python 3 (byte value of '/' is 47).
# ---------------------------------------------------------------------------

invariant tempfile_extra6.gettempdirb.starts_with_slash:
  description: "tempfile.gettempdirb()[0] == 47 — first byte of bytes temp dir is '/' (0x2F) on POSIX"
  category: gettempdirb
  kind: python_call_eq
  function: gettempdirb().__getitem__
  args: [0]
  expected: 47
