spec: socket_extra1261
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "socket_extra126.zspec.zsdl — covers earlier socket invariants from prior waves."
  notes:
    - "Wave 531: socket has __all__ (a list with 238 entries on this platform). This spec checks socket.__all__.__contains__ for names in __all__ (true), names NOT in __all__ (false), and __all__.__class__.__name__.__eq__ identity."
    - "socket.__all__.__class__.__name__ == 'list'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Names IN socket.__all__ include: socket, error, timeout, gethostname, getfqdn, gethostbyname, AF_INET, AF_INET6, SOCK_STREAM, create_connection, AddressFamily, SocketKind, getnameinfo, getaddrinfo, setdefaulttimeout, getdefaulttimeout, IPPROTO_TCP. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Names NOT in socket.__all__: _GLOBAL_DEFAULT_TIMEOUT, _blocking_errnos, _real_close, _socket, _intenum_converter (private names). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1261.all_contains_true:
  description: "socket.__all__.__contains__ returns true for names that are members of socket.__all__"
  kind: python_call_eq
  category: all_membership_true
  id_prefix: sk1261at
  columns: [id, function, args, expected]
  rows:
    - [sk1261at001, socket.__all__.__contains__, ["socket"],             true]
    - [sk1261at002, socket.__all__.__contains__, ["error"],              true]
    - [sk1261at003, socket.__all__.__contains__, ["timeout"],            true]
    - [sk1261at004, socket.__all__.__contains__, ["gethostname"],        true]
    - [sk1261at005, socket.__all__.__contains__, ["getfqdn"],            true]
    - [sk1261at006, socket.__all__.__contains__, ["gethostbyname"],      true]
    - [sk1261at007, socket.__all__.__contains__, ["AF_INET"],            true]
    - [sk1261at008, socket.__all__.__contains__, ["AF_INET6"],           true]
    - [sk1261at009, socket.__all__.__contains__, ["SOCK_STREAM"],        true]
    - [sk1261at010, socket.__all__.__contains__, ["create_connection"],  true]
    - [sk1261at011, socket.__all__.__contains__, ["AddressFamily"],      true]
    - [sk1261at012, socket.__all__.__contains__, ["SocketKind"],         true]
    - [sk1261at013, socket.__all__.__contains__, ["getnameinfo"],        true]
    - [sk1261at014, socket.__all__.__contains__, ["getaddrinfo"],        true]
    - [sk1261at015, socket.__all__.__contains__, ["IPPROTO_TCP"],        true]
    - [sk1261at016, socket.__all__.__contains__, ["setdefaulttimeout"],  true]
    - [sk1261at017, socket.__all__.__contains__, ["getdefaulttimeout"],  true]

table socket_extra1261.all_contains_false:
  description: "socket.__all__.__contains__ returns false for private names and symbols not exported in socket.__all__"
  kind: python_call_eq
  category: all_membership_false
  id_prefix: sk1261af
  columns: [id, function, args, expected]
  rows:
    - [sk1261af001, socket.__all__.__contains__, ["_GLOBAL_DEFAULT_TIMEOUT"], false]
    - [sk1261af002, socket.__all__.__contains__, ["_blocking_errnos"],        false]
    - [sk1261af003, socket.__all__.__contains__, ["_real_close"],             false]
    - [sk1261af004, socket.__all__.__contains__, ["_socket"],                 false]
    - [sk1261af005, socket.__all__.__contains__, ["_intenum_converter"],      false]
    - [sk1261af006, socket.__all__.__contains__, ["__all__"],                 false]
    - [sk1261af007, socket.__all__.__contains__, ["xyz"],                     false]
    - [sk1261af008, socket.__all__.__contains__, [""],                        false]
    - [sk1261af009, socket.__all__.__contains__, ["os"],                      false]
    - [sk1261af010, socket.__all__.__contains__, ["sys"],                     false]
    - [sk1261af011, socket.__all__.__contains__, ["SOCK"],                    false]
    - [sk1261af012, socket.__all__.__contains__, ["inet_aton_packed"],        false]

table socket_extra1261.all_class_and_type_checks:
  description: "socket.__all__ is a list; class name identity checks and module name checks"
  kind: python_call_eq
  category: all_class_checks
  id_prefix: sk1261ac
  columns: [id, function, args, expected]
  rows:
    - [sk1261ac001, socket.__all__.__class__.__name__.__eq__,     ["list"],     true]
    - [sk1261ac002, socket.__all__.__class__.__name__.__eq__,     ["tuple"],    false]
    - [sk1261ac003, socket.__all__.__class__.__name__.__eq__,     ["set"],      false]
    - [sk1261ac004, socket.__all__.__class__.__name__.__eq__,     ["frozenset"],false]
    - [sk1261ac005, socket.__all__.__class__.__name__.__eq__,     ["dict"],     false]
    - [sk1261ac006, socket.__all__.__class__.__qualname__.__eq__, ["list"],     true]
    - [sk1261ac007, socket.__all__.__class__.__module__.__eq__,   ["builtins"], true]
    - [sk1261ac008, socket.__name__.__eq__,                       ["socket"],   true]
    - [sk1261ac009, socket.__spec__.name.__eq__,                  ["socket"],   true]
    - [sk1261ac010, socket.__all__.__len__.__class__.__name__.__eq__, ["method-wrapper"], true]
