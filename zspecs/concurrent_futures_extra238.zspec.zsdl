spec: concurrent_futures_extra238
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers concurrent.futures.Executor class identity and method contracts."
    - "concurrent.futures.Executor.__name__ == 'Executor' — 8 characters."
    - "concurrent.futures.Executor.__module__ == 'concurrent.futures._base' — defined in the private _base submodule (24 chars)."
    - "concurrent.futures.Executor.__bases__[0].__name__ == 'object' — Executor directly inherits from object."
    - "concurrent.futures.Executor.__qualname__ == 'Executor' — simple top-level class name."
    - "Executor.map.__name__ == 'map'; __qualname__ == 'Executor.map' (12 chars)."
    - "Executor.submit.__name__ == 'submit'; __qualname__ == 'Executor.submit' (15 chars)."
    - "Executor.shutdown.__name__ == 'shutdown'; __qualname__ == 'Executor.shutdown' (17 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures.Executor class identity contracts
#
# Verifies __name__, __module__, __qualname__ to confirm the class is defined
# in concurrent.futures._base and carries the expected identity attributes.
# ---------------------------------------------------------------------------

table concurrent_futures_extra238.executor_class_identity:
  description: "concurrent.futures.Executor class identity: name, module, qualname; new to extra238"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf238exec

  columns: [id, function, args, expected, description]
  rows:
    - [exec_name_eq,
       Executor.__name__.__eq__,
       ["Executor"],
       true,
       "concurrent.futures.Executor.__name__.__eq__('Executor') == True — class carries unqualified name 'Executor'; new to extra238"]
    - [exec_module_eq,
       Executor.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base') == True — Executor defined in _base submodule; new to extra238"]
    - [exec_qualname_eq,
       Executor.__qualname__.__eq__,
       ["Executor"],
       true,
       "concurrent.futures.Executor.__qualname__.__eq__('Executor') == True — top-level class; qualname equals __name__; new to extra238"]
    - [exec_name_len_8,
       Executor.__name__.__len__,
       [],
       8,
       "concurrent.futures.Executor.__name__.__len__() == 8 — 'Executor' has exactly 8 characters; new to extra238"]
    - [exec_module_len_24,
       Executor.__module__.__len__,
       [],
       24,
       "concurrent.futures.Executor.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters; new to extra238"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures.Executor base class contract
#
# Executor.__bases__[0].__name__ == 'object' — Executor directly inherits from object.
# The function path contains '[' so must be double-quoted.
# ---------------------------------------------------------------------------

table concurrent_futures_extra238.executor_base_class:
  description: "concurrent.futures.Executor base class identity; new to extra238"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf238execb

  columns: [id, function, args, expected, description]
  rows:
    - [exec_base_name_eq,
       "Executor.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "concurrent.futures.Executor.__bases__[0].__name__.__eq__('object') == True — Executor directly subclasses object; new to extra238"]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures.Executor method __name__ contracts
#
# map, submit, shutdown each carry their simple __name__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra238.executor_method_names:
  description: "concurrent.futures.Executor method __name__ contracts; new to extra238"
  kind: python_call_eq
  category: method_names
  id_prefix: cf238execm

  columns: [id, function, args, expected, description]
  rows:
    - [map_name_eq,
       Executor.map.__name__.__eq__,
       ["map"],
       true,
       "concurrent.futures.Executor.map.__name__.__eq__('map') == True — method carries its simple name; new to extra238"]
    - [submit_name_eq,
       Executor.submit.__name__.__eq__,
       ["submit"],
       true,
       "concurrent.futures.Executor.submit.__name__.__eq__('submit') == True — method carries its simple name; new to extra238"]
    - [shutdown_name_eq,
       Executor.shutdown.__name__.__eq__,
       ["shutdown"],
       true,
       "concurrent.futures.Executor.shutdown.__name__.__eq__('shutdown') == True — method carries its simple name; new to extra238"]

# ---------------------------------------------------------------------------
# Table 4: concurrent.futures.Executor method __qualname__ contracts
#
# map, submit, shutdown each carry qualname 'Executor.<method>'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra238.executor_method_qualnames:
  description: "concurrent.futures.Executor method __qualname__ contracts; new to extra238"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: cf238execm

  columns: [id, function, args, expected, description]
  rows:
    - [map_qualname_eq,
       Executor.map.__qualname__.__eq__,
       ["Executor.map"],
       true,
       "concurrent.futures.Executor.map.__qualname__ == 'Executor.map' (12 chars); new to extra238"]
    - [submit_qualname_eq,
       Executor.submit.__qualname__.__eq__,
       ["Executor.submit"],
       true,
       "concurrent.futures.Executor.submit.__qualname__ == 'Executor.submit' (15 chars); new to extra238"]
    - [shutdown_qualname_eq,
       Executor.shutdown.__qualname__.__eq__,
       ["Executor.shutdown"],
       true,
       "concurrent.futures.Executor.shutdown.__qualname__ == 'Executor.shutdown' (17 chars); new to extra238"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra238
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra238.Executor.name:
  description: "concurrent.futures.Executor.__name__ == 'Executor'; new to extra238"
  category: class_identity
  kind: python_call_eq
  function: Executor.__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra238.Executor.module:
  description: "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'; new to extra238"
  category: class_identity
  kind: python_call_eq
  function: Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra238.Executor.qualname:
  description: "concurrent.futures.Executor.__qualname__ == 'Executor'; new to extra238"
  category: class_identity
  kind: python_call_eq
  function: Executor.__qualname__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra238.Executor.base_name:
  description: "concurrent.futures.Executor.__bases__[0].__name__ == 'object' — Executor directly subclasses object; new to extra238"
  category: class_identity
  kind: python_call_eq
  function: "Executor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra238.Executor.module_len:
  description: "concurrent.futures.Executor.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters; new to extra238"
  category: class_identity
  kind: python_call_eq
  function: Executor.__module__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra238.Executor.map_name:
  description: "concurrent.futures.Executor.map.__name__ == 'map'; new to extra238"
  category: method_names
  kind: python_call_eq
  function: Executor.map.__name__.__eq__
  args: ["map"]
  expected: true

invariant concurrent_futures_extra238.Executor.map_qualname:
  description: "concurrent.futures.Executor.map.__qualname__ == 'Executor.map'; new to extra238"
  category: method_qualnames
  kind: python_call_eq
  function: Executor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra238.Executor.submit_name:
  description: "concurrent.futures.Executor.submit.__name__ == 'submit'; new to extra238"
  category: method_names
  kind: python_call_eq
  function: Executor.submit.__name__.__eq__
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra238.Executor.submit_qualname:
  description: "concurrent.futures.Executor.submit.__qualname__ == 'Executor.submit'; new to extra238"
  category: method_qualnames
  kind: python_call_eq
  function: Executor.submit.__qualname__.__eq__
  args: ["Executor.submit"]
  expected: true

invariant concurrent_futures_extra238.Executor.shutdown_name:
  description: "concurrent.futures.Executor.shutdown.__name__ == 'shutdown'; new to extra238"
  category: method_names
  kind: python_call_eq
  function: Executor.shutdown.__name__.__eq__
  args: ["shutdown"]
  expected: true

invariant concurrent_futures_extra238.Executor.shutdown_qualname:
  description: "concurrent.futures.Executor.shutdown.__qualname__ == 'Executor.shutdown'; new to extra238"
  category: method_qualnames
  kind: python_call_eq
  function: Executor.shutdown.__qualname__.__eq__
  args: ["Executor.shutdown"]
