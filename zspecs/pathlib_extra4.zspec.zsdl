spec: pathlib_extra4
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath runtime behaviors (name, stem, suffix, parts, parent, joinpath, str, as_posix, relative_to, is_absolute)"
    - "pathlib_pure.zspec.zsdl — covers PurePosixPath/__name__, PureWindowsPath/__name__, PurePath/__name__, PurePosixPath/__module__, PureWindowsPath/__module__, class hierarchy, Windows/POSIX components, match"
    - "pathlib_extra.zspec.zsdl — covers Path/__name__, Path/__module__, PurePosixPath/__module__, component access, parent, truediv, parts"
    - "pathlib_extra2.zspec.zsdl — covers suffixes, with_name, with_suffix, joinpath multi-arg, is_absolute, parents"
    - "pathlib_extra3.zspec.zsdl — covers PosixPath/__name__, WindowsPath/__name__, PosixPath/__module__, WindowsPath/__module__, PurePath/__module__, Path.__bases__[0] == PurePath, PosixPath.__bases__[0] == Path"
  notes:
    - "This spec extends the pathlib chain; it does NOT duplicate invariants present in any prior spec."
    - "This spec focuses on method identity — Path.iterdir, Path.glob, Path.rglob, Path.open, Path.stat, Path.mkdir, Path.exists, Path.is_file, Path.is_dir, Path.is_symlink — none of which are covered in any prior pathlib spec."
    - "Method __name__ checks are stateless class attribute reads; they do not create, open, or stat any file."
    - "pathlib.Path.glob.__name__ == 'glob' and pathlib.Path.rglob.__name__ == 'rglob' — both are instance methods for pattern-based directory traversal."
    - "pathlib.Path.iterdir.__name__ == 'iterdir' — yields the immediate children of a directory path."
    - "pathlib.Path.open.__name__ == 'open' — opens the path for reading or writing."
    - "pathlib.Path.stat.__name__ == 'stat' — returns an os.stat_result for the path."
    - "pathlib.Path.mkdir.__name__ == 'mkdir' — creates the directory at this path."
    - "pathlib.Path.exists.__name__ == 'exists' — returns True if the path exists."
    - "pathlib.Path.is_file.__name__ == 'is_file' — returns True if the path is a regular file."
    - "pathlib.Path.is_dir.__name__ == 'is_dir' — returns True if the path is a directory."
    - "pathlib.Path.is_symlink.__name__ == 'is_symlink' — returns True if the path is a symbolic link."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path traversal method name checks
# These are class-level attribute reads; no filesystem access occurs.
# ---------------------------------------------------------------------------

invariant pathlib_extra4.Path.iterdir_name:
  description: "pathlib.Path.iterdir.__name__ == 'iterdir'"
  category: method_names
  kind: python_call_eq
  function: Path.iterdir.__name__.__eq__
  args: ["iterdir"]
  expected: true

invariant pathlib_extra4.Path.glob_name:
  description: "pathlib.Path.glob.__name__ == 'glob'"
  category: method_names
  kind: python_call_eq
  function: Path.glob.__name__.__eq__
  args: ["glob"]
  expected: true

invariant pathlib_extra4.Path.rglob_name:
  description: "pathlib.Path.rglob.__name__ == 'rglob'"
  category: method_names
  kind: python_call_eq
  function: Path.rglob.__name__.__eq__
  args: ["rglob"]
  expected: true

# ---------------------------------------------------------------------------
# Path I/O method name checks
# ---------------------------------------------------------------------------

invariant pathlib_extra4.Path.open_name:
  description: "pathlib.Path.open.__name__ == 'open'"
  category: method_names
  kind: python_call_eq
  function: Path.open.__name__.__eq__
  args: ["open"]
  expected: true

invariant pathlib_extra4.Path.stat_name:
  description: "pathlib.Path.stat.__name__ == 'stat'"
  category: method_names
  kind: python_call_eq
  function: Path.stat.__name__.__eq__
  args: ["stat"]
  expected: true

invariant pathlib_extra4.Path.mkdir_name:
  description: "pathlib.Path.mkdir.__name__ == 'mkdir'"
  category: method_names
  kind: python_call_eq
  function: Path.mkdir.__name__.__eq__
  args: ["mkdir"]
  expected: true

# ---------------------------------------------------------------------------
# Path predicate method name checks
# These methods return bool based on filesystem state, but their __name__
# attributes are constant class-level strings — no filesystem I/O occurs.
# ---------------------------------------------------------------------------

invariant pathlib_extra4.Path.exists_name:
  description: "pathlib.Path.exists.__name__ == 'exists'"
  category: method_names
  kind: python_call_eq
  function: Path.exists.__name__.__eq__
  args: ["exists"]
  expected: true

invariant pathlib_extra4.Path.is_file_name:
  description: "pathlib.Path.is_file.__name__ == 'is_file'"
  category: method_names
  kind: python_call_eq
  function: Path.is_file.__name__.__eq__
  args: ["is_file"]
  expected: true

invariant pathlib_extra4.Path.is_dir_name:
  description: "pathlib.Path.is_dir.__name__ == 'is_dir'"
  category: method_names
  kind: python_call_eq
  function: Path.is_dir.__name__.__eq__
  args: ["is_dir"]
  expected: true

invariant pathlib_extra4.Path.is_symlink_name:
  description: "pathlib.Path.is_symlink.__name__ == 'is_symlink'"
  category: method_names
  kind: python_call_eq
  function: Path.is_symlink.__name__.__eq__
  args: ["is_symlink"]
  expected: true

# ---------------------------------------------------------------------------
# WindowsPath — base class hierarchy (completes pathlib_extra3 coverage)
# pathlib_extra3 checks PosixPath.__bases__[0] == 'Path'; this spec adds
# WindowsPath.__bases__[0] == 'Path' to complete the concrete class hierarchy.
# ---------------------------------------------------------------------------

invariant pathlib_extra4.WindowsPath.base:
  description: "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — WindowsPath inherits from Path"
  category: class_hierarchy
  kind: python_call_eq
  function: WindowsPath.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Path"

# ---------------------------------------------------------------------------
# Path text/binary I/O convenience method name checks (Python 3.5+)
# read_text, write_text, read_bytes, write_bytes are high-level helpers
# not checked in any prior pathlib spec.
# ---------------------------------------------------------------------------

invariant pathlib_extra4.Path.read_text_name:
  description: "pathlib.Path.read_text.__name__ == 'read_text'"
  category: method_names
  kind: python_call_eq
  function: Path.read_text.__name__.__eq__
  args: ["read_text"]
  expected: true

invariant pathlib_extra4.Path.write_text_name:
  description: "pathlib.Path.write_text.__name__ == 'write_text'"
  category: method_names
  kind: python_call_eq
  function: Path.write_text.__name__.__eq__
  args: ["write_text"]
  expected: true
