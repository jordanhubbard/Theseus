  "error_model": {
    "return_code_semantics": "zstd functions that return size_t encode errors as large values near SIZE_MAX. Use ZSTD_isError(code) to test for errors.",
    "stream_error_field": "ZSTD_getErrorName(code)",
    "error_stickiness": "Streaming contexts must be reset after error; single-call functions are stateless",
    "error_codes": [
      {
        "name": "ZSTD_error_no_error",
        "value": 0,
        "meaning": "Operation completed successfully"
      },
      {
        "name": "ZSTD_error_GENERIC",
        "value": 1,
        "meaning": "Unspecified generic error"
      },
      {
        "name": "ZSTD_error_prefix_unknown",
        "value": 10,
        "meaning": "Source data does not begin with a valid zstd frame magic"
      },
      {
        "name": "ZSTD_error_dstSize_tooSmall",
        "value": 70,
        "meaning": "Destination buffer is too small to hold the output"
      },
      {
        "name": "ZSTD_error_srcSize_wrong",
        "value": 72,
        "meaning": "Content size in header does not match actual data"
      }
    ]
