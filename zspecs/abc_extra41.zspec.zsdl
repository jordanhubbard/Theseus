spec: abc_extra41
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra40.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token/update_abstractmethods, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), ABCMeta/__subclasshook__/__qualname__.__len__()==24, update_abstractmethods/__qualname__.__len__()==22, ABC/__abstractmethods__/__class__/__name__.__len__()==9, ABC/__name__.__len__()==3, abstractmethod/__name__.__len__()==14, get_cache_token/__name__.__len__()==15, abc/__name__.__len__()==3, ABCMeta mro entry name/qualname lengths, ABC/__subclasshook__/__qualname__.__len__()==20, issubclass/isinstance behavioral invariants, abstractmethod/__class__/__name__.__len__()==8, ABC/__doc__/__class__/__name__.__len__()==3, ABCMeta/__prepare__/__qualname__.__len__()==19, ABCMeta/__init__/__qualname__.__len__()==13, ABCMeta/__getattribute__/__qualname__.__len__()==21, ABCMeta/__call__/__repr__/__qualname__.__len__()==13, ABCMeta/__setattr__/__delattr__/__qualname__.__len__()==16, abstractmethod/__code__/__class__/__name__.__len__()==4, ABC/__init_subclass__/__qualname__/__len__()==21, metaclass chain tables, abstractmethod/__annotations__/__class__/__name__.__len__()==4, get_cache_token/__class__/__name__.__len__()==26, ABCMeta/__bases__[0]/__module__/__qualname__.__len__(), ABC/__bases__[0]/__module__/__qualname__.__len__(), abstractmethod/__class__/__module__.__len__()==8, abc/__spec__/__class__/__name__.__len__()==10, ABCMeta MRO __module__/__qualname__.__len__() tables, abstractmethod/__name__=='abstractmethod', get_cache_token/__module__=='_abc', ABC/__name__=='ABC', ABC/__bases__[0].__name__=='object', ABCMeta/__name__=='ABCMeta'/__module__=='abc'/__bases__[0].__name__=='type', ABCMeta.register/__qualname__.__len__()==16, ABCMeta/__mro__.__len__()==3, ABC/__mro__.__len__()==2, ABC/__mro__[1].__name__=='object', ABCMeta MRO entries [0]/'ABCMeta'/[1]/'type'/[2]/'object', ABC/__mro__[0].__name__=='ABC', abstractmethod/__qualname__.__len__()==14, abstractproperty/__name__=='abstractproperty'/__module__=='abc', abstractclassmethod/__name__=='abstractclassmethod'/__module__=='abc', abstractproperty/__qualname__=='abstractproperty', abstractproperty/__qualname__.__len__()==16, abstractproperty/__bases__[0].__name__=='property', abstractclassmethod/__bases__[0].__name__=='classmethod', abstractstaticmethod/__name__=='abstractstaticmethod', abstractstaticmethod/__bases__[0].__name__=='staticmethod', ABC/__qualname__=='ABC', ABC/__qualname__.__len__()==3, abstractmethod/__qualname__=='abstractmethod', abstractclassmethod/__qualname__=='abstractclassmethod', abstractstaticmethod/__qualname__=='abstractstaticmethod', ABCMeta.register/__qualname__=='ABCMeta.register', ABC/__abstractmethods__/__class__/__name__=='frozenset', ABC/__abstractmethods__/__len__()==0, ABCMeta/__call__/__qualname__=='type.__call__', ABCMeta/__qualname__=='ABCMeta', ABCMeta/__qualname__.__len__()==7, ABC/__qualname__.__len__()==3, abstractmethod/__qualname__.__len__()==14, abstractproperty/__qualname__.__len__()==16, abstractclassmethod/__qualname__.__len__()==19, abstractstaticmethod/__qualname__.__len__()==20, get_cache_token/__qualname__=='get_cache_token', get_cache_token/__qualname__.__len__()==15, abstractproperty/__mro__.__len__()==3, abstractclassmethod/__mro__.__len__()==3, abstractstaticmethod/__mro__.__len__()==3, abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta', abstractproperty/__bases__[0].__name__.__len__()==8, abstractclassmethod/__bases__[0].__name__.__len__()==11, abstractstaticmethod/__bases__[0].__name__.__len__()==12 (extra40)."
    - "This spec covers: abstractproperty/__class__.__qualname__=='type'; ABC/__class__.__qualname__=='ABCMeta'; ABCMeta/__class__.__qualname__=='type'; abstractmethod/__class__.__qualname__=='function'; get_cache_token/__class__.__qualname__=='builtin_function_or_method'; abstractproperty/__class__.__qualname__.__len__()==4; ABC/__class__.__qualname__.__len__()==7; ABCMeta/__class__.__qualname__.__len__()==4; abstractmethod/__class__.__qualname__.__len__()==8; get_cache_token/__class__.__qualname__.__len__()==26."
    - "abc.abstractproperty.__class__.__qualname__ == 'type'. abstractproperty is a class (a subclass of property); its metaclass is 'type'. __class__.__qualname__ == 'type' (4 chars). Extra40 captured the string equality via __class__.__name__ == 'type'; extra41 uses __class__.__qualname__ to confirm the same result (for 'type', __qualname__ == __name__). Verified with Python 3.14.3."
    - "abc.ABC.__class__.__qualname__ == 'ABCMeta'. ABC is an instance of ABCMeta; its __class__.__qualname__ == 'ABCMeta' (7 chars). Extra40 captured this via __class__.__name__ == 'ABCMeta'; extra41 uses __class__.__qualname__. For top-level classes, __qualname__ == __name__. Verified with Python 3.14.3."
    - "abc.ABCMeta.__class__.__qualname__ == 'type'. ABCMeta is a class whose metaclass is the built-in 'type'; ABCMeta.__class__ == type, and type.__qualname__ == 'type' (4 chars). Verified with Python 3.14.3."
    - "abc.abstractmethod.__class__.__qualname__ == 'function'. abstractmethod is a plain Python function; its __class__.__qualname__ == 'function' (8 chars). For the built-in 'function' type, __qualname__ == __name__. Extra40 captured __class__.__name__ == 'function'; extra41 adds __class__.__qualname__. Verified with Python 3.14.3."
    - "abc.get_cache_token.__class__.__qualname__ == 'builtin_function_or_method'. get_cache_token is a C-extension function from _abc; its __class__ is builtin_function_or_method with __qualname__ == 'builtin_function_or_method' (26 chars). This matches __class__.__name__ (prior spec captured __len__()==26 via get_cache_token/__class__/__name__.__len__()). Verified with Python 3.14.3."
    - "ABCMeta has no __abstractmethods__ attribute. ABCMeta is a metaclass (a class whose instances are classes); it does not itself have __abstractmethods__ since it is not abstract in the traditional sense. Accessing ABCMeta.__abstractmethods__ raises AttributeError. Only instances of ABCMeta (like ABC and user-defined ABCs) have __abstractmethods__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc object identity via __class__.__qualname__ string equality — extra41
#
# Extra40 captured __class__.__name__ string equality for three abc objects:
#   abstractmethod.__class__.__name__ == 'function'
#   abstractproperty.__class__.__name__ == 'type'
#   ABC.__class__.__name__ == 'ABCMeta'
# Extra41 extends to __class__.__qualname__ for five abc exports:
#   abstractproperty.__class__.__qualname__ == 'type'           (4 chars)
#   ABC.__class__.__qualname__             == 'ABCMeta'         (7 chars)
#   ABCMeta.__class__.__qualname__         == 'type'            (4 chars)
#   abstractmethod.__class__.__qualname__  == 'function'        (8 chars)
#   get_cache_token.__class__.__qualname__ == 'builtin_function_or_method' (26 chars)
# For built-in types like 'type', 'function', 'builtin_function_or_method',
# and user-defined metaclasses like 'ABCMeta', __qualname__ == __name__.
# ---------------------------------------------------------------------------

table abc_extra41.class_qualname_identity:
  description: "abc object identity via __class__.__qualname__ string equality in extra41 namespace — five abc exports"
  kind: python_call_eq
  category: class_names
  id_prefix: abcclsqnidentity41

  columns: [id, function, args, expected, description]
  rows:
    - [abstractproperty_class_qualname, abstractproperty.__class__.__qualname__.__eq__, ["type"],                       true, "abstractproperty.__class__.__qualname__ == 'type' — abstractproperty is a class; its metaclass __qualname__ is 'type' (4 chars)"]
    - [ABC_class_qualname,              ABC.__class__.__qualname__.__eq__,              ["ABCMeta"],                    true, "ABC.__class__.__qualname__ == 'ABCMeta' — ABC's metaclass is ABCMeta; ABCMeta is a top-level class with qualname == name (7 chars)"]
    - [ABCMeta_class_qualname,          ABCMeta.__class__.__qualname__.__eq__,          ["type"],                       true, "ABCMeta.__class__.__qualname__ == 'type' — ABCMeta's metaclass is the built-in type; type.__qualname__ == 'type' (4 chars)"]
    - [abstractmethod_class_qualname,   abstractmethod.__class__.__qualname__.__eq__,   ["function"],                   true, "abstractmethod.__class__.__qualname__ == 'function' — abstractmethod is a plain Python function (8 chars)"]
    - [get_cache_token_class_qualname,  get_cache_token.__class__.__qualname__.__eq__,  ["builtin_function_or_method"], true, "get_cache_token.__class__.__qualname__ == 'builtin_function_or_method' — C-extension function from _abc (26 chars)"]

# ---------------------------------------------------------------------------
# abc object __class__.__qualname__.__len__() — extra41
#
# __class__.__qualname__ lengths for the five abc exports:
#   abstractproperty.__class__.__qualname__.__len__() ==  4  ('type')
#   ABC.__class__.__qualname__.__len__()              ==  7  ('ABCMeta')
#   ABCMeta.__class__.__qualname__.__len__()          ==  4  ('type')
#   abstractmethod.__class__.__qualname__.__len__()   ==  8  ('function')
#   get_cache_token.__class__.__qualname__.__len__()  == 26  ('builtin_function_or_method')
# abstractproperty and ABCMeta share __class__.__qualname__.__len__()==4 (both 'type').
# get_cache_token has the longest at 26 chars (prior spec captured this length via
# get_cache_token/__class__/__name__.__len__()==26 in extra34; extra41 captures
# the same length via __class__.__qualname__.__len__() explicitly).
# ---------------------------------------------------------------------------

table abc_extra41.class_qualname_lengths:
  description: "abc object __class__.__qualname__.__len__() in extra41 namespace — five abc exports"
  kind: python_call_eq
  category: class_names
  id_prefix: abcclsqnlen41

  columns: [id, function, args, expected, description]
  rows:
    - [abstractproperty, abstractproperty.__class__.__qualname__.__len__, [],  4, "abstractproperty.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"]
    - [ABC,              ABC.__class__.__qualname__.__len__,              [],  7, "ABC.__class__.__qualname__.__len__() == 7 — 'ABCMeta' has 7 characters"]
    - [ABCMeta,          ABCMeta.__class__.__qualname__.__len__,          [],  4, "ABCMeta.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters; same as abstractproperty"]
    - [abstractmethod,   abstractmethod.__class__.__qualname__.__len__,   [],  8, "abstractmethod.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"]
    - [get_cache_token,  get_cache_token.__class__.__qualname__.__len__,  [], 26, "get_cache_token.__class__.__qualname__.__len__() == 26 — 'builtin_function_or_method' has 26 characters; longest of the five"]

# ---------------------------------------------------------------------------
# ABCMeta.__abstractmethods__ raises AttributeError — extra41
#
# ABCMeta is a metaclass (its instances are classes, not abstract objects).
# It does not have __abstractmethods__ itself:
#   ABCMeta.__abstractmethods__ -> AttributeError
# This contrasts with ABC.__abstractmethods__ == frozenset() (empty frozenset,
# captured in extra38). ABCMeta itself is not subject to the abstract method
# machinery in the same way its instances are.
# ---------------------------------------------------------------------------

invariant abc_extra41.ABCMeta_no_abstractmethods:
  description: "abc.ABCMeta.__abstractmethods__ raises AttributeError — ABCMeta is a metaclass and does not expose __abstractmethods__ as an instance attribute"
  category: class_names
  kind: python_call_raises
  function: ABCMeta.__abstractmethods__.__class__.__name__.__len__
  args: []
  raises: AttributeError

# ---------------------------------------------------------------------------
# Standalone invariants — extra41
# ---------------------------------------------------------------------------

invariant abc_extra41.abstractproperty_class_qualname_eq:
  description: "abc.abstractproperty.__class__.__qualname__ == 'type' — abstractproperty is a class; its metaclass is type (4 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra41.ABC_class_qualname_eq:
  description: "abc.ABC.__class__.__qualname__ == 'ABCMeta' — ABC is an instance of ABCMeta; ABCMeta is the metaclass for ABC (7 chars)"
  category: class_names
  kind: python_call_eq
  function: ABC.__class__.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra41.ABCMeta_class_qualname_eq:
  description: "abc.ABCMeta.__class__.__qualname__ == 'type' — ABCMeta's metaclass is the built-in type; type.__qualname__ == 'type' (4 chars)"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__class__.__qualname__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra41.abstractmethod_class_qualname_eq:
  description: "abc.abstractmethod.__class__.__qualname__ == 'function' — abstractmethod is a plain Python function; __class__.__qualname__ == 'function' (8 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra41.get_cache_token_class_qualname_eq:
  description: "abc.get_cache_token.__class__.__qualname__ == 'builtin_function_or_method' — C-extension function from _abc; qualname is 26 chars"
  category: class_names
  kind: python_call_eq
  function: get_cache_token.__class__.__qualname__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra41.abstractproperty_class_qualname_len:
  description: "abc.abstractproperty.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__class__.__qualname__.__len__
  args: []
  expected: 4

invariant abc_extra41.ABC_class_qualname_len:
  description: "abc.ABC.__class__.__qualname__.__len__() == 7 — 'ABCMeta' has 7 characters"
  category: class_names
  kind: python_call_eq
  function: ABC.__class__.__qualname__.__len__
  args: []
  expected: 7

invariant abc_extra41.ABCMeta_class_qualname_len:
  description: "abc.ABCMeta.__class__.__qualname__.__len__() == 4 — 'type' has 4 characters; same as abstractproperty.__class__.__qualname__.__len__()"
  category: class_names
  kind: python_call_eq
  function: ABCMeta.__class__.__qualname__.__len__
  args: []
  expected: 4

invariant abc_extra41.abstractmethod_class_qualname_len:
  description: "abc.abstractmethod.__class__.__qualname__.__len__() == 8 — 'function' has 8 characters"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__class__.__qualname__.__len__
  args: []
  expected: 8

invariant abc_extra41.get_cache_token_class_qualname_len:
  description: "abc.get_cache_token.__class__.__qualname__.__len__() == 26 — 'builtin_function_or_method' has 26 characters; longest of the five abc exports"
  category: class_names
  kind: python_call_eq
  function: get_cache_token.__class__.__qualname__.__len__
  args: []
  expected: 26
