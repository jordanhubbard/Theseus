spec: inspect_extra1981
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "inspect.Parameter, inspect.Signature, inspect.BoundArguments do NOT define __sizeof__ in their own dict."
    - "None of the inspect classes define __length_hint__ — they are not iterators."
    - "None of the inspect classes define __floor__, __ceil__, or __trunc__ — they are not numeric types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra1981.sizeof_protocol:
  description: "inspect types __sizeof__ dict-presence checks — none define __sizeof__ in own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1981
  columns: [id, function, args, expected]
  rows:
    - ["in1981001", "inspect.Parameter.__dict__.__contains__",      ["__sizeof__"], false]
    - ["in1981002", "inspect.Signature.__dict__.__contains__",      ["__sizeof__"], false]
    - ["in1981003", "inspect.BoundArguments.__dict__.__contains__", ["__sizeof__"], false]

