spec: concurrent_futures_extra901
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures primitives __module__ identity for Future, ThreadPoolExecutor, ProcessPoolExecutor, as_completed, wait"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra901.future_module:
  description: "concurrent.futures.Future __module__ identity"
  kind: python_call_eq
  category: future_module
  id_prefix: cf901fm
  columns: [id, function, args, expected]
  rows:
    - [cf901fm001, concurrent.futures.Future.__module__.__eq__,          ["concurrent.futures._base"], true]
    - [cf901fm002, concurrent.futures.Future.__name__.__eq__,            ["Future"],                   true]
    - [cf901fm003, concurrent.futures.Future.__qualname__.__eq__,        ["Future"],                   true]
    - [cf901fm004, concurrent.futures.Future.__class__.__name__.__eq__,  ["type"],                     true]
    - [cf901fm005, concurrent.futures.Future.cancel.__qualname__.__eq__, ["Future.cancel"],            true]
    - [cf901fm006, concurrent.futures.Future.result.__qualname__.__eq__, ["Future.result"],            true]

table concurrent_futures_extra901.executor_modules:
  description: "concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor __module__ identity"
  kind: python_call_eq
  category: executor_modules
  id_prefix: cf901ex
  columns: [id, function, args, expected]
  rows:
    - [cf901ex001, concurrent.futures.ThreadPoolExecutor.__module__.__eq__,         ["concurrent.futures.thread"], true]
    - [cf901ex002, concurrent.futures.ProcessPoolExecutor.__module__.__eq__,        ["concurrent.futures.process"], true]
    - [cf901ex003, concurrent.futures.ThreadPoolExecutor.__name__.__eq__,           ["ThreadPoolExecutor"],         true]
    - [cf901ex004, concurrent.futures.ProcessPoolExecutor.__name__.__eq__,          ["ProcessPoolExecutor"],        true]
    - [cf901ex005, concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__,       ["ThreadPoolExecutor"],         true]
    - [cf901ex006, concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__,      ["ProcessPoolExecutor"],        true]

table concurrent_futures_extra901.function_modules:
  description: "concurrent.futures.as_completed and wait __module__ identity"
  kind: python_call_eq
  category: function_modules
  id_prefix: cf901fn
  columns: [id, function, args, expected]
  rows:
    - [cf901fn001, concurrent.futures.as_completed.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf901fn002, concurrent.futures.wait.__module__.__eq__,         ["concurrent.futures._base"], true]
    - [cf901fn003, concurrent.futures.as_completed.__name__.__eq__,   ["as_completed"],              true]
    - [cf901fn004, concurrent.futures.wait.__name__.__eq__,           ["wait"],                      true]
    - [cf901fn005, concurrent.futures.as_completed.__qualname__.__eq__, ["as_completed"],             true]
    - [cf901fn006, concurrent.futures.wait.__qualname__.__eq__,       ["wait"],                      true]
    - [cf901fn007, concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__, ["str"],            true]
