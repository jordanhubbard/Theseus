spec: socket_extra2176
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/socket.html"
    - "CPython source: Lib/socket.py and Modules/socketmodule.c"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2176: iterator/sequence protocol dict-presence — __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__."
    - "socket.socket is a Python I/O class — it is not an iterator, awaitable, or mapping."
    - "socket.error (alias for OSError), socket.timeout, and socket.gaierror are exception classes — none are iterators or awaitables."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses — they support iteration via the enum metaclass, but define no iterator dunders in their own __dict__."
    - "None of the 6 classes define any of the 8 iterator/sequence protocol dunders in their own __dict__."
    - "socket.timeout.__dict__ contains only __doc__; socket.gaierror.__dict__ contains __module__, __weakref__, __doc__."
    - "All expected values (false) verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2176.socket_iterator_protocol:
  description: "socket.socket iterator/sequence protocol dict-presence — socket is an I/O class, not an iterator or awaitable"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2176

  columns: [id, function, args, expected]
  rows:
    - ["sk2176001", "socket.socket.__dict__.__contains__", ["__iter__"], false]
    - ["sk2176002", "socket.socket.__dict__.__contains__", ["__next__"], false]
    - ["sk2176003", "socket.socket.__dict__.__contains__", ["__aiter__"], false]
    - ["sk2176004", "socket.socket.__dict__.__contains__", ["__anext__"], false]
    - ["sk2176005", "socket.socket.__dict__.__contains__", ["__await__"], false]
    - ["sk2176006", "socket.socket.__dict__.__contains__", ["__length_hint__"], false]
    - ["sk2176007", "socket.socket.__dict__.__contains__", ["__reversed__"], false]
    - ["sk2176008", "socket.socket.__dict__.__contains__", ["__missing__"], false]

