spec: operator_extra34
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator_extra33.zspec.zsdl."
    - "Prior specs covered: __name__/__module__ for all core functions, __qualname__.__len__() for add/sub/mul/attrgetter/itemgetter/methodcaller, __mro__/__bases__ for attrgetter/itemgetter/methodcaller, __name__.__len__() for ne/gt/ge/le/neg/mod/lshift/rshift/floordiv, __module__.__len__() for itemgetter/methodcaller/sub/mul/neg, __call__/__new__/__repr__/__reduce__ qualname lens for attrgetter/itemgetter/methodcaller, boolean/bitwise qualname lens (and_/or_/xor/not_/concat/matmul/invert/pow), truth qualname len (5), __all__.__len__() (57) and .__class__.__name__.__len__() (4), __doc__.__class__.__name__.__len__() (3), methodcaller.__mro__.__len__() (2), methodcaller.__bases__[0].__name__.__len__() (6), methodcaller.__repr__.__qualname__.__len__() (21), division qualname lens (truediv=7/floordiv=8), in-place qualname lens, callable class qualname lens, comparison qualname lens (lt/le/eq/ne/gt/ge all 2), __dict__.__class__.__name__.__len__() for attrgetter/itemgetter/methodcaller (all 12), sequence/item operator qualname lens."
    - "This spec covers: arithmetic function __name__.__len__() for add/sub/mul/mod/pow (all 3), truediv (7), floordiv (8); arithmetic __qualname__.__len__() for add/sub/mul/mod/pow (all 3), truediv (7), floordiv (8); operator.add.__module__.__len__() (9 — '_operator', the C extension module name); operator.add.__doc__.__class__.__name__ ('str'); __mro__.__len__() for methodcaller/attrgetter/itemgetter (all 2)."
    - "Key findings: add/sub/mul/mod/pow have identical __name__ and __qualname__ lengths (3 each). truediv has length 7; floordiv has length 8. The C extension module name '_operator' is 9 characters (8 for 'operator' + 1 for the leading underscore). operator.add.__doc__ is a str object."
    - "Surprise: operator.add.__module__ == '_operator' (9 chars), not 'operator' (8). The arithmetic functions are implemented in the C extension module '_operator', not the Python-level 'operator' wrapper."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() table — arithmetic operator functions
#
# operator.add, sub, mul, mod, pow each have __name__ length 3 (their short
# function names). operator.truediv.__name__ == 'truediv' (length 7).
# operator.floordiv.__name__ == 'floordiv' (length 8). These are the actual
# C function names returned by __name__, identical to their __qualname__ for
# C-level builtin_function_or_method objects. No prior operator spec records
# __name__.__len__() for add/sub/mul/truediv as a grouped table.
# ---------------------------------------------------------------------------

table operator_extra34.arithmetic_name_lengths:
  description: "__name__.__len__() for arithmetic operator functions"
  kind: python_call_eq
  category: string_properties
  id_prefix: name_len

  columns: [id, function, args, expected, description]
  rows:
    - [add,
       add.__name__.__len__,
       [],
       3,
       "len(operator.add.__name__) == 3 — 'add'"]
    - [sub,
       sub.__name__.__len__,
       [],
       3,
       "len(operator.sub.__name__) == 3 — 'sub'"]
    - [mul,
       mul.__name__.__len__,
       [],
       3,
       "len(operator.mul.__name__) == 3 — 'mul'"]
    - [mod,
       mod.__name__.__len__,
       [],
       3,
       "len(operator.mod.__name__) == 3 — 'mod'"]
    - [pow,
       pow.__name__.__len__,
       [],
       3,
       "len(operator.pow.__name__) == 3 — 'pow'"]
    - [truediv,
       truediv.__name__.__len__,
       [],
       7,
       "len(operator.truediv.__name__) == 7 — 'truediv'"]
    - [floordiv,
       floordiv.__name__.__len__,
       [],
       8,
       "len(operator.floordiv.__name__) == 8 — 'floordiv'"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — arithmetic operator functions
#
# For C-level builtin_function_or_method objects, __qualname__ equals __name__.
# Therefore operator.add/sub/mul/mod/pow all have __qualname__ length 3;
# truediv has length 7; floordiv has length 8. This table records the
# __qualname__ side to complement the __name__ table above and confirm the
# name==qualname invariant for these C functions. No prior operator spec groups
# all seven arithmetic qualname lengths in a single table.
# ---------------------------------------------------------------------------

table operator_extra34.arithmetic_qualname_lengths:
  description: "__qualname__.__len__() for arithmetic operator functions — equals __name__.__len__() for C builtins"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [add,
       add.__qualname__.__len__,
       [],
       3,
       "len(operator.add.__qualname__) == 3 — 'add'; __qualname__ == __name__ for C builtins"]
    - [sub,
       sub.__qualname__.__len__,
       [],
       3,
       "len(operator.sub.__qualname__) == 3 — 'sub'"]
    - [mul,
       mul.__qualname__.__len__,
       [],
       3,
       "len(operator.mul.__qualname__) == 3 — 'mul'"]
    - [mod,
       mod.__qualname__.__len__,
       [],
       3,
       "len(operator.mod.__qualname__) == 3 — 'mod'"]
    - [pow,
       pow.__qualname__.__len__,
       [],
       3,
       "len(operator.pow.__qualname__) == 3 — 'pow'"]
    - [truediv,
       truediv.__qualname__.__len__,
       [],
       7,
       "len(operator.truediv.__qualname__) == 7 — 'truediv'"]
    - [floordiv,
       floordiv.__qualname__.__len__,
       [],
       8,
       "len(operator.floordiv.__qualname__) == 8 — 'floordiv'"]

# ---------------------------------------------------------------------------
# operator.add.__module__.__len__() == 9 — standalone invariant
#
# operator.add.__module__ == '_operator' (9 characters). The arithmetic
# functions are implemented in the C extension '_operator', not in the Python
# wrapper module 'operator'. The leading underscore adds 1 char vs 'operator'
# (8). This confirms that __module__ for these functions points to the C layer,
# not the public Python API module. No prior operator spec records
# add.__module__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant operator_extra34.add.module_len:
  description: "operator.add.__module__.__len__() == 9 — module is '_operator' (9 chars); the leading underscore identifies the C extension backing the operator module"
  category: module_attrs
  kind: python_call_eq
  function: add.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# operator.add.__doc__.__class__.__name__ == 'str' — standalone invariant
#
# operator.add.__doc__ is a str object. The docstring class name is 'str'
# (length 3). This confirms that the C extension docstring is exposed as a
# plain Python string, not a custom descriptor or bytes object. No prior
# operator spec records add.__doc__.__class__.__name__ as a standalone.
# ---------------------------------------------------------------------------

invariant operator_extra34.add.doc_class_name:
  description: "operator.add.__doc__.__class__.__name__ == 'str' — C extension docstrings are plain Python str objects"
  category: doc_type_checks
  kind: python_call_eq
  function: add.__doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# __mro__.__len__() — callable class types
#
# operator.methodcaller, attrgetter, and itemgetter are C-implemented callable
# classes. Each has __mro__ length 2 — a direct subclass of object with no
# intermediate base. This was implied by prior specs recording __bases__[0]
# but is recorded here as standalone invariants for direct testability under
# the extra34 namespace. No prior operator spec records these as invariants.
# ---------------------------------------------------------------------------

invariant operator_extra34.methodcaller.mro_len:
  description: "operator.methodcaller.__mro__.__len__() == 2 — (methodcaller, object); C type directly subclasses object"
  category: mro_lengths
  kind: python_call_eq
  function: methodcaller.__mro__.__len__
  args: []
  expected: 2

invariant operator_extra34.attrgetter.mro_len:
  description: "operator.attrgetter.__mro__.__len__() == 2 — (attrgetter, object); C type directly subclasses object"
  category: mro_lengths
  kind: python_call_eq
  function: attrgetter.__mro__.__len__
  args: []
  expected: 2

invariant operator_extra34.itemgetter.mro_len:
  description: "operator.itemgetter.__mro__.__len__() == 2 — (itemgetter, object); C type directly subclasses object"
  category: mro_lengths
  kind: python_call_eq
  function: itemgetter.__mro__.__len__
  args: []
  expected: 2
