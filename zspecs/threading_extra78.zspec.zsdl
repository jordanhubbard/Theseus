spec: threading_extra78
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra77.zspec.zsdl."
    - "This spec covers: threading Barrier __dict__ content + Timer __dict__ content (Wave 243)."
    - "Barrier.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of Barrier is a mappingproxy. Verified with Python 3.14.3."
    - "Barrier.__dict__.__contains__('wait') == True — Barrier.wait is defined. Verified with Python 3.14.3."
    - "Barrier.__dict__.__contains__('reset') == True — Barrier.reset is defined. Verified with Python 3.14.3."
    - "Barrier.__dict__.__contains__('abort') == True — Barrier.abort is defined. Verified with Python 3.14.3."
    - "Barrier.__dict__.__contains__('parties') == True — parties is a property on Barrier. Verified with Python 3.14.3."
    - "Timer.__dict__.__class__.__name__ == 'mappingproxy' — the class namespace of Timer is a mappingproxy. Verified with Python 3.14.3."
    - "Timer.__dict__.__contains__('run') == True — Timer overrides Thread.run. Verified with Python 3.14.3."
    - "Timer.__dict__.__contains__('cancel') == True — Timer.cancel is defined. Verified with Python 3.14.3."
    - "Timer.run.__code__.co_name == 'run' — code object name matches method name. Verified with Python 3.14.3."
    - "Timer.run.__code__.co_argcount == 1 — Timer.run takes only self. Verified with Python 3.14.3."
    - "Timer.cancel.__code__.co_name == 'cancel' — code object name matches method name. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Barrier __dict__ class name — extra78
#
# Wave 243 theme: Barrier.__dict__ is a mappingproxy.
#
# threading.Barrier.__dict__.__class__.__name__ == 'mappingproxy'
#
# No prior threading spec checks Barrier.__dict__.__class__.__name__ via thrdmore78. New to extra78.
# ---------------------------------------------------------------------------

table threading_extra78.Barrier_dict_class_name:
  description: "Barrier.__dict__.__class__.__name__=='mappingproxy'; wave 243 Barrier __dict__ content; new to extra78"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore78

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_dict_class_name_eq_mappingproxy,
       Barrier.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "threading.Barrier.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Barrier is a pure-Python class defined in Lib/threading.py that implements a reusable barrier synchronization primitive; its class namespace is exposed as a read-only mappingproxy; __dict__.__class__.__name__ == 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior threading spec checks Barrier.__dict__.__class__.__name__ via thrdmore78; new to extra78"]

# ---------------------------------------------------------------------------
# Barrier __dict__ method presence — extra78
#
# Wave 243 theme: Barrier.__dict__ contains wait/reset/abort/parties.
#
# threading.Barrier.__dict__.__contains__('wait')    == True
# threading.Barrier.__dict__.__contains__('reset')   == True
# threading.Barrier.__dict__.__contains__('abort')   == True
# threading.Barrier.__dict__.__contains__('parties') == True
#
# No prior threading spec checks Barrier.__dict__ method keys via thrdmore78. New to extra78.
# ---------------------------------------------------------------------------

table threading_extra78.Barrier_dict_methods:
  description: "Barrier.__dict__.__contains__('wait')==True, 'reset'==True, 'abort'==True, 'parties'==True; wave 243 Barrier __dict__ content; new to extra78"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore78

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_dict_contains_wait,
       Barrier.__dict__.__contains__,
       ["wait"],
       true,
       "threading.Barrier.__dict__.__contains__('wait') == True — Barrier.wait(timeout=None) is defined in the Barrier class body in Lib/threading.py; it blocks until all parties have called wait(); mappingproxy.__contains__('wait') returns True; no prior threading spec checks Barrier.__dict__.__contains__('wait') via thrdmore78; new to extra78"]
    - [Barrier_dict_contains_reset,
       Barrier.__dict__.__contains__,
       ["reset"],
       true,
       "threading.Barrier.__dict__.__contains__('reset') == True — Barrier.reset() is defined in the Barrier class body in Lib/threading.py; it resets the barrier to the empty state; mappingproxy.__contains__('reset') returns True; no prior threading spec checks Barrier.__dict__.__contains__('reset') via thrdmore78; new to extra78"]
    - [Barrier_dict_contains_abort,
       Barrier.__dict__.__contains__,
       ["abort"],
       true,
       "threading.Barrier.__dict__.__contains__('abort') == True — Barrier.abort() is defined in the Barrier class body in Lib/threading.py; it puts the barrier into a broken state causing all waiting threads to raise BrokenBarrierError; mappingproxy.__contains__('abort') returns True; no prior threading spec checks Barrier.__dict__.__contains__('abort') via thrdmore78; new to extra78"]
    - [Barrier_dict_contains_parties,
       Barrier.__dict__.__contains__,
       ["parties"],
       true,
       "threading.Barrier.__dict__.__contains__('parties') == True — Barrier.parties is a property defined in the Barrier class body in Lib/threading.py; it returns the number of threads required to pass the barrier; mappingproxy.__contains__('parties') returns True; no prior threading spec checks Barrier.__dict__.__contains__('parties') via thrdmore78; new to extra78"]

# ---------------------------------------------------------------------------
# Timer __dict__ class name and method presence — extra78
#
# Wave 243 theme: Timer.__dict__ is a mappingproxy; contains run/cancel.
#
# threading.Timer.__dict__.__class__.__name__     == 'mappingproxy'
# threading.Timer.__dict__.__contains__('run')    == True
# threading.Timer.__dict__.__contains__('cancel') == True
#
# No prior threading spec checks Timer.__dict__ attrs via thrdmore78. New to extra78.
# ---------------------------------------------------------------------------

table threading_extra78.Timer_dict_attrs:
  description: "Timer.__dict__.__class__.__name__=='mappingproxy', __contains__('run')==True, __contains__('cancel')==True; wave 243 Timer __dict__ content; new to extra78"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore78

  columns: [id, function, args, expected, description]
  rows:
    - [Timer_dict_class_name_eq_mappingproxy,
       Timer.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "threading.Timer.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Timer is a pure-Python class defined in Lib/threading.py that represents an action that should be run only after a certain amount of time has passed; it subclasses Thread; its class namespace is exposed as a read-only mappingproxy; __dict__.__class__.__name__ == 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior threading spec checks Timer.__dict__.__class__.__name__ via thrdmore78; new to extra78"]
    - [Timer_dict_contains_run,
       Timer.__dict__.__contains__,
       ["run"],
       true,
       "threading.Timer.__dict__.__contains__('run') == True — Timer overrides Thread.run() in its class body in Lib/threading.py; Timer.run() waits for the interval and then calls the function if not cancelled; mappingproxy.__contains__('run') returns True; no prior threading spec checks Timer.__dict__.__contains__('run') via thrdmore78; new to extra78"]
    - [Timer_dict_contains_cancel,
       Timer.__dict__.__contains__,
       ["cancel"],
       true,
       "threading.Timer.__dict__.__contains__('cancel') == True — Timer.cancel() is defined in the Timer class body in Lib/threading.py; it stops the timer and cancels the execution of the timer's action if the timer is still in its waiting stage; mappingproxy.__contains__('cancel') returns True; no prior threading spec checks Timer.__dict__.__contains__('cancel') via thrdmore78; new to extra78"]

# ---------------------------------------------------------------------------
# Timer.run and Timer.cancel code objects — extra78
#
# Wave 243 theme: Timer.run/__code__.co_name == 'run'; Timer.cancel same.
#
# threading.Timer.run.__code__.co_name       == 'run'
# threading.Timer.run.__code__.co_argcount   == 1
# threading.Timer.cancel.__code__.co_name    == 'cancel'
#
# No prior threading spec checks Timer method code objects via thrdmore78. New to extra78.
# ---------------------------------------------------------------------------

table threading_extra78.Timer_method_code_objects:
  description: "Timer.run.__code__.co_name=='run', co_argcount==1; Timer.cancel.__code__.co_name=='cancel'; wave 243 Timer code objects; new to extra78"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore78

  columns: [id, function, args, expected, description]
  rows:
    - [Timer_run_code_co_name_eq_run,
       Timer.run.__code__.co_name.__eq__,
       ["run"],
       true,
       "threading.Timer.run.__code__.co_name.__eq__('run') == True — Timer.run is a pure-Python method defined in Lib/threading.py; its code object's co_name attribute records the method name 'run' (3 chars); str.__eq__('run') returns True; no prior threading spec checks Timer.run.__code__.co_name via thrdmore78; new to extra78"]
    - [Timer_run_code_co_argcount_eq_1,
       Timer.run.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Timer.run.__code__.co_argcount.__eq__(1) == True — Timer.run(self) takes exactly one positional argument 'self'; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior threading spec checks Timer.run.__code__.co_argcount via thrdmore78; new to extra78"]
    - [Timer_cancel_code_co_name_eq_cancel,
       Timer.cancel.__code__.co_name.__eq__,
       ["cancel"],
       true,
       "threading.Timer.cancel.__code__.co_name.__eq__('cancel') == True — Timer.cancel is a pure-Python method defined in Lib/threading.py; its code object's co_name attribute records the method name 'cancel' (6 chars); str.__eq__('cancel') returns True; no prior threading spec checks Timer.cancel.__code__.co_name via thrdmore78; new to extra78"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra78
# ---------------------------------------------------------------------------

invariant threading_extra78.Barrier_dict_class_name:
  description: "threading.Barrier.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Barrier class namespace is a mappingproxy; wave 243 Barrier __dict__ content; new to extra78"
  kind: python_call_eq
  function: Barrier.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant threading_extra78.Barrier_dict_contains_wait:
  description: "threading.Barrier.__dict__.__contains__('wait') == True — Barrier class namespace contains 'wait'; wave 243 Barrier __dict__ content; new to extra78"
  kind: python_call_eq
  function: Barrier.__dict__.__contains__
  args: ["wait"]
  expected: true

invariant threading_extra78.Barrier_dict_contains_abort:
  description: "threading.Barrier.__dict__.__contains__('abort') == True — Barrier class namespace contains 'abort'; wave 243 Barrier __dict__ content; new to extra78"
  kind: python_call_eq
  function: Barrier.__dict__.__contains__
  args: ["abort"]
  expected: true

invariant threading_extra78.Timer_dict_contains_run:
  description: "threading.Timer.__dict__.__contains__('run') == True — Timer class namespace contains 'run' override; wave 243 Timer __dict__ content; new to extra78"
  kind: python_call_eq
  function: Timer.__dict__.__contains__
  args: ["run"]
  expected: true

invariant threading_extra78.Timer_cancel_code_co_name:
  description: "threading.Timer.cancel.__code__.co_name.__eq__('cancel') == True — Timer.cancel code object name is 'cancel'; wave 243 Timer code objects; new to extra78"
  kind: python_call_eq
  function: Timer.cancel.__code__.co_name.__eq__
  args: ["cancel"]
  expected: true
