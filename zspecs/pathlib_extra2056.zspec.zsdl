spec: pathlib_extra2056
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "pathlib.Path, pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath are filesystem path types."
    - "None of these classes implements the sequence/mapping protocol (__getitem__, __setitem__, __delitem__, __len__)."
    - "pathlib.PurePath defines __truediv__ and __rtruediv__ for path joining (/) but no item-access or attribute-hook operators."
    - "pathlib.PosixPath is the concrete POSIX path class; it also defines none of the item-access or attribute-hook operators."
    - "None defines __getattr__, __setattr__, or __delattr__ in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __getitem__ / __setitem__ / __delitem__ — sequence/mapping protocol
# All False: pathlib path types do not implement item access protocol
# ---------------------------------------------------------------------------

table pathlib_extra2056.getitem_protocol:
  description: "pathlib types __getitem__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2056

  columns: [id, function, args, expected]
  rows:
    - ["pl2056001", "pathlib.PurePath.__dict__.__contains__",        ["__getitem__"], false]
    - ["pl2056002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__getitem__"], false]
    - ["pl2056003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__getitem__"], false]
    - ["pl2056004", "pathlib.Path.__dict__.__contains__",            ["__getitem__"], false]
    - ["pl2056029", "pathlib.PosixPath.__dict__.__contains__",       ["__getitem__"], false]

