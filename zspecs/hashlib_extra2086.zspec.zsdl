spec: hashlib_extra2086
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 hashlib documentation — https://docs.python.org/3/library/hashlib.html"
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "_hashlib.zspec.zsdl"
    - "hashlib.zspec.zsdl"
  notes:
    - "Wave extra2086, theme: __format__ string formatting protocol dict-presence; __bytes__ bytes conversion dict-presence; __fspath__ filesystem path protocol dict-presence; __buffer__/__release_buffer__ buffer protocol dict-presence."
    - "hashlib exposes blake2b and blake2s as first-class type objects; other hash constructors (sha256, md5, etc.) return _hashlib.HASH instances but are not type objects themselves."
    - "Neither hashlib.blake2b nor hashlib.blake2s define __format__, __bytes__, __fspath__, __buffer__, or __release_buffer__ in their own __dict__."
    - "hashlib.blake2b and hashlib.blake2s are the same objects as _blake2.blake2b and _blake2.blake2s."
    - "pbkdf2_hmac and scrypt return plain bytes objects; their callables are not type objects and do not have __dict__."
    - "All expected values verified by running Python 3.12 hashlib on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __format__ string formatting protocol dict-presence
# ---------------------------------------------------------------------------

table hashlib_extra2086.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["hl2086001", "hashlib.blake2b.__dict__.__contains__", ["__format__"], false]
    - ["hl2086002", "hashlib.blake2s.__dict__.__contains__", ["__format__"], false]

# ---------------------------------------------------------------------------
# __bytes__ bytes conversion protocol dict-presence
# ---------------------------------------------------------------------------

table hashlib_extra2086.bytes_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["hl2086003", "hashlib.blake2b.__dict__.__contains__", ["__bytes__"], false]
    - ["hl2086004", "hashlib.blake2s.__dict__.__contains__", ["__bytes__"], false]

# ---------------------------------------------------------------------------
# __fspath__ filesystem path protocol dict-presence
# ---------------------------------------------------------------------------

table hashlib_extra2086.fspath_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["hl2086005", "hashlib.blake2b.__dict__.__contains__", ["__fspath__"], false]
    - ["hl2086006", "hashlib.blake2s.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# __buffer__ / __release_buffer__ buffer protocol dict-presence
# ---------------------------------------------------------------------------

table hashlib_extra2086.buffer_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["hl2086007", "hashlib.blake2b.__dict__.__contains__", ["__buffer__"], false]
    - ["hl2086008", "hashlib.blake2b.__dict__.__contains__", ["__release_buffer__"], false]
    - ["hl2086009", "hashlib.blake2s.__dict__.__contains__", ["__buffer__"], false]
    - ["hl2086010", "hashlib.blake2s.__dict__.__contains__", ["__release_buffer__"], false]

# ---------------------------------------------------------------------------
# blake2b class attributes — digest_size, block_size, SALT_SIZE etc.
# ---------------------------------------------------------------------------

table hashlib_extra2086.blake2b_class_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["hl2086011", "hashlib.blake2b.__dict__.__contains__", ["digest_size"], true]
    - ["hl2086012", "hashlib.blake2b.__dict__.__contains__", ["block_size"], true]
    - ["hl2086013", "hashlib.blake2b.__dict__.__contains__", ["SALT_SIZE"], true]
    - ["hl2086014", "hashlib.blake2b.__dict__.__contains__", ["MAX_KEY_SIZE"], true]
    - ["hl2086015", "hashlib.blake2b.__dict__.__contains__", ["MAX_DIGEST_SIZE"], true]
    - ["hl2086016", "hashlib.blake2b.__dict__.__contains__", ["PERSON_SIZE"], true]
    - ["hl2086017", "hashlib.blake2b.__dict__.__contains__", ["update"], true]
    - ["hl2086018", "hashlib.blake2b.__dict__.__contains__", ["digest"], true]
    - ["hl2086019", "hashlib.blake2b.__dict__.__contains__", ["hexdigest"], true]
    - ["hl2086020", "hashlib.blake2b.__dict__.__contains__", ["copy"], true]

# ---------------------------------------------------------------------------
# blake2s class attributes — mirrors blake2b
# ---------------------------------------------------------------------------

table hashlib_extra2086.blake2s_class_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["hl2086021", "hashlib.blake2s.__dict__.__contains__", ["digest_size"], true]
    - ["hl2086022", "hashlib.blake2s.__dict__.__contains__", ["block_size"], true]
    - ["hl2086023", "hashlib.blake2s.__dict__.__contains__", ["SALT_SIZE"], true]
    - ["hl2086024", "hashlib.blake2s.__dict__.__contains__", ["MAX_KEY_SIZE"], true]
    - ["hl2086025", "hashlib.blake2s.__dict__.__contains__", ["update"], true]
    - ["hl2086026", "hashlib.blake2s.__dict__.__contains__", ["digest"], true]
    - ["hl2086027", "hashlib.blake2s.__dict__.__contains__", ["hexdigest"], true]
    - ["hl2086028", "hashlib.blake2s.__dict__.__contains__", ["copy"], true]
