  rows:
    - ["io1816-cp-001", "io.BytesIO.__dict__.__contains__", ["__reduce__"], false]
    - ["io1816-cp-002", "io.BytesIO.__dict__.__contains__", ["__copy__"], false]
    - ["io1816-cp-003", "io.BytesIO.__dict__.__contains__", ["__deepcopy__"], false]
    - ["io1816-cp-004", "io.StringIO.__dict__.__contains__", ["__reduce__"], false]
    - ["io1816-cp-005", "io.StringIO.__dict__.__contains__", ["__copy__"], false]
    - ["io1816-cp-006", "io.IOBase.__dict__.__contains__", ["__reduce__"], false]
    - ["io1816-cp-007", "io.IOBase.__dict__.__contains__", ["__copy__"], false]
    - ["io1816-cp-008", "io.FileIO.__dict__.__contains__", ["__reduce__"], false]

table io_extra1816.iobase_protocol:
