spec: io_extra1816
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "io module CPython source"
    - "Python data model documentation"
  not_derived_from:
    - "any third-party io library"
  notes:
    - "Tests __format__, __repr__, __str__, __reduce__, __copy__, __deepcopy__ presence in class __dict__"
    - "Tests IOBase abstract protocol attribute presence"
  created_at: "2026-04-12"

table io_extra1816.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["io1816-fp-001", "io.BytesIO.__dict__.__contains__", ["__format__"], false]
    - ["io1816-fp-002", "io.BytesIO.__dict__.__contains__", ["__repr__"], false]
    - ["io1816-fp-003", "io.StringIO.__dict__.__contains__", ["__format__"], false]
    - ["io1816-fp-004", "io.StringIO.__dict__.__contains__", ["__repr__"], false]
    - ["io1816-fp-005", "io.FileIO.__dict__.__contains__", ["__repr__"], true]
    - ["io1816-fp-006", "io.BufferedReader.__dict__.__contains__", ["__repr__"], true]
    - ["io1816-fp-007", "io.TextIOWrapper.__dict__.__contains__", ["__repr__"], true]
    - ["io1816-fp-008", "io.IOBase.__dict__.__contains__", ["__repr__"], false]

table io_extra1816.copy_protocol:
