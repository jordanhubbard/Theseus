spec: asyncio_extra239
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-stream.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — Python asyncio streams documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "This spec covers asyncio.StreamReader and asyncio.StreamWriter class identity."
    - "asyncio.StreamReader.__name__ == 'StreamReader' — 12 characters."
    - "asyncio.StreamReader.__module__ == 'asyncio.streams' — defined in the streams submodule (15 chars)."
    - "asyncio.StreamReader.__bases__[0].__name__ == 'object' — direct base is object in Python 3.14."
    - "asyncio.StreamWriter.__name__ == 'StreamWriter' — 12 characters."
    - "asyncio.StreamWriter.__module__ == 'asyncio.streams' — defined in the streams submodule (15 chars)."
    - "asyncio.StreamWriter.__bases__[0].__name__ == 'object' — direct base is object in Python 3.14."
    - "StreamReader methods: feed_data, read, readline, readexactly all carry expected qualnames."
    - "StreamWriter methods: write, drain, close all carry expected qualnames."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.StreamReader class identity contracts
#
# StreamReader.__name__, __module__, and __bases__[0].__name__ confirm the
# class is defined in asyncio.streams and inherits directly from object.
# ---------------------------------------------------------------------------

table asyncio_extra239.streamreader_class_identity:
  description: "asyncio.StreamReader class identity: name, module, qualname, base class; new to extra239"
  kind: python_call_eq
  category: class_identity
  id_prefix: aiostream239r

  columns: [id, function, args, expected, description]
  rows:
    - [sr_name_eq,
       StreamReader.__name__.__eq__,
       ["StreamReader"],
       true,
       "asyncio.StreamReader.__name__.__eq__('StreamReader') == True — class carries unqualified name 'StreamReader'; new to extra239"]
    - [sr_module_eq,
       StreamReader.__module__.__eq__,
       ["asyncio.streams"],
       true,
       "asyncio.StreamReader.__module__.__eq__('asyncio.streams') == True — StreamReader defined in asyncio.streams submodule; new to extra239"]
    - [sr_qualname_eq,
       StreamReader.__qualname__.__eq__,
       ["StreamReader"],
       true,
       "asyncio.StreamReader.__qualname__.__eq__('StreamReader') == True — top-level class; qualname equals __name__; new to extra239"]
    - [sr_base_name_eq,
       "StreamReader.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "asyncio.StreamReader.__bases__[0].__name__.__eq__('object') == True — direct base is object in Python 3.14; new to extra239"]
    - [sr_name_len_12,
       StreamReader.__name__.__len__,
       [],
       12,
       "asyncio.StreamReader.__name__.__len__() == 12 — 'StreamReader' has exactly 12 characters; new to extra239"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.StreamWriter class identity contracts
#
# StreamWriter.__name__, __module__, and __bases__[0].__name__ confirm the
# class is defined in asyncio.streams and inherits directly from object.
# ---------------------------------------------------------------------------

table asyncio_extra239.streamwriter_class_identity:
  description: "asyncio.StreamWriter class identity: name, module, qualname, base class; new to extra239"
  kind: python_call_eq
  category: class_identity
  id_prefix: aiostream239w

  columns: [id, function, args, expected, description]
  rows:
    - [sw_name_eq,
       StreamWriter.__name__.__eq__,
       ["StreamWriter"],
       true,
       "asyncio.StreamWriter.__name__.__eq__('StreamWriter') == True — class carries unqualified name 'StreamWriter'; new to extra239"]
    - [sw_module_eq,
       StreamWriter.__module__.__eq__,
       ["asyncio.streams"],
       true,
       "asyncio.StreamWriter.__module__.__eq__('asyncio.streams') == True — StreamWriter defined in asyncio.streams submodule; new to extra239"]
    - [sw_qualname_eq,
       StreamWriter.__qualname__.__eq__,
       ["StreamWriter"],
       true,
       "asyncio.StreamWriter.__qualname__.__eq__('StreamWriter') == True — top-level class; qualname equals __name__; new to extra239"]
    - [sw_base_name_eq,
       "StreamWriter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "asyncio.StreamWriter.__bases__[0].__name__.__eq__('object') == True — direct base is object in Python 3.14; new to extra239"]
    - [sw_name_len_12,
       StreamWriter.__name__.__len__,
       [],
       12,
       "asyncio.StreamWriter.__name__.__len__() == 12 — 'StreamWriter' has exactly 12 characters; new to extra239"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.StreamReader method qualname contracts
#
# For methods defined directly on StreamReader, the __qualname__ is
# 'StreamReader.<method>'.  Verifies feed_data, read, readline, readexactly.
# ---------------------------------------------------------------------------

table asyncio_extra239.streamreader_method_qualnames:
  description: "asyncio.StreamReader method __qualname__ contracts; new to extra239"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aiostream239r

  columns: [id, function, args, expected, description]
  rows:
    - [sr_feed_data_qualname_eq,
       StreamReader.feed_data.__qualname__.__eq__,
       ["StreamReader.feed_data"],
       true,
       "asyncio.StreamReader.feed_data.__qualname__ == 'StreamReader.feed_data'; new to extra239"]
    - [sr_read_qualname_eq,
       StreamReader.read.__qualname__.__eq__,
       ["StreamReader.read"],
       true,
       "asyncio.StreamReader.read.__qualname__ == 'StreamReader.read'; new to extra239"]
    - [sr_readline_qualname_eq,
       StreamReader.readline.__qualname__.__eq__,
       ["StreamReader.readline"],
       true,
       "asyncio.StreamReader.readline.__qualname__ == 'StreamReader.readline'; new to extra239"]
    - [sr_readexactly_qualname_eq,
       StreamReader.readexactly.__qualname__.__eq__,
       ["StreamReader.readexactly"],
       true,
       "asyncio.StreamReader.readexactly.__qualname__ == 'StreamReader.readexactly'; new to extra239"]

# ---------------------------------------------------------------------------
# Table 4: asyncio.StreamWriter method qualname contracts
#
# For methods defined directly on StreamWriter, the __qualname__ is
# 'StreamWriter.<method>'.  Verifies write, drain, close.
# ---------------------------------------------------------------------------

table asyncio_extra239.streamwriter_method_qualnames:
  description: "asyncio.StreamWriter method __qualname__ contracts; new to extra239"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aiostream239w

  columns: [id, function, args, expected, description]
  rows:
    - [sw_write_qualname_eq,
       StreamWriter.write.__qualname__.__eq__,
       ["StreamWriter.write"],
       true,
       "asyncio.StreamWriter.write.__qualname__ == 'StreamWriter.write'; new to extra239"]
    - [sw_drain_qualname_eq,
       StreamWriter.drain.__qualname__.__eq__,
       ["StreamWriter.drain"],
       true,
       "asyncio.StreamWriter.drain.__qualname__ == 'StreamWriter.drain'; new to extra239"]
    - [sw_close_qualname_eq,
       StreamWriter.close.__qualname__.__eq__,
       ["StreamWriter.close"],
       true,
       "asyncio.StreamWriter.close.__qualname__ == 'StreamWriter.close'; new to extra239"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra239
# ---------------------------------------------------------------------------

invariant asyncio_extra239.StreamReader.name:
  description: "asyncio.StreamReader.__name__ == 'StreamReader'; new to extra239"
  category: class_identity
  kind: python_call_eq
  function: StreamReader.__name__.__eq__
  args: ["StreamReader"]
  expected: true

invariant asyncio_extra239.StreamReader.module:
  description: "asyncio.StreamReader.__module__ == 'asyncio.streams'; new to extra239"
  category: class_identity
  kind: python_call_eq
  function: StreamReader.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

invariant asyncio_extra239.StreamReader.base_name:
  description: "asyncio.StreamReader.__bases__[0].__name__ == 'object' — direct base in Python 3.14; new to extra239"
  category: class_identity
  kind: python_call_eq
  function: "StreamReader.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra239.StreamReader.module_len:
  description: "asyncio.StreamReader.__module__.__len__() == 15 — 'asyncio.streams' has 15 characters; new to extra239"
  category: class_identity
  kind: python_call_eq
  function: StreamReader.__module__.__len__
  args: []
  expected: 15

