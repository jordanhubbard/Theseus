spec: urllib_parse_extra13
version: ">=3.9"
backend: python_module(urllib.parse)

docs: https://docs.python.org/3/library/urllib.parse.html
rfcs:
  - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.parse.html — Python urllib.parse module documentation"
    - "RFC 3986 — Uniform Resource Identifier (URI): Generic Syntax"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/parse.py"
    - "urllib_parse_extra.zspec.zsdl — covers ParseResult/SplitResult/DefragResult __name__; urldefrag/urlunparse/urlunsplit behavioral; parse_qsl behavioral"
    - "urllib_parse_extra5.zspec.zsdl — covers quote_plus/unquote_plus/parse_qs/parse_qsl qualnames; urlparse.__module__"
    - "urllib_parse_extra6.zspec.zsdl — covers ParseResult/SplitResult/DefragResult __module__; urlsplit/urljoin/urlencode/quote/unquote/urlunparse/urlunsplit __module__"
    - "urllib_parse_extra7.zspec.zsdl — covers ParseResult/SplitResult/DefragResult __qualname__; DefragResult/_fields/__len__()==2; ParseResult/_fields/__len__()==6; SplitResult/_fields/__len__()==5"
    - "urllib_parse_extra11.zspec.zsdl — covers quote space->%20; unquote %20->space; urlencode return class; urlparse result class"
    - "urllib_parse_extra12.zspec.zsdl — covers urlparse with full URL (scheme/netloc/path/query/fragment); urlencode two-key dict; quote_plus space->plus"
  notes:
    - "This spec extends the urllib_parse chain through extra12; it does NOT duplicate invariants in any prior spec."
    - "Focus: ParseResult/SplitResult/DefragResult __bases__[0].__name__ (no prior spec checks this via dotted __bases__[0].__name__ chain — the not_derived_from reference in extra7 is inaccurate; verified no such invariants exist); __module__.__len__()==12 for the three result classes and key parse functions not yet length-checked."
    - "urllib.parse.ParseResult.__bases__[0].__name__ == '_ParseResultBase' — ParseResult inherits from a private named-tuple base. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "urllib.parse.SplitResult.__bases__[0].__name__ == '_SplitResultBase' — SplitResult inherits from its own private named-tuple base. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "urllib.parse.DefragResult.__bases__[0].__name__ == '_DefragResultBase' — same pattern. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "urllib.parse.ParseResult.__module__.__len__() == 12 — len('urllib.parse') == 12. urllib_parse_extra6 checks ParseResult.__module__=='urllib.parse' via __eq__; length is new."
    - "urllib.parse.urlparse.__module__.__len__() == 12 — urllib_parse_extra5 checks urlparse.__module__ via __eq__; length is new."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ParseResult / SplitResult / DefragResult __bases__[0].__name__
#
# No prior spec in the urllib_parse family checks any attribute accessed via
# the __bases__[0].__name__ dotted chain for these result classes. Each result
# class inherits from a private named-tuple base generated at import time.
# ---------------------------------------------------------------------------

table urllib_parse_extra13.result_base_names:
  description: "Direct base class name for urllib.parse result named-tuple classes"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base_name13

  columns: [id, function, args, expected]
  rows:
    - [ParseResult,  "ParseResult.__bases__[0].__name__.__eq__",  ["_ParseResultBase"],  true]
    - [SplitResult,  "SplitResult.__bases__[0].__name__.__eq__",  ["_SplitResultBase"],  true]
    - [DefragResult, "DefragResult.__bases__[0].__name__.__eq__", ["_DefragResultBase"], true]

# ---------------------------------------------------------------------------
# ParseResult.__module__.__len__() == 12
#
# urllib_parse_extra6 covers ParseResult.__module__ == 'urllib.parse' via __eq__.
# No prior spec checks the length of the module string. len('urllib.parse') == 12.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra13.ParseResult.module_len:
  description: "urllib.parse.ParseResult.__module__.__len__() == 12 — len('urllib.parse') == 12"
  category: class_metadata
  kind: python_call_eq
  function: ParseResult.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# SplitResult.__module__.__len__() == 12
#
# Same rationale as ParseResult above. urllib_parse_extra6 covers __module__
# equality; length is a new axis.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra13.SplitResult.module_len:
  description: "urllib.parse.SplitResult.__module__.__len__() == 12 — len('urllib.parse') == 12"
  category: class_metadata
  kind: python_call_eq
  function: SplitResult.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# DefragResult.__module__.__len__() == 12
#
# Same rationale. No prior spec checks the length of DefragResult.__module__.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra13.DefragResult.module_len:
  description: "urllib.parse.DefragResult.__module__.__len__() == 12 — len('urllib.parse') == 12"
  category: class_metadata
  kind: python_call_eq
  function: DefragResult.__module__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# urlparse.__module__.__len__() == 12
#
# urllib_parse_extra5 covers urlparse.__module__ == 'urllib.parse' via __eq__.
# No prior spec checks the length. len('urllib.parse') == 12.
# ---------------------------------------------------------------------------

invariant urllib_parse_extra13.urlparse.module_len:
  description: "urllib.parse.urlparse.__module__.__len__() == 12 — len('urllib.parse') == 12"
  category: function_metadata
  kind: python_call_eq
  function: urlparse.__module__.__len__
  args: []
  expected: 12
