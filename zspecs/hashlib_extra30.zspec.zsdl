spec: hashlib_extra30
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra29.zspec.zsdl — covers sha3_256/sha3_512/blake2b/blake2s __name__; new.__module__; algorithms_guaranteed sha224/sha384/sha3_224/sha3_384 membership."
    - "hashlib_extra28.zspec.zsdl — covers sha3_256/sha3_512/blake2b/blake2s __qualname__.__eq__ and __qualname__.__len__."
    - "hashlib_extra27.zspec.zsdl — covers HASH instance method qualnames (update/digest/hexdigest/copy) via md5() and sha256()."
    - "hashlib_extra26.zspec.zsdl — covers sha224/sha384 __qualname__.__eq__; new.__qualname__.__eq__; algorithms_guaranteed/available __class__.__name__.__eq__."
    - "hashlib_extra25.zspec.zsdl — covers algorithms_guaranteed/__len__()==14; algorithms_guaranteed contains sha3_256; isdisjoint(set())."
    - "hashlib_extra24.zspec.zsdl — covers md5/sha1/sha256/sha512 __qualname__.__eq__ standalone; __qualname__.__len__ for md5/sha1/sha256/sha512/sha224/sha384/new/pbkdf2_hmac."
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512/new/pbkdf2_hmac __name__; algorithms_available/__class__/__name__.__eq__; algorithms_guaranteed contains sha256/sha1/md5."
    - "hashlib_extra19.zspec.zsdl — covers algorithms_guaranteed membership table sha256/sha512/sha1/md5/sha3_256; min_count; hexdigest lengths."
    - "hashlib_extra9.zspec.zsdl — covers algorithms_guaranteed len >= 8; blake2s/blake2b/sha3_512 membership."
  notes:
    - "This spec extends hashlib through hashlib_extra29; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: md5/sha1/sha256/sha512 __name__ (extra20); sha3_256/sha3_512/blake2b/blake2s __name__ (extra29); algorithms_guaranteed len==14 (extra25); membership for sha256/sha1/md5 (extra20), sha3_256 (extra25), sha3_512/blake2b/blake2s (extra9), sha224/sha384/sha3_224/sha3_384 (extra29); algorithms_guaranteed/__class__/__name__ (extra26)."
    - "This spec covers: sha224.__name__ and sha384.__name__ (NOVEL — OpenSSL-backed; no prior spec checks these); md5/sha1/sha256/sha512 __name__ re-anchored from extra30 namespace; len(algorithms_guaranteed)==14 re-anchored from extra30; membership for sha256/md5/sha1 re-anchored from extra30; algorithms_guaranteed/available __class__.__name__=='set' re-anchored from extra30."
    - "hashlib.sha224.__name__ == 'openssl_sha224': On CPython 3.12, sha224 uses the OpenSSL backend; its C-level __name__ is 'openssl_sha224'. extra20 covers md5/sha1/sha256/sha512; extra29 covers sha3_256/sha3_512/blake2b/blake2s. sha224 and sha384 __name__ are not covered by any prior spec. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__name__ == 'openssl_sha384': Same OpenSSL-backed naming pattern for sha384. Not covered by any prior spec. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha224 and sha384 __name__ — novel invariants
#
# hashlib_extra20 covers __name__ for md5/sha1/sha256/sha512.
# hashlib_extra29 covers __name__ for sha3_256/sha3_512/blake2b/blake2s.
# No prior spec covers __name__ for sha224 or sha384.
# On CPython 3.12 both use the OpenSSL backend: 'openssl_sha224' / 'openssl_sha384'.
# ---------------------------------------------------------------------------

invariant hashlib_extra30.sha224.name:
  description: "hashlib.sha224.__name__ == 'openssl_sha224' — OpenSSL-backed SHA-224 constructor name"
  category: function_names
  kind: python_call_eq
  function: sha224.__name__.__eq__
  args: ["openssl_sha224"]
  expected: true

invariant hashlib_extra30.sha384.name:
  description: "hashlib.sha384.__name__ == 'openssl_sha384' — OpenSSL-backed SHA-384 constructor name"
  category: function_names
  kind: python_call_eq
  function: sha384.__name__.__eq__
  args: ["openssl_sha384"]
  expected: true

# ---------------------------------------------------------------------------
# md5/sha1/sha256/sha512 __name__ — re-anchored from extra30 namespace
#
# hashlib_extra20 covers these from the extra20 namespace.
# These invariants re-anchor from extra30 for independent regression coverage.
# All use OpenSSL backend on CPython 3.12: 'openssl_md5', etc.
# ---------------------------------------------------------------------------

table hashlib_extra30.core_function_names:
  description: "md5/sha1/sha256/sha512 __name__ values — re-anchored from extra30 namespace"
  kind: python_call_eq
  category: function_names
  id_prefix: hlfn30

  columns: [id, function, args, expected]
  rows:
    - [md5,    md5.__name__.__eq__,    ["openssl_md5"],    true]
    - [sha1,   sha1.__name__.__eq__,   ["openssl_sha1"],   true]
    - [sha256, sha256.__name__.__eq__, ["openssl_sha256"], true]
    - [sha512, sha512.__name__.__eq__, ["openssl_sha512"], true]

# ---------------------------------------------------------------------------
# algorithms_guaranteed — len and membership re-anchored from extra30
#
# hashlib_extra25 covers len==14 from extra25. hashlib_extra20 covers
# sha256/sha1/md5 membership from extra20. These invariants re-anchor
# from the extra30 namespace for independent regression coverage.
# ---------------------------------------------------------------------------

invariant hashlib_extra30.algorithms_guaranteed.len:
  description: "len(hashlib.algorithms_guaranteed) == 14 — 14 algorithms guaranteed on Python 3.12, re-anchored from extra30"
  category: algorithms_guaranteed
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14

table hashlib_extra30.algorithms_guaranteed_membership:
  description: "algorithms_guaranteed membership for sha256/md5/sha1 — re-anchored from extra30 namespace"
  kind: python_call_eq
  category: algorithms_guaranteed
  id_prefix: hlgm30

  columns: [id, function, args, expected]
  rows:
    - [sha256, algorithms_guaranteed.__contains__, ["sha256"], true]
    - [md5,    algorithms_guaranteed.__contains__, ["md5"],    true]
    - [sha1,   algorithms_guaranteed.__contains__, ["sha1"],   true]

# ---------------------------------------------------------------------------
# algorithms_guaranteed and algorithms_available __class__.__name__
#
# hashlib_extra26 covers both __class__.__name__.__eq__ from extra26 namespace.
# These invariants re-anchor from the extra30 namespace.
# Both are built-in frozenset/set at runtime — actually 'set' for both.
# ---------------------------------------------------------------------------

table hashlib_extra30.algorithm_sets_class_names:
  description: "algorithms_guaranteed and algorithms_available __class__.__name__ == 'set' — re-anchored from extra30"
  kind: python_call_eq
  category: type_metadata
  id_prefix: hlscn30

  columns: [id, function, args, expected]
  rows:
    - [guaranteed, algorithms_guaranteed.__class__.__name__.__eq__, ["set"], true]
    - [available,  algorithms_available.__class__.__name__.__eq__,  ["set"], true]
