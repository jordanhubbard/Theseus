spec: uuid_extra159
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra158.zspec.zsdl — covers uuid.uuid1/__uuid3/__uuid4/__uuid5 .__name__/__module__/__class__.__name__ and name lengths (table + invariants)."
    - "uuid_extra157.zspec.zsdl — covers uuid.UUID.__name__=='UUID' / UUID.__module__=='uuid' / UUID.__bases__[0].__name__=='object' / NAMESPACE_DNS/URL/OID/X500.__class__.__name__=='UUID' (table + invariants)."
    - "uuid_extra156.zspec.zsdl — covers uuid.UUID.__dict__ property membership and meta-attributes (table + invariants)."
    - "uuid_extra155.zspec.zsdl — covers uuid.UUID.__init__.__code__ attributes (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra158."
    - "Wave 349 theme: uuid.SafeUUID enum class identity — SafeUUID.__name__=='SafeUUID' / SafeUUID.__module__=='uuid' / SafeUUID.__bases__[0].__name__=='Enum' (NOT IntEnum — SafeUUID is a plain Enum, not IntEnum; verified Python 3.14.3 macOS/Darwin) / SafeUUID.safe.__class__.__name__=='SafeUUID' / SafeUUID.unsafe.__class__.__name__=='SafeUUID' / SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1. SafeUUID was added in Python 3.7 to indicate whether a UUID was generated safely (using os.urandom()) or unsafely. SafeUUID.safe==0, SafeUUID.unsafe==-1."
    - "uuid.SafeUUID.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.__class__.__name__ == 'SafeUUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.safe.value == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.unsafe.value == -1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.SafeUUID.__bases__[0].__name__ == 'Enum' (4 chars). SafeUUID is a plain Enum, NOT an IntEnum. uuid_extra157 anchors UUID.__bases__[0].__name__=='object'; SafeUUID.__bases__[0].__name__ is 'Enum' (4 chars). The SafeUUID mro is ['SafeUUID', 'Enum', 'object'] — no int in the chain."
    - "Note: uuid.SafeUUID.safe.value == 0 and uuid.SafeUUID.unsafe.value == -1. SafeUUID.safe (value 0) indicates a UUID generated safely via os.urandom() or equivalent. SafeUUID.unsafe (value -1) indicates the UUID was generated without guaranteed safety. The unknown sentinel is the default for UUID instances that do not record safety."
    - "Note: SafeUUID.__name__ == 'SafeUUID' (8 chars = 'Safe'=4 + 'UUID'=4). SafeUUID.__module__ == 'uuid' (4 chars). 'SafeUUID'(8) > 'UUID'(4) by 4 chars — the 'Safe' prefix doubles the length of the base name 'UUID'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__name__.__eq__('SafeUUID')
# uuid.SafeUUID.__module__.__eq__('uuid')
# uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum')
# uuid.SafeUUID.__name__.__len__()==8
#
# Wave 349 theme: SafeUUID class identity metadata.
#
# SafeUUID.__name__ == 'SafeUUID' (8 chars; 'Safe'=4 + 'UUID'=4).
# SafeUUID.__module__ == 'uuid' (4 chars; defined in Lib/uuid.py).
# SafeUUID.__bases__[0].__name__ == 'Enum' (4 chars; plain Enum, not IntEnum).
# SafeUUID.__name__.__len__() == 8 ('SafeUUID' = 8 chars).
# No prior uuid spec anchors SafeUUID class identity as a table under uuidsafe159.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra159.SafeUUID_class_identity:
  description: "uuid.SafeUUID.__name__.__eq__('SafeUUID')==True / SafeUUID.__module__.__eq__('uuid')==True / SafeUUID.__bases__[0].__name__.__eq__('Enum')==True / SafeUUID.__name__.__len__()==8 — SafeUUID.__name__ is 'SafeUUID' (8 chars = 'Safe'=4 + 'UUID'=4; the class name for the safety indicator enum; 'Safe' prefix indicates it marks UUID generation safety; 'SafeUUID'(8) > 'UUID'(4) by 4 chars — the 'Safe' prefix doubles the length of 'UUID'); SafeUUID.__module__ is 'uuid' (4 chars; SafeUUID is defined in Lib/uuid.py; same module as UUID class; uuid_extra157 anchors UUID.__module__=='uuid'(4 chars)); SafeUUID.__bases__[0].__name__ is 'Enum' (4 chars; SafeUUID inherits from enum.Enum; it is a plain Enum NOT an IntEnum; SafeUUID's mro is SafeUUID -> Enum -> object; 'Enum'(4 chars) == 'uuid'(4 chars) == 'UUID'(4 chars) in length — a three-way tie; SafeUUID.safe.value==0 and SafeUUID.unsafe.value==-1 are the two enum members); SafeUUID.__name__.__len__() is 8 ('SafeUUID' = 8 chars; 'SafeUUID'(8) > 'Enum'(4) > by 4; same as SafeUUID.__module__.__len__()==4 * 2; first uuidsafe159 anchor for SafeUUID class identity)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidsafe159

  columns: [id, function, args, expected, description]
  rows:
    - [safe_uuid_name,       "SafeUUID.__name__.__eq__",               ["SafeUUID"], true, "uuid.SafeUUID.__name__ == 'SafeUUID' (8 chars = 'Safe'=4 + 'UUID'=4; 8 > UUID.__name__.__len__()==4 by 4; safety indicator enum)"]
    - [safe_uuid_module,     "SafeUUID.__module__.__eq__",             ["uuid"],     true, "uuid.SafeUUID.__module__ == 'uuid' (4 chars; defined in Lib/uuid.py; same module as UUID class; uuid_extra157 anchors UUID.__module__=='uuid')"]
    - [safe_uuid_bases_enum, "SafeUUID.__bases__[0].__name__.__eq__",  ["Enum"],     true, "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' (4 chars; plain Enum not IntEnum; mro: SafeUUID->Enum->object; 'Enum'(4)==uuid'(4)=='UUID'(4))"]
    - [safe_uuid_name_len_8, "SafeUUID.__name__.__len__",              [],           8,    "uuid.SafeUUID.__name__.__len__() is 8 ('SafeUUID' = 8 chars; 'Safe'=4 + 'UUID'=4; twice the length of 'UUID'=4 and 'uuid'=4)"]

# ---------------------------------------------------------------------------
