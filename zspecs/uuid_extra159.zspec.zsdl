    - [safe_uuid_module_len_4,    "SafeUUID.__module__.__len__",             [], 4,    "uuid.SafeUUID.__module__.__len__() is 4 ('uuid' = 4 chars; same module length as UUID.__module__='uuid'(4); uuid_extra157 anchors)"]
