    - [safe_value_0_b,            "SafeUUID.safe.value.__eq__",              [0], true, "uuid.SafeUUID.safe.value == 0 (confirmed; safe generation value; unsafe.value==-1; safe(0) > unsafe(-1))"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__name__.__eq__('SafeUUID') — standalone
#
# uuid.SafeUUID.__name__ is 'SafeUUID' (8 chars). SafeUUID is an enum class added in
# Python 3.7 to report whether a UUID was generated in a safe manner. Its __name__ is
# 'SafeUUID' (8 chars = 'Safe'=4 + 'UUID'=4). The 'Safe' prefix prepended to 'UUID' doubles
# the name length from 4 to 8 chars. SafeUUID has exactly two members: safe (value 0) and
# unsafe (value -1). uuid.UUID.__is_safe attribute holds a SafeUUID member.
# No prior uuid spec anchors SafeUUID.__name__ as a standalone under uuidsafe159.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra159.SafeUUID_name_SafeUUID:
  description: "uuid.SafeUUID.__name__.__eq__('SafeUUID') == True — 'SafeUUID' (8 chars = 'Safe'=4 + 'UUID'=4; added in Python 3.7 to report UUID generation safety; two members: safe(value=0) and unsafe(value=-1); UUID.__is_safe holds a SafeUUID member; SafeUUID.__module__=='uuid'(4 chars); SafeUUID.__bases__[0].__name__=='Enum'(4 chars; plain Enum not IntEnum); 'SafeUUID'(8) > 'UUID'(4) by 4 chars; first uuidsafe159 standalone for SafeUUID.__name__"
  category: identity
  kind: python_call_eq
  function: SafeUUID.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__module__.__eq__('uuid') — standalone
#
# uuid.SafeUUID.__module__ is 'uuid' (4 chars). SafeUUID is defined in Lib/uuid.py alongside
# the UUID class. SafeUUID.__module__ == 'uuid' (4 chars) == UUID.__module__ (4 chars).
# The SafeUUID enum and the UUID class share the same module. 'uuid' (4 chars) is the same
# length as 'UUID' (4 chars) and 'Enum' (4 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra159.SafeUUID_module_uuid:
  description: "uuid.SafeUUID.__module__.__eq__('uuid') == True — 'uuid' (4 chars; same module as UUID class; SafeUUID.__module__(4)==UUID.__module__(4)=='uuid'(4)); SafeUUID is defined in Lib/uuid.py; SafeUUID.__name__=='SafeUUID'(8 chars); 'uuid'(4)==Enum'(4)=='UUID'(4) — three-way length tie; SafeUUID and UUID both live in the same module; first uuidsafe159 standalone for SafeUUID.__module__"
  category: identity
  kind: python_call_eq
  function: SafeUUID.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') — standalone
#
# uuid.SafeUUID.__bases__[0].__name__ is 'Enum' (4 chars). SafeUUID inherits from enum.Enum,
# making it a plain Enum (not IntEnum). The SafeUUID mro is [SafeUUID, Enum, object].
# SafeUUID members (safe, unsafe) do NOT inherit from int. Their values are accessed via
# .value (safe.value==0, unsafe.value==-1). This contrasts with socket.AddressFamily and
# socket.SocketKind which are IntEnum subclasses (bases[0].__name__=='IntEnum').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra159.SafeUUID_bases_Enum:
  description: "uuid.SafeUUID.__bases__[0].__name__.__eq__('Enum') == True — 'Enum' (4 chars; plain Enum not IntEnum; SafeUUID mro: [SafeUUID, Enum, object]; members do NOT inherit from int; values accessed via .value: safe.value==0, unsafe.value==-1); contrasts with socket.AddressFamily.__bases__[0].__name__=='IntEnum' and SocketKind.__bases__[0].__name__=='IntEnum' (those are IntEnum); 'Enum'(4)==uuid'(4)=='UUID'(4) — three-way tie; first uuidsafe159 standalone for SafeUUID.__bases__[0].__name__"
  category: identity
  kind: python_call_eq
  function: "SafeUUID.__bases__[0].__name__.__eq__"
  args: ["Enum"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe.__class__.__name__.__eq__('SafeUUID') — standalone
#
# uuid.SafeUUID.safe.__class__.__name__ is 'SafeUUID' (8 chars). SafeUUID.safe is the enum
# member representing safe UUID generation (generated using a cryptographically strong random
# source such as os.urandom()). Its __class__ is the SafeUUID enum itself, so __class__.__name__
# is 'SafeUUID'. SafeUUID.safe has value 0. uuid.uuid4() sets is_safe=SafeUUID.safe (value 0)
# when the OS provides a safe random source. The is_safe attribute was added in Python 3.7.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra159.SafeUUID_safe_class_name:
  description: "uuid.SafeUUID.safe.__class__.__name__.__eq__('SafeUUID') == True — 'SafeUUID' (8 chars; SafeUUID.safe is an instance of the SafeUUID enum class; .safe is the 'safe generation' member with value 0; uuid.uuid4() may set is_safe=SafeUUID.safe(value=0) when OS provides cryptographic randomness; SafeUUID.safe.value==0; SafeUUID.__name__=='SafeUUID'(8 chars); first uuidsafe159 standalone for SafeUUID.safe.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: SafeUUID.safe.__class__.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.unsafe.__class__.__name__.__eq__('SafeUUID') — standalone
#
# uuid.SafeUUID.unsafe.__class__.__name__ is 'SafeUUID' (8 chars). SafeUUID.unsafe is the
# enum member representing unsafe UUID generation (where the OS cannot guarantee
# cryptographic randomness). Its __class__ is the SafeUUID enum so __class__.__name__ is
# 'SafeUUID'. SafeUUID.unsafe has value -1. uuid.uuid4() may set is_safe=SafeUUID.unsafe
# (value -1) on platforms where uuid generation is not guaranteed to be safe.
# Both SafeUUID.safe and SafeUUID.unsafe have __class__.__name__ == 'SafeUUID'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra159.SafeUUID_unsafe_class_name:
  description: "uuid.SafeUUID.unsafe.__class__.__name__.__eq__('SafeUUID') == True — 'SafeUUID' (8 chars; SafeUUID.unsafe is an instance of the SafeUUID enum class; .unsafe is the 'unsafe generation' member with value -1; uuid.uuid4() may set is_safe=SafeUUID.unsafe(value=-1) when OS cannot guarantee cryptographic safety; SafeUUID.unsafe.value==-1; same __class__.__name__ as SafeUUID.safe (both are SafeUUID members); first uuidsafe159 standalone for SafeUUID.unsafe.__class__.__name__"
  category: identity
  kind: python_call_eq
  function: SafeUUID.unsafe.__class__.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.safe.value.__eq__(0) — standalone
#
# uuid.SafeUUID.safe.value is 0. The .safe member's underlying value is 0. In Python Enum
# members, .value returns the underlying scalar value. SafeUUID.safe.value == 0 means that
# safe generation is represented by the integer 0. Since SafeUUID is a plain Enum (not
# IntEnum), you cannot use SafeUUID.safe == 0 directly for integer comparison — you must use
# SafeUUID.safe.value == 0 or SafeUUID.safe == SafeUUID.safe. The value 0 for safe is
# intentional: 0 is the default falsy value for unset/no-info, and the choice of safe==0
# vs unsafe==-1 means that safe is "less negative" than unsafe.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra159.SafeUUID_safe_value_0:
  description: "uuid.SafeUUID.safe.value.__eq__(0) == True — SafeUUID.safe.value is 0 (the underlying integer value of the .safe enum member; safe generation represented by 0; SafeUUID is a plain Enum so .value must be used for integer comparison; SafeUUID.safe.value(0) > SafeUUID.unsafe.value(-1): safe(0) > unsafe(-1) by 1; the .value attribute returns the raw scalar; uuid.uuid4() sets is_safe=SafeUUID.safe(value=0) on safe platforms; first uuidsafe159 standalone for SafeUUID.safe.value"
  category: identity
  kind: python_call_eq
  function: SafeUUID.safe.value.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.unsafe.value.__eq__(-1) — standalone
#
# uuid.SafeUUID.unsafe.value is -1. The .unsafe member's underlying value is -1. This is
# a negative sentinel value indicating that UUID generation was not safe. SafeUUID.unsafe.value
# (−1) < SafeUUID.safe.value (0). The choice of -1 for unsafe makes unsafe.value the only
# negative value in the SafeUUID enum, making it easy to check: if is_safe.value < 0:
# (the UUID was generated unsafely). SafeUUID has exactly two members: safe (0) and unsafe (-1).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra159.SafeUUID_unsafe_value_neg1:
  description: "uuid.SafeUUID.unsafe.value.__eq__(-1) == True — SafeUUID.unsafe.value is -1 (negative sentinel for unsafe UUID generation; -1 < 0: unsafe(-1) < safe(0) by 1; the only negative value in SafeUUID; SafeUUID has exactly two members: safe(0) and unsafe(-1); SafeUUID is a plain Enum so .value must be used for integer comparison; uuid.uuid4() may set is_safe=SafeUUID.unsafe(value=-1) on platforms without guaranteed randomness; first uuidsafe159 standalone for SafeUUID.unsafe.value"
  category: identity
  kind: python_call_eq
  function: SafeUUID.unsafe.value.__eq__
  args: [-1]
  expected: true
