spec: asyncio_extra29
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra28.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/wait_for/create_task/ensure_future/get_event_loop/new_event_loop/get_running_loop/__name__, Queue.__module__, Lock/Event/Semaphore/Condition/__module__, PriorityQueue/LifoQueue/__bases__[0].__name__, QueueEmpty/QueueFull/__bases__[0].__name__, CancelledError/TimeoutError/InvalidStateError/__module__, Queue.__bases__[0].__name__=='_LoopBoundMixin', Queue/Lock/Event __module__.__len__(), Queue/Lock/Event/Semaphore __name__.__len__(), gather/sleep/wait/create_task/get_event_loop __qualname__."
    - "This spec covers: Condition/BoundedSemaphore/TaskGroup __module__.__len__(); PriorityQueue/LifoQueue __module__.__len__() and __name__.__len__(); Task/Future __module__.__len__() (from C extension _asyncio); Semaphore/Condition/BoundedSemaphore __name__.__len__(); TaskGroup __name__.__len__()."
    - "Condition.__module__ == 'asyncio.locks' — length 13."
    - "BoundedSemaphore.__module__ == 'asyncio.locks' — length 13."
    - "TaskGroup.__module__ == 'asyncio.taskgroups' — length 18."
    - "PriorityQueue.__module__ == 'asyncio.queues' — length 14."
    - "LifoQueue.__module__ == 'asyncio.queues' — length 14."
    - "Task.__module__ == '_asyncio' — length 8 (C-extension type)."
    - "Future.__module__ == '_asyncio' — length 8 (C-extension type)."
    - "Semaphore.__name__ == 'Semaphore' — length 9."
    - "Condition.__name__ == 'Condition' — length 9."
    - "BoundedSemaphore.__name__ == 'BoundedSemaphore' — length 16."
    - "TaskGroup.__name__ == 'TaskGroup' — length 9."
    - "PriorityQueue.__name__ == 'PriorityQueue' — length 13."
    - "LifoQueue.__name__ == 'LifoQueue' — length 9."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __module__ length table — extra29 namespace
#
# Extending prior module-length coverage to classes not yet measured:
#   Condition.__module__ == 'asyncio.locks' (length 13)
#   BoundedSemaphore.__module__ == 'asyncio.locks' (length 13)
#   TaskGroup.__module__ == 'asyncio.taskgroups' (length 18)
#   PriorityQueue.__module__ == 'asyncio.queues' (length 14)
#   LifoQueue.__module__ == 'asyncio.queues' (length 14)
# Note: TaskGroup lives in asyncio.taskgroups, which is longer than
# asyncio.locks (13) or asyncio.queues (14) — it measures 18 chars.
# ---------------------------------------------------------------------------

table asyncio_extra29.class_module_lengths:
  description: "asyncio class __module__ lengths for Condition/BoundedSemaphore/TaskGroup/PriorityQueue/LifoQueue in extra29 namespace"
  kind: python_call_eq
  category: class_modules
  id_prefix: clsmodlen29

  columns: [id, function, args, expected]
  rows:
    - [Condition,        Condition.__module__.__len__,        [], 13]
    - [BoundedSemaphore, BoundedSemaphore.__module__.__len__, [], 13]
    - [TaskGroup,        TaskGroup.__module__.__len__,        [], 18]
    - [PriorityQueue,    PriorityQueue.__module__.__len__,    [], 14]
    - [LifoQueue,        LifoQueue.__module__.__len__,        [], 14]

# ---------------------------------------------------------------------------
# C-extension class __module__ length table — extra29 namespace
#
# asyncio.Task and asyncio.Future are implemented in the C-extension module
# _asyncio (not the pure-Python asyncio subpackage). Their __module__ is
# '_asyncio' (length 8), distinct from the pure-Python lock/queue/task
# helper classes. No prior spec has measured __module__.__len__() for these
# two classes.
# ---------------------------------------------------------------------------

table asyncio_extra29.c_ext_class_module_lengths:
  description: "asyncio C-extension class __module__ lengths for Task and Future in extra29 namespace"
  kind: python_call_eq
  category: class_modules
  id_prefix: cextmodlen29

  columns: [id, function, args, expected]
  rows:
    - [Task,   Task.__module__.__len__,   [], 8]
    - [Future, Future.__module__.__len__, [], 8]

# ---------------------------------------------------------------------------
# Class __name__ length table — extra29 namespace
#
# Extending prior __name__.__len__() coverage to the remaining asyncio sync
# and queue classes:
#   Semaphore.__name__ == 'Semaphore' (length 9)
#   Condition.__name__ == 'Condition' (length 9)
#   BoundedSemaphore.__name__ == 'BoundedSemaphore' (length 16)
#   TaskGroup.__name__ == 'TaskGroup' (length 9)
#   PriorityQueue.__name__ == 'PriorityQueue' (length 13)
#   LifoQueue.__name__ == 'LifoQueue' (length 9)
# Prior spec (extra28) covered Queue (5), Lock (4), Event (5), Semaphore (9).
# This table covers Condition, BoundedSemaphore, TaskGroup, PriorityQueue,
# and LifoQueue which were absent from the extra28 table.
# ---------------------------------------------------------------------------

table asyncio_extra29.class_name_lengths:
  description: "asyncio class __name__ lengths for Condition/BoundedSemaphore/TaskGroup/PriorityQueue/LifoQueue in extra29 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: clsnamelen29

  columns: [id, function, args, expected]
  rows:
    - [Condition,        Condition.__name__.__len__,        [], 9]
    - [BoundedSemaphore, BoundedSemaphore.__name__.__len__, [], 16]
    - [TaskGroup,        TaskGroup.__name__.__len__,        [], 9]
    - [PriorityQueue,    PriorityQueue.__name__.__len__,    [], 13]
    - [LifoQueue,        LifoQueue.__name__.__len__,        [], 9]

# ---------------------------------------------------------------------------
# TaskGroup __module__ string equality — extra29 standalone invariant
#
# asyncio.TaskGroup.__module__ == 'asyncio.taskgroups' (length 18). This
# confirms the full string value (not just length) for a class whose module
# differs from the common asyncio.locks (len=13) and asyncio.queues (len=14)
# submodules.
# ---------------------------------------------------------------------------

invariant asyncio_extra29.TaskGroup.module_eq:
  description: "asyncio.TaskGroup.__module__ == 'asyncio.taskgroups' — distinct submodule from locks/queues"
  category: class_modules
  kind: python_call_eq
  function: TaskGroup.__module__.__eq__
  args: ["asyncio.taskgroups"]
  expected: true

# ---------------------------------------------------------------------------
# Task.__module__ string equality — extra29 standalone invariant
#
# asyncio.Task.__module__ == '_asyncio' — the C-extension backing module.
# This confirms the full string value alongside the length invariant in the
# c_ext_class_module_lengths table above.
# ---------------------------------------------------------------------------

invariant asyncio_extra29.Task.module_eq:
  description: "asyncio.Task.__module__ == '_asyncio' — Task is implemented in the _asyncio C extension"
  category: class_modules
  kind: python_call_eq
  function: Task.__module__.__eq__
  args: ["_asyncio"]
  expected: true
