spec: theseus_re_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_re_cr3)
blocks: re

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html"
  notes:
    - "Clean-room extended regex utilities. Do NOT import re."
    - "fullmatch(pattern, string): match entire string against pattern."
    - "escape(pattern): escape all non-alphanumeric chars for literal matching."
    - "split(pattern, string, maxsplit=0): split string by pattern occurrences."
    - "re3_fullmatch(): fullmatch('[0-9]+', '123') is not None."
    - "re3_escape(): escape('a.b') == 'a\\.b' (dot escaped)."
    - "re3_split(): split('[,;]', 'a,b;c') == ['a','b','c']."
    - "Implement using the same NFA/DFA approach as theseus_re_cr but adding fullmatch, escape, split."
    - "fullmatch: same as match but anchors both ends of string."
    - "escape: replace non-alphanumeric with backslash-prefix."
    - "split: find all matches and split string around them."
    - "Export: fullmatch, escape, split, match, search, findall, compile."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_re_cr3.fullmatch:
  description: "fullmatch('[0-9]+', '123') is not None"
  category: fullmatch
  kind: python_call_eq
  function: re3_fullmatch
  args: []
  expected: true

invariant theseus_re_cr3.escape:
  description: "'.' escaped to '\\.'"
  category: escape
  kind: python_call_eq
  function: re3_escape
  args: []
  expected: "a\\.b"

invariant theseus_re_cr3.split:
  description: "split('[,;]', 'a,b;c') == ['a','b','c']"
  category: split
  kind: python_call_eq
  function: re3_split
  args: []
  expected: ["a", "b", "c"]
