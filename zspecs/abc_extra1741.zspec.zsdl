spec: abc_extra1741
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol dict-presence checks."
    - "Theme: which abc stdlib types define __get__, __set__, __delete__, __set_name__ in their own __dict__."
    - "abc.abstractmethod IS a descriptor: it defines __get__ in its own __dict__ -> True."
    - "abc.abstractmethod.__dict__.__contains__('__get__') -> True: abstractmethod implements __get__ so that when accessed on a class or instance it behaves like a bound method wrapper around the decorated callable."
    - "abc.abstractmethod.__dict__.__contains__('__set__') -> False: abstractmethod is a non-data descriptor (no __set__), so attribute assignment shadows the descriptor rather than routing through it."
    - "abc.abstractmethod.__dict__.__contains__('__delete__') -> False: no deletion protocol needed."
    - "abc.abstractmethod.__dict__.__contains__('__set_name__') -> False: abstractmethod does not use __set_name__ to record the attribute name — it relies on the wrapped function's __name__ instead."
    - "abc.ABCMeta: metaclass for abstract base classes; no descriptor methods in own __dict__ -> all False."
    - "abc.ABC: simple helper base class; no descriptor methods in own __dict__ -> all False."
    - "Key insight: abstractmethod.__get__ enables abstractmethod instances to participate in Python's descriptor protocol so they can be invoked as bound methods, and so that subclass method resolution works correctly through the ABC machinery."
    - "Cross-check: abc.abstractmethod.__isabstractmethod__ == True (confirms it is a true abstractmethod decorator)."
    - "Cross-check: abc.abstractmethod has no __set_name__ because it does not need to record the class-attribute name at class-creation time."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: descriptor protocol dict-presence checks (__get__, __set__, __delete__)
#
# Wave 563 theme: do abc types define descriptor dunders in their own __dict__?
#
# abc.abstractmethod IS a descriptor. It defines __get__ in its own __dict__,
# making it a non-data descriptor. When a method decorated with @abstractmethod
# is accessed through the normal attribute lookup path, Python calls
# abstractmethod.__get__(instance, owner) to return a bound-method-like wrapper.
# This is how abstractmethod can enforce the abstract contract while still
# allowing concrete subclass overrides to work through the descriptor machinery.
#
# abc.ABCMeta is a metaclass; it controls class creation and virtual-subclass
# registration, not attribute access interception on ordinary objects. It has
# no descriptor methods in its own __dict__.
#
# abc.ABC is a plain helper class that uses ABCMeta as its metaclass. It adds
# no descriptor machinery of its own.
# ---------------------------------------------------------------------------

table abc_extra1741.descriptor_protocol:
  description: "abc types: __get__, __set__, __delete__ dict-presence checks (__get__ True for abstractmethod; all others False)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1741

  columns: [id, function, args, expected]
  rows:
    - ["ab1741001", "abstractmethod.__dict__.__contains__", ["__get__"],    true]
    - ["ab1741002", "abstractmethod.__dict__.__contains__", ["__set__"],    false]
    - ["ab1741003", "abstractmethod.__dict__.__contains__", ["__delete__"], false]
    - ["ab1741004", "ABCMeta.__dict__.__contains__",        ["__get__"],    false]
    - ["ab1741005", "ABCMeta.__dict__.__contains__",        ["__set__"],    false]
    - ["ab1741006", "ABCMeta.__dict__.__contains__",        ["__delete__"], false]
    - ["ab1741007", "ABC.__dict__.__contains__",            ["__get__"],    false]
    - ["ab1741008", "ABC.__dict__.__contains__",            ["__set__"],    false]
    - ["ab1741009", "ABC.__dict__.__contains__",            ["__delete__"], false]
    - ["ab1741010", "abstractmethod.__dict__.__contains__", ["__get__"],    true]

# ---------------------------------------------------------------------------
# Table 2: __set_name__ dict-presence cross-checks and complementary attribute checks
#
# Wave 563 cross-check: __set_name__ (PEP 487) is called at class creation time
# when the metaclass detects a descriptor being stored as a class body attribute.
# abstractmethod does not implement __set_name__ — it extracts the method name
# from the wrapped callable's __name__ instead, which is already available
# because @abstractmethod is applied to a named function or method. ABCMeta and
# ABC similarly have no __set_name__ in their own __dict__.
#
# Complementary checks: verify abstractmethod.__isabstractmethod__ (True) and
# the presence of 'register' in ABCMeta's own __dict__ (True — ABCMeta.register
# adds virtual subclasses to an ABC). These cross-checks make the spec
# informative beyond the all-False rows.
# ---------------------------------------------------------------------------

table abc_extra1741.set_name_and_complementary:
  description: "abc types: __set_name__ dict-presence and complementary attribute checks (abstractmethod.__get__ True; all __set_name__ False)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1741

  columns: [id, function, args, expected]
  rows:
    - ["ab1741011", "abstractmethod.__dict__.__contains__", ["__set_name__"],      false]
    - ["ab1741012", "ABCMeta.__dict__.__contains__",        ["__set_name__"],      false]
    - ["ab1741013", "ABC.__dict__.__contains__",            ["__set_name__"],      false]
    - ["ab1741014", "abstractmethod.__dict__.__contains__", ["__isabstractmethod__"], true]
    - ["ab1741015", "ABCMeta.__dict__.__contains__",        ["register"],          true]
    - ["ab1741016", "abstractmethod.__dict__.__contains__", ["__wrapped__"],       false]
    - ["ab1741017", "abstractmethod.__dict__.__contains__", ["__get__"],           true]
    - ["ab1741018", "ABCMeta.__dict__.__contains__",        ["__get__"],           false]
    - ["ab1741019", "ABC.__dict__.__contains__",            ["__get__"],           false]
    - ["ab1741020", "ABCMeta.__dict__.__contains__",        ["__instancecheck__"], true]
    - ["ab1741021", "ABCMeta.__dict__.__contains__",        ["__subclasscheck__"], true]
    - ["ab1741022", "abstractmethod.__dict__.__contains__", ["__set__"],           false]
    - ["ab1741023", "abstractmethod.__dict__.__contains__", ["__delete__"],        false]
    - ["ab1741024", "ABCMeta.__dict__.__contains__",        ["__set__"],           false]
    - ["ab1741025", "ABC.__dict__.__contains__",            ["__set_name__"],      false]
