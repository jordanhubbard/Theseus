spec: hashlib_extra293
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hmac.html — hmac module identity and HMAC descriptor attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hmac.py, Modules/_hashopenssl.c"
  notes:
    - "hmac.__all__ is a list containing HMAC, new, compare_digest, digest"
    - "HMAC.name, HMAC.digest_size, HMAC.block_size are property descriptors"
    - "hmac functions new and compare_digest are builtin_function_or_method or function types"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra293.hmac_all_membership:
  description: "hmac.__all__ membership checks for key public names"
  kind: python_call_eq
  category: identity
  id_prefix: hmac293a

  columns: [id, function, args, expected, description]
  rows:
    - [hmac293a001, hmac.__all__.__contains__, ["HMAC"], true, "HMAC in hmac.__all__"]
    - [hmac293a002, hmac.__all__.__contains__, ["new"], true, "new in hmac.__all__"]
    - [hmac293a003, hmac.__all__.__contains__, ["compare_digest"], true, "compare_digest in hmac.__all__"]
    - [hmac293a004, hmac.__all__.__contains__, ["digest"], true, "digest in hmac.__all__"]
    - [hmac293a005, hmac.__all__.__class__.__name__, [], "list", "hmac.__all__ is a list"]

table hashlib_extra293.hmac_descriptor_class_names:
  description: "HMAC instance attribute descriptor class names (name, digest_size, block_size)"
  kind: python_call_eq
  category: identity
  id_prefix: hmac293b

  columns: [id, function, args, expected, description]
  rows:
    - [hmac293b001, hmac.HMAC.name.__class__.__name__, [], "property", "HMAC.name is a property descriptor"]
    - [hmac293b002, hmac.HMAC.digest_size.__class__.__name__, [], "property", "HMAC.digest_size is a property descriptor"]
    - [hmac293b003, hmac.HMAC.block_size.__class__.__name__, [], "property", "HMAC.block_size is a property descriptor"]
    - [hmac293b004, hmac.HMAC.__class__.__name__, [], "type", "hmac.HMAC is a type"]
    - [hmac293b005, hmac.new.__class__.__name__, [], "function", "hmac.new is a function"]
    - [hmac293b006, hmac.compare_digest.__class__.__name__, [], "builtin_function_or_method", "hmac.compare_digest is a builtin_function_or_method"]

invariant hashlib_extra293.hmac_update_qualname:
  description: "HMAC.update __qualname__ is 'HMAC.update'"
  category: identity
  kind: python_call_eq
  function: hmac.HMAC.update.__qualname__.__eq__
  args: ["HMAC.update"]
  expected: true

invariant hashlib_extra293.hmac_all_len:
  description: "hmac.__all__ has exactly 4 elements"
  category: identity
  kind: python_call_eq
  function: hmac.__all__.__len__
  args: []
  expected: 4

invariant hashlib_extra293.hmac_digest_function_class:
  description: "hmac.digest is a builtin_function_or_method"
  category: identity
  kind: python_call_eq
  function: hmac.digest.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
