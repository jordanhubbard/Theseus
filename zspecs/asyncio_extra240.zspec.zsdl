spec: asyncio_extra240
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec covers asyncio.Lock class identity and method contracts."
    - "asyncio.Lock.__name__ == 'Lock' — 4 characters."
    - "asyncio.Lock.__module__ == 'asyncio.locks' — defined in the locks submodule (13 chars)."
    - "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin' — first base is the mixin class."
    - "asyncio.Lock.__qualname__ == 'Lock' — simple top-level class name."
    - "Lock.acquire.__name__ == 'acquire'; __qualname__ == 'Lock.acquire' (12 chars)."
    - "Lock.release.__name__ == 'release'; __qualname__ == 'Lock.release' (12 chars)."
    - "Lock.locked.__name__ == 'locked'; __qualname__ == 'Lock.locked' (11 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Lock class identity contracts
#
# Verifies __name__, __module__, __qualname__ to confirm the class is defined
# in asyncio.locks and carries the expected identity attributes.
# ---------------------------------------------------------------------------

table asyncio_extra240.lock_class_identity:
  description: "asyncio.Lock class identity: name, module, qualname; new to extra240"
  kind: python_call_eq
  category: class_identity
  id_prefix: aiolock240

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,
       Lock.__name__.__eq__,
       ["Lock"],
       true,
       "asyncio.Lock.__name__.__eq__('Lock') == True — class carries unqualified name 'Lock'; new to extra240"]
    - [lock_module_eq,
       Lock.__module__.__eq__,
       ["asyncio.locks"],
       true,
       "asyncio.Lock.__module__.__eq__('asyncio.locks') == True — Lock defined in asyncio.locks submodule; new to extra240"]
    - [lock_qualname_eq,
       Lock.__qualname__.__eq__,
       ["Lock"],
       true,
       "asyncio.Lock.__qualname__.__eq__('Lock') == True — top-level class; qualname equals __name__; new to extra240"]
    - [lock_name_len_4,
       Lock.__name__.__len__,
       [],
       4,
       "asyncio.Lock.__name__.__len__() == 4 — 'Lock' has exactly 4 characters; new to extra240"]
    - [lock_module_len_13,
       Lock.__module__.__len__,
       [],
       13,
       "asyncio.Lock.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters; new to extra240"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Lock base class contract
#
# Lock.__bases__[0].__name__ == '_ContextManagerMixin' — the first base class.
# The function path contains '[' so must be double-quoted.
# ---------------------------------------------------------------------------

table asyncio_extra240.lock_base_class:
  description: "asyncio.Lock base class identity; new to extra240"
  kind: python_call_eq
  category: class_identity
  id_prefix: aiolock240b

  columns: [id, function, args, expected, description]
  rows:
    - [lock_base_name_eq,
       "Lock.__bases__[0].__name__.__eq__",
       ["_ContextManagerMixin"],
       true,
       "asyncio.Lock.__bases__[0].__name__.__eq__('_ContextManagerMixin') == True — first base is the mixin; new to extra240"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Lock method __name__ contracts
#
# acquire, release, locked each carry their simple __name__.
# ---------------------------------------------------------------------------

table asyncio_extra240.lock_method_names:
  description: "asyncio.Lock method __name__ contracts; new to extra240"
  kind: python_call_eq
  category: method_names
  id_prefix: aiolock240m

  columns: [id, function, args, expected, description]
  rows:
    - [acquire_name_eq,
       Lock.acquire.__name__.__eq__,
       ["acquire"],
       true,
       "asyncio.Lock.acquire.__name__.__eq__('acquire') == True — method carries its simple name; new to extra240"]
    - [release_name_eq,
       Lock.release.__name__.__eq__,
       ["release"],
       true,
       "asyncio.Lock.release.__name__.__eq__('release') == True — method carries its simple name; new to extra240"]
    - [locked_name_eq,
       Lock.locked.__name__.__eq__,
       ["locked"],
       true,
       "asyncio.Lock.locked.__name__.__eq__('locked') == True — method carries its simple name; new to extra240"]

# ---------------------------------------------------------------------------
# Table 4: asyncio.Lock method __qualname__ contracts
#
# acquire, release, locked each carry qualname 'Lock.<method>'.
# ---------------------------------------------------------------------------

table asyncio_extra240.lock_method_qualnames:
  description: "asyncio.Lock method __qualname__ contracts; new to extra240"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aiolock240m

  columns: [id, function, args, expected, description]
  rows:
    - [acquire_qualname_eq,
       Lock.acquire.__qualname__.__eq__,
       ["Lock.acquire"],
       true,
       "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire' (12 chars); new to extra240"]
    - [release_qualname_eq,
       Lock.release.__qualname__.__eq__,
       ["Lock.release"],
       true,
       "asyncio.Lock.release.__qualname__ == 'Lock.release' (12 chars); new to extra240"]
    - [locked_qualname_eq,
       Lock.locked.__qualname__.__eq__,
       ["Lock.locked"],
       true,
       "asyncio.Lock.locked.__qualname__ == 'Lock.locked' (11 chars); new to extra240"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra240
# ---------------------------------------------------------------------------

invariant asyncio_extra240.Lock.name:
  description: "asyncio.Lock.__name__ == 'Lock'; new to extra240"
  category: class_identity
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant asyncio_extra240.Lock.module:
  description: "asyncio.Lock.__module__ == 'asyncio.locks'; new to extra240"
  category: class_identity
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra240.Lock.qualname:
  description: "asyncio.Lock.__qualname__ == 'Lock'; new to extra240"
  category: class_identity
  kind: python_call_eq
  function: Lock.__qualname__.__eq__
  args: ["Lock"]
  expected: true

invariant asyncio_extra240.Lock.base_name:
  description: "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin'; new to extra240"
  category: class_identity
  kind: python_call_eq
  function: "Lock.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra240.Lock.module_len:
  description: "asyncio.Lock.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters; new to extra240"
  category: class_identity
  kind: python_call_eq
  function: Lock.__module__.__len__
  args: []
  expected: 13

invariant asyncio_extra240.Lock.acquire_name:
  description: "asyncio.Lock.acquire.__name__ == 'acquire'; new to extra240"
  category: method_names
  kind: python_call_eq
  function: Lock.acquire.__name__.__eq__
  args: ["acquire"]
  expected: true

invariant asyncio_extra240.Lock.acquire_qualname:
  description: "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire'; new to extra240"
  category: method_qualnames
  kind: python_call_eq
  function: Lock.acquire.__qualname__.__eq__
  args: ["Lock.acquire"]
  expected: true

invariant asyncio_extra240.Lock.release_name:
  description: "asyncio.Lock.release.__name__ == 'release'; new to extra240"
  category: method_names
  kind: python_call_eq
  function: Lock.release.__name__.__eq__
  args: ["release"]
  expected: true

invariant asyncio_extra240.Lock.release_qualname:
  description: "asyncio.Lock.release.__qualname__ == 'Lock.release'; new to extra240"
  category: method_qualnames
  kind: python_call_eq
  function: Lock.release.__qualname__.__eq__
  args: ["Lock.release"]
  expected: true

invariant asyncio_extra240.Lock.locked_name:
  description: "asyncio.Lock.locked.__name__ == 'locked'; new to extra240"
  category: method_names
  kind: python_call_eq
  function: Lock.locked.__name__.__eq__
  args: ["locked"]
  expected: true

invariant asyncio_extra240.Lock.locked_qualname:
  description: "asyncio.Lock.locked.__qualname__ == 'Lock.locked'; new to extra240"
  category: method_qualnames
  kind: python_call_eq
  function: Lock.locked.__qualname__.__eq__
  args: ["Lock.locked"]
  expected: true
