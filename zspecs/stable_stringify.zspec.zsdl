spec: stable_stringify
version: ">=1.0.0"
backend: node(stable-stringify)

docs: https://www.npmjs.com/package/stable-stringify

provenance:
  derived_from:
    - "stable-stringify README — https://www.npmjs.com/package/stable-stringify"
    - "Test vectors verified with stable-stringify via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "stable-stringify source"
  notes:
    - "stable-stringify is an npm package. Install: npm install stable-stringify"
    - "Serializes an object to JSON with keys sorted deterministically."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a JSON string with keys in sorted order."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table stable_stringify.stringify:
  kind: node_module_call_eq
  function: ~
  category: serialization
  id_prefix: sstrs

  columns: [id, args, expected]
  rows:
    - [sorted,   [{"b": 2, "a": 1}],           "{\"a\":1,\"b\":2}"]
    - [three,    [{"c": 3, "a": 1, "b": 2}],   "{\"a\":1,\"b\":2,\"c\":3}"]
    - [array,    [[3, 1, 2]],                   "[3,1,2]"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:10:06Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
