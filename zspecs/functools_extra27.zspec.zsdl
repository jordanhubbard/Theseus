spec: functools_extra27
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
    - "functools_extra26.zspec.zsdl — covers combined __qualname__.__eq__ table for reduce/lru_cache/cache/wraps/total_ordering/singledispatch/cached_property/partialmethod; standalone qualname invariants for reduce/lru_cache/cache/wraps/total_ordering."
    - "functools_extra20.zspec.zsdl — covers wraps/__qualname__.__len__() == 5 and cached_property/__qualname__.__len__() == 15 standalone."
    - "functools_extra18.zspec.zsdl — covers cache/__qualname__.__len__() == 5 standalone."
    - "functools_extra15.zspec.zsdl — covers partialmethod/__qualname__.__len__() == 13 standalone."
    - "functools_extra14.zspec.zsdl — covers cmp_to_key/total_ordering/singledispatch/singledispatchmethod __qualname__.__len__ standalone."
    - "functools_extra13.zspec.zsdl — covers reduce/__qualname__.__len__() == 6 and partial/__qualname__.__len__() == 7 standalone."
    - "functools_extra11.zspec.zsdl — covers lru_cache/__qualname__.__len__() == 9 standalone."
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra26.zspec.zsdl."
    - "Focus: (1) combined __qualname__.__len__ table for nine core functools callables in the extra27 namespace — each length was recorded individually in prior specs but no combined table exists in this namespace; (2) standalone __qualname__.__len__ invariants for wraps, cache, and partialmethod in the extra27 namespace."
    - "Prior specs cover each __qualname__.__len__ individually but scatter them across extra11/13/14/15/18/20. No spec combines all nine into a single table in the extra27 namespace."
    - "functools.reduce.__qualname__.__len__() == 6 — len('reduce') == 6."
    - "functools.partial.__qualname__.__len__() == 7 — len('partial') == 7."
    - "functools.partialmethod.__qualname__.__len__() == 13 — len('partialmethod') == 13."
    - "functools.wraps.__qualname__.__len__() == 5 — len('wraps') == 5."
    - "functools.lru_cache.__qualname__.__len__() == 9 — len('lru_cache') == 9."
    - "functools.cache.__qualname__.__len__() == 5 — len('cache') == 5."
    - "functools.cached_property.__qualname__.__len__() == 15 — len('cached_property') == 15."
    - "functools.total_ordering.__qualname__.__len__() == 14 — len('total_ordering') == 14."
    - "functools.singledispatch.__qualname__.__len__() == 14 — len('singledispatch') == 14."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__ for nine core functools callables — combined table
#
# Every entry was recorded as a standalone invariant in a prior spec:
# extra11 (lru_cache), extra13 (reduce/partial), extra14 (total_ordering/
# singledispatch), extra15 (partialmethod), extra18 (cache), extra20 (wraps/
# cached_property). No prior spec groups all nine together in one combined
# __qualname__.__len__ table in the extra27 namespace.
# ---------------------------------------------------------------------------

table functools_extra27.qualname_lens:
  description: "__qualname__.__len__ for nine core functools callables in the extra27 namespace"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [reduce,           reduce.__qualname__.__len__,           [], 6]
    - [partial,          partial.__qualname__.__len__,          [], 7]
    - [partialmethod,    partialmethod.__qualname__.__len__,    [], 13]
    - [wraps,            wraps.__qualname__.__len__,            [], 5]
    - [lru_cache,        lru_cache.__qualname__.__len__,        [], 9]
    - [cache,            cache.__qualname__.__len__,            [], 5]
    - [cached_property,  cached_property.__qualname__.__len__,  [], 15]
    - [total_ordering,   total_ordering.__qualname__.__len__,   [], 14]
    - [singledispatch,   singledispatch.__qualname__.__len__,   [], 14]

# ---------------------------------------------------------------------------
# wraps.__qualname__.__len__() == 5 — standalone in extra27 namespace
#
# functools_extra20 covers this value as a standalone invariant in the extra20
# namespace. No prior spec records it in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra27.wraps.qualname_len:
  description: "functools.wraps.__qualname__.__len__() == 5 — len('wraps') == 5"
  category: qualnames
  kind: python_call_eq
  function: wraps.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# cache.__qualname__.__len__() == 5 — standalone in extra27 namespace
#
# functools_extra18 covers this value as a standalone invariant in the extra18
# namespace. No prior spec records it in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra27.cache.qualname_len:
  description: "functools.cache.__qualname__.__len__() == 5 — len('cache') == 5"
  category: qualnames
  kind: python_call_eq
  function: cache.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# partialmethod.__qualname__.__len__() == 13 — standalone in extra27 namespace
#
# functools_extra15 covers this value as a standalone invariant in the extra15
# namespace. No prior spec records it in the extra27 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra27.partialmethod.qualname_len:
  description: "functools.partialmethod.__qualname__.__len__() == 13 — len('partialmethod') == 13"
  category: qualnames
  kind: python_call_eq
  function: partialmethod.__qualname__.__len__
  args: []
  expected: 13
