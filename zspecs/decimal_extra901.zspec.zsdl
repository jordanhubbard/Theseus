spec: decimal_extra901
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __module__ and __class__.__name__ attributes of decimal classes and constants"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra901.class_modules:
  description: "decimal class __module__ identity"
  kind: python_call_eq
  category: class_modules
  id_prefix: dc901m
  columns: [id, function, args, expected]
  rows:
    - [dc901m001, decimal.Decimal.__module__.__eq__,          ["decimal"], true]
    - [dc901m002, decimal.Context.__module__.__eq__,          ["decimal"], true]
    - [dc901m003, decimal.DecimalException.__module__.__eq__, ["decimal"], true]
    - [dc901m004, decimal.Decimal.__class__.__name__.__eq__,          ["type"], true]
    - [dc901m005, decimal.Context.__class__.__name__.__eq__,          ["type"], true]
    - [dc901m006, decimal.DecimalException.__class__.__name__.__eq__, ["type"], true]

table decimal_extra901.constant_class_names:
  description: "decimal constant __class__.__name__ identity"
  kind: python_call_eq
  category: constant_class_names
  id_prefix: dc901k
  columns: [id, function, args, expected]
  rows:
    - [dc901k001, decimal.ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"],     true]
    - [dc901k002, decimal.ROUND_DOWN.__class__.__name__.__eq__,      ["str"],     true]
    - [dc901k003, decimal.ROUND_UP.__class__.__name__.__eq__,        ["str"],     true]
    - [dc901k004, decimal.ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"],     true]
    - [dc901k005, decimal.DefaultContext.__class__.__name__.__eq__,  ["Context"], true]
    - [dc901k006, decimal.BasicContext.__class__.__name__.__eq__,    ["Context"], true]
    - [dc901k007, decimal.ExtendedContext.__class__.__name__.__eq__, ["Context"], true]

table decimal_extra901.class_name_checks:
  description: "decimal class __name__ identity"
  kind: python_call_eq
  category: class_name_checks
  id_prefix: dc901n
  columns: [id, function, args, expected]
  rows:
    - [dc901n001, decimal.Decimal.__name__.__eq__,          ["Decimal"],          true]
    - [dc901n002, decimal.Context.__name__.__eq__,          ["Context"],          true]
    - [dc901n003, decimal.DecimalException.__name__.__eq__, ["DecimalException"], true]
    - [dc901n004, decimal.Decimal.__qualname__.__eq__,          ["Decimal"],          true]
    - [dc901n005, decimal.Context.__qualname__.__eq__,          ["Context"],          true]
    - [dc901n006, decimal.DecimalException.__qualname__.__eq__, ["DecimalException"], true]
    - [dc901n007, decimal.__name__.__eq__,                  ["decimal"],          true]
