# ---------------------------------------------------------------------------
# Table 3: hashlib.sha224 and sha384 class identity
#
# hashlib.sha224.__class__.__name__ == 'builtin_function_or_method'  (len=26)
# hashlib.sha384.__class__.__name__ == 'builtin_function_or_method'  (len=26)
#
# Both sha224 and sha384 are C-level callables; their __class__ is the
# builtin_function_or_method type, not a Python function or classmethod.
# ---------------------------------------------------------------------------

table hashlib_extra190.sha224_sha384_class_identity:
  description: "hashlib.sha224 and sha384 __class__.__name__ both 'builtin_function_or_method'; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibsha224384190

  columns: [id, function, args, expected, description]
  rows:
    - [sha224_class_name_eq,
       hashlib.sha224.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "hashlib.sha224.__class__.__name__.__eq__('builtin_function_or_method') == True — C-level callable type; new to extra190"]
    - [sha224_class_name_len,
       hashlib.sha224.__class__.__name__.__len__,
       [],
       26,
       "hashlib.sha224.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' has 26 characters; new to extra190"]
    - [sha384_class_name_eq,
       hashlib.sha384.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "hashlib.sha384.__class__.__name__.__eq__('builtin_function_or_method') == True — C-level callable type; new to extra190"]
    - [sha384_class_name_len,
       hashlib.sha384.__class__.__name__.__len__,
       [],
       26,
       "hashlib.sha384.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' has 26 characters; new to extra190"]

