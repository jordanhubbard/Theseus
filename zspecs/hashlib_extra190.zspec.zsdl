    - [sha384_name_len,
       hashlib.sha384.__name__.__len__,
       [],
       14,
       "hashlib.sha384.__name__.__len__() == 14 — 'openssl_sha384' has 14 characters; new to extra190"]
    - [sha384_qualname_eq,
       hashlib.sha384.__qualname__.__eq__,
       ["openssl_sha384"],
       true,
       "hashlib.sha384.__qualname__.__eq__('openssl_sha384') == True — qualname matches __name__ for C builtins; new to extra190"]
    - [sha384_qualname_len,
       hashlib.sha384.__qualname__.__len__,
       [],
       14,
       "hashlib.sha384.__qualname__.__len__() == 14 — 'openssl_sha384' has 14 characters; new to extra190"]
    - [sha384_module_eq,
       hashlib.sha384.__module__.__eq__,
       ["_hashlib"],
       true,
       "hashlib.sha384.__module__.__eq__('_hashlib') == True — private C extension backing OpenSSL hashes; new to extra190"]
    - [sha384_module_len,
