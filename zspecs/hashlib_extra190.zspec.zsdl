spec: hashlib_extra190
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "hashlib.sha224.__name__ == 'openssl_sha224' — OpenSSL-backed constructor; not 'sha224'."
    - "hashlib.sha384.__name__ == 'openssl_sha384' — OpenSSL-backed constructor; not 'sha384'."
    - "hashlib.sha224.__qualname__ == 'openssl_sha224' — qualname matches __name__ for C builtins."
    - "hashlib.sha384.__qualname__ == 'openssl_sha384' — qualname matches __name__ for C builtins."
    - "hashlib.sha224.__module__ == '_hashlib' — private C extension module backing OpenSSL hashes."
    - "hashlib.sha384.__module__ == '_hashlib' — private C extension module backing OpenSSL hashes."
    - "hashlib.sha224.__class__.__name__ == 'builtin_function_or_method' — C-level callable."
    - "hashlib.sha384.__class__.__name__ == 'builtin_function_or_method' — C-level callable."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.sha224 identity attributes
#
# hashlib.sha224.__name__     == 'openssl_sha224'             (len=14)
# hashlib.sha224.__qualname__ == 'openssl_sha224'             (len=14)
# hashlib.sha224.__module__   == '_hashlib'                   (len=8)
#
# On macOS/Darwin with OpenSSL, hashlib.sha224 is the C builtin
# openssl_sha224 from the _hashlib extension module.  Its __name__
# and __qualname__ both reflect the OpenSSL symbol name, not 'sha224'.
# ---------------------------------------------------------------------------

table hashlib_extra190.sha224_identity:
  description: "hashlib.sha224 name, qualname, and module identity attributes; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibsha224384190

  columns: [id, function, args, expected, description]
  rows:
    - [sha224_name_eq,
       hashlib.sha224.__name__.__eq__,
       ["openssl_sha224"],
       true,
       "hashlib.sha224.__name__.__eq__('openssl_sha224') == True — OpenSSL-backed constructor name; len=14; new to extra190"]
    - [sha224_name_len,
       hashlib.sha224.__name__.__len__,
       [],
       14,
       "hashlib.sha224.__name__.__len__() == 14 — 'openssl_sha224' has 14 characters; new to extra190"]
    - [sha224_qualname_eq,
       hashlib.sha224.__qualname__.__eq__,
       ["openssl_sha224"],
       true,
       "hashlib.sha224.__qualname__.__eq__('openssl_sha224') == True — qualname matches __name__ for C builtins; new to extra190"]
    - [sha224_qualname_len,
       hashlib.sha224.__qualname__.__len__,
       [],
       14,
       "hashlib.sha224.__qualname__.__len__() == 14 — 'openssl_sha224' has 14 characters; new to extra190"]
    - [sha224_module_eq,
       hashlib.sha224.__module__.__eq__,
       ["_hashlib"],
       true,
       "hashlib.sha224.__module__.__eq__('_hashlib') == True — private C extension backing OpenSSL hashes; new to extra190"]
    - [sha224_module_len,
       hashlib.sha224.__module__.__len__,
       [],
       8,
       "hashlib.sha224.__module__.__len__() == 8 — '_hashlib' has 8 characters; new to extra190"]

# ---------------------------------------------------------------------------
# Table 2: hashlib.sha384 identity attributes
#
# hashlib.sha384.__name__     == 'openssl_sha384'             (len=14)
# hashlib.sha384.__qualname__ == 'openssl_sha384'             (len=14)
# hashlib.sha384.__module__   == '_hashlib'                   (len=8)
#
# Symmetric with sha224: both constructors are C builtins from _hashlib
# whose names are the OpenSSL algorithm identifiers prefixed with 'openssl_'.
# ---------------------------------------------------------------------------

table hashlib_extra190.sha384_identity:
  description: "hashlib.sha384 name, qualname, and module identity attributes; new to extra190"
