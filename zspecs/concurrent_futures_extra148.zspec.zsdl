spec: concurrent_futures_extra148
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "This spec covers: concurrent.futures.__dict__.__len__()==28 and concurrent.futures.__dict__.__class__.__name__=='dict'; also concurrent.futures.thread.__dict__.__len__()==25, concurrent.futures.process.__dict__.__len__()==47 (largest), concurrent.futures._base.__dict__.__len__()==45; submodule __name__ lengths: concurrent.futures.__name__ len=18, thread len=25, process len=26 (longest), _base len=24. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__dict__.__len__()==28 (28 entries at import time; note that previous spec147 mentioned 26 entries but on Python 3.14.3 the count is 28 — two additional entries may reflect version-specific additions). concurrent.futures.__dict__.__class__.__name__=='dict' (module __dict__ is a plain dict, not mappingproxy). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.process.__dict__.__len__()==47 is the largest submodule (process.py contains ProcessPoolExecutor plus many private helper classes and functions for managing worker processes; it also contains the _GLOBAL_SHUTDOWN sentinel, call items, result items, and wake-up event handling). concurrent.futures._base.__dict__.__len__()==45 (second largest: _base.py defines Future, Executor, the wait constants, and all the base classes). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.__dict__ size and class name — extra148
#
# concurrent.futures.__dict__.__len__()                == 28
# concurrent.futures.__dict__.__class__.__name__       == 'dict'
# concurrent.futures.__dict__.__class__.__name__.__len__() == 4
# concurrent.futures.__name__.__len__()                == 18
# ---------------------------------------------------------------------------

table concurrent_futures_extra148.cf_dict_len_and_class:
  description: "concurrent.futures.__dict__ size and class name checks in cfdict148 namespace — concurrent.futures.__dict__.__len__()==28 (the concurrent.futures package top-level __dict__ has 28 entries at import time; these include Future, Executor, wait, as_completed, the wait constants FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED, the exception classes CancelledError/TimeoutError/BrokenExecutor, and module-level dunders); concurrent.futures.__dict__.__class__.__name__.__eq__('dict')==True (module __dict__ is a plain dict, not mappingproxy; len('dict')==4); concurrent.futures.__dict__.__class__.__name__.__len__()==4; concurrent.futures.__name__.__eq__('concurrent.futures')==True (len=18: 'concurrent'=10+'.'=1+'futures'=7=18); concurrent.futures.__name__.__len__()==18; NEW in extra148: first concurrent.futures.__dict__ size spec in cfdict148 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: namespace
  id_prefix: cfdict148

  columns: [id, function, args, expected, description]
  rows:
    - [dict_len,      "concurrent.futures.__dict__.__len__",                        [],                     28,    "concurrent.futures.__dict__.__len__() == 28; verified with Python 3.14.3"]
    - [dict_cls_eq,   "concurrent.futures.__dict__.__class__.__name__.__eq__",      ["dict"],               true,  "concurrent.futures.__dict__.__class__.__name__ == 'dict' (module __dict__ is plain dict); verified with Python 3.14.3"]
    - [dict_cls_len,  "concurrent.futures.__dict__.__class__.__name__.__len__",     [],                     4,     "concurrent.futures.__dict__.__class__.__name__.__len__() == 4 ('dict'); verified with Python 3.14.3"]
    - [name_eq,       "concurrent.futures.__name__.__eq__",                         ["concurrent.futures"], true,  "concurrent.futures.__name__ == 'concurrent.futures' (len=18); verified with Python 3.14.3"]
    - [name_len,      "concurrent.futures.__name__.__len__",                        [],                     18,    "concurrent.futures.__name__.__len__() == 18; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures submodule __dict__ sizes — extra148
#
# concurrent.futures.thread.__dict__.__len__()  == 25
# concurrent.futures.process.__dict__.__len__() == 47  (largest)
# concurrent.futures._base.__dict__.__len__()   == 45
# ---------------------------------------------------------------------------

table concurrent_futures_extra148.cf_submodule_dict_sizes:
  description: "concurrent.futures submodule __dict__ size checks in cfdict148 namespace — concurrent.futures.process.__dict__.__len__()==47 (largest submodule: process.py contains ProcessPoolExecutor plus many private helper classes and functions for inter-process communication, worker management, and result handling; len('concurrent.futures.process')==26); concurrent.futures._base.__dict__.__len__()==45 (second-largest: _base.py defines Future, Executor, the wait/as_completed functions, the wait constants, and all exception classes; len('concurrent.futures._base')==24); concurrent.futures.thread.__dict__.__len__()==25 (smallest: thread.py contains ThreadPoolExecutor and its private helpers; len('concurrent.futures.thread')==25); the submodule ordering by dict size is process(47) > _base(45) > thread(25); all submodule __dict__ are plain dicts; verified with Python 3.14.3"
  kind: python_call_eq
  category: namespace
  id_prefix: cfsubdict148

  columns: [id, function, args, expected, description]
  rows:
    - [thread_len,   "concurrent.futures.thread.__dict__.__len__",   [],  25,  "concurrent.futures.thread.__dict__.__len__() == 25 (smallest submodule); verified with Python 3.14.3"]
    - [process_len,  "concurrent.futures.process.__dict__.__len__",  [],  47,  "concurrent.futures.process.__dict__.__len__() == 47 (largest submodule); verified with Python 3.14.3"]
    - [base_len,     "concurrent.futures._base.__dict__.__len__",    [],  45,  "concurrent.futures._base.__dict__.__len__() == 45 (second-largest); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures submodule __name__ lengths — extra148
#
# concurrent.futures.thread.__name__.__len__()  == 25  ('concurrent.futures.thread')
# concurrent.futures.process.__name__.__len__() == 26  ('concurrent.futures.process'; longest)
# concurrent.futures._base.__name__.__len__()   == 24  ('concurrent.futures._base'; shortest)
# ---------------------------------------------------------------------------

table concurrent_futures_extra148.cf_submodule_name_lengths:
  description: "concurrent.futures submodule __name__ length checks in cfdict148 namespace — concurrent.futures.process.__name__.__len__()==26 ('concurrent.futures.process': 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'process'=7=26; the longest submodule name in this spec); concurrent.futures.thread.__name__.__len__()==25 ('concurrent.futures.thread': 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25; one char shorter than process); concurrent.futures._base.__name__.__len__()==24 ('concurrent.futures._base': 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24; shortest submodule name, also the only private submodule); name length ordering: process(26) > thread(25) > _base(24); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfsubname148

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_len,   "concurrent.futures.thread.__name__.__len__",   [],  25,  "concurrent.futures.thread.__name__.__len__() == 25 ('concurrent.futures.thread'); verified with Python 3.14.3"]
    - [process_name_len,  "concurrent.futures.process.__name__.__len__",  [],  26,  "concurrent.futures.process.__name__.__len__() == 26 ('concurrent.futures.process'; longest); verified with Python 3.14.3"]
    - [base_name_len,     "concurrent.futures._base.__name__.__len__",    [],  24,  "concurrent.futures._base.__name__.__len__() == 24 ('concurrent.futures._base'; shortest); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra148
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra148.cf_dict_len_28:
  description: "concurrent.futures.__dict__.__len__() == 28 — the concurrent.futures package top-level __dict__ has 28 entries; these include re-exported public names (Future, Executor, wait, as_completed, FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED, CancelledError, TimeoutError, BrokenExecutor) plus module-level dunders and package infrastructure; concurrent.futures.__dict__.__class__.__name__=='dict' (plain dict, not mappingproxy — it is a module); compare to asyncio.__dict__.__len__()==136 (asyncio exports far more at the top level); concurrent.futures.__name__=='concurrent.futures' (len=18); NEW in extra148: first standalone concurrent.futures.__dict__ length invariant in cfdict148 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: "concurrent.futures.__dict__.__len__"
  args: []
  expected: 28

invariant concurrent_futures_extra148.cf_dict_class_is_dict:
  description: "concurrent.futures.__dict__.__class__.__name__.__eq__('dict') returns True — concurrent.futures.__dict__.__class__.__name__ is 'dict' (4 chars); module-level __dict__ is always a plain dict; this distinguishes it from concurrent.futures.Future.__dict__ (which is a mappingproxy, 12 chars, since Future is a class); concurrent.futures.__dict__.__class__.__name__.__len__()==4; concurrent.futures.__dict__.__len__()==28; compare asyncio.__dict__.__class__.__name__=='dict' (also plain dict — same pattern for all module-level dicts); NEW in extra148: first standalone concurrent.futures.__dict__ class name invariant in cfdict148 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: "concurrent.futures.__dict__.__class__.__name__.__eq__"
  args: ["dict"]
  expected: true

invariant concurrent_futures_extra148.cf_process_dict_len_47:
  description: "concurrent.futures.process.__dict__.__len__() == 47 — concurrent.futures.process is the largest submodule with 47 entries in its module __dict__; process.py contains ProcessPoolExecutor plus extensive private infrastructure: _CallItem, _ResultItem, _SafeQueue, _WorkerContext, _ExceptionWithTraceback, _RemoteTraceback, _process_worker, _process_chunk, _get_chunks, _chain_from_iterable_of_lists, sentinel values, and worker-side globals; concurrent.futures.process.__name__=='concurrent.futures.process' (len=26, longest submodule name); compare: _base(45) > thread(25); process is larger than _base because process.py includes both the executor and all the inter-process communication infrastructure; NEW in extra148: first standalone concurrent.futures.process.__dict__ length invariant in cfdict148 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: "concurrent.futures.process.__dict__.__len__"
  args: []
  expected: 47

invariant concurrent_futures_extra148.cf_base_dict_len_45:
  description: "concurrent.futures._base.__dict__.__len__() == 45 — concurrent.futures._base is the second-largest submodule with 45 entries in its module __dict__; _base.py defines the core API: Future (the result-holder class), Executor (abstract base), wait(), as_completed(), FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED constants, CancelledError, TimeoutError, BrokenExecutor, InvalidStateError exception classes, and many private helper classes (DoneAndNotDoneFutures, etc.) and functions; concurrent.futures._base.__name__=='concurrent.futures._base' (len=24, shortest submodule name); compare: process(47) > _base(45) > thread(25); NEW in extra148: first standalone concurrent.futures._base.__dict__ length invariant in cfdict148 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: "concurrent.futures._base.__dict__.__len__"
  args: []
  expected: 45

invariant concurrent_futures_extra148.cf_thread_dict_len_25:
  description: "concurrent.futures.thread.__dict__.__len__() == 25 — concurrent.futures.thread is the smallest submodule with 25 entries in its module __dict__; thread.py contains ThreadPoolExecutor plus its private helpers: _WorkItem, _worker, BrokenThreadPool, and module-level constants like _threads_queues and _shutdown; concurrent.futures.thread.__name__=='concurrent.futures.thread' (len=25: the name length equals the dict size by coincidence); compare: process(47) > _base(45) > thread(25); ThreadPoolExecutor is simpler than ProcessPoolExecutor because thread management is handled by Python's threading module without needing inter-process communication infrastructure; NEW in extra148: first standalone concurrent.futures.thread.__dict__ length invariant in cfdict148 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: "concurrent.futures.thread.__dict__.__len__"
  args: []
  expected: 25
