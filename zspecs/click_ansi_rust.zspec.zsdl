spec: click_ansi_rust
version: ">=3.9"
backend: rust_module(click_ansi_rust)

docs: https://click.palletsprojects.com/en/stable/api/

provenance:
  derived_from:
    - "https://click.palletsprojects.com/ — Click documentation"
  not_derived_from:
    - "click source: src/click/utils.py"
  notes:
    - "click utility functions not covered in other specs."
    - "click.strip_ansi(value) removes ANSI escape sequences from a string."
    - "strip_ansi('hello') == 'hello' — no ANSI codes, returned unchanged."
    - "strip_ansi('\\x1b[1mhello\\x1b[0m') == 'hello' — bold ANSI codes removed."
    - "strip_ansi('\\x1b[31mred\\x1b[0m text') == 'red text' — color codes removed."
    - "click.format_filename(filename) converts filename to str for display."
    - "format_filename('test.txt') == 'test.txt' — str input returned as-is."
    - "format_filename(b'test.txt') == 'test.txt' — bytes decoded to str."
    - "All test vectors verified against click 8.1.8."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# strip_ansi — remove ANSI escape sequences
table click_ansi_rust.strip_ansi.vectors:
  kind: python_call_eq
  category: strip_ansi
  id_prefix: ca_sa
  function: strip_ansi

  columns: [id, args, expected]
  rows:
    - [plain,      ["hello"],                            "hello"]
    - [bold,       ["\x1b[1mhello\x1b[0m"],             "hello"]
    - [red,        ["\x1b[31mred\x1b[0m text"],         "red text"]
    - [underline,  ["\x1b[4munderline\x1b[0m"],         "underline"]
    - [empty,      [""],                                  ""]
    - [no_close,   ["\x1b[1mbold"],                     "bold"]
    - [multi,      ["\x1b[1m\x1b[31mbright red\x1b[0m"], "bright red"]

# format_filename — convert filename to display string
table click_ansi_rust.format_filename.vectors:
  kind: python_call_eq
  category: format_filename
  id_prefix: ca_ff
  function: format_filename

  columns: [id, args, expected]
  rows:
    - [str_plain,  ["test.txt"],       "test.txt"]
    - [str_path,   ["/foo/bar.py"],    "/foo/bar.py"]
    - [bytes_txt,  [b"test.txt"],      "test.txt"]
    - [bytes_path, [b"/foo/bar.py"],   "/foo/bar.py"]
    - [str_empty,  [""],              ""]

