spec: asyncio_extra1636
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html — asyncio: Asynchronous I/O"
    - "https://docs.python.org/3/library/asyncio-task.html — Coroutines and Tasks"
    - "https://docs.python.org/3/library/asyncio-sync.html — Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — Event Loop"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
    - "CPython source: Lib/asyncio/ (internal implementation)"
  notes:
    - "behavioral invariants for ABC virtual subclassing protocol"
    - "Wave 1636: theme is __subclasshook__, __instancecheck__, __subclasscheck__ — the ABC virtual subclassing protocol."
    - "asyncio concrete classes (Future, Task, Lock, Event, Queue, Semaphore) are NOT ABCs; they do not define __subclasshook__ in their own __dict__."
    - "asyncio.AbstractEventLoop and asyncio.AbstractServer use ABCMeta as metaclass, but __subclasshook__ is not defined in their own __dict__ — it is inherited from ABCMeta machinery."
    - "asyncio.BaseProtocol, asyncio.Protocol, asyncio.DatagramProtocol define abstract methods but may not define __subclasshook__ in their own __dict__."
    - "isinstance(asyncio.Lock(), asyncio.AbstractEventLoop) is False — Lock does not implement the AbstractEventLoop interface."
    - "issubclass(asyncio.Task, asyncio.Future) is True — Task inherits from Future."
    - "issubclass(asyncio.Future, object) is True — all Python classes ultimately inherit from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: concrete asyncio classes have no __subclasshook__ in their own __dict__
#
# asyncio.Future, Task, Lock, Event, Queue, Semaphore are all concrete
# pure-Python classes. None defines __subclasshook__ in its own __dict__,
# meaning they participate in no ABC virtual subclassing protocol.
# __instancecheck__ and __subclasscheck__ are also absent from their __dict__
# because their metaclass is the plain built-in `type`, not ABCMeta.
# ---------------------------------------------------------------------------

table asyncio_extra1636.classes_no_virtual_subclassing:
  description: "asyncio concrete classes do not define ABC hooks in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1636nv

  columns: [id, function, args, expected]
  rows:
    - ["as1636nv001", "asyncio.Future.__dict__.__contains__",           ["__subclasshook__"],    false]
    - ["as1636nv002", "asyncio.Task.__dict__.__contains__",             ["__subclasshook__"],    false]
    - ["as1636nv003", "asyncio.Lock.__dict__.__contains__",             ["__subclasshook__"],    false]
    - ["as1636nv004", "asyncio.Event.__dict__.__contains__",            ["__subclasshook__"],    false]
    - ["as1636nv005", "asyncio.Queue.__dict__.__contains__",            ["__subclasshook__"],    false]
    - ["as1636nv006", "asyncio.Semaphore.__dict__.__contains__",        ["__subclasshook__"],    false]
    - ["as1636nv007", "asyncio.Condition.__dict__.__contains__",        ["__subclasshook__"],    false]
    - ["as1636nv008", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__subclasshook__"],    false]
    - ["as1636nv009", "asyncio.Future.__dict__.__contains__",           ["__instancecheck__"],   false]
    - ["as1636nv010", "asyncio.Task.__dict__.__contains__",             ["__instancecheck__"],   false]
    - ["as1636nv011", "asyncio.Lock.__dict__.__contains__",             ["__instancecheck__"],   false]
    - ["as1636nv012", "asyncio.Queue.__dict__.__contains__",            ["__instancecheck__"],   false]
    - ["as1636nv013", "asyncio.Future.__dict__.__contains__",           ["__subclasscheck__"],   false]
    - ["as1636nv014", "asyncio.Task.__dict__.__contains__",             ["__subclasscheck__"],   false]
    - ["as1636nv015", "asyncio.Lock.__dict__.__contains__",             ["__subclasscheck__"],   false]
    - ["as1636nv016", "asyncio.Queue.__dict__.__contains__",            ["__subclasscheck__"],   false]
    - ["as1636nv017", "asyncio.AbstractEventLoop.__dict__.__contains__", ["__subclasshook__"],   false]
    - ["as1636nv018", "asyncio.AbstractServer.__dict__.__contains__",   ["__subclasshook__"],    false]
    - ["as1636nv019", "asyncio.BaseProtocol.__dict__.__contains__",     ["__subclasshook__"],    false]
    - ["as1636nv020", "asyncio.Protocol.__dict__.__contains__",         ["__subclasshook__"],    false]
    - ["as1636nv021", "asyncio.DatagramProtocol.__dict__.__contains__", ["__subclasshook__"],    false]
    - ["as1636nv022", "asyncio.SubprocessProtocol.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["as1636nv023", "asyncio.StreamReader.__dict__.__contains__",     ["__subclasshook__"],    false]
    - ["as1636nv024", "asyncio.StreamWriter.__dict__.__contains__",     ["__subclasshook__"],    false]

# ---------------------------------------------------------------------------
# Table 2: isinstance checks — asyncio classes and abstract protocols
#
# Concrete asyncio classes do not implement the AbstractEventLoop interface,
# so isinstance of a concrete instance against an abstract class is False
# unless the class is actually in the inheritance chain.
# ---------------------------------------------------------------------------

table asyncio_extra1636.isinstance_checks:
  description: "isinstance checks between asyncio concrete instances and abstract protocols"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1636ic

  columns: [id, function, args, expected]
  rows:
    - ["as1636ic001", "asyncio.Future.__subclasshook__.__class__.__name__.__eq__",          ["method-wrapper"],    true]
    - ["as1636ic002", "asyncio.Lock.__class__.__name__.__eq__",                              ["type"],              true]
    - ["as1636ic003", "asyncio.Future.__class__.__name__.__eq__",                            ["type"],              true]
    - ["as1636ic004", "asyncio.Task.__class__.__name__.__eq__",                              ["type"],              true]
    - ["as1636ic005", "asyncio.Queue.__class__.__name__.__eq__",                             ["type"],              true]
    - ["as1636ic006", "asyncio.AbstractEventLoop.__class__.__name__.__eq__",                 ["ABCMeta"],           true]
    - ["as1636ic007", "asyncio.AbstractServer.__class__.__name__.__eq__",                    ["ABCMeta"],           true]
    - ["as1636ic008", "asyncio.BaseProtocol.__class__.__name__.__eq__",                      ["ABCMeta"],           true]
    - ["as1636ic009", "asyncio.Protocol.__class__.__name__.__eq__",                          ["ABCMeta"],           true]
    - ["as1636ic010", "asyncio.DatagramProtocol.__class__.__name__.__eq__",                  ["ABCMeta"],           true]
    - ["as1636ic011", "asyncio.Future.__bases__.__contains__",                               ["object"],            false]
    - ["as1636ic012", "asyncio.Future.__bases__.__getitem__",                                [0],                   null]
    - ["as1636ic013", "asyncio.AbstractEventLoop.__dict__.__contains__",                     ["__instancecheck__"], false]
    - ["as1636ic014", "asyncio.AbstractEventLoop.__dict__.__contains__",                     ["__subclasscheck__"], false]
    - ["as1636ic015", "asyncio.BaseProtocol.__dict__.__contains__",                          ["__instancecheck__"], false]
    - ["as1636ic016", "asyncio.Protocol.__dict__.__contains__",                              ["__instancecheck__"], false]

# ---------------------------------------------------------------------------
# Table 3: class hierarchy — inheritance relationships for asyncio classes
#
# Task is a concrete subclass of Future.
# Future, Lock, Queue, Event, Semaphore, Condition all inherit from object.
# Abstract classes: AbstractEventLoop, AbstractServer, BaseProtocol, Protocol
# use ABCMeta but their metaclass defines __instancecheck__/__subclasscheck__,
# not the classes themselves.
# ---------------------------------------------------------------------------

table asyncio_extra1636.subclass_hierarchy:
  description: "asyncio class inheritance relationships and metaclass identity"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1636sh

  columns: [id, function, args, expected]
  rows:
    - ["as1636sh001", "asyncio.Future.__name__.__eq__",                              ["Future"],       true]
    - ["as1636sh002", "asyncio.Task.__name__.__eq__",                                ["Task"],         true]
    - ["as1636sh003", "asyncio.Lock.__name__.__eq__",                                ["Lock"],         true]
    - ["as1636sh004", "asyncio.Queue.__name__.__eq__",                               ["Queue"],        true]
    - ["as1636sh005", "asyncio.Task.__bases__.__getitem__",                          [0],              null]
    - ["as1636sh006", "asyncio.Task.__mro__.__contains__",                           ["asyncio.Future"], false]
    - ["as1636sh007", "asyncio.Future.__dict__.__contains__",                        ["cancel"],       true]
    - ["as1636sh008", "asyncio.Future.__dict__.__contains__",                        ["result"],       true]
    - ["as1636sh009", "asyncio.Future.__dict__.__contains__",                        ["done"],         true]
    - ["as1636sh010", "asyncio.Lock.__dict__.__contains__",                          ["acquire"],      true]
    - ["as1636sh011", "asyncio.Lock.__dict__.__contains__",                          ["release"],      true]
    - ["as1636sh012", "asyncio.Queue.__dict__.__contains__",                         ["put"],          true]
    - ["as1636sh013", "asyncio.Queue.__dict__.__contains__",                         ["get"],          true]
    - ["as1636sh014", "asyncio.AbstractEventLoop.__dict__.__contains__",             ["run_forever"],  true]
    - ["as1636sh015", "asyncio.AbstractEventLoop.__dict__.__contains__",             ["run_until_complete"], true]
    - ["as1636sh016", "asyncio.AbstractEventLoop.__dict__.__contains__",             ["stop"],         true]
    - ["as1636sh017", "asyncio.AbstractEventLoop.__dict__.__contains__",             ["close"],        true]
    - ["as1636sh018", "asyncio.AbstractEventLoop.__dict__.__contains__",             ["create_task"],  true]
    - ["as1636sh019", "asyncio.BaseProtocol.__dict__.__contains__",                  ["connection_made"], true]
    - ["as1636sh020", "asyncio.BaseProtocol.__dict__.__contains__",                  ["connection_lost"], true]
    - ["as1636sh021", "asyncio.Protocol.__dict__.__contains__",                      ["data_received"], true]
    - ["as1636sh022", "asyncio.DatagramProtocol.__dict__.__contains__",              ["datagram_received"], true]
    - ["as1636sh023", "asyncio.AbstractServer.__dict__.__contains__",                ["close"],        true]
    - ["as1636sh024", "asyncio.Event.__dict__.__contains__",                         ["set"],          true]
    - ["as1636sh025", "asyncio.Event.__dict__.__contains__",                         ["clear"],        true]
    - ["as1636sh026", "asyncio.Event.__dict__.__contains__",                         ["is_set"],       true]
    - ["as1636sh027", "asyncio.Semaphore.__dict__.__contains__",                     ["acquire"],      true]
    - ["as1636sh028", "asyncio.Semaphore.__dict__.__contains__",                     ["release"],      true]
