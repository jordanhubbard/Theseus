spec: decimal_extra284
version: ">=3.9"
backend: python_module(decimal)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Decimal comparison, math, and predicate method identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "All Decimal method qualnames verified against live Python 3.14 runtime"
    - "decimal module implemented in C (_decimal) for CPython; qualnames follow Python class convention"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table decimal_extra284.decimal_comparison_qualnames:
  description: "Decimal comparison and extremum method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: deccmp284

  columns: [id, function, args, expected, description]
  rows:
    - [deccmp284_001, decimal.Decimal.compare.__qualname__.__eq__, ["Decimal.compare"], true, "Decimal.compare qualname"]
    - [deccmp284_002, decimal.Decimal.compare_signal.__qualname__.__eq__, ["Decimal.compare_signal"], true, "Decimal.compare_signal qualname"]
    - [deccmp284_003, decimal.Decimal.compare_total.__qualname__.__eq__, ["Decimal.compare_total"], true, "Decimal.compare_total qualname"]
    - [deccmp284_004, decimal.Decimal.compare_total_mag.__qualname__.__eq__, ["Decimal.compare_total_mag"], true, "Decimal.compare_total_mag qualname"]
    - [deccmp284_005, decimal.Decimal.max.__qualname__.__eq__, ["Decimal.max"], true, "Decimal.max qualname"]
    - [deccmp284_006, decimal.Decimal.min.__qualname__.__eq__, ["Decimal.min"], true, "Decimal.min qualname"]
    - [deccmp284_007, decimal.Decimal.max_mag.__qualname__.__eq__, ["Decimal.max_mag"], true, "Decimal.max_mag qualname"]
    - [deccmp284_008, decimal.Decimal.min_mag.__qualname__.__eq__, ["Decimal.min_mag"], true, "Decimal.min_mag qualname"]
    - [deccmp284_009, decimal.Decimal.fma.__qualname__.__eq__, ["Decimal.fma"], true, "Decimal.fma qualname"]

table decimal_extra284.decimal_math_predicate_qualnames:
  description: "Decimal math and predicate method __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: decmp284

  columns: [id, function, args, expected, description]
  rows:
    - [decmp284_001, decimal.Decimal.sqrt.__qualname__.__eq__, ["Decimal.sqrt"], true, "Decimal.sqrt qualname"]
    - [decmp284_002, decimal.Decimal.exp.__qualname__.__eq__, ["Decimal.exp"], true, "Decimal.exp qualname"]
    - [decmp284_003, decimal.Decimal.ln.__qualname__.__eq__, ["Decimal.ln"], true, "Decimal.ln qualname"]
    - [decmp284_004, decimal.Decimal.log10.__qualname__.__eq__, ["Decimal.log10"], true, "Decimal.log10 qualname"]
    - [decmp284_005, decimal.Decimal.logb.__qualname__.__eq__, ["Decimal.logb"], true, "Decimal.logb qualname"]
    - [decmp284_006, decimal.Decimal.is_finite.__qualname__.__eq__, ["Decimal.is_finite"], true, "Decimal.is_finite qualname"]
    - [decmp284_007, decimal.Decimal.is_infinite.__qualname__.__eq__, ["Decimal.is_infinite"], true, "Decimal.is_infinite qualname"]
    - [decmp284_008, decimal.Decimal.is_nan.__qualname__.__eq__, ["Decimal.is_nan"], true, "Decimal.is_nan qualname"]
    - [decmp284_009, decimal.Decimal.is_signed.__qualname__.__eq__, ["Decimal.is_signed"], true, "Decimal.is_signed qualname"]
    - [decmp284_010, decimal.Decimal.is_zero.__qualname__.__eq__, ["Decimal.is_zero"], true, "Decimal.is_zero qualname"]
    - [decmp284_011, decimal.Decimal.is_normal.__qualname__.__eq__, ["Decimal.is_normal"], true, "Decimal.is_normal qualname"]

invariant decimal_extra284.compare_qualname_confirmed:
  description: "Decimal.compare qualname confirmed as standalone invariant"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.compare.__qualname__.__eq__
  args: ["Decimal.compare"]
  expected: true

invariant decimal_extra284.is_nan_qualname_confirmed:
  description: "Decimal.is_nan qualname confirmed as standalone invariant"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.is_nan.__qualname__.__eq__
  args: ["Decimal.is_nan"]
  expected: true
