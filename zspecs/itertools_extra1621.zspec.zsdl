spec: itertools_extra1621
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "All itertools types are C extension types implemented in Modules/itertoolsmodule.c"
    - "C extension types do not expose a __weakref__ getset_descriptor in their type __dict__ unless tp_weaklistoffset is set AND the type explicitly adds a __weakref__ slot"
    - "Itertools C types do NOT set tp_weaklistoffset; instances of itertools types cannot be weakly referenced"
    - "No itertools type has __weakref__ in its __dict__ — neither as a slot descriptor (C types have no Python __slots__) nor as a getset_descriptor from tp_weaklistoffset"
    - "No itertools type has __dict__ in its type dict (C types with fixed struct layout; no per-instance __dict__)"
    - "itertools.chain uniquely exposes from_iterable as a classmethod descriptor; still no __weakref__"
    - "itertools.repeat uniquely exposes __length_hint__; still no __weakref__"
    - "itertools.pairwise was added in Python 3.10; rows testing pairwise assume Python>=3.10 but are listed under version>=3.9 for spec consistency"
  created_at: "2026-04-12"
error_model: python_exceptions

table itertools_extra1621.c_types_no_weakref_slot:
  description: "core itertools C extension types do not have __weakref__ in their type __dict__; C types implemented without tp_weaklistoffset lack any weakref descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1621nw

  columns: [id, function, args, expected]
  rows:
    - ["it1621nw001", "itertools.chain.__dict__.__contains__",                         ["__weakref__"], false]
    - ["it1621nw002", "itertools.islice.__dict__.__contains__",                        ["__weakref__"], false]
