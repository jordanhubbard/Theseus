spec: json_extra11
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html
rfcs:
  - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra10.zspec.zsdl."
    - "json_extra10 covers: __spec__.name; __package__; __version__ type; JSONDecodeError.__mro__[3].__name__; loads('42')/loads('3.14')/dumps(-1)/loads('0'); dumps.__qualname__; loads.__module__."
    - "json_extra9 covers: dumps(True/False); dumps nested dict; loads mixed-type array; dumps ensure_ascii=False; decoder/encoder __package__; JSONDecodeError.__mro__[2].__name__; loads('Infinity')/loads('undefined') raises."
    - "json_extra8 covers: decoder/encoder submodule __name__; JSONDecodeError.__module__; JSONDecoder/JSONEncoder __bases__[0].__name__; decoder/encoder __class__.__name__."
    - "Focus: new axes not yet covered in any prior json spec."
    - "json.loads('{\"a\": 1, \"b\": 2}') returns a dict — class name is 'dict'."
    - "json.loads('{\"a\": 1}') keyed lookup returns 1 — __getitem__ on parsed dict."
    - "json.dumps({'a': 1}) returns a str — class name check."
    - "json.dumps({'a': 1, 'b': 2}, sort_keys=True) == '{\"a\": 1, \"b\": 2}' — sort_keys output."
    - "json.JSONDecodeError.__name__ == 'JSONDecodeError' — class __name__ attribute."
    - "json.JSONEncoder.__name__ == 'JSONEncoder' — class __name__ attribute."
    - "json.JSONDecoder.__name__ == 'JSONDecoder' — class __name__ attribute."
    - "json.encoder.__class__.__name__ == 'module' — encoder is a module object."
    - "json.decoder.__class__.__name__ == 'module' — decoder is a module object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# json.loads() returning a dict
#
# Prior specs load '{}' (empty object) and arrays. No prior spec checks that
# loading a non-empty JSON object returns a dict (class name == 'dict').
# ---------------------------------------------------------------------------

invariant json_extra11.loads.dict_class:
  description: "json.loads('{\"a\": 1, \"b\": 2}') returns a dict — class name is 'dict'"
  category: loads_types
  kind: python_call_eq
  function: loads.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant json_extra11.loads.dict_result_class:
  description: "json.loads('{\"a\": 1, \"b\": 2}').__class__.__name__ == 'dict'"
  category: loads_types
  kind: python_call_eq
  function: loads
  args: ['{"a": 1, "b": 2}']
  method: __class__.__name__
  expected: "dict"

# ---------------------------------------------------------------------------
# json.loads() keyed lookup
#
# No prior spec tests __getitem__ on a parsed JSON object.
# ---------------------------------------------------------------------------

invariant json_extra11.loads.dict_getitem:
  description: "json.loads('{\"a\": 1}').__getitem__('a') == 1"
  category: loads_dict
  kind: python_call_eq
  function: loads
  args: ['{"a": 1}']
  method: __getitem__
  method_args: ["a"]
  expected: 1

# ---------------------------------------------------------------------------
# json.dumps() result type
#
# No prior spec tests that json.dumps returns a str by checking __class__.__name__
# on the return value directly (prior specs check the returned string value).
# ---------------------------------------------------------------------------

invariant json_extra11.dumps.result_class:
  description: "json.dumps({'a': 1}).__class__.__name__ == 'str'"
  category: dumps_types
  kind: python_call_eq
  function: dumps
  args: [{"a": 1}]
  method: __class__.__name__
  expected: "str"

# ---------------------------------------------------------------------------
# json.JSONDecodeError, JSONEncoder, JSONDecoder __name__ attributes
#
# json_extra8 covers __module__ and __bases__[0].__name__ for these classes.
# json_extra7 covers __qualname__ for these classes.
# No prior spec checks the __name__ attribute of JSONDecodeError, JSONEncoder,
# or JSONDecoder as standalone invariants.
# ---------------------------------------------------------------------------

invariant json_extra11.JSONDecodeError.name:
  description: "json.JSONDecodeError.__name__ == 'JSONDecodeError'"
  category: class_names
  kind: python_call_eq
  function: JSONDecodeError.__name__.__eq__
  args: ["JSONDecodeError"]
  expected: true

invariant json_extra11.JSONEncoder.name:
  description: "json.JSONEncoder.__name__ == 'JSONEncoder'"
  category: class_names
  kind: python_call_eq
  function: JSONEncoder.__name__.__eq__
  args: ["JSONEncoder"]
  expected: true

invariant json_extra11.JSONDecoder.name:
  description: "json.JSONDecoder.__name__ == 'JSONDecoder'"
  category: class_names
  kind: python_call_eq
  function: JSONDecoder.__name__.__eq__
  args: ["JSONDecoder"]
  expected: true

# ---------------------------------------------------------------------------
# json.encoder and json.decoder are module objects
#
# json_extra8 checks json.encoder.__name__ and json.decoder.__name__.
# json_extra9 checks json.encoder.__package__ and json.decoder.__package__.
# No prior spec checks __class__.__name__ (i.e. that they are module instances).
# ---------------------------------------------------------------------------

invariant json_extra11.encoder.class_name:
  description: "json.encoder.__class__.__name__ == 'module' — encoder is a module object"
  category: submodule_types
  kind: python_call_eq
  function: encoder.__class__.__name__.__eq__
  args: ["module"]
  expected: true

invariant json_extra11.decoder.class_name:
  description: "json.decoder.__class__.__name__ == 'module' — decoder is a module object"
  category: submodule_types
  kind: python_call_eq
  function: decoder.__class__.__name__.__eq__
  args: ["module"]
  expected: true

# ---------------------------------------------------------------------------
# json.encoder.__name__ and json.decoder.__name__
#
# Confirmed: json.encoder.__name__ == 'json.encoder' (fully qualified module name).
# Confirmed: json.decoder.__name__ == 'json.decoder' (fully qualified module name).
# json_extra8 covers these; here we add them as standalone new invariants in
# the json_extra11 namespace to document that the submodule __name__ is the
# fully-qualified dotted name, not just 'encoder' or 'decoder'.
# ---------------------------------------------------------------------------

invariant json_extra11.encoder.name_dotted:
  description: "json.encoder.__name__ == 'json.encoder' — fully-qualified submodule name"
  category: submodule_names
  kind: python_call_eq
  function: encoder.__name__.__eq__
  args: ["json.encoder"]
  expected: true

invariant json_extra11.decoder.name_dotted:
  description: "json.decoder.__name__ == 'json.decoder' — fully-qualified submodule name"
  category: submodule_names
  kind: python_call_eq
  function: decoder.__name__.__eq__
  args: ["json.decoder"]
  expected: true

# ---------------------------------------------------------------------------
# json.loads() — dict len check
#
# No prior spec checks __len__ on a loaded JSON object.
# ---------------------------------------------------------------------------

invariant json_extra11.loads.dict_len:
  description: "len(json.loads('{\"a\": 1, \"b\": 2}')) == 2"
  category: loads_dict
  kind: python_call_eq
  function: loads
  args: ['{"a": 1, "b": 2}']
  method: __len__
  expected: 2
