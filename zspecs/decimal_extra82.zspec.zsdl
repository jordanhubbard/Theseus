spec: decimal_extra82
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra81."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for various dunders; Decimal comparison/equality/hash wrapper_descriptor identity; Context/__dict__ class and membership; getcontext/setcontext __class__.__name__ and __module__; Decimal division/power operator wrapper_descriptor identity and __dict__ membership; Context arithmetic method __class__.__name__; Decimal arithmetic/string/conversion dunder __qualname__ values and lengths; Decimal comparison operator __qualname__ lengths; Decimal to_*/normalize/quantize/sqrt/compare __qualname__ lengths; Decimal.__dict__.__contains__ for arithmetic/comparison/math operators; Decimal/__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); Context/__name__/__module__/__qualname__; ROUND_* constants; Decimal arithmetic operator __doc__.__class__.__name__ (all 'str'); Decimal unary/comparison/math method __doc__.__class__.__name__."
    - "This spec covers: decimal.InvalidOperation.__name__ == 'InvalidOperation'; decimal.InvalidOperation.__module__ == 'decimal'; decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException'; decimal.InvalidOperation.__mro__.__len__() == 6; decimal.DivisionByZero.__name__ == 'DivisionByZero'; decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException'; decimal.DivisionByZero.__mro__.__len__() == 7; decimal.Overflow.__name__ == 'Overflow'; decimal.Overflow.__bases__[0].__name__ == 'Inexact'; decimal.Overflow.__mro__.__len__() == 8; decimal.Underflow.__name__ == 'Underflow'; decimal.Underflow.__bases__[0].__name__ == 'Inexact'; decimal.Inexact.__name__ == 'Inexact'; decimal.DecimalException.__name__ == 'DecimalException'; decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError'."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation' — verified on Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__module__ == 'decimal' — verified on Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — direct base class."
    - "decimal.InvalidOperation.__mro__.__len__() == 6 — MRO: [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.DivisionByZero.__name__ == 'DivisionByZero' — verified on Python 3.14.3 macOS."
    - "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' — direct base class."
    - "decimal.DivisionByZero.__mro__.__len__() == 7 — MRO: [DivisionByZero, DecimalException, ZeroDivisionError, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Overflow.__name__ == 'Overflow' — verified on Python 3.14.3 macOS."
    - "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — Overflow inherits from Inexact (which inherits from DecimalException)."
    - "decimal.Overflow.__mro__.__len__() == 8 — MRO: [Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Underflow.__name__ == 'Underflow' — verified on Python 3.14.3 macOS."
    - "decimal.Underflow.__bases__[0].__name__ == 'Inexact' — Underflow inherits from Inexact."
    - "decimal.Underflow.__mro__.__len__() == 9 — MRO: [Underflow, Inexact, Rounded, Subnormal, DecimalException, ArithmeticError, Exception, BaseException, object]; length 9."
    - "decimal.Inexact.__name__ == 'Inexact' — verified on Python 3.14.3 macOS."
    - "decimal.DecimalException.__name__ == 'DecimalException' — verified on Python 3.14.3 macOS."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — direct base class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.InvalidOperation class identity: __name__, __module__, __bases__[0].__name__
# InvalidOperation is a direct subclass of DecimalException; MRO length is 6.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra82.InvalidOperation_identity:
  description: "decimal.InvalidOperation __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalextra82

  columns: [id, function, args, expected]
  rows:
    - [inval_name,    InvalidOperation.__name__.__eq__,                       ["InvalidOperation"],  true]
    - [inval_module,  InvalidOperation.__module__.__eq__,                     ["decimal"],           true]
    - [inval_base0,   "InvalidOperation.__bases__[0].__name__.__eq__",        ["DecimalException"],  true]
    - [inval_mrolen,  InvalidOperation.__mro__.__len__,                       [],                    6]

# ---------------------------------------------------------------------------
# decimal.DivisionByZero class identity: __name__, __bases__[0].__name__, __mro__.__len__()
# DivisionByZero has a complex MRO (length 7) including ZeroDivisionError.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra82.DivisionByZero_identity:
  description: "decimal.DivisionByZero __name__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalextra82

  columns: [id, function, args, expected]
  rows:
    - [divz_name,   DivisionByZero.__name__.__eq__,                    ["DivisionByZero"],  true]
    - [divz_base0,  "DivisionByZero.__bases__[0].__name__.__eq__",     ["DecimalException"], true]
    - [divz_mrolen, DivisionByZero.__mro__.__len__,                    [],                  7]

# ---------------------------------------------------------------------------
# decimal.Overflow and Underflow class identity
# Overflow inherits from Inexact (MRO length 8).
# Underflow inherits from Inexact and also Subnormal (MRO length 9).
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra82.Overflow_Underflow_identity:
  description: "decimal.Overflow/Underflow __name__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalextra82

  columns: [id, function, args, expected]
  rows:
    - [ovf_name,    Overflow.__name__.__eq__,                  ["Overflow"],  true]
    - [ovf_base0,   "Overflow.__bases__[0].__name__.__eq__",   ["Inexact"],   true]
    - [ovf_mrolen,  Overflow.__mro__.__len__,                  [],            8]
    - [ufl_name,    Underflow.__name__.__eq__,                 ["Underflow"], true]
    - [ufl_base0,   "Underflow.__bases__[0].__name__.__eq__",  ["Inexact"],   true]
    - [ufl_mrolen,  Underflow.__mro__.__len__,                 [],            9]

# ---------------------------------------------------------------------------
# decimal.Inexact and DecimalException class identity
# Inexact is the common base for Overflow/Underflow/Rounded.
# DecimalException.__bases__[0].__name__ == 'ArithmeticError'.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra82.Inexact_DecimalException_identity:
  description: "decimal.Inexact/__name__; DecimalException/__name__/__bases__[0].__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalextra82

  columns: [id, function, args, expected]
  rows:
    - [inexact_name,   Inexact.__name__.__eq__,                          ["Inexact"],          true]
    - [decexc_name,    DecimalException.__name__.__eq__,                 ["DecimalException"],  true]
    - [decexc_base0,   "DecimalException.__bases__[0].__name__.__eq__",  ["ArithmeticError"],   true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra82.InvalidOperation.name:
  description: "decimal.InvalidOperation.__name__ == 'InvalidOperation' (verified on Python 3.14.3 macOS)"
  category: class_identity
  kind: python_call_eq
  function: InvalidOperation.__name__.__eq__
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra82.InvalidOperation.mro_len:
  description: "decimal.InvalidOperation.__mro__.__len__() == 6 (MRO: InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object)"
  category: class_identity
  kind: python_call_eq
  function: InvalidOperation.__mro__.__len__
  args: []
  expected: 6

invariant decimal_extra82.DivisionByZero.base_is_DecimalException:
  description: "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' (direct base class)"
  category: class_identity
  kind: python_call_eq
  function: "DivisionByZero.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra82.Overflow.base_is_Inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (Overflow inherits from Inexact, not directly from DecimalException)"
  category: class_identity
  kind: python_call_eq
  function: "Overflow.__bases__[0].__name__.__eq__"
  args: ["Inexact"]
  expected: true

invariant decimal_extra82.DecimalException.base_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (DecimalException is rooted in ArithmeticError)"
  category: class_identity
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true
