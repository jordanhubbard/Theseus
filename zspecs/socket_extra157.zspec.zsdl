#
# SOL_SOCKET == 65535 (0xFFFF) on macOS (platform-specific; Linux uses 1).
# SO_REUSEADDR.__class__.__name__ == 'int' (3 chars; plain int).
# SO_KEEPALIVE.__class__.__name__ == 'int' (3 chars; plain int).
# SO_REUSEADDR == 4 on macOS (platform-specific; Linux uses 2).
# No prior socket spec anchors SOL_SOCKET value or SO_* class names as a table under
# sockipproto157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra157.SOL_SOCKET_and_SO_option_identity:
  description: "socket.SOL_SOCKET.__eq__(65535)==True / SO_REUSEADDR.__class__.__name__.__eq__('int')==True / SO_KEEPALIVE.__class__.__name__.__eq__('int')==True / SO_REUSEADDR.__eq__(4)==True — SOL_SOCKET is 65535 (0xFFFF; macOS/BSD-specific; Linux uses 1; socket-level option layer constant for getsockopt/setsockopt); SO_REUSEADDR.__class__.__name__ is 'int' (3 chars; plain int constant; not IntEnum); SO_KEEPALIVE.__class__.__name__ is 'int' (3 chars; same type); SO_REUSEADDR is 4 on macOS (macOS/BSD-specific; Linux uses 2; allows port reuse in TIME_WAIT state); first sockipproto157 anchor for SOL_SOCKET value and SO_* type identity"
  kind: python_call_eq
