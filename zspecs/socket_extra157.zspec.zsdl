    - [SO_REUSEADDR_class_int,     "SO_REUSEADDR.__class__.__name__.__eq__", ["int"],  true, "socket.SO_REUSEADDR.__class__.__name__ == 'int' (3 chars; plain int constant; allows port reuse in TIME_WAIT state)"]
    - [SO_KEEPALIVE_class_int,     "SO_KEEPALIVE.__class__.__name__.__eq__", ["int"],  true, "socket.SO_KEEPALIVE.__class__.__name__ == 'int' (3 chars; plain int constant; enables TCP keepalive probes on socket)"]
    - [SO_REUSEADDR_eq_4,          "SO_REUSEADDR.__eq__",                    [4],     true, "socket.SO_REUSEADDR == 4 (macOS/BSD-specific; Linux uses 2; allows reuse of port address in TIME_WAIT state)"]

# ---------------------------------------------------------------------------
# IPPROTO protocol value ordering and SO_* option value ordering
#
# Wave 339 theme: numeric ordering checks for protocol and socket option constants.
#
# IPPROTO_IP(0) < IPPROTO_TCP(6) < IPPROTO_UDP(17) — ordering by protocol number.
# SO_REUSEADDR(4) < SO_KEEPALIVE(8) on macOS.
# These ordering checks confirm the numeric relationships between the constants.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra157.IPPROTO_and_SO_option_values:
  description: "socket.IPPROTO_IP.__eq__(0)==True / IPPROTO_TCP.__eq__(6)==True / SO_REUSEADDR.__eq__(4)==True / SO_KEEPALIVE.__eq__(8)==True — IPPROTO_IP is 0 (IP level); IPPROTO_TCP is 6 (TCP; between IP=0 and UDP=17); ordering: IPPROTO_IP(0) < IPPROTO_TCP(6) < IPPROTO_UDP(17); SO_REUSEADDR is 4 on macOS (SO_REUSEADDR(4) < SO_KEEPALIVE(8)); SO_KEEPALIVE is 8 on macOS; all four constants are plain 'int' (__class__.__name__=='int'); macOS/BSD-specific values for SO_REUSEADDR and SO_KEEPALIVE; IANA-standardized values for IPPROTO_IP/TCP/UDP; first sockipproto157 anchor for SO_KEEPALIVE value"
  kind: python_call_eq
  category: identity
  id_prefix: sockipproto157

  columns: [id, function, args, expected, description]
  rows:
    - [IPPROTO_IP_eq_0b,    "IPPROTO_IP.__eq__",     [0],  true, "socket.IPPROTO_IP == 0 (IP protocol level; IANA; cross-platform; smallest IPPROTO_ constant in this spec)"]
    - [IPPROTO_TCP_eq_6b,   "IPPROTO_TCP.__eq__",    [6],  true, "socket.IPPROTO_TCP == 6 (IANA TCP; RFC 793; ordering: IP=0 < TCP=6 < UDP=17; 'Transmission Control Protocol')"]
    - [SO_REUSEADDR_eq_4b,  "SO_REUSEADDR.__eq__",   [4],  true, "socket.SO_REUSEADDR == 4 (macOS/BSD; allow port reuse; SO_REUSEADDR(4) < SO_KEEPALIVE(8) on macOS)"]
    - [SO_KEEPALIVE_eq_8,   "SO_KEEPALIVE.__eq__",   [8],  true, "socket.SO_KEEPALIVE == 8 (macOS/BSD; enable TCP keepalive probes; SO_REUSEADDR(4) < SO_KEEPALIVE(8) on macOS)"]

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__eq__(6) — standalone
#
# socket.IPPROTO_TCP is 6. TCP (Transmission Control Protocol) has been assigned
# protocol number 6 by IANA (Internet Assigned Numbers Authority) since its
# standardization in RFC 793 (1981). This value is consistent across all platforms
# (Linux, macOS, FreeBSD, Windows). IPPROTO_TCP is used as the third argument to
# socket.socket() when explicitly specifying the TCP protocol for SOCK_STREAM sockets:
# socket.socket(socket.AF_INET, socket.SOCK_STREAM, socket.IPPROTO_TCP).
# IPPROTO_TCP.__class__.__name__ == 'int' (plain int, not IntEnum).
# No prior socket spec anchors IPPROTO_TCP.__eq__(6) as a standalone under sockipproto157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra157.IPPROTO_TCP_eq_6:
  description: "socket.IPPROTO_TCP.__eq__(6) == True — IANA protocol number 6; RFC 793 (1981); cross-platform (Linux/macOS/FreeBSD/Windows); Transmission Control Protocol; used in socket(AF_INET, SOCK_STREAM, IPPROTO_TCP); IPPROTO_TCP.__class__.__name__=='int' (3 chars; plain int from _socket); ordering: IPPROTO_IP(0) < IPPROTO_TCP(6) < IPPROTO_UDP(17); no prior socket spec anchors this as a standalone; first standalone under sockipproto157"
  category: identity
  kind: python_call_eq
  function: IPPROTO_TCP.__eq__
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET.__eq__(65535) — standalone (macOS)
#
# socket.SOL_SOCKET is 65535 (0xFFFF) on macOS/BSD systems. SOL_SOCKET is the
# socket-level option layer constant used as the first argument (level) in
# getsockopt() and setsockopt() when working with socket-level options (as opposed
# to protocol-level options like IPPROTO_TCP). On Linux, SOL_SOCKET == 1.
# On macOS and BSD, SOL_SOCKET == 0xFFFF == 65535 — a design choice in the BSD
# socket implementation that predates POSIX standardization. SOL_SOCKET.__class__.__name__
# == 'int' (plain int, same as all socket constants). This value is macOS-specific
# and should not be assumed for other platforms.
# No prior socket spec anchors SOL_SOCKET.__eq__(65535) as a standalone under sockipproto157.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra157.SOL_SOCKET_eq_65535_macos:
  description: "socket.SOL_SOCKET.__eq__(65535) == True — 0xFFFF; macOS/BSD-specific (Linux uses 1); socket-level option layer constant; used as level argument in getsockopt(sock, SOL_SOCKET, optname) and setsockopt(sock, SOL_SOCKET, optname, value); BSD socket design choice; SOL_SOCKET.__class__.__name__=='int' (3 chars; plain int); SO_REUSEADDR and SO_KEEPALIVE are also plain int constants; no prior socket spec anchors SOL_SOCKET value as a standalone; first standalone under sockipproto157"
  category: identity
  kind: python_call_eq
  function: SOL_SOCKET.__eq__
  args: [65535]
  expected: true

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int') — standalone
#
# socket.IPPROTO_TCP.__class__.__name__ is 'int' (3 chars). The IPPROTO_* constants
# in the socket module are plain Python int values (not IntEnum members). This is
# unlike some other constants in socket (e.g., socket.AF_INET and socket.SOCK_STREAM
# which are IntEnum members in Python 3.4+). The IPPROTO_ constants (TCP=6, UDP=17,
# IP=0, etc.) remain plain int objects. __class__.__name__ == 'int' (3 chars; same
# type as SO_REUSEADDR and SO_KEEPALIVE). This confirms the type is 'int' and not
# 'IntEnum', 'AddressFamily', 'SocketKind', or any other enum type.
# No prior socket spec anchors IPPROTO_TCP.__class__.__name__ as a standalone under
# sockipproto157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra157.IPPROTO_TCP_class_int:
  description: "socket.IPPROTO_TCP.__class__.__name__.__eq__('int') == True — 'int' (3 chars); plain Python int constant from _socket C extension; NOT an IntEnum member (unlike some socket constants such as AF_INET which is AddressFamily IntEnum); IPPROTO_TCP(6)/IPPROTO_UDP(17)/IPPROTO_IP(0) are all plain int; SO_REUSEADDR(4)/SO_KEEPALIVE(8)/SOL_SOCKET(65535) are also plain int; no prior socket spec anchors IPPROTO_TCP.__class__.__name__ as a standalone; first standalone under sockipproto157"
  category: identity
  kind: python_call_eq
  function: IPPROTO_TCP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

