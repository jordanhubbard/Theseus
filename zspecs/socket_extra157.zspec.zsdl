spec: socket_extra157
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra156.zspec.zsdl — covers socket.__spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('socket') / socket.socket makefile/__setblocking/__settimeout/__getpeername/__getsockname/__setsockopt qualnames and lengths (table + invariants)."
    - "socket_extra155.zspec.zsdl — covers socket.setdefaulttimeout/__class__.__name__/__module__ / getdefaulttimeout/__class__.__name__ / gethostname/__class__.__name__/__module__ / getaddrinfo/__class__.__name__/__module__ / socket.socket.__doc__/__class__.__name__ (table + invariants)."
    - "socket_extra154.zspec.zsdl — covers socket.error/__name__/__eq__('OSError') / gaierror/__bases__[0].__name__ / herror/__name__/__module__ / timeout/__name__/__eq__('TimeoutError') / timeout/__module__/__eq__('builtins') / timeout/__bases__[0].__name__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra156."
    - "Wave 339 theme: socket IPPROTO_* protocol constants and SO_* socket option types — IPPROTO_TCP.__eq__(6) / IPPROTO_UDP.__eq__(17) / IPPROTO_IP.__eq__(0) / IPPROTO_TCP.__class__.__name__.__eq__('int') / SOL_SOCKET.__eq__(65535) / SO_REUSEADDR.__class__.__name__.__eq__('int') / SO_KEEPALIVE.__class__.__name__.__eq__('int')."
    - "socket.IPPROTO_TCP == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_UDP == 17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_IP == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOL_SOCKET == 65535 (0xFFFF) on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_REUSEADDR == 4 on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_REUSEADDR.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_KEEPALIVE == 8 on macOS. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SO_KEEPALIVE.__class__.__name__ == 'int'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.IPPROTO_TCP == 6. The TCP protocol number is defined in RFC 793 and IANA's Protocol Number registry. TCP is protocol number 6. IPPROTO_UDP is 17. IPPROTO_IP is 0. These are IANA-standardized protocol numbers, the same across all Unix platforms. On macOS, socket.IPPROTO_TCP.__class__.__name__ == 'int' (plain int, not IntEnum; these are raw integer constants from the _socket C extension)."
    - "Note: socket.SOL_SOCKET == 65535 (0xFFFF) on macOS. SOL_SOCKET is the socket-level option layer constant used as the first argument to getsockopt()/setsockopt(). On macOS/BSD, SOL_SOCKET == 0xFFFF == 65535. On Linux, SOL_SOCKET == 1. This is a significant platform difference. This spec is macOS-specific for SOL_SOCKET."
    - "Note: socket.SO_REUSEADDR == 4 on macOS and socket.SO_KEEPALIVE == 8 on macOS. Both are plain int constants (__class__.__name__ == 'int'). SO_REUSEADDR allows reuse of a port in TIME_WAIT state. SO_KEEPALIVE enables TCP keepalives. On Linux, SO_REUSEADDR == 2 and SO_KEEPALIVE == 9. These are macOS/BSD-specific values. SO_REUSEADDR(4) < SO_KEEPALIVE(8) on macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.IPPROTO_TCP.__eq__(6)
# socket.IPPROTO_UDP.__eq__(17)
# socket.IPPROTO_IP.__eq__(0)
# socket.IPPROTO_TCP.__class__.__name__.__eq__('int')
#
# Wave 339 theme: IANA standard IP protocol numbers and their type identity.
#
# IPPROTO_TCP == 6 (IANA TCP protocol number; RFC 793; cross-platform).
# IPPROTO_UDP == 17 (IANA UDP protocol number; RFC 768; cross-platform).
# IPPROTO_IP == 0 (IP protocol number; cross-platform).
# IPPROTO_TCP.__class__.__name__ == 'int' (3 chars; plain int, not IntEnum; from _socket C extension).
# No prior socket spec anchors IPPROTO_TCP/UDP/IP values or class names as a table under
# sockipproto157. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra157.IPPROTO_constants_values_and_type:
  description: "socket.IPPROTO_TCP.__eq__(6)==True / IPPROTO_UDP.__eq__(17)==True / IPPROTO_IP.__eq__(0)==True / IPPROTO_TCP.__class__.__name__.__eq__('int')==True — IPPROTO_TCP is 6 (IANA TCP protocol number; RFC 793; 'Transmission Control Protocol'; cross-platform); IPPROTO_UDP is 17 (IANA UDP protocol number; RFC 768; 'User Datagram Protocol'); IPPROTO_IP is 0 (IP protocol level; used as the level argument in setsockopt/getsockopt for IP options); IPPROTO_TCP.__class__.__name__ is 'int' (3 chars; plain int constant from _socket C extension; not IntEnum or SocketKind); first sockipproto157 anchor for IPPROTO constant values and type identity"
  kind: python_call_eq
  category: identity
  id_prefix: sockipproto157

  columns: [id, function, args, expected, description]
  rows:
    - [IPPROTO_TCP_eq_6,          "IPPROTO_TCP.__eq__",                     [6],    true, "socket.IPPROTO_TCP == 6 (IANA TCP protocol number; RFC 793; cross-platform; used in socket(AF_INET, SOCK_STREAM, IPPROTO_TCP))"]
    - [IPPROTO_UDP_eq_17,         "IPPROTO_UDP.__eq__",                     [17],   true, "socket.IPPROTO_UDP == 17 (IANA UDP protocol number; RFC 768; cross-platform; used in socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP))"]
    - [IPPROTO_IP_eq_0,           "IPPROTO_IP.__eq__",                      [0],    true, "socket.IPPROTO_IP == 0 (IP protocol level constant; used as level in setsockopt/getsockopt for IP-level options)"]
    - [IPPROTO_TCP_class_int,     "IPPROTO_TCP.__class__.__name__.__eq__",  ["int"], true, "socket.IPPROTO_TCP.__class__.__name__ == 'int' (3 chars; plain int constant from _socket C extension; not IntEnum or SocketKind)"]

# ---------------------------------------------------------------------------
# socket.SOL_SOCKET.__eq__(65535) — macOS-specific
# socket.SO_REUSEADDR.__class__.__name__.__eq__('int')
# socket.SO_KEEPALIVE.__class__.__name__.__eq__('int')
# socket.SO_REUSEADDR.__eq__(4) — macOS-specific
#
