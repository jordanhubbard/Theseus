spec: picomatch
version: ">=4.0.0"
backend: node(picomatch)

docs: https://github.com/micromatch/picomatch#readme

provenance:
  derived_from:
    - "picomatch README — https://github.com/micromatch/picomatch#readme"
    - "Test vectors verified with picomatch@4.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "picomatch source: lib/picomatch.js"
  notes:
    - "picomatch exports the function as the module default (CJS)."
    - "pm(pattern) returns a matcher function; call that function with a filepath to test."
    - "The factory call pattern: pm('*.js') produces a function, then call it with 'foo.js'."
    - "Specced using node_factory_call_eq with method: call and method_args: [null, filepath]."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean from matcher function. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table picomatch.match:
  kind: node_factory_call_eq
  function: ~
  method: call
  category: match
  id_prefix: pm

  columns: [id, args, method_args, expected]
  rows:
    - [js_match,    ["*.js"],   [~, "foo.js"],   true]
    - [js_nomatch,  ["*.js"],   [~, "foo.txt"],  false]
    - [exact,       ["foo"],    [~, "foo"],      true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:42:05Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
