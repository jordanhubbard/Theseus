spec: multiprocessing_extra1006
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.Process and multiprocessing.Queue method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1006.process_qualnames:
  description: "multiprocessing.Process method __qualname__ identity"
  kind: python_call_eq
  category: process_qualnames
  id_prefix: mp1006pr
  columns: [id, function, args, expected]
  rows:
    - [mp1006pr001, multiprocessing.Process.__init__.__qualname__.__eq__,   ["Process.__init__"],   true]
    - [mp1006pr002, multiprocessing.Process.__repr__.__qualname__.__eq__,   ["Process.__repr__"],   true]
    - [mp1006pr003, multiprocessing.Process.__name__.__eq__,                ["Process"],            true]
    - [mp1006pr004, multiprocessing.Process.__module__.__eq__,              ["multiprocessing.process"], true]
    - [mp1006pr005, multiprocessing.Process.__qualname__.__eq__,            ["Process"],            true]

table multiprocessing_extra1006.queue_qualnames:
  description: "multiprocessing.Queue method __qualname__ identity"
  kind: python_call_eq
  category: queue_qualnames
  id_prefix: mp1006qu
  columns: [id, function, args, expected]
  rows:
    - [mp1006qu001, multiprocessing.Queue.get.__qualname__.__eq__,         ["Queue.get"],         true]
    - [mp1006qu002, multiprocessing.Queue.put.__qualname__.__eq__,         ["Queue.put"],         true]
    - [mp1006qu003, multiprocessing.Queue.empty.__qualname__.__eq__,       ["Queue.empty"],       true]
    - [mp1006qu004, multiprocessing.Queue.full.__qualname__.__eq__,        ["Queue.full"],        true]
    - [mp1006qu005, multiprocessing.Queue.close.__qualname__.__eq__,       ["Queue.close"],       true]
    - [mp1006qu006, multiprocessing.Queue.join_thread.__qualname__.__eq__, ["Queue.join_thread"], true]

table multiprocessing_extra1006.module_identity:
  description: "multiprocessing module-level identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: mp1006mi
  columns: [id, function, args, expected]
  rows:
    - [mp1006mi001, multiprocessing.Queue.__name__.__eq__,     ["Queue"],                    true]
    - [mp1006mi002, multiprocessing.Queue.__module__.__eq__,   ["multiprocessing.queues"],   true]
    - [mp1006mi003, multiprocessing.Queue.__qualname__.__eq__, ["Queue"],                    true]
    - [mp1006mi004, multiprocessing.Process.__init__.__qualname__.__eq__, ["Process.__init__"], true]
