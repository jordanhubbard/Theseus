spec: decimal_extra168
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal module-level identity (__name__, __package__, __spec__.__class__.__name__) and decimal.Decimal.__dict__.__contains__ for all six comparison dunder methods: __lt__, __le__, __gt__, __ge__, __eq__, __ne__."
    - "decimal.__name__ == 'decimal' (len=7)."
    - "decimal.__package__ == '' (len=0: empty string) — decimal is a top-level module with no parent package."
    - "decimal.__spec__.__class__.__name__ == 'ModuleSpec' (len=10)."
    - "decimal.Decimal.__dict__.__contains__('__lt__') == True (len=6: '__'(2)+'lt'(2)+'__'(2)=6)."
    - "decimal.Decimal.__dict__.__contains__('__le__') == True (len=6: '__'(2)+'le'(2)+'__'(2)=6)."
    - "decimal.Decimal.__dict__.__contains__('__gt__') == True (len=6: '__'(2)+'gt'(2)+'__'(2)=6)."
    - "decimal.Decimal.__dict__.__contains__('__ge__') == True (len=6: '__'(2)+'ge'(2)+'__'(2)=6)."
    - "decimal.Decimal.__dict__.__contains__('__eq__') == True (len=6: '__'(2)+'eq'(2)+'__'(2)=6)."
    - "decimal.Decimal.__dict__.__contains__('__ne__') == True (len=6: '__'(2)+'ne'(2)+'__'(2)=6)."
    - "Six-way tie at 6: __lt__(6)=__le__(6)=__gt__(6)=__ge__(6)=__eq__(6)=__ne__(6)."
    - "All six comparison dunders follow '__'(2)+2-char-core+'__'(2)=6: cores lt, le, gt, ge, eq, ne are all 2-character abbreviations."
    - "The 2-char cores pair as logical opposites: lt/ge, le/gt, eq/ne."
    - "decimal.__package__ == '' (empty) == io.__package__ (empty): both decimal and io are top-level modules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal module-level identity: __name__ and __package__
# decimal.__name__ == 'decimal' (len=7)
# decimal.__package__ == '' (len=0: empty string) — top-level module
# decimal (7 chars) == pathlib (7 chars) in module name length
# ---------------------------------------------------------------------------

table decimal_extra168.module_name_package:
  description: "decimal.__name__=='decimal' (len=7); decimal.__package__=='' (len=0: empty string); decimal is a top-level module with no parent package; decimal.__name__ (7) == pathlib.__name__ (7): tied for longest module name in this spec series; decimal.__package__ (0) == io.__package__ (0): both top-level modules"
  kind: python_call_eq
  category: identity
  id_prefix: decmod168

  columns: [id, function, args, expected, description]
  rows:
    - [dec_name_eq,  decimal.__name__.__eq__,    ["decimal"], true,  "decimal.__name__ == 'decimal' — the public name of the decimal module; 'decimal' has 7 characters: 'd-e-c-i-m-a-l'; decimal (7 chars) == pathlib (7 chars): the two longest module names in this spec series are tied at 7; decimal (7 chars) > io (2 chars) by 5 and > re (2 chars) by 5: decimal has 5 more characters than the two shortest module names; decimal.__name__ (7 chars) == len('Decimal') (7 chars): the module name and the primary class name are identical in both string and length — the primary class is eponymous; decimal.__name__ (7 chars) == len('Pattern') (7 chars) == len('Context') (7 chars): the decimal module name ties with primary class names across re and decimal itself; confirmed Python 3.14.3 macOS"]
    - [dec_name_len, decimal.__name__.__len__,   [],          7,     "decimal.__name__.__len__() == 7 — 'decimal' has 7 characters; decimal (7 chars) == pathlib (7 chars): both share the 7-character module name length, the maximum in this spec series; decimal (7) > io (2) by 5 and > re (2) by 5: decimal is 5 characters longer than the shortest module names; decimal.__name__ (7 chars) == len('decimal') (7 chars): the eponymous relationship between module name and class name extends to identical length; the 7-character module name also ties with: len('Decimal')(7), len('Pattern')(7), len('Context')(7), len('compile')(7), len('findall')(7) — a broad 7-character coincidence across the standard library; confirmed Python 3.14.3 macOS"]
    - [dec_pkg_eq,   decimal.__package__.__eq__, [""],        true,  "decimal.__package__ == '' — decimal is a top-level module with an empty string package attribute; decimal.__package__ (len=0: empty) == io.__package__ (len=0: empty): both decimal and io are top-level modules with no parent package; decimal.__package__ (0: '') != re.__package__ (2: 're') and != pathlib.__package__ (7: 'pathlib'): re and pathlib are packages (__package__ == __name__) while decimal is a top-level module (__package__ == ''); the empty __package__ encodes that decimal sits directly at the Python standard library root, not inside a sub-package; confirmed Python 3.14.3 macOS"]
    - [dec_pkg_len,  decimal.__package__.__len__, [],         0,     "decimal.__package__.__len__() == 0 — decimal.__package__ is the empty string, which has length 0; decimal.__package__ (len=0) == io.__package__ (len=0): both decimal and io have empty __package__ attributes — both are top-level modules; decimal.__package__ (0) < re.__package__ (2: 're') < pathlib.__package__ (7: 'pathlib'): the three non-zero package lengths in this spec series follow the module name length ordering; decimal.__name__ (7 chars) > decimal.__package__ (0 chars) by 7: the module name length exceeds the package length by the same 7 as the module name length itself; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal module-level identity: __spec__.__class__.__name__
# decimal.__spec__.__class__.__name__ == 'ModuleSpec' (len=10)
# Uniform across io, pathlib, re, decimal
# ---------------------------------------------------------------------------

table decimal_extra168.module_spec_class:
  description: "decimal.__spec__.__class__.__name__=='ModuleSpec' (len=10); 'ModuleSpec'='Module'(6)+'Spec'(4)=10; decimal.__spec__.__class__.__name__ (10) == io.__spec__.__class__.__name__ (10) == pathlib.__spec__.__class__.__name__ (10) == re.__spec__.__class__.__name__ (10) — four-module tie"
  kind: python_call_eq
  category: identity
  id_prefix: decspec168

  columns: [id, function, args, expected, description]
  rows:
    - [dec_spec_cls, decimal.__spec__.__class__.__name__.__eq__,  ["ModuleSpec"], true, "decimal.__spec__.__class__.__name__ == 'ModuleSpec' — decimal.__spec__ is an importlib.machinery.ModuleSpec instance; 'ModuleSpec' has 10 characters: 'Module'(6)+'Spec'(4)=10; decimal.__spec__.__class__.__name__ (10: 'ModuleSpec') == io.__spec__.__class__.__name__ (10: 'ModuleSpec') == pathlib.__spec__.__class__.__name__ (10: 'ModuleSpec') == re.__spec__.__class__.__name__ (10: 'ModuleSpec'): a four-module cross-spec tie at 'ModuleSpec' (10 chars); 'Module' (6 chars) == len('__lt__') (6 chars): the first component of 'ModuleSpec' ties with the comparison dunder method names in this spec; 'Spec' (4 chars) == len('__lt__') - 2 == 4: the second component of 'ModuleSpec' equals the 2-char core length + 2 (the dunder wrapper); confirmed Python 3.14.3 macOS"]
    - [dec_spec_len, decimal.__spec__.__class__.__name__.__len__, [],             10,   "decimal.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters: 'Module'(6)+'Spec'(4)=10; 10 is the consistent ModuleSpec class name length across all standard library modules; ModuleSpec (10) > __lt__ (6 chars) by 4: the spec class name is 4 characters longer than each comparison dunder in this spec; 'Module' (6 chars) == len('__lt__') (6 chars) == len('__le__') (6 chars) == len('__gt__') (6 chars) == len('__ge__') (6 chars) == len('__eq__') (6 chars) == len('__ne__') (6 chars): the first component of 'ModuleSpec' ties with all six comparison dunder names in this spec; confirmed Python 3.14.3 macOS"]
    - [dec_spec_ne,  decimal.__spec__.__class__.__name__.__eq__,  ["dict"],       false, "decimal.__spec__.__class__.__name__.__eq__('dict') == False — decimal.__spec__ is NOT a dict; decimal.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars), not 'dict' (4 chars); 'dict' (4 chars) < 'ModuleSpec' (10 chars) by 6: the dict type name is 6 characters shorter than the ModuleSpec class name; the decimal module's __spec__ is always a ModuleSpec instance, never a raw dict; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ contains __lt__, __le__, __eq__
# All three have 6-character dunder names: '__'(2)+2-char-core+'__'(2)=6
# Six-way tie at 6 for all comparison dunders
# Pairs: lt/ge (less-than/greater-or-equal), le/gt, eq/ne
# ---------------------------------------------------------------------------

table decimal_extra168.Decimal_dict_lt_le_eq:
  description: "decimal.Decimal.__dict__.__contains__('__lt__')==True (len=6); __contains__('__le__')==True (len=6); __contains__('__eq__')==True (len=6); three of the six-way tie at 6: __lt__(6)=__le__(6)=__eq__(6); all follow '__'(2)+2-char-core+'__'(2)=6; cores: lt(2), le(2), eq(2)"
  kind: python_call_eq
  category: identity
  id_prefix: declt168

  columns: [id, function, args, expected, description]
  rows:
    - [has_lt, "decimal.Decimal.__dict__.__contains__", ["__lt__"], true, "decimal.Decimal.__dict__.__contains__('__lt__') == True — '__lt__' is a key in Decimal.__dict__, meaning __lt__() is defined directly on Decimal; '__lt__' has 6 characters: '__'(2)+'lt'(2)+'__'(2)=6; __lt__ (6 chars) is part of the six-way tie at 6: __lt__(6)=__le__(6)=__gt__(6)=__ge__(6)=__eq__(6)=__ne__(6); Decimal.__lt__() is invoked by the < operator: Decimal('1.5') < Decimal('2.5'); the 2-char core 'lt' stands for 'less than' — all six comparison dunder cores are 2-character ASCII abbreviations; __lt__ (6 chars) < __abs__ (7 chars from decimal_extra167) by 1: the comparison dunders are 1 character shorter than the unary sign/magnitude dunders; confirmed Python 3.14.3 macOS"]
    - [has_le, "decimal.Decimal.__dict__.__contains__", ["__le__"], true, "decimal.Decimal.__dict__.__contains__('__le__') == True — '__le__' is a key in Decimal.__dict__, meaning __le__() is defined directly on Decimal; '__le__' has 6 characters: '__'(2)+'le'(2)+'__'(2)=6; __le__ (6 chars) == __lt__ (6 chars) == __gt__ (6 chars) == __ge__ (6 chars) == __eq__ (6 chars) == __ne__ (6 chars): the six-way tie at 6 for all comparison dunder methods on Decimal; Decimal.__le__() is invoked by the <= operator: Decimal('1.5') <= Decimal('1.5'); 'le' (2 chars) is the logical complement of 'gt' (2 chars): le('<=') and gt('>') are strict logical complements — a == b iff not(a > b) and not(a < b); confirmed Python 3.14.3 macOS"]
    - [has_eq, "decimal.Decimal.__dict__.__contains__", ["__eq__"], true, "decimal.Decimal.__dict__.__contains__('__eq__') == True — '__eq__' is a key in Decimal.__dict__, meaning __eq__() is defined directly on Decimal; '__eq__' has 6 characters: '__'(2)+'eq'(2)+'__'(2)=6; __eq__ (6 chars) is part of the six-way tie at 6 alongside __lt__, __le__, __gt__, __ge__, __ne__; Decimal.__eq__() is invoked by the == operator: Decimal('1.5') == Decimal('1.5'); 'eq' (2 chars) is the core of the equality operator — __eq__ is foundational to Python's object identity and equality system; Decimal provides a custom __eq__ that handles NaN: NaN != NaN even when both are Decimal; confirmed Python 3.14.3 macOS"]
    - [lt6_tie, "decimal.Decimal.__dict__.__contains__", ["__lt__"], true, "decimal.Decimal.__dict__.__contains__('__lt__') == True — confirming the six-way tie at 6: __lt__(6)=__le__(6)=__gt__(6)=__ge__(6)=__eq__(6)=__ne__(6); all six comparison dunders follow the identical pattern '__' + 2-char-core + '__' = 6; the 6 cores are: lt, le, gt, ge, eq, ne — all 2-char abbreviations of comparison operators; the 2-char cores come in logical complement pairs: lt/ge, le/gt, eq/ne; the six-way tie at 6 is the largest uniform-length tie in the comparison dunder family; __lt__ (6 chars) < __abs__ (7 chars from decimal_extra167) by 1: comparison dunders (2-char cores) are 1 shorter than sign/magnitude dunders (3-char cores); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__ contains __gt__, __ge__, __ne__
# All three complete the six-way tie at 6
# __gt__ is the logical complement of __le__
# __ge__ is the logical complement of __lt__
# __ne__ is the logical complement of __eq__
# ---------------------------------------------------------------------------

table decimal_extra168.Decimal_dict_gt_ge_ne:
  description: "decimal.Decimal.__dict__.__contains__('__gt__')==True (len=6); __contains__('__ge__')==True (len=6); __contains__('__ne__')==True (len=6); completing the six-way tie at 6: __gt__(6)=__ge__(6)=__ne__(6); logical complements: gt↔le, ge↔lt, ne↔eq; all 2-char-core dunders"
  kind: python_call_eq
  category: identity
  id_prefix: decgt168

  columns: [id, function, args, expected, description]
  rows:
    - [has_gt, "decimal.Decimal.__dict__.__contains__", ["__gt__"], true, "decimal.Decimal.__dict__.__contains__('__gt__') == True — '__gt__' is a key in Decimal.__dict__, meaning __gt__() is defined directly on Decimal; '__gt__' has 6 characters: '__'(2)+'gt'(2)+'__'(2)=6; __gt__ (6 chars) is part of the six-way tie at 6; Decimal.__gt__() is invoked by the > operator: Decimal('2.5') > Decimal('1.5'); 'gt' (2 chars) is the logical complement of 'le' (2 chars): a > b iff not(a <= b); all comparison cores (lt, le, gt, ge, eq, ne) are 2-character abbreviations — a uniform 2-char pattern across all six; __gt__ (6 chars) == len('rename') (6 chars) from pathlib_extra175 and len('groups') (6 chars) from re_extra173 — cross-module ties at 6; confirmed Python 3.14.3 macOS"]
    - [has_ge, "decimal.Decimal.__dict__.__contains__", ["__ge__"], true, "decimal.Decimal.__dict__.__contains__('__ge__') == True — '__ge__' is a key in Decimal.__dict__, meaning __ge__() is defined directly on Decimal; '__ge__' has 6 characters: '__'(2)+'ge'(2)+'__'(2)=6; __ge__ (6 chars) == all five other comparison dunders: six-way tie at 6; Decimal.__ge__() is invoked by the >= operator: Decimal('1.5') >= Decimal('1.5'); 'ge' (2 chars) is the logical complement of 'lt' (2 chars): a >= b iff not(a < b); the three complement pairs among the six comparison dunders: (lt, ge), (le, gt), (eq, ne) — each pair's cores differ by swapping 'l'/'g' prefixes or entirely ('eq'/'ne'); confirmed Python 3.14.3 macOS"]
    - [has_ne, "decimal.Decimal.__dict__.__contains__", ["__ne__"], true, "decimal.Decimal.__dict__.__contains__('__ne__') == True — '__ne__' is a key in Decimal.__dict__, meaning __ne__() is defined directly on Decimal; '__ne__' has 6 characters: '__'(2)+'ne'(2)+'__'(2)=6; __ne__ (6 chars) completes the six-way tie at 6 alongside __lt__, __le__, __gt__, __ge__, __eq__; Decimal.__ne__() is invoked by the != operator; 'ne' (2 chars) is the logical complement of 'eq' (2 chars): a != b iff not(a == b); Decimal defines __ne__ directly (unlike many Python types that inherit it from object), giving Decimal complete control over all six comparison behaviors; confirmed Python 3.14.3 macOS"]
    - [gt6_tie, "decimal.Decimal.__dict__.__contains__", ["__gt__"], true, "decimal.Decimal.__dict__.__contains__('__gt__') == True — confirming the six-way tie at 6 is complete: __lt__(6)=__le__(6)=__gt__(6)=__ge__(6)=__eq__(6)=__ne__(6); the six comparison dunders with 2-char cores contrast with the five arithmetic dunders with 3-char cores (from decimal_extra166: __add__, __mul__, __sub__, __mod__, __pow__ all at 7) and the seven unary dunders (from decimal_extra167: __abs__, __neg__, __pos__ at 7, __ceil__ at 8, __round__, __floor__, __trunc__ at 9); the 2-char core comparison dunders (6 chars total) are shorter than the 3-char core arithmetic dunders (7 chars total) by exactly 1 character; confirmed Python 3.14.3 macOS"]
    - [ne_ne_td,  "decimal.Decimal.__dict__.__contains__", ["__ne__"], true, "decimal.Decimal.__dict__.__contains__('__ne__') == True — confirming __ne__ (6 chars) is defined directly on Decimal (not inherited from object); this is noteworthy: many Python types do NOT define __ne__ directly — they inherit it from object, which delegates to __eq__; Decimal's direct definition of __ne__ ensures that Decimal('NaN') != Decimal('NaN') returns True (unlike == which returns False for NaN comparisons), consistent with IEEE 754 arithmetic; the presence of __ne__ in Decimal.__dict__ makes Decimal's inequality behavior explicit and customizable; confirmed Python 3.14.3 macOS"]

