invariant decimal_extra168.decimal_name_is_decimal:
  description: "decimal.__name__ == 'decimal' — the public name of the decimal module; 'decimal' has 7 characters; decimal (7 chars) == pathlib (7 chars): the two longest module names in this spec series share the 7-character length; decimal.__name__ (7 chars) == len('Decimal') (7 chars): the module name and the primary class name are identical in string and length (eponymous class); decimal (7 chars) == len('Pattern') (7 chars) == len('Context') (7 chars): cross-module tie at 7; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.__name__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra168.decimal_package_is_empty:
  description: "decimal.__package__ == '' — decimal is a top-level module with an empty string package; decimal.__package__ (len=0: empty) == io.__package__ (len=0: empty): both decimal and io have empty __package__ attributes; decimal.__package__ (0: '') != re.__package__ (2: 're') and != pathlib.__package__ (7: 'pathlib'): re and pathlib are packages while decimal is a top-level module; confirmed Python 3.14.3 macOS"
  category: identity
