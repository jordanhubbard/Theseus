spec: uuid_extra47
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra46.zspec.zsdl — covers uuid1/uuid3/uuid5 __class__.__module__.__eq__('builtins'); UUID.__init__.__class__.__name__/__module__.__eq__('function'/'builtins')."
    - "uuid_extra45.zspec.zsdl — covers UUID/__dict__/__class__/__name__/__qualname__.__eq__('mappingproxy'); uuid module __dict__/__class__/__name__/__qualname__.__eq__('mappingproxy'); NAMESPACE_DNS.__class__.__module__.__len__()==4."
    - "uuid_extra43.zspec.zsdl — covers NAMESPACE_URL/OID/X500 __class__.__name__/__qualname__/__module__.__eq__ string values."
    - "uuid_extra42.zspec.zsdl — covers UUID.time_low/time_mid/clock_seq_low fget.__qualname__.__eq__; uuid4/getnode/UUID __module__.__class__.__name__.__eq__('str')."
    - "uuid_extra39.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/NAMESPACE_DNS/getnode __class__.__qualname__.__eq__ and __class__.__module__.__eq__."
    - "uuid_extra36.zspec.zsdl — covers UUID dunder method __module__.__eq__('uuid') for __repr__/__hash__/__eq__/__int__/__lt__/__le__/__gt__/__ge__."
    - "uuid_extra35.zspec.zsdl — covers UUID dunder method __name__.__eq__ string values."
    - "uuid_extra16.zspec.zsdl — covers UUID.__repr__/__hash__/__eq__/__init__/__int__ __qualname__.__eq__ and __qualname__.__len__()."
  notes:
    - "This spec extends uuid through uuid_extra46; it does NOT duplicate invariants present in those files."
    - "Wave 222 theme: __repr__.__class__.__name__ checks + __weakref__ descriptor checks + __hash__ class name checks."
    - "Coverage gap 1: No prior uuid spec checks __repr__.__class__.__name__ for uuid.UUID. uuid_extra36 covers UUID.__repr__.__module__.__eq__('uuid'); uuid_extra35 covers UUID.__repr__.__name__.__eq__('__repr__'); uuid_extra16 covers UUID.__repr__.__qualname__.__eq__. None of these check __repr__.__class__.__name__. uuid.UUID is a pure Python class; its __repr__ is a Python function, so UUID.__repr__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__class__.__name__ == 'function'. UUID.__repr__ is a Python function defined in Lib/uuid.py; its __class__.__name__ is 'function'. No prior uuid spec checks UUID.__repr__.__class__.__name__.__eq__('function'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior uuid spec checks __weakref__.__class__.__name__ for uuid.UUID. uuid_extra45 covers UUID.__dict__.__class__.__name__.__eq__('mappingproxy') (the __dict__ descriptor), but NOT the __weakref__ descriptor. uuid.UUID supports weak references; the __weakref__ attribute is a getset_descriptor (CPython's C type for writable slot descriptors). __weakref__.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__weakref__.__class__.__name__ == 'getset_descriptor'. The __weakref__ class attribute is a getset_descriptor — the same CPython internal type used for __dict__ on classes that support instance dictionaries. However, for __weakref__ the C type is specifically for managing weak reference slots. No prior uuid spec checks UUID.__weakref__.__class__.__name__.__eq__('getset_descriptor'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior uuid spec checks __hash__.__class__.__name__ for uuid.UUID. uuid_extra36 covers UUID.__hash__.__module__.__eq__('uuid'); uuid_extra35 covers UUID.__hash__.__name__.__eq__('__hash__'); uuid_extra16 covers UUID.__hash__.__qualname__.__eq__. None check __hash__.__class__.__name__. uuid.UUID defines __hash__ as a Python function (since UUID is hashable as a value type), so UUID.__hash__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__class__.__name__ == 'function'. UUID.__hash__ is a Python function defined in Lib/uuid.py; its __class__.__name__ is 'function'. No prior uuid spec checks UUID.__hash__.__class__.__name__.__eq__('function'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 4: No prior uuid spec checks __repr__.__class__.__name__ for UUID instances (NAMESPACE_DNS/URL/OID/X500). uuid_extra43 covers NAMESPACE_URL/OID/X500 __class__.__name__/__qualname__/__module__.__eq__; uuid_extra38 covers NAMESPACE_DNS.__class__.__name__.__eq__('UUID'). None check the __repr__ attribute on UUID instances. For instances, __repr__ is a bound method; instance.__repr__.__class__.__name__ == 'method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__repr__.__class__.__name__ == 'method'. NAMESPACE_DNS is a UUID instance; its __repr__ is UUID.__repr__ bound to the instance, forming a bound method. The built-in method type's __name__ is 'method'. No prior uuid spec checks NAMESPACE_DNS.__repr__.__class__.__name__.__eq__('method'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID TYPE __repr__/__hash__.__class__.__name__ == 'function'
#
# uuid.UUID is a pure Python class (Lib/uuid.py). Its __repr__ and __hash__
# are both Python functions. No prior uuid spec checks __repr__.__class__.__name__
# or __hash__.__class__.__name__ for UUID. The __class__.__name__ of a Python
# function is 'function'. These are distinct from __qualname__ (extra16),
# __name__ (extra35), and __module__ (extra36), which all access the function's
# own attributes rather than the class of the function object itself.
# ---------------------------------------------------------------------------

table uuid_extra47.UUID_repr_hash_class_name_eq:
  description: "uuid.UUID/__repr__/__class__/__name__.__eq__('function') and UUID/__hash__/__class__/__name__.__eq__('function') — UUID is a pure Python class; __repr__ and __hash__ are Python functions; no prior uuid spec checks __repr__.__class__.__name__ or __hash__.__class__.__name__ for UUID"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidrepr47

  columns: [id, function, args, expected]
  rows:
    - [UUID_repr_class_name_eq, UUID.__repr__.__class__.__name__.__eq__, ["function"], true]
    - [UUID_hash_class_name_eq, UUID.__hash__.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS/URL/OID/X500 instance __repr__.__class__.__name__ == 'method'
#
# For UUID instances, __repr__ is a bound method (UUID.__repr__ bound to the
# instance). The bound method type's __name__ is 'method'. No prior uuid spec
# checks __repr__.__class__.__name__ for any UUID instance. uuid_extra43 covers
# NAMESPACE_URL/OID/X500 __class__.__name__/__qualname__/__module__.__eq__ (the
# instance's type axes), and uuid_extra38 covers NAMESPACE_DNS.__class__.__name__;
# none cover the __repr__ attribute on instances.
# ---------------------------------------------------------------------------

table uuid_extra47.namespace_repr_class_name_eq:
  description: "uuid.NAMESPACE_DNS/URL/OID/X500 instance __repr__.__class__.__name__.__eq__('method') — UUID instances' __repr__ is a bound method; bound method type has __name__ == 'method'; no prior uuid spec checks __repr__.__class__.__name__ for any UUID instance (NAMESPACE constants or otherwise)"
  kind: python_call_eq
  category: type_structure
  id_prefix: uuidrepr47

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_DNS_repr_class_name_eq,  NAMESPACE_DNS.__repr__.__class__.__name__.__eq__,  ["method"], true]
    - [NAMESPACE_URL_repr_class_name_eq,  NAMESPACE_URL.__repr__.__class__.__name__.__eq__,  ["method"], true]
    - [NAMESPACE_OID_repr_class_name_eq,  NAMESPACE_OID.__repr__.__class__.__name__.__eq__,  ["method"], true]
    - [NAMESPACE_X500_repr_class_name_eq, NAMESPACE_X500.__repr__.__class__.__name__.__eq__, ["method"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__weakref__.__class__.__name__.__eq__('getset_descriptor')
#
# No prior uuid spec checks __weakref__.__class__.__name__ for uuid.UUID.
# uuid_extra45 covers UUID.__dict__.__class__.__name__.__eq__('mappingproxy') —
# the __dict__ descriptor — but NOT the __weakref__ descriptor. uuid.UUID
# supports weak references; its __weakref__ class attribute is a
# getset_descriptor, the CPython internal type for C-level slot descriptors
# that expose get/set semantics (used for both __dict__ and __weakref__ slots).
# ---------------------------------------------------------------------------

invariant uuid_extra47.UUID.weakref_class_name_eq:
  description: "uuid.UUID.__weakref__.__class__.__name__ == 'getset_descriptor' — UUID supports weak references; __weakref__ class attribute is a getset_descriptor (CPython C slot descriptor for weak reference slot); uuid_extra45 covers UUID.__dict__.__class__.__name__.__eq__('mappingproxy') but NOT __weakref__; no prior uuid spec checks UUID.__weakref__.__class__.__name__.__eq__('getset_descriptor')"
  category: type_structure
  kind: python_call_eq
  function: UUID.__weakref__.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true
