spec: concurrent_futures_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython concurrent.futures source"
    - "Python docs: concurrent.futures"
    - "Python docs: concurrent.futures.Future"
  not_derived_from:
    - "any third-party futures library"
  notes:
    - "Covers as_completed, wait qualnames and module identity"
    - "Covers FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED constants"
    - "Covers concurrent.futures.Future method qualnames"
  created_at: "2026-04-12"

table concurrent_futures_extra826.function_qualnames:
  description: "concurrent.futures top-level function __qualname__ and __module__ identity checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: cf826fq
  columns: [id, function, args, expected]
  rows:
    - [cf826fq001, concurrent.futures.as_completed.__qualname__.__eq__, ["as_completed"], true]
    - [cf826fq002, concurrent.futures.as_completed.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf826fq003, concurrent.futures.wait.__qualname__.__eq__, ["wait"], true]
    - [cf826fq004, concurrent.futures.wait.__module__.__eq__, ["concurrent.futures._base"], true]

table concurrent_futures_extra826.constants:
  description: "concurrent.futures sentinel constant type checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: cf826cn
  columns: [id, function, args, expected]
  rows:
    - [cf826cn001, concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__, ["str"], true]
    - [cf826cn002, concurrent.futures.FIRST_EXCEPTION.__class__.__name__.__eq__, ["str"], true]
    - [cf826cn003, concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__, ["str"], true]

table concurrent_futures_extra826.future_qualnames:
  description: "concurrent.futures.Future method __qualname__ identity checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: cf826fu
  columns: [id, function, args, expected]
  rows:
    - [cf826fu001, concurrent.futures.Future.set_result.__qualname__.__eq__, ["Future.set_result"], true]
    - [cf826fu002, concurrent.futures.Future.set_exception.__qualname__.__eq__, ["Future.set_exception"], true]
    - [cf826fu003, concurrent.futures.Future.cancel.__qualname__.__eq__, ["Future.cancel"], true]
    - [cf826fu004, concurrent.futures.Future.cancelled.__qualname__.__eq__, ["Future.cancelled"], true]
    - [cf826fu005, concurrent.futures.Future.running.__qualname__.__eq__, ["Future.running"], true]
