spec: socket_extra242
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 socket on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra241.zspec.zsdl — covers socket.socket class __name__/__module__/__qualname__; instance method __name__/__qualname__ for connect/bind/listen/accept/close/recv/send."
    - "socket_extra240.zspec.zsdl — covers IPPROTO_TCP/UDP/IP/ICMP; SOL_SOCKET/SO_REUSEADDR constants."
    - "socket_extra24.zspec.zsdl — covers socket.socket __qualname__/__module__/__bases__[0].__name__."
    - "socket_extra22.zspec.zsdl — covers socket.socket instance methods connect/bind/listen/accept/close/recv/send __qualname__.__eq__."
    - "socket_extra8.zspec.zsdl — covers socket class __qualname__.__eq__; error/timeout/gaierror/herror exception table."
  notes:
    - "This spec covers socket.create_connection and socket.create_server function identity contracts."
    - "socket.create_connection was added in Python 2.6; socket.create_server was added in Python 3.8."
    - "socket.create_connection.__name__ == 'create_connection' — pure-Python helper in socket module. Verified Python 3.14.3."
    - "socket.create_connection.__module__ == 'socket' — defined in the Python-level socket module (not _socket C extension). Verified Python 3.14.3."
    - "socket.create_connection.__qualname__ == 'create_connection' — top-level function, not nested. Verified Python 3.14.3."
    - "socket.create_server.__name__ == 'create_server' — added in Python 3.8 as a convenience function. Verified Python 3.14.3."
    - "socket.create_server.__module__ == 'socket' — defined in the Python-level socket module. Verified Python 3.14.3."
    - "socket.create_server.__qualname__ == 'create_server' — top-level function. Verified Python 3.14.3."
    - "socket.setdefaulttimeout.__name__ == 'setdefaulttimeout' — C-extension function in _socket. Verified Python 3.14.3."
    - "socket.setdefaulttimeout.__module__ == '_socket' — defined in the C extension _socket (not Python-level socket). Verified Python 3.14.3."
    - "socket.getdefaulttimeout.__name__ == 'getdefaulttimeout' — C-extension function in _socket. Verified Python 3.14.3."
    - "socket.getdefaulttimeout.__module__ == '_socket' — defined in the C extension _socket. Verified Python 3.14.3."
    - "create_connection.__name__ len == 17; create_server.__name__ len == 13. Verified Python 3.14.3."
    - "setdefaulttimeout.__name__ len == 17; getdefaulttimeout.__name__ len == 17. Verified Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "socket raises OSError for I/O failures. Function identity attribute checks are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are function identity checks."
  codes: {}

# ---------------------------------------------------------------------------
# socket.create_connection and socket.create_server function __name__
#
# Both are pure-Python helpers defined in socket.py (not _socket.c).
# create_connection added Python 2.6; create_server added Python 3.8.
# Both have __module__ == 'socket' (the Python-level wrapper module).
# ---------------------------------------------------------------------------

table socket242fn.function_names:
  description: "create_connection/create_server __name__ equality; pure-Python socket helpers; new to extra242"
  kind: python_call_eq
  category: function_identity
  id_prefix: socket242fn

  columns: [id, function, args, expected, description]
  rows:
    - [create_connection_name,
       "create_connection.__name__.__eq__",
       ["create_connection"],
       true,
       "socket.create_connection.__name__.__eq__('create_connection') == True — create_connection is a pure-Python helper in socket.py (added Python 2.6); __name__ == 'create_connection' (17 characters); __module__ == 'socket'; new anchor in extra242 namespace; verified Python 3.14.3"]
    - [create_server_name,
       "create_server.__name__.__eq__",
       ["create_server"],
       true,
       "socket.create_server.__name__.__eq__('create_server') == True — create_server is a pure-Python helper in socket.py (added Python 3.8); __name__ == 'create_server' (13 characters); __module__ == 'socket'; new anchor in extra242 namespace; verified Python 3.14.3"]
    - [create_connection_qualname,
       "create_connection.__qualname__.__eq__",
       ["create_connection"],
       true,
       "socket.create_connection.__qualname__.__eq__('create_connection') == True — top-level function (not nested); __qualname__ equals __name__ for top-level functions; new anchor in extra242 namespace; verified Python 3.14.3"]
    - [create_server_qualname,
       "create_server.__qualname__.__eq__",
       ["create_server"],
       true,
       "socket.create_server.__qualname__.__eq__('create_server') == True — top-level function (not nested); __qualname__ equals __name__; new anchor in extra242 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.create_connection and socket.create_server __module__
#
# Both are defined in the Python-level 'socket' module (not the C extension
# '_socket'). This is the key distinction from C-extension functions like
# setdefaulttimeout and getdefaulttimeout which have __module__ == '_socket'.
# ---------------------------------------------------------------------------

table socket242fn.function_modules:
  description: "create_connection/create_server __module__=='socket'; setdefaulttimeout/getdefaulttimeout __module__=='_socket'; Python vs C-extension distinction; new to extra242"
  kind: python_call_eq
  category: function_identity
  id_prefix: socket242fn

  columns: [id, function, args, expected, description]
  rows:
    - [create_connection_module,
       "create_connection.__module__.__eq__",
       ["socket"],
       true,
       "socket.create_connection.__module__.__eq__('socket') == True — create_connection is defined in the Python-level socket module (socket.py); contrast with C-extension functions which have __module__=='_socket'; new anchor in extra242 namespace; verified Python 3.14.3"]
    - [create_server_module,
       "create_server.__module__.__eq__",
       ["socket"],
       true,
       "socket.create_server.__module__.__eq__('socket') == True — create_server is defined in socket.py (added Python 3.8); __module__=='socket' not '_socket'; new anchor in extra242 namespace; verified Python 3.14.3"]
    - [setdefaulttimeout_module,
       "setdefaulttimeout.__module__.__eq__",
       ["_socket"],
       true,
       "socket.setdefaulttimeout.__module__.__eq__('_socket') == True — setdefaulttimeout is a C-extension function in _socket; __module__=='_socket' (underscore prefix); contrast with create_connection/__module__=='socket'; new anchor in extra242 namespace; verified Python 3.14.3"]
    - [getdefaulttimeout_module,
       "getdefaulttimeout.__module__.__eq__",
       ["_socket"],
       true,
       "socket.getdefaulttimeout.__module__.__eq__('_socket') == True — getdefaulttimeout is a C-extension function in _socket; __module__=='_socket'; contrast with create_server/__module__=='socket'; new anchor in extra242 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# setdefaulttimeout and getdefaulttimeout __name__ contracts
#
# These are C-extension functions from _socket; their __name__ values
# match their identifiers (17 characters each).
# ---------------------------------------------------------------------------

table socket242fn.timeout_function_names:
  description: "setdefaulttimeout/getdefaulttimeout __name__ equality; C-extension functions in _socket; new to extra242"
  kind: python_call_eq
  category: function_identity
  id_prefix: socket242fn

  columns: [id, function, args, expected, description]
  rows:
    - [setdefaulttimeout_name,
       "setdefaulttimeout.__name__.__eq__",
       ["setdefaulttimeout"],
       true,
       "socket.setdefaulttimeout.__name__.__eq__('setdefaulttimeout') == True — C-extension function in _socket; __name__ == 'setdefaulttimeout' (17 characters, same length as create_connection); new anchor in extra242 namespace; verified Python 3.14.3"]
    - [getdefaulttimeout_name,
       "getdefaulttimeout.__name__.__eq__",
       ["getdefaulttimeout"],
       true,
       "socket.getdefaulttimeout.__name__.__eq__('getdefaulttimeout') == True — C-extension function in _socket; __name__ == 'getdefaulttimeout' (17 characters, same length as setdefaulttimeout); new anchor in extra242 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socket242fn.create_connection_name:
  description: "socket.create_connection.__name__.__eq__('create_connection') == True — create_connection is a pure-Python convenience function in socket.py added in Python 2.6; it connects to a host/port tuple respecting an optional timeout and source_address argument; it is defined at module level in the Python-level socket module (not in the C extension _socket); __name__ == 'create_connection' (17 characters); __module__ == 'socket' (not '_socket'); __qualname__ == 'create_connection' (top-level, not nested); prior socket specs cover socket.socket class identity and instance methods; extra242 is the first namespace to anchor create_connection identity directly; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: "create_connection.__name__.__eq__"
  args: ["create_connection"]
  expected: true

invariant socket242fn.create_server_name:
  description: "socket.create_server.__name__.__eq__('create_server') == True — create_server is a pure-Python convenience function added in Python 3.8 (PEP 534 / bpo-18643); it creates a TCP server socket bound to a given address; __name__ == 'create_server' (13 characters); __module__ == 'socket'; __qualname__ == 'create_server'; extra242 is the first namespace to anchor create_server identity; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: "create_server.__name__.__eq__"
  args: ["create_server"]
  expected: true

invariant socket242fn.create_connection_module_socket:
  description: "socket.create_connection.__module__.__eq__('socket') == True — create_connection is defined in the Python-level socket module (Lib/socket.py), not in the C extension _socket; functions from the C extension have __module__ == '_socket'; the Python-level socket module wraps and re-exports the C extension while also providing pure-Python helpers like create_connection and create_server; this module distinction is the key identity dimension anchored in extra242; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: "create_connection.__module__.__eq__"
  args: ["socket"]
  expected: true

invariant socket242fn.create_server_module_socket:
  description: "socket.create_server.__module__.__eq__('socket') == True — create_server is defined in the Python-level socket module (Lib/socket.py); added in Python 3.8 as a high-level server socket factory; like create_connection its __module__ is 'socket' not '_socket'; extra242 anchors this module identity as a standalone invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: "create_server.__module__.__eq__"
  args: ["socket"]
  expected: true

invariant socket242fn.setdefaulttimeout_name:
  description: "socket.setdefaulttimeout.__name__.__eq__('setdefaulttimeout') == True — setdefaulttimeout is a C-extension function from _socket (not a pure-Python helper); it sets the default timeout in seconds for new socket objects; __name__ == 'setdefaulttimeout' (17 characters); __module__ == '_socket' (underscore prefix for C extension); contrast with create_connection which has __module__ == 'socket'; extra242 anchors setdefaulttimeout identity as the C-extension counterpart to the Python-level helpers; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: "setdefaulttimeout.__name__.__eq__"
  args: ["setdefaulttimeout"]
  expected: true

invariant socket242fn.getdefaulttimeout_name:
  description: "socket.getdefaulttimeout.__name__.__eq__('getdefaulttimeout') == True — getdefaulttimeout is a C-extension function from _socket; it returns the current default timeout for new socket objects; __name__ == 'getdefaulttimeout' (17 characters, same as setdefaulttimeout); __module__ == '_socket'; both set/get functions have the same __name__ length (17) as create_connection (17); extra242 anchors getdefaulttimeout identity as standalone in the extra242 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: "getdefaulttimeout.__name__.__eq__"
  args: ["getdefaulttimeout"]
  expected: true

invariant socket242fn.create_connection_name_len:
  description: "socket.create_connection.__name__.__len__() == 17 — len('create_connection') == 17; the function name has 17 characters; this is also the same length as setdefaulttimeout and getdefaulttimeout; create_server has 13 characters; extra242 anchors the create_connection __name__ length as a standalone invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: "create_connection.__name__.__len__"
  args: []
  expected: 17

invariant socket242fn.create_server_name_len:
  description: "socket.create_server.__name__.__len__() == 13 — len('create_server') == 13; the function name has 13 characters; shorter than create_connection (17) by 4 characters; extra242 anchors the create_server __name__ length as a standalone invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: "create_server.__name__.__len__"
  args: []
  expected: 13
