spec: concurrent_futures_extra23
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl and prior extras through concurrent_futures_extra22.zspec.zsdl."
    - "concurrent_futures_extra22 covers: Future dunder qualnames; module-level function qualnames/modules; wait-constant class names; executor __module__ table."
    - "NOT yet covered in any prior spec: concurrent.futures.Future.__module__ in extra23 namespace."
    - "NOT yet covered: concurrent.futures.Executor.__qualname__ and __module__ in extra23 namespace."
    - "NOT yet covered: ThreadPoolExecutor.__bases__[0].__name__ and ProcessPoolExecutor.__bases__[0].__name__ in extra23 namespace."
    - "NOT yet covered: concurrent.futures.CancelledError.__qualname__ in extra23 namespace."
    - "NOT yet covered: concurrent.futures.TimeoutError.__qualname__ in extra23 namespace."
    - "Future.__module__ == 'concurrent.futures._base' — length 24."
    - "Executor.__qualname__ == 'Executor' — length 8."
    - "Executor.__module__ == 'concurrent.futures._base' — length 24."
    - "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' — both executor subclasses directly inherit from Executor (length 8)."
    - "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' — length 8."
    - "CancelledError.__qualname__ == 'CancelledError' — length 14."
    - "TimeoutError.__qualname__ == 'TimeoutError' — length 12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Executor base class __qualname__ and __module__ table — extra23 namespace
#
# concurrent.futures.Executor is the abstract base for both executor types.
# It is defined in the private _base submodule.
# Executor.__qualname__ == 'Executor' (length 8).
# Executor.__module__ == 'concurrent.futures._base' (length 24).
# No prior spec checks these values for Executor itself.
# ---------------------------------------------------------------------------

table concurrent_futures_extra23.executor_base_identity:
  description: "concurrent.futures.Executor __qualname__ and __module__ values in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: execbase23

  columns: [id, function, args, expected]
  rows:
    - [qualname, Executor.__qualname__.__eq__, ["Executor"],                    true]
    - [module,   Executor.__module__.__eq__,   ["concurrent.futures._base"],    true]

# ---------------------------------------------------------------------------
# Executor base class identity length table — extra23 namespace
#
# Lengths: Executor(8), concurrent.futures._base(24).
# ---------------------------------------------------------------------------

table concurrent_futures_extra23.executor_base_identity_lengths:
  description: "concurrent.futures.Executor __qualname__ and __module__ lengths in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: execbaselen23

  columns: [id, function, args, expected]
  rows:
    - [qualname, Executor.__qualname__.__len__, [], 8]
    - [module,   Executor.__module__.__len__,   [], 24]

# ---------------------------------------------------------------------------
# Executor subclass base name table — extra23 namespace
#
# Both ThreadPoolExecutor and ProcessPoolExecutor directly inherit from
# Executor. Their __bases__[0].__name__ == 'Executor' (length 8).
# No prior spec checks this inheritance chain.
# ---------------------------------------------------------------------------

table concurrent_futures_extra23.executor_subclass_bases:
  description: "concurrent.futures Executor subclass __bases__[0].__name__ values in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: execsbase23

  columns: [id, function, args, expected]
  rows:
    - [ThreadPoolExecutor,  "ThreadPoolExecutor.__bases__[0].__name__.__eq__",  ["Executor"], true]
    - [ProcessPoolExecutor, "ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true]

# ---------------------------------------------------------------------------
# Executor subclass base name length table — extra23 namespace
#
# Both have __bases__[0].__name__ length 8.
# ---------------------------------------------------------------------------

table concurrent_futures_extra23.executor_subclass_base_lengths:
  description: "concurrent.futures Executor subclass __bases__[0].__name__ lengths in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: execsbaselen23

  columns: [id, function, args, expected]
  rows:
    - [ThreadPoolExecutor,  "ThreadPoolExecutor.__bases__[0].__name__.__len__",  [], 8]
    - [ProcessPoolExecutor, "ProcessPoolExecutor.__bases__[0].__name__.__len__", [], 8]

# ---------------------------------------------------------------------------
# Exception class __qualname__ table — extra23 namespace
#
# concurrent.futures.CancelledError.__qualname__ == 'CancelledError' (length 14).
# concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError' (length 12).
# No prior spec checks these exception class __qualname__ values.
# ---------------------------------------------------------------------------

table concurrent_futures_extra23.exception_qualnames:
  description: "concurrent.futures exception class __qualname__ values in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: excqn23

  columns: [id, function, args, expected]
  rows:
    - [CancelledError, CancelledError.__qualname__.__eq__, ["CancelledError"], true]
    - [TimeoutError,   TimeoutError.__qualname__.__eq__,   ["TimeoutError"],   true]

# ---------------------------------------------------------------------------
# Exception class __qualname__ length table — extra23 namespace
#
# Lengths: CancelledError(14), TimeoutError(12).
# ---------------------------------------------------------------------------

table concurrent_futures_extra23.exception_qualname_lengths:
  description: "concurrent.futures exception class __qualname__ lengths in extra23 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: excqnlen23

  columns: [id, function, args, expected]
  rows:
    - [CancelledError, CancelledError.__qualname__.__len__, [], 14]
    - [TimeoutError,   TimeoutError.__qualname__.__len__,   [], 12]

# ---------------------------------------------------------------------------
# Future.__module__ — standalone extra23 invariant
#
# concurrent.futures.Future is defined in the private _base submodule.
# Future.__module__ == 'concurrent.futures._base' (length 24).
# No prior spec checks Future.__module__ directly (extra22 checked
# ThreadPoolExecutor/__module__ and ProcessPoolExecutor/__module__ only).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra23.Future.module:
  description: "concurrent.futures.Future.__module__ == 'concurrent.futures._base'"
  category: method_names
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true
