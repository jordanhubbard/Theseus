spec: threading_extra83
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra82

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra82.zspec.zsdl."
    - "This spec covers: threading Lock/Semaphore/BoundedSemaphore/Event/Condition/Barrier/Timer identity attributes (Wave 246)."
    - "threading.Lock.__class__.__name__ == 'type' — threading.Lock is the _thread.lock C type itself; Lock.__class__ is type (the metaclass); __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "threading.Lock.__doc__.__class__.__name__ == 'str' — Lock's __doc__ is a plain Python str. Verified with Python 3.14.3."
    - "threading.Semaphore.__name__ == 'Semaphore' — pure-Python class defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading' — defined in the threading module. Verified with Python 3.14.3."
    - "threading.Semaphore.__qualname__ == 'Semaphore' (len 9). Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len 16). Verified with Python 3.14.3."
    - "threading.Event.__name__ == 'Event' (len 5). Verified with Python 3.14.3."
    - "threading.Event.__module__ == 'threading' — defined in the threading module. Verified with Python 3.14.3."
    - "threading.Condition.__name__ == 'Condition' (len 9). Verified with Python 3.14.3."
    - "threading.Barrier.__name__ == 'Barrier' (len 7). Verified with Python 3.14.3."
    - "threading.Timer.__name__ == 'Timer' (len 5). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Lock identity and Semaphore identity — extra83
#
# Wave 246 theme: threading Lock C-type identity and Semaphore pure-Python class identity.
#
# threading.Lock.__class__.__name__       == 'type'
# threading.Lock.__doc__.__class__.__name__ == 'str'
# threading.Semaphore.__name__            == 'Semaphore'
# threading.Semaphore.__module__          == 'threading'
#
# No prior threading spec checks Lock.__class__.__name__/Semaphore identity via threadingextra83. New to extra83.
# ---------------------------------------------------------------------------

table threading_extra83.lock_semaphore_identity:
  description: "Lock.__class__.__name__=='type'; Lock.__doc__.__class__.__name__=='str'; Semaphore.__name__=='Semaphore'; Semaphore.__module__=='threading'; wave 246 threading Lock/Semaphore identity; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra83

  columns: [id, function, args, expected, description]
  rows:
    - [Lock_class_name_eq_type,
       Lock.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — threading.Lock is the _thread.lock C type object; its __class__ is the metaclass 'type'; type.__name__ is 'type' (4 chars); str.__eq__('type') returns True; no prior threading spec checks Lock.__class__.__name__ via threadingextra83; new to extra83"]
    - [Lock_doc_class_name_eq_str,
       Lock.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Lock.__doc__.__class__.__name__.__eq__('str') == True — threading.Lock is the _thread.lock C type; its __doc__ is a plain Python str; str.__class__.__name__ is 'str' (3 chars); str.__eq__('str') returns True; no prior threading spec checks Lock.__doc__.__class__.__name__ via threadingextra83; new to extra83"]
    - [Semaphore_name_eq_Semaphore,
       Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is a pure-Python class defined in Lib/threading.py; its __name__ attribute is the string 'Semaphore' (9 chars); str.__eq__('Semaphore') returns True; no prior threading spec checks Semaphore.__name__ via threadingextra83; new to extra83"]
    - [Semaphore_module_eq_threading,
       Semaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is a pure-Python class defined in Lib/threading.py; its __module__ attribute records 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks Semaphore.__module__ via threadingextra83; new to extra83"]

# ---------------------------------------------------------------------------
# Semaphore and BoundedSemaphore __qualname__ lengths — extra83
#
# Wave 246 theme: threading Semaphore/BoundedSemaphore __qualname__ lengths.
#
# threading.Semaphore.__qualname__.__len__()        == 9
# threading.BoundedSemaphore.__name__.__len__()     == 16
# threading.BoundedSemaphore.__qualname__.__len__() == 16
# threading.Event.__name__.__len__()                == 5
#
# No prior threading spec checks Semaphore/BoundedSemaphore/Event name lengths via threadingextra83. New to extra83.
# ---------------------------------------------------------------------------

table threading_extra83.semaphore_boundedsemaphore_event_names:
  description: "Semaphore.__qualname__ len==9; BoundedSemaphore.__name__ len==16; BoundedSemaphore.__qualname__ len==16; Event.__name__ len==5; wave 246 threading class name lengths; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra83

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_qualname_len_eq_9,
       "Semaphore.__qualname__.__len__",
       [],
       9,
       "threading.Semaphore.__qualname__.__len__() == 9 — Semaphore is a pure-Python class in Lib/threading.py; its __qualname__ attribute is the string 'Semaphore' (9 chars); str.__len__() returns 9; no prior threading spec checks Semaphore.__qualname__.__len__() via threadingextra83; new to extra83"]
    - [BoundedSemaphore_name_len_eq_16,
       "BoundedSemaphore.__name__.__len__",
       [],
       16,
       "threading.BoundedSemaphore.__name__.__len__() == 16 — BoundedSemaphore is a pure-Python class in Lib/threading.py; its __name__ attribute is the string 'BoundedSemaphore' (16 chars); str.__len__() returns 16; no prior threading spec checks BoundedSemaphore.__name__.__len__() via threadingextra83; new to extra83"]
    - [BoundedSemaphore_qualname_len_eq_16,
       "BoundedSemaphore.__qualname__.__len__",
       [],
       16,
       "threading.BoundedSemaphore.__qualname__.__len__() == 16 — BoundedSemaphore is a pure-Python class in Lib/threading.py; its __qualname__ attribute is the string 'BoundedSemaphore' (16 chars); str.__len__() returns 16; no prior threading spec checks BoundedSemaphore.__qualname__.__len__() via threadingextra83; new to extra83"]
    - [Event_name_len_eq_5,
       "Event.__name__.__len__",
       [],
       5,
       "threading.Event.__name__.__len__() == 5 — Event is a pure-Python class in Lib/threading.py; its __name__ attribute is the string 'Event' (5 chars: 'E','v','e','n','t'); str.__len__() returns 5; no prior threading spec checks Event.__name__.__len__() via threadingextra83; new to extra83"]

# ---------------------------------------------------------------------------
# Event and Condition identity attributes — extra83
#
# Wave 246 theme: threading Event/Condition identity attributes.
#
# threading.Event.__name__     == 'Event'
# threading.Event.__module__   == 'threading'
# threading.Condition.__name__ == 'Condition'
# threading.Condition.__qualname__.__len__() == 9
#
# No prior threading spec checks Event/Condition identity via threadingextra83. New to extra83.
# ---------------------------------------------------------------------------

table threading_extra83.event_condition_identity:
  description: "Event.__name__=='Event'; Event.__module__=='threading'; Condition.__name__=='Condition'; Condition.__qualname__ len==9; wave 246 threading Event/Condition identity; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra83

  columns: [id, function, args, expected, description]
  rows:
    - [Event_name_eq_Event,
       Event.__name__.__eq__,
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — Event is a pure-Python class defined in Lib/threading.py; its __name__ attribute is the string 'Event' (5 chars); str.__eq__('Event') returns True; no prior threading spec checks Event.__name__ via threadingextra83; new to extra83"]
    - [Event_module_eq_threading,
       Event.__module__.__eq__,
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is a pure-Python class defined in Lib/threading.py; its __module__ attribute records 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks Event.__module__ via threadingextra83; new to extra83"]
    - [Condition_name_eq_Condition,
       Condition.__name__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — Condition is a pure-Python class defined in Lib/threading.py; its __name__ attribute is the string 'Condition' (9 chars); str.__eq__('Condition') returns True; no prior threading spec checks Condition.__name__ via threadingextra83; new to extra83"]
    - [Condition_qualname_len_eq_9,
       "Condition.__qualname__.__len__",
       [],
       9,
       "threading.Condition.__qualname__.__len__() == 9 — Condition is a pure-Python class in Lib/threading.py; its __qualname__ attribute is the string 'Condition' (9 chars); str.__len__() returns 9; no prior threading spec checks Condition.__qualname__.__len__() via threadingextra83; new to extra83"]

# ---------------------------------------------------------------------------
# Barrier and Timer identity attributes — extra83
#
# Wave 246 theme: threading Barrier/Timer identity attributes.
#
# threading.Barrier.__name__            == 'Barrier'
# threading.Barrier.__qualname__.__len__() == 7
# threading.Timer.__name__              == 'Timer'
# threading.Timer.__qualname__.__len__() == 5
#
# No prior threading spec checks Barrier/Timer identity via threadingextra83. New to extra83.
# ---------------------------------------------------------------------------

table threading_extra83.barrier_timer_identity:
  description: "Barrier.__name__=='Barrier'; Barrier.__qualname__ len==7; Timer.__name__=='Timer'; Timer.__qualname__ len==5; wave 246 threading Barrier/Timer identity; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingextra83

  columns: [id, function, args, expected, description]
  rows:
    - [Barrier_name_eq_Barrier,
       Barrier.__name__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier is a pure-Python class defined in Lib/threading.py; its __name__ attribute is the string 'Barrier' (7 chars); str.__eq__('Barrier') returns True; no prior threading spec checks Barrier.__name__ via threadingextra83; new to extra83"]
    - [Barrier_qualname_len_eq_7,
       "Barrier.__qualname__.__len__",
       [],
       7,
       "threading.Barrier.__qualname__.__len__() == 7 — Barrier is a pure-Python class in Lib/threading.py; its __qualname__ attribute is the string 'Barrier' (7 chars); str.__len__() returns 7; no prior threading spec checks Barrier.__qualname__.__len__() via threadingextra83; new to extra83"]
    - [Timer_name_eq_Timer,
       Timer.__name__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a pure-Python class defined in Lib/threading.py; its __name__ attribute is the string 'Timer' (5 chars); str.__eq__('Timer') returns True; no prior threading spec checks Timer.__name__ via threadingextra83; new to extra83"]
    - [Timer_qualname_len_eq_5,
       "Timer.__qualname__.__len__",
       [],
       5,
       "threading.Timer.__qualname__.__len__() == 5 — Timer is a pure-Python class in Lib/threading.py; its __qualname__ attribute is the string 'Timer' (5 chars); str.__len__() returns 5; no prior threading spec checks Timer.__qualname__.__len__() via threadingextra83; new to extra83"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra83
# ---------------------------------------------------------------------------

invariant threading_extra83.Semaphore_name:
  description: "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is a pure-Python class; __name__ is 'Semaphore'; wave 246 threading Semaphore identity; new to extra83"
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra83.Semaphore_qualname_len:
  description: "threading.Semaphore.__qualname__.__len__() == 9 — Semaphore.__qualname__ is 'Semaphore' (9 chars); wave 246 threading Semaphore identity; new to extra83"
  kind: python_call_eq
  function: "Semaphore.__qualname__.__len__"
  args: []
  expected: 9

invariant threading_extra83.Event_module:
  description: "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; wave 246 threading Event identity; new to extra83"
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra83.Barrier_qualname_len:
  description: "threading.Barrier.__qualname__.__len__() == 7 — Barrier.__qualname__ is 'Barrier' (7 chars); wave 246 threading Barrier identity; new to extra83"
  kind: python_call_eq
  function: "Barrier.__qualname__.__len__"
  args: []
  expected: 7

invariant threading_extra83.Timer_name:
  description: "threading.Timer.__name__.__eq__('Timer') == True — Timer is a pure-Python class; __name__ is 'Timer'; wave 246 threading Timer identity; new to extra83"
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true
