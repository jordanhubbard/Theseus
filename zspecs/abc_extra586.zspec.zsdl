spec: abc_extra586
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — ABCMeta and ABC module and qualname identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__ and __module__ identity for abc.ABC, abc.ABCMeta, and abc decorators"
    - "abc.ABCMeta.__subclasses__ delegates to type.__subclasses__, reflected in __qualname__"
    - "abc.abstractmethod.__doc__ is a str instance"
  created_at: "2026-04-12T00:00:00Z"

table abc_class_qualname:
  description: "__qualname__ identity for abc classes and decorators"
  columns: [id, function, args, expected]
  rows:
    - [ab586qn01, abc.ABC.__qualname__.__eq__, ["ABC"], true]
    - [ab586qn02, abc.ABCMeta.__qualname__.__eq__, ["ABCMeta"], true]
    - [ab586qn03, abc.abstractmethod.__qualname__.__eq__, ["abstractmethod"], true]
    - [ab586qn04, abc.abstractclassmethod.__qualname__.__eq__, ["abstractclassmethod"], true]
    - [ab586qn05, abc.abstractstaticmethod.__qualname__.__eq__, ["abstractstaticmethod"], true]
    - [ab586qn06, abc.abstractproperty.__qualname__.__eq__, ["abstractproperty"], true]

table abc_class_module:
  description: "__module__ identity for abc classes and decorators"
  columns: [id, function, args, expected]
  rows:
    - [ab586md01, abc.ABC.__module__.__eq__, ["abc"], true]
    - [ab586md02, abc.ABCMeta.__module__.__eq__, ["abc"], true]
    - [ab586md03, abc.abstractmethod.__module__.__eq__, ["abc"], true]

table abc_method_qualname:
  description: "__qualname__ identity for ABCMeta methods and inherited descriptors"
  columns: [id, function, args, expected]
  rows:
    - [ab586mq01, abc.ABCMeta.register.__qualname__.__eq__, ["ABCMeta.register"], true]
    - [ab586mq02, abc.ABCMeta.__subclasses__.__qualname__.__eq__, ["type.__subclasses__"], true]

table abc_doc_type:
  description: "abstractmethod.__doc__ is a str instance"
  columns: [id, function, args, expected]
  rows:
    - [ab586dt01, abc.abstractmethod.__doc__.__class__.__name__.__eq__, ["str"], true]
