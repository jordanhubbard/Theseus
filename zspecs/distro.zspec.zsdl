spec: distro
version: ">=1.5"
backend: python_module(distro)

docs: https://distro.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "distro documentation — https://distro.readthedocs.io/en/latest/"
    - "distro PyPI page — https://pypi.org/project/distro/"
    - "Test vectors verified with distro 1.9.0 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "distro source: distro/__init__.py"
    - "distro source: distro/_distro.py"
  notes:
    - "distro is a cross-platform OS distribution identification library."
    - "On macOS, id() returns 'darwin', name() returns 'Darwin', like() and codename() return ''."
    - "On Linux, id() returns e.g. 'ubuntu', name() returns e.g. 'Ubuntu', like() may return 'debian'."
    - "All public API functions (id, name, version, like, codename) always return str (including empty string)."
    - "info() always returns a dict with keys: id, version, version_parts, like, codename."
    - "os_release_info() returns a dict (empty on macOS, populated on Linux)."
    - "String-return checks use endswith('') which is True for all str values including empty string."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — __version__ is a non-empty string containing a dot
#
# Access pattern: getattr(distro, '__version__') -> str '1.9.0',
# then getattr(str_obj, '__contains__') -> bound method, call('.') -> True.
# ---------------------------------------------------------------------------

invariant distro.version.contains_dot:
  description: "__version__ is a version string containing a dot separator"
  category: version
  kind: python_call_eq
  function: __version__.__contains__
  args: ["."]
  expected: true

invariant distro.version.startswith_digit:
  description: "__version__ starts with '1' (distro 1.x)"
  category: version
  kind: python_call_eq
  function: __version__.startswith
  args: ["1"]
  expected: true

# ---------------------------------------------------------------------------
# api_callable — function name checks confirm each public API function exists
#
# Access pattern: getattr(distro, 'id') -> function object,
# then getattr(fn, '__name__') -> str 'id',
# then getattr(str, '__eq__') -> bound method, call('id') -> True.
#
# This is a safe, cross-platform check that the named function is present
# in the module and reports its own correct name.
# ---------------------------------------------------------------------------

invariant distro.api_callable.id_function:
  description: "distro.id is a callable named 'id'"
  category: api_callable
  kind: python_call_eq
  function: id.__name__.__eq__
  args: ["id"]
  expected: true

invariant distro.api_callable.name_function:
  description: "distro.name is a callable named 'name'"
  category: api_callable
  kind: python_call_eq
  function: name.__name__.__eq__
  args: ["name"]
  expected: true

invariant distro.api_callable.version_function:
  description: "distro.version is a callable named 'version'"
  category: api_callable
  kind: python_call_eq
  function: version.__name__.__eq__
  args: ["version"]
  expected: true

invariant distro.api_callable.like_function:
  description: "distro.like is a callable named 'like'"
  category: api_callable
  kind: python_call_eq
  function: like.__name__.__eq__
  args: ["like"]
  expected: true

invariant distro.api_callable.codename_function:
  description: "distro.codename is a callable named 'codename'"
  category: api_callable
  kind: python_call_eq
  function: codename.__name__.__eq__
  args: ["codename"]
  expected: true

# ---------------------------------------------------------------------------
# api_returns_str — id(), name(), version(), like(), codename() return strings
#
# Strategy: endswith('') returns True for ALL str values including empty
# string, and is not defined for non-string types. This is the most
# reliable cross-platform check that a return value is a str.
# ---------------------------------------------------------------------------

invariant distro.api_returns_str.id:
  description: "id() returns a str — endswith('') is True for all strings"
  category: api_returns_str
  kind: python_call_eq
  function: id
  args: []
  method: endswith
  method_args: [""]
  expected: true

invariant distro.api_returns_str.name:
  description: "name() returns a str — endswith('') is True for all strings"
  category: api_returns_str
  kind: python_call_eq
  function: name
  args: []
  method: endswith
  method_args: [""]
  expected: true

invariant distro.api_returns_str.version:
  description: "version() returns a str — endswith('') is True for all strings"
  category: api_returns_str
  kind: python_call_eq
  function: version
  args: []
  method: endswith
  method_args: [""]
  expected: true

invariant distro.api_returns_str.like:
  description: "like() returns a str — endswith('') is True for all strings"
  category: api_returns_str
  kind: python_call_eq
  function: like
  args: []
  method: endswith
  method_args: [""]
  expected: true

invariant distro.api_returns_str.codename:
  description: "codename() returns a str — endswith('') is True for all strings"
  category: api_returns_str
  kind: python_call_eq
  function: codename
  args: []
  method: endswith
  method_args: [""]
  expected: true

# ---------------------------------------------------------------------------
# info — info() returns a dict with required keys
#
# info() always returns a dict with keys: id, version, version_parts,
# like, codename. Using __contains__ to test for key presence.
# ---------------------------------------------------------------------------

invariant distro.info.has_id_key:
  description: "info() result contains 'id' key"
  category: info
  kind: python_call_eq
  function: info
  args: []
  method: __contains__
  method_args: ["id"]
  expected: true

invariant distro.info.has_version_key:
  description: "info() result contains 'version' key"
  category: info
  kind: python_call_eq
  function: info
  args: []
  method: __contains__
  method_args: ["version"]
  expected: true

invariant distro.info.has_like_key:
  description: "info() result contains 'like' key"
  category: info
  kind: python_call_eq
  function: info
  args: []
  method: __contains__
  method_args: ["like"]
  expected: true

