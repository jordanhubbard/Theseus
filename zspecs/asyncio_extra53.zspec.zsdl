spec: asyncio_extra53
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-runner.html — asyncio runners"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/runners.py"
  notes:
    - "This spec extends asyncio_extra52.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13 (extra29), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, BoundedSemaphore/__mro__.__len__()==5 (extra32), BoundedSemaphore/__bases__[0].__name__=='Semaphore' (extra11/extra20), Condition/__bases__[0].__name__=='object' (extra11), Condition/__module__.__eq__('asyncio.locks') (extra/extra20), BoundedSemaphore/__module__.__eq__('asyncio.locks') (extra20), run/__module__.__eq__('asyncio.runners') (extra4/extra10/extra20/extra42), run/__qualname__.__eq__('run') (extra6/extra22/extra43), class/function __qualname__ string equality tables, Task/__bases__[0].__name__=='Future', Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/TaskGroup/Runner/Task/Future __class__.__name__=='type', gather/sleep/run __class__.__name__=='function', class/function __class__.__qualname__=='type'/'function' tables, QueueEmpty/QueueFull __class__.__name__=='type', exception __module__ string equality, Queue/__doc__/__class__ tables, asyncio.__all__.__class__.__name__=='list' (extra51), Queue/Lock method qualname string equality (extra51), asyncio class __module__ string equality for Queue/Lock/Event/Semaphore/gather/sleep (extra52)."
    - "This spec covers: asyncio.Condition.__name__.__eq__('Condition') — string equality novel in extra53 namespace; asyncio.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') — string equality novel in extra53 namespace; asyncio.Condition.__qualname__.__eq__('Condition'); asyncio.BoundedSemaphore.__qualname__.__eq__('BoundedSemaphore'); asyncio.Condition.__name__.__len__()==9; asyncio.BoundedSemaphore.__name__.__len__()==16; asyncio.Condition.__qualname__.__len__()==9; asyncio.BoundedSemaphore.__qualname__.__len__()==16. Also: asyncio.run.__module__.__len__()==15 — 'asyncio.runners' has 15 characters (novel len check in extra53 namespace); asyncio.run.__name__.__eq__('run') — novel name equality in extra53 namespace; asyncio.run.__name__.__len__()==3. Also: asyncio.BoundedSemaphore.__bases__[0].__qualname__.__eq__('Semaphore') — qualname of BoundedSemaphore's base; asyncio.Condition.__bases__[0].__qualname__.__eq__('object') — qualname of Condition's base."
    - "asyncio.Condition.__name__ == 'Condition'. Condition is a synchronization primitive defined in Lib/asyncio/locks.py. Its __name__ is the bare class name 'Condition' (9 chars: C-o-n-d-i-t-i-o-n). Prior specs captured __name__.__len__()==9 in earlier length tables and __module__.__eq__('asyncio.locks') in extra/extra20; extra53 supplies the __name__.__eq__ string equality check in the asynciocond53 namespace, complementing the length facts. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore'. BoundedSemaphore is a subclass of Semaphore in Lib/asyncio/locks.py that adds an upper bound to the semaphore counter. Its __name__ is 'BoundedSemaphore' (16 chars). Prior specs captured __name__.__len__()==16 and __module__.__eq__('asyncio.locks'); extra53 supplies the string equality for __name__ in a novel namespace. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__qualname__ == 'Condition'. Condition is a top-level class in asyncio/locks.py with no enclosing class, so __qualname__ == __name__ == 'Condition' (9 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__qualname__ == 'BoundedSemaphore'. BoundedSemaphore is a top-level class in asyncio/locks.py with no enclosing class, so __qualname__ == __name__ == 'BoundedSemaphore' (16 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.run.__module__.__len__() == 15. 'asyncio.runners' has 15 characters: a-s-y-n-c-i-o-.-r-u-n-n-e-r-s = 15. This is longer than 'asyncio.locks' (13 chars) and 'asyncio.tasks' (13 chars). Prior specs captured the string equality run.__module__=='asyncio.runners' (extra4/extra10/extra20/extra42) but not this specific __len__() in the asynciocond53 namespace. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.run.__name__ == 'run'. The run() function's __name__ is the bare function name 'run' (3 chars). Prior specs captured __qualname__=='run' (extra6/extra22/extra43) and __module__=='asyncio.runners' but not the __name__ string equality as a distinct attribute in this namespace. For completeness, __name__ == __qualname__ == 'run' for module-level functions with no enclosing scope. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__bases__[0].__qualname__ == 'Semaphore'. BoundedSemaphore extends Semaphore; its first base class is Semaphore, which is a top-level class with __qualname__ == __name__ == 'Semaphore'. Prior specs captured __bases__[0].__name__ == 'Semaphore' (extra11/extra20) and __bases__[0].__name__.__len__()==9; extra53 captures the complementary __qualname__ string equality check. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__bases__[0].__qualname__ == 'object'. Condition's first base class is object, which has __qualname__ == __name__ == 'object'. Prior specs captured __bases__[0].__name__ == 'object' (extra11) and the length; extra53 captures the __qualname__ equality. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Condition and BoundedSemaphore __name__ string equality — extra53
#
# Condition and BoundedSemaphore are defined in Lib/asyncio/locks.py. Both
# are top-level classes with __qualname__ == __name__ (no enclosing scope).
#
# Prior specs measured __name__.__len__() for these classes in length tables
# and captured __module__.__eq__ in earlier namespaces. Extra53 captures the
# __name__ and __qualname__ string equality checks in the asynciocond53 namespace:
#
#   Condition.__name__         == 'Condition'        (9 chars)
#   BoundedSemaphore.__name__  == 'BoundedSemaphore' (16 chars)
#   Condition.__qualname__     == 'Condition'        (9 chars)
#   BoundedSemaphore.__qualname__ == 'BoundedSemaphore' (16 chars)
# ---------------------------------------------------------------------------

table asyncio_extra53.cond_boundsem_name_eq:
  description: "asyncio.Condition and BoundedSemaphore __name__ string equality in extra53 namespace — bare class names as defined in asyncio/locks.py"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciocond53name

  columns: [id, function, args, expected, description]
  rows:
    - [Condition,        Condition.__name__.__eq__,        ["Condition"],        true, "Condition.__name__ == 'Condition' — 9-char class name defined in asyncio/locks.py; string equality complement to prior __len__() checks"]
    - [BoundedSemaphore, BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true, "BoundedSemaphore.__name__ == 'BoundedSemaphore' — 16-char class name defined in asyncio/locks.py; subclass of Semaphore with counter upper bound"]

table asyncio_extra53.cond_boundsem_qualname_eq:
  description: "asyncio.Condition and BoundedSemaphore __qualname__ string equality in extra53 namespace — top-level classes have __qualname__ == __name__"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciocond53qualname

  columns: [id, function, args, expected, description]
  rows:
    - [Condition,        Condition.__qualname__.__eq__,        ["Condition"],        true, "Condition.__qualname__ == 'Condition' — top-level class; no enclosing scope; __qualname__ == __name__ == 'Condition' (9 chars)"]
    - [BoundedSemaphore, BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"], true, "BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — top-level class; no enclosing scope; __qualname__ == __name__ == 'BoundedSemaphore' (16 chars)"]

# ---------------------------------------------------------------------------
# asyncio.Condition and BoundedSemaphore __name__/__qualname__.__len__() — extra53
#
# 'Condition' has 9 characters; 'BoundedSemaphore' has 16 characters.
# __qualname__.__len__() equals __name__.__len__() for top-level classes.
# These cross-check the string equality values in the tables above.
# ---------------------------------------------------------------------------

table asyncio_extra53.cond_boundsem_name_len:
  description: "asyncio.Condition and BoundedSemaphore __name__/__qualname__.__len__() in extra53 namespace — 'Condition'==9, 'BoundedSemaphore'==16"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciocond53namelen

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_name,        Condition.__name__.__len__,            [], 9,  "Condition.__name__.__len__() == 9 — 'Condition' has 9 characters"]
    - [Condition_qualname,    Condition.__qualname__.__len__,        [], 9,  "Condition.__qualname__.__len__() == 9 — equals __name__.__len__() for top-level class"]
    - [BoundedSem_name,       BoundedSemaphore.__name__.__len__,     [], 16, "BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has 16 characters"]
    - [BoundedSem_qualname,   BoundedSemaphore.__qualname__.__len__, [], 16, "BoundedSemaphore.__qualname__.__len__() == 16 — equals __name__.__len__() for top-level class"]

# ---------------------------------------------------------------------------
# asyncio.BoundedSemaphore and Condition base class __qualname__ — extra53
#
# BoundedSemaphore.__bases__[0] is Semaphore; Semaphore is a top-level class
# with __qualname__ == __name__ == 'Semaphore' (9 chars).
# Condition.__bases__[0] is object; object has __qualname__ == __name__ == 'object' (6 chars).
#
# Prior specs captured the __name__ string equality for these bases (extra11/extra20).
# Extra53 captures the complementary __qualname__ string equality checks, which
# confirm the same value for top-level classes (no enclosing scope).
# ---------------------------------------------------------------------------

table asyncio_extra53.base_qualname_eq:
  description: "asyncio.Condition and BoundedSemaphore __bases__[0].__qualname__ string equality in extra53 namespace — base class qualnames equal their names for top-level classes"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: asynciocond53basequal

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_base,        "Condition.__bases__[0].__qualname__.__eq__",        ["object"],    true, "Condition.__bases__[0].__qualname__ == 'object' — Condition extends object directly; object.__qualname__ == object.__name__ == 'object'"]
    - [BoundedSem_base,       "BoundedSemaphore.__bases__[0].__qualname__.__eq__", ["Semaphore"], true, "BoundedSemaphore.__bases__[0].__qualname__ == 'Semaphore' — BoundedSemaphore extends Semaphore; Semaphore.__qualname__ == 'Semaphore' (9 chars)"]

# ---------------------------------------------------------------------------
# asyncio.run __name__ string equality and __module__.__len__() — extra53
#
# asyncio.run is defined in Lib/asyncio/runners.py:
#   run.__name__           == 'run'              (3 chars)
#   run.__module__         == 'asyncio.runners'  (15 chars)
#
# Prior specs captured:
#   run.__qualname__ == 'run'             (extra6/extra22/extra43)
#   run.__module__   == 'asyncio.runners' (extra4/extra10/extra20/extra42)
#
# Extra53 adds: run.__name__.__eq__('run') — the __name__ attribute specifically
# (distinct from __qualname__; both equal 'run' for module-level functions but
# are separate attributes), and run.__module__.__len__()==15 in this namespace.
# ---------------------------------------------------------------------------

table asyncio_extra53.run_identity:
  description: "asyncio.run __name__ string equality and __module__.__len__() in extra53 namespace — run is defined in asyncio.runners (15 chars)"
  kind: python_call_eq
  category: module_identity
  id_prefix: asynciocond53run

  columns: [id, function, args, expected, description]
  rows:
    - [run_name,       run.__name__.__eq__,       ["run"], true, "run.__name__ == 'run' — bare function name (3 chars); distinct from __qualname__=='run' captured in earlier specs"]
    - [run_name_len,   run.__name__.__len__,       [],     3,    "run.__name__.__len__() == 3 — 'run' has 3 characters; same as __qualname__.__len__()==3 for module-level function"]
    - [run_module_len, run.__module__.__len__,     [],     15,   "run.__module__.__len__() == 15 — 'asyncio.runners' has 15 characters: 'asyncio.'(8) + 'runners'(7) = 15; longer than 'asyncio.locks'(13) and 'asyncio.tasks'(13)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra53
# ---------------------------------------------------------------------------

invariant asyncio_extra53.Condition_name_eq:
  description: "asyncio.Condition.__name__ == 'Condition' — bare class name (9 chars) defined in asyncio/locks.py; string equality complement to __name__.__len__()==9 from prior specs"
  category: class_names
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant asyncio_extra53.BoundedSemaphore_name_eq:
  description: "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' — bare class name (16 chars) defined in asyncio/locks.py; BoundedSemaphore extends Semaphore and enforces an upper bound"
  category: class_names
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant asyncio_extra53.Condition_qualname_eq:
  description: "asyncio.Condition.__qualname__ == 'Condition' — top-level class in asyncio/locks.py; no enclosing scope; __qualname__ == __name__ == 'Condition' (9 chars)"
  category: class_names
  kind: python_call_eq
  function: Condition.__qualname__.__eq__
  args: ["Condition"]
  expected: true

invariant asyncio_extra53.BoundedSemaphore_qualname_eq:
  description: "asyncio.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — top-level class in asyncio/locks.py; no enclosing scope; __qualname__ == __name__ == 'BoundedSemaphore' (16 chars)"
  category: class_names
  kind: python_call_eq
  function: BoundedSemaphore.__qualname__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant asyncio_extra53.Condition_base_qualname_eq:
  description: "asyncio.Condition.__bases__[0].__qualname__ == 'object' — Condition's first base is object; object is a built-in top-level type with __qualname__ == __name__ == 'object' (6 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "Condition.__bases__[0].__qualname__.__eq__"
  args: ["object"]
  expected: true

invariant asyncio_extra53.BoundedSemaphore_base_qualname_eq:
  description: "asyncio.BoundedSemaphore.__bases__[0].__qualname__ == 'Semaphore' — BoundedSemaphore extends Semaphore; Semaphore is a top-level class with __qualname__ == __name__ == 'Semaphore' (9 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__qualname__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra53.run_name_eq:
  description: "asyncio.run.__name__ == 'run' — bare function name attribute (3 chars); run is a module-level function in asyncio.runners; __name__ is the unqualified name, distinct from __qualname__ (both equal 'run' for module-level functions)"
  category: module_identity
  kind: python_call_eq
  function: run.__name__.__eq__
  args: ["run"]
  expected: true

invariant asyncio_extra53.run_module_len:
  description: "asyncio.run.__module__.__len__() == 15 — 'asyncio.runners' has 15 characters: 'asyncio.'(8) + 'runners'(7) = 15; longer than 'asyncio.locks'(13) and 'asyncio.tasks'(13); cross-check for run.__module__=='asyncio.runners' from extra4/extra10/extra20/extra42"
  category: module_identity
  kind: python_call_eq
  function: run.__module__.__len__
  args: []
  expected: 15
