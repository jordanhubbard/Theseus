spec: d3_time_format
version: ">=4.0.0"
backend: node(d3-time-format)

docs: https://d3js.org/d3-time-format

provenance:
  derived_from:
    - "d3-time-format docs — https://d3js.org/d3-time-format"
    - "Test vectors verified with d3-time-format via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "d3-time-format source"
  notes:
    - "strftime-style date/time format and parse — '%Y-%m-%d', '%H:%M:%S', etc."
    - "Install: npm install d3-time-format"
    - "v4 ESM only; named exports timeFormat / timeParse / utcFormat / utcParse."
    - "Tests use UTC variants for timezone-independent vectors."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factories; never throw on valid format strings."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant d3_time_format.utc_format_iso:
  description: "utcFormat('%Y-%m-%d') on epoch ms 1705276800000 (= 2024-01-15 UTC) yields '2024-01-15'"
  category: format
  kind: node_chain_eq
  entry: named
  function: utcFormat
  entry_args: ["%Y-%m-%d"]
  chain:
    - {call: [1705276800000]}
  expected: "2024-01-15"

invariant d3_time_format.utc_parse_round_trip:
  description: "utcParse('%Y-%m-%d')('2024-01-15').getTime() is 1705276800000"
  category: parse
  kind: node_chain_eq
  entry: named
  function: utcParse
  entry_args: ["%Y-%m-%d"]
  chain:
    - {call: ["2024-01-15"]}
    - {method: getTime, args: []}
  expected: 1705276800000

invariant d3_time_format.utc_format_with_time:
  description: "utcFormat('%Y-%m-%dT%H:%M:%S') on 2024-01-15T12:34:56Z (1705322096000) ISO-style"
  category: format
  kind: node_chain_eq
  entry: named
  function: utcFormat
  entry_args: ["%Y-%m-%dT%H:%M:%S"]
  chain:
    - {call: [1705322096000]}
  expected: "2024-01-15T12:34:56"

invariant d3_time_format.utc_parse_invalid_returns_null:
  description: "utcParse on a malformed input returns null"
  category: parse
  kind: node_chain_eq
  entry: named
  function: utcParse
  entry_args: ["%Y-%m-%d"]
  chain:
    - {call: ["not a date"]}
  expected: ~

invariant d3_time_format.utc_format_year_only:
  description: "utcFormat('%Y') extracts year from 2024-01-15 UTC"
  category: format
  kind: node_chain_eq
  entry: named
  function: utcFormat
  entry_args: ["%Y"]
  chain:
    - {call: [1705276800000]}
  expected: "2024"

invariant d3_time_format.utc_format_month_padded:
  description: "utcFormat('%m') zero-pads month — March (1710460800000) → '03'"
  category: format
  kind: node_chain_eq
  entry: named
  function: utcFormat
  entry_args: ["%m"]
  chain:
    - {call: [1710460800000]}
  expected: "03"

invariant d3_time_format.timeFormat_export_present:
  description: "timeFormat is exported as a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "timeFormat.constructor.name"}
  expected: "Function"

invariant d3_time_format.timeParse_export_present:
  description: "timeParse is exported as a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "timeParse.constructor.name"}
  expected: "Function"
