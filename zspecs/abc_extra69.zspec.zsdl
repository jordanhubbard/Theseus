spec: abc_extra69
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra68.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, length tables for all identifiers, ABCMeta.register/__new__/__instancecheck__/__subclasscheck__ qualname lengths, __mro__.__len__() for ABC(2) and ABCMeta(3), MRO entry name lengths, __dict__.__class__.__name__.__len__() for ABC/ABCMeta, ABC/__dict__ content (doc/slots/abstractmethods/abc_impl), ABCMeta/__dict__ content (register/instancecheck/subclasscheck/new)."
    - "This spec covers (abcmore69 namespace): wave 240 theme — abstractmethod wrapper behavior invariants + ABCMeta.__subclasshook__ code. NEW in extra69: ABCMeta.__subclasshook__.__class__.__name__=='builtin_function_or_method' (in CPython, ABCMeta.__subclasshook__ is exposed as a built-in method); ABC.__module__=='abc'; abstractproperty.__mro__[1].__name__=='property'; abstractproperty.__mro__[2].__name__=='object'; abstractclassmethod.__mro__[1].__name__=='classmethod'; abstractstaticmethod.__mro__[1].__name__=='staticmethod'; abstractclassmethod.__dict__.__class__.__name__=='mappingproxy'; abstractstaticmethod.__dict__.__class__.__name__=='mappingproxy'."
    - "abc.ABCMeta.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. In CPython, ABCMeta.__subclasshook__ is implemented in C (_abc module) and exposed as a builtin_function_or_method, not a classmethod. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__module__ == 'abc'. ABC is defined in Lib/abc.py; __module__ is 'abc'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__mro__[1].__name__ == 'property'. abstractproperty subclasses property; __mro__[1].__name__ is 'property'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__mro__[2].__name__ == 'object'. abstractproperty MRO is (abstractproperty, property, object); __mro__[2].__name__ is 'object'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__mro__[1].__name__ == 'classmethod'. abstractclassmethod subclasses classmethod; __mro__[1].__name__ is 'classmethod'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__mro__[1].__name__ == 'staticmethod'. abstractstaticmethod subclasses staticmethod; __mro__[1].__name__ is 'staticmethod'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__dict__.__class__.__name__ == 'mappingproxy'. The __dict__ of any Python class is a mappingproxy; abstractclassmethod.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__dict__.__class__.__name__ == 'mappingproxy'. abstractstaticmethod.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta.__subclasshook__ class name + ABC.__module__ — extra69
#
# Wave 240 theme: abstractmethod wrapper behavior + ABCMeta.__subclasshook__ code.
#
# ABCMeta.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'
# ABC.__module__ == 'abc'
# ---------------------------------------------------------------------------

table abc_extra69.ABCMeta_subclasshook_and_ABC_module:
  description: "abc ABCMeta.__subclasshook__.__class__.__name__ and ABC.__module__ checks in abcmore69 namespace — wave 240 theme: ABCMeta.__subclasshook__ identity; ABCMeta.__subclasshook__.__class__.__name__=='builtin_function_or_method' (implemented in C via _abc module in CPython; exposed as builtin_function_or_method); ABC.__module__=='abc' (ABC is defined in Lib/abc.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmore69

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_subclasshook_class_name, ABCMeta.__subclasshook__.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "ABCMeta.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C-implemented in _abc module; verified with Python 3.14.3"]
    - [abc_module,                       ABC.__module__.__eq__,                              ["abc"],                        true, "ABC.__module__ == 'abc' — ABC is defined in Lib/abc.py; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abstractproperty MRO entry names — extra69
#
# abstractproperty.__mro__[1].__name__ == 'property'
# abstractproperty.__mro__[2].__name__ == 'object'
# ---------------------------------------------------------------------------

table abc_extra69.abstractproperty_mro:
  description: "abc abstractproperty MRO entry name checks in abcmore69 namespace — wave 240 theme: abstractproperty hierarchy; abstractproperty.__mro__[1].__name__=='property' (abstractproperty directly subclasses property); abstractproperty.__mro__[2].__name__=='object' (full MRO: abstractproperty, property, object); verified with Python 3.14.3"
  kind: python_call_eq
  category: hierarchy
  id_prefix: abcmore69a

  columns: [id, function, args, expected, description]
  rows:
    - [abstractproperty_mro_1, "abstractproperty.__mro__[1].__name__.__eq__", ["property"], true, "abstractproperty.__mro__[1].__name__ == 'property' — abstractproperty subclasses property; verified with Python 3.14.3"]
    - [abstractproperty_mro_2, "abstractproperty.__mro__[2].__name__.__eq__", ["object"],   true, "abstractproperty.__mro__[2].__name__ == 'object' — MRO: (abstractproperty, property, object); verified with Python 3.14.3"]

