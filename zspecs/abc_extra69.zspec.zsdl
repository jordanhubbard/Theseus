table abc_extra69.abstractclassmethod_abstractstaticmethod_mro:
  description: "abc abstractclassmethod and abstractstaticmethod MRO entry name checks in abcmore69 namespace — wave 240 theme: deprecated abstract wrapper hierarchy; abstractclassmethod.__mro__[1].__name__=='classmethod' (abstractclassmethod subclasses classmethod); abstractstaticmethod.__mro__[1].__name__=='staticmethod' (abstractstaticmethod subclasses staticmethod); verified with Python 3.14.3"
  kind: python_call_eq
  category: hierarchy
  id_prefix: abcmore69b

  columns: [id, function, args, expected, description]
  rows:
    - [abstractclassmethod_mro_1,  "abstractclassmethod.__mro__[1].__name__.__eq__",  ["classmethod"],  true, "abstractclassmethod.__mro__[1].__name__ == 'classmethod' — abstractclassmethod subclasses classmethod; verified with Python 3.14.3"]
    - [abstractstaticmethod_mro_1, "abstractstaticmethod.__mro__[1].__name__.__eq__", ["staticmethod"], true, "abstractstaticmethod.__mro__[1].__name__ == 'staticmethod' — abstractstaticmethod subclasses staticmethod; verified with Python 3.14.3"]

