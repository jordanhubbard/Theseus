table abc_extra69.abstractclassmethod_abstractstaticmethod_dict:
  description: "abc abstractclassmethod and abstractstaticmethod __dict__.__class__.__name__ checks in abcmore69 namespace — wave 240 theme: abstract wrapper __dict__ type; abstractclassmethod.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is always a mappingproxy in CPython); abstractstaticmethod.__dict__.__class__.__name__=='mappingproxy'; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcmore69c

  columns: [id, function, args, expected, description]
  rows:
    - [abstractclassmethod_dict_class_name,  abstractclassmethod.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true, "abstractclassmethod.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a mappingproxy; verified with Python 3.14.3"]
    - [abstractstaticmethod_dict_class_name, abstractstaticmethod.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "abstractstaticmethod.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is a mappingproxy; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra69
# ---------------------------------------------------------------------------

invariant abc_extra69.ABCMeta_subclasshook_class_name:
  description: "abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') returns True — ABCMeta.__subclasshook__ is implemented in C via the _abc module in CPython; it is exposed as a builtin_function_or_method; NEW in extra69: first standalone __class__.__name__ invariant for ABCMeta.__subclasshook__ in abcmore69 namespace; wave 240; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra69.abstractproperty_mro_1:
  description: "abc.abstractproperty.__mro__[1].__name__.__eq__('property') returns True — abstractproperty directly subclasses property; __mro__[1].__name__ is 'property'; NEW in extra69: first standalone __mro__[1].__name__ invariant for abstractproperty in abcmore69 namespace; wave 240; verified with Python 3.14.3"
  category: hierarchy
  kind: python_call_eq
  function: "abstractproperty.__mro__[1].__name__.__eq__"
  args: ["property"]
  expected: true

invariant abc_extra69.abstractclassmethod_mro_1:
  description: "abc.abstractclassmethod.__mro__[1].__name__.__eq__('classmethod') returns True — abstractclassmethod subclasses classmethod; __mro__[1].__name__ is 'classmethod'; NEW in extra69: first standalone __mro__[1].__name__ invariant for abstractclassmethod in abcmore69 namespace; wave 240; verified with Python 3.14.3"
  category: hierarchy
  kind: python_call_eq
  function: "abstractclassmethod.__mro__[1].__name__.__eq__"
  args: ["classmethod"]
  expected: true

invariant abc_extra69.abstractstaticmethod_mro_1:
  description: "abc.abstractstaticmethod.__mro__[1].__name__.__eq__('staticmethod') returns True — abstractstaticmethod subclasses staticmethod; __mro__[1].__name__ is 'staticmethod'; NEW in extra69: first standalone __mro__[1].__name__ invariant for abstractstaticmethod in abcmore69 namespace; wave 240; verified with Python 3.14.3"
  category: hierarchy
  kind: python_call_eq
  function: "abstractstaticmethod.__mro__[1].__name__.__eq__"
  args: ["staticmethod"]
  expected: true

invariant abc_extra69.abstractclassmethod_dict_class_name:
  description: "abc.abstractclassmethod.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — class __dict__ objects are always mappingproxy in CPython; NEW in extra69: first standalone __dict__.__class__.__name__ invariant for abstractclassmethod in abcmore69 namespace; wave 240; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: abstractclassmethod.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
