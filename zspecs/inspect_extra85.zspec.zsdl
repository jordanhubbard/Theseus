spec: inspect_extra85
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra84

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra84.zspec.zsdl."
    - "This spec covers: inspect FullArgSpec named tuple identity attributes + code object attributes (Wave 249)."
    - "inspect.FullArgSpec.__name__ == 'FullArgSpec' — FullArgSpec is a NamedTuple. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__module__ == 'inspect' — FullArgSpec is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a NamedTuple subclassing tuple. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__mro__.__len__() == 3 — [FullArgSpec, tuple, object]. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__qualname__ == 'FullArgSpec' — qualname matches name for module-level NamedTuple. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__qualname__.__len__() == 11 — 'FullArgSpec' is 11 chars. Verified with Python 3.14.3."
    - "inspect.ArgInfo.__name__ == 'ArgInfo' — ArgInfo is a NamedTuple still present in Python 3.14. Verified with Python 3.14.3."
    - "inspect.Attribute.__name__ == 'Attribute' — Attribute is a NamedTuple. Verified with Python 3.14.3."
    - "NOTE: inspect.ArgSpec was removed in Python 3.11; not used here."
    - "NOTE: inspect.ModuleInfo does not exist in Python 3.14; not used here."
    - "inspect.getfullargspec.__code__.co_name == 'getfullargspec' — code object name matches function name. Verified with Python 3.14.3."
    - "inspect.getfullargspec.__code__.co_argcount == 1 — getfullargspec takes exactly one positional arg (func). Verified with Python 3.14.3."
    - "inspect.getargvalues.__code__.co_name == 'getargvalues' — code object name matches function name. Verified with Python 3.14.3."
    - "inspect.getargvalues.__code__.co_argcount == 1 — getargvalues takes exactly one positional arg (frame). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.FullArgSpec named tuple identity — __name__/__module__/__bases__/__mro__ — extra85
#
# Wave 249 theme: FullArgSpec NamedTuple identity attributes.
#
# inspect.FullArgSpec.__name__               == 'FullArgSpec'
# inspect.FullArgSpec.__module__             == 'inspect'
# inspect.FullArgSpec.__bases__[0].__name__  == 'tuple'
# inspect.FullArgSpec.__mro__.__len__()      == 3
#
# No prior inspect spec checks FullArgSpec.__name__/__module__/__bases__/__mro__ via inspectextra85. New to extra85.
# ---------------------------------------------------------------------------

table inspect_extra85.FullArgSpec_identity_group1:
  description: "FullArgSpec __name__/module/__bases__[0]/__mro__ len; wave 249 inspect FullArgSpec NamedTuple identity; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra85

  columns: [id, function, args, expected, description]
  rows:
    - [FullArgSpec_name_eq_FullArgSpec,
       FullArgSpec.__name__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec is a NamedTuple defined via collections.namedtuple in Lib/inspect.py; its __name__ attribute is the string 'FullArgSpec' (11 chars); str.__eq__('FullArgSpec') returns True; no prior inspect spec checks FullArgSpec.__name__.__eq__ via inspectextra85; new to extra85"]
    - [FullArgSpec_module_eq_inspect,
       FullArgSpec.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — FullArgSpec is defined in the inspect module (Lib/inspect.py); its __module__ attribute is the string 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks FullArgSpec.__module__.__eq__ via inspectextra85; new to extra85"]
    - [FullArgSpec_bases0_name_eq_tuple,
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — FullArgSpec is a NamedTuple; NamedTuples inherit directly from the built-in tuple type; __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; no prior inspect spec checks FullArgSpec.__bases__[0].__name__ via inspectextra85; new to extra85"]
    - [FullArgSpec_mro_len_eq_3,
       "FullArgSpec.__mro__.__len__",
       [],
       3,
       "inspect.FullArgSpec.__mro__.__len__() == 3 — FullArgSpec MRO is [FullArgSpec, tuple, object]; a NamedTuple adds one level above tuple; tuple.__len__() returns 3; no prior inspect spec checks FullArgSpec.__mro__.__len__ via inspectextra85; new to extra85"]

# ---------------------------------------------------------------------------
# inspect.FullArgSpec __qualname__ + ArgInfo/Attribute names — extra85
#
# Wave 249 theme: FullArgSpec qualname + other NamedTuple names.
#
# inspect.FullArgSpec.__qualname__          == 'FullArgSpec'
# inspect.FullArgSpec.__qualname__.__len__() == 11
# inspect.ArgInfo.__name__                  == 'ArgInfo'
# inspect.Attribute.__name__                == 'Attribute'
#
# No prior inspect spec checks these via inspectextra85. New to extra85.
# ---------------------------------------------------------------------------

table inspect_extra85.FullArgSpec_qualname_and_other_named_tuples:
  description: "FullArgSpec __qualname__/__qualname__ len; ArgInfo/__name__; Attribute/__name__; wave 249; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra85

  columns: [id, function, args, expected, description]
  rows:
    - [FullArgSpec_qualname_eq_FullArgSpec,
       FullArgSpec.__qualname__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__qualname__.__eq__('FullArgSpec') == True — FullArgSpec is a module-level NamedTuple; for types defined at module scope, __qualname__ equals __name__; __qualname__ is 'FullArgSpec' (11 chars); str.__eq__('FullArgSpec') returns True; no prior inspect spec checks FullArgSpec.__qualname__.__eq__ via inspectextra85; new to extra85"]
    - [FullArgSpec_qualname_len_eq_11,
       "FullArgSpec.__qualname__.__len__",
       [],
       11,
       "inspect.FullArgSpec.__qualname__.__len__() == 11 — __qualname__ is 'FullArgSpec' (11 chars: F,u,l,l,A,r,g,S,p,e,c); str.__len__() returns 11; no prior inspect spec checks FullArgSpec.__qualname__.__len__ via inspectextra85; new to extra85"]
    - [ArgInfo_name_eq_ArgInfo,
       ArgInfo.__name__.__eq__,
       ["ArgInfo"],
       true,
       "inspect.ArgInfo.__name__.__eq__('ArgInfo') == True — ArgInfo is a NamedTuple defined in Lib/inspect.py representing argument info from getargvalues(); its __name__ is 'ArgInfo' (7 chars); str.__eq__('ArgInfo') returns True; no prior inspect spec checks ArgInfo.__name__.__eq__ via inspectextra85; new to extra85"]
    - [Attribute_name_eq_Attribute,
       Attribute.__name__.__eq__,
       ["Attribute"],
       true,
       "inspect.Attribute.__name__.__eq__('Attribute') == True — Attribute is a NamedTuple defined in Lib/inspect.py representing a class attribute; its __name__ is 'Attribute' (9 chars); str.__eq__('Attribute') returns True; no prior inspect spec checks Attribute.__name__.__eq__ via inspectextra85; new to extra85"]

# ---------------------------------------------------------------------------
# inspect.getfullargspec code object attributes — co_name/co_argcount — extra85
#
# Wave 249 theme: getfullargspec/getargvalues code object introspection.
#
# inspect.getfullargspec.__code__.co_name     == 'getfullargspec'
# inspect.getfullargspec.__code__.co_argcount == 1
# inspect.getargvalues.__code__.co_name       == 'getargvalues'
# inspect.getargvalues.__code__.co_argcount   == 1
#
# No prior inspect spec checks getfullargspec/__code__.co_name/co_argcount via inspectextra85. New to extra85.
# ---------------------------------------------------------------------------

table inspect_extra85.getfullargspec_code_attrs:
  description: "getfullargspec.__code__.co_name/co_argcount; getargvalues.__code__.co_name/co_argcount; wave 249; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra85

  columns: [id, function, args, expected, description]
  rows:
    - [getfullargspec_co_name_eq_getfullargspec,
       getfullargspec.__code__.co_name.__eq__,
       ["getfullargspec"],
       true,
       "inspect.getfullargspec.__code__.co_name.__eq__('getfullargspec') == True — getfullargspec is a pure-Python function in Lib/inspect.py; its code object co_name attribute holds the function name as defined in the source; co_name is 'getfullargspec' (14 chars); str.__eq__('getfullargspec') returns True; no prior inspect spec checks getfullargspec.__code__.co_name via inspectextra85; new to extra85"]
    - [getfullargspec_co_argcount_eq_1,
       "getfullargspec.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getfullargspec.__code__.co_argcount.__eq__(1) == True — getfullargspec accepts exactly one positional argument (func); co_argcount counts positional args excluding *args and **kwargs; co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks getfullargspec.__code__.co_argcount via inspectextra85; new to extra85"]
    - [getargvalues_co_name_eq_getargvalues,
       getargvalues.__code__.co_name.__eq__,
       ["getargvalues"],
       true,
       "inspect.getargvalues.__code__.co_name.__eq__('getargvalues') == True — getargvalues is a pure-Python function in Lib/inspect.py; its code object co_name attribute holds the function name as defined in the source; co_name is 'getargvalues' (12 chars); str.__eq__('getargvalues') returns True; no prior inspect spec checks getargvalues.__code__.co_name via inspectextra85; new to extra85"]
    - [getargvalues_co_argcount_eq_1,
       "getargvalues.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getargvalues.__code__.co_argcount.__eq__(1) == True — getargvalues accepts exactly one positional argument (frame); co_argcount counts positional args excluding *args and **kwargs; co_argcount is 1; int.__eq__(1) returns True; no prior inspect spec checks getargvalues.__code__.co_argcount via inspectextra85; new to extra85"]

# ---------------------------------------------------------------------------
# FullArgSpec __bases__[0].__name__ + FullArgSpec mro len double-confirm + name len — extra85
#
# Wave 249 theme: FullArgSpec additional identity attributes.
#
# inspect.FullArgSpec.__name__.__len__()                == 11
# inspect.ArgInfo.__bases__[0].__name__                 == 'tuple'
# inspect.Attribute.__bases__[0].__name__               == 'tuple'
# inspect.FullArgSpec.__module__.__len__()              == 7
#
# No prior inspect spec checks these via inspectextra85. New to extra85.
# ---------------------------------------------------------------------------

table inspect_extra85.FullArgSpec_name_len_and_other_attrs:
  description: "FullArgSpec __name__ len==11; ArgInfo/Attribute bases tuple; FullArgSpec module len==7; wave 249; new to extra85"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectextra85

  columns: [id, function, args, expected, description]
  rows:
    - [FullArgSpec_name_len_eq_11,
       "FullArgSpec.__name__.__len__",
       [],
       11,
       "inspect.FullArgSpec.__name__.__len__() == 11 — __name__ is 'FullArgSpec' (11 chars: F,u,l,l,A,r,g,S,p,e,c); str.__len__() returns 11; no prior inspect spec checks FullArgSpec.__name__.__len__ via inspectextra85; new to extra85"]
    - [ArgInfo_bases0_name_eq_tuple,
       "ArgInfo.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.ArgInfo.__bases__[0].__name__.__eq__('tuple') == True — ArgInfo is a NamedTuple defined in Lib/inspect.py; NamedTuples inherit directly from tuple; __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; no prior inspect spec checks ArgInfo.__bases__[0].__name__ via inspectextra85; new to extra85"]
    - [Attribute_bases0_name_eq_tuple,
       "Attribute.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.Attribute.__bases__[0].__name__.__eq__('tuple') == True — Attribute is a NamedTuple defined in Lib/inspect.py; NamedTuples inherit directly from tuple; __bases__[0].__name__ is 'tuple'; str.__eq__('tuple') returns True; no prior inspect spec checks Attribute.__bases__[0].__name__ via inspectextra85; new to extra85"]
    - [FullArgSpec_module_len_eq_7,
       "FullArgSpec.__module__.__len__",
       [],
       7,
       "inspect.FullArgSpec.__module__.__len__() == 7 — __module__ is 'inspect' (7 chars: i,n,s,p,e,c,t); str.__len__() returns 7; no prior inspect spec checks FullArgSpec.__module__.__len__ via inspectextra85; new to extra85"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra85
# ---------------------------------------------------------------------------

invariant inspect_extra85.FullArgSpec_name_eq:
  description: "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec NamedTuple __name__ matches type name; wave 249; new to extra85"
  kind: python_call_eq
  function: FullArgSpec.__name__.__eq__
  args: ["FullArgSpec"]
  expected: true

invariant inspect_extra85.FullArgSpec_bases0_name:
  description: "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — FullArgSpec is a NamedTuple subclassing tuple; wave 249; new to extra85"
  kind: python_call_eq
  function: "FullArgSpec.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

invariant inspect_extra85.FullArgSpec_mro_len:
  description: "inspect.FullArgSpec.__mro__.__len__() == 3 — MRO is [FullArgSpec, tuple, object]; wave 249; new to extra85"
  kind: python_call_eq
  function: FullArgSpec.__mro__.__len__
  args: []
  expected: 3

invariant inspect_extra85.getfullargspec_co_name:
  description: "inspect.getfullargspec.__code__.co_name.__eq__('getfullargspec') == True — code object co_name matches function name; wave 249; new to extra85"
  kind: python_call_eq
  function: getfullargspec.__code__.co_name.__eq__
  args: ["getfullargspec"]
  expected: true

invariant inspect_extra85.getargvalues_co_name:
  description: "inspect.getargvalues.__code__.co_name.__eq__('getargvalues') == True — code object co_name matches function name; wave 249; new to extra85"
  kind: python_call_eq
  function: getargvalues.__code__.co_name.__eq__
  args: ["getargvalues"]
  expected: true
