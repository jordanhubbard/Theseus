# ---------------------------------------------------------------------------

table abc_extra84.deprecated_abstract_decorators_doc_class:
  description: "abc deprecated abstract decorators doc class name checks in abcmetacheck84 namespace — wave 249 theme: abc.ABCMeta.__instancecheck__ and __subclasscheck__ identity and deprecated abstract decorators doc class; abstractproperty.__doc__.__class__.__name__=='str' (deprecated but has docstring); abstractclassmethod.__doc__.__class__.__name__=='str' (deprecated but has docstring); abstractstaticmethod.__doc__.__class__.__name__=='str' (deprecated but has docstring); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacheck84b

  columns: [id, function, args, expected, description]
  rows:
    - [absprop_doc_cls,    "abstractproperty.__doc__.__class__.__name__.__eq__",    ["str"], true, "abstractproperty.__doc__.__class__.__name__ == 'str' — deprecated but has a docstring; verified with Python 3.14.3"]
    - [abscls_doc_cls,     "abstractclassmethod.__doc__.__class__.__name__.__eq__", ["str"], true, "abstractclassmethod.__doc__.__class__.__name__ == 'str' — deprecated but has a docstring; verified with Python 3.14.3"]
    - [absstatic_doc_cls,  "abstractstaticmethod.__doc__.__class__.__name__.__eq__",["str"], true, "abstractstaticmethod.__doc__.__class__.__name__ == 'str' — deprecated but has a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc cross-checks: __instancecheck__, __subclasscheck__, and deprecated decorators — extra84
#
# Cross-checks across identity and doc class facts.
# ---------------------------------------------------------------------------

table abc_extra84.cross_checks:
  description: "abc ABCMeta check methods and deprecated decorators cross-checks in abcmetacheck84 namespace — wave 249 theme: abc.ABCMeta.__instancecheck__ and __subclasscheck__ identity and deprecated abstract decorators doc class; ABCMeta.__instancecheck__.__module__.__eq__('abc')==True (cross-check); ABCMeta.__subclasscheck__.__module__.__eq__('abc')==True (cross-check); abstractproperty.__doc__.__class__.__name__=='str' (cross-check); ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (cross-check); ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacheck84c

  columns: [id, function, args, expected, description]
  rows:
    - [ic_module_cross,    ABCMeta.__instancecheck__.__module__.__eq__,           ["abc"],                      true, "ABCMeta.__instancecheck__.__module__ == 'abc' — cross-check; verified with Python 3.14.3"]
    - [sc_module_cross,    ABCMeta.__subclasscheck__.__module__.__eq__,           ["abc"],                      true, "ABCMeta.__subclasscheck__.__module__ == 'abc' — cross-check; verified with Python 3.14.3"]
    - [absprop_doc_cross,  "abstractproperty.__doc__.__class__.__name__.__eq__",  ["str"],                      true, "abstractproperty.__doc__.__class__.__name__ == 'str' — cross-check; verified with Python 3.14.3"]
    - [ic_qualname_cross,  ABCMeta.__instancecheck__.__qualname__.__eq__,         ["ABCMeta.__instancecheck__"], true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — cross-check; verified with Python 3.14.3"]
    - [sc_qualname_cross,  ABCMeta.__subclasscheck__.__qualname__.__eq__,         ["ABCMeta.__subclasscheck__"], true, "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra84
# ---------------------------------------------------------------------------

invariant abc_extra84.ABCMeta_instancecheck_class_is_function:
  description: "abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__('function') returns True — ABCMeta.__instancecheck__ is a Python function defined in abc.py (not a C-level method_descriptor); it delegates to the _abc C extension for the actual check; NEW in extra84: first standalone __class__.__name__ invariant for ABCMeta.__instancecheck__ in abcmetacheck84 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__instancecheck__.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

invariant abc_extra84.ABCMeta_subclasscheck_class_is_function:
  description: "abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__('function') returns True — ABCMeta.__subclasscheck__ is a Python function defined in abc.py; it implements the customized subclass checking used by isinstance and issubclass with ABCs; NEW in extra84: first standalone __class__.__name__ invariant for ABCMeta.__subclasscheck__ in abcmetacheck84 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__subclasscheck__.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

invariant abc_extra84.ABCMeta_instancecheck_qualname:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') returns True — the qualified name includes the class prefix ABCMeta, confirming it is defined as a method within ABCMeta; NEW in extra84: first standalone __qualname__ invariant for ABCMeta.__instancecheck__ in abcmetacheck84 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

invariant abc_extra84.abstractclassmethod_doc_is_str:
  description: "abc.abstractclassmethod.__doc__.__class__.__name__.__eq__('str') returns True — abstractclassmethod is deprecated since Python 3.3 but still has a docstring; the docstring is a str instance; NEW in extra84: first standalone doc class name invariant for abstractclassmethod in abcmetacheck84 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abstractclassmethod.__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

invariant abc_extra84.abstractstaticmethod_doc_is_str:
  description: "abc.abstractstaticmethod.__doc__.__class__.__name__.__eq__('str') returns True — abstractstaticmethod is deprecated since Python 3.3 but still has a docstring; the docstring is a str instance; NEW in extra84: first standalone doc class name invariant for abstractstaticmethod in abcmetacheck84 namespace; wave 249; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abstractstaticmethod.__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true
