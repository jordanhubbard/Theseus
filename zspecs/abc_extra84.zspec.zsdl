table abc_extra84.ABCMeta_subclasscheck_identity:
  description: "abc ABCMeta __subclasscheck__ identity checks in abcmetacheck84 namespace — wave 249 theme: abc.ABCMeta.__instancecheck__ and __subclasscheck__ identity and deprecated abstract decorators doc class; ABCMeta.__subclasscheck__.__class__.__name__=='function' (Python function defined in abc.py, not a C method); ABCMeta.__subclasscheck__.__module__.__eq__('abc')==True; ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacheck84a

  columns: [id, function, args, expected, description]
  rows:
    - [sc_class_name,   "ABCMeta.__subclasscheck__.__class__.__name__.__eq__", ["function"],                  true, "ABCMeta.__subclasscheck__.__class__.__name__ == 'function' — Python function in abc.py; verified with Python 3.14.3"]
    - [sc_module_eq,    ABCMeta.__subclasscheck__.__module__.__eq__,            ["abc"],                      true, "ABCMeta.__subclasscheck__.__module__ == 'abc' — defined in abc.py; verified with Python 3.14.3"]
    - [sc_qualname_eq,  ABCMeta.__subclasscheck__.__qualname__.__eq__,          ["ABCMeta.__subclasscheck__"], true, "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — verified with Python 3.14.3"]

