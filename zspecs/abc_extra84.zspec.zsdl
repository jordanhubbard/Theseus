spec: abc_extra84
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra83

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra83.zspec.zsdl."
    - "This spec covers: wave 249 theme — abc.ABCMeta.__instancecheck__ and abc.ABCMeta.__subclasscheck__ class identity, and abc.abstractproperty/abstractclassmethod/abstractstaticmethod doc class names. NEW in extra84: ABCMeta.__instancecheck__.__class__.__name__=='function'; ABCMeta.__subclasscheck__.__class__.__name__=='function'; ABCMeta.__instancecheck__.__module__=='abc'; ABCMeta.__subclasscheck__.__module__=='abc'; ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__'; ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__'; abstractproperty.__doc__.__class__.__name__=='str'; abstractclassmethod.__doc__.__class__.__name__=='str'; abstractstaticmethod.__doc__.__class__.__name__=='str'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__class__.__name__ == 'function'. ABCMeta.__instancecheck__ is a Python function (defined in abc.py). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__class__.__name__ == 'function'. ABCMeta.__subclasscheck__ is a Python function (defined in abc.py). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__module__ == 'abc'. Defined in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__module__ == 'abc'. Defined in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__doc__.__class__.__name__ == 'str'. abstractproperty has a docstring (it is deprecated). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__doc__.__class__.__name__ == 'str'. abstractclassmethod has a docstring (it is deprecated). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__doc__.__class__.__name__ == 'str'. abstractstaticmethod has a docstring (it is deprecated). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABCMeta __instancecheck__ identity — extra84
#
# Wave 249 theme: abc.ABCMeta.__instancecheck__ and __subclasscheck__ identity,
# and abstractproperty/abstractclassmethod/abstractstaticmethod doc class names.
#
# ABCMeta.__instancecheck__.__class__.__name__ == 'function'
# ABCMeta.__instancecheck__.__module__ == 'abc'
# ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'
# ---------------------------------------------------------------------------

table abc_extra84.ABCMeta_instancecheck_identity:
  description: "abc ABCMeta __instancecheck__ identity checks in abcmetacheck84 namespace — wave 249 theme: abc.ABCMeta.__instancecheck__ and __subclasscheck__ identity and deprecated abstract decorators doc class; ABCMeta.__instancecheck__.__class__.__name__=='function' (Python function defined in abc.py, not a C method); ABCMeta.__instancecheck__.__module__.__eq__('abc')==True; ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacheck84

  columns: [id, function, args, expected, description]
  rows:
    - [ic_class_name,   "ABCMeta.__instancecheck__.__class__.__name__.__eq__", ["function"],               true, "ABCMeta.__instancecheck__.__class__.__name__ == 'function' — Python function in abc.py; verified with Python 3.14.3"]
    - [ic_module_eq,    ABCMeta.__instancecheck__.__module__.__eq__,           ["abc"],                    true, "ABCMeta.__instancecheck__.__module__ == 'abc' — defined in abc.py; verified with Python 3.14.3"]
    - [ic_qualname_eq,  ABCMeta.__instancecheck__.__qualname__.__eq__,         ["ABCMeta.__instancecheck__"], true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
