spec: multiprocessing_extra13
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra12.zspec.zsdl."
    - "multiprocessing_extra covers: Process/__name__, Queue/__name__, Pipe/__name__."
    - "multiprocessing_extra12 covers: synchronize classes __name__/__module__, process.BaseProcess identity."
    - "NOT yet covered in any prior spec: pool.Pool.__name__ == 'Pool' — pool class via submodule."
    - "NOT yet covered: pool.Pool.__module__ == 'multiprocessing.pool'."
    - "NOT yet covered: pool.Pool.__qualname__ == 'Pool'."
    - "NOT yet covered: queues.Queue.__name__ == 'Queue' — queue class via submodule."
    - "NOT yet covered: queues.Queue.__module__ == 'multiprocessing.queues'."
    - "NOT yet covered: queues.JoinableQueue.__name__ == 'JoinableQueue'."
    - "NOT yet covered: managers.BaseManager.__name__ == 'BaseManager'."
    - "NOT yet covered: managers.BaseManager.__module__ == 'multiprocessing.managers'."
    - "NOT yet covered: managers.SyncManager.__name__ == 'SyncManager'."
    - "NOT yet covered: active_children.__name__ == 'active_children'."
    - "NOT yet covered: active_children.__module__ == 'multiprocessing.process'."
    - "NOT yet covered: cpu_count.__module__ == 'multiprocessing.context'."
    - "multiprocessing.pool.Pool.__qualname__ == 'Pool' — top-level class in the pool submodule."
    - "multiprocessing.queues.JoinableQueue.__name__ == 'JoinableQueue' — extends Queue with task_done/join."
    - "multiprocessing.managers.SyncManager.__name__ == 'SyncManager' — the default shared-object manager."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool class identity — __name__, __module__, __qualname__
#
# The top-level multiprocessing.Pool is a context-bound method. Accessing the
# underlying class directly via multiprocessing.pool.Pool gives a different
# access path. No prior spec checks pool.Pool __name__/__module__/__qualname__.
# ---------------------------------------------------------------------------

table multiprocessing_extra13.pool_class_identity:
  description: "multiprocessing.pool.Pool class has correct __name__, __module__, __qualname__"
  kind: python_call_eq
  category: class_names
  id_prefix: poolclsid

  columns: [id, function, args, expected]
  rows:
    - [name,     pool.Pool.__name__.__eq__,     ["Pool"],                  true]
    - [module,   pool.Pool.__module__.__eq__,   ["multiprocessing.pool"],  true]
    - [qualname, pool.Pool.__qualname__.__eq__, ["Pool"],                  true]

# ---------------------------------------------------------------------------
# multiprocessing.queues classes — __name__ and __module__
#
# The top-level multiprocessing.Queue is a context-bound method. No prior spec
# checks queues.Queue or queues.JoinableQueue directly via the queues submodule.
# ---------------------------------------------------------------------------

table multiprocessing_extra13.queues_class_names:
  description: "multiprocessing.queues classes have correct __name__ and __module__"
  kind: python_call_eq
  category: class_names
  id_prefix: qcname13

  columns: [id, function, args, expected]
  rows:
    - [Queue_name,          queues.Queue.__name__.__eq__,          ["Queue"],                    true]
    - [Queue_module,        queues.Queue.__module__.__eq__,        ["multiprocessing.queues"],   true]
    - [JoinableQueue_name,  queues.JoinableQueue.__name__.__eq__,  ["JoinableQueue"],            true]

# ---------------------------------------------------------------------------
# multiprocessing.managers classes — __name__ and __module__
#
# No prior spec checks managers.BaseManager or managers.SyncManager. These are
# the key classes in the multiprocessing.managers submodule used for shared
# state across processes.
# ---------------------------------------------------------------------------

table multiprocessing_extra13.managers_class_names:
  description: "multiprocessing.managers classes have correct __name__ and __module__"
  kind: python_call_eq
  category: class_names
  id_prefix: mgrclsid

  columns: [id, function, args, expected]
  rows:
    - [BaseManager_name,   managers.BaseManager.__name__.__eq__,   ["BaseManager"],               true]
    - [BaseManager_module, managers.BaseManager.__module__.__eq__, ["multiprocessing.managers"],  true]
    - [SyncManager_name,   managers.SyncManager.__name__.__eq__,   ["SyncManager"],               true]

# ---------------------------------------------------------------------------
# active_children function — __name__ and __module__
#
# multiprocessing_extra covers active_count and similar. No prior spec checks
# active_children.__name__ or active_children.__module__.
# active_children is defined in multiprocessing/process.py.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra13.active_children.name:
  description: "multiprocessing.active_children.__name__ == 'active_children'"
  category: function_names
  kind: python_call_eq
  function: active_children.__name__.__eq__
  args: ["active_children"]
  expected: true

invariant multiprocessing_extra13.active_children.module:
  description: "multiprocessing.active_children.__module__ == 'multiprocessing.process'"
  category: function_modules
  kind: python_call_eq
  function: active_children.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

# ---------------------------------------------------------------------------
# cpu_count __module__ check
#
# multiprocessing_extra covers cpu_count/__name__. No prior spec checks
# cpu_count.__module__. It is defined in multiprocessing/context.py.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra13.cpu_count.module:
  description: "multiprocessing.cpu_count.__module__ == 'multiprocessing.context'"
  category: function_modules
  kind: python_call_eq
  function: cpu_count.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true
