spec: unicodedata_extra4
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends prior unicodedata specs."
    - "Focus: __module__ and __name__ for unicodedata functions not yet covered."
    - "unicodedata.lookup.__name__ == 'lookup'."
    - "unicodedata.unidata_version.__class__.__name__ == 'str'."
    - "unicodedata.category('A') == 'Lu' (uppercase letter)."
    - "unicodedata.category('a') == 'Ll' (lowercase letter)."
    - "unicodedata.category('0') == 'Nd' (decimal digit number)."
    - "unicodedata.bidirectional('A') == 'L' (left-to-right)."
    - "unicodedata.combining('A') == 0 (not a combining character)."
    - "unicodedata.east_asian_width('A') == 'Na' (narrow)."
    - "unicodedata.mirrored('(') == 1 (mirrored bracket)."
    - "unicodedata.decomposition('ü') != '' (has decomposition)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table unicodedata_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [lookup,           lookup.__name__.__eq__,           ["lookup"],           true]
    - [category,         category.__name__.__eq__,         ["category"],         true]
    - [bidirectional,    bidirectional.__name__.__eq__,    ["bidirectional"],    true]
    - [combining,        combining.__name__.__eq__,        ["combining"],        true]
    - [east_asian_width, east_asian_width.__name__.__eq__, ["east_asian_width"], true]
    - [mirrored,         mirrored.__name__.__eq__,         ["mirrored"],         true]
    - [decomposition,    decomposition.__name__.__eq__,    ["decomposition"],    true]
    - [normalize,        normalize.__name__.__eq__,        ["normalize"],        true]
    - [is_normalized,    is_normalized.__name__.__eq__,    ["is_normalized"],    true]

invariant unicodedata_extra4.unidata_version.is_str:
  description: "unicodedata.unidata_version.__class__.__name__ == 'str'"
  category: version
  kind: python_call_eq
  function: unidata_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant unicodedata_extra4.category.uppercase_A:
  description: "unicodedata.category('A') == 'Lu'"
  category: category
  kind: python_call_eq
  function: category
  args: ["A"]
  expected: "Lu"

invariant unicodedata_extra4.category.lowercase_a:
  description: "unicodedata.category('a') == 'Ll'"
  category: category
  kind: python_call_eq
  function: category
  args: ["a"]
  expected: "Ll"

invariant unicodedata_extra4.category.digit_zero:
  description: "unicodedata.category('0') == 'Nd'"
  category: category
  kind: python_call_eq
  function: category
  args: ["0"]
  expected: "Nd"

invariant unicodedata_extra4.bidirectional.A:
  description: "unicodedata.bidirectional('A') == 'L'"
  category: bidirectional
  kind: python_call_eq
  function: bidirectional
  args: ["A"]
  expected: "L"

invariant unicodedata_extra4.combining.A:
  description: "unicodedata.combining('A') == 0"
  category: combining
  kind: python_call_eq
  function: combining
  args: ["A"]
  expected: 0

invariant unicodedata_extra4.east_asian_width.A:
  description: "unicodedata.east_asian_width('A') == 'Na'"
  category: east_asian_width
  kind: python_call_eq
  function: east_asian_width
  args: ["A"]
  expected: "Na"

invariant unicodedata_extra4.mirrored.open_paren:
  description: "unicodedata.mirrored('(') == 1"
  category: mirrored
  kind: python_call_eq
  function: mirrored
  args: ["("]
  expected: 1
