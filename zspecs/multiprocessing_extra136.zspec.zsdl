table multiprocessing_extra136.connection_identity:
  description: "multiprocessing.connection.Connection class identity checks — Connection.__name__.__eq__('Connection')==True (len=10); Connection.__module__.__eq__('multiprocessing.connection')==True (len=26: 'multiprocessing'=15+'.'=1+'connection'=10=26); Connection.__bases__[0].__name__.__eq__('_ConnectionBase')==True (len=15: '_ConnectionBase' has leading underscore, indicating internal base class); Connection.__qualname__.__eq__('Connection')==True (len=10, same as __name__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpconn136

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    multiprocessing.connection.Connection.__name__.__eq__,              ["Connection"],                   true, "Connection.__name__ == 'Connection' (len=10); verified with Python 3.14.3"]
    - [name_len,   multiprocessing.connection.Connection.__name__.__len__,              [],                              10,   "Connection.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [mod_eq,     multiprocessing.connection.Connection.__module__.__eq__,            ["multiprocessing.connection"],   true, "Connection.__module__ == 'multiprocessing.connection' (len=26); verified with Python 3.14.3"]
    - [mod_len,    multiprocessing.connection.Connection.__module__.__len__,            [],                              26,   "Connection.__module__.__len__() == 26; verified with Python 3.14.3"]
    - [base_eq,    "multiprocessing.connection.Connection.__bases__[0].__name__.__eq__", ["_ConnectionBase"],              true, "Connection.__bases__[0].__name__ == '_ConnectionBase' (len=15); verified with Python 3.14.3"]
    - [base_len,   "multiprocessing.connection.Connection.__bases__[0].__name__.__len__", [],                             15,   "Connection.__bases__[0].__name__.__len__() == 15; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra136
# ---------------------------------------------------------------------------

invariant multiprocessing_extra136.pipe_qualname_len_16:
  description: "multiprocessing.Pipe.__qualname__.__len__() == 16 — Pipe.__qualname__ is 'BaseContext.Pipe' (16 chars: 'BaseContext'=11+'.'=1+'Pipe'=4=16); Pipe.__class__.__name__=='method' (it is a bound method, not a function); Pipe.__module__=='multiprocessing.context' (len=23); Pipe.__func__.__code__.co_argcount==2; co_varnames.__len__()==3; NEW in extra136: first standalone Pipe qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Pipe.__qualname__.__len__
  args: []
  expected: 16

invariant multiprocessing_extra136.queue_qualname_len_17:
  description: "multiprocessing.Queue.__qualname__.__len__() == 17 — Queue.__qualname__ is 'BaseContext.Queue' (17 chars: 'BaseContext'=11+'.'=1+'Queue'=5=17); Queue qualname len (17) is one more than Pipe qualname len (16); Queue is also a bound method (type.__name__=='method'); Queue.__func__.__code__.co_argcount==2; NEW in extra136: first standalone Queue qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Queue.__qualname__.__len__
  args: []
  expected: 17

invariant multiprocessing_extra136.pipe_module_len_23:
  description: "multiprocessing.Pipe.__module__.__len__() == 23 — Pipe.__module__ is 'multiprocessing.context' (23 chars: 'multiprocessing'=15+'.'=1+'context'=7=23); this is the context module where the default multiprocessing context is defined; Pipe.__func__.__code__.co_varnames.__len__()==3; NEW in extra136: first standalone Pipe module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Pipe.__module__.__len__
  args: []
  expected: 23

invariant multiprocessing_extra136.connection_name_len_10:
  description: "multiprocessing.connection.Connection.__name__.__len__() == 10 — Connection.__name__ is 'Connection' (10 chars); Connection.__module__=='multiprocessing.connection' (len=26); Connection.__bases__[0].__name__=='_ConnectionBase' (len=15); NEW in extra136: first standalone Connection __name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.connection.Connection.__name__.__len__
  args: []
  expected: 10

invariant multiprocessing_extra136.connection_module_len_26:
  description: "multiprocessing.connection.Connection.__module__.__len__() == 26 — Connection.__module__ is 'multiprocessing.connection' (26 chars: 'multiprocessing'=15+'.'=1+'connection'=10=26); same length as ProcessPoolExecutor.__module__ ('concurrent.futures.process', also 26); Connection.__bases__[0].__name__=='_ConnectionBase'; NEW in extra136: first standalone Connection module length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.connection.Connection.__module__.__len__
  args: []
  expected: 26
