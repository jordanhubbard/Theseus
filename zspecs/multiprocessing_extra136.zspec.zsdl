spec: multiprocessing_extra136
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py, Lib/multiprocessing/connection.py"
  notes:
    - "This spec covers: multiprocessing.Pipe, multiprocessing.Queue (both bound methods on a BaseContext instance — type is 'method'), and multiprocessing.connection.Connection. Pipe.__qualname__=='BaseContext.Pipe' (len=16); Pipe.__class__.__name__=='method' (len=6); Pipe.__module__=='multiprocessing.context' (len=23); Pipe.__func__.__code__.co_argcount==2 (self, duplex); Pipe.__func__.__code__.co_varnames.__len__()==3 ('self','duplex','Pipe'). Queue.__qualname__=='BaseContext.Queue' (len=17); Queue.__func__.__code__.co_argcount==2 (self, maxsize); Queue.__func__.__code__.co_varnames.__len__()==3 ('self','maxsize','Queue'). Connection.__name__=='Connection' (len=10); Connection.__module__=='multiprocessing.connection' (len=26); Connection.__bases__[0].__name__=='_ConnectionBase' (len=15). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Pipe and multiprocessing.Queue are bound methods (not functions) — they are bound to a DefaultContext/SpawnContext/ForkContext/ForkServerContext instance and accessed as multiprocessing.Pipe and multiprocessing.Queue. Their type.__name__ is 'method'. Their __qualname__ comes from the underlying BaseContext class. Pipe.__func__.__code__ and Queue.__func__.__code__ are the underlying unbound function code objects. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Pipe qualname, class name, module — extra136
#
# multiprocessing.Pipe.__qualname__       == 'BaseContext.Pipe' (len=16)
# multiprocessing.Pipe.__class__.__name__ == 'method'           (len=6)
# multiprocessing.Pipe.__module__         == 'multiprocessing.context' (len=23)
# ---------------------------------------------------------------------------

table multiprocessing_extra136.pipe_identity:
  description: "multiprocessing.Pipe qualname, class name, and module identity checks — Pipe.__qualname__.__eq__('BaseContext.Pipe')==True (len=16: 'BaseContext'=11+'.'=1+'Pipe'=4=16); Pipe.__class__.__name__.__eq__('method')==True (len=6: Pipe is a bound method on a BaseContext instance, NOT a plain function); Pipe.__module__.__eq__('multiprocessing.context')==True (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppipe136

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,        multiprocessing.Pipe.__qualname__.__eq__,        ["BaseContext.Pipe"],          true, "multiprocessing.Pipe.__qualname__ == 'BaseContext.Pipe' (len=16); verified with Python 3.14.3"]
    - [qn_len,       multiprocessing.Pipe.__qualname__.__len__,        [],                           16,   "multiprocessing.Pipe.__qualname__.__len__() == 16; verified with Python 3.14.3"]
    - [cls_name_eq,  multiprocessing.Pipe.__class__.__name__.__eq__,  ["method"],                   true, "multiprocessing.Pipe.__class__.__name__ == 'method' (Pipe is a bound method); verified with Python 3.14.3"]
    - [cls_name_len, multiprocessing.Pipe.__class__.__name__.__len__,  [],                          6,    "multiprocessing.Pipe.__class__.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [mod_eq,       multiprocessing.Pipe.__module__.__eq__,          ["multiprocessing.context"],  true, "multiprocessing.Pipe.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [mod_len,      multiprocessing.Pipe.__module__.__len__,          [],                          23,   "multiprocessing.Pipe.__module__.__len__() == 23; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Pipe.__func__ code object attributes — extra136
#
# multiprocessing.Pipe.__func__.__code__.co_argcount   == 2
# multiprocessing.Pipe.__func__.__code__.co_varnames   has len 3
# ---------------------------------------------------------------------------

table multiprocessing_extra136.pipe_func_code:
  description: "multiprocessing.Pipe.__func__ code object attribute checks — Pipe.__func__.__qualname__.__eq__('BaseContext.Pipe')==True (same as Pipe.__qualname__); Pipe.__func__.__code__.co_argcount==2 (self, duplex); co_varnames.__len__()==3 ('self','duplex','Pipe'); 'duplex' is in co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppipecode136

  columns: [id, function, args, expected, description]
  rows:
    - [argc,         multiprocessing.Pipe.__func__.__code__.co_argcount.__eq__,          [2],       true, "multiprocessing.Pipe.__func__.__code__.co_argcount == 2 (self, duplex); verified with Python 3.14.3"]
    - [varnames_len, multiprocessing.Pipe.__func__.__code__.co_varnames.__len__,          [],        3,    "multiprocessing.Pipe.__func__.__code__.co_varnames.__len__() == 3; verified with Python 3.14.3"]
    - [duplex_in,    multiprocessing.Pipe.__func__.__code__.co_varnames.__contains__,    ["duplex"], true, "multiprocessing.Pipe.__func__.__code__.co_varnames contains 'duplex'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Queue qualname and __func__ code — extra136
#
# multiprocessing.Queue.__qualname__                       == 'BaseContext.Queue' (len=17)
# multiprocessing.Queue.__func__.__code__.co_argcount      == 2
# multiprocessing.Queue.__func__.__code__.co_varnames len  == 3
# ---------------------------------------------------------------------------

table multiprocessing_extra136.queue_identity:
  description: "multiprocessing.Queue qualname and __func__ code attribute checks — Queue.__qualname__.__eq__('BaseContext.Queue')==True (len=17: 'BaseContext'=11+'.'=1+'Queue'=5=17); Queue is also a bound method (type.__name__=='method'); Queue.__func__.__code__.co_argcount==2 (self, maxsize); Queue.__func__.__code__.co_varnames.__len__()==3 ('self','maxsize','Queue'); Queue qualname len (17) is one more than Pipe qualname len (16); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpqueue136

  columns: [id, function, args, expected, description]
  rows:
    - [qn_eq,        multiprocessing.Queue.__qualname__.__eq__,                        ["BaseContext.Queue"], true, "multiprocessing.Queue.__qualname__ == 'BaseContext.Queue' (len=17); verified with Python 3.14.3"]
    - [qn_len,       multiprocessing.Queue.__qualname__.__len__,                        [],                   17,   "multiprocessing.Queue.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [argc,         multiprocessing.Queue.__func__.__code__.co_argcount.__eq__,       [2],                  true, "multiprocessing.Queue.__func__.__code__.co_argcount == 2 (self, maxsize); verified with Python 3.14.3"]
    - [varnames_len, multiprocessing.Queue.__func__.__code__.co_varnames.__len__,       [],                   3,    "multiprocessing.Queue.__func__.__code__.co_varnames.__len__() == 3; verified with Python 3.14.3"]
    - [maxsize_in,   multiprocessing.Queue.__func__.__code__.co_varnames.__contains__, ["maxsize"],           true, "multiprocessing.Queue.__func__.__code__.co_varnames contains 'maxsize'; verified with Python 3.14.3"]

