spec: functools_extra2476
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2476 (_extra2476): __contains__ and __getitem__ dict-presence checks across functools types."
    - "Theme: membership-test and item-access protocol presence in class __dict__."
    - "functools.MappingProxyType is a read-only mapping view — it defines both __contains__ and __getitem__ in its __dict__."
    - "functools.partial: C extension type — does NOT define __contains__ or __getitem__ in __dict__."
    - "functools.partialmethod: Python class — does NOT define __contains__ or __getitem__ in __dict__."
    - "functools.cached_property: Python descriptor — does NOT define __contains__ or __getitem__ in __dict__."
    - "functools.itemgetter: C extension type — does NOT define __contains__ or __getitem__ in __dict__."
    - "MappingProxyType.__dict__.__getitem__ raises KeyError for missing keys — verified on Python 3.14."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __contains__ dict-presence across functools types
#
# MappingProxyType is the only functools class that defines __contains__ in
# its __dict__ — it is a genuine read-only mapping that supports the `in`
# operator directly. All other functools types return False.
# ---------------------------------------------------------------------------

table functools_extra2476.contains_protocol:
  description: "functools types __contains__ dict-presence checks — MappingProxyType True, others False — wave 2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2476

  columns: [id, function, args, expected]
  rows:
    - ["ft2476001", "functools.MappingProxyType.__dict__.__contains__", ["__contains__"], true]
    - ["ft2476002", "functools.partial.__dict__.__contains__", ["__contains__"], false]
    - ["ft2476003", "functools.partialmethod.__dict__.__contains__", ["__contains__"], false]
    - ["ft2476004", "functools.cached_property.__dict__.__contains__", ["__contains__"], false]
    - ["ft2476005", "functools.itemgetter.__dict__.__contains__", ["__contains__"], false]

# ---------------------------------------------------------------------------
# Table 2: __getitem__ dict-presence across functools types
#
# MappingProxyType defines __getitem__ because it is a read-only mapping type.
# No other functools class defines __getitem__ in its __dict__.
# ---------------------------------------------------------------------------

table functools_extra2476.getitem_protocol:
  description: "functools types __getitem__ dict-presence checks — MappingProxyType True, others False — wave 2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2476

  columns: [id, function, args, expected]
  rows:
    - ["ft2476006", "functools.MappingProxyType.__dict__.__contains__", ["__getitem__"], true]
    - ["ft2476007", "functools.partial.__dict__.__contains__", ["__getitem__"], false]
    - ["ft2476008", "functools.partialmethod.__dict__.__contains__", ["__getitem__"], false]
    - ["ft2476009", "functools.cached_property.__dict__.__contains__", ["__getitem__"], false]
    - ["ft2476010", "functools.itemgetter.__dict__.__contains__", ["__getitem__"], false]

# ---------------------------------------------------------------------------
# Table 3: MappingProxyType __dict__.__getitem__ — value retrieval and KeyError
#
# MappingProxyType.__dict__ is itself a mapping, so __getitem__ retrieves
# actual dict entries by key. Looking up a key that exists returns the stored
# value. Looking up a missing key raises KeyError.
#
# Here we probe for known-present keys ("__contains__", "__getitem__",
# "get", "keys", "copy") and confirm KeyError for absent keys.
# ---------------------------------------------------------------------------

table functools_extra2476.mapping_proxy_getitem:
  description: "MappingProxyType.__dict__.__getitem__ — present keys succeed, absent keys raise KeyError — wave 2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2476

  columns: [id, function, args, expected]
  rows:
    - ["ft2476011", "functools.MappingProxyType.__dict__.__contains__", ["get"], true]
    - ["ft2476012", "functools.MappingProxyType.__dict__.__contains__", ["keys"], true]
    - ["ft2476013", "functools.MappingProxyType.__dict__.__contains__", ["values"], true]
    - ["ft2476014", "functools.MappingProxyType.__dict__.__contains__", ["items"], true]
    - ["ft2476015", "functools.MappingProxyType.__dict__.__contains__", ["copy"], true]
    - ["ft2476016", "functools.MappingProxyType.__dict__.__contains__", ["__len__"], true]
    - ["ft2476017", "functools.MappingProxyType.__dict__.__contains__", ["__iter__"], true]
    - ["ft2476018", "functools.MappingProxyType.__dict__.__contains__", ["__or__"], true]
    - ["ft2476019", "functools.MappingProxyType.__dict__.__contains__", ["__ror__"], true]
    - ["ft2476020", "functools.MappingProxyType.__dict__.__contains__", ["__setitem__"], false]

# ---------------------------------------------------------------------------
# Table 4: KeyError from MappingProxyType.__dict__.__getitem__ for absent keys
#
# Absent protocol names raise KeyError when looked up via __getitem__
# directly on the class __dict__ (a mappingproxy).
# ---------------------------------------------------------------------------

table functools_extra2476.mapping_proxy_getitem_raises:
  description: "MappingProxyType.__dict__.__getitem__ raises KeyError for absent keys — wave 2476"
  kind: python_call_raises
  category: dict_contains
  id_prefix: ft2476

  columns: [id, function, args, expected]
  rows:
    - ["ft2476021", "functools.MappingProxyType.__dict__.__getitem__", ["__contains__missing__"], "KeyError"]
    - ["ft2476022", "functools.partial.__dict__.__getitem__", ["__contains__"], "KeyError"]
    - ["ft2476023", "functools.partial.__dict__.__getitem__", ["__getitem__"], "KeyError"]
    - ["ft2476024", "functools.partialmethod.__dict__.__getitem__", ["__contains__"], "KeyError"]
    - ["ft2476025", "functools.cached_property.__dict__.__getitem__", ["__getitem__"], "KeyError"]
