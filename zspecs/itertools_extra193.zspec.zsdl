  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.chain.__name__ == 'chain' (len=5); chain is a C iterator type implemented in itertoolsmodule.c; verified with Python 3.14.3."
    - "itertools.chain.__qualname__ == 'chain' (len=5); top-level type so __qualname__ equals __name__; verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools' (len=9); defined in the itertools C extension; verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable' (len=13); class method for constructing chain from a single iterable of iterables; verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' (len=19); qualified name includes class prefix 'chain.'; verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' (len=26); from_iterable is a C builtin classmethod, not a Python-level function; verified with Python 3.14.3."
    - "itertools.chain.__bases__[0].__name__ == 'object' (len=6); chain inherits directly from object with no special superclass; verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__name__.__len__() == 13 — 'from_iterable' has 13 characters; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain name, qualname, and module identity
#
# itertools.chain.__name__    == 'chain' (len=5)
# itertools.chain.__qualname__ == 'chain' (len=5)
# itertools.chain.__module__  == 'itertools' (len=9)
#
# chain is a C iterator type. Its __name__ and __qualname__ are both 'chain'
# since it is a top-level type. Its __module__ is 'itertools'.
# New to extra193.
# ---------------------------------------------------------------------------

table itertools_extra193.chain_name_qualname_module:
  description: "itertools.chain identity: __name__=='chain'(len=5); __qualname__=='chain'(len=5); __module__=='itertools'(len=9); new to extra193"
  kind: python_call_eq
  category: identity
  id_prefix: iterchain193

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_eq,
       chain.__name__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — chain is a C iterator type in itertoolsmodule.c; __name__ is 'chain' (len=5); str.__eq__('chain') returns True; verified with Python 3.14.3; new to extra193"]
    - [chain_name_len,
       chain.__name__.__len__,
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — 'chain' has 5 characters: c-h-a-i-n; str.__len__() returns 5; verified with Python 3.14.3; new to extra193"]
    - [chain_qualname_eq,
       chain.__qualname__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — chain is a top-level C type so __qualname__ equals __name__; __qualname__ is 'chain' (len=5); str.__eq__('chain') returns True; verified with Python 3.14.3; new to extra193"]
    - [chain_module_eq,
       chain.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is defined in the itertools C extension; __module__ is 'itertools' (len=9); str.__eq__('itertools') returns True; verified with Python 3.14.3; new to extra193"]
    - [chain_module_len,
       chain.__module__.__len__,
       [],
       9,
       "itertools.chain.__module__.__len__() == 9 — 'itertools' has 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra193"]

# ---------------------------------------------------------------------------
