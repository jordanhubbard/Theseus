spec: io_extra58
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra57.zspec.zsdl — covers BytesIO/StringIO method qualname equality, DEFAULT_BUFFER_SIZE value == 131072."
    - "io_extra56.zspec.zsdl — covers __doc__.__class__.__name__/qualname for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase/RawIOBase/BufferedIOBase/TextIOBase and module."
    - "io_extra55.zspec.zsdl — covers BytesIO method qualname lengths (read=12, write=13, seek=12, tell=12, getvalue=16) and StringIO method qualname lengths (read=13, write=14, seek=13, getvalue=17)."
    - "io_extra54.zspec.zsdl — covers io concrete class __class__.__qualname__.__eq__('type') for FileIO/BytesIO/StringIO/BufferedWriter/BufferedReader/TextIOWrapper; IOBase.__class__.__qualname__.__eq__('ABCMeta'); open.__class__.__qualname__.__eq__('builtin_function_or_method'); DEFAULT_BUFFER_SIZE.__class__.__qualname__.__eq__('int')."
    - "io_extra53.zspec.zsdl — covers concrete io class __class__.__name__.__len__()==4; IOBase.__class__.__name__.__eq__('ABCMeta'); open.__name__/__qualname__.__len__()==4; open.__class__.__name__.__eq__('builtin_function_or_method')."
    - "io_extra52.zspec.zsdl — covers BufferedRandom.__module__.__len__()==3; IncrementalNewlineDecoder.__module__.__len__()==3."
    - "io_extra50.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedWriter/BufferedReader/TextIOWrapper __qualname__.__len__()."
    - "io_extra49.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedWriter/BufferedReader/TextIOWrapper __qualname__.__eq__()."
    - "io_extra47.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__/__module__/__bases__[0].__name__ — IOBase.__module__=='io'; RawIOBase.__module__=='io'."
    - "io_extra46.zspec.zsdl — covers BufferedWriter/__module__=='_io'; BufferedReader/__module__=='_io'."
    - "io_extra45.zspec.zsdl — covers StringIO.__module__.__eq__('_io')."
    - "io_extra35.zspec.zsdl — covers FileIO.__module__.__len__()==3; TextIOWrapper.__module__.__len__()==3."
    - "io_extra34.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __module__.__len__()==2 (abstract base classes report 'io', len 2)."
    - "io_extra33.zspec.zsdl — covers open.__qualname__.__eq__('open')."
    - "io_extra32.zspec.zsdl — covers FileIO/__module__=='_io'; TextIOWrapper/__module__=='_io'."
    - "io_extra25.zspec.zsdl — covers open.__module__.__eq__('_io')."
    - "io_extra22.zspec.zsdl — covers BytesIO/__module__=='_io'; StringIO/__module__=='_io'; BufferedReader/__module__=='_io'; BufferedWriter/__module__=='_io'."
    - "io_extra14.zspec.zsdl — covers FileIO/__module__=='_io'; TextIOWrapper/__module__=='_io'."
    - "io_extra6.zspec.zsdl — covers TextIOWrapper/__module__=='_io'; open/__module__=='_io'."
    - "io_extra4.zspec.zsdl — covers FileIO/__module__=='_io'."
    - "io_extra3.zspec.zsdl — covers open.__name__.__eq__('open')."
  notes:
    - "This spec extends io_extra57.zspec.zsdl."
    - "Prior specs collectively covered: __module__.__eq__() for BytesIO/_io (io_extra22); StringIO/_io (io_extra22/io_extra45); FileIO/_io (io_extra4/io_extra14/io_extra32); BufferedReader/_io (io_extra22/io_extra46); BufferedWriter/_io (io_extra22/io_extra46); TextIOWrapper/_io (io_extra6/io_extra14/io_extra32); IOBase/io (io_extra47); RawIOBase/io (io_extra47); open/_io (io_extra6/io_extra25). __module__.__len__()==3 for FileIO/TextIOWrapper (io_extra35) and BufferedRandom/IncrementalNewlineDecoder (io_extra52). __module__.__len__()==2 for IOBase/RawIOBase/BufferedIOBase/TextIOBase (io_extra34). NO prior io spec checks __module__.__len__() for BytesIO, StringIO, BufferedReader, or BufferedWriter as standalone invariants. NO prior io spec checks __module__.__len__() for open as a standalone invariant."
    - "This spec covers: io.BytesIO.__module__.__len__()==3 (NOVEL — io_extra22 covers __eq__('_io') but no prior io spec checks BytesIO.__module__.__len__(); '_io' has 3 characters; novel length anchor in io_extra58 namespace); io.StringIO.__module__.__len__()==3 (NOVEL — io_extra22/io_extra45 cover __eq__('_io'); no prior io spec checks StringIO.__module__.__len__(); novel); io.BufferedReader.__module__.__len__()==3 (NOVEL — io_extra22/io_extra46 cover __eq__('_io'); no prior io spec checks BufferedReader.__module__.__len__(); novel); io.BufferedWriter.__module__.__len__()==3 (NOVEL — io_extra22/io_extra46 cover __eq__('_io'); no prior io spec checks BufferedWriter.__module__.__len__(); novel); io.open.__module__.__len__()==3 (NOVEL — io_extra6/io_extra25 cover __eq__('_io'); io_extra53 covers open.__name__.__len__()==4; no prior io spec checks open.__module__.__len__(); novel); io.BytesIO.__module__.__eq__('_io') (namespace anchor; functionally covered in io_extra22); io.StringIO.__module__.__eq__('_io') (namespace anchor; covered in io_extra22/io_extra45); io.FileIO.__module__.__eq__('_io') (namespace anchor; covered in io_extra4/io_extra14/io_extra32); io.BufferedReader.__module__.__eq__('_io') (namespace anchor; covered in io_extra22/io_extra46); io.BufferedWriter.__module__.__eq__('_io') (namespace anchor; covered in io_extra22/io_extra46); io.TextIOWrapper.__module__.__eq__('_io') (namespace anchor; covered in io_extra6/io_extra14/io_extra32); io.IOBase.__module__.__eq__('io') (namespace anchor; covered in io_extra47); io.RawIOBase.__module__.__eq__('io') (namespace anchor; covered in io_extra47); io.open.__module__.__eq__('_io') (namespace anchor; covered in io_extra6/io_extra25)."
    - "io.BytesIO.__module__ == '_io'. BytesIO is implemented in the C extension _io; re-exported by the io wrapper. __module__ == '_io'. io_extra22 checks the equality string. The length '_io'.__len__() == 3 has not been checked for BytesIO as a standalone invariant. Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.StringIO.__module__ == '_io'. StringIO is implemented in the C extension _io. io_extra22 and io_extra45 check equality. The length 3 has not been standalone-checked for StringIO. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedReader.__module__ == '_io'. io_extra22 and io_extra46 check equality. __module__.__len__()==3 has not been checked for BufferedReader. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.__module__ == '_io'. io_extra22 and io_extra46 check equality. __module__.__len__()==3 has not been checked for BufferedWriter. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.open.__module__ == '_io'. io.open is a C-level builtin from _io. io_extra6 and io_extra25 check equality. __module__.__len__()==3 has not been checked for open. Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.IOBase.__module__ == 'io'. IOBase is implemented in _io but reports __module__ == 'io' on Python 3.14. io_extra47 covers this equality as a standalone invariant. Namespace anchor in io_extra58. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.RawIOBase.__module__ == 'io'. Like IOBase, reports 'io' not '_io'. io_extra47 covers this. Namespace anchor in io_extra58. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io class __module__ equality (io_extra58 namespace anchors)
#
# The concrete io classes (BytesIO, StringIO, FileIO, BufferedReader,
# BufferedWriter, TextIOWrapper) are implemented in the C extension _io;
# their __module__ attribute is '_io'. The abstract base classes
# (IOBase, RawIOBase) report __module__ == 'io' (the public wrapper module).
# io.open is a C-level builtin; its __module__ is '_io'.
#
# These equality values were established in io_extra4/io_extra6/io_extra14/
# io_extra22/io_extra25/io_extra32/io_extra45/io_extra46/io_extra47.
# This table consolidates them as io_extra58 namespace anchors:
#
#   BytesIO.__module__        == '_io'
#   StringIO.__module__       == '_io'
#   FileIO.__module__         == '_io'
#   BufferedReader.__module__ == '_io'
#   BufferedWriter.__module__ == '_io'
#   TextIOWrapper.__module__  == '_io'
#   IOBase.__module__         == 'io'
#   RawIOBase.__module__      == 'io'
#   open.__module__           == '_io'
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra58.class_module_eq:
  description: "io class __module__.__eq__() for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/'_io'; IOBase/RawIOBase/'io'; open/'_io' — concrete classes from C extension _io; abstract bases report public 'io'; namespace anchors in io_extra58 complementing earlier specs; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iomod58eq

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_module_eq,        BytesIO.__module__.__eq__,        ["_io"], true]
    - [StringIO_module_eq,       StringIO.__module__.__eq__,       ["_io"], true]
    - [FileIO_module_eq,         FileIO.__module__.__eq__,         ["_io"], true]
    - [BufferedReader_module_eq, BufferedReader.__module__.__eq__, ["_io"], true]
    - [BufferedWriter_module_eq, BufferedWriter.__module__.__eq__, ["_io"], true]
    - [TextIOWrapper_module_eq,  TextIOWrapper.__module__.__eq__,  ["_io"], true]
    - [IOBase_module_eq,         IOBase.__module__.__eq__,         ["io"],  true]
    - [RawIOBase_module_eq,      RawIOBase.__module__.__eq__,      ["io"],  true]
    - [open_module_eq,           open.__module__.__eq__,           ["_io"], true]

# ---------------------------------------------------------------------------
# io class __module__ lengths (novel — no prior io spec checks these)
#
# The __module__ attribute for concrete io C-extension classes is '_io'
# (3 characters). The abstract base classes IOBase and RawIOBase report
# 'io' (2 characters). io.open.__module__ is '_io' (3 characters).
#
# io_extra35 covers FileIO.__module__.__len__()==3 and
# TextIOWrapper.__module__.__len__()==3.
# io_extra52 covers BufferedRandom.__module__.__len__()==3 and
# IncrementalNewlineDecoder.__module__.__len__()==3.
# io_extra34 covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __module__.__len__()==2.
#
# NO prior io spec checks __module__.__len__() for:
#   BytesIO, StringIO, BufferedReader, BufferedWriter, open
#
# All five are novel length anchors in the io_extra58 namespace.
# '_io' has 3 characters; all five should return 3.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra58.class_module_len:
  description: "io class __module__.__len__() for BytesIO(3)/StringIO(3)/BufferedReader(3)/BufferedWriter(3)/open(3) — '_io' has 3 characters; io_extra35 covers FileIO/TextIOWrapper lengths; io_extra52 covers BufferedRandom/IncrementalNewlineDecoder lengths; no prior io spec checks BytesIO/StringIO/BufferedReader/BufferedWriter/open __module__.__len__(); all five novel length anchors in io_extra58 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: string_length
  id_prefix: iomod58len

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_module_len,        BytesIO.__module__.__len__,        [], 3]
    - [StringIO_module_len,       StringIO.__module__.__len__,       [], 3]
    - [BufferedReader_module_len, BufferedReader.__module__.__len__, [], 3]
    - [BufferedWriter_module_len, BufferedWriter.__module__.__len__, [], 3]
    - [open_module_len,           open.__module__.__len__,           [], 3]
