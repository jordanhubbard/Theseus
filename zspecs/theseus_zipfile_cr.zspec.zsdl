spec: theseus_zipfile_cr
version: ">=3.8"
backend: python_cleanroom(theseus_zipfile_cr)
blocks: zipfile

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/zipfile.html"
  not_derived_from:
    - "CPython source: Lib/zipfile/__init__.py (internal implementation)"
  notes:
    - "Clean-room ZIP file reader/writer. Do NOT import zipfile."
    - "ZIP format: local file headers, central directory, end-of-central-directory record."
    - "Supports STORED (no compression) and DEFLATED (zlib) methods."
    - "ZipFile(file, mode): open/create a zip archive; mode is 'r', 'w', or 'a'."
    - "ZipFile.write(filename, arcname): add file to archive."
    - "ZipFile.read(name): return bytes of named entry."
    - "ZipFile.namelist(): return list of archive member names."
    - "ZipFile.writestr(zinfo_or_name, data): write bytes directly into archive."
    - "is_zipfile(filename_or_file): return True if file appears to be a valid ZIP."

error_model: python_exceptions

invariant theseus_zipfile_cr.zipfile2_write_read:
  description: "write bytes to in-memory zip, read back same bytes"
  category: writestr
  kind: python_call_eq
  function: zipfile2_write_read
  args: []
  expected: "hello"

invariant theseus_zipfile_cr.zipfile2_namelist:
  description: "write 2 entries, namelist() has length 2"
  category: namelist
  kind: python_call_eq
  function: zipfile2_namelist
  args: []
  expected: 2

invariant theseus_zipfile_cr.zipfile2_is_zipfile:
  description: "is_zipfile on in-memory zip BytesIO returns True"
  category: is_zipfile
  kind: python_call_eq
  function: zipfile2_is_zipfile
  args: []
  expected: true
