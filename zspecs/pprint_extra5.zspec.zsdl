spec: pprint_extra5
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint.zspec.zsdl, pprint_extra.zspec.zsdl, pprint_extra2.zspec.zsdl, pprint_extra3.zspec.zsdl, and pprint_extra4.zspec.zsdl."
    - "pprint.zspec.zsdl: pformat primitives/containers, isreadable/isrecursive/saferepr tables, PrettyPrinter.__name__, function type checks."
    - "pprint_extra.zspec.zsdl: PrettyPrinter.__name__, PrettyPrinter.__module__, pformat/pprint/isreadable/isrecursive/saferepr __name__, pformat(42), pformat('hello'), pformat([1,2,3]), isreadable(42), isrecursive({})."
    - "pprint_extra2.zspec.zsdl: pformat([1,2,3]), pformat({}), pformat(''), isreadable([1,2,3]), isreadable({}), isrecursive([1,2,3]), isrecursive([])."
    - "pprint_extra3.zspec.zsdl: pformat/pprint/isreadable/isrecursive/saferepr/PrettyPrinter __module__, pformat({}), pformat([]), isreadable(None), isreadable({'a':1}), saferepr(42), saferepr(None), saferepr([1,2,3]), saferepr(True)."
    - "pprint_extra4.zspec.zsdl: PrettyPrinter.__name__ table, function_names table (pformat/pprint/isreadable/isrecursive/saferepr/pp), PrettyPrinter.__module__, pformat.__module__, PrettyPrinter._indent_per_level==1, PrettyPrinter._width==80, PrettyPrinter instance class name, isreadable(42), isrecursive([1,2,3]), saferepr('hello'), pformat([1,2,3])."
    - "Focus: __qualname__ attributes for PrettyPrinter, pformat, isreadable, isrecursive, saferepr, pp; PrettyPrinter.__bases__[0].__name__; saferepr(False); saferepr(''); isreadable(True); isreadable(3.14); pp.__module__."
    - "pprint.PrettyPrinter.__qualname__ == 'PrettyPrinter' — module-level class has a flat qualname."
    - "pprint.PrettyPrinter.__bases__[0].__name__ == 'object' — PrettyPrinter inherits directly from object."
    - "pprint.pformat.__qualname__ == 'pformat' — module-level function has a flat qualname."
    - "pprint.isreadable.__qualname__ == 'isreadable' — module-level function has a flat qualname."
    - "pprint.isrecursive.__qualname__ == 'isrecursive' — module-level function has a flat qualname."
    - "pprint.saferepr.__qualname__ == 'saferepr' — module-level function has a flat qualname."
    - "pprint.pp.__module__ == 'pprint' — pp (Python 3.8+) belongs to the pprint module."
    - "pprint.pp.__qualname__ == 'pp' — module-level function has a flat qualname."
    - "pprint.saferepr(False) == 'False' — bool False repr is the string 'False'."
    - "pprint.saferepr('') == \"''\" — empty string repr is two single-quotes."
    - "pprint.isreadable(True) == True — bool True has a readable repr."
    - "pprint.isreadable(3.14) == True — a float has a readable repr."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PrettyPrinter class — __qualname__ and __bases__
# ---------------------------------------------------------------------------

invariant pprint_extra5.PrettyPrinter.qualname:
  description: "pprint.PrettyPrinter.__qualname__ == 'PrettyPrinter' — flat qualname for module-level class"
  category: class_identity
  kind: python_call_eq
  function: PrettyPrinter.__qualname__.__eq__
  args: ["PrettyPrinter"]
  expected: true

invariant pprint_extra5.PrettyPrinter.base_is_object:
  description: "pprint.PrettyPrinter.__bases__[0].__name__ == 'object' — PrettyPrinter inherits from object"
  category: class_identity
  kind: python_call_eq
  function: PrettyPrinter.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Function __qualname__ checks — module-level functions have flat qualnames
# ---------------------------------------------------------------------------

table pprint_extra5.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [pformat,     pformat.__qualname__.__eq__,     ["pformat"],     true]
    - [isreadable,  isreadable.__qualname__.__eq__,  ["isreadable"],  true]
    - [isrecursive, isrecursive.__qualname__.__eq__, ["isrecursive"], true]
    - [saferepr,    saferepr.__qualname__.__eq__,    ["saferepr"],    true]
    - [pp,          pp.__qualname__.__eq__,          ["pp"],          true]

# ---------------------------------------------------------------------------
# pp function — module affiliation (Python 3.8+)
# ---------------------------------------------------------------------------

invariant pprint_extra5.pp.module:
  description: "pprint.pp.__module__ == 'pprint' — pp belongs to the pprint module"
  category: module
  kind: python_call_eq
  function: pp.__module__.__eq__
  args: ["pprint"]
  expected: true

# ---------------------------------------------------------------------------
# saferepr — additional type coverage
#
# pprint_extra3 covers: saferepr(42), saferepr(None), saferepr([1,2,3]), saferepr(True).
# pprint_extra4 covers: saferepr('hello').
# We add: saferepr(False) and saferepr('').
# ---------------------------------------------------------------------------

invariant pprint_extra5.saferepr.bool_false:
  description: "pprint.saferepr(False) == 'False' — bool False repr is 'False'"
  category: saferepr
  kind: python_call_eq
  function: saferepr
  args: [false]
  expected: "False"

invariant pprint_extra5.saferepr.empty_string:
  description: "pprint.saferepr('') == \"''\" — empty string repr is two single-quotes"
  category: saferepr
  kind: python_call_eq
  function: saferepr
  args: [""]
  expected: "''"

# ---------------------------------------------------------------------------
# isreadable — additional type coverage
#
# pprint.zspec.zsdl: isreadable for int, str, None, bool, list, dict, empty list.
# pprint_extra4 covers: isreadable(42).
# We add: isreadable(True) (bool specifically) and isreadable(3.14) (float).
# ---------------------------------------------------------------------------

invariant pprint_extra5.isreadable.bool_true:
  description: "pprint.isreadable(True) == True — a bool has a readable repr"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [true]
  expected: true

invariant pprint_extra5.isreadable.float:
  description: "pprint.isreadable(3.14) == True — a float has a readable repr"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [3.14]
  expected: true

# ---------------------------------------------------------------------------
# isrecursive — additional coverage
#
# pprint.zspec.zsdl covers isrecursive for int, str, None, list, dict.
# pprint_extra2 covers isrecursive([1,2,3]) and isrecursive([]).
# We add: isrecursive(42) and isrecursive(None) as explicit standalone invariants
# with distinct descriptions for clarity.
# ---------------------------------------------------------------------------

invariant pprint_extra5.isrecursive.int_42:
  description: "pprint.isrecursive(42) == False — a plain int has no recursive references"
  category: isrecursive
  kind: python_call_eq
  function: isrecursive
  args: [42]
  expected: false

invariant pprint_extra5.isrecursive.string:
  description: "pprint.isrecursive('hello') == False — a plain string has no recursive references"
  category: isrecursive
  kind: python_call_eq
  function: isrecursive
  args: ["hello"]
  expected: false
