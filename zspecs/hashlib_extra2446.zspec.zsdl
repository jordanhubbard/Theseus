spec: hashlib_extra2446
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "hashlib_extra306.zspec.zsdl and other pre-existing hashlib_extra files"
  notes:
    - "Theme: __enter__/__exit__ context manager protocol dict-presence for hashlib types."
    - "hashlib.HASH (the CPython internal C type returned by md5(), sha256(), etc.) does NOT define __enter__ or __exit__ in its own __dict__; it is not a context manager."
    - "hashlib.blake2b and hashlib.blake2s are separate C extension types; neither defines __enter__ or __exit__ in their __dict__; they are not context managers."
    - "hashlib.HASH.__dict__ contains update, digest, hexdigest, copy, digest_size, block_size, name — the standard hash API — but no context manager protocol."
    - "hashlib.blake2b.__dict__ additionally contains SALT_SIZE, PERSON_SIZE, MAX_KEY_SIZE, MAX_DIGEST_SIZE as class-level constants."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: hashlib.HASH — context manager protocol absent
#
# hashlib.HASH is the CPython C type for standard hash objects (md5, sha256,
# sha512, sha1, etc.). It does NOT define __enter__ or __exit__ in its class
# __dict__. Hash objects cannot be used as context managers. The dict also
# lacks __iter__ and __next__ — there is no iteration protocol either.
# ---------------------------------------------------------------------------

table hashlib_extra2446.hash_ctx_protocol_absent:
  description: "hashlib.HASH.__dict__: __enter__ and __exit__ absent — HASH is not a context manager; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2446

  columns: [id, function, args, expected]
  rows:
    - ["hl2446-001", "hashlib.HASH.__dict__.__contains__", ["__enter__"], false]
    - ["hl2446-002", "hashlib.HASH.__dict__.__contains__", ["__exit__"], false]
    - ["hl2446-003", "hashlib.HASH.__dict__.__contains__", ["__iter__"], false]
    - ["hl2446-004", "hashlib.HASH.__dict__.__contains__", ["__next__"], false]

# ---------------------------------------------------------------------------
# Table 2: hashlib.HASH — hash API methods present in __dict__
#
# These are the standard HASH interface methods defined directly in the C type.
# Their presence in __dict__ confirms they are own attributes of HASH, not
# inherited. This table contrasts with Table 1: the hash API IS present but
# the context manager protocol is NOT.
# ---------------------------------------------------------------------------

table hashlib_extra2446.hash_api_present:
  description: "hashlib.HASH.__dict__: update, digest, hexdigest, copy, digest_size, block_size, name present; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2446

  columns: [id, function, args, expected]
  rows:
    - ["hl2446-005", "hashlib.HASH.__dict__.__contains__", ["update"], true]
    - ["hl2446-006", "hashlib.HASH.__dict__.__contains__", ["digest"], true]
    - ["hl2446-007", "hashlib.HASH.__dict__.__contains__", ["hexdigest"], true]
    - ["hl2446-008", "hashlib.HASH.__dict__.__contains__", ["copy"], true]
    - ["hl2446-009", "hashlib.HASH.__dict__.__contains__", ["digest_size"], true]
    - ["hl2446-010", "hashlib.HASH.__dict__.__contains__", ["block_size"], true]
    - ["hl2446-011", "hashlib.HASH.__dict__.__contains__", ["name"], true]

# ---------------------------------------------------------------------------
# Table 3: hashlib.blake2b — context manager protocol absent
#
# hashlib.blake2b is a distinct C extension type (from _blake2). It does NOT
# define __enter__ or __exit__ in its own __dict__. It is not a context manager.
# It shares the HASH interface (update, digest, hexdigest, copy) and adds
# BLAKE2-specific constants (SALT_SIZE, PERSON_SIZE, MAX_KEY_SIZE, MAX_DIGEST_SIZE).
# ---------------------------------------------------------------------------

table hashlib_extra2446.blake2b_ctx_protocol:
  description: "hashlib.blake2b.__dict__: __enter__ and __exit__ absent; BLAKE2-specific API present; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2446

  columns: [id, function, args, expected]
  rows:
    - ["hl2446-012", "hashlib.blake2b.__dict__.__contains__", ["__enter__"], false]
    - ["hl2446-013", "hashlib.blake2b.__dict__.__contains__", ["__exit__"], false]
    - ["hl2446-014", "hashlib.blake2b.__dict__.__contains__", ["update"], true]
    - ["hl2446-015", "hashlib.blake2b.__dict__.__contains__", ["digest"], true]
    - ["hl2446-016", "hashlib.blake2b.__dict__.__contains__", ["SALT_SIZE"], true]
    - ["hl2446-017", "hashlib.blake2b.__dict__.__contains__", ["MAX_DIGEST_SIZE"], true]

# ---------------------------------------------------------------------------
# Table 4: hashlib.blake2s — context manager protocol absent
#
# hashlib.blake2s is the 256-bit BLAKE2 variant C extension type. Like blake2b
# it defines no __enter__ or __exit__ in its __dict__. It carries the same
# BLAKE2-specific constants. New to extra2446.
# ---------------------------------------------------------------------------

table hashlib_extra2446.blake2s_ctx_protocol:
  description: "hashlib.blake2s.__dict__: __enter__ and __exit__ absent; SALT_SIZE and PERSON_SIZE present; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2446

  columns: [id, function, args, expected]
  rows:
    - ["hl2446-018", "hashlib.blake2s.__dict__.__contains__", ["__enter__"], false]
    - ["hl2446-019", "hashlib.blake2s.__dict__.__contains__", ["__exit__"], false]
    - ["hl2446-020", "hashlib.blake2s.__dict__.__contains__", ["update"], true]
    - ["hl2446-021", "hashlib.blake2s.__dict__.__contains__", ["SALT_SIZE"], true]
    - ["hl2446-022", "hashlib.blake2s.__dict__.__contains__", ["PERSON_SIZE"], true]
