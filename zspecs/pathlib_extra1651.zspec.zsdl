spec: pathlib_extra1651
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "Python pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/parts/parent/joinpath/str/as_posix/relative_to"
    - "pathlib_extra.zspec.zsdl — covers Path/PurePosixPath class identity, module, components, truediv, is_absolute"
  notes:
    - "Theme: __init_subclass__, __set_name__, __class_getitem__ — class creation and parameterization protocol."
    - "PurePath and Path are Python-implemented but do not define __init_subclass__ in their own __dict__; the method is inherited from object."
    - "pathlib types are not generic containers; they do not own __class_getitem__ in their __dict__ (not parameterizable as PurePath[str])."
    - "Module-level public names are verified via __dict__.__contains__ on the pathlib module dict (a mappingproxy)."
    - "PurePath.__dict__.__contains__ checks the class's own namespace, not inherited attributes."
    - "with_stem() was added in Python 3.9; is_relative_to() was also added in Python 3.9."
    - "All pathlib classes are implemented in pure Python (Lib/pathlib/__init__.py on 3.12+)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: no_init_subclass
# PurePath and Path do not define __init_subclass__ in their own __dict__.
# The hook is inherited from object; pathlib classes do not override it.
# ---------------------------------------------------------------------------

table pathlib_extra1651.no_init_subclass:
  description: "pathlib classes do not own __init_subclass__ in their __dict__"
  kind: python_call_eq
  category: init_subclass
  id_prefix: pl1651

  columns: [id, function, args, expected]
  rows:
    - ["pl1651_purepath_no_init_subclass",        PurePath.__dict__.__contains__,        ["__init_subclass__"], false]
    - ["pl1651_path_no_init_subclass",             Path.__dict__.__contains__,             ["__init_subclass__"], false]
    - ["pl1651_pureposixpath_no_init_subclass",    PurePosixPath.__dict__.__contains__,    ["__init_subclass__"], false]
    - ["pl1651_purewindowspath_no_init_subclass",  PureWindowsPath.__dict__.__contains__,  ["__init_subclass__"], false]
    - ["pl1651_purepath_no_class_getitem",         PurePath.__dict__.__contains__,         ["__class_getitem__"], false]
    - ["pl1651_path_no_class_getitem",             Path.__dict__.__contains__,             ["__class_getitem__"], false]
    - ["pl1651_pureposixpath_no_class_getitem",    PurePosixPath.__dict__.__contains__,    ["__class_getitem__"], false]
    - ["pl1651_purewindowspath_no_class_getitem",  PureWindowsPath.__dict__.__contains__,  ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 2: purepath_methods
# Verifies that navigational methods introduced in 3.9 are present in
# PurePath.__dict__ — confirming the class-creation protocol installed them.
# ---------------------------------------------------------------------------

table pathlib_extra1651.purepath_methods:
  description: "PurePath defines its documented navigational methods in its own __dict__"
  kind: python_call_eq
  category: purepath_method_presence
  id_prefix: pl1651

  columns: [id, function, args, expected]
  rows:
    - ["pl1651_purepath_with_name",       PurePath.__dict__.__contains__, ["with_name"],       true]
    - ["pl1651_purepath_with_suffix",     PurePath.__dict__.__contains__, ["with_suffix"],     true]
    - ["pl1651_purepath_with_stem",       PurePath.__dict__.__contains__, ["with_stem"],       true]
    - ["pl1651_purepath_relative_to",     PurePath.__dict__.__contains__, ["relative_to"],     true]
    - ["pl1651_purepath_is_relative_to",  PurePath.__dict__.__contains__, ["is_relative_to"],  true]
    - ["pl1651_purepath_match",           PurePath.__dict__.__contains__, ["match"],           true]
    - ["pl1651_purepath_joinpath",        PurePath.__dict__.__contains__, ["joinpath"],        true]
    - ["pl1651_purepath_is_absolute",     PurePath.__dict__.__contains__, ["is_absolute"],     true]
    - ["pl1651_purepath_str",             PurePath.__dict__.__contains__, ["__str__"],         true]
    - ["pl1651_purepath_truediv",         PurePath.__dict__.__contains__, ["__truediv__"],     true]
    - ["pl1651_purepath_eq",              PurePath.__dict__.__contains__, ["__eq__"],          true]
    - ["pl1651_purepath_hash",            PurePath.__dict__.__contains__, ["__hash__"],        true]

# ---------------------------------------------------------------------------
# Table 3: path_methods
# Verifies that filesystem-operation methods are defined in Path.__dict__.
# Path inherits from PurePath but adds all IO and navigation filesystem ops.
# ---------------------------------------------------------------------------

table pathlib_extra1651.path_methods:
  description: "Path defines its documented filesystem methods in its own __dict__"
  kind: python_call_eq
  category: path_method_presence
  id_prefix: pl1651

  columns: [id, function, args, expected]
  rows:
    - ["pl1651_path_stat",         Path.__dict__.__contains__, ["stat"],        true]
    - ["pl1651_path_exists",       Path.__dict__.__contains__, ["exists"],      true]
    - ["pl1651_path_is_file",      Path.__dict__.__contains__, ["is_file"],     true]
    - ["pl1651_path_is_dir",       Path.__dict__.__contains__, ["is_dir"],      true]
    - ["pl1651_path_open",         Path.__dict__.__contains__, ["open"],        true]
    - ["pl1651_path_read_text",    Path.__dict__.__contains__, ["read_text"],   true]
    - ["pl1651_path_read_bytes",   Path.__dict__.__contains__, ["read_bytes"],  true]
    - ["pl1651_path_write_text",   Path.__dict__.__contains__, ["write_text"],  true]
    - ["pl1651_path_write_bytes",  Path.__dict__.__contains__, ["write_bytes"], true]
    - ["pl1651_path_mkdir",        Path.__dict__.__contains__, ["mkdir"],       true]
    - ["pl1651_path_unlink",       Path.__dict__.__contains__, ["unlink"],      true]
    - ["pl1651_path_rename",       Path.__dict__.__contains__, ["rename"],      true]
    - ["pl1651_path_glob",         Path.__dict__.__contains__, ["glob"],        true]
    - ["pl1651_path_iterdir",      Path.__dict__.__contains__, ["iterdir"],     true]
