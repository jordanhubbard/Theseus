# ---------------------------------------------------------------------------
# __class_getitem__ dict-presence — operator.contains(Cls.__dict__, '__class_getitem__')
#
# Task, Future, and Queue define __class_getitem__ (true) — they support
# generic subscript syntax (e.g. asyncio.Task[int]) for type annotations.
# Introduced in Python 3.9+.  All other asyncio classes return false.
# ---------------------------------------------------------------------------

table as3031.class_getitem:
  description: "asyncio types __class_getitem__ dict-presence checks; wave 649"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
