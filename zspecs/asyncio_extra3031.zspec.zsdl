spec: as3031
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (as3031): __missing__, __init_subclass__, __class_getitem__ dict-presence for asyncio types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Key findings: Task, Future, and Queue define __class_getitem__ (true) — they support generic annotation syntax Task[T], Future[T], Queue[T] introduced in Python 3.9+."
    - "No asyncio class defines __missing__ (none are dict-like) or __init_subclass__ in their own __dict__."
    - "Event, Semaphore, Lock, Condition, BoundedSemaphore, Handle, TimerHandle, Timeout, TaskGroup, StreamReader, StreamWriter have no __class_getitem__ override."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __missing__ dict-presence — operator.contains(Cls.__dict__, '__missing__')
#
# No asyncio class defines __missing__; all results are false.
# asyncio types are not dict subclasses and do not implement the missing-key hook.
# ---------------------------------------------------------------------------

table as3031.missing:
  description: "asyncio types __missing__ dict-presence checks; wave 649"
