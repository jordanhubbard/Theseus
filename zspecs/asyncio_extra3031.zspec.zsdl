    - ["as3031030", operator.contains, [asyncio.Future.__dict__,          "__class_getitem__"], true]
    - ["as3031031", operator.contains, [asyncio.Queue.__dict__,           "__class_getitem__"], true]
    - ["as3031032", operator.contains, [asyncio.Event.__dict__,           "__class_getitem__"], false]
    - ["as3031033", operator.contains, [asyncio.Semaphore.__dict__,       "__class_getitem__"], false]
    - ["as3031034", operator.contains, [asyncio.Lock.__dict__,            "__class_getitem__"], false]
    - ["as3031035", operator.contains, [asyncio.Condition.__dict__,       "__class_getitem__"], false]
