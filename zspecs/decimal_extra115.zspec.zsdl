spec: decimal_extra115
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra114.zspec.zsdl."
    - "This spec covers: decimal.Decimal conversion method __name__ equality assertions not yet covered."
    - "decimal.Decimal.__int__.__name__ == '__int__' (len 7); prior specs covered __qualname__.__eq__ but not __name__.__eq__."
    - "decimal.Decimal.__float__.__name__ == '__float__' (len 9); prior specs covered __qualname__.__eq__ but not __name__.__eq__."
    - "decimal.Decimal.__complex__.__name__ == '__complex__' (len 11); prior specs covered __qualname__.__eq__ but not __name__.__eq__."
    - "decimal.Decimal.__str__.__name__ == '__str__' (len 7); prior specs covered __qualname__.__eq__ but not __name__.__eq__."
    - "decimal.Decimal.__repr__.__name__ == '__repr__' (len 8); prior specs covered __qualname__.__eq__ but not __name__.__eq__."
    - "Decimal.__int__ and __str__ are wrapper_descriptors (C slots); __complex__ is a method_descriptor."
    - "Length ordering by __name__: __complex__(11) > __float__(9) > __repr__(8) > __int__(7)==__str__(7)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__int__ and __str__ __name__ equality assertions
# Decimal.__int__.__name__ == '__int__' (7 chars).
# Decimal.__str__.__name__ == '__str__' (7 chars).
# Prior specs covered __int__.__qualname__.__eq__('Decimal.__int__') and
# __str__.__qualname__.__eq__('Decimal.__str__'), but NOT __name__.__eq__ for either.
# __name__ is the bare method name (without 'Decimal.' prefix), unlike __qualname__.
# __int__(7) == __str__(7): both have 7-char bare names.
# Both are wrapper_descriptor objects (C extension slot wrappers).
# The bare names '__int__' and '__str__' are identical in length but semantically distinct:
# __int__ converts to Python int; __str__ returns the decimal string representation.
# ---------------------------------------------------------------------------

table decimal_extra115.Decimal_int_str_name:
  description: "decimal.Decimal.__int__.__name__='__int__'(7); __str__.__name__='__str__'(7); bare method names without 'Decimal.' prefix; equality assertions novel; prior specs covered __qualname__.__eq__ for both but not __name__.__eq__"
  kind: python_call_eq
  category: method_identity
  id_prefix: decintstr115a

  columns: [id, function, args, expected, description]
  rows:
    - [int_nm_eq,       "Decimal.__int__.__name__.__eq__",       ["__int__"],   true,  "decimal.Decimal.__int__.__name__ == '__int__' (7 chars; bare name without 'Decimal.' prefix; __int__ converts a Decimal to a Python int by truncating toward zero)"]
    - [int_nm_len,      "Decimal.__int__.__name__.__len__",      [],            7,     "decimal.Decimal.__int__.__name__.__len__() == 7 ('__int__': '__'(2)+'int'(3)+'__'(2)==7)"]
    - [str_nm_eq,       "Decimal.__str__.__name__.__eq__",       ["__str__"],   true,  "decimal.Decimal.__str__.__name__ == '__str__' (7 chars; bare name; __str__ returns the decimal string representation; prior specs covered __qualname__.__eq__ but not __name__.__eq__)"]
    - [str_nm_len,      "Decimal.__str__.__name__.__len__",      [],            7,     "decimal.Decimal.__str__.__name__.__len__() == 7 ('__str__': '__'(2)+'str'(3)+'__'(2)==7; same length as '__int__')"]
    - [int_eq_str_len,  "Decimal.__int__.__name__.__len__.__eq__", [7],         true,  "len('__int__') == len('__str__') == 7 (both are 7-char dunder names using 3-char method abbreviations flanked by double underscores)"]
    - [int_type,        "Decimal.__int__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "type(decimal.Decimal.__int__).__name__ == 'wrapper_descriptor' (C extension slot wrapper for nb_int in Modules/_decimal/_decimal.c)"]
    - [str_type,        "Decimal.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "type(decimal.Decimal.__str__).__name__ == 'wrapper_descriptor' (C extension slot wrapper for tp_str; same type as __int__ and __repr__)"]
    - [int_nm_ne_qn,    "Decimal.__int__.__name__.__eq__",       ["Decimal.__int__"], false, "decimal.Decimal.__int__.__name__ != 'Decimal.__int__' (__name__='__int__'(7); __qualname__='Decimal.__int__'(15); they differ by the 8-char 'Decimal.' prefix)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__float__ and __repr__ __name__ equality assertions
# Decimal.__float__.__name__ == '__float__' (9 chars).
# Decimal.__repr__.__name__ == '__repr__' (8 chars).
# Prior specs covered __float__.__qualname__.__eq__('Decimal.__float__') and
# __repr__.__qualname__.__eq__('Decimal.__repr__'), but NOT __name__.__eq__ for either.
# __float__(9) > __repr__(8): '__float__' is 1 char longer than '__repr__'.
# Both are wrapper_descriptor objects from Modules/_decimal/_decimal.c.
# __float__ converts to Python float (with possible precision loss).
# __repr__ returns a string with 'Decimal(...)' format.
# ---------------------------------------------------------------------------

table decimal_extra115.Decimal_float_repr_name:
  description: "decimal.Decimal.__float__.__name__='__float__'(9); __repr__.__name__='__repr__'(8); bare method names; equality assertions novel; prior specs covered __qualname__.__eq__ for both but not __name__.__eq__"
  kind: python_call_eq
  category: method_identity
  id_prefix: decflrp115b

  columns: [id, function, args, expected, description]
  rows:
    - [float_nm_eq,     "Decimal.__float__.__name__.__eq__",     ["__float__"],  true,  "decimal.Decimal.__float__.__name__ == '__float__' (9 chars; bare name without 'Decimal.' prefix; __float__ converts Decimal to Python float with possible precision loss)"]
    - [float_nm_len,    "Decimal.__float__.__name__.__len__",    [],             9,     "decimal.Decimal.__float__.__name__.__len__() == 9 ('__float__': '__'(2)+'float'(5)+'__'(2)==9)"]
    - [repr_nm_eq,      "Decimal.__repr__.__name__.__eq__",      ["__repr__"],   true,  "decimal.Decimal.__repr__.__name__ == '__repr__' (8 chars; bare name; __repr__ returns 'Decimal(repr_str)' format; prior specs covered __qualname__.__eq__ but not __name__.__eq__)"]
    - [repr_nm_len,     "Decimal.__repr__.__name__.__len__",     [],             8,     "decimal.Decimal.__repr__.__name__.__len__() == 8 ('__repr__': '__'(2)+'repr'(4)+'__'(2)==8)"]
    - [float_gt_repr,   "Decimal.__float__.__name__.__len__.__gt__", [8],        true,  "len('__float__') > len('__repr__') (9 > 8; '__float__' is 1 char longer than '__repr__' because 'float'(5) > 'repr'(4))"]
    - [float_type,      "Decimal.__float__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "type(decimal.Decimal.__float__).__name__ == 'wrapper_descriptor' (C slot wrapper for nb_float in Modules/_decimal/_decimal.c)"]
    - [repr_type,       "Decimal.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "type(decimal.Decimal.__repr__).__name__ == 'wrapper_descriptor' (C slot wrapper for tp_repr; same type as __float__ and __str__)"]
    - [float_nm_ne_qn,  "Decimal.__float__.__name__.__eq__",    ["Decimal.__float__"], false, "decimal.Decimal.__float__.__name__ != 'Decimal.__float__' (__name__='__float__'(9); __qualname__='Decimal.__float__'(17); differ by the 8-char 'Decimal.' prefix)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__complex__ __name__ equality and type assertions
# Decimal.__complex__.__name__ == '__complex__' (11 chars).
# No prior spec asserts Decimal.__complex__.__name__.__eq__('__complex__').
# __complex__ is a method_descriptor (NOT a wrapper_descriptor), unlike __int__,
# __float__, __str__, and __repr__ which are all wrapper_descriptors.
# This distinguishes __complex__ as a method defined via PyMethodDef (method_descriptor)
# rather than as a C slot wrapper (wrapper_descriptor).
# '__complex__'(11) is the longest bare name among the five conversion methods.
# __complex__(11) > __float__(9) > __repr__(8) > __int__(7) == __str__(7).
# ---------------------------------------------------------------------------

table decimal_extra115.Decimal_complex_name_ordering:
  description: "decimal.Decimal.__complex__.__name__='__complex__'(11); longest conversion method bare name; type is method_descriptor (unlike __int__/__float__/__str__/__repr__ which are wrapper_descriptor); equality assertion novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: deccmplx115c

  columns: [id, function, args, expected, description]
  rows:
    - [cplx_nm_eq,      "Decimal.__complex__.__name__.__eq__",    ["__complex__"],  true,  "decimal.Decimal.__complex__.__name__ == '__complex__' (11 chars; bare name; __complex__ converts Decimal to Python complex number; no prior spec asserts this equality)"]
    - [cplx_nm_len,     "Decimal.__complex__.__name__.__len__",   [],               11,    "decimal.Decimal.__complex__.__name__.__len__() == 11 ('__complex__': '__'(2)+'complex'(7)+'__'(2)==11; longest conversion method bare name)"]
    - [cplx_gt_float,   "Decimal.__complex__.__name__.__len__.__gt__", [9],         true,  "len('__complex__') > len('__float__') (11 > 9; '__complex__' is 2 chars longer than '__float__' because 'complex'(7) > 'float'(5))"]
    - [cplx_type,       "Decimal.__complex__.__class__.__name__.__eq__", ["method_descriptor"], true, "type(decimal.Decimal.__complex__).__name__ == 'method_descriptor' (NOT a wrapper_descriptor; __complex__ is defined via PyMethodDef rather than as a C slot; distinct from __int__/__float__/__str__/__repr__)"]
    - [cplx_type_ne_wd, "Decimal.__complex__.__class__.__name__.__eq__", ["wrapper_descriptor"], false, "type(decimal.Decimal.__complex__).__name__ != 'wrapper_descriptor' (__complex__ is a method_descriptor via PyMethodDef, while __int__/__float__/__str__/__repr__ are wrapper_descriptors)"]
    - [int_type_wd,     "Decimal.__int__.__class__.__name__.__eq__",  ["wrapper_descriptor"], true, "type(decimal.Decimal.__int__).__name__ == 'wrapper_descriptor' (contrasting with __complex__ which is a method_descriptor)"]
    - [float_ne_cplx_type, "Decimal.__float__.__class__.__name__.__eq__", ["method_descriptor"], false, "type(decimal.Decimal.__float__).__name__ != 'method_descriptor' (__float__ is a wrapper_descriptor, not a method_descriptor; opposite to __complex__)"]
    - [cplx_nm_ne_qn,   "Decimal.__complex__.__name__.__eq__",    ["Decimal.__complex__"], false, "decimal.Decimal.__complex__.__name__ != 'Decimal.__complex__' (__name__='__complex__'(11); __qualname__='Decimal.__complex__'(19); differ by the 8-char 'Decimal.' prefix)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra115.Decimal.__int___name_eq:
  description: "decimal.Decimal.__int__.__name__ == '__int__' (length 7; __name__ is the bare method name without the 'Decimal.' qualname prefix; Decimal.__int__(self) converts the Decimal value to a Python int by truncating toward zero — for example, Decimal('3.7').__int__() == 3 and Decimal('-3.7').__int__() == -3; Decimal.__int__ is a wrapper_descriptor (C extension slot wrapper for nb_int in Modules/_decimal/_decimal.c); its __name__ '__int__' (7 chars) differs from its __qualname__ 'Decimal.__int__' (15 chars) by the 8-char 'Decimal.' prefix; '__int__' (7) shares its length with '__str__' (7) because both use 3-char base names ('int' and 'str') flanked by double underscores; no prior decimal_extra spec has asserted Decimal.__int__.__name__.__eq__('__int__'); prior specs covered __int__.__qualname__.__eq__('Decimal.__int__') and __int__.__qualname__.__len__()==15)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.__int__.__name__.__eq__"
  args: ["__int__"]
  expected: true

invariant decimal_extra115.Decimal.__float___name_eq:
  description: "decimal.Decimal.__float__.__name__ == '__float__' (length 9; __name__ is the bare method name without the 'Decimal.' qualname prefix; Decimal.__float__(self) converts the Decimal value to a Python float, which may lose precision for high-precision Decimals; for example, Decimal('3.14159265358979323846').__float__() returns the nearest IEEE 754 double-precision approximation; Decimal.__float__ is a wrapper_descriptor (C slot wrapper for nb_float in Modules/_decimal/_decimal.c); its __name__ '__float__' (9 chars) differs from its __qualname__ 'Decimal.__float__' (17 chars) by the 8-char 'Decimal.' prefix; '__float__' (9) is longer than '__int__' (7) and '__str__' (7) but shorter than '__complex__' (11); no prior decimal_extra spec has asserted Decimal.__float__.__name__.__eq__('__float__'); prior specs covered __float__.__qualname__.__eq__('Decimal.__float__') and __float__.__qualname__.__len__()==17)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.__float__.__name__.__eq__"
  args: ["__float__"]
  expected: true

invariant decimal_extra115.Decimal.__complex___name_eq:
  description: "decimal.Decimal.__complex__.__name__ == '__complex__' (length 11; __name__ is the bare method name without the 'Decimal.' qualname prefix; Decimal.__complex__(self) converts the Decimal value to a Python complex number with zero imaginary part — for example, complex(Decimal('3.14')) produces (3.14+0j); Decimal.__complex__ is a method_descriptor (NOT a wrapper_descriptor), which is unusual among the Decimal conversion dunders: __int__, __float__, __str__, and __repr__ are all wrapper_descriptors from C slot entries, while __complex__ is defined via PyMethodDef; its __name__ '__complex__' (11 chars) is the longest among the five conversion method bare names; no prior decimal_extra spec has asserted Decimal.__complex__.__name__.__eq__('__complex__'); prior specs covered __complex__.__qualname__.__eq__('Decimal.__complex__') and __complex__.__qualname__.__len__()==19)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.__complex__.__name__.__eq__"
  args: ["__complex__"]
  expected: true

invariant decimal_extra115.Decimal.__str___name_eq:
  description: "decimal.Decimal.__str__.__name__ == '__str__' (length 7; __name__ is the bare method name without the 'Decimal.' qualname prefix; Decimal.__str__(self) returns the decimal string representation of the value — for example, str(Decimal('1.00')) is '1.00' (trailing zeros are preserved, unlike normalize()); Decimal.__str__ is a wrapper_descriptor (C slot wrapper for tp_str in Modules/_decimal/_decimal.c); its __name__ '__str__' (7 chars) differs from its __qualname__ 'Decimal.__str__' (15 chars) by the 8-char 'Decimal.' prefix; '__str__' (7) equals the length of '__int__' (7) — both use 3-char base names flanked by double underscores; no prior decimal_extra spec has asserted Decimal.__str__.__name__.__eq__('__str__'); prior specs covered __str__.__qualname__.__eq__('Decimal.__str__') and __str__.__qualname__.__len__()==15)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.__str__.__name__.__eq__"
  args: ["__str__"]
  expected: true

invariant decimal_extra115.Decimal.__repr___name_eq:
  description: "decimal.Decimal.__repr__.__name__ == '__repr__' (length 8; __name__ is the bare method name without the 'Decimal.' qualname prefix; Decimal.__repr__(self) returns a string with the 'Decimal(...)' format — for example, repr(Decimal('3.14')) is \"Decimal('3.14')\"; this distinguishes __repr__ from __str__ which returns just the digits; Decimal.__repr__ is a wrapper_descriptor (C slot wrapper for tp_repr in Modules/_decimal/_decimal.c); its __name__ '__repr__' (8 chars) differs from its __qualname__ 'Decimal.__repr__' (16 chars) by the 8-char 'Decimal.' prefix; '__repr__' (8) is longer than '__int__' (7) and '__str__' (7) but shorter than '__float__' (9) and '__complex__' (11); no prior decimal_extra spec has asserted Decimal.__repr__.__name__.__eq__('__repr__'); prior specs covered __repr__.__qualname__.__eq__('Decimal.__repr__') and __repr__.__qualname__.__len__()==16)"
  category: method_identity
  kind: python_call_eq
  function: "Decimal.__repr__.__name__.__eq__"
  args: ["__repr__"]
  expected: true
