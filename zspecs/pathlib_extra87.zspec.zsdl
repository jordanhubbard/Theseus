spec: pathlib_extra87
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra86."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for many methods; PurePath/__dict__ membership; Path/__dict__ membership; Path properties as descriptors; Path method co_name and co_argcount for open/read_text/write_text/iterdir/mkdir/rmdir/stat/lstat/exists/unlink/rename/resolve/absolute/expanduser."
    - "This spec covers: pathlib.PurePath.__name__; pathlib.PurePath.__module__; pathlib.PurePath.__bases__[0].__name__; pathlib.PurePath.__mro__.__len__(); pathlib.PurePosixPath.__name__; pathlib.PurePosixPath.__bases__[0].__name__; pathlib.PurePosixPath.__mro__.__len__(); pathlib.PureWindowsPath.__name__; pathlib.PureWindowsPath.__bases__[0].__name__; pathlib.PosixPath.__name__; pathlib.PosixPath.__bases__[0].__name__; pathlib.PosixPath.__mro__.__len__(); pathlib.Path.__init__.__code__.co_name and co_argcount; pathlib.Path.__new__.__code__.co_name and co_argcount."
    - "pathlib.PurePath.__name__ == 'PurePath' — top-level abstract base for all path flavors."
    - "pathlib.PurePath.__module__ == 'pathlib' — defined in the pathlib module."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' — PurePath has a single base: object."
    - "pathlib.PurePath.__mro__.__len__() == 2 — MRO is [PurePath, object]."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — extends PurePath."
    - "pathlib.PurePosixPath.__mro__.__len__() == 3 — MRO is [PurePosixPath, PurePath, object]."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — extends PurePath."
    - "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath extends Path."
    - "pathlib.PosixPath.__mro__.__len__() == 5 — MRO is [PosixPath, Path, PurePosixPath, PurePath, object]."
    - "pathlib.Path.__init__.__code__.co_argcount == 1 — __init__(self): self only; extra args are keyword-only or handled in __new__."
    - "pathlib.Path.__new__.__code__.co_argcount == 1 — __new__(cls): cls only."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePath class identity: __name__, __module__, __bases__[0].__name__, __mro__.__len__()
# PurePath is the abstract base; it has a single base (object), MRO length 2.
# Function values with [ must be double-quoted.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra87.PurePath_identity:
  description: "PurePath __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibextra87

  columns: [id, function, args, expected]
  rows:
    - [purepath_name,    PurePath.__name__.__eq__,                   ["PurePath"], true]
    - [purepath_module,  PurePath.__module__.__eq__,                 ["pathlib"],  true]
    - [purepath_base0,   "PurePath.__bases__[0].__name__.__eq__",    ["object"],   true]
    - [purepath_mro_len, PurePath.__mro__.__len__,                   [],           2]

# ---------------------------------------------------------------------------
# PurePosixPath and PureWindowsPath identity
# PurePosixPath.__bases__[0].__name__ == 'PurePath' (extends PurePath).
# PurePosixPath.__mro__.__len__() == 3 ([PurePosixPath, PurePath, object]).
# PureWindowsPath.__bases__[0].__name__ == 'PurePath'.
# Function values with [ must be double-quoted.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra87.PurePosixPath_PureWindowsPath_identity:
  description: "PurePosixPath and PureWindowsPath __name__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibextra87

  columns: [id, function, args, expected]
  rows:
    - [purepx_name,    PurePosixPath.__name__.__eq__,                  ["PurePosixPath"], true]
    - [purepx_base0,   "PurePosixPath.__bases__[0].__name__.__eq__",   ["PurePath"],      true]
    - [purepx_mro_len, PurePosixPath.__mro__.__len__,                  [],                3]
    - [purewx_name,    PureWindowsPath.__name__.__eq__,                ["PureWindowsPath"], true]
    - [purewx_base0,   "PureWindowsPath.__bases__[0].__name__.__eq__", ["PurePath"],        true]

# ---------------------------------------------------------------------------
# PosixPath identity
# PosixPath.__bases__[0].__name__ == 'Path' (extends Path, not PurePosixPath directly).
# PosixPath.__mro__.__len__() == 5 ([PosixPath, Path, PurePosixPath, PurePath, object]).
# Function values with [ must be double-quoted.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra87.PosixPath_identity:
  description: "PosixPath __name__, __bases__[0].__name__, and __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibextra87

  columns: [id, function, args, expected]
  rows:
    - [posixpath_name,    PosixPath.__name__.__eq__,                  ["PosixPath"], true]
    - [posixpath_base0,   "PosixPath.__bases__[0].__name__.__eq__",   ["Path"],      true]
    - [posixpath_mro_len, PosixPath.__mro__.__len__,                  [],            5]

# ---------------------------------------------------------------------------
# Path.__init__ and Path.__new__ __code__ attributes
# __init__(self): co_argcount == 1 (self only; keyword args handled elsewhere).
# __new__(cls): co_argcount == 1 (cls only).
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra87.Path_init_new_code:
  description: "Path.__init__ and Path.__new__ __code__.co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibextra87

  columns: [id, function, args, expected]
  rows:
    - [init_co_name, Path.__init__.__code__.co_name.__eq__,      ["__init__"], true]
    - [init_co_argc, Path.__init__.__code__.co_argcount.__eq__,  [1],          true]
    - [new_co_name,  Path.__new__.__code__.co_name.__eq__,       ["__new__"],  true]
    - [new_co_argc,  Path.__new__.__code__.co_argcount.__eq__,   [1],          true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra87.PurePath.name:
  description: "pathlib.PurePath.__name__ == 'PurePath' (abstract base for all path flavors)"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra87.PurePath.module:
  description: "pathlib.PurePath.__module__ == 'pathlib'"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra87.PurePath.mro_len:
  description: "pathlib.PurePath.__mro__.__len__() == 2 ([PurePath, object])"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__mro__.__len__
  args: []
  expected: 2

invariant pathlib_extra87.PosixPath.mro_len:
  description: "pathlib.PosixPath.__mro__.__len__() == 5 ([PosixPath, Path, PurePosixPath, PurePath, object])"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__mro__.__len__
  args: []
  expected: 5

invariant pathlib_extra87.Path_init.co_argcount:
  description: "pathlib.Path.__init__.__code__.co_argcount == 1 (self only)"
  category: code_attrs
  kind: python_call_eq
  function: Path.__init__.__code__.co_argcount.__eq__
  args: [1]
  expected: true
