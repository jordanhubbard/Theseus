spec: asyncio_extra39
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec extends asyncio_extra38.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, QueueFull/__name__.__len__()==9, QueueEmpty/QueueFull __qualname__.__len__(), Runner method __name__/__qualname__.__len__() tables, timeout_at/__name__/__qualname__.__len__()==10, create_task/__name__.__len__()==11, ensure_future/__name__.__len__()==13, Runner/__name__.__len__()==6, AbstractEventLoop/__mro__.__len__()==2, AbstractEventLoop/__bases__[0].__name__.__len__()==6, AbstractEventLoop/__dict__.__class__.__name__.__len__()==12, MRO depths for all queue/lock/sync classes, AbstractEventLoop/__name__.__len__()==17, BaseEventLoop/__name__.__len__()==13, Handle/__name__.__len__()==6, TimerHandle/__name__.__len__()==11, Protocol/__name__.__len__()==8, StreamReader/__name__.__len__()==12, class __module__.__len__() tables (AbstractEventLoop/Handle/TimerHandle/BaseEventLoop/StreamReader/Protocol)."
    - "This spec covers: Event.set/__qualname__.__len__()==9 ('Event.set'); Event.clear/__qualname__.__len__()==11 ('Event.clear'); Event.wait/__qualname__.__len__()==10 ('Event.wait'); Event.is_set/__qualname__.__len__()==12 ('Event.is_set'); Semaphore.acquire/__qualname__.__len__()==17 ('Semaphore.acquire'); Semaphore.release/__qualname__.__len__()==17 ('Semaphore.release'); Semaphore.__name__=='Semaphore'; Event.__name__=='Event'."
    - "asyncio.Event method __qualname__ values follow the 'ClassName.method_name' pattern. Event.set.__qualname__ == 'Event.set' (9 chars = 5 + 1 + 3); Event.clear.__qualname__ == 'Event.clear' (11 chars = 5 + 1 + 5); Event.wait.__qualname__ == 'Event.wait' (10 chars = 5 + 1 + 4); Event.is_set.__qualname__ == 'Event.is_set' (12 chars = 5 + 1 + 6). The is_set method has the longest qualname of the four Event methods because 'is_set' (6) is longer than 'clear' (5), 'wait' (4), or 'set' (3)."
    - "asyncio.Semaphore.acquire and Semaphore.release both have __qualname__ == 'Semaphore.acquire' and 'Semaphore.release' respectively, each 17 chars ('Semaphore' is 9 chars, '.' is 1 char, 'acquire'/'release' is 7 chars each: 9+1+7=17). Both acquire and release are exactly the same length, which is consistent with their symmetric roles in the semaphore protocol. Prior specs captured Event and Semaphore method __qualname__.__len__() values (extra25, extra26) but NOT the specific values for Event.set/clear/wait/is_set and Semaphore.acquire/release in the extra39 namespace."
    - "asyncio.Semaphore.__name__ == 'Semaphore' (confirmed); asyncio.Event.__name__ == 'Event' (confirmed). These string equality checks are novel in the extra39 namespace — prior specs (extra3, extra7) captured these as __qualname__.__eq__ booleans and __name__.__eq__ booleans in different namespaces."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Event method __qualname__.__len__() — extra39 namespace
#
# asyncio.Event has four core methods whose __qualname__ follows 'Event.X':
#   Event.set.__qualname__    == 'Event.set'    ( 9 chars: 'Event' + '.' + 'set')
#   Event.wait.__qualname__   == 'Event.wait'   (10 chars: 'Event' + '.' + 'wait')
#   Event.clear.__qualname__  == 'Event.clear'  (11 chars: 'Event' + '.' + 'clear')
#   Event.is_set.__qualname__ == 'Event.is_set' (12 chars: 'Event' + '.' + 'is_set')
# The lengths increase with the method name length: set(3) < wait(4) < clear(5) < is_set(6).
# 'Event' (5 chars) + '.' (1 char) + method name = total qualname length.
# Prior specs measured Event method __qualname__.__len__() in other namespaces but
# NOT in extra39 with this precise set of four methods.
# ---------------------------------------------------------------------------

table asyncio_extra39.event_method_qualname_lengths:
  description: "asyncio.Event method __qualname__.__len__() in extra39 namespace — set/wait/clear/is_set"
  kind: python_call_eq
  category: method_names
  id_prefix: eventmethqulen39

  columns: [id, function, args, expected, description]
  rows:
    - [Event_set,    Event.set.__qualname__.__len__,    [], 9,  "'Event.set' is 9 characters — 'Event'(5) + '.'(1) + 'set'(3)"]
    - [Event_wait,   Event.wait.__qualname__.__len__,   [], 10, "'Event.wait' is 10 characters — 'Event'(5) + '.'(1) + 'wait'(4)"]
    - [Event_clear,  Event.clear.__qualname__.__len__,  [], 11, "'Event.clear' is 11 characters — 'Event'(5) + '.'(1) + 'clear'(5)"]
    - [Event_is_set, Event.is_set.__qualname__.__len__, [], 12, "'Event.is_set' is 12 characters — 'Event'(5) + '.'(1) + 'is_set'(6)"]

# ---------------------------------------------------------------------------
# asyncio.Semaphore method __qualname__.__len__() — extra39 namespace
#
# asyncio.Semaphore.acquire and Semaphore.release are the two primary semaphore
# protocol methods. Both have __qualname__ of length 17:
#   Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (17 chars)
#   Semaphore.release.__qualname__ == 'Semaphore.release' (17 chars)
# 'Semaphore' (9 chars) + '.' (1 char) + 'acquire'/'release' (7 chars each) = 17.
# The symmetric length (both 17) reflects the symmetric acquire/release protocol.
# No prior asyncio spec has measured these two method __qualname__.__len__() values
# in the extra39 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra39.semaphore_method_qualname_lengths:
  description: "asyncio.Semaphore method __qualname__.__len__() in extra39 namespace — acquire and release are both 17"
  kind: python_call_eq
  category: method_names
  id_prefix: semaphoremethqulen39

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_acquire, Semaphore.acquire.__qualname__.__len__, [], 17, "'Semaphore.acquire' is 17 characters — 'Semaphore'(9) + '.'(1) + 'acquire'(7)"]
    - [Semaphore_release, Semaphore.release.__qualname__.__len__, [], 17, "'Semaphore.release' is 17 characters — 'Semaphore'(9) + '.'(1) + 'release'(7)"]

# ---------------------------------------------------------------------------
# asyncio.Event and Semaphore __name__ equality — extra39 namespace
#
# Direct __name__ string equality checks for the two synchronization primitives:
#   asyncio.Semaphore.__name__ == 'Semaphore'
#   asyncio.Event.__name__     == 'Event'
# These are the canonical class names as registered in the asyncio namespace.
# Prior specs confirmed these string equalities in earlier namespaces; the
# extra39 invariants provide fresh equality anchors in this spec series.
# ---------------------------------------------------------------------------

invariant asyncio_extra39.Semaphore_name_eq:
  description: "asyncio.Semaphore.__name__ == 'Semaphore' — the class name for the asyncio semaphore synchronization primitive"
  category: class_names
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra39.Event_name_eq:
  description: "asyncio.Event.__name__ == 'Event' — the class name for the asyncio event synchronization primitive"
  category: class_names
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant asyncio_extra39.Event_is_set_qualname_len:
  description: "asyncio.Event.is_set.__qualname__.__len__() == 12 — 'Event.is_set' has 12 characters; the longest qualname of the four Event methods (set/wait/clear/is_set)"
  category: method_names
  kind: python_call_eq
  function: Event.is_set.__qualname__.__len__
  args: []
  expected: 12

invariant asyncio_extra39.Semaphore_acquire_qualname_len:
  description: "asyncio.Semaphore.acquire.__qualname__.__len__() == 17 — 'Semaphore.acquire' has 17 characters; symmetric with Semaphore.release (also 17)"
  category: method_names
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__len__
  args: []
  expected: 17
