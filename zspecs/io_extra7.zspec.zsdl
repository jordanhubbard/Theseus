spec: io_extra7
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends prior io specs."
    - "Focus: class names and hierarchy for io classes not yet covered."
    - "io.RawIOBase, io.BufferedIOBase, io.TextIOBase are abstract base classes."
    - "io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom are concrete classes."
    - "io.TextIOWrapper is the concrete text wrapper."
    - "io.StringIO().__class__.__name__ == 'StringIO'."
    - "io.BytesIO().__class__.__name__ == 'BytesIO'."
    - "io.DEFAULT_BUFFER_SIZE == 8192."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table io_extra7.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [RawIOBase,      RawIOBase.__name__.__eq__,      ["RawIOBase"],      true]
    - [BufferedIOBase, BufferedIOBase.__name__.__eq__,  ["BufferedIOBase"],  true]
    - [TextIOBase,     TextIOBase.__name__.__eq__,     ["TextIOBase"],     true]
    - [FileIO,         FileIO.__name__.__eq__,         ["FileIO"],         true]
    - [BufferedReader, BufferedReader.__name__.__eq__,  ["BufferedReader"],  true]
    - [BufferedWriter, BufferedWriter.__name__.__eq__,  ["BufferedWriter"],  true]
    - [BufferedRandom, BufferedRandom.__name__.__eq__,  ["BufferedRandom"],  true]
    - [TextIOWrapper,  TextIOWrapper.__name__.__eq__,  ["TextIOWrapper"],  true]

table io_extra7.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [RawIOBase,      RawIOBase.__module__.__eq__,      ["io"], true]
    - [BufferedIOBase, BufferedIOBase.__module__.__eq__,  ["io"], true]
    - [TextIOBase,     TextIOBase.__module__.__eq__,     ["io"], true]
    - [FileIO,         FileIO.__module__.__eq__,         ["io"], true]
    - [BufferedReader, BufferedReader.__module__.__eq__,  ["io"], true]
    - [TextIOWrapper,  TextIOWrapper.__module__.__eq__,  ["io"], true]

invariant io_extra7.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 8192"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [8192]
  expected: true

invariant io_extra7.StringIO.instance_class:
  description: "io.StringIO().__class__.__name__ == 'StringIO'"
  category: StringIO
  kind: python_call_eq
  function: StringIO
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["StringIO"]
  expected: true

invariant io_extra7.BytesIO.instance_class:
  description: "io.BytesIO().__class__.__name__ == 'BytesIO'"
  category: BytesIO
  kind: python_call_eq
  function: BytesIO
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["BytesIO"]
  expected: true

invariant io_extra7.StringIO.readable:
  description: "io.StringIO('hello').readable.__func__.__name__ == 'readable'"
  category: StringIO
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: readable.__func__.__name__.__eq__
  method_args: ["readable"]
  expected: true

invariant io_extra7.BytesIO.readable_method_name:
  description: "io.BytesIO().readable.__name__ — verifying readable method exists"
  category: BytesIO
  kind: python_call_eq
  function: BytesIO
  args: []
  method: readable.__func__.__name__.__eq__
  method_args: ["readable"]
  expected: true

invariant io_extra7.UnsupportedOperation.class_name:
  description: "io.UnsupportedOperation.__name__ == 'UnsupportedOperation'"
  category: exceptions
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra7.UnsupportedOperation.module:
  description: "io.UnsupportedOperation.__module__ == 'io'"
  category: exceptions
  kind: python_call_eq
  function: UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true
