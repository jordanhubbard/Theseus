spec: re_extra119
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra118.zspec.zsdl."
    - "This spec covers: re.Scanner class identity not previously covered in any re_extra spec."
    - "re.Scanner is an undocumented internal class defined in Lib/re/__init__.py."
    - "re.Scanner.__name__ == 'Scanner' (len 7); __module__ == 're' (len 2)."
    - "re.Scanner.__mro__ has 2 entries: (Scanner, object) — minimal 2-entry MRO."
    - "re.Scanner.__bases__[0].__name__ == 'object' (direct subtype of object; no ABC layer)."
    - "re.Scanner.__class__.__name__ == 'type' (plain Python class, not EnumType or ABCMeta)."
    - "re.Scanner.scan.__qualname__ == 'Scanner.scan' (len 12)."
    - "re.Scanner.__init__.__qualname__ == 'Scanner.__init__' (len 16)."
    - "No prior re_extra spec has covered re.Scanner.__name__, __module__, __mro__, __bases__, or method qualnames."
    - "re.Scanner.__name__ len 7 == re.Pattern.__name__ len 7 (both named with 7 chars)."
    - "re.Scanner.__mro__.__len__() == 2 (minimal; same as re.Pattern and re.Match)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Scanner class identity: __name__, __module__, __class__.__name__
# re.Scanner is an undocumented pure-Python class defined in Lib/re/__init__.py.
# It provides a scanning/tokenizing interface: it takes a list of (pattern, action)
# pairs and a string, then repeatedly matches the patterns against the string,
# invoking the corresponding action for each match.
# __name__ == 'Scanner' (7 chars); __module__ == 're' (2 chars, the shortest module
# name in the re ecosystem). Its metaclass is plain 'type' (not EnumType).
# No prior re_extra spec has covered any re.Scanner attribute.
# ---------------------------------------------------------------------------

table re_extra119.Scanner_name_module_metaclass:
  description: "re.Scanner: __name__='Scanner'(7), __module__='re'(2), metaclass='type'; undocumented pure-Python tokenizer class in Lib/re/__init__.py; no prior re_extra spec covers Scanner identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: rescannm119a

  columns: [id, function, args, expected, description]
  rows:
    - [sc_name_eq,     "Scanner.__name__.__eq__",           ["Scanner"], true,  "re.Scanner.__name__ == 'Scanner' (7 chars; name of the internal scanning/tokenizing class in Lib/re/__init__.py)"]
    - [sc_name_len,    "Scanner.__name__.__len__",          [],          7,     "re.Scanner.__name__.__len__() == 7 ('Scanner' has 7 characters)"]
    - [sc_mod_eq,      "Scanner.__module__.__eq__",         ["re"],      true,  "re.Scanner.__module__ == 're' (2 chars; the public re module; Scanner is a pure-Python class defined in Lib/re/__init__.py, not a C extension type)"]
    - [sc_mod_len,     "Scanner.__module__.__len__",        [],          2,     "re.Scanner.__module__.__len__() == 2 ('re' has 2 characters; the shortest module name in the re type family)"]
    - [sc_cls_type,    "Scanner.__class__.__name__.__eq__", ["type"],    true,  "type(re.Scanner).__name__ == 'type' (plain Python class; no EnumType or ABCMeta metaclass; contrast with RegexFlag which uses 'EnumType')"]
    - [sc_name_ne_mod, "Scanner.__name__.__eq__",           ["re"],      false, "re.Scanner.__name__ != 're' (the class name is 'Scanner'(7), not the module name 're'(2))"]
    - [sc_name_gt_mod, "Scanner.__name__.__len__.__gt__",   [2],         true,  "len('Scanner') > len('re') (7 > 2; the class name is 3.5x longer than the module name)"]

# ---------------------------------------------------------------------------
# re.Scanner MRO: minimal 2-entry chain (Scanner, object)
# re.Scanner.__mro__ == (Scanner, object) — 2 entries.
# This is the minimal MRO for a direct subtype of object.
# Scanner does not participate in any ABC hierarchy; it is a standalone utility class.
# re.Scanner.__bases__[0].__name__ == 'object' (single direct base).
# The 2-entry MRO is shared by re.Pattern and re.Match (also direct object subtypes).
# No prior re_extra spec has covered Scanner.__mro__.__len__() or Scanner.__bases__.
# ---------------------------------------------------------------------------

table re_extra119.Scanner_mro_and_bases:
  description: "re.Scanner.__mro__ has 2 entries: [0]='Scanner'(7),[1]='object'(6); __bases__[0].__name__=='object'; minimal MRO bypasses all ABCs; same 2-entry structure as re.Pattern and re.Match"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: rescannmro119b

  columns: [id, function, args, expected, description]
  rows:
    - [sc_mro_len,    "Scanner.__mro__.__len__",                 [],          2,     "re.Scanner.__mro__.__len__() == 2 (Scanner, object; minimal 2-entry MRO for a direct subtype of object)"]
    - [sc_mro0_name,  "Scanner.__mro__[0].__name__.__eq__",      ["Scanner"], true,  "re.Scanner.__mro__[0].__name__ == 'Scanner' (the class itself is always first in its own MRO)"]
    - [sc_mro1_name,  "Scanner.__mro__[1].__name__.__eq__",      ["object"],  true,  "re.Scanner.__mro__[1].__name__ == 'object' (universal Python base class; Scanner is a direct subtype of object)"]
    - [sc_mro1_len,   "Scanner.__mro__[1].__name__.__len__",     [],          6,     "re.Scanner.__mro__[1].__name__.__len__() == 6 ('object' has 6 characters)"]
    - [sc_base0_name, "Scanner.__bases__[0].__name__.__eq__",    ["object"],  true,  "re.Scanner.__bases__[0].__name__ == 'object' (single direct base; Scanner inherits only from object with no ABC layer)"]
    - [sc_mro1_ne_sc, "Scanner.__mro__[1].__name__.__eq__",      ["Scanner"], false, "re.Scanner.__mro__[1].__name__ != 'Scanner' (slot 1 is 'object', not 'Scanner'; the class itself is at slot 0)"]
    - [sc_mro_not_7,  "Scanner.__mro__.__len__.__eq__",          [2],         true,  "re.Scanner.__mro__.__len__() == 2 (not 7; contrast with re.RegexFlag which has 7-entry MRO through IntFlag/int/Enum chain)"]

# ---------------------------------------------------------------------------
# re.Scanner method qualnames: scan and __init__
# Scanner.scan.__qualname__ == 'Scanner.scan' (12 chars).
# Scanner.__init__.__qualname__ == 'Scanner.__init__' (16 chars).
# scan is the main public method: it tokenizes a string, calling action callables
# for each match. __init__ accepts lexicon (list of (pattern, action) pairs) and flags.
# scan.__class__.__name__ == 'function' (pure Python, not method_descriptor).
# No prior re_extra spec has covered Scanner.scan or Scanner.__init__ qualnames.
# ---------------------------------------------------------------------------

table re_extra119.Scanner_method_qualnames:
  description: "re.Scanner.scan.__qualname__='Scanner.scan'(12); __init__.__qualname__='Scanner.__init__'(16); both plain Python functions (not C method_descriptors); novel for all re_extra specs"
  kind: python_call_eq
  category: method_identity
  id_prefix: rescannmeth119c

  columns: [id, function, args, expected, description]
  rows:
    - [sc_scan_qn_eq,   "Scanner.scan.__qualname__.__eq__",          ["Scanner.scan"],    true,  "re.Scanner.scan.__qualname__ == 'Scanner.scan' (12 chars; scan is the tokenizing method that repeatedly matches the lexicon against the remaining string)"]
    - [sc_scan_qn_len,  "Scanner.scan.__qualname__.__len__",         [],                  12,    "re.Scanner.scan.__qualname__.__len__() == 12 ('Scanner.scan' has 12 characters: 'Scanner.'(8)+'scan'(4)==12)"]
    - [sc_init_qn_eq,   "Scanner.__init__.__qualname__.__eq__",      ["Scanner.__init__"], true, "re.Scanner.__init__.__qualname__ == 'Scanner.__init__' (16 chars; __init__ takes lexicon and flags; initializes pattern list and compiled scanner)"]
    - [sc_init_qn_len,  "Scanner.__init__.__qualname__.__len__",     [],                  16,    "re.Scanner.__init__.__qualname__.__len__() == 16 ('Scanner.__init__' has 16 characters: 'Scanner.'(8)+'__init__'(8)==16)"]
    - [sc_init_gt_scan, "Scanner.__init__.__qualname__.__len__.__gt__", [12],              true,  "len('Scanner.__init__') > len('Scanner.scan') (16 > 12; '__init__'(8) is 4 chars longer than 'scan'(4))"]
    - [sc_scan_type,    "Scanner.scan.__class__.__name__.__eq__",    ["function"],        true,  "type(re.Scanner.scan).__name__ == 'function' (scan is a plain Python function defined in Lib/re/__init__.py; not a C method_descriptor like Pattern.match or Pattern.search)"]
    - [sc_init_type,    "Scanner.__init__.__class__.__name__.__eq__", ["function"],       true,  "type(re.Scanner.__init__).__name__ == 'function' (Scanner.__init__ is a plain Python function; same class as scan)"]
    - [sc_scan_ne_init, "Scanner.scan.__qualname__.__eq__",          ["Scanner.__init__"], false, "re.Scanner.scan.__qualname__ != 'Scanner.__init__' (distinct methods with distinct qualnames: 'Scanner.scan'(12) vs 'Scanner.__init__'(16))"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra119.Scanner.name_eq_Scanner:
  description: "re.Scanner.__name__ == 'Scanner' (length 7; re.Scanner is an undocumented pure-Python scanning/tokenizing class in Lib/re/__init__.py; it accepts a lexicon — a list of (pattern, action) pairs — and a string, and repeatedly applies the patterns to the remaining text, invoking the corresponding action callable for each match found; despite being undocumented, re.Scanner is publicly accessible as re.Scanner; its __name__ is 'Scanner' — the same length as 'Pattern' and longer than 'Match'(5); no prior re_extra spec has ever referenced re.Scanner in any test vector; this invariant is the first assertion about re.Scanner)"
  category: class_identity
  kind: python_call_eq
  function: "Scanner.__name__.__eq__"
  args: ["Scanner"]
  expected: true

invariant re_extra119.Scanner.module_eq_re:
  description: "re.Scanner.__module__ == 're' (length 2; Scanner is a pure-Python class defined in Lib/re/__init__.py and exported from the public 're' module; unlike the C extension types re.Pattern and re.Match — which have __module__ == 're' as well but are implemented in Modules/_sre.c — Scanner is implemented purely in Python; both the C types and the pure-Python Scanner share __module__ == 're'; 're' (2 chars) is the shortest module name in the re type family; no prior re_extra spec has verified Scanner.__module__)"
  category: class_identity
  kind: python_call_eq
  function: "Scanner.__module__.__eq__"
  args: ["re"]
  expected: true

invariant re_extra119.Scanner.mro_len_2:
  description: "re.Scanner.__mro__.__len__() == 2 (the MRO is (Scanner, object) — the minimal 2-entry chain for a direct subtype of object; Scanner does not participate in any ABC hierarchy and has no intermediate base classes; this 2-entry structure is shared by re.Pattern and re.Match (both also have MRO length 2); contrast with re.RegexFlag which has 7 entries through the IntFlag/int/Enum chain and re.PatternError which has 4 entries through the Exception chain; no prior re_extra spec has checked Scanner.__mro__.__len__())"
  category: class_hierarchy
  kind: python_call_eq
  function: "Scanner.__mro__.__len__"
  args: []
  expected: 2

invariant re_extra119.Scanner.scan_qualname_eq:
  description: "re.Scanner.scan.__qualname__ == 'Scanner.scan' (length 12; scan is the main public method of re.Scanner; it takes a string argument and repeatedly matches the compiled patterns from the lexicon against the remaining input, invoking the corresponding action callable for each match; the scan loop continues until no pattern matches the remaining text; scan is a plain Python function (not a C method_descriptor), so its __class__.__name__ == 'function'; its qualname 'Scanner.scan' uses the 'Scanner.' prefix (8 chars) followed by 'scan' (4 chars) totalling 12; no prior re_extra spec has asserted any attribute of Scanner.scan)"
  category: method_identity
  kind: python_call_eq
  function: "Scanner.scan.__qualname__.__eq__"
  args: ["Scanner.scan"]
  expected: true

invariant re_extra119.Scanner.bases0_is_object:
  description: "re.Scanner.__bases__[0].__name__ == 'object' (re.Scanner is a direct subtype of object with no intermediate base class; __bases__ contains exactly one entry — object — meaning Scanner is not part of any ABC hierarchy or type chain; this is consistent with Scanner's standalone utility role as a tokenizer; its MRO is (Scanner, object) — the minimal 2-entry chain; compare with re.RegexFlag whose __bases__[0] is 'IntFlag' (7 chars) from the enum module, and re.PatternError whose __bases__[0] is 'Exception' (9 chars); no prior re_extra spec has verified Scanner.__bases__[0].__name__)"
  category: class_hierarchy
  kind: python_call_eq
  function: "Scanner.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
