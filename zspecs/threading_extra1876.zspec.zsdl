spec: threading_extra1876
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "threading module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party threading extensions"
  notes:
    - "threading.local overrides __getattribute__ to provide thread-local storage semantics"
    - "Thread.daemon, ident, native_id, and name are properties defined in Thread.__dict__"
    - "Barrier.parties, n_waiting, and broken are properties defined in Barrier.__dict__"
    - "setDaemon and setName are deprecated aliases still present in Thread.__dict__"
  created_at: "2026-04-12"

table threading_extra1876.attr_access_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["th1876-aa-001", "threading.Thread.__dict__.__contains__", ["__getattr__"], false]
    - ["th1876-aa-002", "threading.Thread.__dict__.__contains__", ["__setattr__"], false]
    - ["th1876-aa-003", "threading.Thread.__dict__.__contains__", ["__delattr__"], false]
    - ["th1876-aa-004", "threading.Thread.__dict__.__contains__", ["__getattribute__"], false]
    - ["th1876-aa-005", "threading.Event.__dict__.__contains__", ["__getattr__"], false]
    - ["th1876-aa-006", "threading.Condition.__dict__.__contains__", ["__getattr__"], false]
