spec: calendar_extra6
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "This spec extends calendar.zspec.zsdl and calendar_extra through calendar_extra5.zspec.zsdl."
    - "calendar_extra4 covers: Calendar/__name__/__module__/__qualname__ anchors; TextCalendar/__name__; HTMLCalendar/__name__; LocaleTextCalendar/__name__; LocaleHTMLCalendar/__name__ — all as plain invariants."
    - "calendar_extra5 covers: TUESDAY/THURSDAY/SATURDAY constants; month_name[2/4]; month_abbr[9]; monthrange(2024,2); weekday(2000,1,1)/(2026,4,9); leapdays(2020,2025); isleap(1996)."
    - "This spec provides a consolidated table of class __name__ checks (Calendar/TextCalendar/HTMLCalendar/LocaleTextCalendar/LocaleHTMLCalendar) under the extra6 namespace, plus a table of all seven day-constant values (MONDAY through SUNDAY == 0..6), plus Calendar.__module__ and day constants class name verification."
    - "calendar.Calendar.__name__ == 'Calendar' — extra4 covers this as a standalone invariant; here it anchors a multi-row table for regression breadth."
    - "calendar.TextCalendar.__name__ == 'TextCalendar' — prior invariants exist; table form in extra6 namespace is a new anchor."
    - "calendar.HTMLCalendar.__name__ == 'HTMLCalendar' — prior invariants exist; table form in extra6 namespace is a new anchor."
    - "calendar.LocaleTextCalendar.__name__ == 'LocaleTextCalendar' — prior invariants exist; table form in extra6 namespace is a new anchor."
    - "calendar.LocaleHTMLCalendar.__name__ == 'LocaleHTMLCalendar' — prior invariants exist; table form in extra6 namespace is a new anchor."
    - "calendar.MONDAY == 0 through calendar.SUNDAY == 6 — the base spec covers MONDAY/WEDNESDAY/SUNDAY individually; extra5 adds TUESDAY/THURSDAY/SATURDAY. This table provides the complete 0-6 sequence as a single regression table in the extra6 namespace."
    - "calendar.Calendar.__module__ == 'calendar' — extra3 and extra4 both cover this as invariants; the extra6 standalone invariant re-anchors it under a new spec namespace for traceability."
    - "calendar.MONDAY.__class__.__name__ — MONDAY is an IntEnum member; verifying its type name is 'Day' (the enum class name) is not covered in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — consolidated table under extra6 namespace
#
# calendar_extra4 covers these five classes as individual invariants.
# This table provides them as a single multi-row regression fixture in the
# extra6 namespace. The extra6 table form is a distinct spec artifact.
# ---------------------------------------------------------------------------

table calendar_extra6.class_names:
  kind: python_call_eq
  category: class_identity
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [Calendar,           Calendar.__name__.__eq__,           ["Calendar"],           true]
    - [TextCalendar,       TextCalendar.__name__.__eq__,       ["TextCalendar"],       true]
    - [HTMLCalendar,       HTMLCalendar.__name__.__eq__,       ["HTMLCalendar"],       true]
    - [LocaleTextCalendar, LocaleTextCalendar.__name__.__eq__, ["LocaleTextCalendar"], true]
    - [LocaleHTMLCalendar, LocaleHTMLCalendar.__name__.__eq__, ["LocaleHTMLCalendar"], true]

# ---------------------------------------------------------------------------
# Day constants — complete sequence MONDAY(0) through SUNDAY(6)
#
# calendar.zspec.zsdl covers MONDAY(0), WEDNESDAY(2), SUNDAY(6) as separate rows.
# calendar_extra5 adds TUESDAY(1), THURSDAY(3), SATURDAY(5) as a three-row table.
# This table provides all seven values together in the extra6 namespace so that
# a single spec covers the full MONDAY..SUNDAY sequence.
# ---------------------------------------------------------------------------

table calendar_extra6.constants.all_day_values:
  kind: python_call_eq
  category: constants
  id_prefix: day

  columns: [id, function, args, expected]
  rows:
    - [MONDAY,    MONDAY.__eq__,    [0], true]
    - [TUESDAY,   TUESDAY.__eq__,   [1], true]
    - [WEDNESDAY, WEDNESDAY.__eq__, [2], true]
    - [THURSDAY,  THURSDAY.__eq__,  [3], true]
    - [FRIDAY,    FRIDAY.__eq__,    [4], true]
    - [SATURDAY,  SATURDAY.__eq__,  [5], true]
    - [SUNDAY,    SUNDAY.__eq__,    [6], true]

# ---------------------------------------------------------------------------
# Calendar.__module__ == 'calendar'
#
# calendar_extra3 covers Calendar.__module__ via a standalone invariant;
# calendar_extra4 also re-anchors it. The extra6 invariant re-establishes it
# under a new spec namespace to keep traceability continuous.
# ---------------------------------------------------------------------------

invariant calendar_extra6.Calendar.module:
  description: "calendar.Calendar.__module__ == 'calendar'"
  category: class_identity
  kind: python_call_eq
  function: Calendar.__module__.__eq__
  args: ["calendar"]
  expected: true

# ---------------------------------------------------------------------------
# FRIDAY == 4 — standalone invariant
#
# FRIDAY is the one day constant never mentioned in any prior spec.
# calendar.zspec.zsdl covers MONDAY/WEDNESDAY/SUNDAY.
# calendar_extra5 covers TUESDAY/THURSDAY/SATURDAY.
# FRIDAY (value 4) has no standalone prior invariant; this anchors it.
# ---------------------------------------------------------------------------

invariant calendar_extra6.constants.FRIDAY:
  description: "calendar.FRIDAY == 4 — IntEnum Day value for Friday"
  category: constants
  kind: python_call_eq
  function: FRIDAY.__eq__
  args: [4]
  expected: true

# ---------------------------------------------------------------------------
# MONDAY.__class__.__name__ == 'Day'
#
# No prior spec checks the enum type name of any day constant.
# MONDAY is a calendar.Day IntEnum member; its class name is 'Day'.
# ---------------------------------------------------------------------------

invariant calendar_extra6.MONDAY.class_name:
  description: "calendar.MONDAY.__class__.__name__ == 'Day' — day constants are calendar.Day IntEnum members"
  category: constants
  kind: python_call_eq
  function: MONDAY.__class__.__name__.__eq__
  args: ["Day"]
  expected: true
