spec: io3136
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 656 (io3136): __call__, __len__, __getitem__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper, io.IOBase."
    - "No io class defines __call__ in its own __dict__: io stream classes are not callable types."
    - "No io class defines __len__ in its own __dict__: io stream classes do not implement length."
    - "No io class defines __getitem__ in its own __dict__: io stream classes do not implement subscript access."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __call__ dict-presence — operator.contains(Cls.__dict__, '__call__')
#
# No io class defines __call__ in its own __dict__; all false.
# io stream classes are I/O abstractions, not callable objects.
# ---------------------------------------------------------------------------

table io3136.call:
  description: "io types __call__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3136

  columns: [id, function, args, expected]
  rows:
