spec: uuid_extra278
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid.UUID class method and property identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "UUID.int is a member_descriptor (slot), not a property — unlike hex, bytes, etc."
    - "All dunder methods (__init__, __str__, __repr__, __hash__, __eq__, __lt__, __int__) have expected __qualname__ values"
    - "UUID.urn, UUID.node, UUID.version, UUID.variant, UUID.fields, UUID.time_low are all properties"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra278.method_qualnames:
  description: "uuid.UUID dunder method __qualname__ values"
  kind: python_call_eq
  category: identity
  id_prefix: ue278

  columns: [id, function, args, expected, description]
  rows:
    - [ue278_001, uuid.UUID.__init__.__qualname__, [], "UUID.__init__", "__init__ qualname"]
    - [ue278_002, uuid.UUID.__str__.__qualname__, [], "UUID.__str__", "__str__ qualname"]
    - [ue278_003, uuid.UUID.__repr__.__qualname__, [], "UUID.__repr__", "__repr__ qualname"]
    - [ue278_004, uuid.UUID.__hash__.__qualname__, [], "UUID.__hash__", "__hash__ qualname"]
    - [ue278_005, uuid.UUID.__eq__.__qualname__, [], "UUID.__eq__", "__eq__ qualname"]
    - [ue278_006, uuid.UUID.__lt__.__qualname__, [], "UUID.__lt__", "__lt__ qualname"]
    - [ue278_007, uuid.UUID.__int__.__qualname__, [], "UUID.__int__", "__int__ qualname"]

table uuid_extra278.property_class_names:
  description: "uuid.UUID descriptor class names for properties and member slots"
  kind: python_call_eq
  category: identity
  id_prefix: ue278p

  columns: [id, function, args, expected, description]
  rows:
    - [ue278p_001, uuid.UUID.hex.__class__.__name__, [], property, "UUID.hex is a property"]
    - [ue278p_002, uuid.UUID.bytes.__class__.__name__, [], property, "UUID.bytes is a property"]
    - [ue278p_003, uuid.UUID.bytes_le.__class__.__name__, [], property, "UUID.bytes_le is a property"]
    - [ue278p_004, uuid.UUID.fields.__class__.__name__, [], property, "UUID.fields is a property"]
    - [ue278p_005, uuid.UUID.time_low.__class__.__name__, [], property, "UUID.time_low is a property"]
    - [ue278p_006, uuid.UUID.version.__class__.__name__, [], property, "UUID.version is a property"]
    - [ue278p_007, uuid.UUID.variant.__class__.__name__, [], property, "UUID.variant is a property"]
    - [ue278p_008, uuid.UUID.urn.__class__.__name__, [], property, "UUID.urn is a property"]
    - [ue278p_009, uuid.UUID.node.__class__.__name__, [], property, "UUID.node is a property"]
    - [ue278p_010, uuid.UUID.int.__class__.__name__, [], member_descriptor, "UUID.int is a member_descriptor (slot)"]

invariant uuid_extra278.init_qualname:
  description: "UUID.__init__ qualname is 'UUID.__init__'"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__init__.__qualname__
  args: []
  expected: "UUID.__init__"

invariant uuid_extra278.str_qualname:
  description: "UUID.__str__ qualname is 'UUID.__str__'"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__str__.__qualname__
  args: []
  expected: "UUID.__str__"

invariant uuid_extra278.hex_is_property:
  description: "UUID.hex is a property descriptor"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.hex.__class__.__name__
  args: []
  expected: property

invariant uuid_extra278.int_is_member_descriptor:
  description: "UUID.int is a member_descriptor (not a property)"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.int.__class__.__name__
  args: []
  expected: member_descriptor
