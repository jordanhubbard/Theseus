spec: io_extra116
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec extends io_extra115.zspec.zsdl."
    - "This spec covers: io.IOBase method qualnames for close, flush, readable, writable, seekable, readline, readlines, and tell."
    - "All IOBase methods use the '_IOBase.' prefix in their __qualname__ because IOBase is implemented as _io._IOBase in C."
    - "io.IOBase.close.__qualname__ == '_IOBase.close' (len 13); flush == '_IOBase.flush' (13)."
    - "io.IOBase.readable.__qualname__ == '_IOBase.readable' (16); writable == '_IOBase.writable' (16)."
    - "io.IOBase.seekable.__qualname__ == '_IOBase.seekable' (16); readline == '_IOBase.readline' (16)."
    - "io.IOBase.readlines.__qualname__ == '_IOBase.readlines' (17; longest in this group)."
    - "io.IOBase.tell.__qualname__ == '_IOBase.tell' (12; shortest in this group)."
    - "All IOBase methods have type 'method_descriptor' (C extension tp_methods entries)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase.close and io.IOBase.flush qualnames
# Both use '_IOBase.' prefix (not 'IOBase.') because the C implementation
# lives in _io._IOBase. Each qualname is 13 chars.
# close: '_IOBase.close' (13); flush: '_IOBase.flush' (13).
# Both are 'method_descriptor' (C extension tp_methods entries).
# ---------------------------------------------------------------------------

table io_extra116.IOBase_close_flush_qualnames:
  description: "io.IOBase.close and flush __qualname__: both '_IOBase.close'(13) and '_IOBase.flush'(13); '_IOBase.' prefix reflects C implementation in _io._IOBase; both are method_descriptor"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobase116a

  columns: [id, function, args, expected, description]
  rows:
    - [close_type,       "IOBase.close.__class__.__name__.__eq__",     ["method_descriptor"], true,  "type(io.IOBase.close).__name__ == 'method_descriptor' (C extension tp_methods entry)"]
    - [close_qn_eq,      "IOBase.close.__qualname__.__eq__",           ["_IOBase.close"],     true,  "io.IOBase.close.__qualname__ == '_IOBase.close' ('_IOBase.' prefix reflects _io._IOBase C type)"]
    - [close_qn_len,     "IOBase.close.__qualname__.__len__",          [],                    13,    "io.IOBase.close.__qualname__.__len__() == 13 ('_IOBase.close' has 13 chars)"]
    - [flush_type,       "IOBase.flush.__class__.__name__.__eq__",     ["method_descriptor"], true,  "type(io.IOBase.flush).__name__ == 'method_descriptor'"]
    - [flush_qn_eq,      "IOBase.flush.__qualname__.__eq__",           ["_IOBase.flush"],     true,  "io.IOBase.flush.__qualname__ == '_IOBase.flush'"]
    - [flush_qn_len,     "IOBase.flush.__qualname__.__len__",          [],                    13,    "io.IOBase.flush.__qualname__.__len__() == 13 ('_IOBase.flush' has 13 chars; same length as close)"]
    - [close_ne_iobase,  "IOBase.close.__qualname__.__eq__",           ["IOBase.close"],      false, "io.IOBase.close.__qualname__ != 'IOBase.close' (C type uses '_IOBase.' not 'IOBase.' prefix)"]
    - [close_eq_flush_len, "IOBase.close.__qualname__.__len__.__eq__", [13],                  true,  "len('_IOBase.close') == len('_IOBase.flush') == 13 (close and flush share identical qualname length)"]

# ---------------------------------------------------------------------------
# io.IOBase.readable, writable, seekable, readline qualnames
# All four use '_IOBase.' prefix and are 16 chars long.
# readable: '_IOBase.readable' (16); writable: '_IOBase.writable' (16).
# seekable: '_IOBase.seekable' (16); readline: '_IOBase.readline' (16).
# All are 'method_descriptor' types.
# ---------------------------------------------------------------------------

table io_extra116.IOBase_readable_writable_seekable_readline_qualnames:
  description: "io.IOBase readable/writable/seekable/readline __qualname__: all '_IOBase.<method>'(16 chars each); these are the abstract capability-query and line-reading methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobase116b

  columns: [id, function, args, expected, description]
  rows:
    - [readable_qn_eq,   "IOBase.readable.__qualname__.__eq__",    ["_IOBase.readable"],  true,  "io.IOBase.readable.__qualname__ == '_IOBase.readable' (16 chars; returns False by default in IOBase)"]
    - [readable_qn_len,  "IOBase.readable.__qualname__.__len__",   [],                    16,    "io.IOBase.readable.__qualname__.__len__() == 16 ('_IOBase.readable' has 16 chars)"]
    - [writable_qn_eq,   "IOBase.writable.__qualname__.__eq__",    ["_IOBase.writable"],  true,  "io.IOBase.writable.__qualname__ == '_IOBase.writable' (16 chars; returns False by default in IOBase)"]
    - [writable_qn_len,  "IOBase.writable.__qualname__.__len__",   [],                    16,    "io.IOBase.writable.__qualname__.__len__() == 16 ('_IOBase.writable' has 16 chars; same as readable)"]
    - [seekable_qn_eq,   "IOBase.seekable.__qualname__.__eq__",    ["_IOBase.seekable"],  true,  "io.IOBase.seekable.__qualname__ == '_IOBase.seekable' (16 chars; returns False by default in IOBase)"]
    - [seekable_qn_len,  "IOBase.seekable.__qualname__.__len__",   [],                    16,    "io.IOBase.seekable.__qualname__.__len__() == 16 ('_IOBase.seekable' has 16 chars; same as readable and writable)"]
    - [readline_qn_eq,   "IOBase.readline.__qualname__.__eq__",    ["_IOBase.readline"],  true,  "io.IOBase.readline.__qualname__ == '_IOBase.readline' (16 chars; reads a single line)"]
    - [readline_qn_len,  "IOBase.readline.__qualname__.__len__",   [],                    16,    "io.IOBase.readline.__qualname__.__len__() == 16 ('_IOBase.readline' has 16 chars; same as capability methods)"]
    - [readable_eq_writable_len, "IOBase.readable.__qualname__.__len__.__eq__", [16],     true,  "len('_IOBase.readable') == len('_IOBase.writable') == len('_IOBase.seekable') == len('_IOBase.readline') == 16"]

# ---------------------------------------------------------------------------
# io.IOBase.readlines and io.IOBase.tell qualnames
# readlines: '_IOBase.readlines' (17 chars; longest IOBase method qualname here).
# tell: '_IOBase.tell' (12 chars; shortest IOBase method qualname here).
# Both are 'method_descriptor' types.
# ---------------------------------------------------------------------------

table io_extra116.IOBase_readlines_tell_qualnames:
  description: "io.IOBase.readlines='_IOBase.readlines'(17) and tell='_IOBase.tell'(12); readlines is longest, tell is shortest among IOBase methods examined"
  kind: python_call_eq
  category: qualnames
  id_prefix: iobase116c

  columns: [id, function, args, expected, description]
  rows:
    - [readlines_type,    "IOBase.readlines.__class__.__name__.__eq__",  ["method_descriptor"], true,  "type(io.IOBase.readlines).__name__ == 'method_descriptor' (C extension tp_methods entry)"]
    - [readlines_qn_eq,   "IOBase.readlines.__qualname__.__eq__",        ["_IOBase.readlines"], true,  "io.IOBase.readlines.__qualname__ == '_IOBase.readlines' (17 chars; longest IOBase method qualname)"]
    - [readlines_qn_len,  "IOBase.readlines.__qualname__.__len__",       [],                    17,    "io.IOBase.readlines.__qualname__.__len__() == 17 ('_IOBase.readlines' has 17 chars; one longer than readable/writable/seekable/readline)"]
    - [tell_type,         "IOBase.tell.__class__.__name__.__eq__",       ["method_descriptor"], true,  "type(io.IOBase.tell).__name__ == 'method_descriptor'"]
    - [tell_qn_eq,        "IOBase.tell.__qualname__.__eq__",             ["_IOBase.tell"],      true,  "io.IOBase.tell.__qualname__ == '_IOBase.tell' (12 chars; shortest IOBase method qualname)"]
    - [tell_qn_len,       "IOBase.tell.__qualname__.__len__",            [],                    12,    "io.IOBase.tell.__qualname__.__len__() == 12 ('_IOBase.tell' has 12 chars; shortest in this group)"]
    - [readlines_gt_readline, "IOBase.readlines.__qualname__.__len__.__gt__", [16],             true,  "len('_IOBase.readlines') > len('_IOBase.readline') (17 > 16; readlines is one char longer than readline)"]
    - [tell_lt_close,     "IOBase.tell.__qualname__.__len__.__lt__",     [13],                  true,  "len('_IOBase.tell') < len('_IOBase.close') (12 < 13; tell is the shortest IOBase method qualname)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra116.IOBase.close_qualname:
  description: "io.IOBase.close.__qualname__ == '_IOBase.close' (length 13; the '_IOBase.' prefix is 8 chars and 'close' adds 5; the underscore-prefixed class name reflects the C implementation type _io._IOBase; accessing as io.IOBase exposes the same C type)"
  category: qualnames
  kind: python_call_eq
  function: "IOBase.close.__qualname__.__eq__"
  args: ["_IOBase.close"]
  expected: true

invariant io_extra116.IOBase.readable_qualname_len:
  description: "io.IOBase.readable.__qualname__.__len__() == 16 ('_IOBase.readable' has 16 characters; along with writable, seekable, and readline they all share this same length of 16 — the '_IOBase.' prefix (8) plus 8-char method names)"
  category: qualnames
  kind: python_call_eq
  function: "IOBase.readable.__qualname__.__len__"
  args: []
  expected: 16

invariant io_extra116.IOBase.readlines_qualname_len:
  description: "io.IOBase.readlines.__qualname__.__len__() == 17 ('_IOBase.readlines' has 17 characters; it is the longest IOBase method qualname among the methods examined; '_IOBase.' (8) + 'readlines' (9) == 17; one char longer than readline/readable/writable/seekable at 16)"
  category: qualnames
  kind: python_call_eq
  function: "IOBase.readlines.__qualname__.__len__"
  args: []
  expected: 17

invariant io_extra116.IOBase.tell_qualname_len:
  description: "io.IOBase.tell.__qualname__.__len__() == 12 ('_IOBase.tell' has 12 characters; it is the shortest IOBase method qualname among the methods examined; '_IOBase.' (8) + 'tell' (4) == 12; shorter than close/flush at 13)"
  category: qualnames
  kind: python_call_eq
  function: "IOBase.tell.__qualname__.__len__"
  args: []
  expected: 12

invariant io_extra116.IOBase.seekable_type_method_descriptor:
  description: "type(io.IOBase.seekable).__name__ == 'method_descriptor' (all IOBase abstract methods — close, flush, readable, writable, seekable, readline, readlines, tell — are C extension method_descriptor objects when accessed on the class; they return False by default for the capability queries)"
  category: class_names
  kind: python_call_eq
  function: "IOBase.seekable.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true
