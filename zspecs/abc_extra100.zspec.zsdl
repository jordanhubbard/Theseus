spec: abc_extra100
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra99.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc update_abstractmethods code attributes, ABCMeta.__prepare__ qualname, ABC/__subclasshook__ qualnames, and get_cache_token identity. NEW in extra100: abc.update_abstractmethods.__code__.co_name=='update_abstractmethods' (co_argcount=1); abc.update_abstractmethods.__qualname__=='update_abstractmethods' (len=22); abc.update_abstractmethods.__module__=='abc'; abc.ABCMeta.__prepare__.__qualname__=='ABCMeta.__prepare__' (len=19); type(abc.ABCMeta.__prepare__).__name__=='builtin_function_or_method' (C-level); abc.ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20); type(abc.ABC.__subclasshook__).__name__=='builtin_function_or_method'; abc.get_cache_token.__qualname__=='get_cache_token' (len=15); abc.get_cache_token.__module__=='_abc' (C-extension); type(abc.get_cache_token).__name__=='builtin_function_or_method'; abc.abstractmethod.__class__.__name__=='function' (Python-defined in abc.py). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__module__ == '_abc'. get_cache_token is implemented in C (_abc extension module), so its __module__ is '_abc', not 'abc'. This contrasts with abc.update_abstractmethods and abc.abstractmethod whose __module__ is 'abc' (Python-defined in Lib/abc.py). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__prepare__.__qualname__.__len__() == 19. 'ABCMeta.__prepare__' = 'ABCMeta.'=8 + '__prepare__'=11 = 19. type is 'builtin_function_or_method' (C-level). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__qualname__.__len__() == 22. 'update_abstractmethods' = 22 chars: 'update_'=7 + 'abstract'=8 + 'methods'=7 = 22. This is a module-level function so qualname equals the function name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.update_abstractmethods code attributes — extra100
#
# Wave 254 theme: abc.update_abstractmethods and get_cache_token identity.
#
# abc.update_abstractmethods.__code__.co_name     == 'update_abstractmethods' (co_argcount=1)
# abc.update_abstractmethods.__qualname__         == 'update_abstractmethods' (len=22)
# abc.update_abstractmethods.__module__           == 'abc'
# abc.get_cache_token.__qualname__                == 'get_cache_token'        (len=15)
# abc.get_cache_token.__module__                  == '_abc'
# ---------------------------------------------------------------------------

table abc_extra100.abc_update_abstractmethods_code:
  description: "abc.update_abstractmethods code attribute and identity checks in abcupdate100 namespace — wave 254 theme: update_abstractmethods is a Python function (class='function') defined in Lib/abc.py (module='abc'); update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods')==True; update_abstractmethods.__code__.co_argcount.__eq__(1)==True (single parameter: cls); update_abstractmethods.__qualname__.__eq__('update_abstractmethods')==True (len=22: 'update_'=7+'abstract'=8+'methods'=7=22); update_abstractmethods.__module__.__eq__('abc')==True; update_abstractmethods recalculates the __abstractmethods__ frozenset for a class; compare: get_cache_token.__module__=='_abc' (C extension), while update_abstractmethods.__module__=='abc' (Python); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: abcupdate100

  columns: [id, function, args, expected, description]
  rows:
    - [uam_co_name,  abc.update_abstractmethods.__code__.co_name.__eq__,     ["update_abstractmethods"], true, "abc.update_abstractmethods.__code__.co_name == 'update_abstractmethods'; verified with Python 3.14.3"]
    - [uam_co_argc,  abc.update_abstractmethods.__code__.co_argcount.__eq__,  [1],                        true, "abc.update_abstractmethods.__code__.co_argcount == 1 (cls); verified with Python 3.14.3"]
    - [uam_qn_eq,    abc.update_abstractmethods.__qualname__.__eq__,          ["update_abstractmethods"], true, "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' (len=22); verified with Python 3.14.3"]
    - [uam_qn_len,   abc.update_abstractmethods.__qualname__.__len__,         [],                         22,   "abc.update_abstractmethods.__qualname__.__len__() == 22 ('update_'=7+'abstract'=8+'methods'=7); verified with Python 3.14.3"]
    - [uam_module,   abc.update_abstractmethods.__module__.__eq__,            ["abc"],                    true, "abc.update_abstractmethods.__module__ == 'abc' (Python-defined in Lib/abc.py); verified with Python 3.14.3"]
    - [gct_qn_eq,    abc.get_cache_token.__qualname__.__eq__,                 ["get_cache_token"],        true, "abc.get_cache_token.__qualname__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]
    - [gct_qn_len,   abc.get_cache_token.__qualname__.__len__,                [],                         15,   "abc.get_cache_token.__qualname__.__len__() == 15 ('get_cache_token'=15); verified with Python 3.14.3"]
    - [gct_module,   abc.get_cache_token.__module__.__eq__,                   ["_abc"],                   true, "abc.get_cache_token.__module__ == '_abc' (C extension, not Python 'abc' module); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__prepare__ and ABC.__subclasshook__ qualnames — extra100
#
# Wave 254 theme: ABCMeta C-level method qualnames.
#
# abc.ABCMeta.__prepare__.__qualname__      == 'ABCMeta.__prepare__'      (len=19)
# abc.ABC.__subclasshook__.__qualname__     == 'ABC.__subclasshook__'     (len=20)
# abc.ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (len=24, longest)
# ---------------------------------------------------------------------------

table abc_extra100.abc_abcmeta_prepare_subclasshook:
  description: "abc.ABCMeta.__prepare__ and subclasshook __qualname__ checks in abcupdate100 namespace — wave 254 theme: ABCMeta.__prepare__ is a C-level builtin_function_or_method; ABCMeta.__prepare__.__qualname__.__eq__('ABCMeta.__prepare__')==True (len=19: 'ABCMeta.'=8+'__prepare__'=11=19); ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__')==True (len=20: 'ABC.'=4+'__subclasshook__'=16=20); type(ABC.__subclasshook__).__name__=='builtin_function_or_method'; ABCMeta.__subclasshook__.__qualname__.__eq__('ABCMeta.__subclasshook__')==True (len=24: 'ABCMeta.'=8+'__subclasshook__'=16=24; already covered in extra99 as longest method qualname); compare qualname lengths: ABCMeta.__prepare__=19, ABC.__subclasshook__=20, ABCMeta.__subclasshook__=24; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcupdate100a

  columns: [id, function, args, expected, description]
  rows:
    - [prepare_qn_eq,   abc.ABCMeta.__prepare__.__qualname__.__eq__,       ["ABCMeta.__prepare__"],      true, "abc.ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' (len=19); verified with Python 3.14.3"]
    - [prepare_qn_len,  abc.ABCMeta.__prepare__.__qualname__.__len__,       [],                           19,   "abc.ABCMeta.__prepare__.__qualname__.__len__() == 19 ('ABCMeta.'=8+'__prepare__'=11); verified with Python 3.14.3"]
    - [abcsh_qn_eq,     abc.ABC.__subclasshook__.__qualname__.__eq__,       ["ABC.__subclasshook__"],     true, "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20); verified with Python 3.14.3"]
    - [abcsh_qn_len,    abc.ABC.__subclasshook__.__qualname__.__len__,       [],                           20,   "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 ('ABC.'=4+'__subclasshook__'=16); verified with Python 3.14.3"]
    - [metash_qn_eq,    abc.ABCMeta.__subclasshook__.__qualname__.__eq__,   ["ABCMeta.__subclasshook__"], true, "abc.ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (len=24, longest in spec); verified with Python 3.14.3"]
    - [metash_qn_len,   abc.ABCMeta.__subclasshook__.__qualname__.__len__,  [],                           24,   "abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24 ('ABCMeta.'=8+'__subclasshook__'=16); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod and ABCMeta class type identity — extra100
#
# abc.abstractmethod.__class__.__name__   == 'function'   (Python-defined)
# abc.abstractmethod.__module__           == 'abc'
# abc.ABCMeta.__module__                  == 'abc'
# abc.ABCMeta.__mro__.__len__()           == 3
# ---------------------------------------------------------------------------

table abc_extra100.abc_class_type_identity:
  description: "abc.abstractmethod and ABCMeta class type identity checks in abcupdate100 namespace — wave 254 theme: abc.abstractmethod is a Python function (class='function', module='abc') — it is a decorator function defined in Lib/abc.py; abc.abstractmethod.__class__.__name__.__eq__('function')==True; abc.abstractmethod.__module__.__eq__('abc')==True; abc.ABCMeta.__module__.__eq__('abc')==True; abc.ABCMeta.__mro__.__len__()==3 (MRO is [ABCMeta, type, object]); abc.ABCMeta.__qualname__.__eq__('ABCMeta')==True (len=7); abc.ABC.__module__.__eq__('abc')==True; abc.ABC.__qualname__.__eq__('ABC')==True (len=3, shortest in spec); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcupdate100b

  columns: [id, function, args, expected, description]
  rows:
    - [absm_cls_nm,   abc.abstractmethod.__class__.__name__.__eq__,  ["function"], true, "abc.abstractmethod.__class__.__name__ == 'function' (Python-defined decorator in Lib/abc.py); verified with Python 3.14.3"]
    - [absm_module,   abc.abstractmethod.__module__.__eq__,           ["abc"],      true, "abc.abstractmethod.__module__ == 'abc'; verified with Python 3.14.3"]
    - [meta_module,   abc.ABCMeta.__module__.__eq__,                  ["abc"],      true, "abc.ABCMeta.__module__ == 'abc'; verified with Python 3.14.3"]
    - [meta_mro_len,  abc.ABCMeta.__mro__.__len__,                    [],           3,    "abc.ABCMeta.__mro__.__len__() == 3 (MRO: [ABCMeta, type, object]); verified with Python 3.14.3"]
    - [meta_qn_eq,    abc.ABCMeta.__qualname__.__eq__,                ["ABCMeta"],  true, "abc.ABCMeta.__qualname__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [abc_module,    abc.ABC.__module__.__eq__,                      ["abc"],      true, "abc.ABC.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abc_qn_eq,     abc.ABC.__qualname__.__eq__,                    ["ABC"],      true, "abc.ABC.__qualname__ == 'ABC' (len=3, shortest qualname in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra100
# ---------------------------------------------------------------------------

invariant abc_extra100.update_abstractmethods_co_argcount_1:
  description: "abc.update_abstractmethods.__code__.co_argcount == 1 — update_abstractmethods is defined as 'def update_abstractmethods(cls)' in Lib/abc.py; co_argcount==1 (single parameter: cls); this is the only parameter; update_abstractmethods recalculates the __abstractmethods__ frozenset for a given class after it has been modified; abc.update_abstractmethods.__code__.co_name is 'update_abstractmethods' (len=22); abc.update_abstractmethods.__module__ is 'abc'; abc.update_abstractmethods.__class__.__name__ is 'function' (Python-defined); compare: ABCMeta.__new__.__code__.co_argcount==4 (mcls, name, bases, namespace), ABCMeta.register.__code__.co_argcount==2 (cls, subclass); NEW in extra100: first standalone update_abstractmethods co_argcount invariant in abcupdate100 namespace; wave 254; verified with Python 3.14.3"
  category: code_attrs
  kind: python_call_eq
  function: abc.update_abstractmethods.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant abc_extra100.get_cache_token_module_is_abc_c:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — get_cache_token is implemented in C (Modules/_abc.c) and exposed via the _abc extension module; its __module__ is '_abc' (the C extension), not 'abc' (the Python module); this contrasts with abc.update_abstractmethods.__module__=='abc' and abc.abstractmethod.__module__=='abc' which are Python-defined; type(abc.get_cache_token).__name__ is 'builtin_function_or_method'; abc.get_cache_token.__qualname__ is 'get_cache_token' (len=15); get_cache_token() returns the current ABC cache token (an integer that increases each time a class is registered with an ABC); NEW in extra100: first standalone get_cache_token module invariant in abcupdate100 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra100.ABCMeta_prepare_qualname_len_19:
  description: "abc.ABCMeta.__prepare__.__qualname__.__len__() == 19 — ABCMeta.__prepare__.__qualname__ is 'ABCMeta.__prepare__' (19 chars: 'ABCMeta.'=8 + '__prepare__'=11 = 19); type(ABCMeta.__prepare__).__name__ is 'builtin_function_or_method' (C-level, no __code__ attribute); __prepare__ is a classmethod called by the metaclass machinery before __new__ to create the class namespace dict; compare qualname lengths in extra100: abstractmethod=14, get_cache_token=15, ABCMeta.__prepare__=19, ABC.__subclasshook__=20, update_abstractmethods=22, ABCMeta.__subclasshook__=24 (longest); NEW in extra100: first standalone ABCMeta.__prepare__ qualname length invariant in abcupdate100 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__prepare__.__qualname__.__len__
  args: []
  expected: 19

invariant abc_extra100.ABC_subclasshook_qualname_len_20:
  description: "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 — ABC.__subclasshook__.__qualname__ is 'ABC.__subclasshook__' (20 chars: 'ABC.'=4 + '__subclasshook__'=16 = 20); type(ABC.__subclasshook__).__name__ is 'builtin_function_or_method'; compare with ABCMeta.__subclasshook__.__qualname__.__len__()==24 (four more chars because 'ABCMeta.'=8 vs 'ABC.'=4); ABC.__subclasshook__ is the classmethod defined on ABC that can be overridden to customize issubclass() checks; the two subclasshook qualnames differ by 4 chars: ABC.__subclasshook__=20, ABCMeta.__subclasshook__=24; NEW in extra100: first standalone ABC.__subclasshook__ qualname length invariant in abcupdate100 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__subclasshook__.__qualname__.__len__
  args: []
  expected: 20

invariant abc_extra100.ABCMeta_mro_len_3:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — ABCMeta's MRO is [ABCMeta, type, object] (3 elements); ABCMeta.__bases__[0].__name__ is 'type' (ABCMeta inherits directly from type); compare with abc.ABC.__mro__.__len__()==2 ([ABC, object]) — ABC has a simpler MRO since it's just a helper class; ABCMeta.__module__ is 'abc'; ABCMeta.__qualname__ is 'ABCMeta' (len=7); ABCMeta is the metaclass for abstract base classes — any class using ABCMeta as its metaclass gets abstract method enforcement; NEW in extra100: first standalone ABCMeta MRO length invariant in abcupdate100 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__mro__.__len__
  args: []
  expected: 3
