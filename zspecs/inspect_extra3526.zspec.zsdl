spec: in3526
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 682 (in3526): __set_name__, __init_subclass__, __class_getitem__ dict-presence checks for inspect types."
    - "All values false — inspect introspection types do not implement class creation hooks or generic parameterization."
    - "None of the inspect types define __set_name__, __init_subclass__, or __class_getitem__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __set_name__ dict-presence — operator.contains(Cls.__dict__, '__set_name__')
# ---------------------------------------------------------------------------

table in3526.set_name:
  description: "inspect types __set_name__ dict-presence checks; wave 682"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3526
  columns: [id, function, args, expected]
  rows:
    - ["in3526001", operator.contains, [inspect.Parameter.__dict__,           "__set_name__"], false]
    - ["in3526002", operator.contains, [inspect.Signature.__dict__,           "__set_name__"], false]
    - ["in3526003", operator.contains, [inspect.BoundArguments.__dict__,      "__set_name__"], false]
    - ["in3526004", operator.contains, [inspect.FrameInfo.__dict__,           "__set_name__"], false]
    - ["in3526005", operator.contains, [inspect.ArgInfo.__dict__,             "__set_name__"], false]
    - ["in3526006", operator.contains, [inspect.FullArgSpec.__dict__,         "__set_name__"], false]
    - ["in3526007", operator.contains, [inspect.Attribute.__dict__,           "__set_name__"], false]
    - ["in3526008", operator.contains, [inspect.ClassFoundException.__dict__, "__set_name__"], false]
    - ["in3526009", operator.contains, [inspect.EndOfBlock.__dict__,          "__set_name__"], false]

