spec: signal_extra2
version: ">=3.8"
backend: python_module(signal)

docs: https://docs.python.org/3/library/signal.html

provenance:
  derived_from:
    - "Python signal documentation — https://docs.python.org/3/library/signal.html"
    - "POSIX.1-2017 — The Open Group Base Specifications Issue 7, 2018 Edition"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/signalmodule.c"
    - "signal.zspec.zsdl — covers POSIX signal integer values, Signals/Handlers enum values, strsignal strings"
    - "signal_extra.zspec.zsdl — covers getsignal/raise_signal/strsignal/valid_signals __name__, SIG_DFL/SIG_IGN class names, SIGABRT/SIGFPE/SIGILL/SIGINT/SIGSEGV/SIGTERM class names, valid_signals() return type and contents"
  notes:
    - "This spec extends signal.zspec.zsdl and signal_extra.zspec.zsdl with coverage not already present."
    - "signal.signal.__name__ == 'signal' — the signal() function shares a name with the module."
    - "signal.getsignal.__name__ == 'getsignal' is in signal_extra; here we test signal.signal.__name__."
    - "signal.SIGKILL.__class__.__name__ == 'Signals' — SIGKILL (9) is a Signals enum member (POSIX only)."
    - "signal.Signals.__bases__[0].__name__ == 'IntEnum' — Signals is a subclass of IntEnum."
    - "signal.Handlers.__bases__[0].__name__ == 'IntEnum' — Handlers is a subclass of IntEnum."
    - "signal.SIG_DFL.name == 'SIG_DFL' — enum member name attribute."
    - "signal.SIG_IGN.name == 'SIG_IGN' — enum member name attribute."
    - "signal.NSIG == 32 on macOS/Darwin; this is platform-specific."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function identity — signal.signal (the set-handler function)
# signal_extra.zspec.zsdl covers getsignal/raise_signal/strsignal/valid_signals;
# here we add the signal() function itself.
# ---------------------------------------------------------------------------

invariant signal_extra2.signal_func.name:
  description: "signal.signal.__name__ == 'signal'"
  category: functions
  kind: python_call_eq
  function: signal.__name__.__eq__
  args: ["signal"]
  expected: true

# ---------------------------------------------------------------------------
# SIGKILL — Signals enum membership (POSIX only)
# signal_extra.zspec.zsdl covers SIGABRT/SIGFPE/SIGILL/SIGINT/SIGSEGV/SIGTERM;
# here we add SIGKILL.
# ---------------------------------------------------------------------------

invariant signal_extra2.SIGKILL.class_name:
  description: "signal.SIGKILL.__class__.__name__ == 'Signals' — POSIX only"
  category: signals_enum
  kind: python_call_eq
  function: SIGKILL.__class__.__name__.__eq__
  args: ["Signals"]
  expected: true

# ---------------------------------------------------------------------------
# Signals and Handlers base class — both inherit from IntEnum
# ---------------------------------------------------------------------------

invariant signal_extra2.Signals.base_IntEnum:
  description: "signal.Signals.__bases__[0].__name__ == 'IntEnum'"
  category: enum_hierarchy
  kind: python_call_eq
  function: Signals.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntEnum"

invariant signal_extra2.Handlers.base_IntEnum:
  description: "signal.Handlers.__bases__[0].__name__ == 'IntEnum'"
  category: enum_hierarchy
  kind: python_call_eq
  function: Handlers.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IntEnum"

# ---------------------------------------------------------------------------
# SIG_DFL and SIG_IGN — .name attribute (enum member names)
# signal.zspec.zsdl covers .value; here we cover .name.
# ---------------------------------------------------------------------------

invariant signal_extra2.SIG_DFL.name:
  description: "signal.SIG_DFL.name == 'SIG_DFL'"
  category: handlers
  kind: python_call_eq
  function: SIG_DFL.name.__eq__
  args: ["SIG_DFL"]
  expected: true

invariant signal_extra2.SIG_IGN.name:
  description: "signal.SIG_IGN.name == 'SIG_IGN'"
  category: handlers
  kind: python_call_eq
  function: SIG_IGN.name.__eq__
  args: ["SIG_IGN"]
  expected: true

# ---------------------------------------------------------------------------
# NSIG — total number of signal slots on this platform (macOS: 32)
# ---------------------------------------------------------------------------

invariant signal_extra2.NSIG.value:
  description: "signal.NSIG == 32 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: NSIG.__eq__
  args: [32]
  expected: true
