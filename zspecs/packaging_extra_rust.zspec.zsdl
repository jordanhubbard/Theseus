    - "packaging.version.Version('1.2.3').major == 1."
    - "packaging.requirements.Requirement('requests>=2.0') is parsed."
    - "packaging.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant packaging_extra_rust.version_major:
  description: "packaging.version.Version('1.2.3').major == 1"
  category: version_parse
  kind: python_call_eq
  function: packaging_extra_version_major
