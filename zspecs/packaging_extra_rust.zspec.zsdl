invariant packaging_extra_rust.has_requirement:
  description: "packaging.requirements.Requirement is a class"
  category: presence
  kind: python_call_eq
  function: packaging_extra_has_requirement
  args: []
  expected: true

invariant packaging_extra_rust.version_nonempty:
  description: "packaging.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: packaging_extra_version_nonempty
  args: []
  expected: true

