spec: multiprocessing_extra2431
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing: Process-based parallelism"
    - "https://docs.python.org/3/library/multiprocessing.html#module-multiprocessing.pool — Pool objects"
    - "https://docs.python.org/3/library/multiprocessing.html#module-multiprocessing.queues — Queue objects"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Theme: __aiter__ and __anext__ async iteration protocol dict-presence for multiprocessing classes."
    - "multiprocessing is a process-based library; it defines NO async iteration protocol anywhere."
    - "multiprocessing.pool.IMapIterator defines __iter__ and __next__ (sync iteration) but NOT __aiter__."
    - "multiprocessing.pool.IMapUnorderedIterator inherits from IMapIterator; no own __iter__ or __aiter__."
    - "multiprocessing.queues.Queue has no iteration protocol (sync or async) in its __dict__."
    - "multiprocessing.pool.Pool, Process, ApplyResult, MapResult: no iteration protocol."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.queues.Queue, SimpleQueue, JoinableQueue
#
# None define __aiter__, __anext__, or __iter__ in their own __dict__
# ---------------------------------------------------------------------------

table multiprocessing_extra2431.Queue_types_async_iter_protocol:
  description: "multiprocessing.queues.Queue, SimpleQueue, JoinableQueue __aiter__ dict-presence checks — multiprocessing queue types are process-safe blocking queues with no iteration protocol of any kind defined in their __dict__"
  kind: python_call_eq
  category: async_iter_protocol
  id_prefix: mp2431

  columns: [id, function, args, expected]
  rows:
    - ["mp2431001", multiprocessing.queues.Queue.__dict__.__contains__,         ["__aiter__"], false]
    - ["mp2431002", multiprocessing.queues.Queue.__dict__.__contains__,         ["__anext__"], false]
    - ["mp2431003", multiprocessing.queues.Queue.__dict__.__contains__,         ["__iter__"],  false]
    - ["mp2431004", multiprocessing.queues.SimpleQueue.__dict__.__contains__,   ["__aiter__"], false]
    - ["mp2431005", multiprocessing.queues.SimpleQueue.__dict__.__contains__,   ["__anext__"], false]
    - ["mp2431006", multiprocessing.queues.SimpleQueue.__dict__.__contains__,   ["__iter__"],  false]
    - ["mp2431007", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__aiter__"], false]
    - ["mp2431008", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__anext__"], false]
    - ["mp2431009", multiprocessing.queues.JoinableQueue.__dict__.__contains__, ["__iter__"],  false]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.pool.IMapIterator — sync iter only, NOT async
#
# IMapIterator defines __iter__ and __next__ (sync) but NOT __aiter__ or __anext__
# IMapUnorderedIterator inherits from IMapIterator; no own __iter__ in its __dict__
# ---------------------------------------------------------------------------

table multiprocessing_extra2431.IMapIterator_async_iter_protocol:
  description: "multiprocessing.pool.IMapIterator and IMapUnorderedIterator __aiter__ dict-presence checks — IMapIterator defines __iter__ and __next__ for sync iteration over imap results, but NOT __aiter__ or __anext__; IMapUnorderedIterator inherits __iter__ from IMapIterator and defines neither in its own __dict__"
  kind: python_call_eq
  category: async_iter_protocol
  id_prefix: mp2431

  columns: [id, function, args, expected]
  rows:
    - ["mp2431010", multiprocessing.pool.IMapIterator.__dict__.__contains__,          ["__aiter__"], false]
    - ["mp2431011", multiprocessing.pool.IMapIterator.__dict__.__contains__,          ["__anext__"], false]
    - ["mp2431012", multiprocessing.pool.IMapIterator.__dict__.__contains__,          ["__iter__"],  true]
    - ["mp2431013", multiprocessing.pool.IMapIterator.__dict__.__contains__,          ["__next__"],  true]
    - ["mp2431014", multiprocessing.pool.IMapUnorderedIterator.__dict__.__contains__, ["__aiter__"], false]
    - ["mp2431015", multiprocessing.pool.IMapUnorderedIterator.__dict__.__contains__, ["__anext__"], false]
    - ["mp2431016", multiprocessing.pool.IMapUnorderedIterator.__dict__.__contains__, ["__iter__"],  false]
    - ["mp2431017", multiprocessing.pool.IMapUnorderedIterator.__dict__.__contains__, ["__next__"],  false]

