spec: asyncio_extra141
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py, Lib/asyncio/queues.py"
  notes:
    - "This spec covers: asyncio.Queue — __name__=='Queue' (len=5), __module__=='asyncio.queues' (len=14), __init__ co_argcount==2, co_varnames.__len__()==2 ('self','maxsize'). asyncio.Lock — __name__=='Lock' (len=4), __module__=='asyncio.locks' (len=13), __init__ co_argcount==1, co_varnames.__len__()==1. asyncio.Event — __name__=='Event' (len=5), __module__=='asyncio.locks' (len=13), __init__ co_argcount==1, co_varnames.__len__()==1. asyncio.Semaphore — __name__=='Semaphore' (len=9), __module__=='asyncio.locks' (len=13), __init__ co_argcount==2, co_varnames.__len__()==2. Also asyncio.__spec__.__class__.__name__=='ModuleSpec' (len=10); asyncio.__spec__.name=='asyncio' (len=7). Queue.get co_varnames.__len__()==2; Lock.acquire co_varnames.__len__()==2; Event.set co_varnames.__len__()==2; Semaphore.acquire co_varnames.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.__module__=='asyncio.queues' (len=14: 'asyncio'=7+'.'=1+'queues'=6=14); Lock, Event, Semaphore all have __module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13). Queue.__bases__[0].__name__=='_LoopBoundMixin'; Lock.__bases__[0].__name__=='_ContextManagerMixin'; Event.__bases__[0].__name__=='_LoopBoundMixin'; Semaphore.__bases__[0].__name__=='_ContextManagerMixin'. Queue.__init__.__qualname__=='Queue.__init__' (len=14); Lock.__init__.__qualname__=='Lock.__init__' (len=13); Event.__init__.__qualname__=='Event.__init__' (len=14); Semaphore.__init__.__qualname__=='Semaphore.__init__' (len=18). asyncio.__spec__.__class__.__name__=='ModuleSpec' (len=10). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

