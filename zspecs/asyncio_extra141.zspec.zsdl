# ---------------------------------------------------------------------------

table asyncio_extra141.spec_metadata:
  description: "asyncio module spec metadata checks — __spec__.__class__.__name__.__eq__('ModuleSpec')==True (len=10: 'Module'=6+'Spec'=4=10; the importlib.machinery.ModuleSpec type for package modules); __spec__.name.__eq__('asyncio')==True (len=7: the canonical package name); __package__.__eq__('asyncio')==True (len=7: same as spec name for top-level package); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciospec141

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_eq,  asyncio.__spec__.__class__.__name__.__eq__,  ["ModuleSpec"],  true,  "asyncio.__spec__.__class__.__name__ == 'ModuleSpec' (len=10); verified with Python 3.14.3"]
    - [spec_cls_len, asyncio.__spec__.__class__.__name__.__len__,  [],             10,    "asyncio.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec' is 10 chars); verified with Python 3.14.3"]
    - [spec_name_eq, asyncio.__spec__.name.__eq__,                ["asyncio"],     true,  "asyncio.__spec__.name == 'asyncio' (len=7); verified with Python 3.14.3"]
    - [spec_name_len,asyncio.__spec__.name.__len__,                [],             7,     "asyncio.__spec__.name.__len__() == 7; verified with Python 3.14.3"]
    - [pkg_eq,       asyncio.__package__.__eq__,                  ["asyncio"],     true,  "asyncio.__package__ == 'asyncio' (len=7); verified with Python 3.14.3"]

