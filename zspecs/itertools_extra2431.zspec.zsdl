spec: itertools_extra2431
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — chain, cycle, count, combinations, islice, repeat, groupby, zip_longest, accumulate, filterfalse sync vs async protocol dict-presence"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Theme: __aiter__ and __anext__ async iteration protocol dict-presence for itertools types."
    - "All itertools types are synchronous iterators: they define __iter__ and __next__ in their class __dict__."
    - "No itertools type defines __aiter__ or __anext__ — they are purely synchronous and have no async protocol."
    - "itertools.chain, cycle, count, combinations, islice, repeat, groupby, zip_longest, accumulate, filterfalse all verified."
    - "The sync protocol (__iter__/__next__) is confirmed present as a contrast to the absent async protocol."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

table itertools_extra2431.async_iter_absent:
  description: "itertools types do not define __aiter__ or __anext__ in their class __dict__ — they are purely synchronous"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2431

  columns: [id, function, args, expected]
  rows:
    - ["it2431001", "itertools.chain.__dict__.__contains__", ["__aiter__"], false]
    - ["it2431002", "itertools.chain.__dict__.__contains__", ["__anext__"], false]
    - ["it2431003", "itertools.cycle.__dict__.__contains__", ["__aiter__"], false]
    - ["it2431004", "itertools.cycle.__dict__.__contains__", ["__anext__"], false]
    - ["it2431005", "itertools.count.__dict__.__contains__", ["__aiter__"], false]
    - ["it2431006", "itertools.count.__dict__.__contains__", ["__anext__"], false]
    - ["it2431007", "itertools.combinations.__dict__.__contains__", ["__aiter__"], false]
    - ["it2431008", "itertools.combinations.__dict__.__contains__", ["__anext__"], false]
    - ["it2431009", "itertools.islice.__dict__.__contains__", ["__aiter__"], false]
    - ["it2431010", "itertools.islice.__dict__.__contains__", ["__anext__"], false]

