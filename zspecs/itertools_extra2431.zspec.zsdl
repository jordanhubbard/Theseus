table itertools_extra2431.sync_iter_present:
  description: "itertools types DO define __iter__ and __next__ in their class __dict__ — confirming they are synchronous iterators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2431

  columns: [id, function, args, expected]
  rows:
    - ["it2431021", "itertools.chain.__dict__.__contains__", ["__iter__"], true]
    - ["it2431022", "itertools.chain.__dict__.__contains__", ["__next__"], true]
    - ["it2431023", "itertools.cycle.__dict__.__contains__", ["__iter__"], true]
    - ["it2431024", "itertools.cycle.__dict__.__contains__", ["__next__"], true]
    - ["it2431025", "itertools.count.__dict__.__contains__", ["__iter__"], true]
    - ["it2431026", "itertools.count.__dict__.__contains__", ["__next__"], true]
    - ["it2431027", "itertools.repeat.__dict__.__contains__", ["__iter__"], true]
    - ["it2431028", "itertools.repeat.__dict__.__contains__", ["__next__"], true]
    - ["it2431029", "itertools.accumulate.__dict__.__contains__", ["__iter__"], true]
    - ["it2431030", "itertools.accumulate.__dict__.__contains__", ["__next__"], true]
