spec: itertools_extra99
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra98

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra98.zspec.zsdl."
    - "This spec covers: itertools C-type __module__ attributes (all 'itertools'); itertools C-type __name__ attributes; itertools C-type __reduce__.__class__.__name__ == 'method_descriptor'; itertools.pairwise and permutations identity (Wave 256)."
    - "itertools.chain.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.cycle.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.repeat.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.count.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.chain.__name__ == 'chain'. Verified with Python 3.14.3."
    - "itertools.cycle.__name__ == 'cycle'. Verified with Python 3.14.3."
    - "itertools.repeat.__name__ == 'repeat'. Verified with Python 3.14.3."
    - "itertools.count.__name__ == 'count'. Verified with Python 3.14.3."
    - "itertools.product.__name__ == 'product'. Verified with Python 3.14.3."
    - "itertools.accumulate.__name__ == 'accumulate'. Verified with Python 3.14.3."
    - "itertools.chain.__reduce__.__class__.__name__ == 'method_descriptor' — the __reduce__ method on C extension types is a method_descriptor. Verified with Python 3.14.3."
    - "itertools.cycle.__reduce__.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "itertools.pairwise.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.permutations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.pairwise.__reduce__.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C-type __module__ attributes (all 'itertools')
#
# Wave 256 theme: itertools C-type __module__ membership.
#
# itertools.chain.__module__ == 'itertools'
# itertools.cycle.__module__ == 'itertools'
# itertools.repeat.__module__ == 'itertools'
# itertools.count.__module__ == 'itertools'
# itertools.product.__module__ == 'itertools'
# itertools.combinations.__module__ == 'itertools'
# itertools.accumulate.__module__ == 'itertools'
# itertools.pairwise.__module__ == 'itertools'
#
# All C extension types defined in Modules/itertoolsmodule.c have
# __module__ == 'itertools'. New to extra99.
# ---------------------------------------------------------------------------

table itertools_extra99.module_attrs_group:
  description: "itertools C-type __module__ == 'itertools' for chain/cycle/repeat/count/product/combinations/accumulate/pairwise; all types from itertoolsmodule.c; wave 256; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmod99

  columns: [id, function, args, expected, description]
  rows:
    - [chain_module_eq_itertools,
       "chain.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — itertools.chain is a C extension type defined in Modules/itertoolsmodule.c; its __module__ attribute is set to 'itertools' by the module initializer; str.__eq__('itertools') returns True; new to extra99"]
    - [cycle_module_eq_itertools,
       "cycle.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.cycle.__module__.__eq__('itertools') == True — itertools.cycle is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra99"]
    - [repeat_module_eq_itertools,
       "repeat.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.repeat.__module__.__eq__('itertools') == True — itertools.repeat is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra99"]
    - [count_module_eq_itertools,
       "count.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — itertools.count is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra99"]
    - [product_module_eq_itertools,
       "product.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — itertools.product is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra99"]
    - [combinations_module_eq_itertools,
       "combinations.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — itertools.combinations is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra99"]
    - [accumulate_module_eq_itertools,
       "accumulate.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.accumulate.__module__.__eq__('itertools') == True — itertools.accumulate is a C extension type; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra99"]
    - [pairwise_module_eq_itertools,
       "pairwise.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.pairwise.__module__.__eq__('itertools') == True — itertools.pairwise was added in Python 3.10 as a C extension type in Modules/itertoolsmodule.c; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra99"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-type __name__ attributes
#
# Wave 256 theme: itertools C-type __name__ matches the type's simple name.
#
# itertools.chain.__name__ == 'chain'
# itertools.cycle.__name__ == 'cycle'
# itertools.repeat.__name__ == 'repeat'
# itertools.count.__name__ == 'count'
# itertools.product.__name__ == 'product'
# itertools.accumulate.__name__ == 'accumulate'
# itertools.permutations.__name__ == 'permutations'
# itertools.pairwise.__name__ == 'pairwise'
#
# The __name__ attribute on C extension types matches the type name string
# given in the PyTypeObject tp_name field. New to extra99.
# ---------------------------------------------------------------------------

table itertools_extra99.name_attrs_group:
  description: "itertools C-type __name__ equals simple class name for chain/cycle/repeat/count/product/accumulate/permutations/pairwise; wave 256; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmod99

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_eq_chain,
       "chain.__name__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — the __name__ attribute of a C extension type is set from the PyTypeObject tp_name field; for itertools.chain the name is 'chain'; str.__eq__('chain') returns True; new to extra99"]
    - [cycle_name_eq_cycle,
       "cycle.__name__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — itertools.cycle's __name__ is 'cycle', matching the C type name; str.__eq__('cycle') returns True; new to extra99"]
    - [repeat_name_eq_repeat,
       "repeat.__name__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__name__.__eq__('repeat') == True — itertools.repeat's __name__ is 'repeat'; str.__eq__('repeat') returns True; new to extra99"]
    - [count_name_eq_count,
       "count.__name__.__eq__",
       ["count"],
       true,
       "itertools.count.__name__.__eq__('count') == True — itertools.count's __name__ is 'count'; str.__eq__('count') returns True; new to extra99"]
    - [product_name_eq_product,
       "product.__name__.__eq__",
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — itertools.product's __name__ is 'product'; str.__eq__('product') returns True; new to extra99"]
    - [accumulate_name_eq_accumulate,
       "accumulate.__name__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — itertools.accumulate's __name__ is 'accumulate'; str.__eq__('accumulate') returns True; new to extra99"]
    - [permutations_name_eq_permutations,
       "permutations.__name__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — itertools.permutations is a C extension type; its __name__ is 'permutations'; str.__eq__('permutations') returns True; new to extra99"]
    - [pairwise_name_eq_pairwise,
       "pairwise.__name__.__eq__",
       ["pairwise"],
       true,
       "itertools.pairwise.__name__.__eq__('pairwise') == True — itertools.pairwise (added in 3.10) is a C extension type; its __name__ is 'pairwise'; str.__eq__('pairwise') returns True; new to extra99"]

# ---------------------------------------------------------------------------
# Table 3: itertools C-type __reduce__ class name == 'method_descriptor'
#
# Wave 256 theme: itertools C-type __reduce__ method descriptor identity.
#
# itertools.chain.__reduce__.__class__.__name__ == 'method_descriptor'
# itertools.cycle.__reduce__.__class__.__name__ == 'method_descriptor'
# itertools.repeat.__reduce__.__class__.__name__ == 'method_descriptor'
# itertools.count.__reduce__.__class__.__name__ == 'method_descriptor'
# itertools.product.__reduce__.__class__.__name__ == 'method_descriptor'
# itertools.pairwise.__reduce__.__class__.__name__ == 'method_descriptor'
#
# When accessed on the type (not an instance), C extension methods appear
# as 'method_descriptor' objects. New to extra99.
# ---------------------------------------------------------------------------

table itertools_extra99.reduce_method_descriptor:
  description: "itertools C-type __reduce__.__class__.__name__ == 'method_descriptor' for chain/cycle/repeat/count/product/pairwise; accessed on type not instance; wave 256; new to extra99"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsmod99

  columns: [id, function, args, expected, description]
  rows:
    - [chain_reduce_class_name_eq_method_descriptor,
       "chain.__reduce__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.chain.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — when accessed on the type object (not an instance), C extension methods are exposed as 'method_descriptor' objects; __reduce__ is defined for all itertools C types; str.__eq__('method_descriptor') returns True; new to extra99"]
    - [cycle_reduce_class_name_eq_method_descriptor,
       "cycle.__reduce__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.cycle.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — cycle.__reduce__ accessed on the type is a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra99"]
    - [repeat_reduce_class_name_eq_method_descriptor,
       "repeat.__reduce__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.repeat.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — repeat.__reduce__ is a method_descriptor when accessed on the type object; str.__eq__('method_descriptor') returns True; new to extra99"]
    - [count_reduce_class_name_eq_method_descriptor,
       "count.__reduce__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.count.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — count.__reduce__ is a method_descriptor when accessed on the type; str.__eq__('method_descriptor') returns True; new to extra99"]
    - [product_reduce_class_name_eq_method_descriptor,
       "product.__reduce__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.product.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — product.__reduce__ is a method_descriptor when accessed on the type; str.__eq__('method_descriptor') returns True; new to extra99"]
    - [pairwise_reduce_class_name_eq_method_descriptor,
       "pairwise.__reduce__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.pairwise.__reduce__.__class__.__name__.__eq__('method_descriptor') == True — pairwise.__reduce__ is a method_descriptor when accessed on the type; pairwise was added in Python 3.10; str.__eq__('method_descriptor') returns True; new to extra99"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra99
# ---------------------------------------------------------------------------

invariant itertools_extra99.chain_module:
  description: "itertools.chain.__module__ == 'itertools' — C extension type defined in itertoolsmodule.c; wave 256; new to extra99"
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra99.pairwise_module:
  description: "itertools.pairwise.__module__ == 'itertools' — C extension type added in Python 3.10; wave 256; new to extra99"
  kind: python_call_eq
  function: pairwise.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra99.chain_reduce_method_descriptor:
  description: "itertools.chain.__reduce__.__class__.__name__ == 'method_descriptor' — C extension __reduce__ is a method_descriptor when accessed on type; wave 256; new to extra99"
  kind: python_call_eq
  function: chain.__reduce__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant itertools_extra99.permutations_name:
  description: "itertools.permutations.__name__ == 'permutations' — C extension type; __name__ matches the simple class name; wave 256; new to extra99"
  kind: python_call_eq
  function: permutations.__name__.__eq__
  args: ["permutations"]
  expected: true

invariant itertools_extra99.repeat_name:
  description: "itertools.repeat.__name__ == 'repeat' — C extension type; __name__ matches the PyTypeObject tp_name; wave 256; new to extra99"
  kind: python_call_eq
  function: repeat.__name__.__eq__
  args: ["repeat"]
  expected: true
