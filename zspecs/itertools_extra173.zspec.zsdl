    - [repeat_mro_len_2_xcheck,
       "repeat.__mro__.__len__",
       [],
       2,
       "itertools.repeat.__mro__.__len__() == 2 — cross-check confirming the MRO uniformity pattern: repeat is a C extension type with direct object inheritance, MRO length 2; tuple.__len__() returns 2; new to extra173"]

