spec: itertools_extra173
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.chain.__mro__.__len__() 2 (chain > object); itertools.repeat.__mro__.__len__() 2; itertools.cycle.__mro__.__len__() 2; itertools.count.__mro__.__len__() 2; itertools.islice.__mro__.__len__() 2; itertools.accumulate.__mro__.__len__() 2; itertools.starmap.__mro__.__len__() 2 (Wave 302)."
    - "All itertools C extension types inherit directly from object with no intermediate base classes. Their __mro__ tuples all have length 2: (TypeName, object). Verified with Python 3.14.3."
    - "itertools.chain.__mro__.__len__() == 2 — chain is a C extension type in itertoolsmodule.c; its MRO is (chain, object). Verified with Python 3.14.3."
    - "itertools.repeat.__mro__.__len__() == 2 — repeat is a C extension type in itertoolsmodule.c; its MRO is (repeat, object). Verified with Python 3.14.3."
    - "itertools.cycle.__mro__.__len__() == 2 — cycle is a C extension type in itertoolsmodule.c; its MRO is (cycle, object). Verified with Python 3.14.3."
    - "itertools.count.__mro__.__len__() == 2 — count is a C extension type in itertoolsmodule.c; its MRO is (count, object). Verified with Python 3.14.3."
    - "itertools.islice.__mro__.__len__() == 2 — islice is a C extension type in itertoolsmodule.c; its MRO is (islice, object). Verified with Python 3.14.3."
    - "itertools.accumulate.__mro__.__len__() == 2 — accumulate is a C extension type in itertoolsmodule.c; its MRO is (accumulate, object). Verified with Python 3.14.3."
    - "itertools.starmap.__mro__.__len__() == 2 — starmap is a C extension type in itertoolsmodule.c; its MRO is (starmap, object). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain and itertools.repeat __mro__.__len__() == 2
#
# Wave 302 theme: itertools.chain and itertools.repeat are C extension types
# that inherit directly from object; their __mro__ has exactly 2 entries.
#
# itertools.chain.__mro__.__len__() == 2
# itertools.chain.__mro__[0].__name__ == 'chain'
# itertools.repeat.__mro__.__len__() == 2
# itertools.repeat.__mro__[0].__name__ == 'repeat'
#
# All itertools C extension types are defined in itertoolsmodule.c and inherit
# from object directly. chain(p, q, ...) chains iterables together. repeat(x)
# makes an iterator repeating x indefinitely or n times. Both have MRO length 2.
# New to extra173.
# ---------------------------------------------------------------------------

table itertools_extra173.chain_repeat_mro_len:
  description: "itertools.chain and repeat: __mro__.__len__() 2, mro[0] is self, mro[1] 'object'; wave 302; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscrml173

  columns: [id, function, args, expected, description]
  rows:
    - [chain_mro_len_2,
       "chain.__mro__.__len__",
       [],
       2,
       "itertools.chain.__mro__.__len__() == 2 — itertools.chain is a C extension type defined in itertoolsmodule.c that chains multiple iterables together; it inherits directly from object with no intermediate base classes; its __mro__ is (chain, object), a tuple of length 2; tuple.__len__() returns 2; new to extra173"]
    - ["chain_mro_0_chain",
       "chain.__mro__[0].__name__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__mro__[0].__name__.__eq__('chain') == True — the first entry in chain.__mro__ is the chain class itself; its __name__ is 'chain'; str.__eq__('chain') returns True; new to extra173"]
    - [repeat_mro_len_2,
       "repeat.__mro__.__len__",
       [],
       2,
       "itertools.repeat.__mro__.__len__() == 2 — itertools.repeat is a C extension type defined in itertoolsmodule.c that makes an iterator returning its argument indefinitely or a specified number of times; it inherits directly from object; its __mro__ is (repeat, object), a tuple of length 2; tuple.__len__() returns 2; new to extra173"]
    - ["repeat_mro_0_repeat",
       "repeat.__mro__[0].__name__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__mro__[0].__name__.__eq__('repeat') == True — the first entry in repeat.__mro__ is the repeat class itself; its __name__ is 'repeat'; str.__eq__('repeat') returns True; new to extra173"]

# ---------------------------------------------------------------------------
# Table 2: itertools.cycle and itertools.count __mro__.__len__() == 2
#
# Wave 302 theme: itertools.cycle and itertools.count are C extension types
# that inherit directly from object; their __mro__ has exactly 2 entries.
#
# itertools.cycle.__mro__.__len__() == 2
# itertools.cycle.__mro__[0].__name__ == 'cycle'
# itertools.count.__mro__.__len__() == 2
# itertools.count.__mro__[0].__name__ == 'count'
#
# cycle(p) makes an iterator cycling over the elements of p indefinitely.
# count(start=0, step=1) makes an iterator counting up from start by step.
# Both are C extension types in itertoolsmodule.c with MRO length 2. New to
# extra173.
# ---------------------------------------------------------------------------

table itertools_extra173.cycle_count_mro_len:
  description: "itertools.cycle and count: __mro__.__len__() 2, mro[0] is self; wave 302; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsccml173

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_mro_len_2,
       "cycle.__mro__.__len__",
       [],
       2,
       "itertools.cycle.__mro__.__len__() == 2 — itertools.cycle is a C extension type defined in itertoolsmodule.c that makes an iterator cycling through the elements of an iterable indefinitely (saving a copy); it inherits directly from object; its __mro__ is (cycle, object), a tuple of length 2; tuple.__len__() returns 2; new to extra173"]
    - ["cycle_mro_0_cycle",
       "cycle.__mro__[0].__name__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__mro__[0].__name__.__eq__('cycle') == True — the first entry in cycle.__mro__ is the cycle class itself; its __name__ is 'cycle'; str.__eq__('cycle') returns True; new to extra173"]
    - [count_mro_len_2,
       "count.__mro__.__len__",
       [],
       2,
       "itertools.count.__mro__.__len__() == 2 — itertools.count is a C extension type defined in itertoolsmodule.c that makes an iterator counting from start (default 0) by step (default 1) indefinitely; it inherits directly from object; its __mro__ is (count, object), a tuple of length 2; tuple.__len__() returns 2; new to extra173"]
    - ["count_mro_0_count",
       "count.__mro__[0].__name__.__eq__",
       ["count"],
       true,
       "itertools.count.__mro__[0].__name__.__eq__('count') == True — the first entry in count.__mro__ is the count class itself; its __name__ is 'count'; str.__eq__('count') returns True; new to extra173"]

# ---------------------------------------------------------------------------
# Table 3: itertools.islice and itertools.accumulate __mro__.__len__() == 2
#
# Wave 302 theme: itertools.islice and itertools.accumulate are C extension types
# that inherit directly from object; their __mro__ has exactly 2 entries.
#
# itertools.islice.__mro__.__len__() == 2
# itertools.islice.__mro__[1].__name__ == 'object'
# itertools.accumulate.__mro__.__len__() == 2
# itertools.accumulate.__mro__[1].__name__ == 'object'
#
# islice and accumulate are both covered in extra171 for __name__ and __module__,
# but their __mro__.__len__() is new to extra173. Both inherit from object only.
# New to extra173.
# ---------------------------------------------------------------------------

table itertools_extra173.islice_accumulate_mro_len:
  description: "itertools.islice and accumulate: __mro__.__len__() 2, mro[1] 'object'; wave 302; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsiaml173

  columns: [id, function, args, expected, description]
  rows:
    - [islice_mro_len_2,
       "islice.__mro__.__len__",
       [],
       2,
       "itertools.islice.__mro__.__len__() == 2 — itertools.islice is a C extension type defined in itertoolsmodule.c that makes an iterator returning selected elements from an iterable by index range; it inherits directly from object; its __mro__ is (islice, object), a tuple of length 2; tuple.__len__() returns 2; new to extra173"]
    - ["islice_mro_1_object",
       "islice.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.islice.__mro__[1].__name__.__eq__('object') == True — the second entry in islice.__mro__ is the base class object; its __name__ is 'object'; this confirms islice inherits directly from object with no intermediate classes; str.__eq__('object') returns True; new to extra173"]
    - [accumulate_mro_len_2,
       "accumulate.__mro__.__len__",
       [],
       2,
       "itertools.accumulate.__mro__.__len__() == 2 — itertools.accumulate is a C extension type defined in itertoolsmodule.c that makes an iterator returning accumulated sums (or results of a binary function); it inherits directly from object; its __mro__ is (accumulate, object), a tuple of length 2; tuple.__len__() returns 2; new to extra173"]
    - ["accumulate_mro_1_object",
       "accumulate.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.accumulate.__mro__[1].__name__.__eq__('object') == True — the second entry in accumulate.__mro__ is the base class object; its __name__ is 'object'; this confirms accumulate inherits directly from object with no intermediate classes; str.__eq__('object') returns True; new to extra173"]

# ---------------------------------------------------------------------------
# Table 4: itertools.starmap __mro__.__len__() == 2; cross-checks across types
#
# Wave 302 theme: itertools.starmap is a C extension type that inherits directly
# from object; cross-checks confirm all seven covered types share MRO length 2.
#
# itertools.starmap.__mro__.__len__() == 2
# itertools.starmap.__mro__[0].__name__ == 'starmap'
# itertools.starmap.__mro__[1].__name__ == 'object'
# itertools.starmap.__mro__.__len__() != 3
#
# starmap is covered in extra171 for __name__ and __module__. Its MRO length
# is new to extra173. Cross-checks confirm that chain, repeat, cycle, count,
# islice, accumulate, and starmap all have the same MRO depth of 2. New to
# extra173.
# ---------------------------------------------------------------------------

table itertools_extra173.starmap_mro_and_cross_checks:
  description: "itertools.starmap: __mro__.__len__() 2, mro[0] 'starmap', mro[1] 'object'; not len 3; wave 302; new to extra173"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolssmmro173

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_mro_len_2,
       "starmap.__mro__.__len__",
       [],
       2,
       "itertools.starmap.__mro__.__len__() == 2 — itertools.starmap is a C extension type defined in itertoolsmodule.c that makes an iterator computing a function using arguments obtained from an iterable (equivalent to function(*args) for args in iterable); it inherits directly from object; its __mro__ is (starmap, object), a tuple of length 2; tuple.__len__() returns 2; new to extra173"]
    - ["starmap_mro_0_starmap",
       "starmap.__mro__[0].__name__.__eq__",
       ["starmap"],
       true,
       "itertools.starmap.__mro__[0].__name__.__eq__('starmap') == True — the first entry in starmap.__mro__ is the starmap class itself; its __name__ is 'starmap'; str.__eq__('starmap') returns True; new to extra173"]
    - ["starmap_mro_1_object",
       "starmap.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.starmap.__mro__[1].__name__.__eq__('object') == True — the second entry in starmap.__mro__ is the base class object; its __name__ is 'object'; this confirms starmap inherits directly from object with no intermediate classes; str.__eq__('object') returns True; new to extra173"]
    - [starmap_mro_not_3,
       "starmap.__mro__.__len__",
       [],
       2,
       "itertools.starmap.__mro__.__len__() == 2 (not 3) — starmap inherits only from object; there is no intermediate class; all itertools C extension types covered in this spec share MRO depth 2; tuple.__len__() returns 2; new to extra173"]

# ---------------------------------------------------------------------------
# Table 5: MRO length uniformity — all 7 types have __mro__.__len__() == 2
#
# Wave 302 theme: confirming the pattern that every C extension type in
# itertools has __mro__.__len__() == 2.
#
# itertools.chain.__mro__.__len__() == 2
# itertools.cycle.__mro__.__len__() == 2
# itertools.count.__mro__.__len__() == 2
# itertools.repeat.__mro__.__len__() == 2
#
# All seven C extension types covered in this spec (chain, repeat, cycle, count,
# islice, accumulate, starmap) have __mro__.__len__() == 2. This table reinforces
# the pattern with additional cross-checks for chain, cycle, count, and repeat.
# New to extra173.
# ---------------------------------------------------------------------------

