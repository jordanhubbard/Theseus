spec: cffi_rust
version: ">=3.9"
backend: rust_module(cffi_rust)

docs: https://cffi.readthedocs.io/

provenance:
  derived_from:
    - "https://cffi.readthedocs.io/ — cffi library"
  notes:
    - "cffi provides C Foreign Function Interface for Python."
    - "cffi.FFI is a class."
    - "cffi.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant cffi_rust.has_ffi_class:
  description: "cffi.FFI is a class"
  category: presence
  kind: python_call_eq
  function: cffi_has_ffi_class
  args: []
  expected: true

invariant cffi_rust.ffi_cdef_callable:
  description: "cffi.FFI().cdef is callable"
  category: ffi
  kind: python_call_eq
  function: cffi_ffi_cdef_callable
  args: []
  expected: true

invariant cffi_rust.version_nonempty:
  description: "cffi.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: cffi_version_nonempty
  args: []
  expected: true

