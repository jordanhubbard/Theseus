spec: ftplib_extra
version: ">=3.9"
backend: python_module(ftplib)

docs: https://docs.python.org/3/library/ftplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ftplib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ftplib.py internal socket handling"
    - "ftplib.zspec.zsdl — covers class names, FTP.__module__, FTP.port, Error base hierarchy, exception bases table, and method names"
  notes:
    - "This spec extends ftplib.zspec.zsdl with coverage not already present there."
    - "ftplib.FTP_TLS.__module__ == 'ftplib' — FTP_TLS is also defined in the ftplib module."
    - "ftplib.FTP_TLS.__bases__[0].__name__ == 'FTP' — FTP_TLS subclasses FTP."
    - "all_errors is a tuple (not a class) — its __class__.__name__ is 'tuple'."
    - "all_errors contains 4 items in Python 3.9+: Error, OSError, EOFError, ssl.SSLError."
    - "all_errors[0].__name__ == 'Error' — the first element is the ftplib.Error class."
    - "all_errors[1].__name__ == 'OSError' — the second element is the built-in OSError."
    - "all_errors[2].__name__ == 'EOFError' — the third element is the built-in EOFError."
    - "error_proto.__module__ == 'ftplib' — verifies module placement of the proto error class."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# FTP_TLS — module and base class
# ---------------------------------------------------------------------------

invariant ftplib_extra.FTP_TLS.module:
  description: "FTP_TLS.__module__ == 'ftplib'"
  category: class_metadata
  kind: python_call_eq
  function: FTP_TLS.__module__.__eq__
  args: ["ftplib"]
  expected: true

invariant ftplib_extra.FTP_TLS.base_is_FTP:
  description: "FTP_TLS.__bases__[0].__name__ == 'FTP' — FTP_TLS subclasses FTP"
  category: class_hierarchy
  kind: python_call_eq
  function: FTP_TLS.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "FTP"

# ---------------------------------------------------------------------------
# all_errors — instance class is tuple
# ---------------------------------------------------------------------------

invariant ftplib_extra.all_errors.is_tuple:
  description: "ftplib.all_errors.__class__.__name__ == 'tuple'"
  category: all_errors
  kind: python_call_eq
  function: all_errors.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant ftplib_extra.all_errors.len:
  description: "len(ftplib.all_errors) == 4 — Error, OSError, EOFError, SSLError"
  category: all_errors
  kind: python_call_eq
  function: all_errors.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# all_errors element names
# ---------------------------------------------------------------------------

table ftplib_extra.all_errors.element_names:
  kind: python_call_eq
  category: all_errors
  id_prefix: elem

  columns: [id, function, args, method, expected]
  rows:
    - [error,    all_errors.__getitem__, [0], __name__, "Error"]
    - [oserror,  all_errors.__getitem__, [1], __name__, "OSError"]
    - [eoferror, all_errors.__getitem__, [2], __name__, "EOFError"]

# ---------------------------------------------------------------------------
# error_proto — module check
# ---------------------------------------------------------------------------

invariant ftplib_extra.error_proto.module:
  description: "error_proto.__module__ == 'ftplib'"
  category: class_metadata
  kind: python_call_eq
  function: error_proto.__module__.__eq__
  args: ["ftplib"]
  expected: true
