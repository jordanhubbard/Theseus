spec: struct_extra1051
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.Struct, struct.error, struct.pack, struct.unpack, struct.calcsize __reduce_ex__, __sizeof__, __init_subclass__ qualnames and module doc class"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1051.struct_reduce_ex_qualnames:
  description: "struct.Struct and struct functions __reduce_ex__.__qualname__ identity"
  kind: python_call_eq
  category: reduce_ex_qualnames
  id_prefix: st1051x
  columns: [id, function, args, expected]
  rows:
    - [st1051x001, struct.Struct.__reduce_ex__.__qualname__.__eq__,    ["object.__reduce_ex__"],                   true]
    - [st1051x002, struct.pack.__reduce_ex__.__qualname__.__eq__,      ["builtin_function_or_method.__reduce_ex__"], true]
    - [st1051x003, struct.unpack.__reduce_ex__.__qualname__.__eq__,    ["builtin_function_or_method.__reduce_ex__"], true]
    - [st1051x004, struct.calcsize.__reduce_ex__.__qualname__.__eq__,  ["builtin_function_or_method.__reduce_ex__"], true]
    - [st1051x005, struct.Struct.__reduce_ex__.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [st1051x006, struct.pack.__reduce_ex__.__qualname__.__class__.__name__.__eq__,     ["str"], true]
    - [st1051x007, struct.unpack.__reduce_ex__.__qualname__.__class__.__name__.__eq__,   ["str"], true]

table struct_extra1051.struct_sizeof_qualnames:
  description: "struct.Struct __sizeof__.__qualname__ identity"
  kind: python_call_eq
  category: sizeof_qualnames
  id_prefix: st1051s
  columns: [id, function, args, expected]
  rows:
    - [st1051s001, struct.Struct.__sizeof__.__qualname__.__eq__,              ["Struct.__sizeof__"], true]
    - [st1051s002, struct.Struct.__sizeof__.__qualname__.__class__.__name__.__eq__, ["str"],         true]
    - [st1051s003, struct.Struct.__sizeof__.__class__.__name__.__eq__,        ["slot_wrapper"],      true]

table struct_extra1051.init_subclass_qualnames:
  description: "struct.Struct and struct.error __init_subclass__.__qualname__ identity"
  kind: python_call_eq
  category: init_subclass_qualnames
  id_prefix: st1051i
  columns: [id, function, args, expected]
  rows:
    - [st1051i001, struct.Struct.__init_subclass__.__qualname__.__eq__,  ["object.__init_subclass__"], true]
    - [st1051i002, struct.error.__init_subclass__.__qualname__.__eq__,   ["object.__init_subclass__"], true]
    - [st1051i003, struct.Struct.__init_subclass__.__qualname__.__class__.__name__.__eq__, ["str"],    true]
    - [st1051i004, struct.error.__init_subclass__.__qualname__.__class__.__name__.__eq__, ["str"],     true]
    - [st1051i005, struct.Struct.__class__.__name__.__eq__,              ["type"],                     true]
    - [st1051i006, struct.error.__class__.__name__.__eq__,               ["type"],                     true]
    - [st1051i007, struct.error.__module__.__eq__,                       ["struct"],                   true]
    - [st1051i008, struct.Struct.__module__.__eq__,                      ["struct"],                   true]
    - [st1051i009, struct.Struct.__doc__.__class__.__name__.__eq__,      ["str"],                      true]
