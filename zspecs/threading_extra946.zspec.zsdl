spec: threading_extra946
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading module-level functions __module__ and threading.TIMEOUT_MAX class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra946.module_level_function_modules:
  description: "threading module-level function __module__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: th946mi
  columns: [id, function, args, expected]
  rows:
    - [th946mi001, threading.settrace.__module__.__eq__,                             ["threading"],   true]
    - [th946mi002, threading.setprofile.__module__.__eq__,                           ["threading"],   true]
    - [th946mi003, threading.stack_size.__module__.__eq__,                           ["threading"],   true]
    - [th946mi004, threading.active_count.__module__.__eq__,                         ["threading"],   true]
    - [th946mi005, threading.current_thread.__module__.__eq__,                       ["threading"],   true]
    - [th946mi006, threading.main_thread.__module__.__eq__,                          ["threading"],   true]
    - [th946mi007, threading.excepthook.__module__.__eq__,                           ["threading"],   true]

table threading_extra946.timeout_max_identity:
  description: "threading.TIMEOUT_MAX class identity and value checks"
  kind: python_call_eq
  category: timeout_identity
  id_prefix: th946ti
  columns: [id, function, args, expected]
  rows:
    - [th946ti001, threading.TIMEOUT_MAX.__class__.__name__.__eq__,                  ["float"],       true]
    - [th946ti002, threading.TIMEOUT_MAX.__class__.__module__.__eq__,                ["builtins"],    true]
    - [th946ti003, threading.TIMEOUT_MAX.__gt__,                                     [0],             true]

table threading_extra946.local_class_identity:
  description: "threading.local class identity checks"
  kind: python_call_eq
  category: local_identity
  id_prefix: th946li
  columns: [id, function, args, expected]
  rows:
    - [th946li001, threading.local.__module__.__eq__,                                ["_thread"],     true]
    - [th946li002, threading.local.__class__.__name__.__eq__,                        ["type"],        true]
    - [th946li003, threading.local.__name__.__eq__,                                  ["_local"],      true]

table threading_extra946.module_function_class_names:
  description: "threading module-level function __class__.__name__ identity"
  kind: python_call_eq
  category: function_class_names
  id_prefix: th946fc
  columns: [id, function, args, expected]
  rows:
    - [th946fc001, threading.settrace.__class__.__name__.__eq__,                     ["function"],    true]
    - [th946fc002, threading.setprofile.__class__.__name__.__eq__,                   ["function"],    true]
    - [th946fc003, threading.active_count.__class__.__name__.__eq__,                 ["function"],    true]
    - [th946fc004, threading.current_thread.__class__.__name__.__eq__,               ["function"],    true]
    - [th946fc005, threading.main_thread.__class__.__name__.__eq__,                  ["function"],    true]
    - [th946fc006, threading.excepthook.__class__.__name__.__eq__,                   ["function"],    true]
    - [th946fc007, threading.stack_size.__class__.__name__.__eq__,                   ["builtin_function_or_method"], true]
