spec: select_extra7
version: ">=3.9"
backend: python_module(select)

docs: https://docs.python.org/3/library/select.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/select.html — Python select module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/selectmodule.c"
  notes:
    - "Extends select.zspec.zsdl through select_extra6.zspec.zsdl."
    - "select.zspec.zsdl covers: select.__name__; poll.__name__; kqueue.__name__; kevent.__name__; POLLIN/POLLOUT/POLLERR is_int; KQ_FILTER_READ/WRITE is_int; kqueue()/poll() instance class."
    - "select_extra covers: error.__name__=='error'; error.__bases__[0].__name__=='OSError'; select.__name__; select.__module__."
    - "select_extra2 covers: select.__name__/module; error.__name__=='OSError'; error base=='Exception'; POLLIN==1; POLLOUT==4; KQ_FILTER_READ==-1; KQ_FILTER_WRITE==-2; KQ_EV_ADD/DELETE/ENABLE/DISABLE."
    - "select_extra3 covers: module __name__; poll.__module__; error.__module__; POLLERR>=1; POLLERR==8; POLLHUP==16; POLLNVAL==32."
    - "select_extra4 covers: kqueue/kevent __module__/__qualname__; select.__qualname__; KQ_FILTER_PROC==-5; KQ_FILTER_SIGNAL==-6; KQ_EV_ONESHOT/CLEAR/ERROR/EOF values and types."
    - "select_extra5 covers: PIPE_BUF==512; POLLPRI/POLLRDNORM/POLLWRNORM/POLLRDBAND/POLLWRBAND values and types; KQ_FILTER_AIO/VNODE/TIMER values; KQ_NOTE_DELETE/WRITE/EXTEND/ATTRIB/LINK/RENAME/REVOKE; KQ_NOTE_EXIT/FORK/EXEC."
    - "select_extra6 covers: error.__qualname__=='OSError'; poll.__qualname__=='poll'; POLLIN & POLLOUT == 0; POLLIN | POLLOUT == 5; POLLIN | POLLERR == 9; epoll raises AttributeError on macOS."
    - "This spec adds: kqueue.__bases__[0].__name__=='object'; kevent.__bases__[0].__name__=='object'; kqueue.__mro__ length==2; kevent.__mro__ length==2; KQ_EV_ADD | KQ_EV_ENABLE == 5; KQ_EV_ADD | KQ_EV_DELETE == 3; KQ_EV_ONESHOT | KQ_EV_CLEAR == 48; KQ_EV_ERROR | KQ_EV_EOF == 49152; POLLHUP | POLLNVAL == 48; POLLOUT | POLLERR == 12; PIPE_BUF << 1 == 1024; KQ_NOTE_DELETE | KQ_NOTE_WRITE == 3 (low vnode note bits)."
    - "kqueue and kevent are C extension types that inherit directly from object — same pattern as mmap.mmap."
    - "kqueue.__mro__ == [kqueue, object]; kevent.__mro__ == [kevent, object] — both have exactly two MRO entries."
    - "KQ_EV_ADD==1, KQ_EV_ENABLE==4: OR == 5 — typical add+enable combination for new kevent registrations."
    - "KQ_EV_ADD==1, KQ_EV_DELETE==2: OR == 3 — add and delete flags combined (documentation contrast pattern)."
    - "KQ_EV_ONESHOT==16, KQ_EV_CLEAR==32: OR == 48 — non-persistent trigger combinations."
    - "KQ_EV_ERROR==16384, KQ_EV_EOF==32768: OR == 49152 — output-side status flags combined."
    - "POLLHUP==16, POLLNVAL==32: OR == 48 — combined hangup+invalid mask."
    - "POLLOUT==4, POLLERR==8: OR == 12 — combined write+error poll event mask."
    - "PIPE_BUF==512: left-shift by 1 == 1024 — double the minimum atomic pipe-write size."
    - "KQ_NOTE_DELETE==1, KQ_NOTE_WRITE==2: OR == 3 — first two vnode-watch note bits combined."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# kqueue and kevent — base class and MRO length
#
# select_extra4 covers kqueue/__module__/__qualname__ and kevent/__module__/__qualname__.
# No prior spec checks kqueue.__bases__[0].__name__ or kevent.__bases__[0].__name__.
# No prior spec checks the MRO length for kqueue or kevent.
# Both are C extension types inheriting directly from object (2-entry MRO).
# ---------------------------------------------------------------------------

table select_extra7.kqueue_kevent_bases:
  description: "kqueue and kevent base class is object — direct C extension types"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [kqueue_base0, kqueue.__bases__.__getitem__, [0], __name__, [], "object"]
    - [kevent_base0, kevent.__bases__.__getitem__, [0], __name__, [], "object"]

table select_extra7.kqueue_kevent_mro_len:
  description: "kqueue and kevent __mro__ has exactly 2 entries (self + object)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mrolen

  columns: [id, function, args, expected]
  rows:
    - [kqueue, kqueue.__mro__.__len__, [], 2]
    - [kevent, kevent.__mro__.__len__, [], 2]

# ---------------------------------------------------------------------------
# KQ_EV_* bitmask combinations — not covered by any prior spec
#
# select_extra2 covers KQ_EV_ADD/DELETE/ENABLE/DISABLE individual values.
# select_extra4 covers KQ_EV_ONESHOT/CLEAR/ERROR/EOF individual values.
# No prior spec checks bitwise OR combinations of kevent flag constants.
# ---------------------------------------------------------------------------

invariant select_extra7.kqev_mask.add_or_enable:
  description: "select.KQ_EV_ADD | select.KQ_EV_ENABLE == 5 — typical new-registration combined flag"
  category: constants
  kind: python_call_eq
  function: KQ_EV_ADD.__or__
  args: [4]
  expected: 5

invariant select_extra7.kqev_mask.add_or_delete:
  description: "select.KQ_EV_ADD | select.KQ_EV_DELETE == 3 — add and delete flags combined"
  category: constants
  kind: python_call_eq
  function: KQ_EV_ADD.__or__
  args: [2]
  expected: 3

invariant select_extra7.kqev_mask.oneshot_or_clear:
  description: "select.KQ_EV_ONESHOT | select.KQ_EV_CLEAR == 48 — non-persistent trigger flags combined"
  category: constants
  kind: python_call_eq
  function: KQ_EV_ONESHOT.__or__
  args: [32]
  expected: 48

invariant select_extra7.kqev_mask.error_or_eof:
  description: "select.KQ_EV_ERROR | select.KQ_EV_EOF == 49152 — output status flags combined"
  category: constants
  kind: python_call_eq
  function: KQ_EV_ERROR.__or__
  args: [32768]
  expected: 49152

# ---------------------------------------------------------------------------
# POLL bitmask combinations — additional pairs not covered by select_extra6
#
# select_extra6 covers: POLLIN & POLLOUT == 0; POLLIN | POLLOUT == 5; POLLIN | POLLERR == 9.
# New here: POLLHUP | POLLNVAL, POLLOUT | POLLERR — additional poll event mask combinations.
# ---------------------------------------------------------------------------

invariant select_extra7.poll_mask.pollhup_or_pollnval:
  description: "select.POLLHUP | select.POLLNVAL == 48 — combined hangup+invalid poll mask"
  category: constants
  kind: python_call_eq
  function: POLLHUP.__or__
  args: [32]
  expected: 48

invariant select_extra7.poll_mask.pollout_or_pollerr:
  description: "select.POLLOUT | select.POLLERR == 12 — combined write+error poll event mask"
  category: constants
  kind: python_call_eq
  function: POLLOUT.__or__
  args: [8]
  expected: 12

# ---------------------------------------------------------------------------
# PIPE_BUF bit-shift arithmetic
#
# select_extra5 covers PIPE_BUF == 512 and PIPE_BUF is_int.
# No prior spec checks PIPE_BUF arithmetic operations.
# PIPE_BUF.__lshift__(1) == 1024 — double the minimum atomic pipe-write size.
# ---------------------------------------------------------------------------

invariant select_extra7.PIPE_BUF.lshift1:
  description: "select.PIPE_BUF << 1 == 1024 — double the minimum atomic pipe-write size on macOS"
  category: constants
  kind: python_call_eq
  function: PIPE_BUF.__lshift__
  args: [1]
  expected: 1024

# ---------------------------------------------------------------------------
# KQ_NOTE_DELETE | KQ_NOTE_WRITE — low vnode note bits combined
#
# select_extra5 covers individual KQ_NOTE_DELETE==1 and KQ_NOTE_WRITE==2 values.
# No prior spec checks bitwise combinations of KQ_NOTE_* vnode watch constants.
# KQ_NOTE_DELETE==1, KQ_NOTE_WRITE==2: OR == 3.
# ---------------------------------------------------------------------------

invariant select_extra7.kq_note.delete_or_write:
  description: "select.KQ_NOTE_DELETE | select.KQ_NOTE_WRITE == 3 — first two vnode-watch note bits combined"
  category: constants
  kind: python_call_eq
  function: KQ_NOTE_DELETE.__or__
  args: [2]
  expected: 3
