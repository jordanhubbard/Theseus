spec: threading_extra30
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra29.zspec.zsdl."
    - "Prior specs covered: Thread.__name__/__module__/__qualname__, Lock/RLock/Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier class names and modules, current_thread/main_thread/active_count/enumerate/__name__, TIMEOUT_MAX, local().__class__.__name__, threading.excepthook/__name__, threading.stack_size/__name__, Thread.__init__.__name__, Event.__qualname__=='Event', various __module__ checks, class __name__ length table for Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier, __module__.__len__() for Thread/Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier (all 9), __qualname__.__len__() for Thread/Event/Condition, __name__.__len__() for Thread/Event."
    - "This spec covers: __name__.__len__() for Semaphore/BoundedSemaphore/Barrier/Timer/RLock; __qualname__.__len__() for Semaphore/BoundedSemaphore/Barrier/Timer; Lock.__module__.__len__() == 7 (from _thread C extension); current_thread/__name__.__len__(); main_thread/__name__.__len__()."
    - "Semaphore.__name__ == 'Semaphore' — length 9."
    - "BoundedSemaphore.__name__ == 'BoundedSemaphore' — length 16."
    - "Barrier.__name__ == 'Barrier' — length 7."
    - "Timer.__name__ == 'Timer' — length 5."
    - "RLock.__name__ == 'RLock' — length 5 (RLock is a factory function, not a class; __name__ reflects the function name)."
    - "Lock.__module__ == '_thread' — length 7. Lock is the C-extension _thread.lock type, not a pure-Python class."
    - "current_thread.__name__ == 'current_thread' — length 14."
    - "main_thread.__name__ == 'main_thread' — length 11."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ length table — extra30 namespace
#
# Prior specs covered Thread (len=6) and Event (len=5). This table extends
# the __name__.__len__() axis to the remaining threading sync classes:
#   Semaphore.__name__ == 'Semaphore' (length 9)
#   BoundedSemaphore.__name__ == 'BoundedSemaphore' (length 16)
#   Barrier.__name__ == 'Barrier' (length 7)
#   Timer.__name__ == 'Timer' (length 5)
#   RLock.__name__ == 'RLock' (length 5)
# ---------------------------------------------------------------------------

table threading_extra30.class_name_lengths:
  description: "threading class __name__ lengths for Semaphore/BoundedSemaphore/Barrier/Timer/RLock in extra30 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: clsnamelen30

  columns: [id, function, args, expected]
  rows:
    - [Semaphore,        Semaphore.__name__.__len__,        [], 9]
    - [BoundedSemaphore, BoundedSemaphore.__name__.__len__, [], 16]
    - [Barrier,          Barrier.__name__.__len__,          [], 7]
    - [Timer,            Timer.__name__.__len__,            [], 5]
    - [RLock,            RLock.__name__.__len__,            [], 5]

# ---------------------------------------------------------------------------
# Class __qualname__ length table — extra30 namespace
#
# For pure-Python threading classes, __qualname__ == __name__ (no nesting).
# This table covers Semaphore/BoundedSemaphore/Barrier/Timer, which were
# absent from prior __qualname__.__len__() tables (those covered Thread,
# Event, and Condition only).
#   Semaphore.__qualname__ == 'Semaphore' (length 9)
#   BoundedSemaphore.__qualname__ == 'BoundedSemaphore' (length 16)
#   Barrier.__qualname__ == 'Barrier' (length 7)
#   Timer.__qualname__ == 'Timer' (length 5)
# ---------------------------------------------------------------------------

table threading_extra30.class_qualname_lengths:
  description: "threading class __qualname__ lengths for Semaphore/BoundedSemaphore/Barrier/Timer in extra30 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: clsqualnamelen30

  columns: [id, function, args, expected]
  rows:
    - [Semaphore,        Semaphore.__qualname__.__len__,        [], 9]
    - [BoundedSemaphore, BoundedSemaphore.__qualname__.__len__, [], 16]
    - [Barrier,          Barrier.__qualname__.__len__,          [], 7]
    - [Timer,            Timer.__qualname__.__len__,            [], 5]

# ---------------------------------------------------------------------------
# Lock.__module__ length — extra30 standalone invariant
#
# threading.Lock is actually the C-extension type _thread.lock; its __module__
# is '_thread' (length 7), not 'threading' (length 9). This distinguishes it
# from all other threading sync classes which are pure-Python with __module__
# == 'threading'.
# ---------------------------------------------------------------------------

invariant threading_extra30.Lock.module_len:
  description: "threading.Lock.__module__.__len__() == 7 — Lock is _thread.lock from the C extension '_thread'"
  category: class_modules
  kind: python_call_eq
  function: Lock.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# current_thread.__name__ length — extra30 standalone invariant
#
# threading.current_thread is a module-level pure-Python function with
# __name__ == 'current_thread' (length 14). Prior specs confirm the string
# value; this spec adds the length invariant in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra30.current_thread.name_len:
  description: "threading.current_thread.__name__.__len__() == 14 — 'current_thread' has fourteen characters"
  category: method_names
  kind: python_call_eq
  function: current_thread.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# main_thread.__name__ length — extra30 standalone invariant
#
# threading.main_thread is a module-level pure-Python function with
# __name__ == 'main_thread' (length 11). Prior specs confirm the string
# value; this spec adds the length invariant in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra30.main_thread.name_len:
  description: "threading.main_thread.__name__.__len__() == 11 — 'main_thread' has eleven characters"
  category: method_names
  kind: python_call_eq
  function: main_thread.__name__.__len__
  args: []
  expected: 11
