spec: lodash_snakecase
version: ">=4.0.0"
backend: node(lodash.snakecase)

docs: https://lodash.com/docs/#snakeCase

provenance:
  derived_from:
    - "lodash.snakecase README — https://www.npmjs.com/package/lodash.snakecase"
    - "Test vectors verified with lodash.snakecase@4.1.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.snakecase exports the _.snakeCase function directly as module.exports."
    - "Converts a string to snake_case."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns snake_case string. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_snakecase.convert:
  kind: node_module_call_eq
  function: ~
  category: convert
  id_prefix: lsnake

  columns: [id, args, expected]
  rows:
    - [camel,  ["helloWorld"],  "hello_world"]
    - [kebab,  ["foo-bar"],     "foo_bar"]
    - [space,  ["foo bar"],     "foo_bar"]
