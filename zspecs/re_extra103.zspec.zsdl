spec: re_extra103
version: ">=3.9"
backend: python_module(re)
extends: re_extra102

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra102.zspec.zsdl."
    - "This spec covers: re.Match method __qualname__ values and lengths; re.Match method class names."
    - "re.Match is a C extension type (_sre.SRE_Match or re.Match). Its methods are C-level method_descriptors."
    - "re.Match.group.__qualname__ = 'Match.group' (length 11)."
    - "re.Match.groups.__qualname__ = 'Match.groups' (length 12)."
    - "re.Match.start.__qualname__ = 'Match.start' (length 11; same as group)."
    - "re.Match.end.__qualname__ = 'Match.end' (length 9)."
    - "re.Match.span.__qualname__ = 'Match.span' (length 10)."
    - "re.Match.groupdict.__qualname__ = 'Match.groupdict' (length 15)."
    - "re.Match.expand.__qualname__ = 'Match.expand' (length 12; same as groups)."
    - "All re.Match methods are C method_descriptors."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match method __qualname__ values
# re.Match is a C extension type. Its methods are method_descriptors.
# Their __qualname__ uses the 'Match.method_name' pattern.
# ---------------------------------------------------------------------------

table re_extra103.Match_method_qualnames:
  description: "re.Match method __qualname__ values: group, groups, start, end, span, groupdict, expand all use 'Match.method_name' format"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: rematchmeth103

  columns: [id, function, args, expected, description]
  rows:
    - [group_qn,     Match.group.__qualname__.__eq__,     ["Match.group"],     true, "Match.group.__qualname__ == 'Match.group'"]
    - [groups_qn,    Match.groups.__qualname__.__eq__,    ["Match.groups"],    true, "Match.groups.__qualname__ == 'Match.groups'"]
    - [start_qn,     Match.start.__qualname__.__eq__,     ["Match.start"],     true, "Match.start.__qualname__ == 'Match.start'"]
    - [end_qn,       Match.end.__qualname__.__eq__,       ["Match.end"],       true, "Match.end.__qualname__ == 'Match.end'"]
    - [span_qn,      Match.span.__qualname__.__eq__,      ["Match.span"],      true, "Match.span.__qualname__ == 'Match.span'"]
    - [gdict_qn,     Match.groupdict.__qualname__.__eq__, ["Match.groupdict"], true, "Match.groupdict.__qualname__ == 'Match.groupdict'"]
    - [expand_qn,    Match.expand.__qualname__.__eq__,    ["Match.expand"],    true, "Match.expand.__qualname__ == 'Match.expand'"]
    - [group_not_re, Match.group.__qualname__.__eq__,     ["re.Match.group"],  false, "Match.group.__qualname__ is NOT 're.Match.group' (qualname does not include the module name)"]

# ---------------------------------------------------------------------------
# re.Match method __qualname__ lengths
# end (9) is the shortest; groupdict (15) is the longest in this spec.
# ---------------------------------------------------------------------------

table re_extra103.Match_method_qualname_lengths:
  description: "re.Match method __qualname__ length values: group=11, groups=12, start=11, end=9, span=10, groupdict=15, expand=12"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: rematchmeth103

  columns: [id, function, args, expected, description]
  rows:
    - [group_qn_len,  Match.group.__qualname__.__len__,     [], 11, "Match.group.__qualname__.__len__() == 11 ('Match.group' has 11 characters)"]
    - [groups_qn_len, Match.groups.__qualname__.__len__,    [], 12, "Match.groups.__qualname__.__len__() == 12 ('Match.groups' has 12 characters)"]
    - [start_qn_len,  Match.start.__qualname__.__len__,     [], 11, "Match.start.__qualname__.__len__() == 11 ('Match.start' has 11 characters; same length as group)"]
    - [end_qn_len,    Match.end.__qualname__.__len__,       [], 9,  "Match.end.__qualname__.__len__() == 9 ('Match.end' has 9 characters; shortest Match method qualname in this spec)"]
    - [span_qn_len,   Match.span.__qualname__.__len__,      [], 10, "Match.span.__qualname__.__len__() == 10 ('Match.span' has 10 characters)"]
    - [gdict_qn_len,  Match.groupdict.__qualname__.__len__, [], 15, "Match.groupdict.__qualname__.__len__() == 15 ('Match.groupdict' has 15 characters; longest Match method qualname in this spec)"]
    - [expand_qn_len, Match.expand.__qualname__.__len__,    [], 12, "Match.expand.__qualname__.__len__() == 12 ('Match.expand' has 12 characters; same length as groups)"]

# ---------------------------------------------------------------------------
# re.Match method class names
# re.Match is a C extension type (_sre.SRE_Match). Its methods are
# C-level method_descriptors (not Python functions).
# ---------------------------------------------------------------------------

table re_extra103.Match_method_class_names:
  description: "re.Match methods are C method_descriptors because Match is a C extension type; __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_class_names
  id_prefix: rematchmeth103

  columns: [id, function, args, expected, description]
  rows:
    - [group_cls,      Match.group.__class__.__name__.__eq__,     ["method_descriptor"], true,  "Match.group.__class__.__name__ == 'method_descriptor'"]
    - [groups_cls,     Match.groups.__class__.__name__.__eq__,    ["method_descriptor"], true,  "Match.groups.__class__.__name__ == 'method_descriptor'"]
    - [start_cls,      Match.start.__class__.__name__.__eq__,     ["method_descriptor"], true,  "Match.start.__class__.__name__ == 'method_descriptor'"]
    - [end_cls,        Match.end.__class__.__name__.__eq__,       ["method_descriptor"], true,  "Match.end.__class__.__name__ == 'method_descriptor'"]
    - [span_cls,       Match.span.__class__.__name__.__eq__,      ["method_descriptor"], true,  "Match.span.__class__.__name__ == 'method_descriptor'"]
    - [group_not_fn,   Match.group.__class__.__name__.__eq__,     ["function"],          false, "Match.group.__class__.__name__ is NOT 'function' (Match methods are C extension descriptors, not Python functions)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra103.Match.group_qualname:
  description: "re.Match.group.__qualname__ == 'Match.group' (re.Match is a C extension type; method qualnames use the 'Match.method_name' pattern, not 're.Match.method_name')"
  category: method_qualnames
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra103.Match.groupdict_qualname_len:
  description: "re.Match.groupdict.__qualname__.__len__() == 15 ('Match.groupdict' is 15 characters; the longest Match method qualname in this spec)"
  category: method_qualnames
  kind: python_call_eq
  function: Match.groupdict.__qualname__.__len__
  args: []
  expected: 15

invariant re_extra103.Match.end_qualname_len:
  description: "re.Match.end.__qualname__.__len__() == 9 ('Match.end' is the shortest Match method qualname in this spec at 9 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: Match.end.__qualname__.__len__
  args: []
  expected: 9

invariant re_extra103.Match.group_is_method_descriptor:
  description: "re.Match.group.__class__.__name__ == 'method_descriptor' (re.Match is a C extension type from _sre; its methods are C-level method_descriptors, not Python functions)"
  category: method_class_names
  kind: python_call_eq
  function: Match.group.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra103.Match.span_qualname_len:
  description: "re.Match.span.__qualname__.__len__() == 10 ('Match.span' has 10 characters, one more than Match.end at 9 and one fewer than Match.group at 11)"
  category: method_qualnames
  kind: python_call_eq
  function: Match.span.__qualname__.__len__
  args: []
  expected: 10
