spec: zod_validation_error
version: ">=4.0.0"
backend: node(zod-validation-error)

docs: https://github.com/causaly/zod-validation-error#readme

provenance:
  derived_from:
    - "zod-validation-error README — https://github.com/causaly/zod-validation-error#readme"
    - "Test vectors verified with zod-validation-error via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "zod-validation-error source"
  notes:
    - "Wrap ZodError in a more user-friendly ValidationError class — used in many zod-using projects."
    - "Install: npm install zod-validation-error"
    - "v4 CJS; named exports ValidationError / fromZodError / fromError / toValidationError / isValidationError / isValidationErrorLike / isZodErrorLike."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "ValidationError is a Error subclass; wrap functions never throw."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes:
    ValidationError: "Wrapped ZodError with friendlier .message and .details"

invariant zod_validation_error.has_ValidationError:
  description: "ValidationError class exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "ValidationError.constructor.name"}
  expected: "Function"

invariant zod_validation_error.has_fromZodError:
  description: "fromZodError() helper exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "fromZodError.constructor.name"}
  expected: "Function"

invariant zod_validation_error.has_fromError:
  description: "fromError() (generic) exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "fromError.constructor.name"}
  expected: "Function"

invariant zod_validation_error.has_toValidationError:
  description: "toValidationError() exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "toValidationError.constructor.name"}
  expected: "Function"

invariant zod_validation_error.has_isValidationError:
  description: "isValidationError() predicate exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "isValidationError.constructor.name"}
  expected: "Function"

invariant zod_validation_error.isValidationError_on_random_object:
  description: "isValidationError({}) returns false"
  category: predicate
  kind: node_chain_eq
  entry: named
  function: isValidationError
  entry_args: [{}]
  chain: []
  expected: false

invariant zod_validation_error.isValidationError_on_string:
  description: "isValidationError('hi') returns false"
  category: predicate
  kind: node_chain_eq
  entry: named
  function: isValidationError
  entry_args: ["hi"]
  chain: []
  expected: false

invariant zod_validation_error.has_createErrorMap:
  description: "createErrorMap() helper exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "createErrorMap.constructor.name"}
  expected: "Function"

invariant zod_validation_error.has_createMessageBuilder:
  description: "createMessageBuilder() helper exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "createMessageBuilder.constructor.name"}
  expected: "Function"
