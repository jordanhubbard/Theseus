spec: asyncio_extra133
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec covers: wave 256 theme — asyncio.Event method qualnames and identity. NEW in extra133: asyncio.Event.__init__.__qualname__=='Event.__init__' (len=14); asyncio.Event.set.__qualname__=='Event.set' (len=9); asyncio.Event.clear.__qualname__=='Event.clear' (len=11); asyncio.Event.wait.__qualname__=='Event.wait' (len=10); asyncio.Event.is_set.__qualname__=='Event.is_set' (len=12); asyncio.Event.__qualname__=='Event' (len=5); asyncio.Event.__module__=='asyncio.locks' (len=13); asyncio.Event.__bases__[0].__name__=='_LoopBoundMixin'; asyncio.Event.__mro__.__len__()==3; asyncio.Event.__init__.__code__.co_argcount==1; asyncio.Event.set.__code__.co_argcount==1; asyncio.Event.clear.__code__.co_argcount==1; asyncio.Event.is_set.__code__.co_argcount==1. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Event.__init__.__qualname__ == 'Event.__init__' (len=14). 'Event'=5 + '.'=1 + '__init__'=8 = 14. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Event.wait is a coroutine function (inspect.iscoroutinefunction returns True). The other Event methods (set, clear, is_set, __init__) are regular synchronous functions. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Event.__module__ == 'asyncio.locks' (len=13). Event is defined in Lib/asyncio/locks.py and re-exported via asyncio/__init__.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

