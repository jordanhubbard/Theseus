    - [set_qn_eq,    asyncio.Event.set.__qualname__.__eq__,        ["Event.set"],      true, "asyncio.Event.set.__qualname__ == 'Event.set' (len=9); verified with Python 3.14.3"]
    - [clear_qn_eq,  asyncio.Event.clear.__qualname__.__eq__,      ["Event.clear"],    true, "asyncio.Event.clear.__qualname__ == 'Event.clear' (len=11); verified with Python 3.14.3"]
