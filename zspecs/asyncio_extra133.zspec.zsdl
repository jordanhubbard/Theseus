    - [clear_argc,   asyncio.Event.clear.__code__.co_argcount.__eq__,      [1],              true, "asyncio.Event.clear.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
    - [isset_argc,   asyncio.Event.is_set.__code__.co_argcount.__eq__,     [1],              true, "asyncio.Event.is_set.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra133
# ---------------------------------------------------------------------------

invariant asyncio_extra133.Event_init_qualname_len_14:
  description: "asyncio.Event.__init__.__qualname__.__len__() == 14 — asyncio.Event.__init__.__qualname__ is 'Event.__init__' (14 chars: 'Event'=5 + '.'=1 + '__init__'=8 = 14); this is the longest method qualname among the 5 asyncio.Event methods: __init__=14 > is_set=12 > clear=11 > wait=10 > set=9; all five qualnames share the prefix 'Event.' (6 chars) followed by the method name; Event.__init__ takes only self (co_argcount=1) — no parameters for initialization; Event.__module__ is 'asyncio.locks' (len=13); NEW in extra133: first standalone Event.__init__ qualname length invariant in asyncioeventqn133 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.__init__.__qualname__.__len__
  args: []
  expected: 14

invariant asyncio_extra133.Event_set_qualname_eq:
  description: "asyncio.Event.set.__qualname__.__eq__('Event.set') returns True — asyncio.Event.set.__qualname__ is 'Event.set' (9 chars: 'Event'=5 + '.'=1 + 'set'=3 = 9); this is the shortest method qualname among the 5 asyncio.Event methods; Event.set is a synchronous function (not a coroutine, unlike Event.wait) that sets the internal flag to True and wakes all waiters; Event.set.__code__.co_argcount is 1 (self only); Event.set.__class__.__name__ is 'function'; Event.set.__module__ is 'asyncio.locks'; NEW in extra133: first standalone Event.set qualname equality invariant in asyncioeventqn133 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.set.__qualname__.__eq__
  args: ["Event.set"]
  expected: true

invariant asyncio_extra133.Event_clear_qualname_len_11:
  description: "asyncio.Event.clear.__qualname__.__len__() == 11 — asyncio.Event.clear.__qualname__ is 'Event.clear' (11 chars: 'Event'=5 + '.'=1 + 'clear'=5 = 11); Event.clear is the synchronous complement of Event.set; it resets the internal flag to False so that coroutines calling Event.wait() will block; Event.clear.__code__.co_argcount is 1 (self only); Event.clear.__class__.__name__ is 'function'; qualname length 11 places Event.clear between Event.wait (10) and Event.is_set (12) in the ordering; NEW in extra133: first standalone Event.clear qualname length invariant in asyncioeventqn133 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.clear.__qualname__.__len__
  args: []
  expected: 11

invariant asyncio_extra133.Event_is_set_qualname_eq:
  description: "asyncio.Event.is_set.__qualname__.__eq__('Event.is_set') returns True — asyncio.Event.is_set.__qualname__ is 'Event.is_set' (12 chars: 'Event'=5 + '.'=1 + 'is_set'=6 = 12); Event.is_set returns True if the internal flag is set, False otherwise; Event.is_set is a synchronous function (not a coroutine); Event.is_set.__code__.co_name is 'is_set' and co_argcount is 1 (self only); Event.is_set qualname length 12 is one less than Event.__init__ (14) and one greater than Event.clear (11); Event.__module__ is 'asyncio.locks'; NEW in extra133: first standalone Event.is_set qualname equality invariant in asyncioeventqn133 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.is_set.__qualname__.__eq__
  args: ["Event.is_set"]
  expected: true

invariant asyncio_extra133.Event_wait_qualname_len_10:
  description: "asyncio.Event.wait.__qualname__.__len__() == 10 — asyncio.Event.wait.__qualname__ is 'Event.wait' (10 chars: 'Event'=5 + '.'=1 + 'wait'=4 = 10); Event.wait is a coroutine function (inspect.iscoroutinefunction returns True), unlike the other four Event methods (set, clear, is_set, __init__) which are synchronous; Event.wait blocks until the internal flag is set to True; Event.wait.__qualname__ len 10 is between Event.clear (11) and Event.set (9); Event.__module__ is 'asyncio.locks' (len=13); asyncio.Event.__mro__.__len__() is 3 ([Event, _LoopBoundMixin, object]); NEW in extra133: first standalone Event.wait qualname length invariant in asyncioeventqn133 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.wait.__qualname__.__len__
  args: []
  expected: 10
