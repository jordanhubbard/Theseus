table asyncio_extra133.asyncio_event_class_identity_and_argcount:
  description: "asyncio.Event class identity and method co_argcount checks in asyncioeventqn133 namespace — wave 256 theme: asyncio.Event class identity; Event.__module__.__eq__('asyncio.locks')==True (len=13: 'asyncio.'=8+'locks'=5; Event is defined in Lib/asyncio/locks.py, same file as Lock, Semaphore, Condition, Barrier); Event.__module__.__len__()==13; Event.__bases__[0].__name__.__eq__('_LoopBoundMixin')==True (Event's sole direct base is _LoopBoundMixin, the same base used by asyncio.Queue); Event.__mro__.__len__()==3 (MRO=[Event, _LoopBoundMixin, object]); Event.__init__.__code__.co_argcount==1 (takes only self; no parameters for Event.__init__); Event.set.__code__.co_argcount==1 (self only); Event.clear.__code__.co_argcount==1 (self only); Event.is_set.__code__.co_argcount==1 (self only — all four synchronous methods take only self); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioeventqn133b

  columns: [id, function, args, expected, description]
  rows:
    - [mod_eq,       asyncio.Event.__module__.__eq__,                      ["asyncio.locks"], true, "asyncio.Event.__module__ == 'asyncio.locks' (len=13); verified with Python 3.14.3"]
    - [mod_len,      asyncio.Event.__module__.__len__,                     [],               13,   "asyncio.Event.__module__.__len__() == 13 ('asyncio.locks'=13); verified with Python 3.14.3"]
    - [base0,        "asyncio.Event.__bases__[0].__name__.__eq__",         ["_LoopBoundMixin"], true, "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin' (same base as asyncio.Queue); verified with Python 3.14.3"]
    - [mro_len,      asyncio.Event.__mro__.__len__,                        [],               3,    "asyncio.Event.__mro__.__len__() == 3 — MRO=[Event, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [init_argc,    asyncio.Event.__init__.__code__.co_argcount.__eq__,   [1],              true, "asyncio.Event.__init__.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]
