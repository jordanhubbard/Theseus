# asyncio.Event.set.__qualname__       == 'Event.set'       (len=9)
# asyncio.Event.clear.__qualname__     == 'Event.clear'     (len=11)
# asyncio.Event.wait.__qualname__      == 'Event.wait'      (len=10)
# asyncio.Event.is_set.__qualname__    == 'Event.is_set'    (len=12)
# ---------------------------------------------------------------------------

table asyncio_extra133.asyncio_event_method_qualnames:
  description: "asyncio.Event method qualname string equality checks in asyncioeventqn133 namespace — wave 256 theme: asyncio.Event method qualnames; Event is defined in Lib/asyncio/locks.py and its method qualnames take the form 'Event.<method>'; Event.__init__.__qualname__.__eq__('Event.__init__')==True (len=14: 'Event'=5+'.'=1+'__init__'=8); Event.set.__qualname__.__eq__('Event.set')==True (len=9: 'Event'=5+'.'=1+'set'=3); Event.clear.__qualname__.__eq__('Event.clear')==True (len=11: 'Event'=5+'.'=1+'clear'=5); Event.wait.__qualname__.__eq__('Event.wait')==True (len=10: 'Event'=5+'.'=1+'wait'=4); Event.is_set.__qualname__.__eq__('Event.is_set')==True (len=12: 'Event'=5+'.'=1+'is_set'=6); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
