  derived_from:
    - "lodash.set README — https://www.npmjs.com/package/lodash.set"
    - "Test vectors verified with lodash.set@4.3.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.set exports the _.set function directly as module.exports."
    - "set(object, path, value) mutates object by setting the value at path."
    - "Intermediate objects are created as needed for nested paths."
    - "Returns the mutated object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the mutated object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_set.set:
  kind: node_module_call_eq
  function: ~
  category: set
  id_prefix: lset

  columns: [id, args, expected]
  rows:
    - [top_level,  [{"a": 1}, "b", 2],         {"a": 1, "b": 2}]
    - [nested,     [{}, "a.b.c", 42],           {"a": {"b": {"c": 42}}}]
    - [overwrite,  [{"a": 1}, "a", 99],         {"a": 99}]

