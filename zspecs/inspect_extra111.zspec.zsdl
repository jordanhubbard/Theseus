spec: inspect_extra111
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra110.zspec.zsdl."
    - "This spec covers: inspect.getattr_static, inspect.classify_class_attrs, inspect.getmembers, inspect.getmembers_static, inspect.stack, inspect.trace, inspect.getouterframes code attributes; inspect.currentframe class name; wave 263."
    - "inspect.getattr_static.__code__.co_name == 'getattr_static'. Verified with Python 3.14.3."
    - "inspect.getattr_static.__code__.co_argcount == 3. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__code__.co_name == 'classify_class_attrs'. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_name == 'getmembers'. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.getmembers_static.__code__.co_name == 'getmembers_static'. Verified with Python 3.14.3."
    - "inspect.getmembers_static.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.currentframe.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "inspect.currentframe.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.stack.__code__.co_name == 'stack'. Verified with Python 3.14.3."
    - "inspect.stack.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.trace.__code__.co_name == 'trace'. Verified with Python 3.14.3."
    - "inspect.trace.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.getouterframes.__code__.co_name == 'getouterframes'. Verified with Python 3.14.3."
    - "inspect.getouterframes.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect static-introspection functions — co_name and co_argcount
#
# Wave 263 theme: inspect.getattr_static, inspect.classify_class_attrs,
# inspect.getmembers, and inspect.getmembers_static are pure-Python functions
# in Lib/inspect.py that perform static attribute introspection (without
# triggering descriptor protocol). Their co_name values match their function
# names. getattr_static(obj, attr, default=None) has co_argcount 3.
# classify_class_attrs(cls) has co_argcount 1.
# getmembers(object, predicate=None) has co_argcount 2.
# getmembers_static(object, predicate=None) has co_argcount 2.
#
# inspect.getattr_static.__code__.co_name == 'getattr_static'
# inspect.getattr_static.__code__.co_argcount == 3
# inspect.classify_class_attrs.__code__.co_name == 'classify_class_attrs'
# inspect.classify_class_attrs.__code__.co_argcount == 1
# inspect.getmembers.__code__.co_name == 'getmembers'
# inspect.getmembers.__code__.co_argcount == 2
# inspect.getmembers_static.__code__.co_name == 'getmembers_static'
# inspect.getmembers_static.__code__.co_argcount == 2
#
# New to extra111.
# ---------------------------------------------------------------------------

table inspect_extra111.static_introspection_co_attrs:
  description: "inspect static introspection functions co_name/co_argcount: getattr_static(3), classify_class_attrs(1), getmembers(2), getmembers_static(2); wave 263; new to extra111"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectsi111

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static_co_name,
       "getattr_static.__code__.co_name.__eq__",
       ["getattr_static"],
       true,
       "inspect.getattr_static.__code__.co_name.__eq__('getattr_static') == True — inspect.getattr_static is a pure-Python function in Lib/inspect.py that retrieves attributes without triggering the descriptor protocol (no __get__ calls); its __code__.co_name is 'getattr_static' matching the def-statement name; str.__eq__('getattr_static') returns True; new to extra111"]
    - [getattr_static_co_argcount_3,
       "getattr_static.__code__.co_argcount.__eq__",
       [3],
       true,
       "inspect.getattr_static.__code__.co_argcount.__eq__(3) == True — inspect.getattr_static(obj, name, default=_empty) has 3 positional-or-keyword parameters: obj (the object to inspect), name (the attribute name), and default (optional, sentinel value); co_argcount counts all 3 including those with defaults; int.__eq__(3) returns True; new to extra111"]
    - [classify_class_attrs_co_name,
       "classify_class_attrs.__code__.co_name.__eq__",
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__code__.co_name.__eq__('classify_class_attrs') == True — inspect.classify_class_attrs is a pure-Python function that returns a list of Attribute namedtuples describing the attributes of a class; its __code__.co_name is 'classify_class_attrs'; str.__eq__('classify_class_attrs') returns True; new to extra111"]
    - [classify_class_attrs_co_argcount_1,
       "classify_class_attrs.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.classify_class_attrs.__code__.co_argcount.__eq__(1) == True — inspect.classify_class_attrs(cls) takes exactly one argument: the class to inspect; co_argcount is 1; int.__eq__(1) returns True; new to extra111"]
    - [getmembers_co_name,
       "getmembers.__code__.co_name.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__code__.co_name.__eq__('getmembers') == True — inspect.getmembers is a pure-Python function that returns all members of an object as (name, value) pairs, sorted alphabetically; it triggers descriptors; its __code__.co_name is 'getmembers'; str.__eq__('getmembers') returns True; new to extra111"]
    - [getmembers_co_argcount_2,
       "getmembers.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — inspect.getmembers(object, predicate=None) has 2 positional-or-keyword parameters: object and an optional predicate callable; co_argcount is 2; int.__eq__(2) returns True; new to extra111"]
    - [getmembers_static_co_name,
       "getmembers_static.__code__.co_name.__eq__",
       ["getmembers_static"],
       true,
       "inspect.getmembers_static.__code__.co_name.__eq__('getmembers_static') == True — inspect.getmembers_static was added in Python 3.11; it is like getmembers but uses getattr_static internally to avoid triggering descriptors; its __code__.co_name is 'getmembers_static'; str.__eq__('getmembers_static') returns True; new to extra111"]
    - [getmembers_static_co_argcount_2,
       "getmembers_static.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers_static.__code__.co_argcount.__eq__(2) == True — inspect.getmembers_static(object, predicate=None) has 2 positional-or-keyword parameters: object and an optional predicate; same signature shape as getmembers; co_argcount is 2; int.__eq__(2) returns True; new to extra111"]

# ---------------------------------------------------------------------------
# Table 2: inspect frame/stack functions — co_name, co_argcount, and currentframe
#
# Wave 263 theme: inspect.stack, inspect.trace, and inspect.getouterframes are
# pure-Python wrappers around the C-level frame inspection machinery. Their
# co_name values match their function names. stack(context=1) and
# trace(context=1) each take 1 argument. getouterframes(frame, context=1) takes
# 2 arguments. inspect.currentframe is a reference to the C builtin
# sys._getframe; accessed via inspect, it is of type 'function' because
# inspect assigns it via: currentframe = sys._getframe.
#
# inspect.stack.__code__.co_name == 'stack'
# inspect.stack.__code__.co_argcount == 1
# inspect.trace.__code__.co_name == 'trace'
# inspect.trace.__code__.co_argcount == 1
# inspect.getouterframes.__code__.co_name == 'getouterframes'
# inspect.getouterframes.__code__.co_argcount == 2
# inspect.currentframe.__class__.__name__ == 'function'
#
# New to extra111.
# ---------------------------------------------------------------------------

table inspect_extra111.frame_stack_co_attrs:
  description: "inspect frame/stack functions: stack co_argcount 1, trace co_argcount 1, getouterframes co_argcount 2; co_name matches function name; currentframe class is 'function'; wave 263; new to extra111"
  kind: python_call_eq
  category: code_identity
  id_prefix: inspectfs111

  columns: [id, function, args, expected, description]
  rows:
    - [stack_co_name,
       "stack.__code__.co_name.__eq__",
       ["stack"],
       true,
       "inspect.stack.__code__.co_name.__eq__('stack') == True — inspect.stack is a pure-Python function that returns a list of FrameInfo namedtuples for the caller's stack; it calls getouterframes(sys._getframe(1), context); its __code__.co_name is 'stack'; str.__eq__('stack') returns True; new to extra111"]
    - [stack_co_argcount_1,
       "stack.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.stack.__code__.co_argcount.__eq__(1) == True — inspect.stack(context=1) has 1 positional-or-keyword parameter: context (the number of lines of context to return around the current line, with default 1); co_argcount is 1; int.__eq__(1) returns True; new to extra111"]
    - [trace_co_name,
       "trace.__code__.co_name.__eq__",
       ["trace"],
       true,
       "inspect.trace.__code__.co_name.__eq__('trace') == True — inspect.trace is a pure-Python function that returns the stack trace for the current exception; it calls getinnerframes(sys.exc_info()[2], context); its __code__.co_name is 'trace'; str.__eq__('trace') returns True; new to extra111"]
    - [trace_co_argcount_1,
       "trace.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.trace.__code__.co_argcount.__eq__(1) == True — inspect.trace(context=1) has 1 positional-or-keyword parameter: context (default 1); same signature shape as stack; co_argcount is 1; int.__eq__(1) returns True; new to extra111"]
    - [getouterframes_co_name,
       "getouterframes.__code__.co_name.__eq__",
       ["getouterframes"],
       true,
       "inspect.getouterframes.__code__.co_name.__eq__('getouterframes') == True — inspect.getouterframes is a pure-Python function that returns a list of FrameInfo namedtuples for the frame and all outer frames; its __code__.co_name is 'getouterframes'; str.__eq__('getouterframes') returns True; new to extra111"]
    - [getouterframes_co_argcount_2,
       "getouterframes.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getouterframes.__code__.co_argcount.__eq__(2) == True — inspect.getouterframes(frame, context=1) has 2 positional-or-keyword parameters: frame (the starting frame object) and context (number of context lines, default 1); co_argcount is 2; int.__eq__(2) returns True; new to extra111"]
    - [currentframe_class_function,
       "currentframe.__class__.__name__.__eq__",
       ["function"],
       true,
       "inspect.currentframe.__class__.__name__.__eq__('function') == True — inspect.currentframe is assigned from sys._getframe in Lib/inspect.py; it is a built-in function; however, its __class__.__name__ is 'function' when accessed via the inspect module; str.__eq__('function') returns True; new to extra111"]

# ---------------------------------------------------------------------------
# Table 3: inspect static-introspection function qualnames
#
# Wave 263 theme: inspect.getattr_static, inspect.classify_class_attrs,
# inspect.getmembers, inspect.getmembers_static, inspect.stack, inspect.trace,
# and inspect.getouterframes are all top-level pure-Python functions in
# Lib/inspect.py. Their __qualname__ equals their __name__ (no dotted prefix)
# since they are not nested inside a class or other function.
#
# inspect.getattr_static.__qualname__ == 'getattr_static'
# inspect.classify_class_attrs.__qualname__ == 'classify_class_attrs'
# inspect.getmembers.__qualname__ == 'getmembers'
# inspect.getmembers_static.__qualname__ == 'getmembers_static'
# inspect.stack.__qualname__ == 'stack'
# inspect.getouterframes.__qualname__ == 'getouterframes'
#
# New to extra111.
# ---------------------------------------------------------------------------

table inspect_extra111.introspection_qualnames:
  description: "inspect introspection function qualnames: getattr_static, classify_class_attrs, getmembers, getmembers_static, stack, getouterframes all have qualname equal to function name (top-level); wave 263; new to extra111"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectiqn111

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static_qualname,
       "getattr_static.__qualname__.__eq__",
       ["getattr_static"],
       true,
       "inspect.getattr_static.__qualname__.__eq__('getattr_static') == True — inspect.getattr_static is a top-level function in Lib/inspect.py; its __qualname__ is 'getattr_static' (no dotted prefix since it is not nested inside a class); str.__eq__('getattr_static') returns True; new to extra111"]
    - [classify_class_attrs_qualname,
       "classify_class_attrs.__qualname__.__eq__",
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__qualname__.__eq__('classify_class_attrs') == True — inspect.classify_class_attrs is a top-level function; its __qualname__ is 'classify_class_attrs'; str.__eq__('classify_class_attrs') returns True; new to extra111"]
    - [getmembers_qualname,
       "getmembers.__qualname__.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__qualname__.__eq__('getmembers') == True — inspect.getmembers is a top-level function; its __qualname__ is 'getmembers'; str.__eq__('getmembers') returns True; new to extra111"]
    - [getmembers_static_qualname,
       "getmembers_static.__qualname__.__eq__",
       ["getmembers_static"],
       true,
       "inspect.getmembers_static.__qualname__.__eq__('getmembers_static') == True — inspect.getmembers_static (added Python 3.11) is a top-level function; its __qualname__ is 'getmembers_static'; str.__eq__('getmembers_static') returns True; new to extra111"]
    - [stack_qualname,
       "stack.__qualname__.__eq__",
       ["stack"],
       true,
       "inspect.stack.__qualname__.__eq__('stack') == True — inspect.stack is a top-level function; its __qualname__ is 'stack'; str.__eq__('stack') returns True; new to extra111"]
    - [getouterframes_qualname,
       "getouterframes.__qualname__.__eq__",
       ["getouterframes"],
       true,
       "inspect.getouterframes.__qualname__.__eq__('getouterframes') == True — inspect.getouterframes is a top-level function; its __qualname__ is 'getouterframes'; str.__eq__('getouterframes') returns True; new to extra111"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra111
# ---------------------------------------------------------------------------

invariant inspect_extra111.getattr_static_co_argcount:
  description: "inspect.getattr_static.__code__.co_argcount == 3 — getattr_static(obj, name, default=_empty); 3 parameters; wave 263; new to extra111"
  kind: python_call_eq
  function: getattr_static.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant inspect_extra111.classify_class_attrs_co_argcount:
  description: "inspect.classify_class_attrs.__code__.co_argcount == 1 — classify_class_attrs(cls); single class argument; wave 263; new to extra111"
  kind: python_call_eq
  function: classify_class_attrs.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra111.getmembers_static_co_name:
  description: "inspect.getmembers_static.__code__.co_name == 'getmembers_static' — top-level function added in 3.11; co_name matches def name; wave 263; new to extra111"
  kind: python_call_eq
  function: getmembers_static.__code__.co_name.__eq__
  args: ["getmembers_static"]
  expected: true

invariant inspect_extra111.stack_co_argcount:
  description: "inspect.stack.__code__.co_argcount == 1 — stack(context=1); single context parameter; wave 263; new to extra111"
  kind: python_call_eq
  function: stack.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra111.currentframe_module:
  description: "inspect.currentframe.__module__ == 'inspect' — currentframe is assigned from sys._getframe in Lib/inspect.py; its module attribute reports 'inspect'; wave 263; new to extra111"
  kind: python_call_eq
  function: currentframe.__module__.__eq__
  args: ["inspect"]
  expected: true
