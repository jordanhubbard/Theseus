spec: multiprocessing_extra323
version: ">=3.8"
backend: python_module(multiprocessing.shared_memory)

docs: https://docs.python.org/3/library/multiprocessing.shared_memory.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.shared_memory.html — multiprocessing.shared_memory documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "multiprocessing.shared_memory was added in Python 3.8 (PEP 526 / bpo-35813)."
    - "SharedMemory and ShareableList are both plain classes whose direct base is object."
    - "SharedMemory.__module__ == 'multiprocessing.shared_memory' — defined in the submodule itself."
    - "ShareableList.__module__ == 'multiprocessing.shared_memory' — same submodule."
    - "The module's __name__ is 'multiprocessing.shared_memory' and __package__ is 'multiprocessing'."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity — __name__ and __package__
# ---------------------------------------------------------------------------

invariant multiprocessing_extra323.module.name:
  description: "multiprocessing.shared_memory.__name__ == 'multiprocessing.shared_memory'"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["multiprocessing.shared_memory"]
  expected: true

invariant multiprocessing_extra323.module.package:
  description: "multiprocessing.shared_memory.__package__ == 'multiprocessing'"
  category: module
  kind: python_call_eq
  function: __package__.__eq__
  args: ["multiprocessing"]
  expected: true

# ---------------------------------------------------------------------------
# SharedMemory — class name, module, and base class
# ---------------------------------------------------------------------------

invariant multiprocessing_extra323.SharedMemory.name:
  description: "multiprocessing.shared_memory.SharedMemory.__name__ == 'SharedMemory'"
  category: shared_memory
  kind: python_call_eq
  function: SharedMemory.__name__.__eq__
  args: ["SharedMemory"]
  expected: true

invariant multiprocessing_extra323.SharedMemory.module:
  description: "multiprocessing.shared_memory.SharedMemory.__module__ == 'multiprocessing.shared_memory'"
  category: shared_memory
  kind: python_call_eq
  function: SharedMemory.__module__.__eq__
  args: ["multiprocessing.shared_memory"]
  expected: true

invariant multiprocessing_extra323.SharedMemory.base:
  description: "multiprocessing.shared_memory.SharedMemory.__bases__[0].__name__ == 'object'"
  category: shared_memory
  kind: python_call_eq
  function: SharedMemory.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# ShareableList — class name, module, and base class
# ---------------------------------------------------------------------------

invariant multiprocessing_extra323.ShareableList.name:
  description: "multiprocessing.shared_memory.ShareableList.__name__ == 'ShareableList'"
  category: shareable_list
  kind: python_call_eq
  function: ShareableList.__name__.__eq__
  args: ["ShareableList"]
  expected: true

invariant multiprocessing_extra323.ShareableList.module:
  description: "multiprocessing.shared_memory.ShareableList.__module__ == 'multiprocessing.shared_memory'"
  category: shareable_list
  kind: python_call_eq
  function: ShareableList.__module__.__eq__
  args: ["multiprocessing.shared_memory"]
  expected: true

invariant multiprocessing_extra323.ShareableList.base:
  description: "multiprocessing.shared_memory.ShareableList.__bases__[0].__name__ == 'object'"
  category: shareable_list
  kind: python_call_eq
  function: ShareableList.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
