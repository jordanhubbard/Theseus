spec: theseus_ctypes_cr
version: ">=3.0"
backend: python_cleanroom(theseus_ctypes_cr)
blocks: ctypes

docs: https://docs.python.org/3/library/ctypes.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ctypes.html"
  not_derived_from:
    - "CPython source: Lib/ctypes/__init__.py"
  notes:
    - "Clean-room ctypes module. Do NOT import ctypes."

error_model: python_exceptions

invariant theseus_ctypes_cr.ctypes2_simple_types:
  description: "c_int, c_char, c_double and other simple types exist"
  category: behavior
  kind: python_call_eq
  function: ctypes2_simple_types
  args: []
  expected: true

invariant theseus_ctypes_cr.ctypes2_structure:
  description: "Structure base class exists"
  category: behavior
  kind: python_call_eq
  function: ctypes2_structure
  args: []
  expected: true

invariant theseus_ctypes_cr.ctypes2_byref:
  description: "byref() and addressof() functions exist"
  category: behavior
  kind: python_call_eq
  function: ctypes2_byref
  args: []
  expected: true
