spec: just_safe_get
version: ">=4.0.0"
backend: node(just-safe-get)

docs: https://www.npmjs.com/package/just-safe-get

provenance:
  derived_from:
    - "just-safe-get README — https://www.npmjs.com/package/just-safe-get"
    - "Test vectors verified with just-safe-get via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-safe-get source"
  notes:
    - "just-safe-get is an npm package. Install: npm install just-safe-get"
    - "safeGet(obj, path) retrieves a nested value using dot-notation path."
    - "Returns the value at the path, or undefined if not found (test cases avoid undefined)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns value at the given path."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_safe_get.get:
  kind: node_module_call_eq
  function: ~
  category: get
  id_prefix: jsg

  columns: [id, args, expected]
  rows:
    - [deep,   [{"a": {"b": 42}}, "a.b"],           42]
    - [shallow,[{"x": 1}, "x"],                     1]
    - [string, [{"a": {"b": "hello"}}, "a.b"],      "hello"]
    - [array,  [{"a": [1, 2, 3]}, "a.1"],           2]
