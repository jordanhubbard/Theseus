spec: compileall_extra6
version: ">=3.9"
backend: python_module(compileall)

docs: https://docs.python.org/3/library/compileall.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/compileall.html — Python compileall documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/compileall.py"
  notes:
    - "This spec extends compileall.zspec.zsdl through compileall_extra5.zspec.zsdl."
    - "compileall (base) covers: __name__, __module__, type, docstring, __qualname__ for compile_file/compile_dir."
    - "compileall_extra covers: __name__ and __module__ for compile_file, compile_dir, compile_path."
    - "compileall_extra2 covers: __name__, __module__, __qualname__, type, docstring for all three functions."
    - "compileall_extra3 covers: __name__, __module__, __qualname__ for all three functions (invariant and table form)."
    - "compileall_extra4 covers: __code__.__class__.__name__ == 'code' and __code__.co_name for all three functions."
    - "compileall_extra5 covers: module __name__, module __spec__.name, module __loader__.__class__.__name__, __code__.co_firstlineno type for all three functions."
    - "This spec adds: __code__.co_argcount type (int) for all three functions; compile_file and compile_dir __defaults__ is a tuple (they have default argument values); compile_path __defaults__ is None or a tuple; module __file__ is a non-empty str; __spec__.__class__.__name__ == 'ModuleSpec'."
    - "compile_file has defaults for quiet, legacy, optimize, etc.; __defaults__ is always a tuple."
    - "compile_dir also has default arguments; __defaults__ is a tuple."
    - "compile_path has default arguments; __defaults__ is a tuple."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __code__.co_argcount type — each function's code object arg count is an int.
# The actual values vary (compile_file has more params than compile_path);
# the type is always int. Not covered in any prior compileall spec.
# ---------------------------------------------------------------------------

table compileall_extra6.co_argcount_types:
  kind: python_call_eq
  category: code_objects
  id_prefix: argcount_type

  columns: [id, function, args, expected]
  rows:
    - [compile_file, compile_file.__code__.co_argcount.__class__.__name__.__eq__, ["int"], true]
    - [compile_dir,  compile_dir.__code__.co_argcount.__class__.__name__.__eq__,  ["int"], true]
    - [compile_path, compile_path.__code__.co_argcount.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# __defaults__ type — compile_file, compile_dir, and compile_path all accept
# optional arguments and therefore have __defaults__ set to a tuple.
# Not covered in any prior compileall spec.
# ---------------------------------------------------------------------------

table compileall_extra6.defaults_types:
  kind: python_call_eq
  category: introspection
  id_prefix: defaults_type

  columns: [id, function, args, expected]
  rows:
    - [compile_file, compile_file.__defaults__.__class__.__name__.__eq__, ["tuple"], true]
    - [compile_dir,  compile_dir.__defaults__.__class__.__name__.__eq__,  ["tuple"], true]
    - [compile_path, compile_path.__defaults__.__class__.__name__.__eq__, ["tuple"], true]

# ---------------------------------------------------------------------------
# module __file__ — compileall is a pure-Python source module; its __file__
# attribute is a non-empty string ending with '.py' or '.pyc'.
# We verify the type (str) and that the length is > 0.
# Not covered in any prior compileall spec.
# ---------------------------------------------------------------------------

invariant compileall_extra6.module.file_is_str:
  description: "compileall.__file__.__class__.__name__ == 'str' — module file path is a string"
  category: module_metadata
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant compileall_extra6.module.file_nonempty:
  description: "len(compileall.__file__) >= 1 — module file path is a non-empty string"
  category: module_metadata
  kind: python_call_eq
  function: __file__.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# module __spec__.__class__.__name__ — the import system assigns a ModuleSpec
# object to every successfully imported module.
# Not covered in any prior compileall spec.
# ---------------------------------------------------------------------------

invariant compileall_extra6.module.spec_class:
  description: "compileall.__spec__.__class__.__name__ == 'ModuleSpec' — module carries a ModuleSpec"
  category: module_metadata
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true
