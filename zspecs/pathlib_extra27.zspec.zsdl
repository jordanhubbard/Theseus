spec: pathlib_extra27
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra26.zspec.zsdl — covers __mro__ length for all 5 pathlib classes"
    - "pathlib_extra25.zspec.zsdl — covers __bases__[0].__name__ and __module__ for pathlib classes"
    - "pathlib_extra23.zspec.zsdl — covers __name__ table for Path/PurePath/PosixPath/PurePosixPath/PureWindowsPath"
  notes:
    - "This spec extends pathlib.zspec.zsdl and all prior pathlib_extra specs through pathlib_extra26.zspec.zsdl."
    - "Focus: __qualname__ attributes for pathlib classes."
    - "pathlib.Path.__qualname__ == 'Path' — qualname equals the simple class name; no prior pathlib spec covers any class __qualname__ in the extra27 namespace."
    - "pathlib.PurePath.__qualname__ == 'PurePath'; pathlib.PurePosixPath.__qualname__ == 'PurePosixPath'."
    - "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath'; pathlib.PosixPath.__qualname__ == 'PosixPath'."
    - "pathlib.Path.__module__ == 'pathlib' — re-anchored as qualname-companion check in extra27 namespace."
    - "Qualname length facts: Path=4, PurePath=8, PurePosixPath=13, PureWindowsPath=15, PosixPath=9."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ equality table
#
# For top-level pathlib classes, __qualname__ equals the plain class name
# (no enclosing-class or closure prefix). This table verifies that property
# across the five main pathlib classes. No prior pathlib spec covers __qualname__
# for any of these classes in an equality table.
# ---------------------------------------------------------------------------

table pathlib_extra27.class_qualnames:
  description: "__qualname__ equals the plain class name for core pathlib classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: plqname27

  columns: [id, function, args, expected]
  rows:
    - [Path,            "Path.__qualname__.__eq__",            ["Path"],            true]
    - [PurePath,        "PurePath.__qualname__.__eq__",        ["PurePath"],        true]
    - [PurePosixPath,   "PurePosixPath.__qualname__.__eq__",   ["PurePosixPath"],   true]
    - [PureWindowsPath, "PureWindowsPath.__qualname__.__eq__", ["PureWindowsPath"], true]
    - [PosixPath,       "PosixPath.__qualname__.__eq__",       ["PosixPath"],       true]

# ---------------------------------------------------------------------------
# __qualname__ length checks — standalone invariants
#
# Length of __qualname__ is a distinct axis from equality. These standalone
# invariants anchor the qualname lengths for each pathlib class in the
# extra27 namespace. Prior specs cover __name__ lengths but not __qualname__
# lengths.
# ---------------------------------------------------------------------------

invariant pathlib_extra27.Path.qualname_length:
  description: "pathlib.Path.__qualname__.__len__() == 4 — 'Path' has 4 characters"
  category: class_identity
  kind: python_call_eq
  function: Path.__qualname__.__len__
  args: []
  expected: 4

invariant pathlib_extra27.PurePath.qualname_length:
  description: "pathlib.PurePath.__qualname__.__len__() == 8 — 'PurePath' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__qualname__.__len__
  args: []
  expected: 8

invariant pathlib_extra27.PurePosixPath.qualname_length:
  description: "pathlib.PurePosixPath.__qualname__.__len__() == 13 — 'PurePosixPath' has 13 characters"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__qualname__.__len__
  args: []
  expected: 13

invariant pathlib_extra27.PureWindowsPath.qualname_length:
  description: "pathlib.PureWindowsPath.__qualname__.__len__() == 15 — 'PureWindowsPath' has 15 characters"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__qualname__.__len__
  args: []
  expected: 15

invariant pathlib_extra27.PosixPath.qualname_length:
  description: "pathlib.PosixPath.__qualname__.__len__() == 9 — 'PosixPath' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__qualname__.__len__
  args: []
  expected: 9
