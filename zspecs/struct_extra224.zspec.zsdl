spec: struct_extra224
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.calcsize('B') == 1 — unsigned char; 1 byte."
    - "struct.calcsize('H') == 2 — unsigned short; 2 bytes."
    - "struct.calcsize('I') == 4 — unsigned int; 4 bytes."
    - "struct.calcsize('Q') == 8 — unsigned long long; 8 bytes."
    - "struct.calcsize('f') == 4 — IEEE 754 single-precision float; 4 bytes."
    - "struct.calcsize('d') == 8 — IEEE 754 double-precision float; 8 bytes."
    - "struct.calcsize('4B') == 4 — four unsigned chars; 4 * 1 = 4 bytes."
    - "struct.calcsize('2H') == 4 — two unsigned shorts; 2 * 2 = 4 bytes."
    - "struct.calcsize('!I') == 4 — network byte order unsigned int; same size as native."
    - "struct.calcsize('<I') == 4 — little-endian unsigned int; same size as native."
    - "calcsize only computes byte count; byte-order prefixes (!, <, >, =) do not change size."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize — basic format string size contracts
#
# struct.calcsize('B') == 1   (unsigned char)
# struct.calcsize('H') == 2   (unsigned short)
# struct.calcsize('I') == 4   (unsigned int)
# struct.calcsize('Q') == 8   (unsigned long long)
#
# calcsize returns the number of bytes required to pack a value matching the
# format string. These sizes are fixed by the C standard for the native
# sizes used by the struct module.
# ---------------------------------------------------------------------------

table struct_extra224.calcsize_basic_integer_formats:
  description: "calcsize('B')==1; calcsize('H')==2; calcsize('I')==4; calcsize('Q')==8; basic integer format sizes; new to extra224"
  kind: python_call_eq
  category: calcsize
  id_prefix: struct224

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_B_1,  calcsize, ["B"],  1, "struct.calcsize('B') == 1 — unsigned char; 1 byte; 'B' is the format code for unsigned char (range 0-255); minimum struct format size; new anchor in extra224 namespace; verified Python 3.14.3"]
    - [calcsize_H_2,  calcsize, ["H"],  2, "struct.calcsize('H') == 2 — unsigned short; 2 bytes; 'H' is the format code for unsigned short (range 0-65535); new anchor in extra224 namespace; verified Python 3.14.3"]
    - [calcsize_I_4,  calcsize, ["I"],  4, "struct.calcsize('I') == 4 — unsigned int; 4 bytes; 'I' is the format code for unsigned int (range 0-4294967295); same size as float 'f'; new anchor in extra224 namespace; verified Python 3.14.3"]
    - [calcsize_Q_8,  calcsize, ["Q"],  8, "struct.calcsize('Q') == 8 — unsigned long long; 8 bytes; 'Q' is the format code for unsigned long long (range 0-18446744073709551615); new anchor in extra224 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.calcsize — floating-point format sizes
#
# struct.calcsize('f') == 4   (IEEE 754 single-precision)
# struct.calcsize('d') == 8   (IEEE 754 double-precision)
#
# 'f' is single-precision float (4 bytes, same as C float).
# 'd' is double-precision float (8 bytes, same as C double).
# ---------------------------------------------------------------------------

table struct_extra224.calcsize_float_formats:
  description: "calcsize('f')==4; calcsize('d')==8; IEEE 754 single/double precision float sizes; new to extra224"
  kind: python_call_eq
  category: calcsize
  id_prefix: struct224a

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_f_4,  calcsize, ["f"],  4, "struct.calcsize('f') == 4 — IEEE 754 single-precision float; 4 bytes; 'f' is the format code for C float; same byte count as unsigned int 'I'; new anchor in extra224 namespace; verified Python 3.14.3"]
    - [calcsize_d_8,  calcsize, ["d"],  8, "struct.calcsize('d') == 8 — IEEE 754 double-precision float; 8 bytes; 'd' is the format code for C double; same byte count as unsigned long long 'Q'; new anchor in extra224 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.calcsize — repeat-count format strings
#
# struct.calcsize('4B') == 4   (four unsigned chars = 4*1)
# struct.calcsize('2H') == 4   (two unsigned shorts = 2*2)
#
# A numeric prefix N before a format code means N repetitions. calcsize
# returns N * size(code). These contracts verify the repeat-count multiplier.
# ---------------------------------------------------------------------------

table struct_extra224.calcsize_repeat_count_formats:
  description: "calcsize('4B')==4; calcsize('2H')==4; repeat-count prefix multiplies size; new to extra224"
  kind: python_call_eq
  category: calcsize
  id_prefix: struct224b

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_4B_4, calcsize, ["4B"], 4, "struct.calcsize('4B') == 4 — four unsigned chars; repeat count 4 * 1 byte = 4 bytes; equivalent to 'BBBB'; new anchor in extra224 namespace; verified Python 3.14.3"]
    - [calcsize_2H_4, calcsize, ["2H"], 4, "struct.calcsize('2H') == 4 — two unsigned shorts; repeat count 2 * 2 bytes = 4 bytes; equivalent to 'HH'; new anchor in extra224 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.calcsize — byte-order prefix contracts
#
# struct.calcsize('!I') == 4   (network byte order; same size)
# struct.calcsize('<I') == 4   (little-endian; same size)
#
# Byte-order prefix characters (!, <, >, =, @) select byte ordering but
# do not change the number of bytes. calcsize with any byte-order prefix
# returns the same count as without the prefix.
# ---------------------------------------------------------------------------

table struct_extra224.calcsize_byte_order_prefix:
  description: "calcsize('!I')==4; calcsize('<I')==4; byte-order prefixes do not change size; new to extra224"
  kind: python_call_eq
  category: calcsize
  id_prefix: struct224c

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_netI_4,  calcsize, ["!I"], 4, "struct.calcsize('!I') == 4 — network byte order (big-endian) unsigned int; '!' selects network/big-endian byte order; size is still 4 bytes same as native; new anchor in extra224 namespace; verified Python 3.14.3"]
    - [calcsize_leI_4,   calcsize, ["<I"], 4, "struct.calcsize('<I') == 4 — little-endian unsigned int; '<' selects little-endian byte order; size is still 4 bytes same as native; new anchor in extra224 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra224.calcsize_B_1:
  description: "struct.calcsize('B') == 1 — 'B' is the struct format code for unsigned char (C type unsigned char); it occupies exactly 1 byte and has the range 0-255; calcsize('B') is the smallest non-zero calcsize result for a single format code; no prior struct spec anchors calcsize('B')==1 in the extra224 namespace; first extra224 anchor for calcsize; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["B"]
  expected: 1

invariant struct_extra224.calcsize_I_4:
  description: "struct.calcsize('I') == 4 — 'I' is the struct format code for unsigned int (C type unsigned int); it occupies exactly 4 bytes and has the range 0-4294967295; calcsize('I') is equivalent to calcsize('f') (both 4 bytes) demonstrating that integer and float formats can share the same byte size; no prior struct spec anchors calcsize('I')==4 in the extra224 namespace; first extra224 standalone for calcsize('I'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["I"]
  expected: 4

invariant struct_extra224.calcsize_Q_8:
  description: "struct.calcsize('Q') == 8 — 'Q' is the struct format code for unsigned long long (C type unsigned long long); it occupies exactly 8 bytes and has the range 0-18446744073709551615 (2^64 - 1); calcsize('Q') == calcsize('d') == 8 demonstrating that 64-bit integer and double-precision float share the same byte count; no prior struct spec anchors calcsize('Q')==8 in the extra224 namespace; first extra224 standalone for calcsize('Q'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["Q"]
  expected: 8
