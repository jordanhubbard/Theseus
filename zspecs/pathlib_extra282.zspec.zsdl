spec: pathlib_extra282
version: ">=3.12"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "pathlib.Path method __qualname__ values follow the pattern 'Path.<method>' for all instance methods."
    - "pathlib.Path is not abstract in Python 3.12+; the __abstractmethods__ attribute is absent from the class."
    - "pathlib.Path.__class__.__name__ == 'type' — Path is a plain Python class, not a metaclass instance."
    - "All method __qualname__ values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path method __qualname__ — confirms each method's declared owner
# ---------------------------------------------------------------------------

table pathlib_extra282.path_method_qualnames:
  description: "pathlib.Path instance method __qualname__ values"
  kind: python_call_eq
  category: method_identity
  id_prefix: qn

  columns: [id, function, args, expected, description]
  rows:
    - [open,       Path.open.__qualname__.__eq__,       ["Path.open"],       true, "Path.open.__qualname__ == 'Path.open'"]
    - [read_text,  Path.read_text.__qualname__.__eq__,  ["Path.read_text"],  true, "Path.read_text.__qualname__ == 'Path.read_text'"]
    - [write_text, Path.write_text.__qualname__.__eq__, ["Path.write_text"], true, "Path.write_text.__qualname__ == 'Path.write_text'"]
    - [mkdir,      Path.mkdir.__qualname__.__eq__,      ["Path.mkdir"],      true, "Path.mkdir.__qualname__ == 'Path.mkdir'"]
    - [stat,       Path.stat.__qualname__.__eq__,       ["Path.stat"],       true, "Path.stat.__qualname__ == 'Path.stat'"]
    - [exists,     Path.exists.__qualname__.__eq__,     ["Path.exists"],     true, "Path.exists.__qualname__ == 'Path.exists'"]
    - [unlink,     Path.unlink.__qualname__.__eq__,     ["Path.unlink"],     true, "Path.unlink.__qualname__ == 'Path.unlink'"]
    - [rename,     Path.rename.__qualname__.__eq__,     ["Path.rename"],     true, "Path.rename.__qualname__ == 'Path.rename'"]

# ---------------------------------------------------------------------------
# Path class-level metadata — __class__.__name__ and callable identity
# ---------------------------------------------------------------------------

invariant pathlib_extra282.Path.is_type:
  description: "pathlib.Path.__class__.__name__ == 'type' — Path is a plain Python class object"
  category: class_metadata
  kind: python_call_eq
  function: Path.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra282.PurePath.is_type:
  description: "pathlib.PurePath.__class__.__name__ == 'type' — PurePath is a plain Python class object"
  category: class_metadata
  kind: python_call_eq
  function: PurePath.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant pathlib_extra282.Path.open_qualname:
  description: "pathlib.Path.open.__qualname__ == 'Path.open' — open method is owned by Path"
  category: method_identity
  kind: python_call_eq
  function: Path.open.__qualname__.__eq__
  args: ["Path.open"]
  expected: true

invariant pathlib_extra282.Path.read_bytes_qualname:
  description: "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes'"
  category: method_identity
  kind: python_call_eq
  function: Path.read_bytes.__qualname__.__eq__
  args: ["Path.read_bytes"]
  expected: true

invariant pathlib_extra282.Path.write_bytes_qualname:
  description: "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes'"
  category: method_identity
  kind: python_call_eq
  function: Path.write_bytes.__qualname__.__eq__
  args: ["Path.write_bytes"]
  expected: true

invariant pathlib_extra282.Path.iterdir_qualname:
  description: "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir'"
  category: method_identity
  kind: python_call_eq
  function: Path.iterdir.__qualname__.__eq__
  args: ["Path.iterdir"]
  expected: true
