spec: abc_extra75
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra74.zspec.zsdl."
    - "This spec covers: wave 244 theme — abc abstractmethod/abstractproperty __dict__ content and class identity. NEW in extra75: abstractmethod.__dict__.__class__.__name__=='dict' (abstractmethod is a function; function __dict__ is a plain dict, NOT mappingproxy); abstractmethod.__dict__.__contains__('__isabstractmethod__')==False (__isabstractmethod__ is not stored in the function __dict__; it is set as a function attribute dynamically); abstractproperty.__dict__.__contains__('__isabstractmethod__')==True (it IS a class attribute on abstractproperty); abstractclassmethod.__dict__.__contains__('__isabstractmethod__')==True; abstractclassmethod.__dict__.__class__.__name__=='mappingproxy'; abstractstaticmethod.__dict__.__contains__('__isabstractmethod__')==True; abstractstaticmethod.__dict__.__class__.__name__=='mappingproxy'; ABCMeta.register.__code__.co_name=='register'; ABCMeta.register.__code__.co_argcount==2 (self + subclass); ABCMeta._dump_registry.__code__.co_name=='_dump_registry'; ABCMeta._dump_registry.__code__.co_argcount==2 (cls + file); update_abstractmethods.__code__.co_name=='update_abstractmethods'; update_abstractmethods.__code__.co_argcount==1 (cls). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__dict__.__class__.__name__ == 'dict'. abstractmethod is a function; function __dict__ is a plain dict (not mappingproxy). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__dict__.__contains__('__isabstractmethod__') == False. __isabstractmethod__ is NOT stored in abstractmethod's __dict__; it is set as a direct function attribute (abstractmethod.__isabstractmethod__) but that attribute is in the function's own slot, not its __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractproperty.__dict__.__contains__('__isabstractmethod__') == True. abstractproperty is a class; __isabstractmethod__ is a class-level attribute in its __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__dict__.__contains__('__isabstractmethod__') == True. abstractclassmethod is a class; __isabstractmethod__ is a class-level attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__dict__.__class__.__name__ == 'mappingproxy'. abstractclassmethod is a Python class; class __dict__ is always mappingproxy in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__dict__.__contains__('__isabstractmethod__') == True. abstractstaticmethod is a class; __isabstractmethod__ is a class-level attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__dict__.__class__.__name__ == 'mappingproxy'. abstractstaticmethod is a Python class; class __dict__ is always mappingproxy in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_name == 'register'. register is a plain Python function in ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_argcount == 2. self and subclass are positional parameters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta._dump_registry.__code__.co_name == '_dump_registry'. _dump_registry is a plain Python function in ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta._dump_registry.__code__.co_argcount == 2. cls and file are positional parameters (file has a default of None). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_name == 'update_abstractmethods'. update_abstractmethods is a module-level function in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_argcount == 1. Only cls is a positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc abstractmethod __dict__ class name and membership — extra75
#
# Wave 244 theme: abstractmethod/abstractproperty __dict__ content and class identity.
#
# abstractmethod.__dict__.__class__.__name__ == 'dict'
# abstractmethod.__dict__.__contains__('__isabstractmethod__') == False
# abstractproperty.__dict__.__contains__('__isabstractmethod__') == True
# ---------------------------------------------------------------------------

table abc_extra75.abstractmethod_dict_class_and_membership:
  description: "abc abstractmethod __dict__ class name and membership checks in abcextra75 namespace — wave 244 theme: abstractmethod/abstractproperty __dict__ content; abstractmethod.__dict__.__class__.__name__=='dict' (abstractmethod is a function; function __dict__ is a plain dict, not mappingproxy); abstractmethod.__dict__.__contains__('__isabstractmethod__')==False (__isabstractmethod__ is not in function __dict__); abstractproperty.__dict__.__contains__('__isabstractmethod__')==True (abstractproperty is a class; __isabstractmethod__ is a class attribute); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcextra75

  columns: [id, function, args, expected, description]
  rows:
    - [absmeth_dict_class_name,    abstractmethod.__dict__.__class__.__name__.__eq__,  ["dict"],                true,  "abstractmethod.__dict__.__class__.__name__ == 'dict' — function __dict__ is a plain dict, not mappingproxy; verified with Python 3.14.3"]
    - [absmeth_dict_not_proxy,     abstractmethod.__dict__.__class__.__name__.__eq__,  ["mappingproxy"],        false, "abstractmethod.__dict__.__class__.__name__ != 'mappingproxy' — function __dict__ is plain dict, not mappingproxy like class __dict__; verified with Python 3.14.3"]
    - [absmeth_dict_no_isabstract, abstractmethod.__dict__.__contains__,               ["__isabstractmethod__"], false, "abstractmethod.__dict__.__contains__('__isabstractmethod__') == False — not in function __dict__; verified with Python 3.14.3"]
    - [absprop_dict_has_isabstract, abstractproperty.__dict__.__contains__,            ["__isabstractmethod__"], true,  "abstractproperty.__dict__.__contains__('__isabstractmethod__') == True — class-level attribute; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc abstractclassmethod and abstractstaticmethod __dict__ checks — extra75
#
# abstractclassmethod.__dict__.__contains__('__isabstractmethod__') == True
# abstractclassmethod.__dict__.__class__.__name__ == 'mappingproxy'
# abstractstaticmethod.__dict__.__contains__('__isabstractmethod__') == True
# abstractstaticmethod.__dict__.__class__.__name__ == 'mappingproxy'
# ---------------------------------------------------------------------------

table abc_extra75.abstractclassmethod_and_abstractstaticmethod_dicts:
  description: "abc abstractclassmethod and abstractstaticmethod __dict__ checks in abcextra75 namespace — wave 244 theme: abstractclassmethod/abstractstaticmethod __dict__ content; abstractclassmethod.__dict__.__contains__('__isabstractmethod__')==True; abstractclassmethod.__dict__.__class__.__name__=='mappingproxy' (it's a class, not a function); abstractstaticmethod.__dict__.__contains__('__isabstractmethod__')==True; abstractstaticmethod.__dict__.__class__.__name__=='mappingproxy'; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: abcextra75a

  columns: [id, function, args, expected, description]
  rows:
    - [abscm_dict_has_isabstract,  abstractclassmethod.__dict__.__contains__,               ["__isabstractmethod__"], true, "abstractclassmethod.__dict__.__contains__('__isabstractmethod__') == True — class-level attribute; verified with Python 3.14.3"]
    - [abscm_dict_class_name,      abstractclassmethod.__dict__.__class__.__name__.__eq__,  ["mappingproxy"],         true, "abstractclassmethod.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always mappingproxy in CPython; verified with Python 3.14.3"]
    - [abssm_dict_has_isabstract,  abstractstaticmethod.__dict__.__contains__,              ["__isabstractmethod__"], true, "abstractstaticmethod.__dict__.__contains__('__isabstractmethod__') == True — class-level attribute; verified with Python 3.14.3"]
    - [abssm_dict_class_name,      abstractstaticmethod.__dict__.__class__.__name__.__eq__, ["mappingproxy"],         true, "abstractstaticmethod.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always mappingproxy in CPython; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta.register and _dump_registry code attributes — extra75
#
# ABCMeta.register.__code__.co_name == 'register'
# ABCMeta.register.__code__.co_argcount == 2
# ABCMeta._dump_registry.__code__.co_name == '_dump_registry'
# ABCMeta._dump_registry.__code__.co_argcount == 2
# ---------------------------------------------------------------------------

table abc_extra75.ABCMeta_register_and_dump_registry_code_attrs:
  description: "abc ABCMeta.register and _dump_registry code attribute checks in abcextra75 namespace — wave 244 theme: ABCMeta register/_dump_registry code attributes; ABCMeta.register.__code__.co_name=='register'; ABCMeta.register.__code__.co_argcount==2 (self + subclass); ABCMeta._dump_registry.__code__.co_name=='_dump_registry'; ABCMeta._dump_registry.__code__.co_argcount==2 (cls + file, with file defaulting to None); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abcextra75b

  columns: [id, function, args, expected, description]
  rows:
    - [register_co_name,         ABCMeta.register.__code__.co_name.__eq__,          ["register"],       true, "ABCMeta.register.__code__.co_name == 'register' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [register_co_argcount,     ABCMeta.register.__code__.co_argcount.__eq__,       [2],                true, "ABCMeta.register.__code__.co_argcount == 2 — self and subclass are positional parameters; verified with Python 3.14.3"]
    - [dump_reg_co_name,         ABCMeta._dump_registry.__code__.co_name.__eq__,    ["_dump_registry"], true, "ABCMeta._dump_registry.__code__.co_name == '_dump_registry' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [dump_reg_co_argcount,     ABCMeta._dump_registry.__code__.co_argcount.__eq__, [2],                true, "ABCMeta._dump_registry.__code__.co_argcount == 2 — cls and file (default None) are positional parameters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc update_abstractmethods code attributes + cross-check — extra75
# ---------------------------------------------------------------------------

table abc_extra75.update_abstractmethods_and_cross_check:
  description: "abc update_abstractmethods code attributes plus cross-check in abcextra75 namespace — wave 244 theme: update_abstractmethods code attributes + cross-check; update_abstractmethods.__code__.co_name=='update_abstractmethods'; update_abstractmethods.__code__.co_argcount==1 (cls only); ABCMeta.register.__code__.co_name=='register' (cross-check); abstractclassmethod.__dict__.__contains__('__isabstractmethod__')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abcextra75c

  columns: [id, function, args, expected, description]
  rows:
    - [update_abs_co_name,     update_abstractmethods.__code__.co_name.__eq__,    ["update_abstractmethods"], true, "update_abstractmethods.__code__.co_name == 'update_abstractmethods' — module-level function in abc.py; verified with Python 3.14.3"]
    - [update_abs_co_argcount, update_abstractmethods.__code__.co_argcount.__eq__, [1],                        true, "update_abstractmethods.__code__.co_argcount == 1 — only cls is a positional parameter; verified with Python 3.14.3"]
    - [register_co_name_cross, ABCMeta.register.__code__.co_name.__eq__,          ["register"],               true, "ABCMeta.register.__code__.co_name == 'register' — cross-check; verified with Python 3.14.3"]
    - [abscm_isabstract_cross, abstractclassmethod.__dict__.__contains__,         ["__isabstractmethod__"],   true, "abstractclassmethod.__dict__.__contains__('__isabstractmethod__') == True — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra75
# ---------------------------------------------------------------------------

invariant abc_extra75.abstractmethod_dict_class_name:
  description: "abc.abstractmethod.__dict__.__class__.__name__.__eq__('dict') returns True — abstractmethod is a function; function __dict__ is a plain dict, not mappingproxy (unlike class __dict__); NEW in extra75: first standalone __dict__.__class__.__name__ invariant for abstractmethod in abcextra75 namespace; wave 244; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: abstractmethod.__dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant abc_extra75.abstractmethod_dict_no_isabstractmethod:
  description: "abc.abstractmethod.__dict__.__contains__('__isabstractmethod__') returns False — __isabstractmethod__ is NOT stored in abstractmethod's __dict__; it is set as a direct function attribute in a slot, not in __dict__; NEW in extra75: first standalone __dict__.__contains__('__isabstractmethod__') == False invariant for abstractmethod in abcextra75 namespace; wave 244; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: abstractmethod.__dict__.__contains__
  args: ["__isabstractmethod__"]
  expected: false

invariant abc_extra75.abstractclassmethod_dict_class_name:
  description: "abc.abstractclassmethod.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — abstractclassmethod is a Python class, so its __dict__ is always mappingproxy in CPython (unlike function __dict__ which is plain dict); NEW in extra75: first standalone __dict__.__class__.__name__ invariant for abstractclassmethod in abcextra75 namespace; wave 244; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: abstractclassmethod.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra75.ABCMeta_register_co_argcount:
  description: "abc.ABCMeta.register.__code__.co_argcount.__eq__(2) returns True — self and subclass are positional parameters; register is a plain Python function in ABCMeta; NEW in extra75: first standalone co_argcount invariant for ABCMeta.register in abcextra75 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.register.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant abc_extra75.update_abstractmethods_co_name:
  description: "abc.update_abstractmethods.__code__.co_name.__eq__('update_abstractmethods') returns True — update_abstractmethods is a module-level function in abc.py; code object co_name matches the function name; NEW in extra75: first standalone co_name invariant for update_abstractmethods in abcextra75 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: update_abstractmethods.__code__.co_name.__eq__
  args: ["update_abstractmethods"]
  expected: true
