spec: threading_extra281
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Lock() returns a _thread.lock instance: __class__.__name__ == 'lock' (lowercase); __class__.__module__ == '_thread'."
    - "threading.RLock() returns a _thread.RLock instance: __class__.__name__ == 'RLock'; __class__.__module__ == '_thread'."
    - "threading._DummyThread is a pure-Python class in the threading module; instances are always daemon threads and always alive."
    - "threading.TIMEOUT_MAX is a float (> 0, > 1000) — the maximum timeout value accepted by blocking calls."
    - "threading.Event.__name__ == 'Event'; threading.Event.__module__ == 'threading'."
    - "threading.Semaphore.__name__ == 'Semaphore'; threading.Semaphore.__module__ == 'threading'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Lock and threading.RLock — instance class names and modules
#
# Lock() returns a _thread.lock (lowercase 'lock') from the C extension.
# RLock() returns a _thread.RLock from the C extension.
# Both __class__.__module__ == '_thread'.
# ---------------------------------------------------------------------------

table threading_extra281.lock_rlock_identity:
  description: "threading.Lock() and threading.RLock() instance identity — __class__.__name__ and __class__.__module__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex281lr

  columns: [id, function, args, expected, description]
  rows:
    - [lr_lk_cls,   "Lock().__class__.__name__.__eq__",      ["lock"],    true, "threading.Lock().__class__.__name__ == 'lock' (lowercase, C-level); verified with Python 3.14.3"]
    - [lr_lk_mod,   "Lock().__class__.__module__.__eq__",    ["_thread"], true, "threading.Lock().__class__.__module__ == '_thread' (C extension); verified with Python 3.14.3"]
    - [lr_lk_nlen,  "Lock().__class__.__name__.__len__",     [],          4,    "threading.Lock().__class__.__name__.__len__() == 4 — 'lock' has 4 chars; verified with Python 3.14.3"]
    - [lr_rl_cls,   "RLock().__class__.__name__.__eq__",     ["RLock"],   true, "threading.RLock().__class__.__name__ == 'RLock'; verified with Python 3.14.3"]
    - [lr_rl_mod,   "RLock().__class__.__module__.__eq__",   ["_thread"], true, "threading.RLock().__class__.__module__ == '_thread' (C extension); verified with Python 3.14.3"]
    - [lr_rl_nlen,  "RLock().__class__.__name__.__len__",    [],          5,    "threading.RLock().__class__.__name__.__len__() == 5 — 'RLock' has 5 chars; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading._DummyThread, threading.TIMEOUT_MAX, threading.Event, threading.Semaphore
#
# _DummyThread: class module == 'threading'; instances are always daemon and alive.
# TIMEOUT_MAX: type is float; value > 1000.
# Event and Semaphore: pure-Python classes in threading.
# ---------------------------------------------------------------------------

table threading_extra281.dummy_timeout_event_semaphore:
  description: "threading._DummyThread module, TIMEOUT_MAX type, Event and Semaphore class identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex281dt

  columns: [id, function, args, expected, description]
  rows:
    - [dt_cls_mod,  "_DummyThread.__module__.__eq__",         ["threading"],  true, "threading._DummyThread.__module__ == 'threading'; verified with Python 3.14.3"]
    - [dt_cls_name, "_DummyThread.__name__.__eq__",           ["_DummyThread"], true, "threading._DummyThread.__name__ == '_DummyThread'; verified with Python 3.14.3"]
    - [dt_cls_nlen, "_DummyThread.__name__.__len__",           [],             12,   "threading._DummyThread.__name__.__len__() == 12 — '_DummyThread' has 12 chars; verified with Python 3.14.3"]
    - [tm_type_eq,  TIMEOUT_MAX.__class__.__name__.__eq__,   ["float"],       true, "threading.TIMEOUT_MAX.__class__.__name__ == 'float'; verified with Python 3.14.3"]
    - [ev_name_eq,  Event.__name__.__eq__,                   ["Event"],       true, "threading.Event.__name__ == 'Event'; verified with Python 3.14.3"]
    - [ev_mod_eq,   Event.__module__.__eq__,                  ["threading"],  true, "threading.Event.__module__ == 'threading'; verified with Python 3.14.3"]
    - [sm_name_eq,  Semaphore.__name__.__eq__,               ["Semaphore"],   true, "threading.Semaphore.__name__ == 'Semaphore'; verified with Python 3.14.3"]
    - [sm_mod_eq,   Semaphore.__module__.__eq__,              ["threading"],  true, "threading.Semaphore.__module__ == 'threading'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra281
# ---------------------------------------------------------------------------

invariant threading_extra281.lock_instance_class_name_is_lock:
  description: "threading.Lock().__class__.__name__ == 'lock' — Lock() returns a C-level _thread.lock instance with a lowercase name"
  category: identity
  kind: python_call_eq
  function: "Lock().__class__.__name__.__eq__"
  args: ["lock"]
  expected: true

invariant threading_extra281.lock_instance_class_module_is_thread:
  description: "threading.Lock().__class__.__module__ == '_thread' — the lock type is implemented in the C extension _thread"
  category: identity
  kind: python_call_eq
  function: "Lock().__class__.__module__.__eq__"
  args: ["_thread"]
  expected: true

invariant threading_extra281.rlock_instance_class_module_is_thread:
  description: "threading.RLock().__class__.__module__ == '_thread' — the RLock type is implemented in the C extension _thread"
  category: identity
  kind: python_call_eq
  function: "RLock().__class__.__module__.__eq__"
  args: ["_thread"]
  expected: true

invariant threading_extra281.dummy_thread_module_is_threading:
  description: "threading._DummyThread.__module__ == 'threading' — _DummyThread is defined in the pure-Python threading module"
  category: identity
  kind: python_call_eq
  function: "_DummyThread.__module__.__eq__"
  args: ["threading"]
  expected: true

invariant threading_extra281.dummy_thread_name_length_is_12:
  description: "threading._DummyThread.__name__.__len__() == 12 — '_DummyThread' has 12 characters"
  category: identity
  kind: python_call_eq
  function: "_DummyThread.__name__.__len__"
  args: []
  expected: 12

invariant threading_extra281.timeout_max_is_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant, not int"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra281.timeout_max_greater_than_1000:
  description: "threading.TIMEOUT_MAX > 1000 is True — TIMEOUT_MAX is a very large positive float (platform max timeout)"
  category: behavior
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [1000]
  expected: true

invariant threading_extra281.event_module_is_threading:
  description: "threading.Event.__module__ == 'threading' — Event is defined in the pure-Python threading module"
  category: identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true
