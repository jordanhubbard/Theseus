spec: pathlib_extra62
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra61.zspec.zsdl — covers PurePosixPath/PureWindowsPath __class__.__module__.__eq__('builtins'); Path/__init__ and PurePath/__init__ __class__.__name__.__eq__('function'); PurePath property name/suffix/parent/stem __class__.__module__.__eq__('builtins'); Path.__init__.__class__.__module__.__eq__('builtins')."
    - "pathlib_extra60.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy'); PurePath property name/suffix/parent/stem __class__.__qualname__.__eq__('property')."
    - "pathlib_extra59.zspec.zsdl — covers Path property __class__.__qualname__=='property' (8 properties) and PurePath property __class__.__name__=='property' (4 properties)."
    - "pathlib_extra58.zspec.zsdl — covers pathlib class __module__.__eq__('pathlib') for Path/PurePath/PurePosixPath/PureWindowsPath; Path property __class__.__name__=='property' for 10 attributes."
    - "pathlib_extra54.zspec.zsdl — covers Path/__class__.__module__.__eq__('builtins') and PurePath/__class__.__module__.__eq__('builtins') as standalone invariants; Path/PurePath/PurePosixPath/PureWindowsPath __class__.__qualname__.__eq__('type')."
    - "pathlib_extra53.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __class__.__name__.__eq__('type')."
    - "pathlib_extra37.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath __dict__.__class__.__name__.__len__()==12."
  notes:
    - "This spec extends pathlib_extra61.zspec.zsdl."
    - "Prior specs collectively covered: pathlib_extra53 covers __class__.__name__.__eq__('type') for all path classes; pathlib_extra59 covers Path property __class__.__qualname__=='property'; pathlib_extra61 covers Path/__init__ and PurePath/__init__ __class__.__name__.__eq__('function'). NOT YET COVERED: Path/PurePath/PurePosixPath/PureWindowsPath __repr__.__class__.__name__.__eq__('function') — Path/PurePath are pure-Python classes; __repr__ is a regular Python function (PurePath.__repr__ is defined in pathlib.py); no prior pathlib spec checks __repr__.__class__.__name__; novel; Path/PurePath/PurePosixPath/PureWindowsPath __repr__.__class__.__qualname__.__eq__('function') — no prior pathlib spec checks __repr__.__class__.__qualname__; novel; Path/PurePath/PurePosixPath/PureWindowsPath __hash__.__class__.__name__.__eq__('function') — PurePath defines __hash__ as a regular Python function in pathlib.py; Path inherits it; no prior pathlib spec checks __hash__.__class__.__name__; novel."
    - "Note on __weakref__: Path and PurePath use __slots__, which means they do NOT have a __weakref__ descriptor in their __dict__. Instances of Path/PurePath are NOT weakly referenceable. Therefore the __weakref__.__class__.__name__ chain is not applicable to these classes."
    - "This spec covers: pathlib.Path.__repr__.__class__.__name__.__eq__('function') (NOVEL — Path.__repr__ resolves to PurePath.__repr__, a regular Python function defined in pathlib.py; the builtin 'function' type has __name__=='function'; no prior pathlib spec checks __repr__.__class__.__name__; novel in pathlibmod62 namespace); pathlib.PurePath.__repr__.__class__.__name__.__eq__('function') (NOVEL); pathlib.PurePosixPath.__repr__.__class__.__name__.__eq__('function') (NOVEL); pathlib.PureWindowsPath.__repr__.__class__.__name__.__eq__('function') (NOVEL); pathlib.Path.__repr__.__class__.__qualname__.__eq__('function') (NOVEL — the 'function' type has __qualname__=='function'; no prior pathlib spec checks __repr__.__class__.__qualname__; novel in pathlibmod62 namespace); pathlib.PurePath.__repr__.__class__.__qualname__.__eq__('function') (NOVEL); pathlib.PurePosixPath.__repr__.__class__.__qualname__.__eq__('function') (NOVEL); pathlib.PureWindowsPath.__repr__.__class__.__qualname__.__eq__('function') (NOVEL); pathlib.Path.__hash__.__class__.__name__.__eq__('function') (NOVEL — PurePath defines __hash__ as a regular Python function in pathlib.py; Path inherits it; __hash__.__class__.__name__=='function'; no prior pathlib spec checks __hash__.__class__.__name__; novel in pathlibmod62 namespace); pathlib.PurePath.__hash__.__class__.__name__.__eq__('function') (NOVEL)."
    - "pathlib.Path.__repr__.__class__.__name__ == 'function'. Path.__repr__ resolves to PurePath.__repr__ (Path does not override __repr__). PurePath.__repr__ is a regular Python function defined in pathlib.py. Its __class__ is the builtin 'function' type, which has __name__=='function'. No prior pathlib spec checks __repr__.__class__.__name__ for any path class. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__repr__.__class__.__name__ == 'function'. PurePath.__repr__ is a Python function. Same reasoning. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePosixPath.__repr__.__class__.__name__ == 'function'. PurePosixPath inherits __repr__ from PurePath. Same result. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PureWindowsPath.__repr__.__class__.__name__ == 'function'. PureWindowsPath inherits __repr__ from PurePath. Same result. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.Path.__repr__.__class__.__qualname__ == 'function'. The builtin 'function' type has __qualname__=='function' as well as __name__=='function'. No prior pathlib spec checks __repr__.__class__.__qualname__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__hash__.__class__.__name__ == 'function'. PurePath defines __hash__ as a Python function in pathlib.py (confirmed: '__hash__' in PurePath.__dict__ is True). Its __class__ is the 'function' type with __name__=='function'. No prior pathlib spec checks __hash__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.Path.__hash__.__class__.__name__ == 'function'. Path inherits __hash__ from PurePath. Same result. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path/PurePath/PurePosixPath/PureWindowsPath __repr__.__class__.__name__
#
# All path classes are pure-Python classes. __repr__ is defined as a regular
# Python function in PurePath (all other path classes inherit it). The builtin
# 'function' type has __name__ == 'function'. This differs from C-extension types
# (like io.BytesIO) where __repr__ is a 'wrapper_descriptor'.
#
# Note: Path/PurePath use __slots__ and are NOT weakly referenceable — there is
# no __weakref__ descriptor on these classes.
#
#   Path.__repr__.__class__.__name__          == 'function'
#   PurePath.__repr__.__class__.__name__      == 'function'
#   PurePosixPath.__repr__.__class__.__name__ == 'function'
#   PureWindowsPath.__repr__.__class__.__name__ == 'function'
#
# No prior pathlib spec checks __repr__.__class__.__name__ for any path class.
# All four anchors are novel in the pathlibmod62 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra62.repr_class_name_eq:
  description: "pathlib Path/PurePath/PurePosixPath/PureWindowsPath __repr__.__class__.__name__.__eq__('function') — pure-Python path classes define __repr__ as a regular Python function (PurePath.__repr__ defined in pathlib.py); the builtin 'function' type has __name__=='function'; contrasts with C-extension types whose __repr__ is 'wrapper_descriptor'; no prior pathlib spec checks __repr__.__class__.__name__; all four novel anchors in pathlibmod62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibrepr62repr

  columns: [id, function, args, expected]
  rows:
    - [Path_repr_class_name,          "Path.__repr__.__class__.__name__.__eq__",          ["function"], true]
    - [PurePath_repr_class_name,      "PurePath.__repr__.__class__.__name__.__eq__",      ["function"], true]
    - [PurePosixPath_repr_class_name, "PurePosixPath.__repr__.__class__.__name__.__eq__", ["function"], true]
    - [PureWindowsPath_repr_class_name, "PureWindowsPath.__repr__.__class__.__name__.__eq__", ["function"], true]

# ---------------------------------------------------------------------------
# Path/PurePath/PurePosixPath/PureWindowsPath __repr__.__class__.__qualname__
#
# The builtin 'function' type has both __name__ == 'function' and
# __qualname__ == 'function'. Checking __class__.__qualname__ provides an
# additional orthogonal anchor for the same path class __repr__ chain.
# No prior pathlib spec checks __repr__.__class__.__qualname__ for any path class.
#
#   Path.__repr__.__class__.__qualname__          == 'function'
#   PurePath.__repr__.__class__.__qualname__      == 'function'
#   PurePosixPath.__repr__.__class__.__qualname__ == 'function'
#   PureWindowsPath.__repr__.__class__.__qualname__ == 'function'
#
# All four anchors are novel in the pathlibmod62 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra62.repr_class_qualname_eq:
  description: "pathlib Path/PurePath/PurePosixPath/PureWindowsPath __repr__.__class__.__qualname__.__eq__('function') — the builtin 'function' type has __qualname__=='function' as well as __name__=='function'; no prior pathlib spec checks __repr__.__class__.__qualname__ for any path class; all four novel anchors in pathlibmod62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibrepr62reprq

  columns: [id, function, args, expected]
  rows:
    - [Path_repr_class_qualname,          "Path.__repr__.__class__.__qualname__.__eq__",          ["function"], true]
    - [PurePath_repr_class_qualname,      "PurePath.__repr__.__class__.__qualname__.__eq__",      ["function"], true]
    - [PurePosixPath_repr_class_qualname, "PurePosixPath.__repr__.__class__.__qualname__.__eq__", ["function"], true]
    - [PureWindowsPath_repr_class_qualname, "PureWindowsPath.__repr__.__class__.__qualname__.__eq__", ["function"], true]

# ---------------------------------------------------------------------------
# Path/PurePath __hash__.__class__.__name__ == 'function'
#
# PurePath defines __hash__ as a regular Python function in pathlib.py
# (confirmed: '__hash__' in PurePath.__dict__ is True). Path inherits __hash__
# from PurePath. The builtin 'function' type has __name__ == 'function'.
# This differs from C-extension types (like io.BytesIO) where __hash__ is
# a 'wrapper_descriptor'.
#
#   Path.__hash__.__class__.__name__     == 'function'
#   PurePath.__hash__.__class__.__name__ == 'function'
#
# No prior pathlib spec checks __hash__.__class__.__name__ for any path class.
# Both anchors are novel in the pathlibmod62 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra62.hash_class_name_eq:
  description: "pathlib Path/PurePath __hash__.__class__.__name__.__eq__('function') — PurePath defines __hash__ as a Python function in pathlib.py; Path inherits it; the builtin 'function' type has __name__=='function'; contrasts with C-extension types where __hash__ is 'wrapper_descriptor'; no prior pathlib spec checks __hash__.__class__.__name__; both novel anchors in pathlibmod62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibrepr62hash

  columns: [id, function, args, expected]
  rows:
    - [Path_hash_class_name,     "Path.__hash__.__class__.__name__.__eq__",     ["function"], true]
    - [PurePath_hash_class_name, "PurePath.__hash__.__class__.__name__.__eq__", ["function"], true]

invariant pathlib_extra62.Path_repr_class_name_function:
  description: "pathlib.Path.__repr__.__class__.__name__ == 'function' — Path.__repr__ resolves to PurePath.__repr__, a regular Python function defined in pathlib.py; the builtin 'function' type has __name__=='function'; no prior pathlib spec checks __repr__.__class__.__name__; novel anchor in pathlibmod62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Path.__repr__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra62.PurePath_hash_class_name_function:
  description: "pathlib.PurePath.__hash__.__class__.__name__ == 'function' — PurePath defines __hash__ as a Python function in pathlib.py (confirmed in PurePath.__dict__); the builtin 'function' type has __name__=='function'; no prior pathlib spec checks __hash__.__class__.__name__; novel anchor in pathlibmod62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__hash__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant pathlib_extra62.Path_repr_class_qualname_function:
  description: "pathlib.Path.__repr__.__class__.__qualname__ == 'function' — the builtin 'function' type has __qualname__=='function'; no prior pathlib spec checks __repr__.__class__.__qualname__; novel anchor in pathlibmod62 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Path.__repr__.__class__.__qualname__.__eq__
  args: ["function"]
  expected: true
