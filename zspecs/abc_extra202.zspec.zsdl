# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra202
# ---------------------------------------------------------------------------

invariant abc_extra202.abstractmethod_coflags_type_int:
  description: "abc.abstractmethod.__code__.co_flags.__class__.__name__.__eq__('int') returns True — abc.abstractmethod is a regular function used as a decorator; it is defined in the frozen abc module; co_flags is always an integer bitmask regardless of whether the module is frozen; abstractmethod.co_flags==67108867 (CO_OPTIMIZED|CO_NEWLOCALS); co_flags.__class__.__name__ is 'int' (len=3: i-n-t); same co_flags value as abc.update_abstractmethods and concurrent.futures.wait; NEW in extra202: first standalone abc.abstractmethod co_flags type invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant abc_extra202.abstractmethod_costacksize_type_int:
  description: "abc.abstractmethod.__code__.co_stacksize.__class__.__name__.__eq__('int') returns True — abc.abstractmethod.co_stacksize==2 (the smallest co_stacksize among the abc functions examined: abstractmethod=2 < ABCMeta.__new__=6 < update_abstractmethods=7); abstractmethod simply calls setattr(__isabstractmethod__=True) on its argument and returns it, requiring only 2 stack slots; co_stacksize.__class__.__name__ is 'int'; NEW in extra202; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant abc_extra202.abstractmethod_cofilename_type_str:
  description: "abc.abstractmethod.__code__.co_filename.__class__.__name__.__eq__('str') returns True — abc.abstractmethod.co_filename is '<frozen abc>'; even though this is not a real filesystem path, co_filename is always a plain Python str; the abc module is compiled as a frozen module built into the interpreter; co_filename.__class__.__name__ is 'str' (len=3); contrast with asyncio/multiprocessing where co_filename is a real path; NEW in extra202; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_filename.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra202.abcmeta_new_coflags_type_int:
  description: "abc.ABCMeta.__new__.__code__.co_flags.__class__.__name__.__eq__('int') returns True — abc.ABCMeta.__new__ is a special method defined in the frozen abc module; ABCMeta.__new__.co_flags==134217739 (larger than abstractmethod.co_flags==67108867 due to additional interpreter optimization flags applied to __new__ methods); co_flags.__class__.__name__ is 'int'; NEW in extra202; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant abc_extra202.update_abstractmethods_coflags_type_int:
  description: "abc.update_abstractmethods.__code__.co_flags.__class__.__name__.__eq__('int') returns True — abc.update_abstractmethods is a regular function added in Python 3.10 that recalculates the __abstractmethods__ set on a class after modifications; update_abstractmethods.co_flags==67108867 (same value as abstractmethod.co_flags — both are regular functions with identical base compilation flags); co_flags.__class__.__name__ is 'int'; update_abstractmethods.co_stacksize==7 (larger than abstractmethod.co_stacksize==2); NEW in extra202; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attr_types
  kind: python_call_eq
  function: abc.update_abstractmethods.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant abc_extra202.abstractmethod_coflags_value:
  description: "abc.abstractmethod.__code__.co_flags.__eq__(67108867) returns True — abc.abstractmethod.co_flags is 67108867; this is a CO_OPTIMIZED|CO_NEWLOCALS regular function flag pattern; the same value appears in abc.update_abstractmethods.co_flags (67108867) and concurrent.futures.wait.co_flags (67108867) — all regular functions with no special features; abstractmethod.co_flags (67108867) < ABCMeta.__new__.co_flags (134217739); NEW in extra202; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_flag_values
  kind: python_call_eq
  function: abc.abstractmethod.__code__.co_flags.__eq__
  args: [67108867]
  expected: true

invariant abc_extra202.abcmeta_new_coflags_value:
  description: "abc.ABCMeta.__new__.__code__.co_flags.__eq__(134217739) returns True — abc.ABCMeta.__new__.co_flags is 134217739; this is larger than abstractmethod.co_flags (67108867) and update_abstractmethods.co_flags (67108867) because ABCMeta.__new__ is a class constructor method with additional compiler flags; ABCMeta.__new__.co_stacksize==6; ABCMeta.__new__.co_filename=='<frozen abc>'; NEW in extra202; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_flag_values
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__code__.co_flags.__eq__
  args: [134217739]
  expected: true

invariant abc_extra202.update_abstractmethods_coflags_value:
  description: "abc.update_abstractmethods.__code__.co_flags.__eq__(67108867) returns True — abc.update_abstractmethods.co_flags is 67108867; identical to abstractmethod.co_flags (67108867) — both are regular functions with the same CO_OPTIMIZED|CO_NEWLOCALS base flag pattern; update_abstractmethods.co_stacksize==7 (largest among the three abc functions: update=7 > ABCMeta.__new__=6 > abstractmethod=2); update_abstractmethods.co_filename=='<frozen abc>'; NEW in extra202; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_flag_values
  kind: python_call_eq
  function: abc.update_abstractmethods.__code__.co_flags.__eq__
  args: [67108867]
  expected: true

