table abc_extra202.abc_abstractmethod_code_types:
  description: "abc.abstractmethod __code__ attribute type name checks in abccoflags202 namespace — abstractmethod.__code__.co_flags.__class__.__name__=='int' (co_flags==67108867; CO_OPTIMIZED|CO_NEWLOCALS; same value as concurrent.futures.wait and abc.update_abstractmethods); abstractmethod.__code__.co_stacksize.__class__.__name__=='int' (co_stacksize==2; smallest among the abc functions because abstractmethod just sets __isabstractmethod__ on its argument); abstractmethod.__code__.co_filename.__class__.__name__=='str' (co_filename=='<frozen abc>'; the abc module is frozen but co_filename is still a plain Python str object even though it is not a filesystem path); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attr_types
  id_prefix: abccoflags202

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_coflags_type_eq,    abc.abstractmethod.__code__.co_flags.__class__.__name__.__eq__,     ["int"], true, "abc.abstractmethod.__code__.co_flags.__class__.__name__ == 'int'; verified Python 3.14.3"]
    - [abstractmethod_costacksize_type_eq, abc.abstractmethod.__code__.co_stacksize.__class__.__name__.__eq__, ["int"], true, "abc.abstractmethod.__code__.co_stacksize.__class__.__name__ == 'int'; verified Python 3.14.3"]
    - [abstractmethod_cofilename_type_eq,  abc.abstractmethod.__code__.co_filename.__class__.__name__.__eq__,  ["str"], true, "abc.abstractmethod.__code__.co_filename.__class__.__name__ == 'str' (frozen module; '<frozen abc>' is still str); verified Python 3.14.3"]
    - [abcmeta_new_coflags_type_eq,       abc.ABCMeta.__new__.__code__.co_flags.__class__.__name__.__eq__,    ["int"], true, "abc.ABCMeta.__new__.__code__.co_flags.__class__.__name__ == 'int'; verified Python 3.14.3"]

