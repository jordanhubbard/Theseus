spec: abc_extra202
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py (frozen as <frozen abc>)"
  notes:
    - "abc.abstractmethod.__code__.co_flags == 67108867 — abstractmethod is a regular (non-async, non-generator) function; co_flags.__class__.__name__ == 'int'; same co_flags value as concurrent.futures.wait and abc.update_abstractmethods."
    - "abc.abstractmethod.__code__.co_stacksize == 2 — abstractmethod has the smallest co_stacksize among the abc functions checked; it is a simple decorator that sets __isabstractmethod__=True on its argument."
    - "abc.abstractmethod.__code__.co_filename == '<frozen abc>' — abc module is compiled as a frozen module; co_filename.__class__.__name__ == 'str' (the string '<frozen abc>' is still a str even though it is not a real file path)."
    - "abc.ABCMeta.__new__.__code__.co_flags == 134217739 — ABCMeta.__new__ is a regular class method with high interpreter flags; different from abstractmethod (67108867) and update_abstractmethods (67108867)."
    - "abc.update_abstractmethods.__code__.co_flags == 67108867 — same co_flags as abstractmethod; both are regular functions with the same base compilation profile."
    - "abc.ABCMeta.__new__.co_stacksize == 6; abc.update_abstractmethods.co_stacksize == 7 — update_abstractmethods has the largest stack depth among the three abc functions."
    - "abc.ABCMeta.__new__.co_filename == '<frozen abc>'; abc.update_abstractmethods.co_filename == '<frozen abc>' — all abc module functions are frozen."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

