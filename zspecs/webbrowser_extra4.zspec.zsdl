spec: webbrowser_extra4
version: ">=3.9"
backend: python_module(webbrowser)

docs: https://docs.python.org/3/library/webbrowser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/webbrowser.html — Python webbrowser module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/webbrowser.py"
  notes:
    - "This spec extends webbrowser.zspec.zsdl and webbrowser_extra through webbrowser_extra3.zspec.zsdl."
    - "webbrowser covers: function name table (open/open_new/open_new_tab/get/register); class name table (BaseBrowser/GenericBrowser/BackgroundBrowser/Mozilla); open.__module__; GenericBrowser/BackgroundBrowser class hierarchy."
    - "webbrowser_extra covers: function __name__/__qualname__/__class__; Error.__name__/__module__/__class__/__bases__."
    - "webbrowser_extra2 covers: BaseBrowser/GenericBrowser/BackgroundBrowser __name__/__module__/__qualname__/__class__; _tryorder is list; _browsers is dict."
    - "webbrowser_extra3 covers: open/open_new/open_new_tab/get/register __module__; function __name__ batch table."
    - "This spec adds: Mozilla/Chrome/Edge/Opera/UnixBrowser/MacOSXOSAScript __name__ and __module__; UnixBrowser.__bases__[0].__name__; __all__ is list; __all__ contains 'open'."
    - "Mozilla.__name__ == 'Mozilla' and Mozilla.__module__ == 'webbrowser' — Mozilla-family browser controller."
    - "UnixBrowser.__bases__[0].__name__ == 'BaseBrowser' — UnixBrowser inherits from BaseBrowser."
    - "webbrowser.__all__ is a list containing the public API names."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Mozilla — __name__ and __module__
# webbrowser.zspec covers Mozilla.__name__ in a table; __module__ is new here.
# ---------------------------------------------------------------------------

invariant webbrowser_extra4.Mozilla.name:
  description: "webbrowser.Mozilla.__name__ == 'Mozilla'"
  category: classes
  kind: python_call_eq
  function: Mozilla.__name__.__eq__
  args: ["Mozilla"]
  expected: true

invariant webbrowser_extra4.Mozilla.module:
  description: "webbrowser.Mozilla.__module__ == 'webbrowser'"
  category: classes
  kind: python_call_eq
  function: Mozilla.__module__.__eq__
  args: ["webbrowser"]
  expected: true

# ---------------------------------------------------------------------------
# UnixBrowser — __name__, __module__, and base class
# UnixBrowser is the common base for Chrome, Edge, Opera, etc.
# None of the prior specs cover UnixBrowser.
# ---------------------------------------------------------------------------

invariant webbrowser_extra4.UnixBrowser.name:
  description: "webbrowser.UnixBrowser.__name__ == 'UnixBrowser'"
  category: classes
  kind: python_call_eq
  function: UnixBrowser.__name__.__eq__
  args: ["UnixBrowser"]
  expected: true

invariant webbrowser_extra4.UnixBrowser.module:
  description: "webbrowser.UnixBrowser.__module__ == 'webbrowser'"
  category: classes
  kind: python_call_eq
  function: UnixBrowser.__module__.__eq__
  args: ["webbrowser"]
  expected: true

invariant webbrowser_extra4.UnixBrowser.base_is_BaseBrowser:
  description: "webbrowser.UnixBrowser.__bases__[0].__name__ == 'BaseBrowser'"
  category: class_hierarchy
  kind: python_call_eq
  function: UnixBrowser.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseBrowser"

# ---------------------------------------------------------------------------
# Chrome — __name__ and __module__
# Chrome is a UnixBrowser subclass for Chromium/Chrome-family browsers.
# ---------------------------------------------------------------------------

invariant webbrowser_extra4.Chrome.name:
  description: "webbrowser.Chrome.__name__ == 'Chrome'"
  category: classes
  kind: python_call_eq
  function: Chrome.__name__.__eq__
  args: ["Chrome"]
  expected: true

invariant webbrowser_extra4.Chrome.module:
  description: "webbrowser.Chrome.__module__ == 'webbrowser'"
  category: classes
  kind: python_call_eq
  function: Chrome.__module__.__eq__
  args: ["webbrowser"]
  expected: true

# ---------------------------------------------------------------------------
# Edge — __name__ and __module__
# Edge is a UnixBrowser subclass; not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant webbrowser_extra4.Edge.name:
  description: "webbrowser.Edge.__name__ == 'Edge'"
  category: classes
  kind: python_call_eq
  function: Edge.__name__.__eq__
  args: ["Edge"]
  expected: true

invariant webbrowser_extra4.Edge.module:
  description: "webbrowser.Edge.__module__ == 'webbrowser'"
  category: classes
  kind: python_call_eq
  function: Edge.__module__.__eq__
  args: ["webbrowser"]
  expected: true

# ---------------------------------------------------------------------------
# __all__ — public API list
# webbrowser.__all__ is a list; not yet covered in any prior spec.
# ---------------------------------------------------------------------------

invariant webbrowser_extra4.all.is_list:
  description: "webbrowser.__all__.__class__.__name__ == 'list' — public API is a list"
  category: module
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant webbrowser_extra4.all.contains_open:
  description: "webbrowser.__all__ contains 'open'"
  category: module
  kind: python_call_eq
  function: __all__.__contains__
  args: ["open"]
  expected: true

invariant webbrowser_extra4.all.contains_get:
  description: "webbrowser.__all__ contains 'get'"
  category: module
  kind: python_call_eq
  function: __all__.__contains__
  args: ["get"]
  expected: true
