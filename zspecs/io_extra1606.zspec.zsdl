spec: io_extra1606
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "io stream classes are C extension types (from _io); C types do not use Python __slots__"
    - "Absence of __slots__ in a C type class dict is the expected and normal condition"
    - "C types also do not expose __dict__ in their class dicts; instance storage is C-level"
    - "io.IOBase, io.RawIOBase, io.TextIOBase, io.BufferedIOBase are Python ABCs wrapping _io C bases"
    - "io.UnsupportedOperation derives from OSError and ValueError; no explicit __slots__ defined"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Concrete stream classes (C extensions) have no __slots__
# ---------------------------------------------------------------------------

table io_extra1606.stream_classes_no_slots:
  description: "io.StringIO, BytesIO, TextIOWrapper, BufferedReader, BufferedWriter, BufferedRandom, FileIO are C extension types — none define __slots__ in their class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1606sc

  columns: [id, function, args, expected]
  rows:
    - ["io1606sc001", io.StringIO.__dict__.__contains__,       ["__slots__"], false]
    - ["io1606sc002", io.BytesIO.__dict__.__contains__,        ["__slots__"], false]
    - ["io1606sc003", io.TextIOWrapper.__dict__.__contains__,  ["__slots__"], false]
    - ["io1606sc004", io.BufferedReader.__dict__.__contains__,  ["__slots__"], false]
    - ["io1606sc005", io.BufferedWriter.__dict__.__contains__,  ["__slots__"], false]
    - ["io1606sc006", io.BufferedRandom.__dict__.__contains__,  ["__slots__"], false]
    - ["io1606sc007", io.FileIO.__dict__.__contains__,          ["__slots__"], false]
    - ["io1606sc008", io.UnsupportedOperation.__dict__.__contains__, ["__slots__"], false]
    - ["io1606sc009", io.StringIO.__dict__.__contains__,       ["__dict__"],  false]
    - ["io1606sc010", io.BytesIO.__dict__.__contains__,        ["__dict__"],  false]
    - ["io1606sc011", io.TextIOWrapper.__dict__.__contains__,  ["__dict__"],  false]
    - ["io1606sc012", io.BufferedReader.__dict__.__contains__,  ["__dict__"],  false]
    - ["io1606sc013", io.BufferedWriter.__dict__.__contains__,  ["__dict__"],  false]
    - ["io1606sc014", io.BufferedRandom.__dict__.__contains__,  ["__dict__"],  false]
    - ["io1606sc015", io.FileIO.__dict__.__contains__,          ["__dict__"],  false]
    - ["io1606sc016", io.StringIO.__dict__.__contains__,       ["__weakref__"], false]
    - ["io1606sc017", io.BytesIO.__dict__.__contains__,        ["__weakref__"], false]
    - ["io1606sc018", io.TextIOWrapper.__dict__.__contains__,  ["__weakref__"], false]
    - ["io1606sc019", io.BufferedReader.__dict__.__contains__,  ["__weakref__"], false]
    - ["io1606sc020", io.BufferedWriter.__dict__.__contains__,  ["__weakref__"], false]
    - ["io1606sc021", io.BufferedRandom.__dict__.__contains__,  ["__weakref__"], false]
    - ["io1606sc022", io.FileIO.__dict__.__contains__,          ["__weakref__"], false]
    - ["io1606sc023", io.UnsupportedOperation.__dict__.__contains__, ["__dict__"],  false]
    - ["io1606sc024", io.UnsupportedOperation.__dict__.__contains__, ["__weakref__"], true]
    - ["io1606sc025", io.UnsupportedOperation.__dict__.__contains__, ["__module__"], true]

# ---------------------------------------------------------------------------
# Table 2: Abstract base classes in io module also have no __slots__
# ---------------------------------------------------------------------------

table io_extra1606.base_classes_no_slots:
  description: "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are Python ABCs; the _io C base classes they wrap are also C types — none define __slots__ in their own class dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1606bc

  columns: [id, function, args, expected]
  rows:
    - ["io1606bc001", io.IOBase.__dict__.__contains__,       ["__slots__"], false]
    - ["io1606bc002", io.RawIOBase.__dict__.__contains__,    ["__slots__"], false]
    - ["io1606bc003", io.BufferedIOBase.__dict__.__contains__, ["__slots__"], false]
    - ["io1606bc004", io.TextIOBase.__dict__.__contains__,   ["__slots__"], false]
