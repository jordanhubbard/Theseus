    - ["io1606bc006", io.RawIOBase.__dict__.__contains__,    ["__dict__"],  false]
    - ["io1606bc007", io.BufferedIOBase.__dict__.__contains__, ["__dict__"],  false]
    - ["io1606bc008", io.TextIOBase.__dict__.__contains__,   ["__dict__"],  false]
    - ["io1606bc009", io.IOBase.__dict__.__contains__,       ["__weakref__"], false]
    - ["io1606bc010", io.RawIOBase.__dict__.__contains__,    ["__weakref__"], false]
    - ["io1606bc011", io.BufferedIOBase.__dict__.__contains__, ["__weakref__"], false]
    - ["io1606bc012", io.TextIOBase.__dict__.__contains__,   ["__weakref__"], false]
    - ["io1606bc013", io.IOBase.__dict__.__contains__,       ["__module__"], true]
    - ["io1606bc014", io.RawIOBase.__dict__.__contains__,    ["__module__"], true]
    - ["io1606bc015", io.BufferedIOBase.__dict__.__contains__, ["__module__"], true]
    - ["io1606bc016", io.TextIOBase.__dict__.__contains__,   ["__module__"], true]
    - ["io1606bc017", io.IOBase.__dict__.__contains__,       ["__abstractmethods__"], true]
    - ["io1606bc018", io.RawIOBase.__dict__.__contains__,    ["__abstractmethods__"], true]
    - ["io1606bc019", io.BufferedIOBase.__dict__.__contains__, ["__abstractmethods__"], true]
    - ["io1606bc020", io.TextIOBase.__dict__.__contains__,   ["__abstractmethods__"], true]
    - ["io1606bc021", io.IOBase.__dict__.__contains__,       ["_abc_impl"],  true]
    - ["io1606bc022", io.RawIOBase.__dict__.__contains__,    ["_abc_impl"],  true]
    - ["io1606bc023", io.BufferedIOBase.__dict__.__contains__, ["_abc_impl"],  true]
    - ["io1606bc024", io.TextIOBase.__dict__.__contains__,   ["_abc_impl"],  true]
    - ["io1606bc025", io.IOBase.__dict__.__contains__,       ["__static_attributes__"], true]
