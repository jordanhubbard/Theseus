spec: unicodedata_extra2
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
    - "unicodedata.zspec.zsdl — covers name, lookup, category, bidirectional, combining, east_asian_width, decomposition, decimal, numeric, normalize, unidata_version"
    - "unicodedata_extra.zspec.zsdl — covers __name__ for lookup, name, decimal, digit, numeric, category, bidirectional, combining, east_asian_width, mirrored, decomposition, normalize, is_normalized; unidata_version type and value checks"
  notes:
    - "This spec extends unicodedata.zspec.zsdl and unicodedata_extra.zspec.zsdl."
    - "unicodedata_extra.zspec.zsdl already covers __name__ for all major functions. This spec adds __module__ checks and unidata_version length/format invariants."
    - "unicodedata built-in functions report __module__ == 'unicodedata' (C-level module name)."
    - "unidata_version is a dot-separated version string; its length >= 3 (e.g. '15.0.0' has length 6)."
    - "unidata_version.__len__() >= 3 — even a minimal version string 'X.Y' has 3 chars."
    - "normalize.__name__ == 'normalize', decomposition.__name__ == 'decomposition', etc. — already in extra; __module__ checks added here."
    - "is_normalized was added in Python 3.11; this spec is version >=3.9 so is_normalized __name__ check is gated by spec version field."
    - "combining.__name__ == 'combining' is already in unicodedata_extra; __module__ confirmed here."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# unidata_version — type is str (class name check)
# unicodedata_extra covers unidata_version.__class__.__name__ == 'str'
# This spec adds: length >= 3 and contains at least one '.'
# ---------------------------------------------------------------------------

invariant unicodedata_extra2.unidata_version.min_len:
  description: "unicodedata.unidata_version.__len__() >= 3 — version string is at least 3 chars (e.g. '5.0')"
  category: version
  kind: python_call_eq
  function: unidata_version.__len__
  args: []
  method: __ge__
  method_args: [3]
  expected: true

invariant unicodedata_extra2.unidata_version.contains_dot:
  description: "unicodedata.unidata_version.__contains__('.') — version string contains a dot separator"
  category: version
  kind: python_call_eq
  function: unidata_version.__contains__
  args: ["."]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks — all major unicodedata built-in functions live in 'unicodedata'
# ---------------------------------------------------------------------------

table unicodedata_extra2.module_checks:
  description: "unicodedata functions report __module__ == 'unicodedata'"
  kind: python_call_eq
  category: module_identity
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [normalize,      normalize.__module__.__eq__,      ["unicodedata"], true]
    - [decomposition,  decomposition.__module__.__eq__,  ["unicodedata"], true]
    - [bidirectional,  bidirectional.__module__.__eq__,  ["unicodedata"], true]
    - [east_asian_width, east_asian_width.__module__.__eq__, ["unicodedata"], true]
    - [combining,      combining.__module__.__eq__,      ["unicodedata"], true]
    - [category,       category.__module__.__eq__,       ["unicodedata"], true]
    - [lookup,         lookup.__module__.__eq__,         ["unicodedata"], true]
    - [name,           name.__module__.__eq__,           ["unicodedata"], true]

# ---------------------------------------------------------------------------
# normalize/__name__ — explicit invariant (not a table row so it's unambiguous)
# ---------------------------------------------------------------------------

invariant unicodedata_extra2.normalize.name:
  description: "unicodedata.normalize.__name__ == 'normalize'"
  category: function_identity
  kind: python_call_eq
  function: normalize.__name__.__eq__
  args: ["normalize"]
  expected: true

# ---------------------------------------------------------------------------
# decomposition/__name__
# ---------------------------------------------------------------------------

invariant unicodedata_extra2.decomposition.name:
  description: "unicodedata.decomposition.__name__ == 'decomposition'"
  category: function_identity
  kind: python_call_eq
  function: decomposition.__name__.__eq__
  args: ["decomposition"]
  expected: true

# ---------------------------------------------------------------------------
# bidirectional/__name__
# ---------------------------------------------------------------------------

invariant unicodedata_extra2.bidirectional.name:
  description: "unicodedata.bidirectional.__name__ == 'bidirectional'"
  category: function_identity
  kind: python_call_eq
  function: bidirectional.__name__.__eq__
  args: ["bidirectional"]
  expected: true

# ---------------------------------------------------------------------------
# east_asian_width/__name__
# ---------------------------------------------------------------------------

invariant unicodedata_extra2.east_asian_width.name:
  description: "unicodedata.east_asian_width.__name__ == 'east_asian_width'"
  category: function_identity
  kind: python_call_eq
  function: east_asian_width.__name__.__eq__
  args: ["east_asian_width"]
  expected: true

# ---------------------------------------------------------------------------
# combining/__name__
# ---------------------------------------------------------------------------

invariant unicodedata_extra2.combining.name:
  description: "unicodedata.combining.__name__ == 'combining'"
  category: function_identity
  kind: python_call_eq
  function: combining.__name__.__eq__
  args: ["combining"]
  expected: true

# ---------------------------------------------------------------------------
# is_normalized/__name__ — Python >= 3.11 function
# ---------------------------------------------------------------------------

invariant unicodedata_extra2.is_normalized.name:
  description: "unicodedata.is_normalized.__name__ == 'is_normalized' (Python >= 3.11)"
  category: function_identity
  version: ">=3.11"
  kind: python_call_eq
  function: is_normalized.__name__.__eq__
  args: ["is_normalized"]
  expected: true

# ---------------------------------------------------------------------------
# is_normalized/__module__ — Python >= 3.11 function
# ---------------------------------------------------------------------------

invariant unicodedata_extra2.is_normalized.module:
  description: "unicodedata.is_normalized.__module__ == 'unicodedata' (Python >= 3.11)"
  category: module_identity
  version: ">=3.11"
  kind: python_call_eq
  function: is_normalized.__module__.__eq__
  args: ["unicodedata"]
  expected: true
