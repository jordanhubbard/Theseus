spec: inspect_extra766
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/inspect.py"
  not_derived_from:
    - "any third-party inspect extension"
  notes:
    - "Covers inspect.Parameter kind name and value attributes"
    - "Also covers __class__.__name__ identity for _ParameterKind enum members"
    - "All enum values and names are stable across CPython >=3.9"
  created_at: "2026-04-12"

table inspect_extra766.name:
  description: "inspect.Parameter kind name attributes"
  kind: python_call_eq
  category: enum_identity
  id_prefix: in766xx
  columns: [id, function, args, expected]
  rows:
    - [in766xx001, inspect.Parameter.POSITIONAL_ONLY.name.__eq__, ["POSITIONAL_ONLY"], true]
    - [in766xx002, inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__, ["POSITIONAL_OR_KEYWORD"], true]
    - [in766xx003, inspect.Parameter.VAR_POSITIONAL.name.__eq__, ["VAR_POSITIONAL"], true]
    - [in766xx004, inspect.Parameter.KEYWORD_ONLY.name.__eq__, ["KEYWORD_ONLY"], true]
    - [in766xx005, inspect.Parameter.VAR_KEYWORD.name.__eq__, ["VAR_KEYWORD"], true]
    - [in766xx006, inspect.Parameter.POSITIONAL_ONLY.value.__eq__, [0], true]
    - [in766xx007, inspect.Parameter.POSITIONAL_OR_KEYWORD.value.__eq__, [1], true]
    - [in766xx008, inspect.Parameter.VAR_POSITIONAL.value.__eq__, [2], true]
    - [in766xx009, inspect.Parameter.KEYWORD_ONLY.value.__eq__, [3], true]
    - [in766xx010, inspect.Parameter.VAR_KEYWORD.value.__eq__, [4], true]
    - [in766xx011, inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__, ["_ParameterKind"], true]
    - [in766xx012, inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"], true]
