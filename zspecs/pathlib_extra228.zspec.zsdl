spec: pathlib_extra228
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib class __qualname__ contracts for Path, PurePath, PosixPath and selected Path method __qualname__ values."
    - "pathlib.Path.__qualname__ == 'Path'; verified with Python 3.14.3."
    - "pathlib.PurePath.__qualname__ == 'PurePath'; verified with Python 3.14.3."
    - "pathlib.PosixPath.__qualname__ == 'PosixPath'; verified with Python 3.14.3."
    - "pathlib.Path.is_absolute.__qualname__ == 'PurePath.is_absolute'; inherited from PurePath; verified with Python 3.14.3."
    - "pathlib.Path.is_file.__qualname__ == 'Path.is_file'; verified with Python 3.14.3."
    - "pathlib.Path.is_dir.__qualname__ == 'Path.is_dir'; verified with Python 3.14.3."
    - "pathlib.Path.exists.__qualname__ == 'Path.exists'; verified with Python 3.14.3."
    - "pathlib.Path.stat.__qualname__ == 'Path.stat'; verified with Python 3.14.3."
    - "pathlib.Path.open.__qualname__ == 'Path.open'; verified with Python 3.14.3."
    - "pathlib.Path.resolve.__qualname__ == 'Path.resolve'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __qualname__ values
# Top-level classes: qualname equals simple name.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table pathlib_extra228.class_qualnames:
  description: "pathlib class __qualname__ contracts for Path, PurePath, PosixPath; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: plclsqualname228

  columns: [id, function, args, expected]
  rows:
    - [path_qualname,      Path.__qualname__.__eq__,      ["Path"],      true]
    - [purepath_qualname,  PurePath.__qualname__.__eq__,  ["PurePath"],  true]
    - [posixpath_qualname, PosixPath.__qualname__.__eq__, ["PosixPath"], true]

# ---------------------------------------------------------------------------
# pathlib Path method __qualname__ values
# is_absolute is inherited from PurePath so its qualname uses 'PurePath'.
# All others are defined on Path directly.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table pathlib_extra228.method_qualnames:
  description: "pathlib Path method __qualname__ contracts; is_absolute inherited from PurePath; is_file, is_dir, exists, stat, open, resolve defined on Path; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_metadata
  id_prefix: plmethqualname228

  columns: [id, function, args, expected]
  rows:
    - [is_absolute_qualname, Path.is_absolute.__qualname__.__eq__, ["PurePath.is_absolute"], true]
    - [is_file_qualname,     Path.is_file.__qualname__.__eq__,     ["Path.is_file"],         true]
    - [is_dir_qualname,      Path.is_dir.__qualname__.__eq__,      ["Path.is_dir"],          true]
    - [exists_qualname,      Path.exists.__qualname__.__eq__,      ["Path.exists"],          true]
    - [stat_qualname,        Path.stat.__qualname__.__eq__,        ["Path.stat"],            true]
    - [open_qualname,        Path.open.__qualname__.__eq__,        ["Path.open"],            true]
    - [resolve_qualname,     Path.resolve.__qualname__.__eq__,     ["Path.resolve"],         true]

# ---------------------------------------------------------------------------
# Standalone invariants for key __qualname__ values
# ---------------------------------------------------------------------------

invariant pathlib_extra228.Path.qualname:
  description: "pathlib.Path.__qualname__ == 'Path' — top-level class; qualname equals simple name; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: Path.__qualname__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra228.PurePath.qualname:
  description: "pathlib.PurePath.__qualname__ == 'PurePath' — top-level class; qualname equals simple name; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: PurePath.__qualname__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra228.Path.is_absolute.qualname:
  description: "pathlib.Path.is_absolute.__qualname__ == 'PurePath.is_absolute' — inherited from PurePath; qualname reflects the defining class; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Path.is_absolute.__qualname__.__eq__
  args: ["PurePath.is_absolute"]
  expected: true

invariant pathlib_extra228.Path.is_file.qualname:
  description: "pathlib.Path.is_file.__qualname__ == 'Path.is_file' — defined on Path; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Path.is_file.__qualname__.__eq__
  args: ["Path.is_file"]
  expected: true

invariant pathlib_extra228.Path.exists.qualname:
  description: "pathlib.Path.exists.__qualname__ == 'Path.exists' — defined on Path; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Path.exists.__qualname__.__eq__
  args: ["Path.exists"]
  expected: true

invariant pathlib_extra228.Path.resolve.qualname:
  description: "pathlib.Path.resolve.__qualname__ == 'Path.resolve' — defined on Path; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Path.resolve.__qualname__.__eq__
  args: ["Path.resolve"]
  expected: true
