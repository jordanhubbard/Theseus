spec: theseus_datetime_cr
version: ">=3.9"
backend: python_cleanroom(theseus_datetime_cr)
blocks: datetime

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html"
    - "https://www.rfc-editor.org/rfc/rfc3339 — Date/Time RFC"
  notes:
    - "Clean-room date/time implementation. Do NOT import datetime, time, or calendar."
    - "Date(year, month, day): immutable date; .isoformat() returns 'YYYY-MM-DD'."
    - "Date arithmetic: Date(2026, 4, 20) + timedelta(days=10) == Date(2026, 4, 30)."
    - "timedelta(days=N): duration object."
    - "Date.today() is NOT required — just Date/timedelta construction and arithmetic."
    - "datetime_date_isoformat(): Date(2026, 4, 20).isoformat() == '2026-04-20'."
    - "datetime_timedelta_days(): timedelta(days=5).days == 5."
    - "datetime_date_add(): Date(2026, 4, 20) + timedelta(days=10) gives Date(2026, 4, 30)."
    - "Export: Date(year, month, day), timedelta(days=0, seconds=0)."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_datetime_cr.isoformat:
  description: "Date(2026, 4, 20).isoformat() == '2026-04-20'"
  category: format
  kind: python_call_eq
  function: datetime_date_isoformat
  args: []
  expected: "2026-04-20"

invariant theseus_datetime_cr.timedelta_days:
  description: "timedelta(days=5).days == 5"
  category: timedelta
  kind: python_call_eq
  function: datetime_timedelta_days
  args: []
  expected: 5

invariant theseus_datetime_cr.date_add:
  description: "Date(2026,4,20) + timedelta(days=10) == Date(2026,4,30)"
  category: arithmetic
  kind: python_call_eq
  function: datetime_date_add
  args: []
  expected: "2026-04-30"
