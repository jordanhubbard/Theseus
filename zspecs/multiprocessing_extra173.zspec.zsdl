spec: multiprocessing_extra173
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.shared_ctypes.html — multiprocessing shared ctypes documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/sharedctypes.py"
  notes:
    - "This spec covers: multiprocessing.Value and Array shared memory identity — multiprocessing.Value.__name__=='Value' (len=5); multiprocessing.Value.__module__=='multiprocessing.sharedctypes' (len=30: 'multiprocessing'=15+'.'=1+'sharedctypes'=12=28... actually: 'multiprocessing.sharedctypes'=28); multiprocessing.Array.__name__=='Array' (len=5; same len as Value); multiprocessing.Array.__module__=='multiprocessing.sharedctypes'; multiprocessing.sharedctypes.RawValue.__name__=='RawValue' (len=8: 'Raw'=3+'Value'=5=8); multiprocessing.sharedctypes.RawArray.__name__=='RawArray' (len=8; same as RawValue: 'Raw'=3+'Array'=5=8). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Value.__name__.__len__() == 5. 'Value' is 5 characters: 'V'+'a'+'l'+'u'+'e'=5. Same length as 'Array'=5. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.sharedctypes.RawValue.__name__.__len__() == 8. 'RawValue' is 8 characters: 'Raw'=3+'Value'=5=8. Same length as 'RawArray'=8. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Value.__module__ == 'multiprocessing.sharedctypes'. 'multiprocessing.sharedctypes' is 28 characters: 'multiprocessing'=15+'.'=1+'sharedctypes'=12=28. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Value and Array class identity — extra173
#
# multiprocessing.Value.__name__.__eq__('Value')   == True (len=5)
# multiprocessing.Array.__name__.__eq__('Array')   == True (len=5; same as Value)
# multiprocessing.Value.__module__.__eq__('multiprocessing.sharedctypes')  == True (len=28)
# ---------------------------------------------------------------------------

table multiprocessing_extra173.value_array_identity:
  description: "multiprocessing.Value and Array class name and module identity checks in mpsharedctypes173va namespace — multiprocessing.Value.__name__.__eq__('Value')==True ('Value'=5: 'V'+'a'+'l'+'u'+'e'=5; multiprocessing.Value is a function that creates a ctypes object allocated from shared memory, with a lock; it is actually a factory function defined in Lib/multiprocessing/sharedctypes.py that returns a synchronized wrapper); multiprocessing.Value.__name__.__len__()==5; multiprocessing.Array.__name__.__eq__('Array')==True ('Array'=5: 'A'+'r'+'r'+'a'+'y'=5; same length as 'Value'=5; multiprocessing.Array creates a ctypes array allocated in shared memory with a lock); multiprocessing.Array.__name__.__len__()==5; multiprocessing.Value.__module__.__eq__('multiprocessing.sharedctypes')==True ('multiprocessing.sharedctypes'=28: 'multiprocessing'=15+'.'=1+'sharedctypes'=12=28); multiprocessing.Array.__module__.__eq__('multiprocessing.sharedctypes')==True (same module as Value); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsharedctypes173va

  columns: [id, function, args, expected, description]
  rows:
    - [val_name_eq,    multiprocessing.Value.__name__.__eq__,    ["Value"],                          true,  "multiprocessing.Value.__name__ == 'Value' (len=5); verified with Python 3.14.3"]
    - [val_name_len,   multiprocessing.Value.__name__.__len__,   [],                                 5,     "multiprocessing.Value.__name__.__len__() == 5 ('Value'=5); verified with Python 3.14.3"]
    - [val_mod_eq,     multiprocessing.Value.__module__.__eq__,  ["multiprocessing.sharedctypes"],   true,  "multiprocessing.Value.__module__ == 'multiprocessing.sharedctypes' (len=28); verified with Python 3.14.3"]
    - [arr_name_eq,    multiprocessing.Array.__name__.__eq__,    ["Array"],                          true,  "multiprocessing.Array.__name__ == 'Array' (len=5; same as Value=5); verified with Python 3.14.3"]
    - [arr_name_len,   multiprocessing.Array.__name__.__len__,   [],                                 5,     "multiprocessing.Array.__name__.__len__() == 5 ('Array'=5; same as Value=5); verified with Python 3.14.3"]
    - [arr_mod_eq,     multiprocessing.Array.__module__.__eq__,  ["multiprocessing.sharedctypes"],   true,  "multiprocessing.Array.__module__ == 'multiprocessing.sharedctypes' (same as Value); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.sharedctypes.RawValue and RawArray class identity — extra173
#
# multiprocessing.sharedctypes.RawValue.__name__.__eq__('RawValue')  == True (len=8)
# multiprocessing.sharedctypes.RawArray.__name__.__eq__('RawArray')  == True (len=8; same as RawValue)
# ---------------------------------------------------------------------------

table multiprocessing_extra173.rawvalue_rawarray_identity:
  description: "multiprocessing.sharedctypes.RawValue and RawArray class name identity checks in mpsharedctypes173raw namespace — multiprocessing.sharedctypes.RawValue.__name__.__eq__('RawValue')==True ('RawValue'=8: 'Raw'=3+'Value'=5=8; RawValue is a ctypes object in shared memory WITHOUT a lock — contrast with multiprocessing.Value which adds a lock; 'Raw' prefix signifies no synchronization); multiprocessing.sharedctypes.RawValue.__name__.__len__()==8; multiprocessing.sharedctypes.RawArray.__name__.__eq__('RawArray')==True ('RawArray'=8: 'Raw'=3+'Array'=5=8; same length as RawValue=8; RawArray is a ctypes array in shared memory WITHOUT a lock); multiprocessing.sharedctypes.RawArray.__name__.__len__()==8; NAME LENGTH COMPARISON: 'Value'=5 == 'Array'=5 < 'RawValue'=8 == 'RawArray'=8; the 'Raw' prefix adds exactly 3 chars ('R'+'a'+'w'=3) to both Value and Array; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsharedctypes173raw

  columns: [id, function, args, expected, description]
  rows:
    - [rv_name_eq,   multiprocessing.sharedctypes.RawValue.__name__.__eq__,    ["RawValue"],  true,  "RawValue.__name__ == 'RawValue' (len=8: 'Raw'=3+'Value'=5=8; no-lock shared memory); verified with Python 3.14.3"]
    - [rv_name_len,  multiprocessing.sharedctypes.RawValue.__name__.__len__,   [],            8,     "RawValue.__name__.__len__() == 8 ('RawValue'=8; 3 longer than Value=5); verified with Python 3.14.3"]
    - [ra_name_eq,   multiprocessing.sharedctypes.RawArray.__name__.__eq__,    ["RawArray"],  true,  "RawArray.__name__ == 'RawArray' (len=8: 'Raw'=3+'Array'=5=8; same len as RawValue=8); verified with Python 3.14.3"]
    - [ra_name_len,  multiprocessing.sharedctypes.RawArray.__name__.__len__,   [],            8,     "RawArray.__name__.__len__() == 8 ('RawArray'=8; same as RawValue=8); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.sharedctypes module path identity — extra173
#
# multiprocessing.sharedctypes.__name__.__eq__('multiprocessing.sharedctypes')  == True (len=28)
# ---------------------------------------------------------------------------

table multiprocessing_extra173.sharedctypes_module_identity:
  description: "multiprocessing.sharedctypes submodule __name__ identity checks in mpsharedctypes173mod namespace — multiprocessing.sharedctypes.__name__.__eq__('multiprocessing.sharedctypes')==True ('multiprocessing.sharedctypes'=28: 'multiprocessing'=15+'.'=1+'sharedctypes'=12=28; 'sharedctypes'=12: 'shared'=6+'ctypes'=6=12; the module name encodes its purpose: shared (between processes) ctypes (C types for low-level memory manipulation)); multiprocessing.sharedctypes.__name__.__len__()==28; multiprocessing.sharedctypes.__package__.__eq__('multiprocessing')==True (sharedctypes is a submodule of multiprocessing; its __package__ is the parent 'multiprocessing' not itself); multiprocessing.Value.__module__.__len__()==28 (module path length equals 28, same as the module's own __name__); NAME LENGTH: 'multiprocessing.sharedctypes'=28 is a long module path; 'multiprocessing'=15 alone is the longest single-component name in the stdlib; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsharedctypes173mod

  columns: [id, function, args, expected, description]
  rows:
    - [modname_eq,   multiprocessing.sharedctypes.__name__.__eq__,     ["multiprocessing.sharedctypes"],  true,  "multiprocessing.sharedctypes.__name__ == 'multiprocessing.sharedctypes' (len=28); verified with Python 3.14.3"]
    - [modname_len,  multiprocessing.sharedctypes.__name__.__len__,    [],                                28,    "multiprocessing.sharedctypes.__name__.__len__() == 28 ('multiprocessing.sharedctypes'=28); verified with Python 3.14.3"]
    - [modpkg_eq,    multiprocessing.sharedctypes.__package__.__eq__,  ["multiprocessing"],               true,  "multiprocessing.sharedctypes.__package__ == 'multiprocessing' (parent package; len=15); verified with Python 3.14.3"]
    - [val_mod_len,  multiprocessing.Value.__module__.__len__,         [],                                28,    "multiprocessing.Value.__module__.__len__() == 28 (module path 'multiprocessing.sharedctypes'=28); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra173
# ---------------------------------------------------------------------------

invariant multiprocessing_extra173.value_name_eq:
  description: "multiprocessing.Value.__name__.__eq__('Value') returns True — multiprocessing.Value.__name__=='Value' (len=5: 'V'+'a'+'l'+'u'+'e'=5); multiprocessing.Value is a factory function defined in Lib/multiprocessing/sharedctypes.py; it creates a ctypes object allocated in a shared memory block that can be inherited by child processes; the object is wrapped in a synchronized proxy providing a lock (RLock by default) so that multiple processes can safely read and write without data races; usage: v = multiprocessing.Value('i', 42) creates a shared integer initialized to 42; v.value gives the current value; v.get_lock() returns the lock; 'Value'=5 is the same length as 'Array'=5; both are 3 chars shorter than 'RawValue'=8 and 'RawArray'=8; NEW in extra173: first standalone multiprocessing.Value.__name__ invariant in mpsharedctypes173va namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__name__.__eq__
  args: ["Value"]
  expected: true

invariant multiprocessing_extra173.array_name_eq:
  description: "multiprocessing.Array.__name__.__eq__('Array') returns True — multiprocessing.Array.__name__=='Array' (len=5: 'A'+'r'+'r'+'a'+'y'=5; same length as 'Value'=5); multiprocessing.Array creates a ctypes array object in shared memory with a lock; usage: a = multiprocessing.Array('i', [1, 2, 3]) creates a shared array of 3 integers; multiprocessing.Array.__module__=='multiprocessing.sharedctypes' (same module as Value; both are defined in Lib/multiprocessing/sharedctypes.py); NAME LENGTH: 'Array'=5 == 'Value'=5 — both are 5-char class names; 'RawArray'=8 > 'Array'=5 by 3 (the 'Raw' prefix); NEW in extra173: first standalone multiprocessing.Array.__name__ invariant in mpsharedctypes173va namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Array.__name__.__eq__
  args: ["Array"]
  expected: true

invariant multiprocessing_extra173.rawvalue_name_len:
  description: "multiprocessing.sharedctypes.RawValue.__name__.__len__() == 8 — multiprocessing.sharedctypes.RawValue.__name__ is 'RawValue' (8 characters: 'Raw'=3+'Value'=5=8); RawValue is the no-lock variant of Value: it allocates a ctypes object in shared memory but provides NO synchronization; the caller is responsible for their own locking when using RawValue in multiprocess code; RawValue is faster than Value (no lock overhead) but requires careful use; 'RawValue'=8 == 'RawArray'=8 — both Raw variants have the same name length because 'Raw'=3 added to 'Value'=5 and 'Raw'=3 added to 'Array'=5 both yield 8; NEW in extra173: first standalone RawValue.__name__.__len__ invariant in mpsharedctypes173raw namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.sharedctypes.RawValue.__name__.__len__
  args: []
  expected: 8

invariant multiprocessing_extra173.rawarray_name_eq:
  description: "multiprocessing.sharedctypes.RawArray.__name__.__eq__('RawArray') returns True — multiprocessing.sharedctypes.RawArray.__name__=='RawArray' (len=8: 'Raw'=3+'Array'=5=8; same length as RawValue=8); RawArray is the no-lock variant of Array: a ctypes array in shared memory without synchronization; like RawValue, it is faster but requires the caller to handle concurrent access; RawArray and RawValue are defined in the same file (Lib/multiprocessing/sharedctypes.py) as Value and Array; NAME PATTERN: Raw prefix consistently adds 3 chars: RawValue=8=3+5, RawArray=8=3+5; the 'Raw' prefix signals the absence of the synchronization wrapper; NEW in extra173: first standalone RawArray.__name__ invariant in mpsharedctypes173raw namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.sharedctypes.RawArray.__name__.__eq__
  args: ["RawArray"]
  expected: true

invariant multiprocessing_extra173.sharedctypes_module_name_len:
  description: "multiprocessing.sharedctypes.__name__.__len__() == 28 — multiprocessing.sharedctypes.__name__ is 'multiprocessing.sharedctypes' (28 characters: 'multiprocessing'=15+'.'=1+'sharedctypes'=12=28); 'sharedctypes'=12 is itself a compound name: 'shared'=6+'ctypes'=6=12; 'multiprocessing'=15 is the longest component of any standard library module name by character count (compare: 'concurrent.futures'=18 total but 'concurrent'=10 is shorter per component); 'multiprocessing.sharedctypes'=28 > 'concurrent.futures'=18 by 10 chars; multiprocessing.Value.__module__=='multiprocessing.sharedctypes' (same 28-char path; Value and Array live in this module); NEW in extra173: first standalone sharedctypes module name length invariant in mpsharedctypes173mod namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.sharedctypes.__name__.__len__
  args: []
  expected: 28

invariant multiprocessing_extra173.value_module_eq:
  description: "multiprocessing.Value.__module__.__eq__('multiprocessing.sharedctypes') returns True — multiprocessing.Value.__module__=='multiprocessing.sharedctypes' (len=28: 'multiprocessing'=15+'.'=1+'sharedctypes'=12=28); although multiprocessing.Value is accessible at the top-level multiprocessing namespace (via import in Lib/multiprocessing/__init__.py), it is defined in the sharedctypes submodule; __module__ records the definition site, not the import site; the same applies to multiprocessing.Array.__module__=='multiprocessing.sharedctypes' and multiprocessing.sharedctypes.RawValue.__module__=='multiprocessing.sharedctypes'; all four shared ctypes constructors (Value, Array, RawValue, RawArray) share the same __module__; NEW in extra173: first standalone Value.__module__ invariant in mpsharedctypes173va namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__module__.__eq__
  args: ["multiprocessing.sharedctypes"]
  expected: true
