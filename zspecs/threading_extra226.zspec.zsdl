spec: threading_extra226
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers threading __doc__ string contains checks."
    - "threading.__doc__ contains 'Thread' — module docstring is 'Thread module emulating a subset of Java's threading model.'. Verified with Python 3.14.3."
    - "threading.Thread.__doc__ contains 'thread' (lowercase) — docstring: 'A class that represents a thread of control.'. Verified with Python 3.14.3."
    - "threading.Semaphore.__doc__ contains 'semaphore' (lowercase). Verified with Python 3.14.3."
    - "threading.Event.__doc__ contains 'event' (lowercase). Verified with Python 3.14.3."
    - "threading.Condition.__doc__ contains 'condition' (lowercase). Verified with Python 3.14.3."
    - "threading.Barrier.__doc__ contains 'Barrier' (capital B) — docstring: 'Implements a Barrier.'. Verified with Python 3.14.3."
    - "threading.Timer.__doc__ contains 'timer' (lowercase). Verified with Python 3.14.3."
    - "threading.Thread.start.__doc__ contains 'Start' (capital S) — docstring: 'Start the thread's activity.'. Verified with Python 3.14.3."
    - "threading.Thread.join.__doc__ contains 'join' (lowercase). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading __doc__ contains checks (module + sync primitives)
#
# Verified with Python 3.14.3:
#   threading.__doc__ contains 'Thread'
#   threading.Thread.__doc__ contains 'thread' (lowercase)
#   threading.Semaphore.__doc__ contains 'semaphore' (lowercase)
#   threading.Event.__doc__ contains 'event' (lowercase)
#   threading.Condition.__doc__ contains 'condition' (lowercase)
# ---------------------------------------------------------------------------

table threading_extra226.doc_contains_primitives:
  description: "threading __doc__ string contains checks for module and sync primitives; new to extra226"
  kind: python_call_eq
  category: doc_inspection
  id_prefix: threadingextra226docprim

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_contains_thread,
       __doc__.__contains__,
       ["Thread"],
       true,
       "threading.__doc__.__contains__('Thread') == True — module docstring is 'Thread module emulating a subset of Java's threading model.'; contains 'Thread'; new to extra226"]
    - [thread_doc_contains_thread,
       Thread.__doc__.__contains__,
       ["thread"],
       true,
       "threading.Thread.__doc__.__contains__('thread') == True — Thread docstring is 'A class that represents a thread of control.'; contains 'thread' (lowercase); new to extra226"]
    - [semaphore_doc_contains_semaphore,
       Semaphore.__doc__.__contains__,
       ["semaphore"],
       true,
       "threading.Semaphore.__doc__.__contains__('semaphore') == True — Semaphore docstring is 'This class implements semaphore objects.'; contains 'semaphore'; new to extra226"]
    - [event_doc_contains_event,
       Event.__doc__.__contains__,
       ["event"],
       true,
       "threading.Event.__doc__.__contains__('event') == True — Event docstring is 'Class implementing event objects.'; contains 'event'; new to extra226"]
    - [condition_doc_contains_condition,
       Condition.__doc__.__contains__,
       ["condition"],
       true,
       "threading.Condition.__doc__.__contains__('condition') == True — Condition docstring is 'Class that implements a condition variable.'; contains 'condition'; new to extra226"]

# ---------------------------------------------------------------------------
# Table 2: threading __doc__ contains checks (Barrier, Timer, Thread methods)
#
# Verified with Python 3.14.3:
#   threading.Barrier.__doc__ contains 'Barrier' (capital B — docstring: 'Implements a Barrier.')
#   threading.Timer.__doc__ contains 'timer' (lowercase)
#   threading.Thread.start.__doc__ contains 'Start' (capital S — docstring: 'Start the thread's activity.')
#   threading.Thread.join.__doc__ contains 'join' (lowercase)
# ---------------------------------------------------------------------------

table threading_extra226.doc_contains_methods:
  description: "threading __doc__ string contains checks for Barrier, Timer, and Thread methods; new to extra226"
  kind: python_call_eq
  category: doc_inspection
  id_prefix: threadingextra226docmeth

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_doc_contains_barrier,
       Barrier.__doc__.__contains__,
       ["Barrier"],
       true,
       "threading.Barrier.__doc__.__contains__('Barrier') == True — Barrier docstring is 'Implements a Barrier.'; contains 'Barrier' (capital B); new to extra226"]
    - [timer_doc_contains_timer,
       Timer.__doc__.__contains__,
       ["timer"],
       true,
       "threading.Timer.__doc__.__contains__('timer') == True — Timer docstring mentions 'stop the timer's action'; contains 'timer'; new to extra226"]
    - [thread_start_doc_contains_start,
       Thread.start.__doc__.__contains__,
       ["Start"],
       true,
       "threading.Thread.start.__doc__.__contains__('Start') == True — Thread.start docstring is 'Start the thread's activity.'; contains 'Start' (capital S); new to extra226"]
    - [thread_join_doc_contains_join,
       Thread.join.__doc__.__contains__,
       ["join"],
       true,
       "threading.Thread.join.__doc__.__contains__('join') == True — Thread.join docstring is 'Wait until the thread terminates.'; contains 'join'; new to extra226"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra226
# ---------------------------------------------------------------------------

invariant threading_extra226.module_doc_contains_thread:
  description: "threading.__doc__.__contains__('Thread') == True — module docstring contains 'Thread'; new to extra226"
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["Thread"]
  expected: true

invariant threading_extra226.thread_doc_contains_thread:
  description: "threading.Thread.__doc__.__contains__('thread') == True — Thread docstring contains 'thread' (lowercase); new to extra226"
  kind: python_call_eq
  function: Thread.__doc__.__contains__
  args: ["thread"]
  expected: true

invariant threading_extra226.semaphore_doc_contains_semaphore:
  description: "threading.Semaphore.__doc__.__contains__('semaphore') == True — Semaphore docstring contains 'semaphore'; new to extra226"
  kind: python_call_eq
  function: Semaphore.__doc__.__contains__
  args: ["semaphore"]
  expected: true

invariant threading_extra226.event_doc_contains_event:
  description: "threading.Event.__doc__.__contains__('event') == True — Event docstring contains 'event'; new to extra226"
  kind: python_call_eq
  function: Event.__doc__.__contains__
  args: ["event"]
  expected: true

invariant threading_extra226.condition_doc_contains_condition:
  description: "threading.Condition.__doc__.__contains__('condition') == True — Condition docstring contains 'condition'; new to extra226"
  kind: python_call_eq
  function: Condition.__doc__.__contains__
  args: ["condition"]
  expected: true

invariant threading_extra226.barrier_doc_contains_barrier:
  description: "threading.Barrier.__doc__.__contains__('Barrier') == True — Barrier docstring contains 'Barrier' (capital B); new to extra226"
  kind: python_call_eq
  function: Barrier.__doc__.__contains__
  args: ["Barrier"]
  expected: true

invariant threading_extra226.timer_doc_contains_timer:
  description: "threading.Timer.__doc__.__contains__('timer') == True — Timer docstring contains 'timer'; new to extra226"
  kind: python_call_eq
  function: Timer.__doc__.__contains__
  args: ["timer"]
  expected: true

invariant threading_extra226.thread_start_doc_contains_start:
  description: "threading.Thread.start.__doc__.__contains__('Start') == True — Thread.start docstring contains 'Start' (capital S); new to extra226"
  kind: python_call_eq
  function: Thread.start.__doc__.__contains__
  args: ["Start"]
  expected: true

invariant threading_extra226.thread_join_doc_contains_join:
  description: "threading.Thread.join.__doc__.__contains__('join') == True — Thread.join docstring contains 'join'; new to extra226"
  kind: python_call_eq
  function: Thread.join.__doc__.__contains__
  args: ["join"]
  expected: true
