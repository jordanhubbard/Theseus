spec: hashlib_extra75
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra74.zspec.zsdl — covers md5/sha256/sha1/sha512/__class__/__name__=='builtin_function_or_method' / shake_128/sha3_256/scrypt/__class__/__name__=='builtin_function_or_method' / blake2b/blake2s/__class__/__name__=='type' / file_digest/__code__.co_name=='file_digest' (table + invariants)."
    - "hashlib_extra73.zspec.zsdl — covers algorithms_guaranteed/__class__/__name__=='set' / algorithms_available/__class__.__name__=='set' / algorithms_guaranteed/__contains__ md5/sha256/sha512 / algorithms_available/__contains__ md5/sha256 / new/__class__/__name__=='function' / new/__module__=='hashlib' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra74; it does NOT duplicate invariants present in those files."
    - "Wave 239 theme: hashlib HASH type class identity — docstring class and content for hash constructor functions."
    - "hashlib.md5.__doc__.__class__.__name__ == 'str' — md5 has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__class__.__name__ == 'str' — sha256 has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__doc__.__class__.__name__ == 'str' — sha1 has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__doc__.__class__.__name__ == 'str' — sha512 has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__doc__.__contains__('md5') == True — the md5 docstring mentions 'md5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__contains__('sha256') == True — the sha256 docstring mentions 'sha256'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__doc__.__contains__('sha1') == True — the sha1 docstring mentions 'sha1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__doc__.__contains__('sha512') == True — the sha512 docstring mentions 'sha512'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__doc__.__class__.__name__ == 'str' — new() has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__doc__.__class__.__name__ == 'str' — pbkdf2_hmac has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__doc__.__class__.__name__ == 'str' — file_digest has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__doc__.__contains__('file') == True — the file_digest docstring mentions 'file'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.md5 / sha256 / sha1 / sha512 __doc__.__class__.__name__
#
# Wave 239 theme: hashlib hash function docstring class identity.
#
# hashlib.md5, sha256, sha1, and sha512 are C builtin constructors. Each has
# a str docstring. No prior hashlib spec checks __doc__.__class__.__name__ for
# these four hash functions. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra75.core_hash_doc_class:
  description: "hashlib.md5/__doc__/__class__/__name__.__eq__('str')==True / sha256/__doc__/__class__/__name__.__eq__('str')==True / sha1/__doc__/__class__/__name__.__eq__('str')==True / sha512/__doc__/__class__/__name__.__eq__('str')==True — md5/sha256/sha1/sha512 are C builtin constructors each with a str docstring; no prior hashlib spec checks __doc__.__class__.__name__ for these four hash functions; first docstring class identity anchor for md5/sha256/sha1/sha512"
  kind: python_call_eq
  category: docstrings
  id_prefix: hashlibmore75

  columns: [id, function, args, expected]
  rows:
    - [md5_doc_class_str,    md5.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [sha256_doc_class_str, sha256.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sha1_doc_class_str,   sha1.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [sha512_doc_class_str, sha512.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# hashlib.md5 / sha256 / sha1 / sha512 __doc__.__contains__
#
# Wave 239 theme: hashlib hash function docstring content.
#
# Each of hashlib.md5, sha256, sha1, sha512 has a docstring that mentions
# its own algorithm name. No prior hashlib spec checks __doc__.__contains__
# for any of these hash functions.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra75.core_hash_doc_contains:
  description: "hashlib.md5/__doc__.__contains__('md5')==True / sha256/__doc__.__contains__('sha256')==True / sha1/__doc__.__contains__('sha1')==True / sha512/__doc__.__contains__('sha512')==True — each hash constructor docstring mentions its algorithm name; no prior hashlib spec checks __doc__.__contains__ for md5/sha256/sha1/sha512; first docstring content anchor for core hash functions"
  kind: python_call_eq
  category: docstrings
  id_prefix: hashlibmore75

  columns: [id, function, args, expected]
  rows:
    - [md5_doc_contains_md5,       md5.__doc__.__contains__,    ["md5"],    true]
    - [sha256_doc_contains_sha256, sha256.__doc__.__contains__,  ["sha256"], true]
    - [sha1_doc_contains_sha1,     sha1.__doc__.__contains__,    ["sha1"],   true]
    - [sha512_doc_contains_sha512, sha512.__doc__.__contains__,  ["sha512"], true]

# ---------------------------------------------------------------------------
# hashlib.new / pbkdf2_hmac __doc__.__class__.__name__
#
# Wave 239 theme: hashlib utility function docstring class identity.
#
# hashlib.new is a Python function and hashlib.pbkdf2_hmac is a C builtin.
# Both have str docstrings. No prior hashlib spec checks __doc__.__class__.__name__
# for new or pbkdf2_hmac. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra75.utility_func_doc_class:
  description: "hashlib.new/__doc__/__class__/__name__.__eq__('str')==True / pbkdf2_hmac/__doc__/__class__/__name__.__eq__('str')==True — new is a Python function and pbkdf2_hmac is a C builtin, both with str docstrings; no prior hashlib spec checks __doc__.__class__.__name__ for new or pbkdf2_hmac; first docstring class anchor for new and pbkdf2_hmac"
  kind: python_call_eq
  category: docstrings
  id_prefix: hashlibmore75

  columns: [id, function, args, expected]
  rows:
    - [new_doc_class_str,        new.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [pbkdf2_hmac_doc_class_str, pbkdf2_hmac.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# hashlib.file_digest __doc__.__class__.__name__ and __contains__
#
# Wave 239 theme: hashlib.file_digest docstring class and content.
#
# hashlib.file_digest is a Python function in Lib/hashlib.py with a str
# docstring that mentions 'file'. No prior hashlib spec checks
# file_digest.__doc__.__class__.__name__ or file_digest.__doc__.__contains__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra75.file_digest_doc:
  description: "hashlib.file_digest/__doc__/__class__/__name__.__eq__('str')==True / file_digest/__doc__.__contains__('file')==True — file_digest is a Python function with a str docstring that mentions 'file'; no prior hashlib spec checks file_digest.__doc__.__class__.__name__ or file_digest.__doc__.__contains__; first docstring class and content anchor for file_digest"
  kind: python_call_eq
  category: docstrings
  id_prefix: hashlibmore75

  columns: [id, function, args, expected]
  rows:
    - [file_digest_doc_class_str,    file_digest.__doc__.__class__.__name__.__eq__, ["str"],  true]
    - [file_digest_doc_contains_file, file_digest.__doc__.__contains__,              ["file"], true]

# ---------------------------------------------------------------------------
# hashlib.md5.__doc__.__class__.__name__.__eq__('str') — standalone
#
# hashlib.md5 has a str docstring. No prior hashlib spec checks
# md5.__doc__.__class__.__name__. First docstring class standalone for md5.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra75.md5_doc_class_str:
  description: "hashlib.md5.__doc__.__class__.__name__.__eq__('str') == True — md5 has a str docstring; no prior hashlib spec checks md5.__doc__.__class__.__name__; first docstring class standalone for md5"
  category: docstrings
  kind: python_call_eq
  function: md5.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__contains__('sha256') — standalone
#
# hashlib.sha256 has a docstring that contains the algorithm name 'sha256'.
# No prior hashlib spec checks sha256.__doc__.__contains__.
# First docstring content standalone for sha256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra75.sha256_doc_contains_sha256:
  description: "hashlib.sha256.__doc__.__contains__('sha256') == True — sha256 docstring mentions the algorithm name; no prior hashlib spec checks sha256.__doc__.__contains__; first docstring content standalone for sha256"
  category: docstrings
  kind: python_call_eq
  function: sha256.__doc__.__contains__
  args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__doc__.__class__.__name__.__eq__('str') — standalone
#
# hashlib.new is a Python function with a str docstring. No prior hashlib spec
# checks new.__doc__.__class__.__name__. First docstring class standalone for
# new. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra75.new_doc_class_str:
  description: "hashlib.new.__doc__.__class__.__name__.__eq__('str') == True — new() is a Python function with a str docstring; no prior hashlib spec checks new.__doc__.__class__.__name__; first docstring class standalone for new"
  category: docstrings
  kind: python_call_eq
  function: new.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__('str') — standalone
#
# hashlib.pbkdf2_hmac has a str docstring. No prior hashlib spec checks
# pbkdf2_hmac.__doc__.__class__.__name__. First docstring class standalone
# for pbkdf2_hmac. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra75.pbkdf2_hmac_doc_class_str:
  description: "hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__('str') == True — pbkdf2_hmac has a str docstring; no prior hashlib spec checks pbkdf2_hmac.__doc__.__class__.__name__; first docstring class standalone for pbkdf2_hmac"
  category: docstrings
  kind: python_call_eq
  function: pbkdf2_hmac.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__doc__.__contains__('file') — standalone
#
# hashlib.file_digest has a docstring that contains 'file'. No prior hashlib
# spec checks file_digest.__doc__.__contains__. First docstring content
# standalone for file_digest. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra75.file_digest_doc_contains_file:
  description: "hashlib.file_digest.__doc__.__contains__('file') == True — file_digest docstring mentions 'file'; no prior hashlib spec checks file_digest.__doc__.__contains__; first docstring content standalone for file_digest"
  category: docstrings
  kind: python_call_eq
  function: file_digest.__doc__.__contains__
  args: ["file"]
  expected: true
