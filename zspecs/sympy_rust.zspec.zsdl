spec: sympy_rust
version: ">=3.9"
backend: rust_module(sympy_rust)

docs: https://docs.sympy.org/

provenance:
  derived_from:
    - "https://docs.sympy.org/ — SymPy library documentation"
  not_derived_from:
    - "sympy source: sympy/core/*.py"
  notes:
    - "SymPy is a Python library for symbolic mathematics."
    - "sympy.isprime(n) -> bool — True if n is a prime number."
    - "sympy.factorint(n) -> dict — prime factorization as {prime: exponent}."
    - "sympy.gcd(a, b) -> int — greatest common divisor."
    - "sympy.lcm(a, b) -> int — least common multiple."
    - "isprime(2)==True, isprime(3)==True, isprime(4)==False, isprime(17)==True."
    - "factorint(12) == {2: 2, 3: 1} — 12 = 2^2 * 3^1."
    - "factorint(100) == {2: 2, 5: 2} — 100 = 2^2 * 5^2."
    - "gcd(12, 18) == 6, gcd(7, 13) == 1."
    - "lcm(4, 6) == 12, lcm(3, 5) == 15."
    - "All test vectors verified against sympy 1.13.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# isprime — primality test
table sympy_rust.number.isprime:
  kind: python_call_eq
  category: isprime
  id_prefix: sy_prime
  function: isprime

  columns: [id, args, expected]
  rows:
    - [two,     [2],  true]
    - [three,   [3],  true]
    - [four,    [4],  false]
    - [seven,   [7],  true]
    - [nine,    [9],  false]
    - [seventeen, [17], true]
    - [one,     [1],  false]

# factorint — prime factorization
table sympy_rust.number.factorint:
  kind: python_call_eq
  category: factorint
  id_prefix: sy_fi
  function: factorint

  columns: [id, args, expected]
  rows:
    - [twelve,   [12],  {2: 2, 3: 1}]
    - [hundred,  [100], {2: 2, 5: 2}]
    - [prime7,   [7],   {7: 1}]
    - [eight,    [8],   {2: 3}]

# gcd and lcm
table sympy_rust.number.gcd:
  kind: python_call_eq
  category: gcd
  id_prefix: sy_gcd
  function: gcd

  columns: [id, args, expected]
  rows:
    - [twelve_eighteen, [12, 18], 6]
    - [coprime,         [7, 13],  1]
    - [same,            [5, 5],   5]

invariant sympy_rust.number.lcm_four_six:
  description: "lcm(4, 6) == 12"
  category: lcm
  kind: python_call_eq
  function: lcm
  args: [4, 6]
  expected: 12

invariant sympy_rust.number.lcm_three_five:
  description: "lcm(3, 5) == 15"
  category: lcm
  kind: python_call_eq
  function: lcm
  args: [3, 5]
  expected: 15

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:01:46Z
  iterations: 2
  pass_count: 16
  fail_count: 0
  total_invariants: 16
  notes: Synthesis succeeded in 2 iteration(s). 16 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
