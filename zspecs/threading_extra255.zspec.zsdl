spec: threading_extra255
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Barrier class identity, Barrier method and property identity, and threading.BrokenBarrierError exception identity behavioral contracts."
    - "threading.Barrier.__name__ == 'Barrier' — pure Python class; __name__ is 'Barrier'. Verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading' — defined in the threading module; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier directly inherits from object; first base __name__ is 'object'. Verified with Python 3.14.3."
    - "threading.Barrier.wait.__name__ == 'wait' — instance method on Barrier; __name__ is 'wait'. Verified with Python 3.14.3."
    - "threading.Barrier.wait.__qualname__ == 'Barrier.wait' — qualname reflects definition on the Barrier class. Verified with Python 3.14.3."
    - "threading.Barrier.reset.__name__ == 'reset' — instance method on Barrier; __name__ is 'reset'. Verified with Python 3.14.3."
    - "threading.Barrier.abort.__name__ == 'abort' — instance method on Barrier; __name__ is 'abort'. Verified with Python 3.14.3."
    - "threading.Barrier.parties.__class__.__name__ == 'property' — Barrier.parties is a Python property descriptor. Verified with Python 3.14.3."
    - "threading.Barrier.n_waiting.__class__.__name__ == 'property' — Barrier.n_waiting is a Python property descriptor. Verified with Python 3.14.3."
    - "threading.Barrier.broken.__class__.__name__ == 'property' — Barrier.broken is a Python property descriptor. Verified with Python 3.14.3."
    - "threading.BrokenBarrierError.__name__ == 'BrokenBarrierError' — exception class; __name__ is 'BrokenBarrierError'. Verified with Python 3.14.3."
    - "threading.BrokenBarrierError.__module__ == 'threading' — defined in the threading module; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.BrokenBarrierError.__bases__[0].__name__ == 'RuntimeError' — BrokenBarrierError inherits from RuntimeError. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Barrier class identity
#
# threading.Barrier.__name__ == 'Barrier'
# threading.Barrier.__module__ == 'threading'
# threading.Barrier.__bases__[0].__name__ == 'object'
#
# Barrier is a pure Python synchronization primitive that directly inherits
# from object. New to extra255.
# ---------------------------------------------------------------------------

table threading_extra255.barrier_class_identity:
  description: "threading.Barrier __name__, __module__, __bases__[0].__name__ identity contracts; new to extra255"
  kind: python_call_eq
  category: identity
  id_prefix: barrier255

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_name_eq,
       Barrier.__name__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — pure Python synchronization class; __name__ is 'Barrier'; new to extra255"]
    - [barrier_module_eq,
       Barrier.__module__.__eq__,
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — defined in the threading module; __module__ is 'threading'; new to extra255"]
    - ["barrier_base0_name_eq",
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier directly inherits from object; first base __name__ is 'object'; new to extra255"]
    - [barrier_name_len_7,
       Barrier.__name__.__len__,
       [],
       7,
       "threading.Barrier.__name__.__len__() == 7 — 'Barrier' has 7 characters; new to extra255"]
    - [barrier_module_len_9,
       Barrier.__module__.__len__,
       [],
       9,
       "threading.Barrier.__module__.__len__() == 9 — 'threading' has 9 characters; new to extra255"]

# ---------------------------------------------------------------------------
# Table 2: threading.Barrier method identity
#
# threading.Barrier.wait.__name__ == 'wait'
# threading.Barrier.wait.__qualname__ == 'Barrier.wait'
# threading.Barrier.reset.__name__ == 'reset'
# threading.Barrier.abort.__name__ == 'abort'
#
# wait, reset, and abort are Python functions defined on the Barrier class.
# New to extra255.
# ---------------------------------------------------------------------------

table threading_extra255.barrier_methods_identity:
  description: "threading.Barrier.wait, reset, abort __name__ and __qualname__ identity contracts; new to extra255"
  kind: python_call_eq
  category: identity
  id_prefix: barriermeth255

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_wait_name_eq,
       Barrier.wait.__name__.__eq__,
       ["wait"],
       true,
       "threading.Barrier.wait.__name__.__eq__('wait') == True — instance method on Barrier; __name__ is 'wait'; new to extra255"]
    - [barrier_wait_qualname_eq,
       Barrier.wait.__qualname__.__eq__,
       ["Barrier.wait"],
       true,
       "threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True — qualname reflects definition on the Barrier class; new to extra255"]
    - [barrier_reset_name_eq,
       Barrier.reset.__name__.__eq__,
       ["reset"],
       true,
       "threading.Barrier.reset.__name__.__eq__('reset') == True — instance method on Barrier; __name__ is 'reset'; new to extra255"]
    - [barrier_abort_name_eq,
       Barrier.abort.__name__.__eq__,
       ["abort"],
       true,
       "threading.Barrier.abort.__name__.__eq__('abort') == True — instance method on Barrier; __name__ is 'abort'; new to extra255"]
    - [barrier_wait_name_len_4,
       Barrier.wait.__name__.__len__,
       [],
       4,
       "threading.Barrier.wait.__name__.__len__() == 4 — 'wait' has 4 characters; new to extra255"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier property descriptor identity
#
# threading.Barrier.parties.__class__.__name__ == 'property'
# threading.Barrier.n_waiting.__class__.__name__ == 'property'
# threading.Barrier.broken.__class__.__name__ == 'property'
#
# parties, n_waiting, and broken are Python property descriptors that
# expose the internal state of a Barrier instance. New to extra255.
# ---------------------------------------------------------------------------

table threading_extra255.barrier_properties_identity:
  description: "threading.Barrier.parties, n_waiting, broken property descriptor __class__.__name__ identity contracts; new to extra255"
  kind: python_call_eq
  category: identity
  id_prefix: barrierprop255

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_parties_class_eq,
       Barrier.parties.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Barrier.parties.__class__.__name__.__eq__('property') == True — Barrier.parties is a Python property descriptor; new to extra255"]
    - [barrier_n_waiting_class_eq,
       Barrier.n_waiting.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Barrier.n_waiting.__class__.__name__.__eq__('property') == True — Barrier.n_waiting is a Python property descriptor; new to extra255"]
    - [barrier_broken_class_eq,
       Barrier.broken.__class__.__name__.__eq__,
       ["property"],
       true,
       "threading.Barrier.broken.__class__.__name__.__eq__('property') == True — Barrier.broken is a Python property descriptor; new to extra255"]
    - [barrier_reset_name_len_5,
       Barrier.reset.__name__.__len__,
       [],
       5,
       "threading.Barrier.reset.__name__.__len__() == 5 — 'reset' has 5 characters; new to extra255"]
    - [barrier_abort_name_len_5,
       Barrier.abort.__name__.__len__,
       [],
       5,
       "threading.Barrier.abort.__name__.__len__() == 5 — 'abort' has 5 characters; new to extra255"]

# ---------------------------------------------------------------------------
# Table 4: threading.BrokenBarrierError identity
#
# threading.BrokenBarrierError.__name__ == 'BrokenBarrierError'
# threading.BrokenBarrierError.__module__ == 'threading'
# threading.BrokenBarrierError.__bases__[0].__name__ == 'RuntimeError'
#
# BrokenBarrierError is raised when Barrier.abort() is called or the barrier
# is broken. It inherits from RuntimeError. New to extra255.
# ---------------------------------------------------------------------------

table threading_extra255.broken_barrier_error_identity:
  description: "threading.BrokenBarrierError __name__, __module__, __bases__[0].__name__ identity contracts; new to extra255"
  kind: python_call_eq
  category: identity
  id_prefix: brokbarr255

  columns: [id, function, args, expected, description]
  rows:
    - [broken_barrier_error_name_eq,
       BrokenBarrierError.__name__.__eq__,
       ["BrokenBarrierError"],
       true,
       "threading.BrokenBarrierError.__name__.__eq__('BrokenBarrierError') == True — exception raised when barrier is broken; __name__ is 'BrokenBarrierError'; new to extra255"]
    - [broken_barrier_error_module_eq,
       BrokenBarrierError.__module__.__eq__,
       ["threading"],
       true,
       "threading.BrokenBarrierError.__module__.__eq__('threading') == True — defined in the threading module; __module__ is 'threading'; new to extra255"]
    - ["broken_barrier_error_base0_name_eq",
       "BrokenBarrierError.__bases__[0].__name__.__eq__",
       ["RuntimeError"],
       true,
       "threading.BrokenBarrierError.__bases__[0].__name__.__eq__('RuntimeError') == True — BrokenBarrierError inherits from RuntimeError; first base __name__ is 'RuntimeError'; new to extra255"]
    - [broken_barrier_error_name_len_19,
       BrokenBarrierError.__name__.__len__,
       [],
       19,
       "threading.BrokenBarrierError.__name__.__len__() == 19 — 'BrokenBarrierError' has 19 characters; new to extra255"]
    - [broken_barrier_error_module_len_9,
       BrokenBarrierError.__module__.__len__,
       [],
       9,
       "threading.BrokenBarrierError.__module__.__len__() == 9 — 'threading' has 9 characters; new to extra255"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra255
# ---------------------------------------------------------------------------

invariant threading_extra255.Barrier.name_eq:
  description: "threading.Barrier.__name__ == 'Barrier' — pure Python synchronization class; new to extra255"
  category: identity
  kind: python_call_eq
  function: Barrier.__name__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra255.Barrier.module_eq:
  description: "threading.Barrier.__module__ == 'threading' — defined in the threading module; new to extra255"
  category: identity
  kind: python_call_eq
  function: Barrier.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra255.Barrier.base0_is_object:
  description: "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier directly inherits from object; new to extra255"
  category: identity
  kind: python_call_eq
  function: "Barrier.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra255.Barrier.wait.name_eq:
  description: "threading.Barrier.wait.__name__ == 'wait' — instance method on Barrier; new to extra255"
  category: identity
  kind: python_call_eq
  function: Barrier.wait.__name__.__eq__
  args: ["wait"]
  expected: true

invariant threading_extra255.Barrier.wait.qualname_eq:
  description: "threading.Barrier.wait.__qualname__ == 'Barrier.wait' — qualname reflects class membership; new to extra255"
  category: identity
  kind: python_call_eq
  function: Barrier.wait.__qualname__.__eq__
  args: ["Barrier.wait"]
  expected: true

invariant threading_extra255.Barrier.reset.name_eq:
  description: "threading.Barrier.reset.__name__ == 'reset' — instance method on Barrier; new to extra255"
  category: identity
  kind: python_call_eq
  function: Barrier.reset.__name__.__eq__
  args: ["reset"]
  expected: true

invariant threading_extra255.Barrier.abort.name_eq:
  description: "threading.Barrier.abort.__name__ == 'abort' — instance method on Barrier; new to extra255"
  category: identity
  kind: python_call_eq
  function: Barrier.abort.__name__.__eq__
  args: ["abort"]
  expected: true

invariant threading_extra255.Barrier.parties.class_is_property:
  description: "threading.Barrier.parties.__class__.__name__ == 'property' — Barrier.parties is a Python property descriptor; new to extra255"
  category: identity
  kind: python_call_eq
  function: Barrier.parties.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra255.Barrier.n_waiting.class_is_property:
  description: "threading.Barrier.n_waiting.__class__.__name__ == 'property' — Barrier.n_waiting is a Python property descriptor; new to extra255"
  category: identity
  kind: python_call_eq
  function: Barrier.n_waiting.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra255.Barrier.broken.class_is_property:
  description: "threading.Barrier.broken.__class__.__name__ == 'property' — Barrier.broken is a Python property descriptor; new to extra255"
  category: identity
  kind: python_call_eq
  function: Barrier.broken.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra255.BrokenBarrierError.name_eq:
  description: "threading.BrokenBarrierError.__name__ == 'BrokenBarrierError' — exception raised when barrier is broken; new to extra255"
  category: identity
  kind: python_call_eq
  function: BrokenBarrierError.__name__.__eq__
  args: ["BrokenBarrierError"]
  expected: true

invariant threading_extra255.BrokenBarrierError.module_eq:
  description: "threading.BrokenBarrierError.__module__ == 'threading' — defined in the threading module; new to extra255"
  category: identity
  kind: python_call_eq
  function: BrokenBarrierError.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra255.BrokenBarrierError.base0_is_RuntimeError:
  description: "threading.BrokenBarrierError.__bases__[0].__name__ == 'RuntimeError' — BrokenBarrierError inherits from RuntimeError; new to extra255"
  category: identity
  kind: python_call_eq
  function: "BrokenBarrierError.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true
