spec: concurrent_futures_extra120
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: wave 261 theme — concurrent.futures Executor and ThreadPoolExecutor/ProcessPoolExecutor class identity attributes not previously covered. Prior specs covered: extra100 covered Executor/__qualname__=='Executor' (len=8), ThreadPoolExecutor/__qualname__='ThreadPoolExecutor' (len=18), ProcessPoolExecutor/__qualname__='ProcessPoolExecutor' (len=19); extra101 covered ThreadPoolExecutor/__module__=='concurrent.futures.thread', Future/__module__=='concurrent.futures._base'. NOT previously covered: Executor/__module__=='concurrent.futures._base' (len=24); Executor/__mro__.__len__()==2; Executor/__bases__[0].__name__=='object'; ProcessPoolExecutor/__module__=='concurrent.futures.process' (len=26); ThreadPoolExecutor/__mro__.__len__()==3; ProcessPoolExecutor/__mro__.__len__()==3; ThreadPoolExecutor/__bases__[0].__name__=='Executor'; ProcessPoolExecutor/__bases__[0].__name__=='Executor'; FIRST_COMPLETED/__len__()==15; FIRST_EXCEPTION/__len__()==15; ALL_COMPLETED/__len__()==13. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Executor.__module__ == 'concurrent.futures._base' (len=24). Executor is defined in the private implementation module _base.py. Prior specs covered ThreadPoolExecutor.__module__=='concurrent.futures.thread' and Future.__module__=='concurrent.futures._base' but not Executor.__module__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26, longest submodule name). ProcessPoolExecutor is defined in the process.py submodule; its module name is 'concurrent.futures.process'=26 chars (longer than 'concurrent.futures.thread'=25 and 'concurrent.futures._base'=24). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' (len=15, str). FIRST_EXCEPTION == 'FIRST_EXCEPTION' (len=15, tied). ALL_COMPLETED == 'ALL_COMPLETED' (len=13, shorter by 2). These string constants are used as the return_when parameter of concurrent.futures.wait(). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3 ([ThreadPoolExecutor, Executor, object]). ProcessPoolExecutor.__mro__.__len__()==3 (tied: same pattern — both inherit directly from Executor). Executor.__mro__.__len__()==2 ([Executor, object]). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures Executor class identity — extra120
#
# Wave 261 theme: Executor class identity — __module__, __mro__, __bases__.
#
# Executor.__module__         == 'concurrent.futures._base'  (len=24)
# Executor.__mro__.__len__()  == 2   ([Executor, object])
# Executor.__bases__[0].__name__ == 'object'
# ThreadPoolExecutor.__mro__.__len__() == 3  ([TPE, Executor, object])
# ProcessPoolExecutor.__mro__.__len__() == 3  (tied)
# ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'
# ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'
# ---------------------------------------------------------------------------

table concurrent_futures_extra120.executor_class_identity:
  description: "concurrent.futures Executor class identity checks in cfexec120 namespace — wave 261 theme: Executor __module__, __mro__ length, and __bases__ element name; concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base')==True (len=24: Executor is defined in the private _base module alongside Future, CancelledError, TimeoutError; prior specs covered ThreadPoolExecutor.__module__=='concurrent.futures.thread' in extra101 and Future.__module__=='concurrent.futures._base' in extra101; Executor.__module__ is a new first coverage); concurrent.futures.Executor.__module__.__len__()==24 (24: same as Future.__module__.__len__()==24 since both are defined in 'concurrent.futures._base'); concurrent.futures.Executor.__mro__.__len__()==2 ([Executor, object]: Executor inherits directly from object with no intermediate base; same MRO depth as concurrent.futures.Future.__mro__.__len__()==2 covered in prior specs); concurrent.futures.Executor.__bases__[0].__name__.__eq__('object')==True (Executor's only base is object — it is the root class of the Executor hierarchy; ThreadPoolExecutor and ProcessPoolExecutor subclass Executor); concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3 ([ThreadPoolExecutor, Executor, object]: 3-element MRO from inheriting Executor which inherits object; 1 more than Executor=2); concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3 (tied with ThreadPoolExecutor=3: same pattern); concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (ThreadPoolExecutor's direct base is Executor); concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (ProcessPoolExecutor's direct base is also Executor: both executor implementations inherit from the same abstract base); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexec120

  columns: [id, function, args, expected, description]
  rows:
    - [exec_mod_eq,   "concurrent.futures.Executor.__module__.__eq__",              ["concurrent.futures._base"], true, "Executor.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [exec_mod_len,  "concurrent.futures.Executor.__module__.__len__",             [],                           24,   "Executor.__module__.__len__() == 24 ('concurrent.futures._base'=24; same as Future.__module__=24); verified with Python 3.14.3"]
    - [exec_mro_len,  "concurrent.futures.Executor.__mro__.__len__",               [],                           2,    "Executor.__mro__.__len__() == 2 ([Executor, object]; same depth as Future=2); verified with Python 3.14.3"]
    - [exec_base0,    "concurrent.futures.Executor.__bases__[0].__name__.__eq__",  ["object"],                   true, "Executor.__bases__[0].__name__ == 'object' (Executor inherits directly from object); verified with Python 3.14.3"]
    - [tpe_mro_len,   "concurrent.futures.ThreadPoolExecutor.__mro__.__len__",     [],                           3,    "ThreadPoolExecutor.__mro__.__len__() == 3 ([TPE, Executor, object]; 1 more than Executor=2); verified with Python 3.14.3"]
    - [ppe_mro_len,   "concurrent.futures.ProcessPoolExecutor.__mro__.__len__",    [],                           3,    "ProcessPoolExecutor.__mro__.__len__() == 3 (tied with ThreadPoolExecutor=3); verified with Python 3.14.3"]
    - [tpe_base0,     "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],        true, "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' (direct base is Executor); verified with Python 3.14.3"]
    - [ppe_base0,     "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],       true, "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' (direct base is Executor; tied with TPE); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures ProcessPoolExecutor __module__ and module length — extra120
#
# Wave 261 theme: ProcessPoolExecutor module length and module name comparison.
#
# ProcessPoolExecutor.__module__         == 'concurrent.futures.process'  (len=26, longest)
# ThreadPoolExecutor.__module__          == 'concurrent.futures.thread'   (len=25)
# Executor.__module__ == Future.__module__ == 'concurrent.futures._base'  (len=24, shortest)
# Module length ordering: _base=24 < thread=25 < process=26
# ---------------------------------------------------------------------------

table concurrent_futures_extra120.executor_module_lengths:
  description: "concurrent.futures executor __module__ length cross-comparison in cfexec120a namespace — wave 261 theme: ProcessPoolExecutor.__module__ and executor module name length ordering; concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (len=26: ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py; its module is 'concurrent.futures.process'=26 chars; prior specs covered Executor._base=24 and thread=25 as submodule __name__ lengths in extra99, but ProcessPoolExecutor.__module__ as a class attribute was not explicitly covered); concurrent.futures.ProcessPoolExecutor.__module__.__len__()==26 (26: longest executor module name; same as concurrent.futures.process.__name__.__len__()==26 covered in extra99; here we access it via the class __module__ attribute rather than the module object's __name__); concurrent.futures.ThreadPoolExecutor.__module__.__len__()==25 ('concurrent.futures.thread'=25: 1 shorter than ProcessPoolExecutor=26; thread=6 chars vs process=7 chars, diff=1); concurrent.futures.Executor.__module__.__len__()==24 ('concurrent.futures._base'=24: 2 shorter than ProcessPoolExecutor=26; '_base'=5 chars including underscore vs 'process'=7 chars, diff=2); module length ordering: _base=24 (shortest) < thread=25 < process=26 (longest); the ordering maps to alphabetical submodule names with 'process' being longest; concurrent.futures.as_completed.__module__.__eq__('concurrent.futures._base')==True (as_completed is also defined in _base.py, same as Executor and Future); concurrent.futures.as_completed.__module__.__len__()==24 (tied with Executor.__module__=24); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexec120a

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_mod_eq,   "concurrent.futures.ProcessPoolExecutor.__module__.__eq__",  ["concurrent.futures.process"], true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26, longest); verified with Python 3.14.3"]
    - [ppe_mod_len,  "concurrent.futures.ProcessPoolExecutor.__module__.__len__", [],                             26,   "ProcessPoolExecutor.__module__.__len__() == 26 ('concurrent.futures.process'=26; longest executor module); verified with Python 3.14.3"]
    - [tpe_mod_len,  "concurrent.futures.ThreadPoolExecutor.__module__.__len__",  [],                             25,   "ThreadPoolExecutor.__module__.__len__() == 25 ('concurrent.futures.thread'=25; 1 shorter than process=26); verified with Python 3.14.3"]
    - [exec_mod_len, "concurrent.futures.Executor.__module__.__len__",            [],                             24,   "Executor.__module__.__len__() == 24 ('concurrent.futures._base'=24; 2 shorter than process=26); verified with Python 3.14.3"]
    - [asc_mod_len,  "concurrent.futures.as_completed.__module__.__len__",        [],                             24,   "as_completed.__module__.__len__() == 24 (tied with Executor._base=24: both defined in _base.py); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED constants — extra120
#
# Wave 261 theme: wait() return_when string constant lengths.
#
# FIRST_COMPLETED.__len__()  == 15
# FIRST_EXCEPTION.__len__()  == 15 (tied)
# ALL_COMPLETED.__len__()    == 13 (shorter by 2)
# FIRST_COMPLETED.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table concurrent_futures_extra120.wait_constants_lengths:
  description: "concurrent.futures wait() return_when string constant length checks in cfconst120 namespace — wave 261 theme: FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED string lengths; concurrent.futures.FIRST_COMPLETED.__len__()==15 ('FIRST_COMPLETED'=15: 'FIRST_'=6+'COMPLETED'=9=15; FIRST_COMPLETED is passed as return_when to concurrent.futures.wait() to return when the first future completes — either by result or by cancellation or by exception; prior specs covered FIRST_COMPLETED.__class__.__name__=='str' and that it is a plain string constant); concurrent.futures.FIRST_COMPLETED.__len__()==15 (new measurement: the string length of 'FIRST_COMPLETED'; compare: 'FIRST_'=6 prefix + 'COMPLETED'=9 suffix = 15); concurrent.futures.FIRST_EXCEPTION.__len__()==15 (tied with FIRST_COMPLETED=15: both begin with 'FIRST_'=6 and end with 9-char words: 'COMPLETED'=9='EXCEPTION'=9=9; 'EXCEPTION'=9: 'EXCEPT'=6+'ION'=3=9; 'COMPLETED'=9: 'COMPLET'=7+'ED'=2=9; both have the same 15-char total); concurrent.futures.ALL_COMPLETED.__len__()==13 (shorter: 'ALL_COMPLETED'=13: 'ALL_'=4+'COMPLETED'=9=13; 2 shorter than FIRST_COMPLETED=15 and FIRST_EXCEPTION=15: 'FIRST_'=6 vs 'ALL_'=4, diff=2); FIRST_COMPLETED.__class__.__name__.__eq__('str')==True (FIRST_COMPLETED is a plain Python str constant, not an enum member; in Python 3.9+ these remain simple strings for backward compatibility); length ordering: ALL_COMPLETED=13 < FIRST_COMPLETED=15 (tied with FIRST_EXCEPTION=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: cfconst120

  columns: [id, function, args, expected, description]
  rows:
    - [fc_len,   "concurrent.futures.FIRST_COMPLETED.__len__",               [], 15,   "FIRST_COMPLETED.__len__() == 15 ('FIRST_COMPLETED'=15: 'FIRST_'=6+'COMPLETED'=9=15); verified with Python 3.14.3"]
    - [fe_len,   "concurrent.futures.FIRST_EXCEPTION.__len__",               [], 15,   "FIRST_EXCEPTION.__len__() == 15 (tied with FIRST_COMPLETED: 'FIRST_'=6+'EXCEPTION'=9=15); verified with Python 3.14.3"]
    - [ac_len,   "concurrent.futures.ALL_COMPLETED.__len__",                 [], 13,   "ALL_COMPLETED.__len__() == 13 ('ALL_COMPLETED'=13: 'ALL_'=4+'COMPLETED'=9=13; 2 shorter than FIRST_*=15); verified with Python 3.14.3"]
    - [fc_cls,   "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__", ["str"], true, "FIRST_COMPLETED.__class__.__name__ == 'str' (plain string constant, not enum); verified with Python 3.14.3"]
    - [fe_cls,   "concurrent.futures.FIRST_EXCEPTION.__class__.__name__.__eq__", ["str"], true, "FIRST_EXCEPTION.__class__.__name__ == 'str' (tied with FIRST_COMPLETED: both plain str); verified with Python 3.14.3"]
    - [ac_cls,   "concurrent.futures.ALL_COMPLETED.__class__.__name__.__eq__", ["str"], true, "ALL_COMPLETED.__class__.__name__ == 'str' (plain str; shorter name at len=13); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra120
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra120.Executor_module_is_cf_base:
  description: "concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base') returns True — Executor.__module__=='concurrent.futures._base' (len=24); Executor is defined in the private implementation module Lib/concurrent/futures/_base.py alongside concurrent.futures.Future, CancelledError, TimeoutError, BrokenExecutor, InvalidStateError, wait, and as_completed; the module name has an underscore prefix '_base' (indicating it is an internal/private module not meant for direct import); prior spec extra101 covered Future.__module__=='concurrent.futures._base' and BrokenExecutor.__module__=='concurrent.futures._base'; Executor.__module__ is a new first coverage; Executor.__module__.__len__()==24 (tied with Future.__module__.__len__()==24 and as_completed.__module__.__len__()==24: all three are defined in 'concurrent.futures._base'=24); Executor.__mro__.__len__()==2 (simple 2-element MRO: [Executor, object]); NEW in extra120: first standalone Executor.__module__ equality invariant in cfexec120 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Executor.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra120.ProcessPoolExecutor_module_len_26:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__len__() == 26 — ProcessPoolExecutor.__module__=='concurrent.futures.process' (26 chars: 'concurrent.futures.'=19+'process'=7=26); 26 is the longest module name among concurrent.futures executor and utility classes: _base=24 < thread=25 < process=26; the length difference between ProcessPoolExecutor (26) and ThreadPoolExecutor (25) is 1 char: 'process'=7 vs 'thread'=6, diff=1; the length difference between ProcessPoolExecutor (26) and Executor (24) is 2 chars: 'process'=7 vs '_base'=5, diff=2 (the underscore in '_base' makes it 5 chars while process=7); concurrent.futures.process.__name__.__len__()==26 was covered in extra99 (submodule __name__ as a module-level attribute); ProcessPoolExecutor.__module__.__len__()==26 (same value accessed via the class attribute); NEW in extra120: first standalone ProcessPoolExecutor.__module__ length invariant in cfexec120a namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__module__.__len__"
  args: []
  expected: 26

invariant concurrent_futures_extra120.ThreadPoolExecutor_bases0_name_Executor:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ThreadPoolExecutor.__bases__[0].__name__=='Executor' (len=8); ThreadPoolExecutor inherits from Executor as its sole direct base class (single inheritance); ThreadPoolExecutor.__mro__==[ThreadPoolExecutor, Executor, object] (length=3); 'Executor'=8 chars: 'Execute'=7+'r'=1=8 (or 'Execut'=6+'or'=2=8); ProcessPoolExecutor.__bases__[0].__name__=='Executor' (tied: both pool executor implementations share the same direct base class Executor); Executor itself inherits from object (Executor.__bases__[0].__name__=='object'); thus the hierarchy is flat: Executor (root) -> ThreadPoolExecutor, ProcessPoolExecutor (two leaves), with no intermediate base classes between Executor and object; ThreadPoolExecutor.__qualname__=='ThreadPoolExecutor' (len=18, covered in extra100); NEW in extra120: first standalone ThreadPoolExecutor.__bases__[0].__name__ equality invariant in cfexec120 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra120.FIRST_COMPLETED_len_15:
  description: "concurrent.futures.FIRST_COMPLETED.__len__() == 15 — 'FIRST_COMPLETED'=15 chars: 'FIRST_'=6+'COMPLETED'=9=15; FIRST_COMPLETED is one of three string constants used as the return_when parameter of concurrent.futures.wait(): wait(fs, timeout=None, return_when=ALL_COMPLETED); return_when=FIRST_COMPLETED causes wait() to return when the first future finishes (by result, exception, or cancellation); FIRST_EXCEPTION is also 15 chars (tied: 'FIRST_'=6+'EXCEPTION'=9=15; 'EXCEPTION' and 'COMPLETED' are both 9 chars making FIRST_* constants always 15 chars); ALL_COMPLETED is 13 chars (2 shorter: 'ALL_'=4 vs 'FIRST_'=6, diff=2); FIRST_COMPLETED.__class__.__name__=='str' (plain Python string, not an enum value); compare: concurrent.futures.Future.__qualname__=='Future'=6 (11 shorter than FIRST_COMPLETED=15); concurrent.futures.Executor.__qualname__=='Executor'=8 (7 shorter than FIRST_COMPLETED=15); NEW in extra120: first standalone FIRST_COMPLETED length invariant in cfconst120 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: constants
  kind: python_call_eq
  function: "concurrent.futures.FIRST_COMPLETED.__len__"
  args: []
  expected: 15

invariant concurrent_futures_extra120.ALL_COMPLETED_len_13:
  description: "concurrent.futures.ALL_COMPLETED.__len__() == 13 — 'ALL_COMPLETED'=13 chars: 'ALL_'=4+'COMPLETED'=9=13; ALL_COMPLETED is the default value for the return_when parameter of concurrent.futures.wait() — wait() by default waits for all futures to complete; 13 is 2 shorter than FIRST_COMPLETED=15 and FIRST_EXCEPTION=15 (both 15 chars: 'FIRST_'=6 prefix vs 'ALL_'=4 prefix, diff=2); 'ALL_'=4 is the shortest prefix among the three constants; 'COMPLETED'=9 is the shared suffix for both ALL_COMPLETED and FIRST_COMPLETED ('EXCEPTION'=9 is the suffix for FIRST_EXCEPTION: all suffixes are 9 chars); ALL_COMPLETED.__class__.__name__=='str' (plain string, tied with FIRST_COMPLETED='str' and FIRST_EXCEPTION='str'); length ordering: ALL_COMPLETED=13 < FIRST_COMPLETED=15 (tied with FIRST_EXCEPTION=15); NEW in extra120: first standalone ALL_COMPLETED length invariant in cfconst120 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: constants
  kind: python_call_eq
  function: "concurrent.futures.ALL_COMPLETED.__len__"
  args: []
  expected: 13
