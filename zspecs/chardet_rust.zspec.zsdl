spec: chardet_rust
version: ">=3.9"
backend: rust_module(chardet_rust)

docs: https://github.com/chardet/chardet

provenance:
  derived_from:
    - "https://github.com/chardet/chardet — chardet encoding detection"
  notes:
    - "chardet detects character encodings."
    - "chardet.detect(b'hello')['encoding'] is non-empty string."
    - "chardet.detect(b'hello')['confidence'] > 0."
    - "chardet.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant chardet_rust.detect_encoding_nonempty:
  description: "chardet.detect(b'hello')['encoding'] is non-empty"
  category: detect
  kind: python_call_eq
  function: chardet_detect_encoding_nonempty
  args: []
  expected: true

invariant chardet_rust.detect_confidence_positive:
  description: "chardet.detect(b'hello')['confidence'] > 0"
  category: detect
  kind: python_call_eq
  function: chardet_detect_confidence_positive
  args: []
  expected: true

invariant chardet_rust.version_nonempty:
  description: "chardet.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: chardet_version_nonempty
  args: []
  expected: true

