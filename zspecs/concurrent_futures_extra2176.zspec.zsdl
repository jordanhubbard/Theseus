spec: concurrent_futures_extra2176
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Theme: iterator/sequence protocol dict-presence — checks for __iter__, __next__, __aiter__, __anext__, __await__, __length_hint__, __reversed__, __missing__ in class __dict__."
    - "concurrent.futures.Future does not define any iterator/sequence protocol methods in its own __dict__; it is a synchronous future, not awaitable."
    - "concurrent.futures.Executor does not define any iterator/sequence protocol methods in its own __dict__."
    - "concurrent.futures.ThreadPoolExecutor does not define any iterator/sequence protocol methods in its own __dict__."
    - "concurrent.futures.ProcessPoolExecutor does not define any iterator/sequence protocol methods in its own __dict__."
    - "These executor and future classes manage thread/process pools and pending results but do not implement any iterator or awaitable protocol directly."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

