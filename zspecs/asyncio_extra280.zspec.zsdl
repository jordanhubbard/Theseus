spec: asyncio_extra280
version: ">=3.4"
backend: python_module(asyncio.exceptions)

docs: https://docs.python.org/3/library/asyncio-exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-exceptions.html — Python asyncio.exceptions module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py"
    - "asyncio_extra279.zspec.zsdl — covers asyncio.Transport, ReadTransport, BaseTransport class identity and MRO"
  notes:
    - "This spec covers: asyncio.exceptions module identity; CancelledError, InvalidStateError, SendfileNotAvailableError class identity. NEW in extra280: asyncio.exceptions.__name__=='asyncio.exceptions' (len=18); asyncio.exceptions.__spec__.name=='asyncio.exceptions'; asyncio.exceptions.CancelledError.__module__=='asyncio.exceptions'; asyncio.exceptions.CancelledError.__name__=='CancelledError'; asyncio.exceptions.CancelledError.__bases__[0].__name__=='BaseException'; asyncio.exceptions.CancelledError.__mro__.__len__()==3; asyncio.exceptions.InvalidStateError.__module__=='asyncio.exceptions'; asyncio.exceptions.InvalidStateError.__name__=='InvalidStateError'; asyncio.exceptions.InvalidStateError.__bases__[0].__name__=='Exception'; asyncio.exceptions.InvalidStateError.__mro__.__len__()==4; asyncio.exceptions.SendfileNotAvailableError.__module__=='asyncio.exceptions'; asyncio.exceptions.SendfileNotAvailableError.__name__=='SendfileNotAvailableError'; asyncio.exceptions.SendfileNotAvailableError.__bases__[0].__name__=='RuntimeError'; asyncio.exceptions.SendfileNotAvailableError.__mro__.__len__()==5. Note: asyncio.TimeoutError is a re-export of the builtin TimeoutError; its __module__ is 'builtins', not 'asyncio.exceptions'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.exceptions.CancelledError.__mro__.__len__() == 3 — MRO is [CancelledError, BaseException, object]. CancelledError inherits directly from BaseException (not from Exception); this makes its MRO the shortest among the three asyncio-defined exception classes in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.exceptions.SendfileNotAvailableError.__mro__.__len__() == 5 — MRO is [SendfileNotAvailableError, RuntimeError, Exception, BaseException, object]. SendfileNotAvailableError has the deepest MRO in this spec; it indicates the OS does not support the sendfile() syscall. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.TimeoutError is the builtin TimeoutError class; asyncio.exceptions.TimeoutError.__module__ == 'builtins'. The name 'TimeoutError' is re-exported in asyncio.exceptions from the builtins, not defined there. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.exceptions module identity — extra280
#
# asyncio.exceptions.__name__             == 'asyncio.exceptions'
# asyncio.exceptions.__spec__.name        == 'asyncio.exceptions'
# asyncio.exceptions.__name__.__len__()   == 18
# ---------------------------------------------------------------------------

table asyncio_extra280.asyncio_exceptions_module_identity:
  description: "asyncio.exceptions module identity checks in asyncioexc280 namespace — asyncio.exceptions is defined in Lib/asyncio/exceptions.py; its __name__ is 'asyncio.exceptions' (len=18: 'asyncio'=7+'.exceptions'=11); __spec__.name is also 'asyncio.exceptions'; CancelledError, InvalidStateError, SendfileNotAvailableError are defined in this module; TimeoutError is re-exported from builtins; __name__.__len__()==18; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioexc280

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,   asyncio.exceptions.__name__.__eq__,        ["asyncio.exceptions"],  true, "asyncio.exceptions.__name__ == 'asyncio.exceptions'; verified with Python 3.14.3"]
    - [mod_spec_eq,   asyncio.exceptions.__spec__.name.__eq__,   ["asyncio.exceptions"],  true, "asyncio.exceptions.__spec__.name == 'asyncio.exceptions'; verified with Python 3.14.3"]
    - [mod_name_len,  asyncio.exceptions.__name__.__len__,       [],                      18,   "asyncio.exceptions.__name__.__len__() == 18 ('asyncio.exceptions'=18); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.exceptions exception class identity — extra280
#
# CancelledError.__name__                          == 'CancelledError'
# CancelledError.__module__                        == 'asyncio.exceptions'
# CancelledError.__bases__[0].__name__             == 'BaseException'
# CancelledError.__mro__.__len__()                 == 3
# InvalidStateError.__name__                       == 'InvalidStateError'
# InvalidStateError.__module__                     == 'asyncio.exceptions'
# InvalidStateError.__bases__[0].__name__          == 'Exception'
# InvalidStateError.__mro__.__len__()              == 4
# SendfileNotAvailableError.__name__               == 'SendfileNotAvailableError'
# SendfileNotAvailableError.__module__             == 'asyncio.exceptions'
# SendfileNotAvailableError.__bases__[0].__name__  == 'RuntimeError'
# SendfileNotAvailableError.__mro__.__len__()      == 5
# ---------------------------------------------------------------------------

table asyncio_extra280.asyncio_exceptions_class_identity:
  description: "asyncio.exceptions exception class identity checks in asyncioexc280a namespace — three exceptions are defined in asyncio.exceptions: CancelledError (inherits from BaseException, MRO len=3), InvalidStateError (inherits from Exception, MRO len=4), SendfileNotAvailableError (inherits from RuntimeError, MRO len=5); CancelledError.__module__.__eq__('asyncio.exceptions')==True; InvalidStateError.__module__.__eq__('asyncio.exceptions')==True; SendfileNotAvailableError.__module__.__eq__('asyncio.exceptions')==True; CancelledError.__bases__[0].__name__.__eq__('BaseException')==True (shortest MRO, len=3); InvalidStateError.__bases__[0].__name__.__eq__('Exception')==True (MRO len=4); SendfileNotAvailableError.__bases__[0].__name__.__eq__('RuntimeError')==True (deepest MRO, len=5); note: TimeoutError.__module__=='builtins' (re-export, not defined here); CancelledError.__name__.__len__()==14; InvalidStateError.__name__.__len__()==17; SendfileNotAvailableError.__name__.__len__()==25 (longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioexc280a

  columns: [id, function, args, expected, description]
  rows:
    - [ce_name_eq,     asyncio.exceptions.CancelledError.__name__.__eq__,                          ["CancelledError"],                true, "asyncio.exceptions.CancelledError.__name__ == 'CancelledError'; verified with Python 3.14.3"]
    - [ce_mod_eq,      asyncio.exceptions.CancelledError.__module__.__eq__,                        ["asyncio.exceptions"],            true, "asyncio.exceptions.CancelledError.__module__ == 'asyncio.exceptions' (len=18); verified with Python 3.14.3"]
    - [ce_base0_eq,    "asyncio.exceptions.CancelledError.__bases__[0].__name__.__eq__",           ["BaseException"],                 true, "asyncio.exceptions.CancelledError.__bases__[0].__name__ == 'BaseException' (direct subclass, not Exception); verified with Python 3.14.3"]
    - [ce_mro_len,     asyncio.exceptions.CancelledError.__mro__.__len__,                          [],                                3,    "asyncio.exceptions.CancelledError.__mro__.__len__() == 3 — [CancelledError, BaseException, object]; verified with Python 3.14.3"]
    - [ce_qn_eq,       asyncio.exceptions.CancelledError.__qualname__.__eq__,                      ["CancelledError"],                true, "asyncio.exceptions.CancelledError.__qualname__ == 'CancelledError'; verified with Python 3.14.3"]
    - [ise_name_eq,    asyncio.exceptions.InvalidStateError.__name__.__eq__,                       ["InvalidStateError"],             true, "asyncio.exceptions.InvalidStateError.__name__ == 'InvalidStateError'; verified with Python 3.14.3"]
    - [ise_mod_eq,     asyncio.exceptions.InvalidStateError.__module__.__eq__,                     ["asyncio.exceptions"],            true, "asyncio.exceptions.InvalidStateError.__module__ == 'asyncio.exceptions'; verified with Python 3.14.3"]
    - [ise_base0_eq,   "asyncio.exceptions.InvalidStateError.__bases__[0].__name__.__eq__",        ["Exception"],                     true, "asyncio.exceptions.InvalidStateError.__bases__[0].__name__ == 'Exception'; verified with Python 3.14.3"]
    - [ise_mro_len,    asyncio.exceptions.InvalidStateError.__mro__.__len__,                       [],                                4,    "asyncio.exceptions.InvalidStateError.__mro__.__len__() == 4 — [InvalidStateError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [sna_name_eq,    asyncio.exceptions.SendfileNotAvailableError.__name__.__eq__,               ["SendfileNotAvailableError"],      true, "asyncio.exceptions.SendfileNotAvailableError.__name__ == 'SendfileNotAvailableError' (len=25); verified with Python 3.14.3"]
    - [sna_mod_eq,     asyncio.exceptions.SendfileNotAvailableError.__module__.__eq__,             ["asyncio.exceptions"],            true, "asyncio.exceptions.SendfileNotAvailableError.__module__ == 'asyncio.exceptions'; verified with Python 3.14.3"]
    - [sna_base0_eq,   "asyncio.exceptions.SendfileNotAvailableError.__bases__[0].__name__.__eq__", ["RuntimeError"],                  true, "asyncio.exceptions.SendfileNotAvailableError.__bases__[0].__name__ == 'RuntimeError'; verified with Python 3.14.3"]
    - [sna_mro_len,    asyncio.exceptions.SendfileNotAvailableError.__mro__.__len__,               [],                                5,    "asyncio.exceptions.SendfileNotAvailableError.__mro__.__len__() == 5 — [SendfileNotAvailableError, RuntimeError, Exception, BaseException, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra280
# ---------------------------------------------------------------------------

invariant asyncio_extra280.CancelledError_module_is_asyncio_exceptions:
  description: "asyncio.exceptions.CancelledError.__module__.__eq__('asyncio.exceptions') returns True — CancelledError is defined in Lib/asyncio/exceptions.py; its __module__ is 'asyncio.exceptions' (len=18); CancelledError inherits directly from BaseException (not from Exception), giving it the shortest MRO (len=3) among asyncio-defined exceptions in this spec; MRO: [CancelledError, BaseException, object]; CancelledError.__name__.__len__() is 14 ('CancelledError'=14); compare: asyncio.TimeoutError.__module__ is 'builtins' (not 'asyncio.exceptions') because TimeoutError is a re-export of the builtin; NEW in extra280: first standalone CancelledError.__module__ invariant in asyncioexc280 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.exceptions.CancelledError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra280.InvalidStateError_module_is_asyncio_exceptions:
  description: "asyncio.exceptions.InvalidStateError.__module__.__eq__('asyncio.exceptions') returns True — InvalidStateError is defined in Lib/asyncio/exceptions.py; its __module__ is 'asyncio.exceptions' (len=18, same as CancelledError and SendfileNotAvailableError); InvalidStateError inherits from Exception (not BaseException directly), giving it MRO len=4 ([InvalidStateError, Exception, BaseException, object]); InvalidStateError is raised when a Future's result or exception is accessed in an invalid state; InvalidStateError.__name__.__len__() is 17 ('InvalidStateError'=17); NEW in extra280: first standalone InvalidStateError.__module__ invariant in asyncioexc280 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.exceptions.InvalidStateError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra280.SendfileNotAvailableError_module_is_asyncio_exceptions:
  description: "asyncio.exceptions.SendfileNotAvailableError.__module__.__eq__('asyncio.exceptions') returns True — SendfileNotAvailableError is defined in Lib/asyncio/exceptions.py; its __module__ is 'asyncio.exceptions'; SendfileNotAvailableError has the deepest MRO (len=5) among asyncio-defined exception classes in this spec: [SendfileNotAvailableError, RuntimeError, Exception, BaseException, object]; SendfileNotAvailableError inherits from RuntimeError, indicating it is raised at runtime when the OS does not support the sendfile() syscall; SendfileNotAvailableError.__name__.__len__() is 25 ('SendfileNotAvailableError'=25, longest name in spec); NEW in extra280: first standalone SendfileNotAvailableError.__module__ invariant in asyncioexc280 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.exceptions.SendfileNotAvailableError.__module__.__eq__
  args: ["asyncio.exceptions"]
  expected: true

invariant asyncio_extra280.TimeoutError_module_is_builtins:
  description: "asyncio.exceptions.TimeoutError.__module__.__eq__('builtins') returns True — asyncio.TimeoutError (and asyncio.exceptions.TimeoutError) is the builtin TimeoutError class re-exported into the asyncio namespace; its __module__ is 'builtins', NOT 'asyncio.exceptions'; this distinguishes TimeoutError from the three asyncio-defined exceptions (CancelledError, InvalidStateError, SendfileNotAvailableError) whose __module__ is 'asyncio.exceptions'; asyncio.TimeoutError is TimeoutError evaluates True; asyncio.exceptions.TimeoutError.__name__ is 'TimeoutError'; NEW in extra280: first standalone TimeoutError.__module__ builtins check in asyncioexc280 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.exceptions.TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra280.CancelledError_mro_len_is_3:
  description: "asyncio.exceptions.CancelledError.__mro__.__len__() == 3 — CancelledError's MRO is [CancelledError, BaseException, object] (length=3); this is the shortest MRO among asyncio-defined exceptions in this spec; CancelledError inherits from BaseException directly (not from Exception), which is the standard Python 3 pattern for cancellation; compare MRO depths: CancelledError=3, InvalidStateError=4, SendfileNotAvailableError=5 (deepest); CancelledError.__bases__[0].__name__ is 'BaseException'; CancelledError.__module__ is 'asyncio.exceptions'; NEW in extra280: first standalone CancelledError MRO length invariant in asyncioexc280 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.exceptions.CancelledError.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra280.SendfileNotAvailableError_mro_len_is_5:
  description: "asyncio.exceptions.SendfileNotAvailableError.__mro__.__len__() == 5 — SendfileNotAvailableError's MRO is [SendfileNotAvailableError, RuntimeError, Exception, BaseException, object] (length=5); this is the deepest MRO among asyncio-defined exceptions in this spec; compare MRO depths: CancelledError=3, InvalidStateError=4, SendfileNotAvailableError=5; the RuntimeError base adds one extra level compared to InvalidStateError's Exception base; SendfileNotAvailableError.__module__ is 'asyncio.exceptions'; SendfileNotAvailableError.__name__.__len__() is 25; NEW in extra280: first standalone SendfileNotAvailableError MRO length invariant in asyncioexc280 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.exceptions.SendfileNotAvailableError.__mro__.__len__
  args: []
  expected: 5
