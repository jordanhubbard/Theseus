  notes:
    - "asyncpg is a fast async PostgreSQL driver."
    - "asyncpg.connect is callable."
    - "asyncpg.Connection is a class."
    - "asyncpg.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant asyncpg_rust.has_connect:
  description: "asyncpg.connect is callable"
  category: presence
  kind: python_call_eq
