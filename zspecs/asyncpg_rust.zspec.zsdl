invariant asyncpg_rust.has_connection:
  description: "asyncpg.Connection is a class"
  category: presence
  kind: python_call_eq
  function: asyncpg_has_connection
  args: []
  expected: true

invariant asyncpg_rust.version_nonempty:
  description: "asyncpg.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: asyncpg_version_nonempty
  args: []
  expected: true

