spec: threading_extra317
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.main_thread().name == 'MainThread' — the main thread's name is always 'MainThread'."
    - "threading.main_thread().daemon == False — the main thread is never a daemon thread."
    - "threading.main_thread().is_alive() == True — the main thread is alive while the interpreter runs."
    - "threading.main_thread().__class__.__name__ == '_MainThread' — internal CPython class name."
    - "threading.current_thread().name == 'MainThread' — in a single-threaded context current_thread is main_thread."
    - "threading.active_children() does NOT exist on Python 3.14; use threading.enumerate() instead."
    - "threading.enumerate() returns a list; in a single-threaded context it contains exactly 1 element (the main thread)."
    - "threading.Thread.__init__.__qualname__ == 'Thread.__init__'."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# main_thread() — name, daemon, is_alive, class name
# ---------------------------------------------------------------------------

invariant threading_extra317.main_thread.name:
  description: "threading.main_thread().name == 'MainThread'"
  category: main_thread
  kind: python_call_eq
  function: main_thread
  args: []
  method: name
  method_chain: __eq__
  method_chain_args: ["MainThread"]
  expected: true

invariant threading_extra317.main_thread.daemon:
  description: "threading.main_thread().daemon == False"
  category: main_thread
  kind: python_call_eq
  function: main_thread
  args: []
  method: daemon
  method_chain: __eq__
  method_chain_args: [false]
  expected: true

invariant threading_extra317.main_thread.is_alive:
  description: "threading.main_thread().is_alive() == True"
  category: main_thread
  kind: python_call_eq
  function: main_thread
  args: []
  method: is_alive
  expected: true

invariant threading_extra317.main_thread.class_name:
  description: "threading.main_thread().__class__.__name__ == '_MainThread'"
  category: main_thread
  kind: python_call_eq
  function: main_thread
  args: []
  method: __class__
  method_args: []
  method_chain: __name__.__eq__
  method_chain_args: ["_MainThread"]
  expected: true

# ---------------------------------------------------------------------------
# current_thread() — name in single-threaded context
# ---------------------------------------------------------------------------

invariant threading_extra317.current_thread.name:
  description: "threading.current_thread().name == 'MainThread' in single-threaded context"
  category: current_thread
  kind: python_call_eq
  function: current_thread
  args: []
  method: name
  method_chain: __eq__
  method_chain_args: ["MainThread"]
  expected: true

# ---------------------------------------------------------------------------
# enumerate() — return type and length in single-threaded context
#
# threading.enumerate() returns a list of all live Thread objects.
# In a single-threaded context (only the main thread running) the list
# contains exactly 1 element.
# ---------------------------------------------------------------------------

invariant threading_extra317.enumerate.class_name:
  description: "threading.enumerate().__class__.__name__ == 'list'"
  category: enumerate
  kind: python_call_eq
  function: enumerate
  args: []
  method: __class__
  method_args: []
  method_chain: __name__.__eq__
  method_chain_args: ["list"]
  expected: true

invariant threading_extra317.enumerate.length_single_threaded:
  description: "threading.enumerate().__len__() == 1 in single-threaded context (main thread only)"
  category: enumerate
  kind: python_call_eq
  function: enumerate
  args: []
  method: __len__
  expected: 1

# ---------------------------------------------------------------------------
# Thread.__init__ — qualname
# ---------------------------------------------------------------------------

invariant threading_extra317.Thread_init.qualname:
  description: "threading.Thread.__init__.__qualname__ == 'Thread.__init__'"
  category: Thread_init
  kind: python_call_eq
  function: Thread.__init__.__qualname__.__eq__
  args: ["Thread.__init__"]
  expected: true
