spec: threading_extra59
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra58.zspec.zsdl."
    - "Wave 224 theme: __contains__ membership tests on module __all__ lists/tuples + __iter__/__next__ class identity on collections + module __package__ checks."
    - "threading has __all__ (hasattr(threading, '__all__') is True, confirmed in prior specs). threading.__all__ is a list of 28 public names. Wave 224 adds __contains__ membership tests for key members: 'Thread', 'Lock', 'Event', 'Semaphore', 'Condition', 'Timer'. No prior threading spec has table rows checking threading.__all__.__contains__ for individual member names. threading_extra52 confirmed __all__.__class__.__name__=='list' and threading_extra58 confirmed __all__.__len__()==28, but neither has __contains__ rows."
    - "threading.__package__ == '' (empty string) — top-level stdlib modules have __package__ == '' (not the module name). Verified: threading.__package__.__eq__('threading') returns False; threading.__package__.__eq__('') returns True. No prior threading spec records __package__.__eq__('') or __package__.__class__.__name__.__eq__('str') as table rows."
    - "threading.Thread.__doc__ and threading.Event.__doc__ are str objects. Thread.__doc__ is 247 chars; Event.__doc__ is 226 chars. threading_extra58 confirmed Thread/Event/Semaphore do not define __eq__ (inherited from object). No prior threading spec has table rows checking Thread.__doc__.__class__.__name__.__eq__('str') or Event.__doc__.__class__.__name__.__eq__('str') under the thrdpkg59 id_prefix."
    - "This spec covers: threading.__all__.__contains__('Thread')==true; threading.__all__.__contains__('Lock')==true; threading.__all__.__contains__('Event')==true; threading.__all__.__contains__('Semaphore')==true; threading.__all__.__contains__('Condition')==true; threading.__all__.__contains__('Timer')==true; threading.__package__.__eq__('')==true; threading.__package__.__class__.__name__.__eq__('str')==true; threading.Thread.__doc__.__class__.__name__.__eq__('str')==true; threading.Event.__doc__.__class__.__name__.__eq__('str')==true."
    - "Key findings: threading.__package__ is '' (empty string) — same as functools, inspect, itertools; all top-level stdlib modules share this pattern. threading.__all__ contains all six key synchronization primitive names tested. Thread.__doc__ (247 chars) and Event.__doc__ (226 chars) are both Python str objects defined in the class bodies in Lib/threading.py. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.__all__.__contains__ membership tests — extra59
#
# Wave 224 theme: __contains__ membership tests on module __all__ lists/tuples.
#
# threading.__all__ is a list of 28 public names (confirmed in extra58 as a
# table row: __len__()==28; extra52 confirmed __class__.__name__=='list').
# The list.__contains__ method (exposed as a 'method-wrapper' at the instance
# level) returns True when the argument is a member of the list.
#
# Six key members are tested: 'Thread', 'Lock', 'Event', 'Semaphore',
# 'Condition', 'Timer'. All are confirmed present in Python 3.14.
#
# No prior threading spec has table rows calling threading.__all__.__contains__
# for individual member names. All six rows below are new to extra59.
# ---------------------------------------------------------------------------

table threading_extra59.all_contains_members:
  description: "threading.__all__.__contains__ returns True for 'Thread','Lock','Event','Semaphore','Condition','Timer' — wave 224 __contains__ membership test on module __all__ list of 28 names; no prior threading spec has table rows for __all__.__contains__; new to extra59"
  kind: python_call_eq
  category: membership
  id_prefix: thrdpkg59

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_Thread,
       __all__.__contains__,
       ["Thread"],
       true,
       "threading.__all__.__contains__('Thread') == True — 'Thread' is in threading.__all__; threading.Thread is the primary class for representing a thread of control in Python (a pure-Python class in Lib/threading.py); threads are created by instantiating Thread and passing a target callable, or by subclassing Thread and overriding run(); Thread is one of the most fundamental threading exports; extra58 confirmed Thread.__subclasshook__.__class__.__name__=='builtin_function_or_method' and Thread.__eq__.__class__.__name__=='wrapper_descriptor'; no prior threading spec has a table row checking __all__.__contains__('Thread'); new to extra59"]
    - [all_contains_Lock,
       __all__.__contains__,
       ["Lock"],
       true,
       "threading.__all__.__contains__('Lock') == True — 'Lock' is in threading.__all__; threading.Lock is the primitive mutual exclusion (mutex) synchronization primitive; a Lock can be in either locked or unlocked state; once locked it blocks other threads that call acquire() until it is released; implemented via Modules/_threadmodule.c (C extension); no prior threading spec has a table row checking __all__.__contains__('Lock'); new to extra59"]
    - [all_contains_Event,
       __all__.__contains__,
       ["Event"],
       true,
       "threading.__all__.__contains__('Event') == True — 'Event' is in threading.__all__; threading.Event is a class implementing event objects; Events manage a flag that can be set to true with set() and reset to false with clear(); the wait() method blocks until the flag is true; extra58 confirmed Event.__subclasshook__.__class__.__name__=='builtin_function_or_method' and Event.__eq__.__class__.__name__=='wrapper_descriptor'; extra59 adds the __all__.__contains__ test; no prior threading spec has a table row checking __all__.__contains__('Event'); new to extra59"]
    - [all_contains_Semaphore,
       __all__.__contains__,
       ["Semaphore"],
       true,
       "threading.__all__.__contains__('Semaphore') == True — 'Semaphore' is in threading.__all__; threading.Semaphore is a class implementing a counting semaphore; initialized with a count value, acquire() decrements the count (blocking if zero), release() increments it; extra58 confirmed Semaphore.__subclasshook__.__class__.__name__=='builtin_function_or_method' and Semaphore.__eq__.__class__.__name__=='wrapper_descriptor'; no prior threading spec has a table row checking __all__.__contains__('Semaphore'); new to extra59"]
    - [all_contains_Condition,
       __all__.__contains__,
       ["Condition"],
       true,
       "threading.__all__.__contains__('Condition') == True — 'Condition' is in threading.__all__; threading.Condition is a synchronization primitive that combines a lock with the ability to wait for a condition to become true and notify waiting threads; extra58 confirmed Condition.__eq__.__class__.__name__=='wrapper_descriptor'; no prior threading spec has a table row checking __all__.__contains__('Condition'); new to extra59"]
    - [all_contains_Timer,
       __all__.__contains__,
       ["Timer"],
       true,
       "threading.__all__.__contains__('Timer') == True — 'Timer' is in threading.__all__; threading.Timer is a class representing an action that should be run only after a certain amount of time has passed; Timer is a subclass of Thread; Timer(interval, function, args=None, kwargs=None) creates a timer that will run function with arguments args and keyword arguments kwargs after interval seconds; no prior threading spec has a table row checking __all__.__contains__('Timer'); new to extra59"]

# ---------------------------------------------------------------------------
# threading.__package__ identity — extra59
#
# Wave 224 theme: module __package__ checks.
#
# threading.__package__ == '' (empty string). threading is a pure-Python module
# (Lib/threading.py) but follows the same __package__ convention as all other
# top-level stdlib modules: __package__ == '' because threading is not inside
# any package hierarchy.
#
# Note: threading.__package__ == '' (not 'threading'). Verified:
# threading.__package__.__eq__('threading') returns False;
# threading.__package__.__eq__('') returns True.
#
# No prior threading spec records __package__.__eq__('') or
# __package__.__class__.__name__.__eq__('str') as table rows. Both are new
# to extra59.
# ---------------------------------------------------------------------------

table threading_extra59.package_identity:
  description: "threading.__package__.__eq__('')==true and __package__.__class__.__name__.__eq__('str')==true — top-level stdlib module __package__ is empty string (not module name); __package__ is a str; no prior threading spec has table rows for __package__; new to extra59"
  kind: python_call_eq
  category: string_value
  id_prefix: thrdpkg59

  columns: [id, function, args, expected, description]
  rows:
    - [package_eq_empty_string,
       __package__.__eq__,
       [""],
       true,
       "threading.__package__.__eq__('') == True — threading.__package__ is '' (the empty string); threading is a pure-Python module in Lib/threading.py but its __package__ follows the same convention as all other top-level stdlib modules: a top-level module not inside any package hierarchy has __package__ == '' rather than the module name; verified: threading.__package__.__eq__('threading') returns False; consistent with functools, inspect, itertools which all have __package__ == ''; no prior threading spec records __package__.__eq__('') as a table row; new to extra59"]
    - [package_class_name_eq_str,
       __package__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.__package__.__class__.__name__.__eq__('str') == True — threading.__package__ is a Python str object (the empty string ''); the str built-in type has __class__.__name__ == 'str' (3 chars); __package__ is always typed as str for stdlib modules (whether pure-Python or C-extension, top-level or submodule); consistent with functools, inspect, itertools; no prior threading spec records __package__.__class__.__name__.__eq__('str') as a table row; new to extra59"]

# ---------------------------------------------------------------------------
# threading.Thread/Event __doc__ is a str — extra59
#
# Wave 224 theme: docstring type identity as companion to __package__ checks.
#
# threading.Thread and threading.Event are pure-Python classes in Lib/threading.py.
# Their __doc__ attributes are Python str objects (class docstrings defined in
# the class bodies).
#
# Thread.__doc__ is 247 characters: 'A class that represents a thread of
# control.\n\nThis class can be safely subclassed in a limited fashion...'
#
# Event.__doc__ is 226 characters: 'Class implementing event objects.\n\n
# Events manage a flag that can be set to true with the set() method...'
#
# No prior threading spec has table rows checking Thread.__doc__.__class__.__name__.__eq__('str')
# or Event.__doc__.__class__.__name__.__eq__('str') under the thrdpkg59 id_prefix.
# Both rows are new to extra59.
# ---------------------------------------------------------------------------

table threading_extra59.class_doc_string_type:
  description: "threading.Thread/__doc__.__class__.__name__.__eq__('str')==true and Event/__doc__.__class__.__name__.__eq__('str')==true — pure-Python class docstrings are Python str objects; 247 chars and 226 chars respectively; new table rows under thrdpkg59 id_prefix; new to extra59"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdpkg59

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_doc_class_name_eq_str,
       Thread.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Thread.__doc__.__class__.__name__.__eq__('str') == True — threading.Thread is a pure-Python class in Lib/threading.py; its __doc__ attribute is a Python str object containing the class docstring (247 characters: 'A class that represents a thread of control.\\n\\nThis class can be safely subclassed in a limited fashion. There are two ways\\nto specify the activity: by passing a callable object to the constructor, or\\nby overriding the run() method in a subclass.\\n\\n'); the str type has __class__.__name__ == 'str' (3 chars); no prior threading spec has a table row checking Thread.__doc__.__class__.__name__.__eq__('str') under the thrdpkg59 id_prefix; new to extra59"]
    - [Event_doc_class_name_eq_str,
       Event.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.Event.__doc__.__class__.__name__.__eq__('str') == True — threading.Event is a pure-Python class in Lib/threading.py; its __doc__ attribute is a Python str object containing the class docstring (226 characters: 'Class implementing event objects.\\n\\nEvents manage a flag that can be set to true with the set() method and reset\\nto false with the clear() method. The wait() method blocks until the flag is\\ntrue.  The flag is initially false.\\n\\n'); no prior threading spec has a table row checking Event.__doc__.__class__.__name__.__eq__('str') under the thrdpkg59 id_prefix; new to extra59"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra59
# ---------------------------------------------------------------------------

invariant threading_extra59.all_contains_Thread:
  description: "threading.__all__.__contains__('Thread') == True — 'Thread' is one of the 28 public names in threading.__all__; wave 224 __contains__ membership test; new to extra59"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Thread"]
  expected: true

invariant threading_extra59.all_contains_Semaphore:
  description: "threading.__all__.__contains__('Semaphore') == True — 'Semaphore' is in threading.__all__; counting semaphore is a key threading primitive; wave 224 __contains__ test; new to extra59"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Semaphore"]
  expected: true

invariant threading_extra59.package_is_empty_string:
  description: "threading.__package__.__eq__('') == True — top-level stdlib module has __package__ == '' (empty string, not module name); same pattern as functools, inspect, itertools; wave 224 __package__ check; new to extra59"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true
