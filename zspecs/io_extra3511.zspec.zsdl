spec: io3511
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (io3511): __get__, __set__, __delete__ dict-presence checks for io types."
    - "All values false — io stream types do not implement the descriptor protocol."
    - "io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO: none define __get__, __set__, or __delete__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table io3511.get:
  description: "io types __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3511
  columns: [id, function, args, expected]
  rows:
    - ["io3511001", operator.contains, [io.RawIOBase.__dict__,       "__get__"], false]
    - ["io3511002", operator.contains, [io.BufferedIOBase.__dict__,  "__get__"], false]
    - ["io3511003", operator.contains, [io.TextIOBase.__dict__,      "__get__"], false]
    - ["io3511004", operator.contains, [io.FileIO.__dict__,          "__get__"], false]
    - ["io3511005", operator.contains, [io.BytesIO.__dict__,         "__get__"], false]

