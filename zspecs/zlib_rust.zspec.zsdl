spec: zlib_rust
version: ">=3.9"
backend: rust_module(zlib_rust)

docs: https://docs.python.org/3/library/zlib.html
rfcs:
  - "RFC 1950 — ZLIB Compressed Data Format Specification version 3.3"
  - "RFC 1951 — DEFLATE Compressed Data Format Specification version 1.3"

provenance:
  derived_from:
    - "RFC 1950 — ZLIB Compressed Data Format Specification version 3.3, May 1996"
    - "RFC 1951 — DEFLATE Compressed Data Format Specification version 1.3, May 1996"
    - "https://docs.python.org/3/library/zlib.html — Python zlib documentation (API surface)"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib source: zlib.h / compress.c / inflate.c"
  notes:
    - "Clean-room Rust reimplementation of the Python zlib module API, exposed via PyO3."
    - "May use the 'flate2' Rust crate (independent DEFLATE implementation, not derived from zlib C source)."
    - "compress(data: bytes, level: int = -1) -> bytes — zlib-compress data (RFC 1950 wrapper around RFC 1951 DEFLATE)."
    - "decompress(data: bytes) -> bytes — decompress zlib-compressed data."
    - "crc32(data: bytes, value: int = 0) -> int — CRC-32 checksum (32-bit unsigned int, 0..2^32-1)."
    - "adler32(data: bytes, value: int = 1) -> int — Adler-32 checksum."
    - "Z_DEFAULT_COMPRESSION = -1, Z_BEST_SPEED = 1, Z_BEST_COMPRESSION = 9, Z_NO_COMPRESSION = 0."
    - "Errors raise zlib_rust.error (subclass of Exception)."
    - "crc32(b'') = 0 (identity element with value=0 and XOR-out 0xFFFFFFFF)."
    - "adler32(b'') = 1 (initial state: S1=1, S2=0)."
    - "crc32(b'hello') = 907060870 (verified against Python 3.14.3)."
    - "adler32(b'hello') = 103547413 (verified: S1=533, S2=1580, result=1580<<16|533)."
    - "All test vectors verified against Python 3.14.3."
  created_at: "2026-04-18T00:00:00Z"

error_model: python_exceptions

table zlib_rust.crc32.vectors:
  kind: python_call_eq
  category: crc32
  id_prefix: crc32
  function: crc32

  columns: [id, args, expected]
  rows:
    - [empty,         [!b64 ""],        0         ]
    - [hello,         [!ascii hello],   907060870 ]

table zlib_rust.adler32.vectors:
  kind: python_call_eq
  category: adler32
  id_prefix: adler32
  function: adler32

  columns: [id, args, expected]
  rows:
    - [empty,         [!b64 ""],        1         ]
    - [hello,         [!ascii hello],   103547413 ]
    - [a,             [!ascii a],       6422626   ]

invariant zlib_rust.roundtrip.compress_decompress:
  description: "compress then decompress is lossless for arbitrary data"
  category: roundtrip
  kind: python_encode_decode_roundtrip
  encode_fn: compress
  decode_fn: decompress
  inputs_b64: ["", SGVsbG8gV29ybGQ=, AAAAAAAAAAAAAAAA, /wEB/wEB]

invariant zlib_rust.error.bad_decompress:
  description: "decompress of non-zlib data raises zlib_rust.error"
  category: error
  kind: python_call_raises
  function: decompress
  args: [!ascii "not compressed data at all"]
  expected_exception: "zlib_rust.error"

invariant zlib_rust.crc32.incremental_eq_combined:
  description: "crc32 of concatenation equals incremental crc32"
  category: consistency
  kind: python_call_eq
  function: crc32
  args: [!ascii "hello world"]
  expected: 222957957

