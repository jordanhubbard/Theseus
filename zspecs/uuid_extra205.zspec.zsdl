# ---------------------------------------------------------------------------
# Standalone invariants — uuid_extra205
# ---------------------------------------------------------------------------

invariant uuid_extra205.UUID_doc_contains_hex:
  description: "uuid.UUID.__doc__.__contains__('hex') returns True — uuid.UUID's docstring describes the 'hex' attribute: 'hex — the UUID as a 32-character hexadecimal string'; the word 'hex' is both the attribute name and the abbreviated form of 'hexadecimal'; uuid.UUID.hex returns a 32-character lowercase string with no hyphens, e.g., '12345678123412341234123456789abc'; compare: str(uuid) returns the hyphenated 8-4-4-4-12 format; uuid.UUID.hex removes the hyphens; the word 'hex' appears in the attribute listing section of the docstring; NEW in uuid_extra205: first standalone UUID.__doc__.__contains__('hex') invariant in uuiddoc205 namespace; wave 205; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__doc__.__contains__
  args: ["hex"]
  expected: true

invariant uuid_extra205.UUID_doc_contains_hashable:
  description: "uuid.UUID.__doc__.__contains__('hashable') returns True — uuid.UUID's docstring reads 'UUID objects are immutable, hashable, and usable as dictionary keys'; the word 'hashable' describes a key behavioral property: UUID instances can be used as dict keys and set members; hashability requires that the object's hash value does not change during its lifetime, which is guaranteed by UUID's immutability; uuid.UUID implements __hash__ based on the 128-bit integer value; __contains__ on __doc__ is case-sensitive so 'hashable' must be lowercase; NEW in uuid_extra205: first standalone UUID.__doc__.__contains__('hashable') invariant; wave 205; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__doc__.__contains__
  args: ["hashable"]
  expected: true

invariant uuid_extra205.uuid1_doc_contains_sequence:
  description: "uuid.uuid1.__doc__.__contains__('sequence') returns True — uuid.uuid1's docstring reads 'Generate a UUID from a host ID, sequence number, and the current time. If ''node'' is not given, getnode() is used to obtain the hardware address. If ''clock_seq'' is given, it is used as the sequence number; otherwise a random 14-bit sequence number is chosen'; the word 'sequence' appears twice as 'sequence number' which is the clock sequence component of a version-1 UUID; the 14-bit clock sequence helps avoid duplicates when the clock is set backwards or the node ID changes; NEW in uuid_extra205: first standalone uuid1.__doc__.__contains__('sequence') invariant; wave 205; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid.uuid1.__doc__.__contains__
  args: ["sequence"]
  expected: true

invariant uuid_extra205.UUID_doc_contains_128bit:
  description: "uuid.UUID.__doc__.__contains__('128-bit') returns True — uuid.UUID's docstring describes the 'int' attribute as 'the UUID as a 128-bit integer' and also mentions 'a single 128-bit integer as an argument named ''int'''; the hyphenated string '128-bit' precisely quantifies the size of a UUID: 128 binary digits, equivalent to 16 bytes or 32 hexadecimal characters; UUID's 128-bit size is defined by RFC 4122/9562; __contains__ matches the hyphenated '128-bit' exactly as it appears in the docstring; 'integer' alone appears elsewhere but '128-bit' is the specific size qualifier; NEW in uuid_extra205: first standalone UUID.__doc__.__contains__('128-bit') invariant; wave 205; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: uuid.UUID.__doc__.__contains__
  args: ["128-bit"]
  expected: true

