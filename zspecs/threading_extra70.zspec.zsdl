spec: threading_extra70
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra69.zspec.zsdl."
    - "Wave 235 theme: Timer/local class identity and threading module-level constants/functions."
    - "Timer.__class__.__name__ == 'type' — Timer is a pure-Python class in Lib/threading.py whose metaclass is the built-in type. Verified with Python 3.14.3."
    - "Timer.__module__ == 'threading' — defined in and exported from Lib/threading.py. Verified with Python 3.14.3."
    - "Timer.__qualname__ == 'Timer' — top-level class so qualname equals simple name. Verified with Python 3.14.3."
    - "Timer.__bases__[0].__name__ == 'Thread' — Timer inherits directly from Thread. Verified with Python 3.14.3."
    - "Timer.__mro__.__len__() == 3 — MRO is [Timer, Thread, object]. Verified with Python 3.14.3."
    - "local.__class__.__name__ == 'type' — threading.local is a C extension type from _thread module. Verified with Python 3.14.3."
    - "local.__module__ == '_thread' — threading.local is actually defined in the C extension _thread (Modules/_threadmodule.c), not in Lib/threading.py. Verified with Python 3.14.3."
    - "local.__qualname__ == 'local' — module-level C type so qualname equals simple name. Verified with Python 3.14.3."
    - "local.__bases__[0].__name__ == 'object' — local inherits directly from object. Verified with Python 3.14.3."
    - "main_thread.__class__.__name__ == 'function' — threading.main_thread is a pure-Python function defined in Lib/threading.py. Verified with Python 3.14.3."
    - "main_thread.__module__ == 'threading' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "active_count.__class__.__name__ == 'function' — threading.active_count is a pure-Python function defined in Lib/threading.py. Verified with Python 3.14.3."
    - "active_count.__module__ == 'threading' — defined in Lib/threading.py. Verified with Python 3.14.3."
    - "Prior threading_extra69 covered Thread/Semaphore/BoundedSemaphore identity and __kwdefaults__. This spec covers Timer full identity (including __bases__[0]/__name__ and __mro__/__len__), local full identity (including __module__=='_thread'), and main_thread/active_count class/module identity. All checks in this spec are new to extra70."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.Timer class identity — extra70
#
# Wave 235 theme: Timer is a pure-Python class in Lib/threading.py.
#
# threading.Timer is a Thread subclass that runs a function after a specified
# delay. It is a top-level class with:
#
# Timer.__class__.__name__ == 'type'      (metaclass is the built-in type)
# Timer.__module__         == 'threading'  (defined in Lib/threading.py)
# Timer.__qualname__       == 'Timer'      (top-level, no enclosing scope)
#
# No prior threading spec checks Timer.__qualname__ == 'Timer' via the
# thrdmore70 id_prefix. New to extra70.
# ---------------------------------------------------------------------------

table threading_extra70.Timer_identity:
  description: "Timer class identity: __class__.__name__=='type', __module__=='threading', __qualname__=='Timer'; wave 235 Timer identity; new to extra70"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdmore70

  columns: [id, function, args, expected, description]
  rows:
    - [Timer_class_name_eq_type,
       Timer.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Timer.__class__.__name__.__eq__('type') == True — Timer is a pure-Python class defined in Lib/threading.py that is a Thread subclass for running a function after a delay; its metaclass is the built-in type (the default metaclass for classes that do not explicitly specify a different metaclass); type.__name__ == 'type' (4 chars); __eq__ returns True; no prior threading spec checks Timer.__class__.__name__ via thrdmore70 id_prefix; new to extra70"]
    - [Timer_module_eq_threading,
       Timer.__module__.__eq__,
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is a pure-Python class defined in Lib/threading.py; its __module__ attribute is set to 'threading' when the module is imported; __eq__ on the str 'threading' (9 chars) returns True; no prior threading spec checks Timer.__module__ via thrdmore70 id_prefix; new to extra70"]
    - [Timer_qualname_eq_Timer,
       Timer.__qualname__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__qualname__.__eq__('Timer') == True — Timer is a top-level (non-nested) class in the threading module; its __qualname__ is therefore equal to its simple name 'Timer' (5 chars); no intermediate class or function scope appears in the qualified name; __eq__ returns True; no prior threading spec checks Timer.__qualname__ via thrdmore70 id_prefix; new to extra70"]

# ---------------------------------------------------------------------------
# threading.Timer class hierarchy — extra70
#
# Wave 235 theme: Timer inherits from Thread; MRO depth is 3.
#
# Timer.__bases__ == (Thread,)   so __bases__[0].__name__ == 'Thread'
# Timer.__mro__   == (Timer, Thread, object)  so __mro__.__len__() == 3
#
# __bases__[0] contains [ in the expression so must be double-quoted in
# table row function values.
#
# No prior threading spec checks Timer.__bases__[0].__name__ via thrdmore70.
# New to extra70.
# ---------------------------------------------------------------------------

table threading_extra70.Timer_hierarchy:
  description: "Timer inherits from Thread; __bases__[0].__name__=='Thread', __mro__.__len__()==3; wave 235 Timer hierarchy; new to extra70"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: thrdmore70

  columns: [id, function, args, expected, description]
  rows:
    - [Timer_bases_0_name_eq_Thread,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer's __bases__ tuple has exactly one element, Thread, from which Timer directly inherits; Timer is defined as 'class Timer(Thread):' in Lib/threading.py; Thread.__name__ == 'Thread' (6 chars); __eq__ returns True; no prior threading spec checks Timer.__bases__[0].__name__ via thrdmore70 id_prefix; new to extra70"]
    - [Timer_mro_len_eq_3,
       Timer.__mro__.__len__,
       [],
       3,
       "threading.Timer.__mro__.__len__() == 3 — Timer's MRO (Method Resolution Order) is [Timer, Thread, object]; Timer inherits from Thread which inherits from object; the MRO tuple therefore has three elements; tuple.__len__() returns 3; no prior threading spec checks Timer.__mro__.__len__() via thrdmore70 id_prefix; new to extra70"]

# ---------------------------------------------------------------------------
# threading.local class identity — extra70
#
# Wave 235 theme: threading.local is a C extension type from _thread.
#
# threading.local provides thread-local storage. Despite being accessed as
# threading.local, it is actually defined in the C extension module _thread
# (Modules/_threadmodule.c) where it is named '_local' internally but exported
# as 'local'. Its __module__ is '_thread', not 'threading'.
#
# local.__class__.__name__ == 'type'     (C extension type, metaclass is type)
# local.__module__         == '_thread'  (C extension, not Lib/threading.py)
# local.__qualname__       == 'local'    (module-level C type, qualname==name)
#
# No prior threading spec checks local.__module__ == '_thread'. New to extra70.
# ---------------------------------------------------------------------------

table threading_extra70.local_identity:
  description: "threading.local is a C extension type from _thread module; __class__.__name__=='type', __module__=='_thread', __qualname__=='local'; wave 235 local identity; new to extra70"
  kind: python_call_eq
  category: class_identity
  id_prefix: thrdmore70

  columns: [id, function, args, expected, description]
  rows:
    - [local_class_name_eq_type,
       local.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.local.__class__.__name__.__eq__('type') == True — threading.local is actually a C extension type defined in Modules/_threadmodule.c that provides thread-local storage; C extension types have the same metaclass as Python classes by default — the built-in type; type.__name__ == 'type' (4 chars); __eq__ returns True; no prior threading spec checks local.__class__.__name__ via thrdmore70 id_prefix; new to extra70"]
    - [local_module_eq_thread,
       local.__module__.__eq__,
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is defined in the C extension module _thread (Modules/_threadmodule.c), not in Lib/threading.py; the threading module re-exports it as 'local' for convenience, but the type itself has __module__ == '_thread' (7 chars, with leading underscore indicating a private C implementation module); __eq__ returns True; no prior threading spec checks local.__module__ == '_thread'; new to extra70"]
    - [local_qualname_eq_local,
       local.__qualname__.__eq__,
       ["local"],
       true,
       "threading.local.__qualname__.__eq__('local') == True — local is a module-level C extension type in _thread; for C types defined at module level (not nested within another class), __qualname__ equals __name__; local.__qualname__ == 'local' (5 chars); __eq__ returns True; no prior threading spec checks local.__qualname__ via thrdmore70 id_prefix; new to extra70"]

# ---------------------------------------------------------------------------
# threading module-level functions — extra70
#
# Wave 235 theme: main_thread and active_count are Python functions.
#
# threading.main_thread() returns the main Thread object.
# threading.active_count() returns the number of active Thread objects.
# Both are pure-Python functions defined in Lib/threading.py.
#
# main_thread.__class__.__name__  == 'function'
# main_thread.__module__          == 'threading'
# active_count.__class__.__name__ == 'function'
# active_count.__module__         == 'threading'
#
# No prior threading spec checks these attributes via thrdmore70. New to extra70.
# ---------------------------------------------------------------------------

table threading_extra70.threading_functions:
  description: "main_thread/active_count are Python functions in threading module; __class__.__name__=='function', __module__=='threading'; wave 235 threading functions identity; new to extra70"
  kind: python_call_eq
  category: function_identity
  id_prefix: thrdmore70

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_class_name_eq_function,
       main_thread.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.main_thread.__class__.__name__.__eq__('function') == True — main_thread is a pure-Python function defined in Lib/threading.py that returns the main Thread object (the thread that started the Python interpreter); its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior threading spec checks main_thread.__class__.__name__ via thrdmore70 id_prefix; new to extra70"]
    - [main_thread_module_eq_threading,
       main_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.main_thread.__module__.__eq__('threading') == True — main_thread is defined in Lib/threading.py; its __module__ attribute is 'threading' (9 chars); __eq__ returns True; no prior threading spec checks main_thread.__module__ via thrdmore70 id_prefix; new to extra70"]
    - [active_count_class_name_eq_function,
       active_count.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.active_count.__class__.__name__.__eq__('function') == True — active_count is a pure-Python function defined in Lib/threading.py that returns the number of currently alive Thread objects; its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior threading spec checks active_count.__class__.__name__ via thrdmore70 id_prefix; new to extra70"]
    - [active_count_module_eq_threading,
       active_count.__module__.__eq__,
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — active_count is defined in Lib/threading.py; its __module__ attribute is 'threading' (9 chars); __eq__ returns True; no prior threading spec checks active_count.__module__ via thrdmore70 id_prefix; new to extra70"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra70
# ---------------------------------------------------------------------------

invariant threading_extra70.Timer_class_type:
  description: "threading.Timer.__class__.__name__.__eq__('type') == True — Timer is a pure-Python class whose metaclass is the built-in type; wave 235 Timer identity; new to extra70"
  kind: python_call_eq
  function: Timer.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra70.Timer_module_threading:
  description: "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in Lib/threading.py; wave 235 Timer identity; new to extra70"
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra70.Timer_bases_Thread:
  description: "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer inherits directly from Thread; wave 235 Timer hierarchy; new to extra70"
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

invariant threading_extra70.local_class_type:
  description: "threading.local.__class__.__name__.__eq__('type') == True — threading.local is a C extension type from _thread module; wave 235 local identity; new to extra70"
  kind: python_call_eq
  function: local.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra70.main_thread_class_function:
  description: "threading.main_thread.__class__.__name__.__eq__('function') == True — main_thread is a pure-Python function in Lib/threading.py; wave 235 threading function identity; new to extra70"
  kind: python_call_eq
  function: main_thread.__class__.__name__.__eq__
  args: ["function"]
  expected: true
