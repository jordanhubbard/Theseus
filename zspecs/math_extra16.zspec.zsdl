spec: math_extra16
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra15.zspec.zsdl."
    - "math_extra8 covers sin(0)==0, cos(0)==1, asin(0)==0, acos(1)==0 — this spec uses new input values."
    - "math_extra9 covers sinh(0)==0, cosh(0)==1, tanh(0)==0, atan2(0,1)==0, radians(0)==0 — this spec uses new inputs."
    - "math_extra12 covers degrees(2pi)==360 — this spec covers degrees(pi)==180."
    - "math_extra13 covers hypot(0,0)==0, hypot(5,12)==13 — this spec covers hypot(0,1)==1."
    - "No prior spec covers tan(0)==0.0 or atan(0)==0.0 or atan(1)==pi/4."
    - "No prior spec covers sin(pi/2)==1.0 or cos(pi)==-1.0 as precise integer-result vectors."
    - "No prior spec covers hypot(0,1)==1.0 (degenerate single-axis case)."
    - "No prior spec covers dist([0,0],[0,5])==5.0 (axis-aligned 2D distance)."
    - "No prior spec covers radians(90)==pi/2 or degrees(pi/2)==90.0."
    - "No prior spec covers sinh(1).__gt__(1.0)==True or cosh(1).__gt__(1.0)==True."
    - "tan(0) == 0.0 — tangent of zero is zero."
    - "atan(0) == 0.0 — arctangent of zero is zero."
    - "atan(1) == pi/4 — arctangent of 1 is exactly pi/4 (checked via __gt__(0.785) == True)."
    - "sin(pi/2) == 1.0 — sine at 90 degrees is exactly 1."
    - "cos(pi) == -1.0 — cosine at 180 degrees is exactly -1."
    - "hypot(0, 1) == 1.0 — degenerate case where one component is zero."
    - "dist([0,0],[0,5]) == 5.0 — axis-aligned 2D Euclidean distance."
    - "radians(90) == pi/2 — converting 90 degrees gives pi/2."
    - "degrees(pi/2) == 90.0 — converting pi/2 radians gives 90 degrees."
    - "sinh(1) > 1.0 — sinh is greater than its argument for positive x > 0."
    - "cosh(1) > 1.0 — cosh is always >= 1, strictly > 1 for nonzero argument."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# tan — tangent
#
# math.tan(0) == 0.0: tangent of zero is zero.
# No prior spec covers tan().
# ---------------------------------------------------------------------------

invariant math_extra16.tan.zero:
  description: "math.tan(0) == 0.0 — tangent of zero is zero"
  category: trigonometry
  kind: python_call_eq
  function: tan
  args: [0]
  expected: 0.0

# ---------------------------------------------------------------------------
# atan — arctangent (single-argument)
#
# math.atan(0) == 0.0: arctangent of zero is zero.
# math.atan(1) > 0.785: pi/4 ≈ 0.7853981633974483, confirmed with __gt__.
# No prior spec covers atan().
# ---------------------------------------------------------------------------

invariant math_extra16.atan.zero:
  description: "math.atan(0) == 0.0 — arctangent of zero is zero"
  category: trigonometry
  kind: python_call_eq
  function: atan
  args: [0]
  expected: 0.0

invariant math_extra16.atan.one_gt_point785:
  description: "math.atan(1) > 0.785 — result is pi/4 ≈ 0.7854, confirmed as > 0.785"
  category: trigonometry
  kind: python_call_eq
  function: atan
  args: [1]
  method: __gt__
  method_args: [0.785]
  expected: true

# ---------------------------------------------------------------------------
# sin — sine at pi/2
#
# math.sin(pi/2) == 1.0: sine at 90 degrees is exactly 1.
# math_extra8 covers sin(0)==0. This vector uses math.pi/2.
# ---------------------------------------------------------------------------

invariant math_extra16.sin.half_pi:
  description: "math.sin(pi/2) == 1.0 — sine at 90 degrees is exactly 1"
  category: trigonometry
  kind: python_call_eq
  function: sin
  args: [1.5707963267948966]
  expected: 1.0

# ---------------------------------------------------------------------------
# cos — cosine at pi
#
# math.cos(pi) == -1.0: cosine at 180 degrees is exactly -1.
# math_extra8 covers cos(0)==1. This vector uses math.pi.
# ---------------------------------------------------------------------------

invariant math_extra16.cos.pi:
  description: "math.cos(pi) == -1.0 — cosine at 180 degrees is exactly -1"
  category: trigonometry
  kind: python_call_eq
  function: cos
  args: [3.141592653589793]
  expected: -1.0

# ---------------------------------------------------------------------------
# hypot — Euclidean norm, degenerate single-axis case
#
# math.hypot(0, 1) == 1.0: sqrt(0^2 + 1^2) == 1.0.
# math_extra8 covers hypot(3,4)==5; math_extra13 covers hypot(0,0) and hypot(5,12).
# ---------------------------------------------------------------------------

invariant math_extra16.hypot.zero_one:
  description: "math.hypot(0, 1) == 1.0 — degenerate case: sqrt(0^2 + 1^2) == 1.0"
  category: geometry
  kind: python_call_eq
  function: hypot
  args: [0, 1]
  expected: 1.0

# ---------------------------------------------------------------------------
# dist — Euclidean distance between two points
#
# math.dist([0,0],[0,5]) == 5.0: axis-aligned vertical distance.
# Prior specs cover dist([0,0],[3,4]) and dist([0,0,0],[1,1,1]).
# ---------------------------------------------------------------------------

invariant math_extra16.dist.axis_aligned_2d:
  description: "math.dist([0,0],[0,5]) == 5.0 — axis-aligned 2D Euclidean distance"
  category: geometry
  kind: python_call_eq
  function: dist
  args: [[0, 0], [0, 5]]
  expected: 5.0

# ---------------------------------------------------------------------------
# radians — degrees to radians conversion
#
# math.radians(90) == pi/2 ≈ 1.5707963267948966.
# math_extra9 covers radians(180)==pi and radians(0)==0.
# ---------------------------------------------------------------------------

invariant math_extra16.radians.ninety_degrees:
  description: "math.radians(90) == pi/2 — 90 degrees in radians is pi/2"
  category: conversion
  kind: python_call_eq
  function: radians
  args: [90]
  expected: 1.5707963267948966

# ---------------------------------------------------------------------------
# degrees — radians to degrees conversion
#
# math.degrees(pi/2) == 90.0: pi/2 radians is 90 degrees.
# math_extra12 covers degrees(2*pi)==360. This adds degrees(pi/2)==90.
# ---------------------------------------------------------------------------

invariant math_extra16.degrees.half_pi:
  description: "math.degrees(pi/2) == 90.0 — pi/2 radians converts to 90 degrees"
  category: conversion
  kind: python_call_eq
  function: degrees
  args: [1.5707963267948966]
  expected: 90.0

# ---------------------------------------------------------------------------
# sinh and cosh — hyperbolic functions at nonzero argument
#
# math.sinh(1) > 1.0: sinh grows faster than the identity for x > 0.
# math.cosh(1) > 1.0: cosh is always >= 1, strictly > 1 for nonzero argument.
# math_extra9 covers sinh(0)==0 and cosh(0)==1 (the base cases).
# ---------------------------------------------------------------------------

invariant math_extra16.sinh.one_gt_one:
  description: "math.sinh(1) > 1.0 — sinh grows faster than identity for positive x"
  category: hyperbolic
  kind: python_call_eq
  function: sinh
  args: [1]
  method: __gt__
  method_args: [1.0]
  expected: true

invariant math_extra16.cosh.one_gt_one:
  description: "math.cosh(1) > 1.0 — cosh is strictly > 1 for nonzero argument"
  category: hyperbolic
  kind: python_call_eq
  function: cosh
  args: [1]
  method: __gt__
  method_args: [1.0]
  expected: true
