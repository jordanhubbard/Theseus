    - "multiprocessing.cpu_count.__name__ == 'cpu_count' (len=9); __module__ == 'multiprocessing.context'."
    - "multiprocessing.current_process.__name__ == 'current_process' (len=15); __module__ == 'multiprocessing.process'."
    - "multiprocessing.active_children.__name__ == 'active_children' (len=15); __module__ == 'multiprocessing.process'."
    - "multiprocessing.parent_process.__name__ == 'parent_process' (len=14); __module__ == 'multiprocessing.process' (Python 3.8+)."
    - "Length ordering: cpu_count(9) < parent_process(14) < current_process(15)==active_children(15)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

