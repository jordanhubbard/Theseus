spec: uuid_extra72
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra71.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name/co_argcount and __module__/__qualname__ (table + invariants)."
    - "uuid_extra70.zspec.zsdl — covers UUID/__dict__.__contains__('__init__'/'__str__'/'__eq__'/'__hash__'/'__lt__'/'int'/'hex'/'urn'/'version'/'bytes'/'fields') / UUID/__init__/__code__/co_name/co_argcount (table + invariants)."
    - "uuid_extra29.zspec.zsdl — covers SafeUUID/__mro__/__len__()==3 / UUID/__mro__/__len__()==2 (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra71; it does NOT duplicate invariants present in those files."
    - "Wave 247 theme: uuid NAMESPACE_DNS/NAMESPACE_URL/NAMESPACE_OID/NAMESPACE_X500 constant identity and UUID/SafeUUID class identity."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is a UUID instance. No prior uuid spec checks NAMESPACE_DNS.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — NAMESPACE_URL is a UUID instance. No prior uuid spec checks NAMESPACE_URL.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — NAMESPACE_OID is a UUID instance. No prior uuid spec checks NAMESPACE_OID.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' — NAMESPACE_X500 is a UUID instance. No prior uuid spec checks NAMESPACE_X500.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__module__ == 'uuid' — the UUID class is in the uuid module. No prior uuid spec checks NAMESPACE_DNS.__class__.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__qualname__ == 'UUID' — the UUID class qualname. No prior uuid spec checks NAMESPACE_DNS.__class__.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__name__ == 'UUID' — UUID class name. No prior uuid spec checks UUID.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid' — UUID is defined in the uuid module. No prior uuid spec checks UUID.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__qualname__ == 'UUID' — UUID class qualname. No prior uuid spec checks UUID.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__bases__[0].__name__ == 'object' — UUID directly subclasses object. No prior uuid spec checks UUID.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__mro__.__len__() == 2 — MRO is (UUID, object). No prior uuid spec (other than uuid_extra29) checks UUID.__mro__.__len__()==2; uuid_extra29 covers it. Not duplicated."
    - "uuid.UUID.__qualname__.__len__() == 4 — 'UUID' is 4 characters. No prior uuid spec checks UUID.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__.__len__() == 4 — 'uuid' is 4 characters. No prior uuid spec checks UUID.__module__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__name__ == 'SafeUUID' — SafeUUID class name. No prior uuid spec checks SafeUUID.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid' — SafeUUID is defined in uuid. No prior uuid spec checks SafeUUID.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID extends Enum (it is an Enum subclass). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS/__class__/__name__ and NAMESPACE_URL/__class__/__name__
# uuid.NAMESPACE_OID/__class__/__name__ and NAMESPACE_X500/__class__/__name__
#
# Wave 247 theme: namespace constant class name identity.
#
# All four NAMESPACE_* constants are UUID instances; their __class__.__name__
# is 'UUID'. No prior uuid spec checks any of these __class__.__name__ values.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra72.namespace_class_names:
  description: "uuid.NAMESPACE_DNS/__class__/__name__.__eq__('UUID')==True / NAMESPACE_URL/__class__/__name__.__eq__('UUID')==True / NAMESPACE_OID/__class__/__name__.__eq__('UUID')==True / NAMESPACE_X500/__class__/__name__.__eq__('UUID')==True — all four NAMESPACE_* constants are UUID instances; no prior uuid spec checks these __class__.__name__ values; first class name anchor for uuid namespace constants"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra72

  columns: [id, function, args, expected]
  rows:
    - [namespace_dns_class_name_uuid,   NAMESPACE_DNS.__class__.__name__.__eq__,   ["UUID"], true]
    - [namespace_url_class_name_uuid,   NAMESPACE_URL.__class__.__name__.__eq__,   ["UUID"], true]
    - [namespace_oid_class_name_uuid,   NAMESPACE_OID.__class__.__name__.__eq__,   ["UUID"], true]
    - [namespace_x500_class_name_uuid,  NAMESPACE_X500.__class__.__name__.__eq__,  ["UUID"], true]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS/__class__/__module__ and __class__/__qualname__
# uuid.UUID.__name__ and UUID.__module__
#
# Wave 247 theme: namespace DNS class module/qualname and UUID class name/module.
#
# NAMESPACE_DNS.__class__.__module__ == 'uuid', __class__.__qualname__ == 'UUID'.
# UUID.__name__ == 'UUID', UUID.__module__ == 'uuid'.
# No prior uuid spec checks any of these attributes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra72.namespace_dns_class_attrs_uuid_class_name:
  description: "uuid.NAMESPACE_DNS/__class__/__module__.__eq__('uuid')==True / NAMESPACE_DNS/__class__/__qualname__.__eq__('UUID')==True / UUID/__name__.__eq__('UUID')==True / UUID/__module__.__eq__('uuid')==True — NAMESPACE_DNS class is the uuid.UUID type; UUID class name and module are 'UUID' and 'uuid'; no prior uuid spec checks these; first module/qualname anchor for NAMESPACE_DNS class and first name/module anchor for UUID class"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra72

  columns: [id, function, args, expected]
  rows:
    - [namespace_dns_class_module_uuid,   NAMESPACE_DNS.__class__.__module__.__eq__,   ["uuid"], true]
    - [namespace_dns_class_qualname_uuid, NAMESPACE_DNS.__class__.__qualname__.__eq__,  ["UUID"], true]
    - [uuid_class_name_uuid,              UUID.__name__.__eq__,                         ["UUID"], true]
    - [uuid_class_module_uuid,            UUID.__module__.__eq__,                       ["uuid"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__qualname__ / UUID.__bases__[0].__name__
# uuid.UUID.__qualname__.__len__() / UUID.__module__.__len__()
#
# Wave 247 theme: UUID class qualname and base class identity.
#
# UUID.__qualname__ == 'UUID'. UUID.__bases__[0].__name__ == 'object'.
# UUID.__qualname__.__len__() == 4. UUID.__module__.__len__() == 4.
# No prior uuid spec checks any of these.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra72.uuid_qualname_bases_lengths:
  description: "uuid.UUID/__qualname__.__eq__('UUID')==True / UUID/__bases__[0]/__name__.__eq__('object')==True / UUID/__qualname__/__len__()==4 / UUID/__module__/__len__()==4 — UUID is a module-level class directly subclassing object; qualname and module are both 4 characters; no prior uuid spec checks UUID.__qualname__, __bases__[0].__name__, or the string lengths; first qualname/base/length anchor for uuid.UUID"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra72

  columns: [id, function, args, expected]
  rows:
    - [uuid_qualname_eq_uuid,       UUID.__qualname__.__eq__,           ["UUID"],    true]
    - [uuid_bases0_name_object,     "UUID.__bases__[0].__name__.__eq__", ["object"],  true]
    - [uuid_qualname_len_4,         UUID.__qualname__.__len__,           [],          4]
    - [uuid_module_len_4,           UUID.__module__.__len__,             [],          4]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__name__ / SafeUUID.__module__ / SafeUUID.__bases__[0].__name__
#
# Wave 247 theme: SafeUUID class identity.
#
# SafeUUID.__name__ == 'SafeUUID'. SafeUUID.__module__ == 'uuid'.
# SafeUUID.__bases__[0].__name__ == 'Enum' (SafeUUID is an Enum subclass).
# No prior uuid spec checks SafeUUID.__name__, __module__, or __bases__[0].__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra72.safeuuid_identity:
  description: "uuid.SafeUUID/__name__.__eq__('SafeUUID')==True / SafeUUID/__module__.__eq__('uuid')==True / SafeUUID/__bases__[0]/__name__.__eq__('Enum')==True — SafeUUID is an Enum subclass defined in the uuid module; no prior uuid spec checks SafeUUID.__name__/__module__/__bases__[0].__name__; first identity anchor for uuid.SafeUUID"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra72

  columns: [id, function, args, expected]
  rows:
    - [safeuuid_name_eq,          SafeUUID.__name__.__eq__,                ["SafeUUID"], true]
    - [safeuuid_module_eq,        SafeUUID.__module__.__eq__,              ["uuid"],     true]
    - [safeuuid_bases0_name_enum, "SafeUUID.__bases__[0].__name__.__eq__",  ["Enum"],    true]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') — standalone
#
# NAMESPACE_DNS is a UUID instance. No prior uuid spec checks
# NAMESPACE_DNS.__class__.__name__. First __class__.__name__ standalone for
# uuid.NAMESPACE_DNS. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra72.namespace_dns_class_name_uuid:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is an instance of the UUID class; no prior uuid spec checks NAMESPACE_DNS.__class__.__name__; first __class__.__name__ standalone for uuid.NAMESPACE_DNS"
  category: class_attrs
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID') — standalone
#
# UUID class __name__ is 'UUID'. No prior uuid spec checks UUID.__name__.
# First __name__ standalone for uuid.UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra72.uuid_class_name_uuid:
  description: "uuid.UUID.__name__.__eq__('UUID') == True — uuid.UUID is the UUID class; its __name__ is 'UUID'; no prior uuid spec checks UUID.__name__; first __name__ standalone for uuid.UUID"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__name__.__eq__('SafeUUID') — standalone
#
# SafeUUID class __name__ is 'SafeUUID'. No prior uuid spec checks SafeUUID.__name__.
# First __name__ standalone for uuid.SafeUUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra72.safeuuid_name_safeuuid:
  description: "uuid.SafeUUID.__name__.__eq__('SafeUUID') == True — SafeUUID is an Enum class defined in uuid; its __name__ is 'SafeUUID'; no prior uuid spec checks SafeUUID.__name__; first __name__ standalone for uuid.SafeUUID"
  category: class_attrs
  kind: python_call_eq
  function: SafeUUID.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__module__.__eq__('uuid') — standalone
#
# UUID.__module__ is 'uuid'. No prior uuid spec checks UUID.__module__.
# First __module__ standalone for uuid.UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra72.uuid_module_uuid:
  description: "uuid.UUID.__module__.__eq__('uuid') == True — uuid.UUID is defined in the uuid module; no prior uuid spec checks UUID.__module__; first __module__ standalone for uuid.UUID"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__module__.__eq__('uuid') — standalone
#
# SafeUUID.__module__ is 'uuid'. No prior uuid spec checks SafeUUID.__module__.
# First __module__ standalone for uuid.SafeUUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra72.safeuuid_module_uuid:
  description: "uuid.SafeUUID.__module__.__eq__('uuid') == True — SafeUUID is defined in the uuid module; no prior uuid spec checks SafeUUID.__module__; first __module__ standalone for uuid.SafeUUID"
  category: class_attrs
  kind: python_call_eq
  function: SafeUUID.__module__.__eq__
  args: ["uuid"]
  expected: true
