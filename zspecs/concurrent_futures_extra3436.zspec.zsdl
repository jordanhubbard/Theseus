    - ["cf3436004", operator.contains, [concurrent.futures.Future.__dict__,              "__gt__"], false]
    - ["cf3436005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__gt__"], false]
    - ["cf3436006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__gt__"], false]

# ---------------------------------------------------------------------------
# __ge__ dict-presence — operator.contains(Cls.__dict__, '__ge__')
#
# All 3 concurrent.futures classes return false for __ge__.
# >= delegates to __ge__ when defined in the class's own __dict__.
# concurrent.futures types define no ordering protocol in their own __dict__.
# concurrent.futures.Future: an unordered state-machine result handle; no
#   __ge__ is defined in Future.__dict__. Futures are not compared by order;
#   they are queried via done()/result()/exception().
# ThreadPoolExecutor/ProcessPoolExecutor: executor types with no __ge__
#   defined in their own __dict__. Pool instances are not ordered.
# ---------------------------------------------------------------------------

table cf3436.ge:
  description: "concurrent.futures types __ge__ dict-presence checks; wave 676"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
