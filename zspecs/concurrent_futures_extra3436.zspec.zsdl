    - ["cf3436007", operator.contains, [concurrent.futures.Future.__dict__,              "__ge__"], false]
    - ["cf3436008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ge__"], false]
    - ["cf3436009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ge__"], false]

# ---------------------------------------------------------------------------
# combined — __le__, __gt__, __ge__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __le__: false for all 3 — <= protocol not in own __dict__.
# __gt__: false for all 3 — > protocol not in own __dict__.
# __ge__: false for all 3 — >= protocol not in own __dict__.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire
#   public surface is method-based: submit(), map(), result(), cancel(),
#   done(), running(), cancelled(), add_done_callback(), shutdown(). Waves
#   658–675 established that no arithmetic, bitwise, reflected, in-place
#   augmented assignment, unary numeric, rounding, numeric conversion,
#   display, or hash/eq/lt protocol dunder appears in the concurrent.futures
#   type hierarchy. The remaining ordering protocol dunders tested here
#   follow the same pattern.
# concurrent.futures.Future note: despite the name and its state-machine
#   design, Future does not define __le__, __gt__, or __ge__ in its own
#   __dict__. These ordering operators are not meaningful for a result handle
#   whose states are PENDING/RUNNING/CANCELLED/FINISHED — only in entries
#   directly defined on the class appear in its __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate a
#   pool of worker threads or processes; they expose only lifecycle and dispatch
#   methods. No ordering protocol overloads are defined in their __dict__.
# ---------------------------------------------------------------------------

table cf3436.combined:
  description: "concurrent.futures types combined __le__/__gt__/__ge__; wave 676"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3436

  columns: [id, function, args, expected]
  rows:
    - ["cf3436010", operator.contains, [concurrent.futures.Future.__dict__,              "__le__"],  false]
    - ["cf3436011", operator.contains, [concurrent.futures.Future.__dict__,              "__gt__"],  false]
    - ["cf3436012", operator.contains, [concurrent.futures.Future.__dict__,              "__ge__"],  false]
    - ["cf3436013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__le__"],  false]
    - ["cf3436014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__gt__"],  false]
    - ["cf3436015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ge__"],  false]
    - ["cf3436016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__le__"],  false]
    - ["cf3436017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__gt__"],  false]
    - ["cf3436018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ge__"],  false]
