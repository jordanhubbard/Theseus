spec: cf3436
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 676 (cf3436): __le__, __gt__, __ge__ dict-presence (x<=y, x>y, x>=y) for concurrent.futures types."
    - "Theme: __le__/__gt__/__ge__ dict-presence (x<=y, x>y, x>=y)."
    - "All values False — these types do not define ordering comparison operators in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__le__): all 3 concurrent.futures classes return false for __le__. <= delegates to __le__ when defined in the class's own __dict__. concurrent.futures.Future: a state-machine result handle (PENDING/RUNNING/CANCELLED/FINISHED) that does NOT define __le__ in its own __dict__. Even though Future can be awaited and queried for state, it defines no ordering protocol at the dict level. ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers with no __le__ in their own __dict__."
    - "Key finding (__gt__): all 3 concurrent.futures classes return false for __gt__. > delegates to __gt__ when defined in the class's own __dict__. concurrent.futures.Future: does NOT define __gt__ in its own Future.__dict__. Future objects are unordered state-machine handles queried via done()/result()/exception(). ThreadPoolExecutor/ProcessPoolExecutor: no __gt__ defined in their own __dict__."
    - "Key finding (__ge__): all 3 concurrent.futures classes return false for __ge__. >= delegates to __ge__ when defined in the class's own __dict__. concurrent.futures types define no ordering protocol in their own __dict__. Future objects are unordered state-machine handles; no __ge__ is defined in Future.__dict__. ThreadPoolExecutor/ProcessPoolExecutor: executor types with no __ge__ in their own __dict__."
    - "All 9 values in this wave are false. concurrent.futures is a high-level parallel execution API operating entirely through method calls — submit(), map(), result(), cancel(), add_done_callback(), shutdown() — with no comparison or ordering protocol overrides in any class __dict__."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (cf3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (cf3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (cf3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (cf3346): __neg__/__pos__/__abs__ — all false for all 3."
    - "  Wave 671 (cf3361): __invert__/__floor__/__ceil__ — all false for all 3."
    - "  Wave 672 (cf3376): __trunc__/__round__/__index__ — all false for all 3."
    - "  Wave 673 (cf3391): __int__/__float__/__complex__ — all false for all 3."
    - "  Wave 674 (cf3406): __bool__/__str__/__repr__ — all false for all 3."
    - "  Wave 675 (cf3421): __hash__/__eq__/__lt__ — all false for all 3."
    - "  Wave 676 (cf3436): __le__/__gt__/__ge__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __le__ dict-presence — operator.contains(Cls.__dict__, '__le__')
#
# All 3 concurrent.futures classes return false for __le__.
# <= delegates to __le__ when defined in the class's own __dict__.
# concurrent.futures.Future: a state-machine result handle that does not
#   define __le__ in its own __dict__. The <= operator is not part of the
#   Future public API; state is queried via done()/cancelled()/running().
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers
#   with no __le__ in their own __dict__. Pool ordering is not customized.
# ---------------------------------------------------------------------------

table cf3436.le:
  description: "concurrent.futures types __le__ dict-presence checks; wave 676"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3436

  columns: [id, function, args, expected]
  rows:
    - ["cf3436001", operator.contains, [concurrent.futures.Future.__dict__,              "__le__"], false]
    - ["cf3436002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__le__"], false]
    - ["cf3436003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__le__"], false]

# ---------------------------------------------------------------------------
# __gt__ dict-presence — operator.contains(Cls.__dict__, '__gt__')
#
# All 3 concurrent.futures classes return false for __gt__.
# > delegates to __gt__ when defined in the class's own __dict__.
# concurrent.futures.Future: does NOT define __gt__ in its own Future.__dict__.
#   Future objects are unordered state-machine handles; their state is
#   accessed via done()/result()/exception(), not through __gt__.
# ThreadPoolExecutor/ProcessPoolExecutor: executor types with no __gt__
#   defined in their own __dict__. Pool instances are not ordered.
# ---------------------------------------------------------------------------

table cf3436.gt:
  description: "concurrent.futures types __gt__ dict-presence checks; wave 676"
  kind: python_call_eq
