spec: pp3301
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 667 (pp3301): __itruediv__, __ifloordiv__, __imod__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __itruediv__, __ifloordiv__, __imod__ dict-presence (in-place /=, //=, %=)."
    - "No pathlib class defines __itruediv__ in its own __dict__: pathlib defines __truediv__ (wave 659) for path joining via / but does NOT define __itruediv__ as an in-place augmented assignment operator."
    - "No pathlib class defines __ifloordiv__ in its own __dict__: path objects do not implement in-place floor division; arithmetic is not part of the path protocol."
    - "No pathlib class defines __imod__ in its own __dict__: path objects do not implement in-place modulo; augmented assignment operators have no meaning for filesystem paths."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __itruediv__ dict-presence — operator.contains(Cls.__dict__, '__itruediv__')
#
# No pathlib class defines __itruediv__ in its own __dict__; all false.
# pathlib defines __truediv__ for path joining (wave 659) but NOT __itruediv__:
# path /= other rebinds the variable to a new path via __truediv__, not __itruediv__.
# ---------------------------------------------------------------------------

table pp3301.itruediv:
  description: "pathlib types __itruediv__ dict-presence checks; wave 667"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3301

  columns: [id, function, args, expected]
  rows:
    - ["pp3301001", operator.contains, [pathlib.PurePath.__dict__,         "__itruediv__"], false]
    - ["pp3301002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__itruediv__"], false]
    - ["pp3301003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__itruediv__"], false]
    - ["pp3301004", operator.contains, [pathlib.Path.__dict__,             "__itruediv__"], false]
    - ["pp3301005", operator.contains, [pathlib.PosixPath.__dict__,        "__itruediv__"], false]

