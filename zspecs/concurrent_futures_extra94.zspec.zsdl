table concurrent_futures_extra94.ppe_init_code_attrs:
  description: "ProcessPoolExecutor.__init__ code attribute checks in cfexecinitcode94 namespace — wave 254 theme: concurrent.futures executor __init__ code attrs; ProcessPoolExecutor.__init__ is defined in Lib/concurrent/futures/process.py; its __qualname__ is 'ProcessPoolExecutor.__init__' (len=28, one char longer than ThreadPoolExecutor.__init__ len=27 because 'ProcessPoolExecutor' is 19 chars vs 'ThreadPoolExecutor' 18 chars); __code__.co_argcount==5 (self, max_workers, mp_context, initializer, initargs); __code__.co_name=='__init__'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecinitcode94a

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_init_qeq,     "ProcessPoolExecutor.__init__.__qualname__.__eq__",         ["ProcessPoolExecutor.__init__"], true, "ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__'; verified with Python 3.14.3"]
    - [ppe_init_qlen,    "ProcessPoolExecutor.__init__.__qualname__.__len__",         [],                              28,   "ProcessPoolExecutor.__init__.__qualname__.__len__() == 28; one char longer than ThreadPoolExecutor.__init__ (27); verified with Python 3.14.3"]
    - [ppe_init_argcnt,  "ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__",  [5],                             true, "ProcessPoolExecutor.__init__.__code__.co_argcount == 5 (self, max_workers, mp_context, initializer, initargs); verified with Python 3.14.3"]
    - [ppe_init_coname,  "ProcessPoolExecutor.__init__.__code__.co_name.__eq__",      ["__init__"],                    true, "ProcessPoolExecutor.__init__.__code__.co_name == '__init__'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor method __qualname__ equality — extra94
#
# ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25)
# ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27)
# ---------------------------------------------------------------------------

table concurrent_futures_extra94.tpe_method_qualname_eq:
  description: "ThreadPoolExecutor method __qualname__ equality checks in cfexecinitcode94 namespace — wave 254 theme: ThreadPoolExecutor method qualnames; ThreadPoolExecutor.submit is the primary method for scheduling callables; ThreadPoolExecutor.shutdown waits for pending futures and frees resources; ThreadPoolExecutor.submit.__qualname__.__eq__('ThreadPoolExecutor.submit')==True (len=25); ThreadPoolExecutor.shutdown.__qualname__.__eq__('ThreadPoolExecutor.shutdown')==True (len=27); ThreadPoolExecutor.shutdown is 2 chars longer than submit (25); both are Python functions in Lib/concurrent/futures/thread.py; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecinitcode94b

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_submit_qeq,   "ThreadPoolExecutor.submit.__qualname__.__eq__",   ["ThreadPoolExecutor.submit"],   true, "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25); verified with Python 3.14.3"]
    - [tpe_submit_qlen,  "ThreadPoolExecutor.submit.__qualname__.__len__",   [],                              25,   "ThreadPoolExecutor.submit.__qualname__.__len__() == 25; verified with Python 3.14.3"]
    - [tpe_shutdown_qeq, "ThreadPoolExecutor.shutdown.__qualname__.__eq__", ["ThreadPoolExecutor.shutdown"], true, "ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown' (len=27); verified with Python 3.14.3"]
    - [tpe_shutdown_qlen,"ThreadPoolExecutor.shutdown.__qualname__.__len__", [],                              27,   "ThreadPoolExecutor.shutdown.__qualname__.__len__() == 27; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ProcessPoolExecutor method __qualname__ equality — extra94
#
# ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' (len=26)
# ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (len=28)
# ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23)
# ---------------------------------------------------------------------------

table concurrent_futures_extra94.ppe_method_qualname_eq:
  description: "ProcessPoolExecutor method __qualname__ equality checks in cfexecinitcode94 namespace — wave 254 theme: ProcessPoolExecutor method qualnames; ProcessPoolExecutor.submit.__qualname__.__eq__('ProcessPoolExecutor.submit')==True (len=26); ProcessPoolExecutor.shutdown.__qualname__.__eq__('ProcessPoolExecutor.shutdown')==True (len=28); ProcessPoolExecutor.map.__qualname__.__eq__('ProcessPoolExecutor.map')==True (len=23, shortest of the three); ProcessPoolExecutor methods are exactly 1 char longer than their ThreadPoolExecutor counterparts ('ProcessPoolExecutor' is 19 chars vs 'ThreadPoolExecutor' 18 chars); map is inherited from Executor base class and thus has ProcessPoolExecutor qualname when overridden; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecinitcode94c

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_submit_qeq,   "ProcessPoolExecutor.submit.__qualname__.__eq__",   ["ProcessPoolExecutor.submit"],   true, "ProcessPoolExecutor.submit.__qualname__ == 'ProcessPoolExecutor.submit' (len=26); verified with Python 3.14.3"]
    - [ppe_submit_qlen,  "ProcessPoolExecutor.submit.__qualname__.__len__",   [],                               26,   "ProcessPoolExecutor.submit.__qualname__.__len__() == 26; one char longer than ThreadPoolExecutor.submit (25); verified with Python 3.14.3"]
    - [ppe_shutdown_qeq, "ProcessPoolExecutor.shutdown.__qualname__.__eq__", ["ProcessPoolExecutor.shutdown"], true, "ProcessPoolExecutor.shutdown.__qualname__ == 'ProcessPoolExecutor.shutdown' (len=28); verified with Python 3.14.3"]
    - [ppe_map_qeq,      "ProcessPoolExecutor.map.__qualname__.__eq__",      ["ProcessPoolExecutor.map"],      true, "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23); shortest PPE method qualname; verified with Python 3.14.3"]
    - [ppe_map_qlen,     "ProcessPoolExecutor.map.__qualname__.__len__",     [],                               23,   "ProcessPoolExecutor.map.__qualname__.__len__() == 23; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra94
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra94.ThreadPoolExecutor_init_qualname_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__') returns True — ThreadPoolExecutor.__init__ is a Python function defined in Lib/concurrent/futures/thread.py; its __qualname__ is 'ThreadPoolExecutor.__init__' (len=27); it accepts 5 positional parameters (self, max_workers, thread_name_prefix, initializer, initargs); the __code__.co_argcount reflects all positional params including self; NEW in extra94: first standalone ThreadPoolExecutor.__init__.__qualname__.__eq__ invariant in cfexecinitcode94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ThreadPoolExecutor.__init__.__qualname__.__eq__"
  args: ["ThreadPoolExecutor.__init__"]
  expected: true

invariant concurrent_futures_extra94.ProcessPoolExecutor_init_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__('ProcessPoolExecutor.__init__') returns True — ProcessPoolExecutor.__init__ is a Python function defined in Lib/concurrent/futures/process.py; its __qualname__ is 'ProcessPoolExecutor.__init__' (len=28); it accepts 5 positional parameters (self, max_workers, mp_context, initializer, initargs); the mp_context parameter (vs thread_name_prefix for ThreadPoolExecutor) reflects that ProcessPoolExecutor accepts a multiprocessing context object; NEW in extra94: first standalone ProcessPoolExecutor.__init__.__qualname__.__eq__ invariant in cfexecinitcode94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ProcessPoolExecutor.__init__.__qualname__.__eq__"
  args: ["ProcessPoolExecutor.__init__"]
  expected: true

invariant concurrent_futures_extra94.ThreadPoolExecutor_init_co_argcount_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__(5) returns True — ThreadPoolExecutor.__init__.__code__.co_argcount is 5 counting all positional params: self, max_workers, thread_name_prefix, initializer, initargs; co_argcount counts positional-or-keyword parameters (not *args or **kwargs); this is the same argcount as ProcessPoolExecutor.__init__ even though the parameter names differ; NEW in extra94: first standalone co_argcount invariant for ThreadPoolExecutor.__init__ in cfexecinitcode94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__"
  args: [5]
  expected: true

invariant concurrent_futures_extra94.ProcessPoolExecutor_submit_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__eq__('ProcessPoolExecutor.submit') returns True — ProcessPoolExecutor.submit.__qualname__ is 'ProcessPoolExecutor.submit' (len=26); it is exactly 1 char longer than ThreadPoolExecutor.submit.__qualname__ (len=25) because 'ProcessPoolExecutor' (19 chars) is 1 char longer than 'ThreadPoolExecutor' (18 chars); ProcessPoolExecutor.submit schedules a callable to be executed by the process pool; NEW in extra94: first standalone ProcessPoolExecutor.submit qualname invariant in cfexecinitcode94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ProcessPoolExecutor.submit.__qualname__.__eq__"
  args: ["ProcessPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra94.ProcessPoolExecutor_map_qualname_eq:
  description: "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__('ProcessPoolExecutor.map') returns True — ProcessPoolExecutor.map.__qualname__ is 'ProcessPoolExecutor.map' (len=23); this is the shortest method qualname among ProcessPoolExecutor.submit (26), ProcessPoolExecutor.shutdown (28), and ProcessPoolExecutor.map (23); map is shorter because 'map' (3 chars) is shorter than 'submit' (6) or 'shutdown' (8); ProcessPoolExecutor.map applies a function to an iterable using the process pool; NEW in extra94: first standalone ProcessPoolExecutor.map qualname invariant in cfexecinitcode94 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ProcessPoolExecutor.map.__qualname__.__eq__"
  args: ["ProcessPoolExecutor.map"]
  expected: true
