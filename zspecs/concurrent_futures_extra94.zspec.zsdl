spec: concurrent_futures_extra94
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra93

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra93.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures ThreadPoolExecutor.__init__ code attrs + ProcessPoolExecutor.__init__ code attrs. NEW in extra94: ThreadPoolExecutor.__init__.__qualname__=='ThreadPoolExecutor.__init__' (len=27); ThreadPoolExecutor.__init__.__code__.co_argcount==5; ThreadPoolExecutor.__init__.__code__.co_name=='__init__'; ProcessPoolExecutor.__init__.__qualname__=='ProcessPoolExecutor.__init__' (len=28); ProcessPoolExecutor.__init__.__code__.co_argcount==5; ProcessPoolExecutor.__init__.__code__.co_name=='__init__'; ThreadPoolExecutor.submit.__qualname__=='ThreadPoolExecutor.submit' (len=25); ThreadPoolExecutor.shutdown.__qualname__=='ThreadPoolExecutor.shutdown' (len=27); ProcessPoolExecutor.submit.__qualname__=='ProcessPoolExecutor.submit' (len=26); ProcessPoolExecutor.shutdown.__qualname__=='ProcessPoolExecutor.shutdown' (len=28); ProcessPoolExecutor.map.__qualname__=='ProcessPoolExecutor.map' (len=23). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27). ThreadPoolExecutor.__init__ takes 5 args: self, max_workers, thread_name_prefix, initializer, initargs. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' (len=28). ProcessPoolExecutor.__init__ takes 5 args: self, max_workers, mp_context, initializer, initargs. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit' (len=25). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ProcessPoolExecutor.map.__qualname__ == 'ProcessPoolExecutor.map' (len=23). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.__init__ code attrs — extra94
#
# Wave 254 theme: concurrent.futures executor __init__ code attrs.
#
# ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' (len=27)
# ThreadPoolExecutor.__init__.__code__.co_argcount == 5
# ThreadPoolExecutor.__init__.__code__.co_name == '__init__'
# ThreadPoolExecutor.__init__.__qualname__.__len__() == 27
# ---------------------------------------------------------------------------

table concurrent_futures_extra94.tpe_init_code_attrs:
  description: "ThreadPoolExecutor.__init__ code attribute checks in cfexecinitcode94 namespace — wave 254 theme: concurrent.futures executor __init__ code attrs; ThreadPoolExecutor.__init__ is a Python function defined in Lib/concurrent/futures/thread.py; its __qualname__ is 'ThreadPoolExecutor.__init__' (len=27); __code__.co_argcount==5 (self, max_workers, thread_name_prefix, initializer, initargs); __code__.co_name=='__init__'; ThreadPoolExecutor.__init__.__qualname__.__eq__('ThreadPoolExecutor.__init__')==True; ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__(5)==True; ThreadPoolExecutor.__init__.__code__.co_name.__eq__('__init__')==True; ThreadPoolExecutor.__init__.__qualname__.__len__()==27; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecinitcode94

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_init_qeq,     "ThreadPoolExecutor.__init__.__qualname__.__eq__",         ["ThreadPoolExecutor.__init__"], true, "ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__'; verified with Python 3.14.3"]
    - [tpe_init_qlen,    "ThreadPoolExecutor.__init__.__qualname__.__len__",         [],                             27,   "ThreadPoolExecutor.__init__.__qualname__.__len__() == 27; verified with Python 3.14.3"]
    - [tpe_init_argcnt,  "ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__",  [5],                            true, "ThreadPoolExecutor.__init__.__code__.co_argcount == 5 (self, max_workers, thread_name_prefix, initializer, initargs); verified with Python 3.14.3"]
    - [tpe_init_coname,  "ThreadPoolExecutor.__init__.__code__.co_name.__eq__",      ["__init__"],                   true, "ThreadPoolExecutor.__init__.__code__.co_name == '__init__'; verified with Python 3.14.3"]

