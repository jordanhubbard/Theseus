spec: sched_extra6
version: ">=3.9"
backend: python_module(sched)

docs: https://docs.python.org/3/library/sched.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sched.html — Python sched module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sched.py"
    - "sched.zspec.zsdl — covers scheduler.__name__, scheduler.__module__, scheduler is_type, Event.__name__, scheduler().empty(), scheduler().queue==[], method names table (enter/enterabs/cancel/run/empty), Event._fields membership"
    - "sched_extra.zspec.zsdl — covers scheduler.__name__, scheduler.__module__, Event.__name__, Event.__module__, scheduler().queue.__class__.__name__=='list', scheduler().empty()==True, Event._fields.__class__.__name__=='tuple'"
    - "sched_extra2.zspec.zsdl — covers scheduler.__name__/__module__/__qualname__, is_type, method __name__/__qualname__ table (enter/cancel/run/empty), Event.__name__/__module__, _fields is tuple, _fields.__eq__, _fields.__len__, field-presence table"
    - "sched_extra3.zspec.zsdl — covers scheduler.__bases__[0].__name__=='object', scheduler.enterabs.__qualname__, Event.__qualname__=='Event', Event.__bases__[0].__name__=='tuple', Event._fields indexed access table, scheduler.__doc__ is str"
    - "sched_extra4.zspec.zsdl — covers scheduler.__name__ standalone, Event.__name__ standalone, scheduler().__class__.__name__=='scheduler', Event._fields individual field invariants via __getitem__"
    - "sched_extra5.zspec.zsdl — covers scheduler.__module__ standalone, Event.__module__ standalone, scheduler method __qualname__ standalone (cancel/run/empty/enter), scheduler().__class__.__module__=='sched', Event._fields.__len__==6, Event._fields.__eq__ standalone"
  notes:
    - "This spec adds invariants not covered by any prior sched spec."
    - "Focus: class identity via __name__ and __module__ as standalone extra6-namespace invariants, Event namedtuple base class, Event._fields indexed access for field positions not yet covered as extra6 anchors, and scheduler().__class__.__name__ check in extra6 namespace."
    - "sched.scheduler.__name__ == 'scheduler' — standalone extra6 namespace anchor."
    - "sched.scheduler.__module__ == 'sched' — standalone extra6 namespace anchor."
    - "sched.Event.__name__ == 'Event' — standalone extra6 namespace anchor."
    - "sched.Event.__module__ == 'sched' — standalone extra6 namespace anchor."
    - "sched.Event._fields == ('time', 'priority', 'sequence', 'action', 'argument', 'kwargs') — six-field namedtuple."
    - "sched.scheduler().__class__.__name__ == 'scheduler' — instance class name, extra6 namespace anchor."
    - "sched.Event.__bases__[0].__name__ == 'tuple' — Event is a namedtuple, its base is tuple."
    - "sched.Event._fields.__len__() == 6 — standalone extra6 namespace anchor."
    - "sched.Event._fields[0] == 'time', [1] == 'priority', [2] == 'sequence', [3] == 'action' — extra6 indexed access anchors."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# scheduler class identity — standalone extra6-namespace invariants
# ---------------------------------------------------------------------------

invariant sched_extra6.scheduler.name:
  description: "sched.scheduler.__name__ == 'scheduler'"
  category: class_identity
  kind: python_call_eq
  function: scheduler.__name__.__eq__
  args: ["scheduler"]
  expected: true

invariant sched_extra6.scheduler.module:
  description: "sched.scheduler.__module__ == 'sched'"
  category: class_identity
  kind: python_call_eq
  function: scheduler.__module__.__eq__
  args: ["sched"]
  expected: true

# ---------------------------------------------------------------------------
# Event class identity — standalone extra6-namespace invariants
# ---------------------------------------------------------------------------

invariant sched_extra6.Event.name:
  description: "sched.Event.__name__ == 'Event'"
  category: event_identity
  kind: python_call_eq
  function: Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant sched_extra6.Event.module:
  description: "sched.Event.__module__ == 'sched'"
  category: event_identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["sched"]
  expected: true

# ---------------------------------------------------------------------------
# sched.Event._fields — complete tuple value and length
# ---------------------------------------------------------------------------

invariant sched_extra6.Event.fields_value:
  description: "sched.Event._fields == ('time', 'priority', 'sequence', 'action', 'argument', 'kwargs')"
  category: event_fields
  kind: python_call_eq
  function: Event._fields.__eq__
  args: [["time", "priority", "sequence", "action", "argument", "kwargs"]]
  expected: true

invariant sched_extra6.Event.fields_len:
  description: "sched.Event._fields.__len__() == 6 — Event has exactly six named fields"
  category: event_fields
  kind: python_call_eq
  function: Event._fields.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# scheduler() instance — __class__.__name__ check in extra6 namespace
# ---------------------------------------------------------------------------

invariant sched_extra6.scheduler.instance_class_name:
  description: "sched.scheduler().__class__.__name__ == 'scheduler'"
  category: class_identity
  kind: python_call_eq
  function: scheduler
  args: []
  method: __class__.__name__.__eq__
  method_args: ["scheduler"]
  expected: true

# ---------------------------------------------------------------------------
# Event.__bases__[0].__name__ — Event is a namedtuple, its base is tuple
# sched_extra3 covers Event.__bases__[0].__name__ == 'tuple' in table form;
# this is a standalone extra6-namespace anchor.
# ---------------------------------------------------------------------------

invariant sched_extra6.Event.base_is_tuple:
  description: "sched.Event.__bases__[0].__name__ == 'tuple' — Event is a namedtuple"
  category: event_identity
  kind: python_call_eq
  function: Event.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# Event._fields indexed access — extra6-namespace anchors
# sched_extra3 covers all 6 fields in a table; sched_extra4 adds standalone
# invariants. This table provides extra6-namespace anchors for fields 0-3.
# ---------------------------------------------------------------------------

table sched_extra6.Event.fields_by_index:
  kind: python_call_eq
  category: event_fields
  id_prefix: field

  columns: [id, function, args, expected]
  rows:
    - [idx0, Event._fields.__getitem__, [0], "time"]
    - [idx1, Event._fields.__getitem__, [1], "priority"]
    - [idx2, Event._fields.__getitem__, [2], "sequence"]
    - [idx3, Event._fields.__getitem__, [3], "action"]
