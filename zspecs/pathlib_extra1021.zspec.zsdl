spec: pathlib_extra1021
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib.Path method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib.Path method __qualname__ strings for filesystem and resolution methods"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1021.path_stat_methods:
  description: "pathlib.Path stat and permission method __qualname__ checks"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pl1021s
  columns: [id, function, args, expected]
  rows:
    - [pl1021s001, pathlib.Path.stat.__qualname__.__eq__,    ["Path.stat"],    true]
    - [pl1021s002, pathlib.Path.chmod.__qualname__.__eq__,   ["Path.chmod"],   true]
    - [pl1021s003, pathlib.Path.lstat.__qualname__.__eq__,   ["Path.lstat"],   true]
    - [pl1021s004, pathlib.Path.lchmod.__qualname__.__eq__,  ["Path.lchmod"],  true]
    - [pl1021s005, pathlib.Path.owner.__qualname__.__eq__,   ["Path.owner"],   true]
    - [pl1021s006, pathlib.Path.group.__qualname__.__eq__,   ["Path.group"],   true]

table pathlib_extra1021.path_link_methods:
