    - [pl1021k003, pathlib.Path.unlink.__qualname__.__eq__,      ["Path.unlink"],      true]
    - [pl1021k004, pathlib.Path.rmdir.__qualname__.__eq__,       ["Path.rmdir"],       true]
    - [pl1021k005, pathlib.Path.rename.__qualname__.__eq__,      ["Path.rename"],      true]
    - [pl1021k006, pathlib.Path.replace.__qualname__.__eq__,     ["Path.replace"],     true]

table pathlib_extra1021.path_resolution_methods:
