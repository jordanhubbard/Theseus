spec: itertools_extra1366
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks for itertools classes."
    - "All itertools types are C extension types defined in Modules/itertoolsmodule.c."
    - "Every C extension type object carries __flags__, __basicsize__, and __itemsize__ as C-level int attributes."
    - "itertools.chain, count, cycle, repeat, accumulate, combinations, product, islice, pairwise all expose these attributes as ints."
    - "Exact integer values for __flags__ and __basicsize__ are platform-specific; only the type (int) is checked here."
    - "__itemsize__ is 0 for all itertools types (no variable-length C struct tail)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra1366.chain_count_cycle_flags_basicsize_itemsize:
  description: "itertools.chain, count, cycle __flags__, __basicsize__, __itemsize__ type checks; all C extension types carry these as int attributes"
  kind: python_call_eq
  category: flags_basicsize_itemsize_checks
  id_prefix: it1366cc
  columns: [id, function, args, expected]
  rows:
    - [it1366cc001, itertools.chain.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [it1366cc002, itertools.chain.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [it1366cc003, itertools.chain.__itemsize__.__class__.__name__.__eq__,  ["int"],  true]
    - [it1366cc004, itertools.count.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [it1366cc005, itertools.count.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [it1366cc006, itertools.cycle.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [it1366cc007, itertools.cycle.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [it1366cc008, itertools.cycle.__itemsize__.__class__.__name__.__eq__,  ["int"],  true]

