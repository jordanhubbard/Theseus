spec: secrets_extra4
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
  notes:
    - "This spec extends secrets.zspec.zsdl, secrets_extra.zspec.zsdl, secrets_extra2.zspec.zsdl, and secrets_extra3.zspec.zsdl."
    - "secrets.zspec.zsdl covers: token_bytes/token_hex/token_urlsafe lengths at 1/8/16/32 bytes; choice single-element; randbelow(1)==0; SystemRandom.__name__."
    - "secrets_extra.zspec.zsdl covers: function __name__ and __module__; return type class checks."
    - "secrets_extra2.zspec.zsdl covers: function __name__ table; token_bytes/token_hex/token_urlsafe __module__; SystemRandom __name__/__module__/__bases__; token_bytes len32; token_hex len 2*n."
    - "secrets_extra3.zspec.zsdl covers: function __module__ invariants; DEFAULT_ENTROPY class and >= 16 check."
    - "This spec adds: __qualname__ attributes for all secrets callables (new axis not in any prior spec); DEFAULT_ENTROPY == 32 (exact value); token_urlsafe length at new sizes (24, 32 bytes); token_bytes length at new sizes (4, 8, 64 bytes); token_hex length at new sizes (4, 32 bytes)."
    - "secrets.token_bytes.__qualname__ == 'token_bytes' — pure function defined in secrets."
    - "secrets.token_hex.__qualname__ == 'token_hex' — pure function defined in secrets."
    - "secrets.token_urlsafe.__qualname__ == 'token_urlsafe' — pure function defined in secrets."
    - "secrets.choice.__qualname__ == 'Random.choice' — bound method; __qualname__ reflects parent class Random."
    - "secrets.randbelow.__qualname__ == 'randbelow' — SystemRandom.randbelow is defined via _randbelow alias."
    - "secrets.randbits.__qualname__ == 'SystemRandom.getrandbits' — randbits is SystemRandom.getrandbits."
    - "secrets.SystemRandom.__qualname__ == 'SystemRandom' — class qualname equals unqualified name at module level."
    - "secrets.DEFAULT_ENTROPY == 32 — CPython 3.9+ sets this to 32 (256-bit); PEP 506 requires >= 32."
    - "len(secrets.token_urlsafe(24)) == 32 — base64url of 24 bytes yields exactly 32 chars (no padding)."
    - "len(secrets.token_urlsafe(32)) == 43 — base64url of 32 bytes yields exactly 43 chars (no padding)."
    - "len(secrets.token_bytes(4)) == 4 — 4-byte vector not tested in any prior spec."
    - "len(secrets.token_bytes(8)) == 8 — 8-byte vector not tested in any prior spec."
    - "len(secrets.token_bytes(64)) == 64 — 64-byte vector not tested in any prior spec."
    - "len(secrets.token_hex(4)) == 8 — 4 bytes yields 8 hex chars."
    - "len(secrets.token_hex(32)) == 64 — 32 bytes yields 64 hex chars."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — new axis; not in any prior secrets* spec
#
# For functions defined directly in the secrets module, __qualname__ == __name__.
# For bound methods on the module-level SystemRandom instance, __qualname__
# reflects the class hierarchy where the method is originally defined:
#   - choice is Random.choice (Random defines it; SystemRandom inherits)
#   - randbits delegates to SystemRandom.getrandbits (overridden in SystemRandom)
#   - randbelow is defined as _randbelow internally; __qualname__ == 'randbelow'
# ---------------------------------------------------------------------------

table secrets_extra4.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,   token_bytes.__qualname__.__eq__,   ["token_bytes"],   true]
    - [token_hex,     token_hex.__qualname__.__eq__,     ["token_hex"],     true]
    - [token_urlsafe, token_urlsafe.__qualname__.__eq__, ["token_urlsafe"], true]
    - [SystemRandom,  SystemRandom.__qualname__.__eq__,  ["SystemRandom"],  true]

invariant secrets_extra4.choice.qualname:
  description: "secrets.choice.__qualname__ == 'Random.choice' — bound method; qualname reflects parent class Random"
  category: qualnames
  kind: python_call_eq
  function: choice.__qualname__.__eq__
  args: ["Random.choice"]
  expected: true

invariant secrets_extra4.randbelow.qualname:
  description: "secrets.randbelow.__qualname__ == 'randbelow' — _randbelow alias in random module"
  category: qualnames
  kind: python_call_eq
  function: randbelow.__qualname__.__eq__
  args: ["randbelow"]
  expected: true

invariant secrets_extra4.randbits.qualname:
  description: "secrets.randbits.__qualname__ == 'SystemRandom.getrandbits' — randbits is SystemRandom.getrandbits"
  category: qualnames
  kind: python_call_eq
  function: randbits.__qualname__.__eq__
  args: ["SystemRandom.getrandbits"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_ENTROPY exact value
#
# secrets_extra3 checks DEFAULT_ENTROPY.__class__.__name__ == 'int' and >= 16.
# This spec adds the exact equality: DEFAULT_ENTROPY == 32.
# ---------------------------------------------------------------------------

invariant secrets_extra4.DEFAULT_ENTROPY.eq_32:
  description: "secrets.DEFAULT_ENTROPY == 32 — CPython 3.9+ sets this to 32 bytes (256 bits)"
  category: constants
  kind: python_call_eq
  function: DEFAULT_ENTROPY.__eq__
  args: [32]
  expected: true

# ---------------------------------------------------------------------------
# token_urlsafe — length at additional byte counts
#
# Formula: ceil(n * 4 / 3) rounded to no-padding base64url length.
# secrets (none), extra, extra2 cover 0/8/16 bytes; extra3 covers none.
# This spec adds 24 bytes (-> 32 chars) and 32 bytes (-> 43 chars).
# ---------------------------------------------------------------------------

invariant secrets_extra4.token_urlsafe.len_24:
  description: "len(secrets.token_urlsafe(24)) == 32 — base64url of 24 bytes yields 32 chars"
  category: token_urlsafe
  kind: python_call_eq
  function: token_urlsafe
  args: [24]
  method: __len__
  expected: 32

invariant secrets_extra4.token_urlsafe.len_32:
  description: "len(secrets.token_urlsafe(32)) == 43 — base64url of 32 bytes yields 43 chars"
  category: token_urlsafe
  kind: python_call_eq
  function: token_urlsafe
  args: [32]
  method: __len__
  expected: 43

# ---------------------------------------------------------------------------
# token_bytes — length at additional byte counts
#
# Prior specs cover 1/16/32 bytes. This spec adds 4, 8, and 64 bytes.
# ---------------------------------------------------------------------------

table secrets_extra4.token_bytes_lengths:
  kind: python_call_eq
  category: token_bytes
  id_prefix: tblen

  columns: [id, function, args, method, expected]
  rows:
    - [len4,  token_bytes, [4],  __len__, 4]
    - [len8,  token_bytes, [8],  __len__, 8]
    - [len64, token_bytes, [64], __len__, 64]

# ---------------------------------------------------------------------------
# token_hex — length at additional byte counts
#
# Prior specs cover 8/16 bytes. This spec adds 4 bytes (-> 8 chars) and
# 32 bytes (-> 64 chars), completing the 4/8/16/32 set.
# ---------------------------------------------------------------------------

table secrets_extra4.token_hex_lengths:
  kind: python_call_eq
  category: token_hex
  id_prefix: thlen

  columns: [id, function, args, method, expected]
  rows:
    - [len4,  token_hex, [4],  __len__, 8]
    - [len32, token_hex, [32], __len__, 64]
