spec: uuid_extra301
version: ">=3.3"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 9562 — Universally Unique IDentifiers (UUID)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.uuid5 and uuid.uuid3 are deterministic: same namespace + name always produces the same UUID."
    - "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org') == '886313e1-3b8a-5372-9b90-0c9aee199e5d' — verified against Python 3.14.3."
    - "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org') == '6fa459ea-ee8a-3ca4-894e-db77e160355e' — verified against Python 3.14.3."
    - "NAMESPACE_DNS == UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8') per RFC 9562 Appendix C."
    - "NAMESPACE_X500 == UUID('6ba7b814-9dad-11d1-80b4-00c04fd430c8') per RFC 9562 Appendix C."
    - "uuid.uuid5 and uuid.uuid3 return a UUID object; __class__.__name__ == 'UUID'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid5 — SHA-1-based deterministic UUID (RFC 9562 §5.5)
# uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org') == '886313e1-3b8a-5372-9b90-0c9aee199e5d'
# ---------------------------------------------------------------------------

invariant uuid_extra301.uuid5.dns_python_org.class_name:
  description: "uuid.uuid5(NAMESPACE_DNS, 'python.org').__class__.__name__ == 'UUID'"
  category: uuid5
  rfc: "RFC 9562 §5.5"
  kind: python_call_eq
  function: uuid5
  args: [{attr: NAMESPACE_DNS}, "python.org"]
  method: __class__.__name__.__eq__
  method_args: ["UUID"]
  expected: true

invariant uuid_extra301.uuid5.dns_python_org.version:
  description: "uuid.uuid5(NAMESPACE_DNS, 'python.org').version == 5"
  category: uuid5
  rfc: "RFC 9562 §5.5"
  kind: python_call_eq
  function: uuid5
  args: [{attr: NAMESPACE_DNS}, "python.org"]
  method: version.__eq__
  method_args: [5]
  expected: true

invariant uuid_extra301.uuid5.dns_python_org.str:
  description: "str(uuid.uuid5(NAMESPACE_DNS, 'python.org')) == '886313e1-3b8a-5372-9b90-0c9aee199e5d' — deterministic vector"
  category: uuid5
  rfc: "RFC 9562 §5.5"
  kind: python_call_eq
  function: uuid5
  args: [{attr: NAMESPACE_DNS}, "python.org"]
  method: __str__
  method_args: []
  expected: "886313e1-3b8a-5372-9b90-0c9aee199e5d"

# ---------------------------------------------------------------------------
# uuid3 — MD5-based deterministic UUID (RFC 9562 §5.3)
# uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org') == '6fa459ea-ee8a-3ca4-894e-db77e160355e'
# ---------------------------------------------------------------------------

invariant uuid_extra301.uuid3.dns_python_org.class_name:
  description: "uuid.uuid3(NAMESPACE_DNS, 'python.org').__class__.__name__ == 'UUID'"
  category: uuid3
  rfc: "RFC 9562 §5.3"
  kind: python_call_eq
  function: uuid3
  args: [{attr: NAMESPACE_DNS}, "python.org"]
  method: __class__.__name__.__eq__
  method_args: ["UUID"]
  expected: true

invariant uuid_extra301.uuid3.dns_python_org.version:
  description: "uuid.uuid3(NAMESPACE_DNS, 'python.org').version == 3"
  category: uuid3
  rfc: "RFC 9562 §5.3"
  kind: python_call_eq
  function: uuid3
  args: [{attr: NAMESPACE_DNS}, "python.org"]
  method: version.__eq__
  method_args: [3]
  expected: true

invariant uuid_extra301.uuid3.dns_python_org.str:
  description: "str(uuid.uuid3(NAMESPACE_DNS, 'python.org')) == '6fa459ea-ee8a-3ca4-894e-db77e160355e' — deterministic vector"
  category: uuid3
  rfc: "RFC 9562 §5.3"
  kind: python_call_eq
  function: uuid3
  args: [{attr: NAMESPACE_DNS}, "python.org"]
  method: __str__
  method_args: []
  expected: "6fa459ea-ee8a-3ca4-894e-db77e160355e"

# ---------------------------------------------------------------------------
# NAMESPACE_X500 — predefined UUID namespace constant (RFC 9562 Appendix C)
# ---------------------------------------------------------------------------

invariant uuid_extra301.NAMESPACE_X500.class_name:
  description: "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'"
  category: namespaces
  rfc: "RFC 9562 Appendix C"
  kind: python_call_eq
  function: NAMESPACE_X500.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true
