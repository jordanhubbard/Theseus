spec: decimal_extra274
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification, Version 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "decimal_extra273 covers to_integral_value ROUND_HALF_EVEN, quantize, str repr of 0.1/0.3/1.21, equality with int."
    - "This spec focuses on str() representations of special and formatted Decimal values."
    - "str(Decimal('1.0')) == '1.0' — trailing zero after decimal point is preserved."
    - "str(Decimal('0.00')) == '0.00' — two trailing zeros after decimal point are preserved."
    - "str(Decimal('1E+2')) == '1E+2' — engineering/scientific notation is preserved as-is when constructed that way."
    - "str(Decimal('Infinity')) == 'Infinity' — positive infinity special value."
    - "str(Decimal('-Infinity')) == '-Infinity' — negative infinity special value."
    - "str(Decimal('NaN')) == 'NaN' — not-a-number special value."
    - "str(Decimal('0')) == '0' — plain zero has no decimal point."
    - "str(Decimal('-0')) == '-0' — negative zero is distinct from positive zero in decimal arithmetic."
    - "str(Decimal('1.50')) == '1.50' — trailing zero in fractional part is preserved."
    - "str(Decimal('100')) == '100' — integer value without notation; no trailing point."
    - "Decimal('Infinity').is_infinite() == True; Decimal('1.0').is_infinite() == False."
    - "Decimal('NaN').is_nan() == True; Decimal('1.0').is_nan() == False."
    - "Decimal('1.0').is_finite() == True; Decimal('Infinity').is_finite() == False."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# str() representation of Decimal values — exact decimal encoding preserved
# Decimal preserves the exact string used for construction, including trailing
# zeros, scientific notation, and special values.
# ---------------------------------------------------------------------------

table decimal_extra274.str_repr:
  description: "str(Decimal(...)) — string representation preserves construction form"
  kind: python_call_eq
  category: string_repr
  id_prefix: str
  function: Decimal
  method: __str__

  columns: [id, args, expected, description]
  rows:
    - [one_point_zero,  ["1.0"],      "1.0",       "str(Decimal('1.0')) == '1.0' — trailing zero after decimal point preserved"]
    - [zero_dot_zero,   ["0.00"],     "0.00",       "str(Decimal('0.00')) == '0.00' — two trailing zeros preserved"]
    - [sci_notation,    ["1E+2"],     "1E+2",       "str(Decimal('1E+2')) == '1E+2' — scientific notation preserved as-is"]
    - [infinity,        ["Infinity"], "Infinity",   "str(Decimal('Infinity')) == 'Infinity' — positive infinity special value"]
    - [neg_infinity,    ["-Infinity"], "-Infinity", "str(Decimal('-Infinity')) == '-Infinity' — negative infinity special value"]
    - [nan,             ["NaN"],      "NaN",        "str(Decimal('NaN')) == 'NaN' — not-a-number special value"]
    - [plain_zero,      ["0"],        "0",          "str(Decimal('0')) == '0' — zero with no decimal point"]
    - [neg_zero,        ["-0"],       "-0",         "str(Decimal('-0')) == '-0' — negative zero is distinct from zero"]

# ---------------------------------------------------------------------------
# Special value predicates — is_signed
# Decimal('-0').is_signed() == True; Decimal('0').is_signed() == False
# Decimal('-1').is_signed() == True; Decimal('1').is_signed() == False
# ---------------------------------------------------------------------------

table decimal_extra274.is_signed:
  description: "Decimal.is_signed() — True when the Decimal has a negative sign bit"
  kind: python_call_eq
  category: predicates
  id_prefix: signed
  function: Decimal
  method: is_signed

  columns: [id, args, expected, description]
  rows:
    - [neg_zero,     ["-0"],        true,  "Decimal('-0').is_signed() == True — negative zero carries a negative sign bit"]
    - [pos_zero,     ["0"],         false, "Decimal('0').is_signed() == False — positive zero has no negative sign bit"]
    - [neg_one,      ["-1"],        true,  "Decimal('-1').is_signed() == True — negative value has a negative sign bit"]
    - [pos_one,      ["1"],         false, "Decimal('1').is_signed() == False — positive value has no negative sign bit"]

# ---------------------------------------------------------------------------
# Special value predicates — is_infinite, is_nan, is_finite (standalone)
# ---------------------------------------------------------------------------

invariant decimal_extra274.is_infinite.infinity_true:
  description: "Decimal('Infinity').is_infinite() == True — Infinity is an infinite value"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["Infinity"]
  method: is_infinite
  expected: true

invariant decimal_extra274.is_infinite.finite_false:
  description: "Decimal('1.0').is_infinite() == False — a regular decimal value is not infinite"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1.0"]
  method: is_infinite
  expected: false

invariant decimal_extra274.is_nan.nan_true:
  description: "Decimal('NaN').is_nan() == True — NaN is a not-a-number value"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_nan
  expected: true

invariant decimal_extra274.is_nan.finite_false:
  description: "Decimal('1.0').is_nan() == False — a regular decimal value is not NaN"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1.0"]
  method: is_nan
  expected: false

invariant decimal_extra274.is_finite.finite_true:
  description: "Decimal('1.0').is_finite() == True — regular decimal values are finite"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1.0"]
  method: is_finite
  expected: true

invariant decimal_extra274.is_finite.infinity_false:
  description: "Decimal('Infinity').is_finite() == False — Infinity is not a finite value"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["Infinity"]
  method: is_finite
  expected: false

# ---------------------------------------------------------------------------
# Additional str repr — trailing zeros and integer forms
# ---------------------------------------------------------------------------

invariant decimal_extra274.str_repr.one_point_five_zero:
  description: "str(Decimal('1.50')) == '1.50' — two-digit fractional part with trailing zero preserved"
  category: string_repr
  kind: python_call_eq
  function: Decimal
  args: ["1.50"]
  method: __str__
  expected: "1.50"

invariant decimal_extra274.str_repr.hundred:
  description: "str(Decimal('100')) == '100' — integer-valued Decimal has no decimal point in str()"
  category: string_repr
  kind: python_call_eq
  function: Decimal
  args: ["100"]
  method: __str__
  expected: "100"
