spec: string_extra12
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra11.zspec.zsdl."
    - "string_extra11 covers: digits.startswith('0'); octdigits.endswith('7'); hexdigits.endswith('F'); Formatter.format two kwargs; Formatter.format no placeholder; Template brace-delimited substitute; capwords lowercase/all-caps multi-word."
    - "string_extra6 covers: whitespace CR/tab membership; punctuation !/@/not-a membership; ascii_letters z/Z/not-0 membership; capwords with sep."
    - "string_extra7 covers: hexdigits contains A/f (uppercase/lowercase hex letters)."
    - "string_extra9 covers: ascii_letters.endswith('Z')."
    - "NOT yet covered in any prior spec: hexdigits.startswith('0'); octdigits.startswith('0'); printable.startswith('0'); punctuation.startswith('!')."
    - "NOT yet covered in any prior spec: Formatter().vformat('{0} {1}', ['hello', 'world'], {}) == 'hello world'."
    - "NOT yet covered in any prior spec: capwords('fox in a box') == 'Fox In A Box' — four-word input."
    - "NOT yet covered in any prior spec: Template('$name!').substitute(name='World') == 'World!' — exclamation suffix."
    - "hexdigits.startswith('0') — '0123456789abcdefABCDEF' begins with '0'."
    - "octdigits.startswith('0') — '01234567' begins with '0'."
    - "printable.startswith('0') — printable begins with '0'."
    - "punctuation.startswith('!') — punctuation begins with '!'."
    - "Formatter().vformat('{0} {1}', ['hello', 'world'], {}) == 'hello world' — positional via list."
    - "capwords('fox in a box') == 'Fox In A Box' — four words, each capitalized."
    - "Template('$name!').substitute(name='World') == 'World!' — suffix follows identifier."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hexdigits, octdigits, printable, punctuation — startswith checks
#
# string_extra11 covers hexdigits.endswith('F'), octdigits.endswith('7'),
# digits.startswith('0').
# No prior spec checks hexdigits.startswith('0'), octdigits.startswith('0'),
# printable.startswith('0'), or punctuation.startswith('!').
# All four constants begin with those characters.
# ---------------------------------------------------------------------------

invariant string_extra12.hexdigits.startswith_zero:
  description: "string.hexdigits.startswith('0') == True — '0123456789abcdefABCDEF' begins with '0'"
  category: constants
  kind: python_call_eq
  function: hexdigits.startswith
  args: ["0"]
  expected: true

invariant string_extra12.octdigits.startswith_zero:
  description: "string.octdigits.startswith('0') == True — '01234567' begins with '0'"
  category: constants
  kind: python_call_eq
  function: octdigits.startswith
  args: ["0"]
  expected: true

invariant string_extra12.printable.startswith_zero:
  description: "string.printable.startswith('0') == True — printable begins with '0'"
  category: constants
  kind: python_call_eq
  function: printable.startswith
  args: ["0"]
  expected: true

invariant string_extra12.punctuation.startswith_exclamation:
  description: "string.punctuation.startswith('!') == True — punctuation begins with '!'"
  category: constants
  kind: python_call_eq
  function: punctuation.startswith
  args: ["!"]
  expected: true

# ---------------------------------------------------------------------------
# Formatter().vformat — positional args via list
#
# string_extra11 covers Formatter().format('{0}', 'world') and
# Formatter().format('{x}+{y}', x='a', y='b').
# No prior spec covers the lower-level vformat method which accepts
# a positional args list and a kwargs dict directly.
# Formatter().vformat('{0} {1}', ['hello', 'world'], {}) == 'hello world'.
# ---------------------------------------------------------------------------

invariant string_extra12.Formatter.vformat_positional:
  description: "string.Formatter().vformat('{0} {1}', ['hello', 'world'], {}) == 'hello world'"
  category: Formatter
  kind: python_call_eq
  function: Formatter
  args: []
  method: vformat
  method_args: ["{0} {1}", ["hello", "world"], {}]
  expected: "hello world"

# ---------------------------------------------------------------------------
# capwords — four-word input
#
# string_extra9 covers capwords two-word and three-word inputs.
# string_extra11 covers capwords with one word (lowercase and all-caps).
# No prior spec uses a four-word input: capwords('fox in a box') == 'Fox In A Box'.
# ---------------------------------------------------------------------------

invariant string_extra12.capwords.four_words:
  description: "string.capwords('fox in a box') == 'Fox In A Box' — four words each capitalized"
  category: capwords
  kind: python_call_eq
  function: capwords
  args: ["fox in a box"]
  expected: "Fox In A Box"

# ---------------------------------------------------------------------------
# Template — suffix immediately following identifier
#
# string_extra11 covers Template('${greeting} world').substitute(greeting='Hi').
# string_extra10 covers Template('$greeting world').substitute(greeting='Hello').
# No prior spec tests a Template where the substituted variable is immediately
# followed by a non-space character ('!') requiring the braced ${name} form
# is not needed when the suffix is punctuation, only alphanumeric adjacency
# requires bracing. '$name!' — '!' is not alphanumeric so $name is unambiguous.
# Template('$name!').substitute(name='World') == 'World!'.
# ---------------------------------------------------------------------------

invariant string_extra12.Template.substitute_punctuation_suffix:
  description: "string.Template('$name!').substitute(name='World') == 'World!' — punctuation suffix"
  category: Template
  kind: python_call_eq
  function: Template
  args: ["$name!"]
  method: substitute
  method_args: []
  kwargs: {name: "World"}
  expected: "World!"

# ---------------------------------------------------------------------------
# Table: constant startswith boundary checks
#
# Groups the four startswith invariants in one indexed table for compact
# reference. No prior spec provides this table.
# ---------------------------------------------------------------------------

table string_extra12.constant_startswith:
  description: "Leading character checks for string module constants"
  kind: python_call_eq
  category: constants
  id_prefix: sw

  columns: [id, function, args, expected]
  rows:
    - [hexdigits_0,    hexdigits.startswith,   ["0"], true]
    - [octdigits_0,    octdigits.startswith,   ["0"], true]
    - [printable_0,    printable.startswith,   ["0"], true]
    - [punctuation_ex, punctuation.startswith, ["!"], true]
