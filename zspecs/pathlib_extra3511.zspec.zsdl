spec: pp3511
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (pp3511): __get__, __set__, __delete__ dict-presence checks for pathlib types."
    - "All values false — pathlib path types do not implement the descriptor protocol."
    - "pathlib.PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath: none define __get__, __set__, or __delete__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table pp3511.get:
  description: "pathlib types __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3511
  columns: [id, function, args, expected]
  rows:
    - ["pp3511001", operator.contains, [pathlib.PurePath.__dict__,        "__get__"], false]
    - ["pp3511002", operator.contains, [pathlib.PurePosixPath.__dict__,   "__get__"], false]
    - ["pp3511003", operator.contains, [pathlib.PureWindowsPath.__dict__, "__get__"], false]
    - ["pp3511004", operator.contains, [pathlib.Path.__dict__,            "__get__"], false]
    - ["pp3511005", operator.contains, [pathlib.PosixPath.__dict__,       "__get__"], false]

