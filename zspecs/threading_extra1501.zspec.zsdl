spec: threading_extra1501
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 547 theme: __await__, __aiter__, __anext__ async protocol checks and __aenter__/__aexit__ async context manager checks for threading classes."
    - "threading.Thread: no async protocol methods in __dict__. Verified with Python 3.12."
    - "threading.Semaphore: no async protocol methods in __dict__. Has synchronous __enter__ and __exit__. Verified with Python 3.12."
    - "threading.Condition: no async protocol methods in __dict__. Has synchronous __enter__ and __exit__. Verified with Python 3.12."
    - "threading.Event: no async protocol methods in __dict__. Verified with Python 3.12."
    - "threading.Barrier: no async protocol methods in __dict__. Verified with Python 3.12."
    - "All threading synchronization primitives implement only the synchronous threading protocol; none implement any async protocol."
    - "Semaphore and Condition are synchronous context managers (__enter__/__exit__) but not async context managers (__aenter__/__aexit__)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread and threading.Event — async protocol absence checks
#
# Wave 547 theme: Thread runs a function in a separate thread; Event is a
# simple synchronization flag.
#
# threading.Thread.__dict__.__contains__("__await__") == False
# threading.Thread.__dict__.__contains__("__aiter__") == False
# threading.Thread.__dict__.__contains__("__anext__") == False
# threading.Thread.__dict__.__contains__("__aenter__") == False
# threading.Thread.__dict__.__contains__("__aexit__") == False
# threading.Event.__dict__.__contains__("__await__") == False
#
# Both are synchronous threading primitives. Thread has __init__ and __repr__
# but no async protocol. Event has __init__ but no async protocol.
# New to extra1501.
# ---------------------------------------------------------------------------

table threading_extra1501.thread_event_async_protocol_absence:
  description: "threading.Thread and Event have no async protocol methods in __dict__; both are synchronous threading primitives; wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1501te

  columns: [id, function, args, expected, description]
  rows:
    - [th1501te001,
       "Thread.__dict__.__contains__",
       ["__await__"],
       false,
       "threading.Thread.__dict__.__contains__('__await__') == False — Thread is a synchronous threading primitive that runs a target function in a separate OS thread; it does not implement the awaitable protocol; __await__ is not in Thread.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501te002,
       "Thread.__dict__.__contains__",
       ["__aiter__"],
       false,
       "threading.Thread.__dict__.__contains__('__aiter__') == False — Thread does not implement the async iterator protocol; __aiter__ is not in Thread.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501te003,
       "Thread.__dict__.__contains__",
       ["__anext__"],
       false,
       "threading.Thread.__dict__.__contains__('__anext__') == False — Thread does not implement the async iterator protocol; __anext__ is not in Thread.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501te004,
       "Thread.__dict__.__contains__",
       ["__aenter__"],
       false,
       "threading.Thread.__dict__.__contains__('__aenter__') == False — Thread does not implement the async context manager protocol; __aenter__ is not in Thread.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501te005,
       "Thread.__dict__.__contains__",
       ["__aexit__"],
       false,
       "threading.Thread.__dict__.__contains__('__aexit__') == False — Thread does not implement the async context manager protocol; __aexit__ is not in Thread.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501te006,
       "Event.__dict__.__contains__",
       ["__await__"],
       false,
       "threading.Event.__dict__.__contains__('__await__') == False — Event is a synchronous thread-safe flag that threads can wait on; it does not implement the awaitable protocol; __await__ is not in Event.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501te007,
       "Thread.__dict__.__contains__",
       ["__init__"],
       true,
       "threading.Thread.__dict__.__contains__('__init__') == True — Thread defines __init__ in its __dict__ for constructing thread objects with a target function and arguments; this is its primary synchronous construction interface; verified with Python 3.12; new to extra1501"]
    - [th1501te008,
       "Event.__dict__.__contains__",
       ["__init__"],
       true,
       "threading.Event.__dict__.__contains__('__init__') == True — Event defines __init__ in its __dict__ for constructing event objects; this is its primary synchronous construction interface; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore and threading.Condition — async protocol
# absence checks
#
# Wave 547 theme: Semaphore is a counting lock; Condition provides
# wait/notify coordination.
#
# threading.Semaphore.__dict__.__contains__("__await__") == False
# threading.Semaphore.__dict__.__contains__("__aiter__") == False
# threading.Semaphore.__dict__.__contains__("__aenter__") == False
# threading.Semaphore.__dict__.__contains__("__aexit__") == False
# threading.Condition.__dict__.__contains__("__await__") == False
# threading.Condition.__dict__.__contains__("__aenter__") == False
#
# Both have synchronous __enter__ and __exit__ but no async counterparts.
# New to extra1501.
# ---------------------------------------------------------------------------

table threading_extra1501.semaphore_condition_async_protocol_absence:
  description: "threading.Semaphore and Condition have no async protocol methods in __dict__; both are synchronous context managers only (__enter__/__exit__); wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1501sc

  columns: [id, function, args, expected, description]
  rows:
    - [th1501sc001,
       "Semaphore.__dict__.__contains__",
       ["__await__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__await__') == False — Semaphore is a synchronous counting lock primitive; it does not implement the awaitable protocol; __await__ is not in Semaphore.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501sc002,
       "Semaphore.__dict__.__contains__",
       ["__aiter__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__aiter__') == False — Semaphore does not implement the async iterator protocol; __aiter__ is not in Semaphore.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501sc003,
       "Semaphore.__dict__.__contains__",
       ["__aenter__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__aenter__') == False — Semaphore is a synchronous context manager (__enter__/__exit__) but does NOT implement the async context manager protocol; __aenter__ is not in Semaphore.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501sc004,
       "Semaphore.__dict__.__contains__",
       ["__aexit__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__aexit__') == False — Semaphore does not implement the async context manager protocol; __aexit__ is not in Semaphore.__dict__; the synchronous __exit__ IS present but the async counterpart is absent; verified with Python 3.12; new to extra1501"]
    - [th1501sc005,
       "Condition.__dict__.__contains__",
       ["__await__"],
       false,
       "threading.Condition.__dict__.__contains__('__await__') == False — Condition is a synchronous coordination primitive providing wait/notify semantics; it does not implement the awaitable protocol; __await__ is not in Condition.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501sc006,
       "Condition.__dict__.__contains__",
       ["__aenter__"],
       false,
       "threading.Condition.__dict__.__contains__('__aenter__') == False — Condition is a synchronous context manager (__enter__/__exit__) but does NOT implement the async context manager protocol; __aenter__ is not in Condition.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501sc007,
       "Semaphore.__dict__.__contains__",
       ["__enter__"],
       true,
       "threading.Semaphore.__dict__.__contains__('__enter__') == True — Semaphore IS a synchronous context manager and defines __enter__ in its __dict__; this is the synchronous counterpart to the absent __aenter__; verified with Python 3.12; new to extra1501"]
    - [th1501sc008,
       "Condition.__dict__.__contains__",
       ["__enter__"],
       true,
       "threading.Condition.__dict__.__contains__('__enter__') == True — Condition IS a synchronous context manager and defines __enter__ in its __dict__; this is the synchronous counterpart to the absent __aenter__; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier — async protocol absence checks
#
# Wave 547 theme: threading.Barrier — a synchronization barrier that blocks
# until a fixed number of threads have reached it.
#
# threading.Barrier.__dict__.__contains__("__await__") == False
# threading.Barrier.__dict__.__contains__("__aiter__") == False
# threading.Barrier.__dict__.__contains__("__anext__") == False
# threading.Barrier.__dict__.__contains__("__aenter__") == False
# threading.Barrier.__dict__.__contains__("__aexit__") == False
#
# Barrier is a synchronous threading primitive. It has __init__ but no
# async protocol methods and no synchronous __enter__/__exit__ either.
# New to extra1501.
# ---------------------------------------------------------------------------

table threading_extra1501.barrier_async_protocol_absence:
  description: "threading.Barrier has no async protocol methods in __dict__; Barrier is a synchronous thread synchronization primitive; wave 547; new to extra1501"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1501br

  columns: [id, function, args, expected, description]
  rows:
    - [th1501br001,
       "Barrier.__dict__.__contains__",
       ["__await__"],
       false,
       "threading.Barrier.__dict__.__contains__('__await__') == False — Barrier is a synchronous threading primitive that blocks all participating threads until the required number have called wait(); it does not implement the awaitable protocol; __await__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501br002,
       "Barrier.__dict__.__contains__",
       ["__aiter__"],
       false,
       "threading.Barrier.__dict__.__contains__('__aiter__') == False — Barrier does not implement the async iterator protocol; __aiter__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501br003,
       "Barrier.__dict__.__contains__",
       ["__anext__"],
       false,
       "threading.Barrier.__dict__.__contains__('__anext__') == False — Barrier does not implement the async iterator protocol; __anext__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501br004,
       "Barrier.__dict__.__contains__",
       ["__aenter__"],
       false,
       "threading.Barrier.__dict__.__contains__('__aenter__') == False — Barrier does not implement the async context manager protocol; __aenter__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501br005,
       "Barrier.__dict__.__contains__",
       ["__aexit__"],
       false,
       "threading.Barrier.__dict__.__contains__('__aexit__') == False — Barrier does not implement the async context manager protocol; __aexit__ is not in Barrier.__dict__; verified with Python 3.12; new to extra1501"]
    - [th1501br006,
       "Barrier.__dict__.__contains__",
       ["__init__"],
       true,
       "threading.Barrier.__dict__.__contains__('__init__') == True — Barrier defines __init__ in its __dict__ for constructing barrier objects with the required party count; this is its primary synchronous construction interface; verified with Python 3.12; new to extra1501"]
    - [th1501br007,
       "Barrier.__dict__.__contains__",
       ["__repr__"],
       true,
       "threading.Barrier.__dict__.__contains__('__repr__') == True — Barrier defines __repr__ in its __dict__ providing a human-readable representation of the barrier state including party count and wait count; part of its synchronous display interface; verified with Python 3.12; new to extra1501"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1501
# ---------------------------------------------------------------------------

invariant threading_extra1501.thread_no_await:
  description: "threading.Thread.__dict__ does not contain '__await__' — Thread is a synchronous threading primitive, not an awaitable; wave 547; new to extra1501"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant threading_extra1501.thread_no_aenter:
  description: "threading.Thread.__dict__ does not contain '__aenter__' — Thread does not implement the async context manager protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["__aenter__"]
  expected: false

invariant threading_extra1501.semaphore_no_await:
  description: "threading.Semaphore.__dict__ does not contain '__await__' — Semaphore is a synchronous counting lock, not an awaitable; wave 547; new to extra1501"
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant threading_extra1501.semaphore_no_aenter:
  description: "threading.Semaphore.__dict__ does not contain '__aenter__' — Semaphore implements synchronous __enter__ but not async __aenter__; wave 547; new to extra1501"
  kind: python_call_eq
  function: Semaphore.__dict__.__contains__
  args: ["__aenter__"]
  expected: false

invariant threading_extra1501.condition_no_aiter:
  description: "threading.Condition.__dict__ does not contain '__aiter__' — Condition does not implement the async iterator protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: Condition.__dict__.__contains__
  args: ["__aiter__"]
  expected: false

invariant threading_extra1501.barrier_no_await:
  description: "threading.Barrier.__dict__ does not contain '__await__' — Barrier is a synchronous thread synchronization primitive, not an awaitable; wave 547; new to extra1501"
  kind: python_call_eq
  function: Barrier.__dict__.__contains__
  args: ["__await__"]
  expected: false

invariant threading_extra1501.barrier_no_aenter:
  description: "threading.Barrier.__dict__ does not contain '__aenter__' — Barrier does not implement the async context manager protocol; wave 547; new to extra1501"
  kind: python_call_eq
  function: Barrier.__dict__.__contains__
  args: ["__aenter__"]
  expected: false
