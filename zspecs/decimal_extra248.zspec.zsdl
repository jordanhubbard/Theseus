spec: decimal_extra248
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers decimal.Context method identity: add, subtract, multiply, divide, power, sqrt, quantize, compare, create_decimal, clear_flags."
    - "All decimal.Context methods are C-level method_descriptor objects; their __class__.__name__ is 'method_descriptor'."
    - "All Context methods are defined directly on Context, so their __qualname__ values carry the 'Context.' prefix (e.g., decimal.Context.add.__qualname__ == 'Context.add')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Context arithmetic method __name__ identity
#
# add, subtract, multiply, divide, power, sqrt are the core arithmetic
# methods on Context. All are method_descriptor objects defined in the
# _decimal C extension.
# ---------------------------------------------------------------------------

table decimal_extra248.context_arithmetic_method_names:
  description: "decimal.Context arithmetic method __name__ identity — add, subtract, multiply, divide, power, sqrt; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: decxcamn248

  columns: [id, function, args, expected, description]
  rows:
    - [add_name,
       "Context.add.__name__.__eq__",
       ["add"],
       true,
       "decimal.Context.add.__name__.__eq__('add') == True — Context.add is a method_descriptor for adding two Decimal values using the context's precision and rounding; its __name__ is 'add'; str.__eq__('add') returns True; new to extra248"]
    - [subtract_name,
       "Context.subtract.__name__.__eq__",
       ["subtract"],
       true,
       "decimal.Context.subtract.__name__.__eq__('subtract') == True — Context.subtract is a method_descriptor for subtracting two Decimal values using the context settings; its __name__ is 'subtract'; str.__eq__('subtract') returns True; new to extra248"]
    - [multiply_name,
       "Context.multiply.__name__.__eq__",
       ["multiply"],
       true,
       "decimal.Context.multiply.__name__.__eq__('multiply') == True — Context.multiply is a method_descriptor for multiplying two Decimal values using the context settings; its __name__ is 'multiply'; str.__eq__('multiply') returns True; new to extra248"]
    - [divide_name,
       "Context.divide.__name__.__eq__",
       ["divide"],
       true,
       "decimal.Context.divide.__name__.__eq__('divide') == True — Context.divide is a method_descriptor for dividing two Decimal values using the context settings; its __name__ is 'divide'; str.__eq__('divide') returns True; new to extra248"]
    - [power_name,
       "Context.power.__name__.__eq__",
       ["power"],
       true,
       "decimal.Context.power.__name__.__eq__('power') == True — Context.power is a method_descriptor for raising a Decimal to a power using the context settings; its __name__ is 'power'; str.__eq__('power') returns True; new to extra248"]
    - [sqrt_name,
       "Context.sqrt.__name__.__eq__",
       ["sqrt"],
       true,
       "decimal.Context.sqrt.__name__.__eq__('sqrt') == True — Context.sqrt is a method_descriptor for returning the square root of a Decimal using the context's precision; its __name__ is 'sqrt'; str.__eq__('sqrt') returns True; new to extra248"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Context utility method __name__ identity
#
# quantize, compare, create_decimal, clear_flags are context utility methods.
# All are method_descriptor objects defined in the _decimal C extension.
# ---------------------------------------------------------------------------

table decimal_extra248.context_utility_method_names:
  description: "decimal.Context utility method __name__ identity — quantize, compare, create_decimal, clear_flags; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: decxcumn248

  columns: [id, function, args, expected, description]
  rows:
    - [quantize_name,
       "Context.quantize.__name__.__eq__",
       ["quantize"],
       true,
       "decimal.Context.quantize.__name__.__eq__('quantize') == True — Context.quantize is a method_descriptor for rounding a Decimal to the exponent of the second operand using the context; its __name__ is 'quantize'; str.__eq__('quantize') returns True; new to extra248"]
    - [compare_name,
       "Context.compare.__name__.__eq__",
       ["compare"],
       true,
       "decimal.Context.compare.__name__.__eq__('compare') == True — Context.compare is a method_descriptor for comparing two Decimal values numerically within the context; its __name__ is 'compare'; str.__eq__('compare') returns True; new to extra248"]
    - [create_decimal_name,
       "Context.create_decimal.__name__.__eq__",
       ["create_decimal"],
       true,
       "decimal.Context.create_decimal.__name__.__eq__('create_decimal') == True — Context.create_decimal is a method_descriptor for creating a Decimal from a value using the context's precision and rounding; its __name__ is 'create_decimal'; str.__eq__('create_decimal') returns True; new to extra248"]
    - [clear_flags_name,
       "Context.clear_flags.__name__.__eq__",
       ["clear_flags"],
       true,
       "decimal.Context.clear_flags.__name__.__eq__('clear_flags') == True — Context.clear_flags is a method_descriptor for resetting all of the context's signal flags to zero; its __name__ is 'clear_flags'; str.__eq__('clear_flags') returns True; new to extra248"]
    - [quantize_class,
       "Context.quantize.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Context.quantize.__class__.__name__.__eq__('method_descriptor') == True — Context.quantize is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra248"]
    - [clear_flags_class,
       "Context.clear_flags.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Context.clear_flags.__class__.__name__.__eq__('method_descriptor') == True — Context.clear_flags is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra248"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Context method __qualname__ identity
#
# All Context methods are defined directly on Context, so their __qualname__
# values carry the 'Context.' prefix.
# ---------------------------------------------------------------------------

table decimal_extra248.context_method_qualnames:
  description: "decimal.Context method __qualname__ identity — all use 'Context.' prefix; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: decxcmq248

  columns: [id, function, args, expected, description]
  rows:
    - [add_qualname,
       "Context.add.__qualname__.__eq__",
       ["Context.add"],
       true,
       "decimal.Context.add.__qualname__.__eq__('Context.add') == True — add is defined directly on Context; its __qualname__ is 'Context.add'; str.__eq__('Context.add') returns True; new to extra248"]
    - [subtract_qualname,
       "Context.subtract.__qualname__.__eq__",
       ["Context.subtract"],
       true,
       "decimal.Context.subtract.__qualname__.__eq__('Context.subtract') == True — subtract is defined directly on Context; its __qualname__ is 'Context.subtract'; str.__eq__('Context.subtract') returns True; new to extra248"]
    - [multiply_qualname,
       "Context.multiply.__qualname__.__eq__",
       ["Context.multiply"],
       true,
       "decimal.Context.multiply.__qualname__.__eq__('Context.multiply') == True — multiply is defined directly on Context; its __qualname__ is 'Context.multiply'; str.__eq__('Context.multiply') returns True; new to extra248"]
    - [divide_qualname,
       "Context.divide.__qualname__.__eq__",
       ["Context.divide"],
       true,
       "decimal.Context.divide.__qualname__.__eq__('Context.divide') == True — divide is defined directly on Context; its __qualname__ is 'Context.divide'; str.__eq__('Context.divide') returns True; new to extra248"]
    - [power_qualname,
       "Context.power.__qualname__.__eq__",
       ["Context.power"],
       true,
       "decimal.Context.power.__qualname__.__eq__('Context.power') == True — power is defined directly on Context; its __qualname__ is 'Context.power'; str.__eq__('Context.power') returns True; new to extra248"]
    - [sqrt_qualname,
       "Context.sqrt.__qualname__.__eq__",
       ["Context.sqrt"],
       true,
       "decimal.Context.sqrt.__qualname__.__eq__('Context.sqrt') == True — sqrt is defined directly on Context; its __qualname__ is 'Context.sqrt'; str.__eq__('Context.sqrt') returns True; new to extra248"]
    - [quantize_qualname,
       "Context.quantize.__qualname__.__eq__",
       ["Context.quantize"],
       true,
       "decimal.Context.quantize.__qualname__.__eq__('Context.quantize') == True — quantize is defined directly on Context; its __qualname__ is 'Context.quantize'; str.__eq__('Context.quantize') returns True; new to extra248"]
    - [compare_qualname,
       "Context.compare.__qualname__.__eq__",
       ["Context.compare"],
       true,
       "decimal.Context.compare.__qualname__.__eq__('Context.compare') == True — compare is defined directly on Context; its __qualname__ is 'Context.compare'; str.__eq__('Context.compare') returns True; new to extra248"]
    - [create_decimal_qualname,
       "Context.create_decimal.__qualname__.__eq__",
       ["Context.create_decimal"],
       true,
       "decimal.Context.create_decimal.__qualname__.__eq__('Context.create_decimal') == True — create_decimal is defined directly on Context; its __qualname__ is 'Context.create_decimal'; str.__eq__('Context.create_decimal') returns True; new to extra248"]
    - [clear_flags_qualname,
       "Context.clear_flags.__qualname__.__eq__",
       ["Context.clear_flags"],
       true,
       "decimal.Context.clear_flags.__qualname__.__eq__('Context.clear_flags') == True — clear_flags is defined directly on Context; its __qualname__ is 'Context.clear_flags'; str.__eq__('Context.clear_flags') returns True; new to extra248"]

# ---------------------------------------------------------------------------
# Table 4: decimal.Context method __class__.__name__ — all are method_descriptor
# ---------------------------------------------------------------------------

table decimal_extra248.context_method_class_names:
  description: "decimal.Context method __class__.__name__ — all are 'method_descriptor'; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: decxcmcn248

  columns: [id, function, args, expected, description]
  rows:
    - [add_class,
       "Context.add.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Context.add.__class__.__name__.__eq__('method_descriptor') == True — Context.add is a C-level method_descriptor, not a Python function; str.__eq__('method_descriptor') returns True; new to extra248"]
    - [subtract_class,
       "Context.subtract.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Context.subtract.__class__.__name__.__eq__('method_descriptor') == True — Context.subtract is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra248"]
    - [multiply_class,
       "Context.multiply.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Context.multiply.__class__.__name__.__eq__('method_descriptor') == True — Context.multiply is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra248"]
    - [divide_class,
       "Context.divide.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Context.divide.__class__.__name__.__eq__('method_descriptor') == True — Context.divide is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra248"]
    - [power_class,
       "Context.power.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Context.power.__class__.__name__.__eq__('method_descriptor') == True — Context.power is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra248"]
    - [sqrt_class,
       "Context.sqrt.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "decimal.Context.sqrt.__class__.__name__.__eq__('method_descriptor') == True — Context.sqrt is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra248"]

# ---------------------------------------------------------------------------
# Standalone invariants — decimal_extra248
# ---------------------------------------------------------------------------

invariant decimal_extra248.context_add_name:
  description: "decimal.Context.add.__name__ == 'add' — Context.add performs addition using the context's precision and rounding mode; new to extra248"
  kind: python_call_eq
  function: Context.add.__name__.__eq__
  args: ["add"]
  expected: true

invariant decimal_extra248.context_divide_name:
  description: "decimal.Context.divide.__name__ == 'divide' — Context.divide performs division using the context settings; new to extra248"
  kind: python_call_eq
  function: Context.divide.__name__.__eq__
  args: ["divide"]
  expected: true

invariant decimal_extra248.context_add_qualname:
  description: "decimal.Context.add.__qualname__ == 'Context.add' — add is defined directly on Context; new to extra248"
  kind: python_call_eq
  function: Context.add.__qualname__.__eq__
  args: ["Context.add"]
  expected: true

invariant decimal_extra248.context_add_is_method_descriptor:
  description: "decimal.Context.add.__class__.__name__ == 'method_descriptor' — all Context methods are C-level method_descriptors; new to extra248"
  kind: python_call_eq
  function: Context.add.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra248.context_create_decimal_name:
  description: "decimal.Context.create_decimal.__name__ == 'create_decimal' — create_decimal creates a Decimal using the context's precision and rounding; new to extra248"
  kind: python_call_eq
  function: Context.create_decimal.__name__.__eq__
  args: ["create_decimal"]
  expected: true

invariant decimal_extra248.context_clear_flags_name:
  description: "decimal.Context.clear_flags.__name__ == 'clear_flags' — clear_flags resets all signal flags to zero in the context; new to extra248"
  kind: python_call_eq
  function: Context.clear_flags.__name__.__eq__
  args: ["clear_flags"]
  expected: true

invariant decimal_extra248.context_sqrt_qualname:
  description: "decimal.Context.sqrt.__qualname__ == 'Context.sqrt' — sqrt is defined directly on Context; new to extra248"
  kind: python_call_eq
  function: Context.sqrt.__qualname__.__eq__
  args: ["Context.sqrt"]
  expected: true

invariant decimal_extra248.context_compare_qualname:
  description: "decimal.Context.compare.__qualname__ == 'Context.compare' — compare is defined directly on Context; new to extra248"
  kind: python_call_eq
  function: Context.compare.__qualname__.__eq__
  args: ["Context.compare"]
  expected: true
