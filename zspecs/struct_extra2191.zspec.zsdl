spec: struct_extra2191
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/struct.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2191: context manager protocol dict-presence — __enter__, __exit__ (sync context manager); __aenter__, __aexit__ (async context manager); acquire, release (lock-like protocol); __wrapped__ (decorator wrapper); __closure__ (function closure attribute)."
    - "struct.Struct is a C extension type for compiled struct format strings. It is NOT a context manager, async context manager, lock-like object, or decorated wrapper."
    - "struct.error is a pure Python exception subclass (subclass of Exception). It has only __module__, __weakref__, and __doc__ in its own __dict__."
    - "struct.Struct.__dict__ contains: __new__, __repr__, __getattribute__, __setattr__, __delattr__, __init__, iter_unpack, pack, pack_into, unpack, unpack_from, __sizeof__, format, size."
    - "struct.error.__dict__ contains: __module__, __weakref__, __doc__ — no protocol dunders defined directly."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2191.Struct_context_manager_protocol:
  description: "struct.Struct context manager protocol dict-presence — Struct is a C extension packed format type, not a context manager"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2191

  columns: [id, function, args, expected]
  rows:
    - ["st2191001", "struct.Struct.__dict__.__contains__", ["__enter__"], false]
    - ["st2191002", "struct.Struct.__dict__.__contains__", ["__exit__"], false]
    - ["st2191003", "struct.Struct.__dict__.__contains__", ["__aenter__"], false]
    - ["st2191004", "struct.Struct.__dict__.__contains__", ["__aexit__"], false]
    - ["st2191005", "struct.Struct.__dict__.__contains__", ["acquire"], false]
    - ["st2191006", "struct.Struct.__dict__.__contains__", ["release"], false]
    - ["st2191007", "struct.Struct.__dict__.__contains__", ["__wrapped__"], false]
    - ["st2191008", "struct.Struct.__dict__.__contains__", ["__closure__"], false]

table struct_extra2191.error_context_manager_protocol:
  description: "struct.error context manager protocol dict-presence — error is a plain exception class, not a context manager"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2191

  columns: [id, function, args, expected]
  rows:
    - ["st2191009", "struct.error.__dict__.__contains__", ["__enter__"], false]
    - ["st2191010", "struct.error.__dict__.__contains__", ["__exit__"], false]
    - ["st2191011", "struct.error.__dict__.__contains__", ["__aenter__"], false]
    - ["st2191012", "struct.error.__dict__.__contains__", ["__aexit__"], false]
    - ["st2191013", "struct.error.__dict__.__contains__", ["acquire"], false]
    - ["st2191014", "struct.error.__dict__.__contains__", ["release"], false]
    - ["st2191015", "struct.error.__dict__.__contains__", ["__wrapped__"], false]
    - ["st2191016", "struct.error.__dict__.__contains__", ["__closure__"], false]

table struct_extra2191.Struct_dict_keys_positive:
  description: "struct.Struct.__dict__ positive presence — known Struct attributes are present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2191

  columns: [id, function, args, expected]
  rows:
    - ["st2191017", "struct.Struct.__dict__.__contains__", ["pack"], true]
    - ["st2191018", "struct.Struct.__dict__.__contains__", ["unpack"], true]
    - ["st2191019", "struct.Struct.__dict__.__contains__", ["pack_into"], true]
    - ["st2191020", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2191021", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st2191022", "struct.Struct.__dict__.__contains__", ["format"], true]
    - ["st2191023", "struct.Struct.__dict__.__contains__", ["size"], true]
    - ["st2191024", "struct.Struct.__dict__.__contains__", ["__new__"], true]
    - ["st2191025", "struct.Struct.__dict__.__contains__", ["__repr__"], true]
    - ["st2191026", "struct.Struct.__dict__.__contains__", ["__sizeof__"], true]
    - ["st2191027", "struct.Struct.__dict__.__contains__", ["__init__"], true]
    - ["st2191028", "struct.Struct.__dict__.__contains__", ["__getattribute__"], true]
    - ["st2191029", "struct.Struct.__dict__.__contains__", ["__setattr__"], true]
    - ["st2191030", "struct.Struct.__dict__.__contains__", ["__delattr__"], true]

table struct_extra2191.error_dict_keys_positive:
  description: "struct.error.__dict__ positive presence — minimal exception-class attributes are present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2191

  columns: [id, function, args, expected]
  rows:
    - ["st2191031", "struct.error.__dict__.__contains__", ["__doc__"], true]
    - ["st2191032", "struct.error.__dict__.__contains__", ["__module__"], true]
    - ["st2191033", "struct.error.__dict__.__contains__", ["__weakref__"], true]
