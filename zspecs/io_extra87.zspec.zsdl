spec: io_extra87
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra86."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__ membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO lengths; BufferedReader/BufferedWriter/TextIOWrapper __dict__.__class__.__name__ and key method membership; BytesIO/StringIO/FileIO __dict__.__class__.__name__ and membership; UnsupportedOperation identity, bases, MRO; DEFAULT_BUFFER_SIZE and SEEK_* constants class and value; BufferedRandom/__name__/__module__/bases/MRO; BufferedRWPair identity and hierarchy; IncrementalNewlineDecoder identity; TextIOWrapper/__name__/__module__/bases/MRO; StringIO/__name__/__module__/bases/MRO; FileIO/__name__/__module__/bases/MRO; BytesIO/__name__/__module__/bases/MRO; RawIOBase/BufferedIOBase/TextIOBase/IOBase class identity and hierarchy."
    - "This spec covers: io.open.__class__.__name__; io.open.__module__; io.open.__qualname__; io.open.__doc__.__class__.__name__; io.open_code.__class__.__name__; io.open_code.__module__; io.DEFAULT_BUFFER_SIZE.__class__.__name__ and __eq__(131072); io.SEEK_SET/__eq__(0); io.SEEK_CUR/__eq__(1); io.SEEK_END/__eq__(2); io.UnsupportedOperation.__name__; io.UnsupportedOperation.__module__; io.UnsupportedOperation.__bases__.__len__(); io.UnsupportedOperation.__mro__.__len__()."
    - "io.open.__class__.__name__ == 'builtin_function_or_method' — open is the C built-in from _io."
    - "io.open.__module__ == '_io' — the builtin_function_or_method reports the C extension module _io as its home."
    - "io.open.__qualname__ == 'open' — qualname is the simple function name."
    - "io.open.__doc__.__class__.__name__ == 'str' — the docstring is a Python str."
    - "io.open_code.__class__.__name__ == 'builtin_function_or_method' — open_code is also a C builtin from _io."
    - "io.open_code.__module__ == '_io' — reports the C extension module as home."
    - "io.DEFAULT_BUFFER_SIZE == 131072 — platform default on macOS/Darwin."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — standard POSIX seek constants."
    - "io.UnsupportedOperation.__bases__.__len__() == 2 — inherits from OSError and ValueError."
    - "io.UnsupportedOperation.__mro__.__len__() == 6 — [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object]."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.open identity: __class__.__name__, __module__, __qualname__, __doc__ class
# io.open is the C builtin from _io; its __module__ is '_io', not 'io'.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra87.open_identity:
  description: "io.open __class__.__name__, __module__, __qualname__, and __doc__.__class__.__name__"
  kind: python_call_eq
  category: function_identity
  id_prefix: ioextra87

  columns: [id, function, args, expected]
  rows:
    - [open_class,      open.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [open_module,     open.__module__.__eq__,              ["_io"],                        true]
    - [open_qualname,   open.__qualname__.__eq__,            ["open"],                       true]
    - [open_doc_class,  open.__doc__.__class__.__name__.__eq__, ["str"],                     true]

# ---------------------------------------------------------------------------
# io.open_code identity: __class__.__name__ and __module__
# io.open_code is a C builtin; its __module__ is '_io', not 'io'.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra87.open_code_identity:
  description: "io.open_code __class__.__name__ and __module__"
  kind: python_call_eq
  category: function_identity
  id_prefix: ioextra87

  columns: [id, function, args, expected]
  rows:
    - [open_code_class,  open_code.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [open_code_module, open_code.__module__.__eq__,         ["_io"],                        true]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE and io.SEEK_* constants
# DEFAULT_BUFFER_SIZE == 131072 on macOS. SEEK_SET/SEEK_CUR/SEEK_END are 0/1/2.
# Not covered in any prior io spec at this level of identity checking.
# ---------------------------------------------------------------------------

table io_extra87.constants_identity:
  description: "DEFAULT_BUFFER_SIZE __class__.__name__ and value; SEEK_SET/SEEK_CUR/SEEK_END values"
  kind: python_call_eq
  category: constants
  id_prefix: ioextra87

  columns: [id, function, args, expected]
  rows:
    - [dbs_class,    DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"],  true]
    - [dbs_value,    DEFAULT_BUFFER_SIZE.__eq__,                    [131072], true]
    - [seek_set_val, SEEK_SET.__eq__,                               [0],      true]
    - [seek_cur_val, SEEK_CUR.__eq__,                               [1],      true]
    - [seek_end_val, SEEK_END.__eq__,                               [2],      true]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation identity, bases, and MRO
# UnsupportedOperation inherits from OSError and ValueError (2 bases).
# MRO: [UnsupportedOperation, OSError, ValueError, Exception, BaseException, object] — length 6.
# Not covered in any prior io spec at this detail level.
# ---------------------------------------------------------------------------

table io_extra87.UnsupportedOperation_hierarchy:
  description: "UnsupportedOperation __name__, __module__, __bases__.__len__(), __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra87

  columns: [id, function, args, expected]
  rows:
    - [unsup_name,      UnsupportedOperation.__name__.__eq__,      ["UnsupportedOperation"], true]
    - [unsup_module,    UnsupportedOperation.__module__.__eq__,    ["io"],                   true]
    - [unsup_bases_len, UnsupportedOperation.__bases__.__len__,    [],                       2]
    - [unsup_mro_len,   UnsupportedOperation.__mro__.__len__,      [],                       6]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra87.open.class_name:
  description: "io.open.__class__.__name__ == 'builtin_function_or_method' (C builtin from _io)"
  category: function_identity
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant io_extra87.open.module:
  description: "io.open.__module__ == '_io' (builtin reports C extension module, not wrapper 'io')"
  category: function_identity
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra87.open.qualname:
  description: "io.open.__qualname__ == 'open' (simple unqualified name)"
  category: function_identity
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant io_extra87.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra87.UnsupportedOperation.mro_len:
  description: "io.UnsupportedOperation.__mro__.__len__() == 6 ([UnsupportedOperation, OSError, ValueError, Exception, BaseException, object])"
  category: class_identity
  kind: python_call_eq
  function: UnsupportedOperation.__mro__.__len__
  args: []
  expected: 6
