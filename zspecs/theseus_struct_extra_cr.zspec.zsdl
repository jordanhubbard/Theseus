spec: theseus_struct_extra_cr
version: ">=3.8"
backend: python_cleanroom(theseus_struct_extra_cr)
blocks: struct

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "CPython source: Lib/struct.py"
  notes:
    - "Clean-room struct module. Do NOT import struct."
    - "pack/unpack binary data."

error_model: python_exceptions

invariant theseus_struct_extra_cr.struct2_pack_unpack:
  description: "pack and unpack round-trip correctly"
  category: behavior
  kind: python_call_eq
  function: struct2_pack_unpack
  args: []
  expected: true

invariant theseus_struct_extra_cr.struct2_calcsize:
  description: "calcsize returns size of format string"
  category: behavior
  kind: python_call_eq
  function: struct2_calcsize
  args: []
  expected: true

invariant theseus_struct_extra_cr.struct2_network_order:
  description: "! format uses network byte order"
  category: behavior
  kind: python_call_eq
  function: struct2_network_order
  args: []
  expected: true
