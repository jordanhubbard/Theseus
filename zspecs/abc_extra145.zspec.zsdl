spec: abc_extra145
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: wave 255 theme — abc.__dict__.__contains__ membership checks. NEW in extra145: abc.__dict__.__contains__('ABC')==True; abc.__dict__.__contains__('ABCMeta')==True; abc.__dict__.__contains__('abstractmethod')==True; abc.__dict__.__contains__('abstractproperty')==True; abc.__dict__.__contains__('get_cache_token')==True; abc.__dict__.__contains__('update_abstractmethods')==True; abc.__dict__.__contains__('abstractclassmethod')==True; abc.__dict__.__contains__('abstractstaticmethod')==True; abc.__dict__.__contains__('foobar')==False; abc.__dict__.__contains__('abstractasyncgenerator')==False; abc.__dict__.__contains__('BaseABC')==False. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__dict__.__contains__('ABC') == True. ABC is defined in Lib/abc.py and appears in abc.__dict__ under the key 'ABC'. abc.__dict__ has 22 entries. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__dict__.__contains__('get_cache_token') == True. get_cache_token is a C-level builtin_function_or_method from Modules/_abc.c, re-exported into abc.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__dict__.__contains__('update_abstractmethods') == True. update_abstractmethods is a Python function defined in Lib/abc.py, added in Python 3.10. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__dict__.__contains__('abstractproperty') == True. abstractproperty is deprecated since Python 3.3 but still present in abc.__dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__dict__.__contains__('abstractasyncgenerator') == False. 'abstractasyncgenerator' is not a name in the abc module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.__dict__.__contains__ membership — True cases — extra145
#
# Wave 255 theme: abc.__dict__.__contains__ membership checks.
#
# abc.__dict__.__contains__('ABC')                   == True
# abc.__dict__.__contains__('ABCMeta')               == True
# abc.__dict__.__contains__('abstractmethod')        == True
# abc.__dict__.__contains__('abstractproperty')      == True
# abc.__dict__.__contains__('get_cache_token')       == True
# abc.__dict__.__contains__('update_abstractmethods') == True
# abc.__dict__.__contains__('abstractclassmethod')   == True
# abc.__dict__.__contains__('abstractstaticmethod')  == True
# ---------------------------------------------------------------------------

table abc_extra145.abc_dict_contains_true:
  description: "abc.__dict__.__contains__ membership checks (True cases) in abcdictcontains145 namespace — wave 255 theme: abc.__dict__ has 22 entries; ABC, ABCMeta, abstractmethod, abstractproperty, get_cache_token, update_abstractmethods, abstractclassmethod, and abstractstaticmethod are all in abc.__dict__; ABC is a convenience class using ABCMeta as its metaclass (len('ABC')==3, the shortest name in the module); ABCMeta is the metaclass that enables abstract base class functionality; abstractmethod is a function decorator for abstract methods (class='function'); abstractproperty is a deprecated class (since Python 3.3) for abstract properties (class='type'); get_cache_token is a C-level builtin_function_or_method from Modules/_abc.c; update_abstractmethods is a Python function added in Python 3.10; abstractclassmethod and abstractstaticmethod are deprecated since Python 3.3; abc.__dict__.__contains__('ABC')==True; abc.__dict__.__contains__('ABCMeta')==True; abc.__dict__.__contains__('abstractmethod')==True; abc.__dict__.__contains__('abstractproperty')==True; abc.__dict__.__contains__('get_cache_token')==True; abc.__dict__.__contains__('update_abstractmethods')==True; abc.__dict__.__contains__('abstractclassmethod')==True; abc.__dict__.__contains__('abstractstaticmethod')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: abcdictcontains145

  columns: [id, function, args, expected, description]
  rows:
    - [abc_in,       abc.__dict__.__contains__,  ["ABC"],                    true, "abc.__dict__.__contains__('ABC') == True — convenience class using ABCMeta as metaclass; verified with Python 3.14.3"]
    - [abcmeta_in,   abc.__dict__.__contains__,  ["ABCMeta"],                true, "abc.__dict__.__contains__('ABCMeta') == True — metaclass for abstract base classes; verified with Python 3.14.3"]
    - [absm_in,      abc.__dict__.__contains__,  ["abstractmethod"],         true, "abc.__dict__.__contains__('abstractmethod') == True — decorator for abstract methods; verified with Python 3.14.3"]
    - [absprop_in,   abc.__dict__.__contains__,  ["abstractproperty"],       true, "abc.__dict__.__contains__('abstractproperty') == True — deprecated since Python 3.3; verified with Python 3.14.3"]
    - [gct_in,       abc.__dict__.__contains__,  ["get_cache_token"],        true, "abc.__dict__.__contains__('get_cache_token') == True — C-level builtin from _abc.c; verified with Python 3.14.3"]
    - [uam_in,       abc.__dict__.__contains__,  ["update_abstractmethods"], true, "abc.__dict__.__contains__('update_abstractmethods') == True — Python function, added in 3.10; verified with Python 3.14.3"]
    - [abscls_in,    abc.__dict__.__contains__,  ["abstractclassmethod"],    true, "abc.__dict__.__contains__('abstractclassmethod') == True — deprecated since Python 3.3; verified with Python 3.14.3"]
    - [absstm_in,    abc.__dict__.__contains__,  ["abstractstaticmethod"],   true, "abc.__dict__.__contains__('abstractstaticmethod') == True — deprecated since Python 3.3; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.__dict__.__contains__ membership — False cases — extra145
#
# abc.__dict__.__contains__('foobar')                == False
# abc.__dict__.__contains__('abstractasyncgenerator') == False
# abc.__dict__.__contains__('BaseABC')               == False
# ---------------------------------------------------------------------------

table abc_extra145.abc_dict_contains_false:
  description: "abc.__dict__.__contains__ membership checks (False cases) in abcdictcontains145 namespace — wave 255 theme: abc.__dict__ has 22 entries; 'foobar' is an arbitrary non-existent name; 'abstractasyncgenerator' is not a class or function in the abc module (async generators are handled differently); 'BaseABC' is not a name in abc (the base class for ABC is object, accessed through ABCMeta); abc.__dict__.__contains__('foobar')==False; abc.__dict__.__contains__('abstractasyncgenerator')==False; abc.__dict__.__contains__('BaseABC')==False; verified with Python 3.14.3"
  kind: python_call_eq
  category: membership
  id_prefix: abcdictcontains145a

  columns: [id, function, args, expected, description]
  rows:
    - [foobar_out,   abc.__dict__.__contains__,  ["foobar"],                false, "abc.__dict__.__contains__('foobar') == False — not in abc namespace; verified with Python 3.14.3"]
    - [aag_out,      abc.__dict__.__contains__,  ["abstractasyncgenerator"], false, "abc.__dict__.__contains__('abstractasyncgenerator') == False — not a name in abc; verified with Python 3.14.3"]
    - [baseabc_out,  abc.__dict__.__contains__,  ["BaseABC"],               false, "abc.__dict__.__contains__('BaseABC') == False — not a name in abc; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra145
# ---------------------------------------------------------------------------

invariant abc_extra145.abc_dict_contains_ABC:
  description: "abc.__dict__.__contains__('ABC') returns True — abc.ABC is defined in Lib/abc.py as a convenience class that uses ABCMeta as its metaclass; ABC appears in abc.__dict__ under the key 'ABC'; abc.__dict__ has 22 entries; abc.ABC.__qualname__ is 'ABC' (len=3, the shortest abc class qualname); abc.ABC.__class__.__name__ is 'ABCMeta' (unlike other classes whose __class__.__name__ is 'type', ABC's metaclass is ABCMeta); abc.__dict__.__contains__('ABC')==True and abc.__dict__.__contains__('ABCMeta')==True — both the convenience class and its metaclass are in abc.__dict__; NEW in extra145: first standalone abc.__dict__.__contains__('ABC') invariant in abcdictcontains145 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: abc.__dict__.__contains__
  args: ["ABC"]
  expected: true

invariant abc_extra145.abc_dict_contains_ABCMeta:
  description: "abc.__dict__.__contains__('ABCMeta') returns True — abc.ABCMeta is defined in Lib/abc.py as the metaclass that enables abstract base class functionality; ABCMeta appears in abc.__dict__ under the key 'ABCMeta'; abc.ABCMeta.__qualname__ is 'ABCMeta' (len=7); abc.ABCMeta.__class__.__name__ is 'type' (the metaclass of ABCMeta is type); abc.ABCMeta defines Python methods including __new__ (class='function', co_argcount=4), register (class='function', co_argcount=2), and _dump_registry (class='function', co_argcount=2); abc.__dict__.__contains__('ABCMeta')==True; abc.__dict__ has 22 entries; NEW in extra145: first standalone abc.__dict__.__contains__('ABCMeta') invariant in abcdictcontains145 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: abc.__dict__.__contains__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra145.abc_dict_contains_abstractmethod:
  description: "abc.__dict__.__contains__('abstractmethod') returns True — abc.abstractmethod is a function decorator defined in Lib/abc.py; abstractmethod appears in abc.__dict__ under the key 'abstractmethod'; abc.abstractmethod.__class__.__name__ is 'function' (pure-Python decorator); abc.abstractmethod.__qualname__ is 'abstractmethod' (len=14); abstractmethod is the primary tool in the abc module — it decorates methods in classes that use ABCMeta to mark them as abstract, requiring subclasses to provide concrete implementations; abc.__dict__.__contains__('abstractmethod')==True; abc.__dict__.__contains__('abstractproperty')==True (deprecated variant for properties); abc.__dict__ has 22 entries; NEW in extra145: first standalone abc.__dict__.__contains__('abstractmethod') invariant in abcdictcontains145 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: abc.__dict__.__contains__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra145.abc_dict_contains_get_cache_token:
  description: "abc.__dict__.__contains__('get_cache_token') returns True — abc.get_cache_token is a C-level function from Modules/_abc.c; get_cache_token appears in abc.__dict__ under the key 'get_cache_token'; abc.get_cache_token.__class__.__name__ is 'builtin_function_or_method' (C-level, unlike abstractmethod which is 'function'); get_cache_token() returns the current abstract classes cache token — an opaque object that changes whenever the set of ABC subclasses changes; it is used to implement efficient ABC caching; abc.__dict__.__contains__('get_cache_token')==True; abc.__dict__.__contains__('update_abstractmethods')==True (companion Python function added in 3.10); abc.__dict__ has 22 entries; NEW in extra145: first standalone abc.__dict__.__contains__('get_cache_token') invariant in abcdictcontains145 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: abc.__dict__.__contains__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra145.abc_dict_contains_update_abstractmethods:
  description: "abc.__dict__.__contains__('update_abstractmethods') returns True — abc.update_abstractmethods is a Python function defined in Lib/abc.py, added in Python 3.10; update_abstractmethods appears in abc.__dict__ under the key 'update_abstractmethods'; abc.update_abstractmethods.__class__.__name__ is 'function' (pure-Python); abc.update_abstractmethods recalculates the set of abstract methods of a class by inspecting all base classes; this is useful when abstract methods are set or cleared after class creation; abc.__dict__.__contains__('update_abstractmethods')==True; abc.__dict__.__contains__('get_cache_token')==True (C-level companion function); abc.__dict__ has 22 entries; NEW in extra145: first standalone abc.__dict__.__contains__('update_abstractmethods') invariant in abcdictcontains145 namespace; wave 255; verified with Python 3.14.3"
  category: membership
  kind: python_call_eq
  function: abc.__dict__.__contains__
  args: ["update_abstractmethods"]
  expected: true

