spec: socket_extra961
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket class dicts, bases, and module identity for socket, error, timeout, herror, gaierror"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra961.class_dict_types:
  description: "socket class __dict__ type identity"
  kind: python_call_eq
  category: class_dict_types
  id_prefix: sk961dt
  columns: [id, function, args, expected]
  rows:
    - [sk961dt001, socket.socket.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]
    - [sk961dt002, socket.error.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]
    - [sk961dt003, socket.timeout.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [sk961dt004, socket.herror.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]
    - [sk961dt005, socket.gaierror.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [sk961dt006, socket.socket.__dict__.__class__.__module__.__eq__, ["builtins"], true]
    - [sk961dt007, socket.error.__dict__.__class__.__module__.__eq__,  ["builtins"], true]

table socket_extra961.class_bases_types:
  description: "socket class __bases__ type identity"
  kind: python_call_eq
  category: class_bases_types
  id_prefix: sk961bt
  columns: [id, function, args, expected]
  rows:
    - [sk961bt001, socket.socket.__bases__.__class__.__name__.__eq__,  ["tuple"], true]
    - [sk961bt002, socket.error.__bases__.__class__.__name__.__eq__,   ["tuple"], true]
    - [sk961bt003, socket.timeout.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [sk961bt004, socket.herror.__bases__.__class__.__name__.__eq__,  ["tuple"], true]
    - [sk961bt005, socket.gaierror.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [sk961bt006, socket.socket.__class__.__name__.__eq__,             ["type"],  true]

table socket_extra961.module_identity:
  description: "socket module __name__ and __spec__.name identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: sk961mi
  columns: [id, function, args, expected]
  rows:
    - [sk961mi001, socket.__name__.__eq__,                        ["socket"],     true]
    - [sk961mi002, socket.__spec__.name.__eq__,                   ["socket"],     true]
    - [sk961mi003, socket.__name__.__class__.__name__.__eq__,     ["str"],        true]
    - [sk961mi004, socket.__spec__.name.__class__.__name__.__eq__, ["str"],        true]
    - [sk961mi005, socket.__spec__.__class__.__name__.__eq__,     ["ModuleSpec"], true]
    - [sk961mi006, socket.error.__class__.__name__.__eq__,        ["type"],       true]
    - [sk961mi007, socket.timeout.__class__.__name__.__eq__,      ["type"],       true]
