  columns: [id, function, args, expected]
  rows:
    - ["ab3106004", operator.contains, [abc.ABC.__dict__,                                 "__le__"], false]
    - ["ab3106005", operator.contains, [abc.ABCMeta.__dict__,                             "__le__"], false]
    - ["ab3106006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__le__"], false]

# ---------------------------------------------------------------------------
# __gt__ dict-presence — operator.contains(Cls.__dict__, '__gt__')
#
# All 3 abc subjects return false for __gt__.
# Consistent with __lt__ and __le__: no greater-than ordering is defined.
# ---------------------------------------------------------------------------

table ab3106.gt:
  description: "abc types __gt__ dict-presence checks; wave 654"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
