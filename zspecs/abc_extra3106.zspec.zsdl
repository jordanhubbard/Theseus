  columns: [id, function, args, expected]
  rows:
    - ["ab3106007", operator.contains, [abc.ABC.__dict__,                                 "__gt__"], false]
    - ["ab3106008", operator.contains, [abc.ABCMeta.__dict__,                             "__gt__"], false]
    - ["ab3106009", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__gt__"], false]

# ---------------------------------------------------------------------------
# combined — __lt__, __le__, __gt__ across all 3 abc subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __lt__: false for all 3 — no ordering defined at the class level.
# __le__: false for all 3 — no ordering defined at the class level.
# __gt__: false for all 3 — no ordering defined at the class level.
# All three subjects rely entirely on object-inherited behavior, which raises
# TypeError when < or > is attempted on instances at runtime.
# Cross-wave summary for abc subjects:
#   Wave 652 (ab3076): __get__=true for function type only (__set__/__delete__ false).
#   Wave 653 (ab3091): __hash__/__eq__/__bool__ all false for all three.
#   Wave 654 (ab3106): __lt__/__le__/__gt__ all false for all three.
# ---------------------------------------------------------------------------

table ab3106.combined:
  description: "abc types combined __lt__/__le__/__gt__; wave 654"
  kind: python_call_eq
