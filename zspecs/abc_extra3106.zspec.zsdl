spec: ab3106
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (ab3106): __lt__, __le__, __gt__ dict-presence for abc module types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "All 3 abc subjects return false for __lt__, __le__, and __gt__ in their own __dict__."
    - "abc.ABC is a simple convenience base class with no ordering semantics."
    - "abc.ABCMeta is a metaclass; type ordering (via __lt__/__le__/__gt__) is not defined at the ABCMeta level in its own __dict__."
    - "type(abc.abstractmethod(lambda: None)) is <class 'function'>; function objects are not ordered — comparing two functions with < raises TypeError at runtime because object's default raises NotImplemented, and no __lt__ is defined in the function class __dict__."
    - "Wave 653 (ab3091) confirmed all 3 subjects return false for __hash__, __eq__, and __bool__. The absence of ordering methods is consistent with that pattern."
    - "Wave 652 (ab3076) covered __get__/__set__/__delete__ for the same three subjects; type(abstractmethod(lambda: None)) had __get__ = true as a non-data descriptor."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __lt__ dict-presence — operator.contains(Cls.__dict__, '__lt__')
#
# All 3 abc subjects return false for __lt__.
# abc.ABC and abc.ABCMeta are abstract-class infrastructure with no ordering.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>; functions
# do not define __lt__ — comparing them with < raises TypeError.
# ---------------------------------------------------------------------------

table ab3106.lt:
  description: "abc types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3106

  columns: [id, function, args, expected]
  rows:
    - ["ab3106001", operator.contains, [abc.ABC.__dict__,                                 "__lt__"], false]
    - ["ab3106002", operator.contains, [abc.ABCMeta.__dict__,                             "__lt__"], false]
    - ["ab3106003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__lt__"], false]

# ---------------------------------------------------------------------------
# __le__ dict-presence — operator.contains(Cls.__dict__, '__le__')
#
# All 3 abc subjects return false for __le__.
# Consistent with __lt__: no less-than-or-equal ordering is defined for
# abc.ABC, abc.ABCMeta, or <class 'function'> in their own __dict__.
# ---------------------------------------------------------------------------

table ab3106.le:
  description: "abc types __le__ dict-presence checks; wave 654"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
