spec: variance
version: ">=0.0.1"
backend: node(variance)

docs: https://www.npmjs.com/package/variance

provenance:
  derived_from:
    - "variance README — https://www.npmjs.com/package/variance"
    - "Test vectors verified with variance via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "variance source"
  notes:
    - "variance is an npm package. Install: npm install variance"
    - "Returns the population variance of an array of numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table variance.calculate:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: vari

  columns: [id, args, expected]
  rows:
    - [classic,  [[2, 4, 4, 4, 5, 5, 7, 9]],  4]
    - [single,   [[42]],                       0]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
