spec: re_extra254
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers re.Match method and attribute identity: group, groups, groupdict, start, end, span, expand, and the string/re/pos attributes."
    - "All re.Match methods (group, groups, groupdict, start, end, span, expand) are C-level method_descriptor objects; their __class__.__name__ is 'method_descriptor'."
    - "re.Match.string, re.Match.re, and re.Match.pos are member_descriptor objects (type(re.Match.string).__name__ == 'member_descriptor')."
    - "All re.Match methods are defined on the Match C type, so qualnames carry the 'Match.' prefix (e.g., re.Match.group.__qualname__ == 'Match.group')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Match method __name__ identity
#
# group, groups, groupdict, start, end, span, expand are all method_descriptor
# objects defined in the _sre C extension. Their __name__ values match exactly.
# ---------------------------------------------------------------------------

table re_extra254.match_method_names:
  description: "re.Match method __name__ identity — group, groups, groupdict, start, end, span, expand; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: rexmmn254

  columns: [id, function, args, expected, description]
  rows:
    - [group_name,
       "Match.group.__name__.__eq__",
       ["group"],
       true,
       "re.Match.group.__name__.__eq__('group') == True — Match.group is a method_descriptor for returning one or more subgroups of the match; its __name__ is 'group'; str.__eq__('group') returns True; new to extra254"]
    - [groups_name,
       "Match.groups.__name__.__eq__",
       ["groups"],
       true,
       "re.Match.groups.__name__.__eq__('groups') == True — Match.groups is a method_descriptor for returning a tuple of all subgroups; its __name__ is 'groups'; str.__eq__('groups') returns True; new to extra254"]
    - [groupdict_name,
       "Match.groupdict.__name__.__eq__",
       ["groupdict"],
       true,
       "re.Match.groupdict.__name__.__eq__('groupdict') == True — Match.groupdict is a method_descriptor for returning a dictionary of all named subgroups; its __name__ is 'groupdict'; str.__eq__('groupdict') returns True; new to extra254"]
    - [start_name,
       "Match.start.__name__.__eq__",
       ["start"],
       true,
       "re.Match.start.__name__.__eq__('start') == True — Match.start is a method_descriptor for returning the index of the start of a subgroup; its __name__ is 'start'; str.__eq__('start') returns True; new to extra254"]
    - [end_name,
       "Match.end.__name__.__eq__",
       ["end"],
       true,
       "re.Match.end.__name__.__eq__('end') == True — Match.end is a method_descriptor for returning the index past the end of a subgroup; its __name__ is 'end'; str.__eq__('end') returns True; new to extra254"]
    - [span_name,
       "Match.span.__name__.__eq__",
       ["span"],
       true,
       "re.Match.span.__name__.__eq__('span') == True — Match.span is a method_descriptor for returning a (start, end) tuple for a subgroup; its __name__ is 'span'; str.__eq__('span') returns True; new to extra254"]
    - [expand_name,
       "Match.expand.__name__.__eq__",
       ["expand"],
       true,
       "re.Match.expand.__name__.__eq__('expand') == True — Match.expand is a method_descriptor for returning the string obtained by substituting backreferences in template; its __name__ is 'expand'; str.__eq__('expand') returns True; new to extra254"]

# ---------------------------------------------------------------------------
# Table 2: re.Match method __qualname__ identity
#
# All Match methods are defined on the C Match type. Their __qualname__ values
# carry the 'Match.' prefix.
# ---------------------------------------------------------------------------

table re_extra254.match_method_qualnames:
  description: "re.Match method __qualname__ identity — all use 'Match.' prefix; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: rexmmq254

  columns: [id, function, args, expected, description]
  rows:
    - [group_qualname,
       "Match.group.__qualname__.__eq__",
       ["Match.group"],
       true,
       "re.Match.group.__qualname__.__eq__('Match.group') == True — group is defined on the C Match type; its __qualname__ is 'Match.group'; str.__eq__('Match.group') returns True; new to extra254"]
    - [groups_qualname,
       "Match.groups.__qualname__.__eq__",
       ["Match.groups"],
       true,
       "re.Match.groups.__qualname__.__eq__('Match.groups') == True — groups is defined on the C Match type; its __qualname__ is 'Match.groups'; str.__eq__('Match.groups') returns True; new to extra254"]
    - [groupdict_qualname,
       "Match.groupdict.__qualname__.__eq__",
       ["Match.groupdict"],
       true,
       "re.Match.groupdict.__qualname__.__eq__('Match.groupdict') == True — groupdict is defined on the C Match type; its __qualname__ is 'Match.groupdict'; str.__eq__('Match.groupdict') returns True; new to extra254"]
    - [start_qualname,
       "Match.start.__qualname__.__eq__",
       ["Match.start"],
       true,
       "re.Match.start.__qualname__.__eq__('Match.start') == True — start is defined on the C Match type; its __qualname__ is 'Match.start'; str.__eq__('Match.start') returns True; new to extra254"]
    - [end_qualname,
       "Match.end.__qualname__.__eq__",
       ["Match.end"],
       true,
       "re.Match.end.__qualname__.__eq__('Match.end') == True — end is defined on the C Match type; its __qualname__ is 'Match.end'; str.__eq__('Match.end') returns True; new to extra254"]
    - [span_qualname,
       "Match.span.__qualname__.__eq__",
       ["Match.span"],
       true,
       "re.Match.span.__qualname__.__eq__('Match.span') == True — span is defined on the C Match type; its __qualname__ is 'Match.span'; str.__eq__('Match.span') returns True; new to extra254"]
    - [expand_qualname,
       "Match.expand.__qualname__.__eq__",
       ["Match.expand"],
       true,
       "re.Match.expand.__qualname__.__eq__('Match.expand') == True — expand is defined on the C Match type; its __qualname__ is 'Match.expand'; str.__eq__('Match.expand') returns True; new to extra254"]

# ---------------------------------------------------------------------------
# Table 3: re.Match method __class__.__name__ — all are method_descriptor
# ---------------------------------------------------------------------------

table re_extra254.match_method_class_names:
  description: "re.Match method __class__.__name__ — all are 'method_descriptor'; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: rexmmcn254

  columns: [id, function, args, expected, description]
  rows:
    - [group_class,
       "Match.group.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Match.group.__class__.__name__.__eq__('method_descriptor') == True — Match.group is a C-level method_descriptor, not a Python function; str.__eq__('method_descriptor') returns True; new to extra254"]
    - [groups_class,
       "Match.groups.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Match.groups.__class__.__name__.__eq__('method_descriptor') == True — Match.groups is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra254"]
    - [groupdict_class,
       "Match.groupdict.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Match.groupdict.__class__.__name__.__eq__('method_descriptor') == True — Match.groupdict is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra254"]
    - [start_class,
       "Match.start.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Match.start.__class__.__name__.__eq__('method_descriptor') == True — Match.start is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra254"]
    - [span_class,
       "Match.span.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Match.span.__class__.__name__.__eq__('method_descriptor') == True — Match.span is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra254"]
    - [expand_class,
       "Match.expand.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Match.expand.__class__.__name__.__eq__('method_descriptor') == True — Match.expand is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra254"]

# ---------------------------------------------------------------------------
# Table 4: re.Match attribute __class__.__name__ — string, re, pos are member_descriptor
#
# string, re, and pos are read-only attributes stored as C struct members.
# type(re.Match.string).__name__ == 'member_descriptor'.
# ---------------------------------------------------------------------------

table re_extra254.match_attribute_class_names:
  description: "re.Match attribute __class__.__name__ — string, re, pos are 'member_descriptor'; new to extra254"
  kind: python_call_eq
  category: identity
  id_prefix: rexmacn254

  columns: [id, function, args, expected, description]
  rows:
    - [string_class,
       "Match.string.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "re.Match.string.__class__.__name__.__eq__('member_descriptor') == True — Match.string is a C-level member_descriptor providing read-only access to the string passed to match(); its __class__.__name__ is 'member_descriptor'; str.__eq__('member_descriptor') returns True; new to extra254"]
    - [re_class,
       "Match.re.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "re.Match.re.__class__.__name__.__eq__('member_descriptor') == True — Match.re is a C-level member_descriptor providing read-only access to the compiled regex pattern; its __class__.__name__ is 'member_descriptor'; str.__eq__('member_descriptor') returns True; new to extra254"]
    - [pos_class,
       "Match.pos.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "re.Match.pos.__class__.__name__.__eq__('member_descriptor') == True — Match.pos is a C-level member_descriptor providing read-only access to the start index passed to search/match; its __class__.__name__ is 'member_descriptor'; str.__eq__('member_descriptor') returns True; new to extra254"]
    - [end_class,
       "Match.end.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Match.end.__class__.__name__.__eq__('method_descriptor') == True — Match.end is a C-level method_descriptor (a callable method), not a member_descriptor; its __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra254"]
    - [group_class2,
       "Match.group.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "re.Match.group.__class__.__name__.__eq__('method_descriptor') == True — Match.group is a C-level method_descriptor; confirming the distinction from member_descriptor attributes like string and pos; str.__eq__('method_descriptor') returns True; new to extra254"]

# ---------------------------------------------------------------------------
# Standalone invariants — re_extra254
# ---------------------------------------------------------------------------

invariant re_extra254.match_group_name:
  description: "re.Match.group.__name__ == 'group' — Match.group returns one or more subgroups of the match; new to extra254"
  kind: python_call_eq
  function: Match.group.__name__.__eq__
  args: ["group"]
  expected: true

invariant re_extra254.match_span_name:
  description: "re.Match.span.__name__ == 'span' — Match.span returns (start, end) tuple for a subgroup; new to extra254"
  kind: python_call_eq
  function: Match.span.__name__.__eq__
  args: ["span"]
  expected: true

invariant re_extra254.match_group_qualname:
  description: "re.Match.group.__qualname__ == 'Match.group' — group is defined on the C Match type; new to extra254"
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra254.match_group_is_method_descriptor:
  description: "re.Match.group.__class__.__name__ == 'method_descriptor' — all Match methods are C-level method_descriptors; new to extra254"
  kind: python_call_eq
  function: Match.group.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra254.match_string_is_member_descriptor:
  description: "re.Match.string.__class__.__name__ == 'member_descriptor' — string is a read-only C struct member, not a callable method; new to extra254"
  kind: python_call_eq
  function: Match.string.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra254.match_pos_is_member_descriptor:
  description: "re.Match.pos.__class__.__name__ == 'member_descriptor' — pos is a read-only C struct member giving the start index for the search; new to extra254"
  kind: python_call_eq
  function: Match.pos.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra254.match_expand_name:
  description: "re.Match.expand.__name__ == 'expand' — Match.expand substitutes backreferences in a template string; new to extra254"
  kind: python_call_eq
  function: Match.expand.__name__.__eq__
  args: ["expand"]
  expected: true
