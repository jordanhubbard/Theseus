spec: struct_extra231
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra230.zspec.zsdl — covers struct.error identity and pack raises contracts"
    - "struct_extra229.zspec.zsdl — covers pack('!H',1); pack('!H',65535); pack('!I',1); pack('!B',127); pack('!B',128)"
    - "struct_extra222.zspec.zsdl — covers pack('!B',0); pack('!B',255); pack('!H',0); pack('!H',256); pack('!I',256)"
    - "struct_extra214.zspec.zsdl — covers Struct('!H').pack(1); Struct('!I').pack(1)"
    - "_struct.zspec.zsdl — covers _struct C extension identity"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.pack('=B', 255).__len__() == 1 — native byte order '=' packs unsigned byte as 1 byte."
    - "struct.pack('=H', 1).__len__() == 2 — native byte order '=' packs unsigned short as 2 bytes."
    - "struct.pack('=I', 1).__len__() == 4 — native byte order '=' packs unsigned int as 4 bytes."
    - "struct.pack('=Q', 1).__len__() == 8 — native byte order '=' packs unsigned long long as 8 bytes."
    - "struct.unpack('=B', b'\\xff')[0] == 255 — native unpack of b'\\xff' as unsigned byte yields 255."
    - "struct.unpack('=H', struct.pack('=H', 1024))[0] == 1024 — native round-trip for unsigned short."
    - "struct.calcsize('=B') == 1; struct.calcsize('=H') == 2; struct.calcsize('=I') == 4; struct.calcsize('=Q') == 8."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack native byte order ('=') length contracts
#
# struct.pack('=B', 255).__len__() == 1
# struct.pack('=H', 1).__len__()   == 2
# struct.pack('=I', 1).__len__()   == 4
# struct.pack('=Q', 1).__len__()   == 8
#
# The '=' format prefix means native byte order with standard alignment.
# 'B'=unsigned byte (1), 'H'=unsigned short (2), 'I'=unsigned int (4),
# 'Q'=unsigned long long (8). Prior specs cover '!' (network/big-endian) only.
# These are novel contracts for the '=' (native) byte order prefix.
# ---------------------------------------------------------------------------

table struct_extra231.pack_native_length_contracts:
  description: "pack('=B',255) len==1; pack('=H',1) len==2; pack('=I',1) len==4; pack('=Q',1) len==8; struct.pack native byte order length contracts; new to struct_extra231"
  kind: python_call_eq
  category: pack_lengths
  id_prefix: struct231

  columns: [id, function, args, expected, description]
  rows:
    - [pack_native_B_len,
       "pack('=B', 255).__len__",
       [],
       1,
       "struct.pack('=B', 255).__len__() == 1 — native byte order '=' format; 'B' is unsigned byte; packs into exactly 1 byte; maximum value 255 fits; novel native byte order length anchor; new to struct_extra231 namespace; verified Python 3.14.3"]
    - [pack_native_H_len,
       "pack('=H', 1).__len__",
       [],
       2,
       "struct.pack('=H', 1).__len__() == 2 — native byte order '=' format; 'H' is unsigned short; packs into exactly 2 bytes; novel native byte order length anchor for H; new to struct_extra231 namespace; verified Python 3.14.3"]
    - [pack_native_I_len,
       "pack('=I', 1).__len__",
       [],
       4,
       "struct.pack('=I', 1).__len__() == 4 — native byte order '=' format; 'I' is unsigned int; packs into exactly 4 bytes; novel native byte order length anchor for I; new to struct_extra231 namespace; verified Python 3.14.3"]
    - [pack_native_Q_len,
       "pack('=Q', 1).__len__",
       [],
       8,
       "struct.pack('=Q', 1).__len__() == 8 — native byte order '=' format; 'Q' is unsigned long long; packs into exactly 8 bytes; novel native byte order length anchor for Q; new to struct_extra231 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.unpack native byte order ('=') round-trip contracts
#
# struct.unpack('=B', b'\xff')[0]                  == 255
# struct.unpack('=H', struct.pack('=H', 1024))[0]  == 1024
# struct.unpack('=I', struct.pack('=I', 70000))[0] == 70000
#
# Round-trip contracts confirm that pack followed by unpack is an identity
# function for valid values in range. These contracts hold regardless of
# host byte order (little-endian or big-endian) because both pack and unpack
# use '=' (native). Novel to struct_extra231.
# ---------------------------------------------------------------------------

table struct_extra231.unpack_native_roundtrip_contracts:
  description: "unpack('=B',b'\\xff')[0]==255; unpack('=H',pack('=H',1024))[0]==1024; unpack('=I',pack('=I',70000))[0]==70000; struct.unpack native round-trip contracts; new to struct_extra231"
  kind: python_call_eq
  category: unpack_roundtrip
  id_prefix: struct231a

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_native_B_xff,
       "unpack('=B', b'\\xff').__getitem__",
       [0],
       255,
       "struct.unpack('=B', b'\\xff')[0] == 255 — native byte order unpack of b'\\xff' as unsigned byte; b'\\xff' is a single byte with all bits set; value is 255 (2^8 - 1); novel native unpack value anchor; new to struct_extra231 namespace; verified Python 3.14.3"]
    - [unpack_native_H_1024_roundtrip,
       "unpack('=H', pack('=H', 1024)).__getitem__",
       [0],
       1024,
       "struct.unpack('=H', struct.pack('=H', 1024))[0] == 1024 — native byte order round-trip for unsigned short value 1024; pack then unpack is an identity function for valid values; holds on both little-endian and big-endian hosts; novel native round-trip anchor; new to struct_extra231 namespace; verified Python 3.14.3"]
    - [unpack_native_I_70000_roundtrip,
       "unpack('=I', pack('=I', 70000)).__getitem__",
       [0],
       70000,
       "struct.unpack('=I', struct.pack('=I', 70000))[0] == 70000 — native byte order round-trip for unsigned int value 70000; 70000 > 65535 so it exceeds uint16 range; valid for uint32 (max 4294967295); round-trip is identity; novel native round-trip anchor for I; new to struct_extra231 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.calcsize native byte order ('=') contracts
#
# struct.calcsize('=B') == 1
# struct.calcsize('=H') == 2
# struct.calcsize('=I') == 4
# struct.calcsize('=Q') == 8
#
# calcsize returns the number of bytes needed for the format string.
# For '=' (native byte order), sizes match the platform's native C type sizes.
# On all modern platforms: B=1, H=2, I=4, Q=8. Novel to struct_extra231.
# ---------------------------------------------------------------------------

table struct_extra231.calcsize_native_contracts:
  description: "calcsize('=B')==1; calcsize('=H')==2; calcsize('=I')==4; calcsize('=Q')==8; struct.calcsize native byte order contracts; new to struct_extra231"
  kind: python_call_eq
  category: calcsize
  id_prefix: struct231b

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_native_B,
       calcsize,
       ["=B"],
       1,
       "struct.calcsize('=B') == 1 — native byte order '='; 'B' is unsigned byte; calcsize returns 1 byte; consistent with pack('=B',...).__len__()==1; novel calcsize anchor for native B; new to struct_extra231 namespace; verified Python 3.14.3"]
    - [calcsize_native_H,
       calcsize,
       ["=H"],
       2,
       "struct.calcsize('=H') == 2 — native byte order '='; 'H' is unsigned short; calcsize returns 2 bytes; consistent with pack('=H',...).__len__()==2; novel calcsize anchor for native H; new to struct_extra231 namespace; verified Python 3.14.3"]
    - [calcsize_native_I,
       calcsize,
       ["=I"],
       4,
       "struct.calcsize('=I') == 4 — native byte order '='; 'I' is unsigned int; calcsize returns 4 bytes; consistent with pack('=I',...).__len__()==4; novel calcsize anchor for native I; new to struct_extra231 namespace; verified Python 3.14.3"]
    - [calcsize_native_Q,
       calcsize,
       ["=Q"],
       8,
       "struct.calcsize('=Q') == 8 — native byte order '='; 'Q' is unsigned long long; calcsize returns 8 bytes; consistent with pack('=Q',...).__len__()==8; novel calcsize anchor for native Q; new to struct_extra231 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra231.pack_native_B_len_1:
  description: "struct.pack('=B', 255).__len__() == 1 — native byte order '=' with unsigned byte format 'B' always packs into exactly 1 byte; this is the minimum possible struct output and the same size regardless of host byte order; prior struct specs cover only the '!' (network/big-endian) prefix; struct_extra231 is the first namespace to anchor native '=' prefix pack length contracts; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_lengths
  kind: python_call_eq
  function: "pack('=B', 255).__len__"
  args: []
  expected: 1

invariant struct_extra231.unpack_native_B_xff:
  description: "struct.unpack('=B', b'\\xff')[0] == 255 — native byte order unpack of a single byte b'\\xff' as unsigned byte ('B') yields integer 255; b'\\xff' has all 8 bits set so the unsigned interpretation is 2^8-1=255; this round-trip from raw bytes to integer is identical on big-endian and little-endian hosts for a single-byte format because byte order is irrelevant for 1-byte values; no prior struct spec anchors native unpack of b'\\xff'; struct_extra231 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: unpack_roundtrip
  kind: python_call_eq
  function: "unpack('=B', b'\\xff').__getitem__"
  args: [0]
  expected: 255

invariant struct_extra231.calcsize_native_Q_8:
  description: "struct.calcsize('=Q') == 8 — native byte order '=' with unsigned long long format 'Q'; calcsize returns 8 bytes (64 bits); 'Q' is the largest fixed-size integer format in struct; corresponds to uint64_t in C; this size is invariant across little-endian and big-endian platforms for the '=' prefix; no prior struct spec anchors calcsize for the '=' prefix; struct_extra231 is the first namespace to record calcsize('=Q'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["=Q"]
  expected: 8
