spec: struct_extra586
version: ">=3.9"
backend: python_module(struct)
docs: "https://docs.python.org/3/library/struct.html"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct.Struct class and module-level functions"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers Struct method qualnames, module identity for Struct and error, and doc string presence for module functions"
  created_at: "2026-04-12T00:00:00Z"

table struct_extra586.struct_method_qualnames:
  description: "struct.Struct method __qualname__ values"
  columns: [id, function, args, expected]
  rows:
    - [st586qn01, struct.Struct.pack.__qualname__.__eq__, ["Struct.pack"], true]
    - [st586qn02, struct.Struct.unpack.__qualname__.__eq__, ["Struct.unpack"], true]
    - [st586qn03, struct.Struct.pack_into.__qualname__.__eq__, ["Struct.pack_into"], true]
    - [st586qn04, struct.Struct.unpack_from.__qualname__.__eq__, ["Struct.unpack_from"], true]
    - [st586qn05, struct.Struct.iter_unpack.__qualname__.__eq__, ["Struct.iter_unpack"], true]

table struct_extra586.struct_module_identity:
  description: "struct.Struct and struct.error module identity"
  columns: [id, function, args, expected]
  rows:
    - [st586md01, struct.Struct.__module__.__eq__, ["struct"], true]
    - [st586md02, struct.error.__module__.__eq__, ["struct"], true]

table struct_extra586.struct_doc_types:
  description: "struct module-level functions and types have str docstrings"
  columns: [id, function, args, expected]
  rows:
    - [st586md03, struct.pack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st586md04, struct.unpack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st586md05, struct.calcsize.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st586md06, struct.Struct.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st586md07, struct.error.__doc__.__class__.__name__.__eq__, ["str"], true]
