spec: sk3556
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 684 (sk3556): __reduce__, __reduce_ex__, __getstate__ dict-presence checks for socket types."
    - "socket.socket defines __getstate__ (true): socket implements __getstate__ to raise TypeError (sockets are not picklable), making the non-pickability explicit rather than silently failing."
    - "socket.AddressFamily and socket.SocketKind: do NOT define __reduce__, __reduce_ex__, or __getstate__ in their own __dict__ (false)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk3556.reduce:
  description: "socket types __reduce__ dict-presence checks; wave 684"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: sk3556
  columns: [id, function, args, expected]
  rows:
    - ["sk3556001", operator.contains, [socket.socket.__dict__,        "__reduce__"], false]
    - ["sk3556002", operator.contains, [socket.AddressFamily.__dict__, "__reduce__"], false]
    - ["sk3556003", operator.contains, [socket.SocketKind.__dict__,    "__reduce__"], false]

