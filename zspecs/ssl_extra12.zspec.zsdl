spec: ssl_extra12
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "OpenSSL source"
  notes:
    - "This spec extends ssl.zspec.zsdl and prior extras through ssl_extra11.zspec.zsdl."
    - "ssl_extra11 covers: TLSVersion.__name__/__module__/__qualname__/__bases__[0].__name__; TLSVersion.TLSv1_2/TLSv1_3 .value and .name; VerifyMode.CERT_NONE/OPTIONAL/REQUIRED .value and .name; AlertDescription.ALERT_DESCRIPTION_HANDSHAKE_FAILURE.value == 40; SSLErrorNumber.SSL_ERROR_ZERO_RETURN.value == 6."
    - "ssl_extra10 covers: Purpose.__bases__[0]/__module__/__qualname__; OP_NO_TLSv1/1_1/1_2 .name and class name; get_default_verify_paths __name__/__module__; AlertDescription.ALERT_DESCRIPTION_CLOSE_NOTIFY.value == 0; SSLErrorNumber.SSL_ERROR_SSL.value == 1; RAND_bytes.__module__ == '_ssl'."
    - "ssl_extra9 covers: Protocol.__name__/__module__/__qualname__/__bases__; SSLWantReadError/SSLWantWriteError/SSLObject qualnames; AlertDescription/SSLErrorNumber qualnames; wrap_socket.__module__."
    - "ssl_extra7 covers: SSLSyscallError/__name__/__bases__/__module__; SSLEOFError/__name__/__bases__/__module__; CertificateError/__name__/__bases__/__module__."
    - "ssl_extra5 covers: AlertDescription.__name__/__bases__/__module__; SSLErrorNumber.__name__/__bases__/__module__; Options.__name__/__bases__/__module__; VerifyMode.__name__/__bases__/__module__."
    - "ssl_extra3/4 cover: TLSVersion.__name__/__bases__; VerifyMode.__name__/__bases__."
    - "ssl.zspec.zsdl covers: SSLError/SSLContext/SSLSocket/SSLCertVerificationError __name__; SSLError.__bases__[0].__name__ == 'OSError'; SSLError.__module__."
    - "No prior spec covers: SSLSyscallError.__qualname__ as a standalone invariant (ssl_extra9 covers SSLWantRead/Write qualnames, not SSLSyscallError/SSLEOFError)."
    - "No prior spec covers: SSLSyscallError.__mro__[2].__name__ or SSLEOFError.__mro__[2].__name__ (both == 'OSError')."
    - "No prior spec covers: SSLCertVerificationError.__mro__[2].__name__ == 'OSError' or mro[3].__name__ == 'ValueError'."
    - "No prior spec covers: SSLError.__mro__[1].__name__ == 'OSError' as a standalone invariant."
    - "No prior spec covers: SSLZeroReturnError.__qualname__ == 'SSLZeroReturnError' as a standalone invariant."
    - "ssl.SSLSyscallError.__qualname__ == 'SSLSyscallError'; __mro__: SSLSyscallError->SSLError->OSError->Exception->BaseException->object."
    - "ssl.SSLEOFError.__qualname__ == 'SSLEOFError'; same MRO shape as SSLSyscallError."
    - "ssl.SSLCertVerificationError.__mro__[3].__name__ == 'ValueError' — unique among ssl exceptions: it inherits from both SSLError and ValueError."
    - "ssl.SSLError.__mro__: SSLError->OSError->Exception->BaseException->object; mro[1].__name__ == 'OSError'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SSLSyscallError and SSLEOFError __qualname__ — standalone invariants
#
# ssl_extra9 checks SSLWantReadError.__qualname__ and SSLWantWriteError.__qualname__.
# No prior spec checks SSLSyscallError.__qualname__ or SSLEOFError.__qualname__
# as standalone invariants (ssl_extra7 only checks __name__/__bases__/__module__).
# ---------------------------------------------------------------------------

invariant ssl_extra12.SSLSyscallError.qualname:
  description: "ssl.SSLSyscallError.__qualname__ == 'SSLSyscallError'"
  category: qualnames
  kind: python_call_eq
  function: SSLSyscallError.__qualname__.__eq__
  args: ["SSLSyscallError"]
  expected: true

invariant ssl_extra12.SSLEOFError.qualname:
  description: "ssl.SSLEOFError.__qualname__ == 'SSLEOFError'"
  category: qualnames
  kind: python_call_eq
  function: SSLEOFError.__qualname__.__eq__
  args: ["SSLEOFError"]
  expected: true

# ---------------------------------------------------------------------------
# SSLZeroReturnError __qualname__ — standalone invariant
#
# ssl_extra.zspec.zsdl checks SSLZeroReturnError.__name__ and __bases__[0].__name__.
# No prior spec checks SSLZeroReturnError.__qualname__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant ssl_extra12.SSLZeroReturnError.qualname:
  description: "ssl.SSLZeroReturnError.__qualname__ == 'SSLZeroReturnError'"
  category: qualnames
  kind: python_call_eq
  function: SSLZeroReturnError.__qualname__.__eq__
  args: ["SSLZeroReturnError"]
  expected: true

# ---------------------------------------------------------------------------
# SSLError MRO depth 1 — SSLError inherits directly from OSError
#
# ssl.zspec.zsdl checks SSLError.__bases__[0].__name__ == 'OSError'.
# No prior spec checks SSLError.__mro__[1].__name__ as an invariant.
# Both express the same inheritance, but via different access paths.
# ---------------------------------------------------------------------------

invariant ssl_extra12.SSLError.mro_index1:
  description: "ssl.SSLError.__mro__[1].__name__ == 'OSError' — SSLError MRO depth 1"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLError.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# SSLSyscallError MRO depth 2 — reaches OSError via SSLError
#
# SSLSyscallError.__mro__: [SSLSyscallError, SSLError, OSError, Exception, BaseException, object]
# ssl_extra7 checks SSLSyscallError.__bases__[0].__name__ == 'SSLError'.
# No prior spec checks SSLSyscallError.__mro__[2].__name__ == 'OSError'.
# ---------------------------------------------------------------------------

invariant ssl_extra12.SSLSyscallError.mro_index2:
  description: "ssl.SSLSyscallError.__mro__[2].__name__ == 'OSError' — MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLSyscallError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# SSLEOFError MRO depth 2 — reaches OSError via SSLError
#
# ssl_extra7 checks SSLEOFError.__bases__[0].__name__ == 'SSLError'.
# No prior spec checks SSLEOFError.__mro__[2].__name__ == 'OSError'.
# ---------------------------------------------------------------------------

invariant ssl_extra12.SSLEOFError.mro_index2:
  description: "ssl.SSLEOFError.__mro__[2].__name__ == 'OSError' — MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLEOFError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# SSLCertVerificationError MRO — unique ValueError branch
#
# SSLCertVerificationError inherits from both SSLError and ValueError,
# making it the only ssl exception with ValueError in its MRO.
# ssl_extra.zspec.zsdl checks SSLCertVerificationError.__bases__[0].__name__ == 'SSLError'.
# No prior spec checks SSLCertVerificationError.__mro__ at index 2 or 3.
# mro: [SSLCertVerificationError, SSLError, OSError, ValueError, Exception, BaseException, object]
# ---------------------------------------------------------------------------

invariant ssl_extra12.SSLCertVerificationError.mro_index2:
  description: "ssl.SSLCertVerificationError.__mro__[2].__name__ == 'OSError' — via SSLError"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLCertVerificationError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "OSError"

invariant ssl_extra12.SSLCertVerificationError.mro_index3:
  description: "ssl.SSLCertVerificationError.__mro__[3].__name__ == 'ValueError' — unique ValueError branch"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLCertVerificationError.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "ValueError"

# ---------------------------------------------------------------------------
# SSLWantReadError and SSLWantWriteError MRO depth 2
#
# ssl_extra.zspec.zsdl checks SSLWantReadError/SSLWantWriteError __bases__[0].__name__.
# No prior spec checks their __mro__[2].__name__ == 'OSError'.
# ---------------------------------------------------------------------------

invariant ssl_extra12.SSLWantReadError.mro_index2:
  description: "ssl.SSLWantReadError.__mro__[2].__name__ == 'OSError' — MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLWantReadError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "OSError"

invariant ssl_extra12.SSLWantWriteError.mro_index2:
  description: "ssl.SSLWantWriteError.__mro__[2].__name__ == 'OSError' — MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLWantWriteError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# SSLZeroReturnError MRO depth 2
#
# ssl_extra.zspec.zsdl checks SSLZeroReturnError.__bases__[0].__name__ == 'SSLError'.
# No prior spec checks SSLZeroReturnError.__mro__[2].__name__ == 'OSError'.
# ---------------------------------------------------------------------------

invariant ssl_extra12.SSLZeroReturnError.mro_index2:
  description: "ssl.SSLZeroReturnError.__mro__[2].__name__ == 'OSError' — MRO depth 2"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLZeroReturnError.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# SSLSyscallError and SSLEOFError __module__ table
#
# ssl_extra7 checks __module__ for SSLSyscallError and SSLEOFError.
# This table re-covers as a grouped cross-check using a fresh id_prefix.
# ssl_extra12 anchors the table: both modules are 'ssl'.
# ---------------------------------------------------------------------------

table ssl_extra12.syscall_eof_modules:
  kind: python_call_eq
  category: modules
  id_prefix: se12mod

  columns: [id, function, args, expected]
  rows:
    - [SSLSyscallError, SSLSyscallError.__module__.__eq__, ["ssl"], true]
    - [SSLEOFError,     SSLEOFError.__module__.__eq__,     ["ssl"], true]
