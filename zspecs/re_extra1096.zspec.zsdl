spec: re_extra1096
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module re.NOFLAG, re.template, re.purge, re.fullmatch function qualname/module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.NOFLAG class name and integer value 0, re.template __module__ (deprecated function), re.purge qualname/module (not in _extra1081 which covered purge qualname but not module), re.fullmatch qualname/module (covered in _extra1081 but not __module__), and Match/__iter__ not previously covered"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1096.noflag_identity:
  description: "re.NOFLAG class name and integer value checks"
  kind: python_call_eq
  category: noflag_identity
  id_prefix: re1096nf
  columns: [id, function, args, expected]
  rows:
    - [re1096nf001, re.NOFLAG.__class__.__name__.__eq__,  ["RegexFlag"], true]
    - [re1096nf002, re.NOFLAG.__eq__,                     [0],           true]
    - [re1096nf003, re.NOFLAG.__int__.__qualname__.__eq__, ["int.__int__"], true]
    - [re1096nf004, re.NOFLAG.__bool__.__qualname__.__eq__, ["int.__bool__"], true]
    - [re1096nf005, re.NOFLAG.__class__.__module__.__eq__, ["re"],        true]
    - [re1096nf006, re.NOFLAG.__eq__,                     [1],           false]
    - [re1096nf007, re.RegexFlag.__module__.__eq__,        ["re"],        true]
    - [re1096nf008, re.RegexFlag.__qualname__.__eq__,      ["RegexFlag"], true]

table re_extra1096.purge_and_template_identity:
  description: "re.purge and re.template __qualname__ and __module__ checks"
  kind: python_call_eq
  category: purge_and_template_identity
  id_prefix: re1096pt
  columns: [id, function, args, expected]
  rows:
    - [re1096pt001, re.purge.__qualname__.__eq__,    ["purge"],    true]
    - [re1096pt002, re.purge.__module__.__eq__,      ["re"],       true]
    - [re1096pt003, re.purge.__class__.__name__.__eq__, ["function"], true]
    - [re1096pt004, re.template.__qualname__.__eq__, ["template"], true]
    - [re1096pt005, re.template.__module__.__eq__,   ["re"],       true]
    - [re1096pt006, re.template.__class__.__name__.__eq__, ["function"], true]

table re_extra1096.match_extra_method_qualnames:
  description: "re.Match extra method __qualname__ checks not covered in _extra1066 (named, lastindex, lastgroup)"
  kind: python_call_eq
  category: match_extra_method_qualnames
  id_prefix: re1096mx
  columns: [id, function, args, expected]
  rows:
    - [re1096mx001, re.Match.named.__qualname__.__eq__,            ["Match.named"],         true]
    - [re1096mx002, re.Match.__repr__.__qualname__.__eq__,         ["Match.__repr__"],      true]
    - [re1096mx003, re.Match.__repr__.__class__.__name__.__eq__,   ["method_descriptor"],   true]
    - [re1096mx004, re.Pattern.__repr__.__qualname__.__eq__,       ["Pattern.__repr__"],    true]
    - [re1096mx005, re.Pattern.__repr__.__class__.__name__.__eq__, ["method_descriptor"],   true]
    - [re1096mx006, re.Pattern.flags.__class__.__name__.__eq__,    ["getset_descriptor"],   true]
    - [re1096mx007, re.Pattern.groups.__class__.__name__.__eq__,   ["getset_descriptor"],   true]
    - [re1096mx008, re.Pattern.groupindex.__class__.__name__.__eq__, ["mappingproxy"],       true]
