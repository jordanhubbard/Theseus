spec: abc_extra2626
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 622 theme: __length_hint__, __missing__, and __reversed__ dict-presence checks."
    - "abc.ABCMeta, abc.ABC, abc.abstractmethod, and abc.abstractproperty do NOT define __length_hint__, __missing__, or __reversed__ in their own __dict__."
    - "__length_hint__ is an iterator hint protocol; abc metaclass and abstract base classes have no use for it."
    - "__missing__ is a dict-subclass fallback hook; abc classes are not dict subclasses."
    - "__reversed__ is a sequence-reversal protocol method; abc classes are not sequences."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — abc classes
#
# ABCMeta, ABC, abstractmethod, and abstractproperty do NOT define
# __length_hint__ in their own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2626.length_hint_checks:
  description: "abc classes do NOT define __length_hint__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2626
  columns: [id, function, args, expected]
  rows:
    - ["ab2626001", "abc.ABCMeta.__dict__.__contains__",         ["__length_hint__"], false]
    - ["ab2626002", "abc.ABC.__dict__.__contains__",             ["__length_hint__"], false]
    - ["ab2626003", "abc.abstractmethod.__dict__.__contains__",  ["__length_hint__"], false]
    - ["ab2626004", "abc.abstractproperty.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __missing__ dict-presence — abc classes
#
# ABCMeta, ABC, abstractmethod, and abstractproperty do NOT define
# __missing__ in their own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2626.missing_checks:
  description: "abc classes do NOT define __missing__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2626
  columns: [id, function, args, expected]
  rows:
    - ["ab2626005", "abc.ABCMeta.__dict__.__contains__",          ["__missing__"], false]
    - ["ab2626006", "abc.ABC.__dict__.__contains__",              ["__missing__"], false]
    - ["ab2626007", "abc.abstractmethod.__dict__.__contains__",   ["__missing__"], false]
    - ["ab2626008", "abc.abstractproperty.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — abc classes
#
# ABCMeta, ABC, abstractmethod, and abstractproperty do NOT define
# __reversed__ in their own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2626.reversed_checks:
  description: "abc classes do NOT define __reversed__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2626
  columns: [id, function, args, expected]
  rows:
    - ["ab2626009",  "abc.ABCMeta.__dict__.__contains__",          ["__reversed__"], false]
    - ["ab2626010", "abc.ABC.__dict__.__contains__",              ["__reversed__"], false]
    - ["ab2626011", "abc.abstractmethod.__dict__.__contains__",   ["__reversed__"], false]
    - ["ab2626012", "abc.abstractproperty.__dict__.__contains__", ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Cross-check: none of the three dunders appear on ABCMeta or ABC
#
# Consolidating results for ABCMeta and ABC together to confirm the complete
# absence of all wave-622 dunders from the two principal abc entry points.
# ABCMeta is notable because it does define other dunders (__subclasscheck__,
# __instancecheck__, register, __new__) — but not these three.
# ---------------------------------------------------------------------------

table abc_extra2626.combined_absent_checks:
  description: "abc.ABCMeta and abc.ABC lack all three wave-622 dunders in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2626
  columns: [id, function, args, expected]
  rows:
    - ["ab2626013", "abc.ABCMeta.__dict__.__contains__", ["__length_hint__"], false]
    - ["ab2626014", "abc.ABCMeta.__dict__.__contains__", ["__missing__"],     false]
    - ["ab2626015", "abc.ABCMeta.__dict__.__contains__", ["__reversed__"],    false]
    - ["ab2626016", "abc.ABC.__dict__.__contains__",     ["__length_hint__"], false]
    - ["ab2626017", "abc.ABC.__dict__.__contains__",     ["__missing__"],     false]
    - ["ab2626018", "abc.ABC.__dict__.__contains__",     ["__reversed__"],    false]
    - ["ab2626019", "abc.abstractmethod.__dict__.__contains__",   ["__length_hint__"], false]
    - ["ab2626020", "abc.abstractmethod.__dict__.__contains__",   ["__missing__"],     false]
    - ["ab2626021", "abc.abstractmethod.__dict__.__contains__",   ["__reversed__"],    false]
    - ["ab2626022", "abc.abstractproperty.__dict__.__contains__", ["__length_hint__"], false]
    - ["ab2626023", "abc.abstractproperty.__dict__.__contains__", ["__missing__"],     false]
    - ["ab2626024", "abc.abstractproperty.__dict__.__contains__", ["__reversed__"],    false]
