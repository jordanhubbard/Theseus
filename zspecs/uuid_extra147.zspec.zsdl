spec: uuid_extra147
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra146.zspec.zsdl — covers uuid.uuid1/__module__/__code__.co_name/__code__.co_argcount / uuid4/__module__/__code__.co_name/__code__.co_argcount==0 / uuid3/uuid5/__code__.co_argcount==2 (table + invariants)."
    - "uuid_extra145.zspec.zsdl — covers uuid.UUID.hex/__bytes/__version/__variant/__node/__time/__class__.__name__.__eq__('property') / UUID.int/__class__.__name__.__eq__('member_descriptor') / uuid4.__module__.__eq__('uuid') (table + invariants)."
    - "uuid_extra144.zspec.zsdl — covers uuid.UUID.__str__/__repr__/__hash__/__eq__/__int__ qualnames and qualname lengths (table + invariants)."
    - "uuid_extra142.zspec.zsdl — covers uuid.SafeUUID.__dict__.__len__()==19 / UUID.__dict__.__contains__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra146."
    - "Wave 337 theme: uuid.UUID __slots__ attributes and method qualname lengths — UUID.__slots__.__class__.__name__.__eq__('tuple') / UUID.__slots__.__contains__('int') / UUID.__slots__.__len__()==3 / UUID.__hash__.__qualname__.__len__()==13 / UUID.__str__.__qualname__.__len__()==12 / UUID.__repr__.__qualname__.__len__()==13 / UUID.__eq__.__qualname__.__len__()==11."
    - "uuid.UUID.__slots__.__class__.__name__ == 'tuple'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__.__contains__('int') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__slots__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__.__len__() == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.__slots__ == ('int', 'is_safe', '__weakref__') — a tuple of 3 elements. The UUID class uses __slots__ to restrict instance attributes and reduce memory overhead. Only the 'int' slot stores actual UUID data (the 128-bit integer). 'is_safe' stores a SafeUUID enum value. '__weakref__' enables weak references to UUID instances. __slots__ is a tuple (not a list), and __contains__ works directly on it."
    - "Note: uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' (13 chars: 'UUID.'=5 + '__hash__'=8). uuid.UUID.__str__.__qualname__ == 'UUID.__str__' (12 chars: 'UUID.'=5 + '__str__'=7). uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' (13 chars: 'UUID.'=5 + '__repr__'=8). uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' (11 chars: 'UUID.'=5 + '__eq__'=6). The double-underscore dunder methods all carry the 'UUID.' prefix. Length ordering: __eq__(11) < __str__(12) < __hash__==__repr__(13)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__class__.__name__.__eq__('tuple')
# uuid.UUID.__slots__.__contains__('int')
# uuid.UUID.__slots__.__len__()==3
#
# Wave 337 theme: UUID.__slots__ type, contents, and length.
#
# UUID.__slots__.__class__.__name__ == 'tuple' (5 chars; __slots__ is a tuple).
# UUID.__slots__.__contains__('int') == True ('int' is in __slots__).
# UUID.__slots__.__len__() == 3 (three slots: 'int', 'is_safe', '__weakref__').
# extra145 anchors UUID.int as member_descriptor (the slot descriptor itself);
# no prior uuid spec anchors UUID.__slots__ class name or contents as a table under
# uuidslot147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra147.UUID_slots_type_and_contents:
  description: "uuid.UUID.__slots__.__class__.__name__.__eq__('tuple')==True / UUID.__slots__.__contains__('int')==True / UUID.__slots__.__len__()==3 / UUID.__slots__.__contains__('is_safe')==True — __slots__ is a tuple (5 chars; not a list); contains 'int' (True; raw 128-bit integer storage; extra145 anchors UUID.int as member_descriptor); contains 'is_safe' (True; SafeUUID enum value); has 3 elements ('int', 'is_safe', '__weakref__'); first uuidslot147 anchor for UUID.__slots__ identity and contents"
  kind: python_call_eq
  category: identity
  id_prefix: uuidslot147

  columns: [id, function, args, expected, description]
  rows:
    - [slots_class_tuple,       "__slots__.__class__.__name__.__eq__", ["tuple"],   true, "uuid.UUID.__slots__.__class__.__name__ == 'tuple' (5 chars; __slots__ definition stored as tuple by Python)"]
    - [slots_contains_int,      "__slots__.__contains__",              ["int"],     true, "uuid.UUID.__slots__.__contains__('int') == True ('int' slot stores raw 128-bit integer; extra145 anchors member_descriptor)"]
    - [slots_len_3,             "__slots__.__len__",                   [],          3,    "uuid.UUID.__slots__.__len__() is 3 (three slots: 'int', 'is_safe', '__weakref__')"]
    - [slots_contains_is_safe,  "__slots__.__contains__",              ["is_safe"], true, "uuid.UUID.__slots__.__contains__('is_safe') == True ('is_safe' slot stores SafeUUID enum value for UUID generation safety)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__.__qualname__.__len__()==13
# uuid.UUID.__str__.__qualname__.__len__()==12
# uuid.UUID.__repr__.__qualname__.__len__()==13
# uuid.UUID.__eq__.__qualname__.__len__()==11
#
# Wave 337 theme: UUID dunder method qualname lengths.
#
# UUID.__hash__.__qualname__.__len__() == 13 ('UUID.__hash__': 'UUID.'=5 + '__hash__'=8).
# UUID.__str__.__qualname__.__len__() == 12 ('UUID.__str__': 'UUID.'=5 + '__str__'=7).
# UUID.__repr__.__qualname__.__len__() == 13 ('UUID.__repr__': 'UUID.'=5 + '__repr__'=8).
# UUID.__eq__.__qualname__.__len__() == 11 ('UUID.__eq__': 'UUID.'=5 + '__eq__'=6).
# extra144 anchors these qualname strings (eq, str, repr, hash) as table rows;
# no prior uuid spec anchors these lengths as a table under uuidslot147.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra147.UUID_dunder_qualname_lengths:
  description: "uuid.UUID.__hash__.__qualname__.__len__()==13 / UUID.__str__.__qualname__.__len__()==12 / UUID.__repr__.__qualname__.__len__()==13 / UUID.__eq__.__qualname__.__len__()==11 — all follow 'UUID.' prefix (5 chars); __eq__(6)=11; __str__(7)=12; __hash__(8)==__repr__(8)=13; length ordering: __eq__(11) < __str__(12) < __hash__==__repr__(13); extra144 anchors the qualname strings; first uuidslot147 anchor for these length values"
  kind: python_call_eq
  category: identity
  id_prefix: uuidslot147

  columns: [id, function, args, expected, description]
  rows:
    - [hash_qualname_len_13,   "__hash__.__qualname__.__len__",  [], 13, "uuid.UUID.__hash__.__qualname__.__len__() is 13 ('UUID.__hash__' = 'UUID.'=5 + '__hash__'=8 = 13 chars)"]
    - [str_qualname_len_12,    "__str__.__qualname__.__len__",   [], 12, "uuid.UUID.__str__.__qualname__.__len__() is 12 ('UUID.__str__' = 'UUID.'=5 + '__str__'=7 = 12 chars)"]
    - [repr_qualname_len_13,   "__repr__.__qualname__.__len__",  [], 13, "uuid.UUID.__repr__.__qualname__.__len__() is 13 ('UUID.__repr__' = 'UUID.'=5 + '__repr__'=8 = 13 chars; ties with __hash__)"]
    - [eq_qualname_len_11,     "__eq__.__qualname__.__len__",    [], 11, "uuid.UUID.__eq__.__qualname__.__len__() is 11 ('UUID.__eq__' = 'UUID.'=5 + '__eq__'=6 = 11 chars; shortest dunder qualname)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__class__.__name__.__len__()==5
# uuid.UUID.__slots__.__contains__('__weakref__')
#
# Wave 337 theme: __slots__ tuple class name length and __weakref__ membership.
#
# UUID.__slots__.__class__.__name__.__len__() == 5 ('tuple' = 5 chars).
# UUID.__slots__.__contains__('__weakref__') == True (weak reference support enabled).
# Length ordering for class names encountered: 'str'(3) < 'tuple'(5) < 'property'(8) < ...
# No prior uuid spec anchors __slots__.__class__.__name__.__len__() as a table row under
# uuidslot147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra147.UUID_slots_class_name_len_and_weakref:
  description: "uuid.UUID.__slots__.__class__.__name__.__len__()==5 / UUID.__slots__.__contains__('__weakref__')==True / UUID.__slots__.__len__()==3 / UUID.__hash__.__qualname__.__len__()==13 — 'tuple' is 5 chars (class name of __slots__); __weakref__ is in __slots__ (True; enables weak references to UUID instances); slots len is 3 (confirmed); hash qualname len is 13 (confirmed); first uuidslot147 anchor for __slots__ class name length and __weakref__ membership"
  kind: python_call_eq
  category: identity
  id_prefix: uuidslot147

  columns: [id, function, args, expected, description]
  rows:
    - [slots_class_name_len_5,      "__slots__.__class__.__name__.__len__", [],              5,    "uuid.UUID.__slots__.__class__.__name__.__len__() is 5 ('tuple' = 5 chars; class of the __slots__ tuple)"]
    - [slots_contains_weakref,      "__slots__.__contains__",               ["__weakref__"], true, "uuid.UUID.__slots__.__contains__('__weakref__') == True (3rd slot; enables weak references to UUID instances)"]
    - [slots_len_3b,                "__slots__.__len__",                    [],              3,    "uuid.UUID.__slots__.__len__() is 3 (confirmed: 'int', 'is_safe', '__weakref__' — exactly 3 slots)"]
    - [hash_qualname_len_13b,       "__hash__.__qualname__.__len__",        [],              13,   "uuid.UUID.__hash__.__qualname__.__len__() is 13 ('UUID.__hash__' = 5+8 = 13 chars; ties with '__repr__')"]

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__class__.__name__.__eq__('tuple') — standalone
#
# uuid.UUID.__slots__.__class__.__name__ is 'tuple' (5 chars). The UUID class defines
# __slots__ = ('int', 'is_safe', '__weakref__') in Lib/uuid.py. Python stores the
# __slots__ value as a tuple on the class. __slots__.__class__.__name__ == 'tuple'
# (5 chars) confirms this. Using __slots__ prevents arbitrary instance attributes and
# reduces memory per instance (no __dict__ per instance). The three slots are:
# 'int' (stores the raw 128-bit UUID integer; member_descriptor type per extra145),
# 'is_safe' (stores a SafeUUID enum value), and '__weakref__' (enables weak references).
# No prior uuid spec anchors UUID.__slots__.__class__.__name__ as a standalone under
# uuidslot147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra147.UUID_slots_class_eq_tuple:
  description: "uuid.UUID.__slots__.__class__.__name__.__eq__('tuple') == True — 'tuple' (5 chars); UUID.__slots__ is a tuple not a list; defined as __slots__ = ('int', 'is_safe', '__weakref__') in Lib/uuid.py; 3 elements; 'int' slot stores 128-bit UUID integer (extra145 anchors member_descriptor); 'is_safe' stores SafeUUID value; '__weakref__' enables weak refs; no __dict__ per instance; no prior uuid spec anchors this as a standalone; first standalone under uuidslot147"
  category: identity
  kind: python_call_eq
  function: __slots__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__slots__.__contains__('int') — standalone
#
# uuid.UUID.__slots__.__contains__('int') is True. 'int' is the primary storage slot
# of the UUID class. It holds the 128-bit integer that represents the UUID value. All
# UUID properties (hex, bytes, bytes_le, fields, time_low, time_mid, time_hi_version,
# clock_seq_hi_variant, clock_seq_low, node, time, clock_seq, variant, version, urn)
# are computed from self.int. The __contains__ method on a tuple performs a linear
# membership test. extra145 anchors UUID.int.__class__.__name__ == 'member_descriptor'
# (the slot descriptor object itself); this spec anchors the membership of 'int' in
# the __slots__ tuple directly. No prior uuid spec anchors UUID.__slots__.__contains__('int')
# as a standalone under uuidslot147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra147.UUID_slots_contains_int:
  description: "uuid.UUID.__slots__.__contains__('int') == True — 'int' is the primary data slot; holds 128-bit UUID integer; all UUID properties computed from self.int; tuple.__contains__ performs linear membership test; extra145 anchors UUID.int as member_descriptor (the descriptor object); this anchors 'int' membership in __slots__ tuple; UUID.__slots__ has 3 elements total; no prior uuid spec anchors this as a standalone; first standalone under uuidslot147"
  category: identity
  kind: python_call_eq
  function: __slots__.__contains__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__qualname__.__len__()==11 — standalone
#
# uuid.UUID.__eq__.__qualname__.__len__() is 11. UUID.__eq__.__qualname__ is
# 'UUID.__eq__' (11 chars = 'UUID.'=5 + '__eq__'=6). '__eq__' is the shortest of the
# dunder method names checked here: '__eq__'(6) < '__str__'(7) < '__hash__'(8) == '__repr__'(8).
# Combined with the 'UUID.' prefix (5 chars), the total qualname lengths are:
# __eq__(11) < __str__(12) < __hash__==__repr__(13). extra144 anchors UUID.__eq__.__qualname__
# as a table row; no prior uuid spec anchors UUID.__eq__.__qualname__.__len__() as a
# standalone under uuidslot147. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra147.UUID_eq_qualname_len_11:
  description: "uuid.UUID.__eq__.__qualname__.__len__() == 11 — 'UUID.__eq__' = 'UUID.'=5 + '__eq__'=6 = 11 chars; shortest dunder qualname among __eq__/__str__/__repr__/__hash__; length ordering: __eq__(11) < __str__(12) < __hash__==__repr__(13); extra144 anchors UUID.__eq__.__qualname__=='UUID.__eq__' as a table row; no prior uuid spec anchors __eq__ qualname length as a standalone; first standalone under uuidslot147"
  category: identity
  kind: python_call_eq
  function: __eq__.__qualname__.__len__
  args: []
  expected: 11
