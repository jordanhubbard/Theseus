spec: posix_extra2
version: ">=3.9"
backend: python_module(posix)

docs: https://docs.python.org/3/library/posix.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/posix.html — Python posix module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
  notes:
    - "This spec extends posix.zspec.zsdl and posix_extra.zspec.zsdl with new, non-duplicate invariants."
    - "posix.zspec.zsdl covers: O_RDONLY/O_WRONLY/O_RDWR constants, getpid/getuid/getcwd behavior, function __name__ table, stat_result class."
    - "posix_extra.zspec.zsdl covers: function __name__/__module__/__class__ attributes, stat_result __name__/__module__/is_type/n_sequence_fields."
    - "New here: module __name__, posix.F_OK/R_OK/W_OK/X_OK access-check constants, uname_result class identity, uname_result n_sequence_fields/n_unnamed_fields, uname_result __match_args__ field names, stat_result.n_unnamed_fields."
    - "posix is a POSIX-only module; it is available on macOS and Linux but NOT on Windows."
    - "F_OK==0, R_OK==4, W_OK==2, X_OK==1 — POSIX-standardized access(2) mode bits."
    - "uname_result is the C struct-sequence returned by posix.uname(); it has 5 fields: sysname, nodename, release, version, machine."
    - "uname_result.n_sequence_fields == 5 and n_unnamed_fields == 0."
    - "stat_result.n_unnamed_fields == 3 — three anonymous tail fields (st_atime_ns, st_mtime_ns, st_ctime_ns) on CPython."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity — posix.__name__
# Not covered in posix.zspec.zsdl or posix_extra.zspec.zsdl.
# ---------------------------------------------------------------------------

invariant posix_extra2.module.name:
  description: "posix.__name__ == 'posix' — the module's own __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["posix"]
  expected: true

# ---------------------------------------------------------------------------
# F_OK, R_OK, W_OK, X_OK — access(2) mode bit constants
# Not covered in posix.zspec.zsdl or posix_extra.zspec.zsdl.
# POSIX-standardized values used with posix.access().
# ---------------------------------------------------------------------------

invariant posix_extra2.F_OK.value:
  description: "posix.F_OK == 0 — existence check flag for access()"
  category: constants
  kind: python_call_eq
  function: F_OK.__eq__
  args: [0]
  expected: true

invariant posix_extra2.R_OK.value:
  description: "posix.R_OK == 4 — read permission flag for access()"
  category: constants
  kind: python_call_eq
  function: R_OK.__eq__
  args: [4]
  expected: true

invariant posix_extra2.W_OK.value:
  description: "posix.W_OK == 2 — write permission flag for access()"
  category: constants
  kind: python_call_eq
  function: W_OK.__eq__
  args: [2]
  expected: true

invariant posix_extra2.X_OK.value:
  description: "posix.X_OK == 1 — execute permission flag for access()"
  category: constants
  kind: python_call_eq
  function: X_OK.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uname_result — class identity
# posix.uname_result is the C struct-sequence type returned by posix.uname().
# Not covered in posix.zspec.zsdl or posix_extra.zspec.zsdl.
# ---------------------------------------------------------------------------

invariant posix_extra2.uname_result.class_name:
  description: "posix.uname_result.__name__ == 'uname_result'"
  category: class_identity
  kind: python_call_eq
  function: uname_result.__name__.__eq__
  args: ["uname_result"]
  expected: true

invariant posix_extra2.uname_result.module:
  description: "posix.uname_result.__module__ == 'posix'"
  category: class_identity
  kind: python_call_eq
  function: uname_result.__module__.__eq__
  args: ["posix"]
  expected: true

invariant posix_extra2.uname_result.is_type:
  description: "posix.uname_result.__class__.__name__ == 'type' — uname_result is a class object"
  category: class_identity
  kind: python_call_eq
  function: uname_result.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# uname_result — field count and unnamed fields
# ---------------------------------------------------------------------------

invariant posix_extra2.uname_result.n_sequence_fields:
  description: "posix.uname_result.n_sequence_fields == 5 — five positional fields"
  category: struct
  kind: python_call_eq
  function: uname_result.n_sequence_fields.__eq__
  args: [5]
  expected: true

invariant posix_extra2.uname_result.n_unnamed_fields:
  description: "posix.uname_result.n_unnamed_fields == 0 — no anonymous tail fields"
  category: struct
  kind: python_call_eq
  function: uname_result.n_unnamed_fields.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# uname_result.__match_args__ — field names by position
# uname_result has five named fields: sysname, nodename, release, version, machine.
# ---------------------------------------------------------------------------

table posix_extra2.uname_result.match_args:
  kind: python_call_eq
  category: match_args
  id_prefix: uname

  columns: [id, function, args, expected]
  rows:
    - [sysname,  uname_result.__match_args__.__getitem__, [0], "sysname"]
    - [nodename, uname_result.__match_args__.__getitem__, [1], "nodename"]
    - [release,  uname_result.__match_args__.__getitem__, [2], "release"]
    - [version,  uname_result.__match_args__.__getitem__, [3], "version"]
    - [machine,  uname_result.__match_args__.__getitem__, [4], "machine"]

# ---------------------------------------------------------------------------
# stat_result.n_unnamed_fields == 3
# posix.zspec.zsdl and posix_extra.zspec.zsdl cover n_sequence_fields (10)
# but neither covers n_unnamed_fields. CPython exposes 3 anonymous tail fields
# (st_atime_ns, st_mtime_ns, st_ctime_ns) beyond the 10 positional ones.
# ---------------------------------------------------------------------------

invariant posix_extra2.stat_result.n_unnamed_fields:
  description: "posix.stat_result.n_unnamed_fields == 3 — three anonymous ns-precision tail fields"
  category: struct
  kind: python_call_eq
  function: stat_result.n_unnamed_fields.__eq__
  args: [3]
  expected: true
