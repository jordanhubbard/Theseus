spec: ws
version: ">=8.0.0"
backend: node(ws)

docs: https://github.com/websockets/ws#readme

provenance:
  derived_from:
    - "ws README — https://github.com/websockets/ws#readme"
    - "RFC 6455 (The WebSocket Protocol) — readyState values 0/1/2/3"
    - "Test vectors verified with ws via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "ws source"
  notes:
    - "Most-popular WebSocket library for Node — server + client."
    - "Install: npm install ws"
    - "v8 CJS; module export IS the WebSocket class; Server/WebSocketServer/createWebSocketStream attached."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Constructor throws on bad URLs; methods may emit error events."
  stderr: "null"
  stickiness: "N/A — each socket independent."
  codes: {}

invariant ws.CONNECTING_zero:
  description: "WebSocket.CONNECTING is 0 (per RFC 6455)"
  category: readyState
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: CONNECTING}
  expected: 0

invariant ws.OPEN_one:
  description: "WebSocket.OPEN is 1"
  category: readyState
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: OPEN}
  expected: 1

invariant ws.CLOSING_two:
  description: "WebSocket.CLOSING is 2"
  category: readyState
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: CLOSING}
  expected: 2

invariant ws.CLOSED_three:
  description: "WebSocket.CLOSED is 3"
  category: readyState
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: CLOSED}
  expected: 3

invariant ws.has_Server_class:
  description: "WebSocket.Server is exported (alias for WebSocketServer)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Server.constructor.name"}
  expected: "Function"

invariant ws.has_WebSocketServer_class:
  description: "WebSocket.WebSocketServer is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "WebSocketServer.constructor.name"}
  expected: "Function"

invariant ws.has_createWebSocketStream_function:
  description: "createWebSocketStream is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "createWebSocketStream.constructor.name"}
  expected: "Function"

invariant ws.has_Receiver_class:
  description: "Receiver class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Receiver.constructor.name"}
  expected: "Function"

invariant ws.has_Sender_class:
  description: "Sender class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Sender.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:30:25Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
