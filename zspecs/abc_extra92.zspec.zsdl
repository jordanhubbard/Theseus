spec: abc_extra92
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra91

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra91.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc ABCMeta.__getattribute__ and __call__ class names + ABC.__init_subclass__ code attrs. NEW in extra92: ABCMeta.__getattribute__.__class__.__name__=='wrapper_descriptor'; ABCMeta.__call__.__class__.__name__=='wrapper_descriptor'; ABCMeta.__setattr__.__class__.__name__=='wrapper_descriptor'; ABCMeta.__delattr__.__class__.__name__=='wrapper_descriptor'; all four ABCMeta inherited dunder methods are 'wrapper_descriptor' objects inherited from the 'type' metaclass; ABC.__init_subclass__.__class__.__name__=='builtin_function_or_method'; ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21); ABCMeta.__class__.__name__=='type'; ABCMeta.__bases__[0].__name__=='type'; ABCMeta.__mro__.__len__()==3; abstractmethod.__code__.co_name=='abstractmethod'; abstractmethod.__qualname__=='abstractmethod' (len=14); abstractmethod.__module__=='abc' (len=3). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__getattribute__.__class__.__name__ == 'wrapper_descriptor'. All four special methods (__getattribute__, __call__, __setattr__, __delattr__) are inherited from type and are C-level wrapper_descriptor objects. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method'. ABC.__init_subclass__ is a class method implemented in C (inherited from object), not a Python function. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (len=21). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__class__.__name__ == 'type'. ABCMeta is itself a metaclass whose class is 'type'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abstractmethod.__qualname__ == 'abstractmethod' (len=14). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta inherited dunder methods __class__.__name__ — extra92
#
# Wave 254 theme: abc ABCMeta.__getattribute__ and __call__ class names.
#
# ABCMeta.__getattribute__.__class__.__name__ == 'wrapper_descriptor'
# ABCMeta.__call__.__class__.__name__ == 'wrapper_descriptor'
# ABCMeta.__setattr__.__class__.__name__ == 'wrapper_descriptor'
# ABCMeta.__delattr__.__class__.__name__ == 'wrapper_descriptor'
# ---------------------------------------------------------------------------

table abc_extra92.abcmeta_inherited_dunder_class_names:
  description: "ABCMeta inherited dunder method __class__.__name__ checks in abcmetainherited92 namespace — wave 254 theme: ABCMeta inherited dunder class names; ABCMeta is a metaclass that inherits from type; __getattribute__, __call__, __setattr__, and __delattr__ are all inherited from type without override in ABCMeta; because they are C-level slot wrappers defined in type, they are 'wrapper_descriptor' objects rather than Python functions; ABCMeta.__getattribute__.__class__.__name__.__eq__('wrapper_descriptor')==True; ABCMeta.__call__.__class__.__name__.__eq__('wrapper_descriptor')==True; ABCMeta.__setattr__.__class__.__name__.__eq__('wrapper_descriptor')==True; ABCMeta.__delattr__.__class__.__name__.__eq__('wrapper_descriptor')==True; all four share the same class name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetainherited92

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_getattr_cls,  "ABCMeta.__getattribute__.__class__.__name__.__eq__", ["wrapper_descriptor"], true, "ABCMeta.__getattribute__.__class__.__name__ == 'wrapper_descriptor' — inherited from type; verified with Python 3.14.3"]
    - [abcmeta_call_cls,     "ABCMeta.__call__.__class__.__name__.__eq__",         ["wrapper_descriptor"], true, "ABCMeta.__call__.__class__.__name__ == 'wrapper_descriptor' — inherited from type; verified with Python 3.14.3"]
    - [abcmeta_setattr_cls,  "ABCMeta.__setattr__.__class__.__name__.__eq__",      ["wrapper_descriptor"], true, "ABCMeta.__setattr__.__class__.__name__ == 'wrapper_descriptor' — inherited from type; verified with Python 3.14.3"]
    - [abcmeta_delattr_cls,  "ABCMeta.__delattr__.__class__.__name__.__eq__",      ["wrapper_descriptor"], true, "ABCMeta.__delattr__.__class__.__name__ == 'wrapper_descriptor' — inherited from type; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABC.__init_subclass__ class name and qualname — extra92
#
# ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method'
# ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (len=21)
# ---------------------------------------------------------------------------

table abc_extra92.abc_init_subclass_identity:
  description: "ABC.__init_subclass__ class name and qualname checks in abcmetainherited92 namespace — wave 254 theme: ABC.__init_subclass__ is a builtin class method; ABC.__init_subclass__ is a class method inherited from object and specialised in the abc module context; ABC.__init_subclass__.__class__.__name__.__eq__('builtin_function_or_method')==True (it is a C-level built-in, unlike abstractmethod which is a Python function); ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__')==True (len=21); ABC.__init_subclass__.__qualname__.__len__()==21; note: ABC.__init_subclass__ does NOT have a __func__ attribute (it is a builtin_function_or_method, not a classmethod wrapper around a Python function); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetainherited92a

  columns: [id, function, args, expected, description]
  rows:
    - [abc_init_sub_cls,  "ABC.__init_subclass__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"]
    - [abc_init_sub_qeq,  "ABC.__init_subclass__.__qualname__.__eq__",       ["ABC.__init_subclass__"],      true, "ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__'; verified with Python 3.14.3"]
    - [abc_init_sub_qlen, "ABC.__init_subclass__.__qualname__.__len__",       [],                            21,   "ABC.__init_subclass__.__qualname__.__len__() == 21 ('ABC.__init_subclass__'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABCMeta class hierarchy — extra92
#
# ABCMeta.__class__.__name__ == 'type'
# ABCMeta.__bases__[0].__name__ == 'type'
# ABCMeta.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table abc_extra92.abcmeta_class_hierarchy:
  description: "ABCMeta class hierarchy checks in abcmetainherited92 namespace — wave 254 theme: ABCMeta metaclass hierarchy; ABCMeta is itself an instance of type (the metaclass of all metaclasses); ABCMeta.__class__.__name__.__eq__('type')==True (ABCMeta's class is type, as expected for any metaclass); ABCMeta.__bases__[0].__name__.__eq__('type')==True (ABCMeta directly subclasses type, giving it metaclass behavior while adding ABCMeta-specific __new__ and other logic); ABCMeta.__mro__.__len__()==3 (MRO is [ABCMeta, type, object]); this 3-element MRO reflects ABCMeta's position as a direct subclass of type which itself subclasses object; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetainherited92b

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_class_nm,  "ABCMeta.__class__.__name__.__eq__",              ["type"],   true, "ABCMeta.__class__.__name__ == 'type' — ABCMeta is an instance of type; verified with Python 3.14.3"]
    - [abcmeta_base0_nm,  "ABCMeta.__bases__[0].__name__.__eq__",           ["type"],   true, "ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta subclasses type directly; verified with Python 3.14.3"]
    - [abcmeta_mro_len,   "ABCMeta.__mro__.__len__",                        [],         3,    "ABCMeta.__mro__.__len__() == 3 — MRO is [ABCMeta, type, object]; verified with Python 3.14.3"]

