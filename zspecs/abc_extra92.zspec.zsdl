# abstractmethod.__code__.co_name == 'abstractmethod'
# abstractmethod.__qualname__ == 'abstractmethod' (len=14)
# abstractmethod.__module__ == 'abc' (len=3)
# abstractmethod.__code__.co_argcount == 1
# ---------------------------------------------------------------------------

table abc_extra92.abstractmethod_code_attrs:
  description: "abstractmethod code attribute cross-checks in abcmetainherited92 namespace — wave 254 theme: abstractmethod code attrs; abc.abstractmethod is a Python decorator function defined in Lib/abc.py; abstractmethod.__code__.co_name.__eq__('abstractmethod')==True (co_name is the simple name of the function as it appears in source); abstractmethod.__qualname__.__eq__('abstractmethod')==True (len=14; because it is a module-level function, qualname equals __name__); abstractmethod.__module__.__eq__('abc')==True (module is the 3-char string 'abc'); abstractmethod.__code__.co_argcount.__eq__(1)==True (single argument: funcobj, the decorated function); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetainherited92c

  columns: [id, function, args, expected, description]
  rows:
    - [absmeth_coname,   "abstractmethod.__code__.co_name.__eq__",      ["abstractmethod"], true, "abstractmethod.__code__.co_name == 'abstractmethod'; verified with Python 3.14.3"]
    - [absmeth_qeq,      "abstractmethod.__qualname__.__eq__",          ["abstractmethod"], true, "abstractmethod.__qualname__ == 'abstractmethod' (len=14) — module-level function; qualname equals name; verified with Python 3.14.3"]
    - [absmeth_qlen,     "abstractmethod.__qualname__.__len__",         [],                 14,   "abstractmethod.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [absmeth_module,   "abstractmethod.__module__.__eq__",            ["abc"],            true, "abstractmethod.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [absmeth_argcnt,   "abstractmethod.__code__.co_argcount.__eq__",  [1],                true, "abstractmethod.__code__.co_argcount == 1 (single param: funcobj); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra92
# ---------------------------------------------------------------------------

invariant abc_extra92.ABCMeta_getattribute_is_wrapper_descriptor:
  description: "abc.ABCMeta.__getattribute__.__class__.__name__.__eq__('wrapper_descriptor') returns True — ABCMeta.__getattribute__ is inherited from type without override; type.__getattribute__ is a C-level slot wrapper exposed as a 'wrapper_descriptor'; 'wrapper_descriptor' is the class name for C-level slot wrappers on built-in types; this distinguishes these inherited methods from Python-level functions (class='function') or C methods defined in extension modules (class='method_descriptor' or 'builtin_function_or_method'); all four ABCMeta dunder methods checked in extra92 (__getattribute__, __call__, __setattr__, __delattr__) share this class name; NEW in extra92: first standalone ABCMeta inherited dunder invariant in abcmetainherited92 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__getattribute__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant abc_extra92.ABCMeta_call_is_wrapper_descriptor:
  description: "abc.ABCMeta.__call__.__class__.__name__.__eq__('wrapper_descriptor') returns True — ABCMeta.__call__ is inherited from type; when a metaclass instance (i.e., a class) is called to create an instance, Python invokes the metaclass's __call__; ABCMeta does not override __call__ so it inherits type.__call__ which is a 'wrapper_descriptor'; abstractmethod checks happen inside ABCMeta.__new__ and ABCMeta.__call__ (via type.__call__) but ABCMeta.__call__ itself is still the inherited type slot wrapper; NEW in extra92: first standalone ABCMeta.__call__ class name invariant in abcmetainherited92 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__call__.__class__.__name__.__eq__"
  args: ["wrapper_descriptor"]
  expected: true

invariant abc_extra92.ABCMeta_bases0_is_type:
  description: "abc.ABCMeta.__bases__[0].__name__.__eq__('type') returns True — ABCMeta directly subclasses the built-in type metaclass; this gives ABCMeta its metaclass behavior (it can be used as a metaclass in class statements) while adding ABCMeta-specific logic such as tracking abstract methods via __abstractmethods__; ABCMeta.__mro__ is [ABCMeta, type, object] (len=3); the single direct base being type (not object) is what distinguishes metaclasses from regular classes; NEW in extra92: first standalone ABCMeta base class invariant in abcmetainherited92 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra92.abstractmethod_qualname_eq:
  description: "abc.abstractmethod.__qualname__.__eq__('abstractmethod') returns True — abstractmethod is a module-level function in Lib/abc.py; for module-level functions, __qualname__ equals __name__ (both are 'abstractmethod'); the qualname length is 14; abstractmethod is a decorator that sets __isabstractmethod__ = True on the decorated function; its __code__.co_argcount is 1 (a single parameter, the function being decorated); abstractmethod.__code__.co_name is also 'abstractmethod' (matching qualname); NEW in extra92: first standalone abstractmethod qualname invariant in abcmetainherited92 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abstractmethod.__qualname__.__eq__"
  args: ["abstractmethod"]
  expected: true

invariant abc_extra92.ABC_init_subclass_is_builtin:
  description: "abc.ABC.__init_subclass__.__class__.__name__.__eq__('builtin_function_or_method') returns True — ABC.__init_subclass__ is inherited from object; object.__init_subclass__ is implemented in C and exposed as a 'builtin_function_or_method'; unlike Python class methods (which would have class 'classmethod' or 'function'), this C-level class method shows 'builtin_function_or_method'; ABC.__init_subclass__.__qualname__ is 'ABC.__init_subclass__' (len=21); it does NOT have a __func__ attribute because it is not a classmethod wrapper around a Python function; NEW in extra92: first standalone ABC.__init_subclass__ class name invariant in abcmetainherited92 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABC.__init_subclass__.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true
