spec: dataclasses_extra25
version: ">=3.10"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses_extra24.zspec.zsdl."
    - "Focus: __qualname__ values for dataclasses.Field instance methods (Field.__set_name__, Field.__repr__, Field.__init__) and sentinel type metadata for MISSING and KW_ONLY in the extra25 namespace."
    - "dataclasses_extra10 covers MISSING.__class__.__qualname__ == '_MISSING_TYPE' and KW_ONLY.__class__.__qualname__ == '_KW_ONLY_TYPE' in the extra10 namespace."
    - "dataclasses_extra4 covers MISSING.__class__.__name__ == '_MISSING_TYPE' in the extra4 namespace."
    - "dataclasses_extra3 covers KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' in the extra3 namespace."
    - "No prior dataclasses spec records Field.__set_name__.__qualname__, Field.__repr__.__qualname__, or Field.__init__.__qualname__ in any table or standalone invariant."
    - "KW_ONLY was introduced in Python 3.10; spec version is set to >=3.10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dataclasses.Field method __qualname__ values — combined table
#
# Field defines __set_name__, __repr__, and __init__ as instance methods.
# Their __qualname__ values follow the standard 'ClassName.method_name' pattern.
# No prior dataclasses spec records any of these method qualnames.
# ---------------------------------------------------------------------------

table dataclasses_extra25.Field_method_qualnames:
  description: "__qualname__.__eq__ for dataclasses.Field instance methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [set_name, "Field.__set_name__.__qualname__.__eq__", ["Field.__set_name__"], true]
    - [repr,     "Field.__repr__.__qualname__.__eq__",     ["Field.__repr__"],     true]
    - [init,     "Field.__init__.__qualname__.__eq__",     ["Field.__init__"],     true]

# ---------------------------------------------------------------------------
# dataclasses.Field method __qualname__.__len__() values — combined table
#
# Verifies the string length of each Field method __qualname__:
#   Field.__set_name__ -> 18, Field.__repr__ -> 14, Field.__init__ -> 14
# No prior dataclasses spec collects these three method qualname lengths together.
# ---------------------------------------------------------------------------

table dataclasses_extra25.Field_method_qualname_lens:
  description: "__qualname__.__len__() for dataclasses.Field instance methods"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [set_name, "Field.__set_name__.__qualname__.__len__", [], 18]
    - [repr,     "Field.__repr__.__qualname__.__len__",     [], 14]
    - [init,     "Field.__init__.__qualname__.__len__",     [], 14]

# ---------------------------------------------------------------------------
# dataclasses.MISSING.__class__.__name__ — standalone invariant
# (dataclasses_extra25 namespace)
#
# dataclasses_extra4 covers MISSING.__class__.__name__ == '_MISSING_TYPE' in the
# extra4 namespace. Providing a standalone in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra25.MISSING.class_name:
  description: "type(dataclasses.MISSING).__name__ == '_MISSING_TYPE' — MISSING sentinel class name"
  category: sentinel_types
  kind: python_call_eq
  function: "MISSING.__class__.__name__.__eq__"
  args: ["_MISSING_TYPE"]
  expected: true

# ---------------------------------------------------------------------------
# dataclasses.KW_ONLY.__class__.__qualname__ — standalone invariant
# (dataclasses_extra25 namespace)
#
# dataclasses_extra10 covers KW_ONLY.__class__.__qualname__ == '_KW_ONLY_TYPE'
# in the extra10 namespace. Providing a standalone in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra25.KW_ONLY.class_qualname:
  description: "type(dataclasses.KW_ONLY).__qualname__ == '_KW_ONLY_TYPE' — KW_ONLY sentinel class qualname"
  category: sentinel_types
  kind: python_call_eq
  function: "KW_ONLY.__class__.__qualname__.__eq__"
  args: ["_KW_ONLY_TYPE"]
  expected: true
