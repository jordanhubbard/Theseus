spec: pathlib_extra144
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path comparison operators __gt__ and __ge__ (__qualname__, __code__.co_argcount), pathlib.PurePath class identity (__name__, __module__, __qualname__, __class__.__name__), and pathlib.PurePosixPath / pathlib.PureWindowsPath class identity."
    - "Path.__gt__ and Path.__ge__ are inherited from PurePath; their __qualname__ values carry the 'PurePath.' prefix, same pattern as __lt__ and __le__ (covered in spec 143)."
    - "Path.__gt__.__qualname__ == 'PurePath.__gt__' (length 15); Path.__ge__.__qualname__ == 'PurePath.__ge__' (length 15)."
    - "Path.__gt__.__code__.co_argcount == 2 (self + other), same as __lt__, __le__, __eq__."
    - "pathlib.PurePath.__name__ == 'PurePath' (length 8); __module__ == 'pathlib' (length 7); __class__.__name__ == 'type'."
    - "pathlib.PurePosixPath.__name__ == 'PurePosixPath' (length 13); __module__ == 'pathlib' (length 7)."
    - "pathlib.PureWindowsPath.__name__ == 'PureWindowsPath' (length 15); __module__ == 'pathlib' (length 7)."
    - "Path.__init__.__code__.co_varnames.__len__() == 5 (variables: self, args, paths, arg, path)."
    - "Path.__new__.__code__.co_varnames.__len__() == 3 (variables: cls, args, kwargs)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path __gt__ and __ge__ method identity
# Both are inherited from PurePath.
# __gt__: qualname 'PurePath.__gt__' (15), co_argcount 2
# __ge__: qualname 'PurePath.__ge__' (15), co_argcount 2
# ---------------------------------------------------------------------------

table pathlib_extra144.Path_gt_ge_identity:
  description: "pathlib.Path __gt__ and __ge__ comparison method identity: both inherited from PurePath with qualname 'PurePath.__gt__'/'PurePath.__ge__' (15), co_argcount 2"
  kind: python_call_eq
  category: method_qualname
  id_prefix: pathlibcmp144

  columns: [id, function, args, expected]
  rows:
    - [gt_qn_eq,    "Path.__gt__.__qualname__.__eq__",              ["PurePath.__gt__"], true]
    - [gt_qn_len,   "Path.__gt__.__qualname__.__len__",             [],                  15]
    - [gt_argc,     "Path.__gt__.__code__.co_argcount.__eq__",      [2],                 true]
    - [ge_qn_eq,    "Path.__ge__.__qualname__.__eq__",              ["PurePath.__ge__"], true]
    - [ge_qn_len,   "Path.__ge__.__qualname__.__len__",             [],                  15]
    - [ge_argc,     "Path.__ge__.__code__.co_argcount.__eq__",      [2],                 true]

# ---------------------------------------------------------------------------
# pathlib.PurePath class identity
# PurePath is the abstract pure-path base class.
# __name__ == 'PurePath' (8), __module__ == 'pathlib' (7),
# __qualname__ == 'PurePath' (8), __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table pathlib_extra144.PurePath_class_identity:
  description: "pathlib.PurePath class identity: __name__='PurePath' (8), __module__='pathlib' (7), __qualname__='PurePath' (8), __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibpp144

  columns: [id, function, args, expected]
  rows:
    - [pp_name_eq,      PurePath.__name__.__eq__,          ["PurePath"], true]
    - [pp_name_len,     PurePath.__name__.__len__,         [],           8]
    - [pp_module_eq,    PurePath.__module__.__eq__,        ["pathlib"],  true]
    - [pp_module_len,   PurePath.__module__.__len__,       [],           7]
    - [pp_qualname_eq,  PurePath.__qualname__.__eq__,      ["PurePath"], true]
    - [pp_qualname_len, PurePath.__qualname__.__len__,     [],           8]
    - [pp_cls_eq,       PurePath.__class__.__name__.__eq__, ["type"],    true]

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath and pathlib.PureWindowsPath class identity
# PurePosixPath: __name__ == 'PurePosixPath' (13), __module__ == 'pathlib' (7).
# PureWindowsPath: __name__ == 'PureWindowsPath' (15), __module__ == 'pathlib' (7).
# Both have __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table pathlib_extra144.PurePosixPath_PureWindowsPath_identity:
  description: "pathlib.PurePosixPath and PureWindowsPath class identity: __name__ lengths 13/15, __module__='pathlib' (7), __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibpp144

  columns: [id, function, args, expected]
  rows:
    - [ppx_name_eq,      PurePosixPath.__name__.__eq__,           ["PurePosixPath"],   true]
    - [ppx_name_len,     PurePosixPath.__name__.__len__,          [],                  13]
    - [ppx_module_eq,    PurePosixPath.__module__.__eq__,         ["pathlib"],         true]
    - [ppx_qualname_len, PurePosixPath.__qualname__.__len__,      [],                  13]
    - [ppx_cls_eq,       PurePosixPath.__class__.__name__.__eq__, ["type"],            true]
    - [pwx_name_eq,      PureWindowsPath.__name__.__eq__,         ["PureWindowsPath"], true]
    - [pwx_name_len,     PureWindowsPath.__name__.__len__,        [],                  15]
    - [pwx_module_eq,    PureWindowsPath.__module__.__eq__,       ["pathlib"],         true]
    - [pwx_qualname_len, PureWindowsPath.__qualname__.__len__,    [],                  15]
    - [pwx_cls_eq,       PureWindowsPath.__class__.__name__.__eq__, ["type"],          true]

# ---------------------------------------------------------------------------
# pathlib.Path.__init__ and __new__ co_varnames lengths
# __init__.__code__.co_varnames == ('self', 'args', 'paths', 'arg', 'path') -> length 5
# __new__.__code__.co_varnames == ('cls', 'args', 'kwargs') -> length 3
# ---------------------------------------------------------------------------

table pathlib_extra144.Path_init_new_co_varnames:
  description: "pathlib.Path __init__ and __new__ co_varnames tuple lengths: __init__ has 5 local variables (self, args, paths, arg, path), __new__ has 3 (cls, args, kwargs)"
  kind: python_call_eq
  category: method_signature
  id_prefix: pathlibinit144

  columns: [id, function, args, expected]
  rows:
    - [init_vars_len, "Path.__init__.__code__.co_varnames.__len__", [], 5]
    - [new_vars_len,  "Path.__new__.__code__.co_varnames.__len__",  [], 3]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra144.Path.__gt__.qualname_is_PurePath:
  description: "pathlib.Path.__gt__.__qualname__ == 'PurePath.__gt__' (length 15; the > comparison operator is defined on PurePath and inherited by Path, following the same pattern as __lt__ and __le__)"
  category: method_qualname
  kind: python_call_eq
  function: "Path.__gt__.__qualname__.__eq__"
  args: ["PurePath.__gt__"]
  expected: true

invariant pathlib_extra144.Path.__ge__.qualname_len_15:
  description: "pathlib.Path.__ge__.__qualname__.__len__() == 15 ('PurePath.__ge__' has 15 characters; the >= operator inherits from PurePath just like __gt__, __lt__, __le__)"
  category: method_qualname
  kind: python_call_eq
  function: "Path.__ge__.__qualname__.__len__"
  args: []
  expected: 15

invariant pathlib_extra144.PurePath.name_is_PurePath:
  description: "pathlib.PurePath.__name__ == 'PurePath' (length 8; PurePath is the abstract base for all pure path objects, defined in the pathlib module)"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra144.PurePosixPath.name_len_13:
  description: "pathlib.PurePosixPath.__name__.__len__() == 13 ('PurePosixPath' has 13 characters; it is the POSIX-flavored pure path subclass of PurePath)"
  category: class_identity
  kind: python_call_eq
  function: PurePosixPath.__name__.__len__
  args: []
  expected: 13

invariant pathlib_extra144.PureWindowsPath.name_len_15:
  description: "pathlib.PureWindowsPath.__name__.__len__() == 15 ('PureWindowsPath' has 15 characters; it is the Windows-flavored pure path subclass of PurePath)"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__name__.__len__
  args: []
  expected: 15

invariant pathlib_extra144.Path.__init__.co_varnames_len_5:
  description: "pathlib.Path.__init__.__code__.co_varnames.__len__() == 5 (the local variable names are self, args, paths, arg, path — five names in total)"
  category: method_signature
  kind: python_call_eq
  function: "Path.__init__.__code__.co_varnames.__len__"
  args: []
  expected: 5
