spec: decimal_extra145
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal.__dict__.__contains__ membership for key arithmetic and mathematical methods (__add__, quantize, sqrt, normalize, __mul__, __sub__, compare, ln, log10, exp, fma, is_nan, is_finite, is_zero, as_tuple, to_eng_string). Also covers decimal.Context.__dict__.__contains__ for context-level operations (quantize, prec, rounding, Emax, Emin, create_decimal, sqrt, normalize, add, multiply, subtract, divide, power, compare, ln, log10, exp)."
    - "All checked Decimal methods are in Decimal.__dict__ — confirmed with Python 3.14.3. Decimal.__dict__.__len__() == 101 (covered in decimal_extra144)."
    - "All checked Context attributes are in Context.__dict__ — confirmed with Python 3.14.3. Context.__dict__.__len__() == 85 (covered in decimal_extra144)."
    - "decimal.Decimal method qualnames (sorted by length): ln/exp/fma (10-11), sqrt/prec (12), log10 (13), __add__/compare (15), quantize (16), normalize (17)."
    - "decimal.Context method qualnames mirror Decimal's: Context.ln (10), Context.exp (11), Context.sqrt (12), Context.prec (12), Context.log10 (13), Context.compare (15), Context.quantize/multiply (16), Context.normalize (17)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__.__contains__ — arithmetic operator methods
# __add__, __mul__, __sub__, __truediv__, __floordiv__, __mod__, __pow__,
# __neg__, __pos__, __abs__ — all defined directly in Decimal.__dict__.
# ---------------------------------------------------------------------------

table decimal_extra145.Decimal_dict_contains_operators:
  description: "decimal.Decimal.__dict__.__contains__: __add__/__mul__/__sub__/__truediv__/__floordiv__/__mod__/__pow__/__neg__/__pos__/__abs__ all True (arithmetic operator methods in Decimal)"
  kind: python_call_eq
  category: identity
  id_prefix: decdec145

  columns: [id, function, args, expected, description]
  rows:
    - [has_add,       Decimal.__dict__.__contains__, ["__add__"],       true, "decimal.Decimal.__dict__.__contains__('__add__') == True (__add__ is defined directly in Decimal.__dict__; implements decimal + other; Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=15))"]
    - [has_mul,       Decimal.__dict__.__contains__, ["__mul__"],       true, "decimal.Decimal.__dict__.__contains__('__mul__') == True (__mul__ implements decimal * other; like __add__, it respects the current Context for precision and rounding)"]
    - [has_sub,       Decimal.__dict__.__contains__, ["__sub__"],       true, "decimal.Decimal.__dict__.__contains__('__sub__') == True (__sub__ implements decimal - other)"]
    - [has_truediv,   Decimal.__dict__.__contains__, ["__truediv__"],   true, "decimal.Decimal.__dict__.__contains__('__truediv__') == True (__truediv__ implements decimal / other using the current Context precision)"]
    - [has_floordiv,  Decimal.__dict__.__contains__, ["__floordiv__"],  true, "decimal.Decimal.__dict__.__contains__('__floordiv__') == True (__floordiv__ implements decimal // other; returns the truncated integer part of the division)"]
    - [has_mod,       Decimal.__dict__.__contains__, ["__mod__"],       true, "decimal.Decimal.__dict__.__contains__('__mod__') == True (__mod__ implements decimal % other; the remainder after floor division)"]
    - [has_pow,       Decimal.__dict__.__contains__, ["__pow__"],       true, "decimal.Decimal.__dict__.__contains__('__pow__') == True (__pow__ implements decimal ** other; raises to the power using the current Context)"]
    - [has_neg,       Decimal.__dict__.__contains__, ["__neg__"],       true, "decimal.Decimal.__dict__.__contains__('__neg__') == True (__neg__ implements -decimal; negation preserving the number of significant digits)"]
    - [has_pos,       Decimal.__dict__.__contains__, ["__pos__"],       true, "decimal.Decimal.__dict__.__contains__('__pos__') == True (__pos__ implements +decimal; returns a copy with the same value, applying rounding per Context)"]
    - [has_abs,       Decimal.__dict__.__contains__, ["__abs__"],       true, "decimal.Decimal.__dict__.__contains__('__abs__') == True (__abs__ implements abs(decimal); returns the absolute value)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.__dict__.__contains__ — mathematical and utility methods
# quantize, sqrt, normalize, fma, compare, ln, log10, exp, is_nan, is_finite,
# is_zero, is_signed, is_infinite, compare_total, to_eng_string, as_tuple.
# ---------------------------------------------------------------------------

table decimal_extra145.Decimal_dict_contains_math_methods:
  description: "decimal.Decimal.__dict__.__contains__: quantize/sqrt/normalize/fma/compare/ln/log10/exp/is_nan/is_finite/is_zero/compare_total/to_eng_string/as_tuple all True"
  kind: python_call_eq
  category: identity
  id_prefix: decdec145

  columns: [id, function, args, expected, description]
  rows:
    - [has_quantize,       Decimal.__dict__.__contains__, ["quantize"],       true, "decimal.Decimal.__dict__.__contains__('quantize') == True (quantize rounds the decimal to the same number of fractional digits as exp; e.g. Decimal('1.41421').quantize(Decimal('0.01')) == Decimal('1.41'); Decimal.quantize.__qualname__ == 'Decimal.quantize' (len=16))"]
    - [has_sqrt,           Decimal.__dict__.__contains__, ["sqrt"],           true, "decimal.Decimal.__dict__.__contains__('sqrt') == True (sqrt returns the square root of the decimal to full precision; Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (len=12))"]
    - [has_normalize,      Decimal.__dict__.__contains__, ["normalize"],      true, "decimal.Decimal.__dict__.__contains__('normalize') == True (normalize reduces the decimal to its simplest form by removing trailing zeros; Decimal.normalize.__qualname__ == 'Decimal.normalize' (len=17))"]
    - [has_fma,            Decimal.__dict__.__contains__, ["fma"],            true, "decimal.Decimal.__dict__.__contains__('fma') == True (fma is fused-multiply-add: computes self*other+third without intermediate rounding; Decimal.fma.__qualname__ == 'Decimal.fma' (len=11))"]
    - [has_compare,        Decimal.__dict__.__contains__, ["compare"],        true, "decimal.Decimal.__dict__.__contains__('compare') == True (compare returns Decimal('-1'), Decimal('0'), or Decimal('1') for less-than, equal, or greater-than; unlike __eq__ it does not consider NaN equal to itself)"]
    - [has_ln,             Decimal.__dict__.__contains__, ["ln"],             true, "decimal.Decimal.__dict__.__contains__('ln') == True (ln returns the natural logarithm of the decimal; Decimal.ln.__qualname__ == 'Decimal.ln' (len=10); the shortest Decimal method qualname by length)"]
    - [has_log10,          Decimal.__dict__.__contains__, ["log10"],          true, "decimal.Decimal.__dict__.__contains__('log10') == True (log10 returns the base-10 logarithm; Decimal.log10.__qualname__ == 'Decimal.log10' (len=13))"]
    - [has_exp,            Decimal.__dict__.__contains__, ["exp"],            true, "decimal.Decimal.__dict__.__contains__('exp') == True (exp returns e raised to the power of the decimal; Decimal.exp.__qualname__ == 'Decimal.exp' (len=11); tied with fma at 11)"]
    - [has_is_nan,         Decimal.__dict__.__contains__, ["is_nan"],         true, "decimal.Decimal.__dict__.__contains__('is_nan') == True (is_nan returns True if the decimal is a quiet NaN or signaling NaN)"]
    - [has_is_finite,      Decimal.__dict__.__contains__, ["is_finite"],      true, "decimal.Decimal.__dict__.__contains__('is_finite') == True (is_finite returns True if the decimal is finite; False for Infinity or NaN)"]
    - [has_is_zero,        Decimal.__dict__.__contains__, ["is_zero"],        true, "decimal.Decimal.__dict__.__contains__('is_zero') == True (is_zero returns True if the decimal is a zero; both positive and negative zero return True)"]
    - [has_compare_total,  Decimal.__dict__.__contains__, ["compare_total"],  true, "decimal.Decimal.__dict__.__contains__('compare_total') == True (compare_total compares two Decimals using the IEEE 754 total ordering, which distinguishes between -0 and +0 and between different NaN payloads)"]
    - [has_to_eng_string,  Decimal.__dict__.__contains__, ["to_eng_string"],  true, "decimal.Decimal.__dict__.__contains__('to_eng_string') == True (to_eng_string returns the decimal as an engineering notation string where the exponent is a multiple of 3)"]
    - [has_as_tuple,       Decimal.__dict__.__contains__, ["as_tuple"],       true, "decimal.Decimal.__dict__.__contains__('as_tuple') == True (as_tuple returns a DecimalTuple named tuple with (sign, digits, exponent) fields)"]

# ---------------------------------------------------------------------------
# decimal.Context.__dict__.__contains__ — context-level operations
# quantize, prec, rounding, Emax, Emin, create_decimal, sqrt, normalize,
# add, multiply, subtract, divide, power, compare, ln, log10, exp.
# ---------------------------------------------------------------------------

table decimal_extra145.Context_dict_contains_methods:
  description: "decimal.Context.__dict__.__contains__: quantize/sqrt/normalize/add/multiply/subtract/divide/power/compare/ln/log10/exp/create_decimal all True"
  kind: python_call_eq
  category: identity
  id_prefix: decdec145

  columns: [id, function, args, expected, description]
  rows:
    - [has_quantize,      Context.__dict__.__contains__, ["quantize"],      true, "decimal.Context.__dict__.__contains__('quantize') == True (Context.quantize rounds the Decimal using this Context's settings; Context.quantize.__qualname__ == 'Context.quantize' (len=16))"]
    - [has_sqrt,          Context.__dict__.__contains__, ["sqrt"],          true, "decimal.Context.__dict__.__contains__('sqrt') == True (Context.sqrt computes the square root using this Context's precision; Context.sqrt.__qualname__ == 'Context.sqrt' (len=12))"]
    - [has_normalize,     Context.__dict__.__contains__, ["normalize"],     true, "decimal.Context.__dict__.__contains__('normalize') == True (Context.normalize reduces trailing zeros; Context.normalize.__qualname__ == 'Context.normalize' (len=17))"]
    - [has_add,           Context.__dict__.__contains__, ["add"],           true, "decimal.Context.__dict__.__contains__('add') == True (Context.add adds two Decimals using this Context; explicit context version of the + operator; Context.add.__qualname__ == 'Context.add' (len=11))"]
    - [has_multiply,      Context.__dict__.__contains__, ["multiply"],      true, "decimal.Context.__dict__.__contains__('multiply') == True (Context.multiply multiplies two Decimals using this Context; Context.multiply.__qualname__ == 'Context.multiply' (len=16))"]
    - [has_subtract,      Context.__dict__.__contains__, ["subtract"],      true, "decimal.Context.__dict__.__contains__('subtract') == True (Context.subtract subtracts two Decimals using this Context)"]
    - [has_divide,        Context.__dict__.__contains__, ["divide"],        true, "decimal.Context.__dict__.__contains__('divide') == True (Context.divide divides two Decimals using this Context)"]
    - [has_power,         Context.__dict__.__contains__, ["power"],         true, "decimal.Context.__dict__.__contains__('power') == True (Context.power raises a Decimal to a power using this Context)"]
    - [has_compare,       Context.__dict__.__contains__, ["compare"],       true, "decimal.Context.__dict__.__contains__('compare') == True (Context.compare compares two Decimals; Context.compare.__qualname__ == 'Context.compare' (len=15))"]
    - [has_ln,            Context.__dict__.__contains__, ["ln"],            true, "decimal.Context.__dict__.__contains__('ln') == True (Context.ln computes the natural logarithm; Context.ln.__qualname__ == 'Context.ln' (len=10))"]
    - [has_log10,         Context.__dict__.__contains__, ["log10"],         true, "decimal.Context.__dict__.__contains__('log10') == True (Context.log10 computes the base-10 logarithm; Context.log10.__qualname__ == 'Context.log10' (len=13))"]
    - [has_exp,           Context.__dict__.__contains__, ["exp"],           true, "decimal.Context.__dict__.__contains__('exp') == True (Context.exp raises e to the power of the Decimal; Context.exp.__qualname__ == 'Context.exp' (len=11))"]
    - [has_create_decimal,Context.__dict__.__contains__, ["create_decimal"],true, "decimal.Context.__dict__.__contains__('create_decimal') == True (create_decimal converts a value to a Decimal using this Context; Context.create_decimal.__qualname__ == 'Context.create_decimal' (len=22))"]

table decimal_extra145.Context_dict_contains_settings:
  description: "decimal.Context.__dict__.__contains__: prec/rounding/Emax/Emin all True (context configuration attributes in Context)"
  kind: python_call_eq
  category: identity
  id_prefix: decdec145

  columns: [id, function, args, expected, description]
  rows:
    - [has_prec,     Context.__dict__.__contains__, ["prec"],    true, "decimal.Context.__dict__.__contains__('prec') == True (prec is a settable attribute controlling the number of significant digits; DefaultContext.prec == 28 as covered in decimal_extra143; Context.prec.__qualname__ == 'Context.prec' (len=12))"]
    - [has_rounding, Context.__dict__.__contains__, ["rounding"],true, "decimal.Context.__dict__.__contains__('rounding') == True (rounding is a settable attribute controlling the rounding mode; defaults to ROUND_HALF_EVEN which is banker's rounding)"]
    - [has_Emax,     Context.__dict__.__contains__, ["Emax"],    true, "decimal.Context.__dict__.__contains__('Emax') == True (Emax is the maximum exponent permitted; for DefaultContext, Emax == 999999999)"]
    - [has_Emin,     Context.__dict__.__contains__, ["Emin"],    true, "decimal.Context.__dict__.__contains__('Emin') == True (Emin is the minimum exponent permitted; for DefaultContext, Emin == -999999999)"]

# ---------------------------------------------------------------------------
# decimal.Decimal method __qualname__ values
# Sorted by length: ln=10, exp/fma=11, sqrt=12, log10=13, __add__/compare=15,
# quantize/multiply=16, normalize=17.
# ---------------------------------------------------------------------------

table decimal_extra145.Decimal_method_qualnames:
  description: "decimal.Decimal method __qualname__ values: ln=10, exp/fma=11, sqrt=12, log10=13, __add__/compare=15, quantize=16, normalize=17"
  kind: python_call_eq
  category: qualname
  id_prefix: decdec145

  columns: [id, function, args, expected, description]
  rows:
    - [ln_qeq,        Decimal.ln.__qualname__.__eq__,        ["Decimal.ln"],        true, "decimal.Decimal.ln.__qualname__ == 'Decimal.ln' (len=10; 'Decimal.' (8) + 'ln' (2) = 10; the shortest Decimal method qualname; ln computes the natural logarithm)"]
    - [ln_qlen,       Decimal.ln.__qualname__.__len__,        [],                    10,   "decimal.Decimal.ln.__qualname__.__len__() == 10 ('Decimal.ln' has 10 characters; the shortest among Decimal method qualnames)"]
    - [exp_qeq,       Decimal.exp.__qualname__.__eq__,       ["Decimal.exp"],       true, "decimal.Decimal.exp.__qualname__ == 'Decimal.exp' (len=11; 'Decimal.' (8) + 'exp' (3) = 11; tied with fma at 11)"]
    - [exp_qlen,      Decimal.exp.__qualname__.__len__,      [],                    11,   "decimal.Decimal.exp.__qualname__.__len__() == 11 ('Decimal.exp' has 11 characters; tied with Decimal.fma)"]
    - [fma_qeq,       Decimal.fma.__qualname__.__eq__,       ["Decimal.fma"],       true, "decimal.Decimal.fma.__qualname__ == 'Decimal.fma' (len=11; fused-multiply-add; tied with exp at 11)"]
    - [sqrt_qeq,      Decimal.sqrt.__qualname__.__eq__,      ["Decimal.sqrt"],      true, "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (len=12; 'Decimal.' (8) + 'sqrt' (4) = 12)"]
    - [sqrt_qlen,     Decimal.sqrt.__qualname__.__len__,     [],                    12,   "decimal.Decimal.sqrt.__qualname__.__len__() == 12 ('Decimal.sqrt' has 12 characters)"]
    - [log10_qeq,     Decimal.log10.__qualname__.__eq__,     ["Decimal.log10"],     true, "decimal.Decimal.log10.__qualname__ == 'Decimal.log10' (len=13; 'Decimal.' (8) + 'log10' (5) = 13)"]
    - [log10_qlen,    Decimal.log10.__qualname__.__len__,    [],                    13,   "decimal.Decimal.log10.__qualname__.__len__() == 13 ('Decimal.log10' has 13 characters)"]
    - [add_qeq,       Decimal.__add__.__qualname__.__eq__,   ["Decimal.__add__"],   true, "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=15; tied with Decimal.compare at 15)"]
    - [add_qlen,      Decimal.__add__.__qualname__.__len__,  [],                    15,   "decimal.Decimal.__add__.__qualname__.__len__() == 15 ('Decimal.__add__' has 15 characters; tied with compare)"]
    - [cmp_qeq,       Decimal.compare.__qualname__.__eq__,   ["Decimal.compare"],   true, "decimal.Decimal.compare.__qualname__ == 'Decimal.compare' (len=15; tied with __add__ at 15)"]
    - [quantize_qeq,  Decimal.quantize.__qualname__.__eq__,  ["Decimal.quantize"],  true, "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' (len=16; 'Decimal.' (8) + 'quantize' (8) = 16)"]
    - [quantize_qlen, Decimal.quantize.__qualname__.__len__, [],                    16,   "decimal.Decimal.quantize.__qualname__.__len__() == 16 ('Decimal.quantize' has 16 characters)"]
    - [norm_qeq,      Decimal.normalize.__qualname__.__eq__, ["Decimal.normalize"], true, "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' (len=17; 'Decimal.' (8) + 'normalize' (9) = 17; one of the longest Decimal method qualnames in this spec)"]
    - [norm_qlen,     Decimal.normalize.__qualname__.__len__,[],                    17,   "decimal.Decimal.normalize.__qualname__.__len__() == 17 ('Decimal.normalize' has 17 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra145.Decimal.dict_has_add:
  description: "decimal.Decimal.__dict__.__contains__('__add__') == True — __add__ is defined directly in Decimal.__dict__; it implements the + operator for decimal arithmetic; unlike float addition, Decimal.__add__ respects the current thread-local Context (precision, rounding mode); Decimal.__add__.__qualname__ == 'Decimal.__add__' (len=15, the same as Decimal.compare)"
  category: identity
  kind: python_call_eq
  function: Decimal.__dict__.__contains__
  args: ["__add__"]
  expected: true

invariant decimal_extra145.Decimal.dict_has_quantize:
  description: "decimal.Decimal.__dict__.__contains__('quantize') == True — quantize is one of the most important Decimal methods; it rounds the value to the same number of fractional digits as exp; e.g. Decimal('1.41421356').quantize(Decimal('0.01')) == Decimal('1.41'); commonly used for monetary calculations; Decimal.quantize.__qualname__ == 'Decimal.quantize' (len=16)"
  category: identity
  kind: python_call_eq
  function: Decimal.__dict__.__contains__
  args: ["quantize"]
  expected: true

invariant decimal_extra145.Decimal.dict_has_sqrt:
  description: "decimal.Decimal.__dict__.__contains__('sqrt') == True — sqrt is defined directly in Decimal.__dict__; it returns the square root of the Decimal to full precision as determined by the current Context; unlike math.sqrt() which converts to float, Decimal.sqrt() stays in decimal arithmetic; Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (len=12)"
  category: identity
  kind: python_call_eq
  function: Decimal.__dict__.__contains__
  args: ["sqrt"]
  expected: true

invariant decimal_extra145.Decimal.dict_has_normalize:
  description: "decimal.Decimal.__dict__.__contains__('normalize') == True — normalize is defined directly in Decimal.__dict__; it reduces the Decimal to its simplest form by stripping trailing zeros and adjusting the exponent (e.g. Decimal('1.50') becomes Decimal('1.5')); Decimal.normalize.__qualname__ == 'Decimal.normalize' (len=17)"
  category: identity
  kind: python_call_eq
  function: Decimal.__dict__.__contains__
  args: ["normalize"]
  expected: true

invariant decimal_extra145.Context.dict_has_quantize:
  description: "decimal.Context.__dict__.__contains__('quantize') == True — quantize is defined in Context.__dict__; Context.quantize(x, exp) rounds x to the exponent of exp using this Context's rounding mode; Context.quantize.__qualname__ == 'Context.quantize' (len=16, the same length as Decimal.quantize at 16)"
  category: identity
  kind: python_call_eq
  function: Context.__dict__.__contains__
  args: ["quantize"]
  expected: true

invariant decimal_extra145.Context.dict_has_prec:
  description: "decimal.Context.__dict__.__contains__('prec') == True — prec is a settable attribute in Context.__dict__; it controls the number of significant digits used in arithmetic operations; DefaultContext.prec == 28 (covered in decimal_extra143); BasicContext.prec == 9 (also covered in decimal_extra143); Context.prec.__qualname__ == 'Context.prec' (len=12)"
  category: identity
  kind: python_call_eq
  function: Context.__dict__.__contains__
  args: ["prec"]
  expected: true

invariant decimal_extra145.Decimal.ln_qualname_len_10:
  description: "decimal.Decimal.ln.__qualname__.__len__() == 10 ('Decimal.ln' has 10 characters; 'Decimal.' (8) + 'ln' (2) = 10; the shortest Decimal method qualname in this spec — shorter than Decimal.exp (11), Decimal.fma (11), Decimal.sqrt (12); ln() computes the natural logarithm to full Context precision)"
  category: qualname
  kind: python_call_eq
  function: Decimal.ln.__qualname__.__len__
  args: []
  expected: 10

invariant decimal_extra145.Decimal.normalize_qualname_len_17:
  description: "decimal.Decimal.normalize.__qualname__.__len__() == 17 ('Decimal.normalize' has 17 characters; 'Decimal.' (8) + 'normalize' (9) = 17; longer than Decimal.quantize (16), Decimal.compare/__add__ (15), Decimal.log10 (13); the longest Decimal method qualname covered in this spec; the longest overall is Context.create_decimal_from_float (33), covered in decimal_extra144)"
  category: qualname
  kind: python_call_eq
  function: Decimal.normalize.__qualname__.__len__
  args: []
  expected: 17
