# ---------------------------------------------------------------------------
# Table 1: threading.Thread property types and fget qualnames
#
# Wave 263 theme: threading.Thread exposes daemon, name, ident, and native_id
# as Python property objects. All four are 'property' type. The fget (getter)
# function for each property is a pure-Python function whose __qualname__ follows
# the 'Thread.property_name' dotted pattern. fget co_argcount is always 1 (self
# only). Qualname lengths differ by property name length:
# 'Thread.daemon' == 13 (7+1+6=14? no: T-h-r-e-a-d-.-d-a-e-m-o-n = 13)
# 'Thread.name'  == 11 (T-h-r-e-a-d-.-n-a-m-e = 11)
# 'Thread.ident' == 12 (T-h-r-e-a-d-.-i-d-e-n-t = 12)
# 'Thread.native_id' == 16 (T-h-r-e-a-d-.-n-a-t-i-v-e-_-i-d = 16)
#
# type(threading.Thread.daemon).__name__ == 'property'
# threading.Thread.daemon.fget.__qualname__ == 'Thread.daemon'
# type(threading.Thread.name).__name__ == 'property'
# threading.Thread.name.fget.__qualname__ == 'Thread.name'
# type(threading.Thread.ident).__name__ == 'property'
# threading.Thread.ident.fget.__qualname__ == 'Thread.ident'
# type(threading.Thread.native_id).__name__ == 'property'
# threading.Thread.native_id.fget.__qualname__ == 'Thread.native_id'
#
# New to extra113.
# ---------------------------------------------------------------------------

table threading_extra113.thread_property_types_and_fget_qualnames:
  description: "threading.Thread property types and fget qualnames: daemon/name/ident/native_id all 'property'; fget qualnames 'Thread.daemon'(13)/'Thread.name'(11)/'Thread.ident'(12)/'Thread.native_id'(16); wave 263; new to extra113"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtpf113

  columns: [id, function, args, expected, description]
  rows:
    - [daemon_property_type,
       "Thread.daemon.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.daemon.__class__.__name__.__eq__('property') == True — threading.Thread.daemon is a Python property object; accessing it from the class (not an instance) returns the property descriptor itself; type(threading.Thread.daemon).__name__ is 'property'; str.__eq__('property') returns True; new to extra113"]
    - [daemon_fget_qualname,
       "Thread.daemon.fget.__qualname__.__eq__",
       ["Thread.daemon"],
       true,
       "threading.Thread.daemon.fget.__qualname__.__eq__('Thread.daemon') == True — threading.Thread.daemon.fget is the getter function for the daemon property; its __qualname__ is 'Thread.daemon' following the 'Thread.property_name' dotted pattern used by Python property getters defined inside a class body; str.__eq__('Thread.daemon') returns True; new to extra113"]
    - [name_property_type,
       "Thread.name.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.name.__class__.__name__.__eq__('property') == True — threading.Thread.name is a Python property object for the thread name attribute; type(threading.Thread.name).__name__ is 'property'; str.__eq__('property') returns True; new to extra113"]
    - [name_fget_qualname,
       "Thread.name.fget.__qualname__.__eq__",
       ["Thread.name"],
       true,
       "threading.Thread.name.fget.__qualname__.__eq__('Thread.name') == True — threading.Thread.name.fget is the getter for the name property; its __qualname__ is 'Thread.name'; str.__eq__('Thread.name') returns True; new to extra113"]
    - [ident_property_type,
       "Thread.ident.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.ident.__class__.__name__.__eq__('property') == True — threading.Thread.ident is a Python property that returns the thread identifier (an integer) or None before the thread starts; type(threading.Thread.ident).__name__ is 'property'; str.__eq__('property') returns True; new to extra113"]
    - [ident_fget_qualname,
       "Thread.ident.fget.__qualname__.__eq__",
       ["Thread.ident"],
       true,
       "threading.Thread.ident.fget.__qualname__.__eq__('Thread.ident') == True — threading.Thread.ident.fget is the getter for the ident property; its __qualname__ is 'Thread.ident'; str.__eq__('Thread.ident') returns True; new to extra113"]
    - [native_id_property_type,
       "Thread.native_id.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.native_id.__class__.__name__.__eq__('property') == True — threading.Thread.native_id is a Python property (added in Python 3.8) that returns the OS-level native thread ID; type(threading.Thread.native_id).__name__ is 'property'; str.__eq__('property') returns True; new to extra113"]
    - [native_id_fget_qualname,
       "Thread.native_id.fget.__qualname__.__eq__",
       ["Thread.native_id"],
       true,
       "threading.Thread.native_id.fget.__qualname__.__eq__('Thread.native_id') == True — threading.Thread.native_id.fget is the getter for the native_id property; its __qualname__ is 'Thread.native_id'; str.__eq__('Thread.native_id') returns True; new to extra113"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread property fget qualname lengths
#
# Wave 263 theme: The fget qualname lengths vary by property name length.
# All follow the pattern 'Thread.' (7 chars) + property_name.
# 'Thread.daemon'   == 7 + 6 == 13
# 'Thread.name'     == 7 + 4 == 11
# 'Thread.ident'    == 7 + 5 == 12
# 'Thread.native_id'== 7 + 9 == 16
# All fget functions have co_argcount 1 (self only).
# fset functions have co_argcount 2 (self + value).
#
# len(threading.Thread.daemon.fget.__qualname__) == 13
# len(threading.Thread.name.fget.__qualname__) == 11
# len(threading.Thread.ident.fget.__qualname__) == 12
# len(threading.Thread.native_id.fget.__qualname__) == 16
# threading.Thread.daemon.fget.__code__.co_argcount == 1
# threading.Thread.name.fget.__code__.co_argcount == 1
#
# New to extra113.
# ---------------------------------------------------------------------------

table threading_extra113.thread_fget_qualname_lengths:
  description: "threading.Thread property fget qualname lengths: daemon(13), name(11), ident(12), native_id(16); all fget co_argcount==1 (self only); 'Thread.'(7) prefix pattern; wave 263; new to extra113"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtfql113

  columns: [id, function, args, expected, description]
  rows:
    - [daemon_fget_qualname_len_13,
       "Thread.daemon.fget.__qualname__.__len__",
       [],
       13,
       "threading.Thread.daemon.fget.__qualname__.__len__() == 13 — 'Thread.daemon' has 13 characters: T-h-r-e-a-d-.-d-a-e-m-o-n (7+6); str.__len__() returns 13; int.__eq__(13) returns True; new to extra113"]
    - [name_fget_qualname_len_11,
       "Thread.name.fget.__qualname__.__len__",
       [],
       11,
       "threading.Thread.name.fget.__qualname__.__len__() == 11 — 'Thread.name' has 11 characters: T-h-r-e-a-d-.-n-a-m-e (7+4); str.__len__() returns 11; int.__eq__(11) returns True; new to extra113"]
    - [ident_fget_qualname_len_12,
       "Thread.ident.fget.__qualname__.__len__",
       [],
       12,
       "threading.Thread.ident.fget.__qualname__.__len__() == 12 — 'Thread.ident' has 12 characters: T-h-r-e-a-d-.-i-d-e-n-t (7+5); str.__len__() returns 12; int.__eq__(12) returns True; new to extra113"]
    - [native_id_fget_qualname_len_16,
       "Thread.native_id.fget.__qualname__.__len__",
       [],
       16,
       "threading.Thread.native_id.fget.__qualname__.__len__() == 16 — 'Thread.native_id' has 16 characters: T-h-r-e-a-d-.-n-a-t-i-v-e-_-i-d (7+9); str.__len__() returns 16; int.__eq__(16) returns True; new to extra113"]
    - [daemon_fget_co_argcount_1,
       "Thread.daemon.fget.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.daemon.fget.__code__.co_argcount.__eq__(1) == True — threading.Thread.daemon.fget(self) takes only self; it is a property getter that accesses the internal _daemonic attribute; co_argcount is 1; int.__eq__(1) returns True; new to extra113"]
    - [name_fget_co_argcount_1,
       "Thread.name.fget.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.name.fget.__code__.co_argcount.__eq__(1) == True — threading.Thread.name.fget(self) takes only self; it is a property getter that accesses the internal _name attribute; co_argcount is 1; int.__eq__(1) returns True; new to extra113"]
    - [ident_fget_co_argcount_1,
       "Thread.ident.fget.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.ident.fget.__code__.co_argcount.__eq__(1) == True — threading.Thread.ident.fget(self) takes only self; it is a property getter that accesses the internal _ident attribute; co_argcount is 1; int.__eq__(1) returns True; new to extra113"]
    - [native_id_fget_co_argcount_1,
       "Thread.native_id.fget.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.native_id.fget.__code__.co_argcount.__eq__(1) == True — threading.Thread.native_id.fget(self) takes only self; it returns the OS-level native thread identifier; co_argcount is 1; int.__eq__(1) returns True; new to extra113"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread property fset qualnames and co_argcount
#
# Wave 263 theme: threading.Thread.daemon and threading.Thread.name both
# have fset (setter) functions. threading.Thread.ident and .native_id are
# read-only properties and have fset == None (no setter). The fset functions
# for daemon and name have __qualname__ following the same 'Thread.property_name'
# pattern as their fget functions. fset co_argcount is 2 (self + value).
# threading.Thread.daemon.fset.__qualname__ == 'Thread.daemon' (len 13)
# threading.Thread.name.fset.__qualname__ == 'Thread.name' (len 11)
#
# threading.Thread.daemon.fset.__qualname__ == 'Thread.daemon'
# len(threading.Thread.daemon.fset.__qualname__) == 13
# threading.Thread.daemon.fset.__code__.co_argcount == 2
# threading.Thread.name.fset.__qualname__ == 'Thread.name'
# len(threading.Thread.name.fset.__qualname__) == 11
# threading.Thread.name.fset.__code__.co_argcount == 2
#
# New to extra113.
# ---------------------------------------------------------------------------

table threading_extra113.thread_fset_qualnames:
  description: "threading.Thread property fset qualnames: daemon.fset='Thread.daemon'(13)/co_argcount 2, name.fset='Thread.name'(11)/co_argcount 2; ident/native_id read-only (no fset); wave 263; new to extra113"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtfs113

  columns: [id, function, args, expected, description]
  rows:
    - [daemon_fset_qualname,
       "Thread.daemon.fset.__qualname__.__eq__",
       ["Thread.daemon"],
       true,
       "threading.Thread.daemon.fset.__qualname__.__eq__('Thread.daemon') == True — threading.Thread.daemon.fset is the setter for the daemon property; its __qualname__ is 'Thread.daemon' (the same pattern as fget); the setter function name in the def statement uses the @daemon.setter decorator which generates a function with the same name as the property; str.__eq__('Thread.daemon') returns True; new to extra113"]
    - [daemon_fset_qualname_len_13,
       "Thread.daemon.fset.__qualname__.__len__",
       [],
       13,
       "threading.Thread.daemon.fset.__qualname__.__len__() == 13 — 'Thread.daemon' has 13 characters; the fset qualname is the same string as the fget qualname ('Thread.daemon'); str.__len__() returns 13; int.__eq__(13) returns True; new to extra113"]
    - [daemon_fset_co_argcount_2,
       "Thread.daemon.fset.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Thread.daemon.fset.__code__.co_argcount.__eq__(2) == True — threading.Thread.daemon.fset(self, daemonic) takes 2 parameters: self (the thread instance) and the new daemonic value; co_argcount is 2 (setter takes value argument unlike getter); int.__eq__(2) returns True; new to extra113"]
    - [name_fset_qualname,
       "Thread.name.fset.__qualname__.__eq__",
       ["Thread.name"],
       true,
       "threading.Thread.name.fset.__qualname__.__eq__('Thread.name') == True — threading.Thread.name.fset is the setter for the name property; its __qualname__ is 'Thread.name' (same as fget qualname); str.__eq__('Thread.name') returns True; new to extra113"]
    - [name_fset_qualname_len_11,
       "Thread.name.fset.__qualname__.__len__",
       [],
       11,
       "threading.Thread.name.fset.__qualname__.__len__() == 11 — 'Thread.name' has 11 characters; the fset qualname is the same string as the fget qualname ('Thread.name'); str.__len__() returns 11; int.__eq__(11) returns True; new to extra113"]
    - [name_fset_co_argcount_2,
       "Thread.name.fset.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Thread.name.fset.__code__.co_argcount.__eq__(2) == True — threading.Thread.name.fset(self, name) takes 2 parameters: self (the thread instance) and the new name value; co_argcount is 2; int.__eq__(2) returns True; new to extra113"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra113
# ---------------------------------------------------------------------------

invariant threading_extra113.daemon_fget_qualname:
  description: "threading.Thread.daemon.fget.__qualname__ == 'Thread.daemon' — property getter qualname pattern; len 13; wave 263; new to extra113"
  kind: python_call_eq
  function: Thread.daemon.fget.__qualname__.__eq__
  args: ["Thread.daemon"]
  expected: true

invariant threading_extra113.name_fget_qualname:
  description: "threading.Thread.name.fget.__qualname__ == 'Thread.name' — property getter qualname pattern; len 11; wave 263; new to extra113"
  kind: python_call_eq
  function: Thread.name.fget.__qualname__.__eq__
  args: ["Thread.name"]
  expected: true

invariant threading_extra113.ident_fget_qualname:
  description: "threading.Thread.ident.fget.__qualname__ == 'Thread.ident' — read-only property getter; len 12; wave 263; new to extra113"
  kind: python_call_eq
  function: Thread.ident.fget.__qualname__.__eq__
  args: ["Thread.ident"]
  expected: true

invariant threading_extra113.daemon_fset_co_argcount:
  description: "threading.Thread.daemon.fset.__code__.co_argcount == 2 — setter takes (self, value); contrasts with fget co_argcount 1; wave 263; new to extra113"
  kind: python_call_eq
  function: Thread.daemon.fset.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra113.native_id_fget_qualname_len:
  description: "len(threading.Thread.native_id.fget.__qualname__) == 16 — 'Thread.native_id' is 16 chars; longest property name among daemon/name/ident/native_id; wave 263; new to extra113"
  kind: python_call_eq
  function: Thread.native_id.fget.__qualname__.__len__
  args: []
  expected: 16

