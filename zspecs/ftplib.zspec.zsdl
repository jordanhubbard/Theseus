spec: ftplib
version: ">=3.9"
backend: python_module(ftplib)

docs: https://docs.python.org/3/library/ftplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ftplib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ftplib.py internal socket handling"
  notes:
    - "ftplib.FTP is the core FTP client class; FTP_TLS extends it with TLS support."
    - "FTP.port is a class-level attribute set to 21 (the standard FTP control port)."
    - "error_reply, error_temp, error_perm, error_proto all inherit from ftplib.Error."
    - "ftplib.Error inherits from Exception."
    - "all_errors is a tuple of exception types (Error, OSError, EOFError) used for broad exception handling."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

table ftplib.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [ftp,         FTP.__name__.__eq__,         ["FTP"],         true]
    - [ftp_tls,     FTP_TLS.__name__.__eq__,     ["FTP_TLS"],     true]
    - [error_reply, error_reply.__name__.__eq__,  ["error_reply"], true]
    - [error_temp,  error_temp.__name__.__eq__,   ["error_temp"],  true]
    - [error_perm,  error_perm.__name__.__eq__,   ["error_perm"],  true]
    - [error_proto, error_proto.__name__.__eq__,  ["error_proto"], true]
    - [all_errors,  all_errors.__name__.__eq__,   ["all_errors"],  true]

# ---------------------------------------------------------------------------
# Module check
# ---------------------------------------------------------------------------

invariant ftplib.module.FTP:
  description: "ftplib.FTP.__module__ == 'ftplib'"
  category: module
  kind: python_call_eq
  function: FTP.__module__.__eq__
  args: ["ftplib"]
  expected: true

# ---------------------------------------------------------------------------
# Class attribute: FTP.port == 21
# ---------------------------------------------------------------------------

invariant ftplib.port.ftp:
  description: "ftplib.FTP.port == 21 — standard FTP control port"
  category: constants
  kind: python_call_eq
  function: FTP.port.__eq__
  args: [21]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy
# ---------------------------------------------------------------------------

invariant ftplib.hierarchy.Error_base:
  description: "ftplib.Error.__bases__[0].__name__ == 'Exception'"
  category: exceptions
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

table ftplib.exception_bases:
  kind: python_call_eq
  category: exceptions
  id_prefix: base

  columns: [id, function, args, method, expected]
  rows:
    - [error_reply_base, error_reply.__bases__.__getitem__, [0], __name__, "Error"]
    - [error_temp_base,  error_temp.__bases__.__getitem__,  [0], __name__, "Error"]
    - [error_perm_base,  error_perm.__bases__.__getitem__,  [0], __name__, "Error"]
    - [error_proto_base, error_proto.__bases__.__getitem__,  [0], __name__, "Error"]

# ---------------------------------------------------------------------------
# FTP method name checks
# ---------------------------------------------------------------------------

table ftplib.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [login,   FTP.login.__name__.__eq__,   ["login"],   true]
    - [quit,    FTP.quit.__name__.__eq__,    ["quit"],    true]
    - [connect, FTP.connect.__name__.__eq__, ["connect"], true]
