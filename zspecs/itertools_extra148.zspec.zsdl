spec: itertools_extra148
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.__spec__ attributes — __class__.__name__ 'ModuleSpec', name 'itertools' len 9, origin 'built-in' len 8, submodule_search_locations None; itertools.__loader__.__name__ 'BuiltinImporter' len 15; itertools.__package__ == '' len 0; itertools.count.__doc__ len 205; itertools.cycle.__doc__ len 95; itertools.chain.__doc__ len 190; itertools.repeat.__doc__ len 154; itertools C-type __qualname__ matching __name__; itertools.chain.__mro__ len 2 (Wave 277)."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — itertools is a built-in C module; its ModuleSpec is still created by the import system. Verified with Python 3.14.3."
    - "itertools.__spec__.name == 'itertools' (len 9) — the ModuleSpec name is the module's qualified name. Verified with Python 3.14.3."
    - "itertools.__spec__.origin == 'built-in' (len 8) — C extension built-in modules have origin 'built-in'. Verified with Python 3.14.3."
    - "itertools.__spec__.submodule_search_locations is None — itertools is not a package. Verified with Python 3.14.3."
    - "itertools.__loader__.__name__ == 'BuiltinImporter' (len 15) — itertools is loaded by importlib._bootstrap.BuiltinImporter. Verified with Python 3.14.3."
    - "itertools.__package__ == '' (len 0) — built-in modules at top level have empty __package__. Verified with Python 3.14.3."
    - "len(itertools.count.__doc__) == 205 — verified with Python 3.14.3."
    - "len(itertools.cycle.__doc__) == 95 — verified with Python 3.14.3."
    - "len(itertools.chain.__doc__) == 190 — verified with Python 3.14.3."
    - "len(itertools.repeat.__doc__) == 154 — verified with Python 3.14.3."
    - "itertools.chain.__qualname__ == 'chain', itertools.count.__qualname__ == 'count', itertools.cycle.__qualname__ == 'cycle' — all matching their __name__. Verified with Python 3.14.3."
    - "len(itertools.chain.__mro__) == 2 — chain inherits from object only; MRO is [chain, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.__spec__ attributes
#
# Wave 277 theme: itertools.__spec__ — the ModuleSpec for the built-in module.
#
# itertools.__spec__.__class__.__name__ == 'ModuleSpec'
# itertools.__spec__.name == 'itertools' (len 9)
# itertools.__spec__.origin == 'built-in' (len 8)
# itertools.__spec__.submodule_search_locations is None
#
# Even though itertools is a C built-in, the import system creates a
# ModuleSpec for it with origin 'built-in' and no submodule search
# locations. New to extra148.
# ---------------------------------------------------------------------------

table itertools_extra148.module_spec_attrs:
  description: "itertools.__spec__: ModuleSpec, name 'itertools' len 9, origin 'built-in' len 8, submodule_search_locations is None; wave 277; new to extra148"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsspec148

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_eq_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — the import system creates a ModuleSpec for itertools even though it is a C built-in module; __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra148"]
    - [spec_name_eq_itertools,
       "__spec__.name.__eq__",
       ["itertools"],
       true,
       "itertools.__spec__.name.__eq__('itertools') == True — the ModuleSpec name attribute is the fully-qualified module name 'itertools'; str.__eq__('itertools') returns True; new to extra148"]
    - [spec_name_len_eq_9,
       "__spec__.name.__len__",
       [],
       9,
       "itertools.__spec__.name.__len__() == 9 — __spec__.name is 'itertools' which has 9 characters; len('itertools') == 9; new to extra148"]
    - [spec_origin_eq_builtin,
       "__spec__.origin.__eq__",
       ["built-in"],
       true,
       "itertools.__spec__.origin.__eq__('built-in') == True — itertools is a C extension built-in module; the ModuleSpec origin is set to 'built-in' by the BuiltinImporter; str.__eq__('built-in') returns True; new to extra148"]
    - [spec_origin_len_eq_8,
       "__spec__.origin.__len__",
       [],
       8,
       "itertools.__spec__.origin.__len__() == 8 — __spec__.origin is 'built-in' which has 8 characters; len('built-in') == 8; new to extra148"]

# ---------------------------------------------------------------------------
# Table 2: itertools.__loader__ and itertools.__package__
#
# Wave 277 theme: itertools.__loader__ and __package__ identity for a built-in.
#
# itertools.__loader__.__name__ == 'BuiltinImporter' (len 15)
# itertools.__package__ == '' (empty string, len 0)
#
# Built-in modules are loaded by importlib._bootstrap.BuiltinImporter.
# The __package__ attribute for a top-level built-in module is an empty string.
# New to extra148.
# ---------------------------------------------------------------------------

table itertools_extra148.loader_package_identity:
  description: "itertools.__loader__.__name__ 'BuiltinImporter' len 15; itertools.__package__ empty string len 0; wave 277; new to extra148"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsloader148

  columns: [id, function, args, expected, description]
  rows:
    - [loader_name_eq_builtinimporter,
       "__loader__.__name__.__eq__",
       ["BuiltinImporter"],
       true,
       "itertools.__loader__.__name__.__eq__('BuiltinImporter') == True — itertools is a C built-in module loaded by importlib._bootstrap.BuiltinImporter; its __name__ is 'BuiltinImporter'; str.__eq__('BuiltinImporter') returns True; new to extra148"]
    - [loader_name_len_eq_15,
       "__loader__.__name__.__len__",
       [],
       15,
       "itertools.__loader__.__name__.__len__() == 15 — 'BuiltinImporter' has 15 characters; len('BuiltinImporter') == 15; new to extra148"]
    - [package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "itertools.__package__.__eq__('') == True — top-level built-in modules have an empty __package__ (not the module name); str.__eq__('') returns True; new to extra148"]
    - [package_len_eq_0,
       "__package__.__len__",
       [],
       0,
       "itertools.__package__.__len__() == 0 — __package__ is an empty string for the top-level itertools built-in module; len('') == 0; new to extra148"]

# ---------------------------------------------------------------------------
# Table 3: itertools C-type __doc__ lengths
#
# Wave 277 theme: itertools C-type docstring lengths.
#
# len(itertools.count.__doc__) == 205
# len(itertools.cycle.__doc__) == 95
# len(itertools.chain.__doc__) == 190
# len(itertools.repeat.__doc__) == 154
#
# Each itertools C type has a docstring set in its PyTypeObject tp_doc field.
# New to extra148.
# ---------------------------------------------------------------------------

table itertools_extra148.c_type_doc_lengths:
  description: "itertools C-type __doc__ lengths: count 205, cycle 95, chain 190, repeat 154; verified with Python 3.14.3; wave 277; new to extra148"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsdoc148

  columns: [id, function, args, expected, description]
  rows:
    - [count_doc_len_eq_205,
       "count.__doc__.__len__",
       [],
       205,
       "itertools.count.__doc__.__len__() == 205 — the count C extension type docstring has 205 characters in Python 3.14.3; len(__doc__) == 205; new to extra148"]
    - [cycle_doc_len_eq_95,
       "cycle.__doc__.__len__",
       [],
       95,
       "itertools.cycle.__doc__.__len__() == 95 — the cycle C extension type docstring has 95 characters in Python 3.14.3; len(__doc__) == 95; new to extra148"]
    - [chain_doc_len_eq_190,
       "chain.__doc__.__len__",
       [],
       190,
       "itertools.chain.__doc__.__len__() == 190 — the chain C extension type docstring has 190 characters in Python 3.14.3; len(__doc__) == 190; new to extra148"]
    - [repeat_doc_len_eq_154,
       "repeat.__doc__.__len__",
       [],
       154,
       "itertools.repeat.__doc__.__len__() == 154 — the repeat C extension type docstring has 154 characters in Python 3.14.3; len(__doc__) == 154; new to extra148"]
    - [dropwhile_doc_len_eq_126,
       "dropwhile.__doc__.__len__",
       [],
       126,
       "itertools.dropwhile.__doc__.__len__() == 126 — the dropwhile C extension type docstring has 126 characters in Python 3.14.3; len(__doc__) == 126; new to extra148"]
    - [takewhile_doc_len_eq_101,
       "takewhile.__doc__.__len__",
       [],
       101,
       "itertools.takewhile.__doc__.__len__() == 101 — the takewhile C extension type docstring has 101 characters in Python 3.14.3; len(__doc__) == 101; new to extra148"]

# ---------------------------------------------------------------------------
# Table 4: itertools C-type __qualname__ == __name__
#
# Wave 277 theme: itertools C-type __qualname__ attributes match __name__.
#
# itertools.chain.__qualname__ == 'chain'
# itertools.count.__qualname__ == 'count'
# itertools.cycle.__qualname__ == 'cycle'
# len(itertools.chain.__mro__) == 2
# itertools.chain.__bases__[0].__name__ == 'object'
#
# C extension types defined at module scope have __qualname__ equal to their
# simple __name__. All itertools C types inherit directly from object (MRO len 2).
# New to extra148.
# ---------------------------------------------------------------------------

table itertools_extra148.c_type_qualname_mro:
  description: "itertools C-type __qualname__ == __name__ for chain/count/cycle; chain.__mro__ len 2, __bases__[0]=='object'; wave 277; new to extra148"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsqualname148

  columns: [id, function, args, expected, description]
  rows:
    - [chain_qualname_eq_chain,
       "chain.__qualname__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — chain is a C extension type defined at module scope; its __qualname__ equals its __name__ which is 'chain'; str.__eq__('chain') returns True; new to extra148"]
    - [count_qualname_eq_count,
       "count.__qualname__.__eq__",
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a C extension type defined at module scope; its __qualname__ is 'count', equal to its __name__; str.__eq__('count') returns True; new to extra148"]
    - [cycle_qualname_eq_cycle,
       "cycle.__qualname__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__qualname__.__eq__('cycle') == True — cycle is a C extension type defined at module scope; its __qualname__ is 'cycle', equal to its __name__; str.__eq__('cycle') returns True; new to extra148"]
    - [chain_mro_len_eq_2,
       "chain.__mro__.__len__",
       [],
       2,
       "itertools.chain.__mro__.__len__() == 2 — chain inherits directly from object with no intermediate base; MRO is [chain, object]; len(__mro__) == 2; new to extra148"]
    - [chain_bases_first_eq_object,
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__.__eq__('object') == True — chain is a C extension type whose sole base class is object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra148"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra148
# ---------------------------------------------------------------------------

invariant itertools_extra148.spec_name_eq_itertools:
  description: "itertools.__spec__.name == 'itertools' — ModuleSpec name is the module's qualified name; wave 277; new to extra148"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra148.spec_origin_builtin:
  description: "itertools.__spec__.origin == 'built-in' — C built-in module has origin 'built-in'; wave 277; new to extra148"
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["built-in"]
  expected: true

invariant itertools_extra148.spec_origin_len:
  description: "len(itertools.__spec__.origin) == 8 — 'built-in' has 8 characters; wave 277; new to extra148"
  kind: python_call_eq
  function: __spec__.origin.__len__
  args: []
  expected: 8

invariant itertools_extra148.loader_name_eq_builtinimporter:
  description: "itertools.__loader__.__name__ == 'BuiltinImporter' — itertools loaded by BuiltinImporter; wave 277; new to extra148"
  kind: python_call_eq
  function: __loader__.__name__.__eq__
  args: ["BuiltinImporter"]
  expected: true

invariant itertools_extra148.package_is_empty:
  description: "itertools.__package__ == '' — top-level built-in module has empty __package__; wave 277; new to extra148"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra148.count_doc_len:
  description: "len(itertools.count.__doc__) == 205 — count docstring has 205 characters; wave 277; new to extra148"
  kind: python_call_eq
  function: count.__doc__.__len__
  args: []
  expected: 205

invariant itertools_extra148.cycle_doc_len:
  description: "len(itertools.cycle.__doc__) == 95 — cycle docstring has 95 characters; wave 277; new to extra148"
  kind: python_call_eq
  function: cycle.__doc__.__len__
  args: []
  expected: 95

invariant itertools_extra148.chain_mro_len:
  description: "len(itertools.chain.__mro__) == 2 — chain inherits from object only; MRO is [chain, object]; wave 277; new to extra148"
  kind: python_call_eq
  function: chain.__mro__.__len__
  args: []
  expected: 2

invariant itertools_extra148.chain_bases_object:
  description: "itertools.chain.__bases__[0].__name__ == 'object' — chain's sole base is object; wave 277; new to extra148"
  kind: python_call_eq
  function: "chain.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra148.spec_name_len:
  description: "len(itertools.__spec__.name) == 9 — 'itertools' has 9 characters; wave 277; new to extra148"
  kind: python_call_eq
  function: __spec__.name.__len__
  args: []
  expected: 9
