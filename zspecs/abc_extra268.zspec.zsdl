spec: abc_extra268
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc documentation"
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "abc.ABC.__name__ == 'ABC'; abc.ABC.__module__ == 'abc'; abc.ABC.__bases__[0].__name__ == 'object'."
    - "abc.ABCMeta.__name__ == 'ABCMeta'; abc.ABCMeta.__module__ == 'abc'; abc.ABCMeta.__bases__[0].__name__ == 'type'."
    - "abc.abstractmethod.__name__ == 'abstractmethod'; abc.abstractmethod.__module__ == 'abc'."
    - "collections.abc.Sequence.__module__ == 'collections.abc'; __bases__[0].__name__ == 'Reversible'."
    - "collections.abc.Sequence.__abstractmethods__ == frozenset({'__getitem__', '__len__'})."
    - "collections.abc.Iterable.__abstractmethods__ == frozenset({'__iter__'})."
    - "collections.abc.Mapping.__abstractmethods__ == frozenset({'__getitem__', '__iter__', '__len__'})."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC and abc.ABCMeta class identity — table
# ---------------------------------------------------------------------------

table abc_extra268.abc_class_identity:
  description: "abc.ABC and abc.ABCMeta class identity values"
  kind: python_call_eq
  category: identity
  id_prefix: abcid

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name,        ABC.__name__.__eq__,                    ["ABC"],        true, "abc.ABC.__name__ == 'ABC'"]
    - [abc_module,      ABC.__module__.__eq__,                  ["abc"],        true, "abc.ABC.__module__ == 'abc'"]
    - [abc_base,        "ABC.__bases__[0].__name__.__eq__",     ["object"],     true, "abc.ABC.__bases__[0].__name__ == 'object'"]
    - [meta_name,       ABCMeta.__name__.__eq__,                ["ABCMeta"],    true, "abc.ABCMeta.__name__ == 'ABCMeta'"]
    - [meta_module,     ABCMeta.__module__.__eq__,              ["abc"],        true, "abc.ABCMeta.__module__ == 'abc'"]
    - [meta_base,       "ABCMeta.__bases__[0].__name__.__eq__", ["type"],       true, "abc.ABCMeta.__bases__[0].__name__ == 'type'"]
    - [am_name,         abstractmethod.__name__.__eq__,         ["abstractmethod"], true, "abc.abstractmethod.__name__ == 'abstractmethod'"]
    - [am_module,       abstractmethod.__module__.__eq__,       ["abc"],        true, "abc.abstractmethod.__module__ == 'abc'"]

# ---------------------------------------------------------------------------
# collections.abc abstract base class identity — table
# ---------------------------------------------------------------------------

table abc_extra268.collections_abc_identity:
  description: "collections.abc.Sequence, Mapping, and Iterable class identity values"
  kind: python_call_eq
  category: identity
  id_prefix: cabcid

  columns: [id, function, args, expected, description]
  rows:
    - [seq_name,    collections.abc.Sequence.__name__.__eq__,              ["Sequence"],        true, "collections.abc.Sequence.__name__ == 'Sequence'"]
    - [seq_module,  collections.abc.Sequence.__module__.__eq__,            ["collections.abc"], true, "collections.abc.Sequence.__module__ == 'collections.abc'"]
    - [seq_base,    "collections.abc.Sequence.__bases__[0].__name__.__eq__", ["Reversible"],    true, "collections.abc.Sequence.__bases__[0].__name__ == 'Reversible'"]
    - [map_name,    collections.abc.Mapping.__name__.__eq__,               ["Mapping"],         true, "collections.abc.Mapping.__name__ == 'Mapping'"]
    - [map_module,  collections.abc.Mapping.__module__.__eq__,             ["collections.abc"], true, "collections.abc.Mapping.__module__ == 'collections.abc'"]
    - [map_base,    "collections.abc.Mapping.__bases__[0].__name__.__eq__", ["Collection"],     true, "collections.abc.Mapping.__bases__[0].__name__ == 'Collection'"]
    - [iter_name,   collections.abc.Iterable.__name__.__eq__,              ["Iterable"],        true, "collections.abc.Iterable.__name__ == 'Iterable'"]
    - [iter_module, collections.abc.Iterable.__module__.__eq__,            ["collections.abc"], true, "collections.abc.Iterable.__module__ == 'collections.abc'"]

# ---------------------------------------------------------------------------
# abc.abstractmethod __qualname__ — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra268.abstractmethod.qualname:
  description: "abc.abstractmethod.__qualname__ == 'abstractmethod'"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__qualname__.__eq__
  args: ["abstractmethod"]
  expected: true

# ---------------------------------------------------------------------------
# collections.abc.Sequence abstract methods membership — standalone invariants
# ---------------------------------------------------------------------------

invariant abc_extra268.Sequence.abstractmethods_getitem:
  description: "collections.abc.Sequence.__abstractmethods__ contains '__getitem__'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Sequence.__abstractmethods__.__contains__"
  args: ["__getitem__"]
  expected: true

invariant abc_extra268.Sequence.abstractmethods_len:
  description: "collections.abc.Sequence.__abstractmethods__ contains '__len__'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Sequence.__abstractmethods__.__contains__"
  args: ["__len__"]
  expected: true

# ---------------------------------------------------------------------------
# collections.abc.Iterable abstract method membership — standalone invariant
# ---------------------------------------------------------------------------

invariant abc_extra268.Iterable.abstractmethods_iter:
  description: "collections.abc.Iterable.__abstractmethods__ contains '__iter__'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Iterable.__abstractmethods__.__contains__"
  args: ["__iter__"]
  expected: true

# ---------------------------------------------------------------------------
# collections.abc.Mapping abstract methods membership — standalone invariants
# ---------------------------------------------------------------------------

invariant abc_extra268.Mapping.abstractmethods_getitem:
  description: "collections.abc.Mapping.__abstractmethods__ contains '__getitem__'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Mapping.__abstractmethods__.__contains__"
  args: ["__getitem__"]
  expected: true

invariant abc_extra268.Mapping.abstractmethods_iter:
  description: "collections.abc.Mapping.__abstractmethods__ contains '__iter__'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Mapping.__abstractmethods__.__contains__"
  args: ["__iter__"]
  expected: true

invariant abc_extra268.Mapping.abstractmethods_len:
  description: "collections.abc.Mapping.__abstractmethods__ contains '__len__'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Mapping.__abstractmethods__.__contains__"
  args: ["__len__"]
  expected: true
