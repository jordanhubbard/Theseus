spec: functools_extra208
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers deeper __spec__ attributes of functools: name, origin.__class__.__name__, has_location, parent, __class__.__name__, submodule_search_locations.__class__.__name__."
    - "functools.__spec__.name == 'functools' — ModuleSpec.name equals the module name. Verified with Python 3.14.3."
    - "functools.__spec__.origin.__class__.__name__ == 'str' — origin is a str holding the .py file path. Verified with Python 3.14.3."
    - "functools.__spec__.has_location == True — functools is a pure-Python source file; has_location is True. Verified with Python 3.14.3."
    - "functools.__spec__.parent == '' — top-level module; spec.parent is an empty string. Verified with Python 3.14.3."
    - "functools.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an instance of ModuleSpec. Verified with Python 3.14.3."
    - "functools.__spec__.submodule_search_locations.__class__.__name__ == 'NoneType' — functools has no submodules; submodule_search_locations is None. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.__spec__ name, class, and parent identity
#
# functools.__spec__.name == 'functools'
# functools.__spec__.__class__.__name__ == 'ModuleSpec'
# functools.__spec__.parent == ''
# functools.__spec__.__class__.__module__ == '_frozen_importlib'
# ---------------------------------------------------------------------------

table functools_extra208.spec_name_class_parent:
  description: "functools.__spec__ name, __class__.__name__, parent, and __class__.__module__ identity; new to extra208"
  kind: python_call_eq
  category: module_spec
  id_prefix: functspec208

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       __spec__.name.__eq__,
       ["functools"],
       true,
       "functools.__spec__.name.__eq__('functools') == True — ModuleSpec.name attribute equals 'functools'; new to extra208"]
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is a ModuleSpec instance; new to extra208"]
    - [spec_parent_eq,
       __spec__.parent.__eq__,
       [""],
       true,
       "functools.__spec__.parent.__eq__('') == True — top-level module; spec.parent is empty string; new to extra208"]
    - [spec_class_module_eq,
       "__spec__.__class__.__module__.__eq__",
       ["_frozen_importlib"],
       true,
       "functools.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True — ModuleSpec is defined in _frozen_importlib; new to extra208"]

# ---------------------------------------------------------------------------
# Table 2: functools.__spec__ has_location and origin class
#
# functools.__spec__.has_location == True
# functools.__spec__.origin.__class__.__name__ == 'str'
# functools.__spec__.origin.endswith('functools.py') == True
# functools.__spec__.name.__len__() == 9
# ---------------------------------------------------------------------------

table functools_extra208.spec_location_origin:
  description: "functools.__spec__ has_location, origin type, origin suffix, and name length; new to extra208"
  kind: python_call_eq
  category: module_spec
  id_prefix: functspec208

  columns: [id, function, args, expected, description]
  rows:
    - [spec_has_location_true,
       __spec__.has_location.__eq__,
       [true],
       true,
       "functools.__spec__.has_location.__eq__(True) == True — functools is a source file module; has_location is True; new to extra208"]
    - [spec_origin_class_str,
       __spec__.origin.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.__spec__.origin.__class__.__name__.__eq__('str') == True — spec.origin is a str (file path); new to extra208"]
    - [spec_origin_endswith_py,
       __spec__.origin.endswith,
       ["functools.py"],
       true,
       "functools.__spec__.origin.endswith('functools.py') == True — origin path ends with functools.py; new to extra208"]
    - [spec_name_len,
       __spec__.name.__len__,
       [],
       9,
       "functools.__spec__.name.__len__() == 9 — len('functools') is 9; new to extra208"]

# ---------------------------------------------------------------------------
# Table 3: functools.__spec__ submodule_search_locations and cached
#
# functools.__spec__.submodule_search_locations.__class__.__name__ == 'NoneType'
# functools.__spec__.cached.endswith('.pyc') == True
# functools.__spec__.loader.__class__.__name__ == 'SourceFileLoader'
# functools.__spec__.loader.__class__.__module__ == '_frozen_importlib_external'
# ---------------------------------------------------------------------------

table functools_extra208.spec_submodule_cached_loader:
  description: "functools.__spec__ submodule_search_locations, cached suffix, loader class name and module; new to extra208"
  kind: python_call_eq
  category: module_spec
  id_prefix: functspec208

  columns: [id, function, args, expected, description]
  rows:
    - [spec_submodule_locs_class,
       "__spec__.submodule_search_locations.__class__.__name__.__eq__",
       ["NoneType"],
       true,
       "functools.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — functools has no submodules; submodule_search_locations is None; new to extra208"]
    - [spec_cached_endswith_pyc,
       __spec__.cached.endswith,
       [".pyc"],
       true,
       "functools.__spec__.cached.endswith('.pyc') == True — cached path ends with .pyc (compiled bytecode); new to extra208"]
    - [spec_loader_class_name,
       __spec__.loader.__class__.__name__.__eq__,
       ["SourceFileLoader"],
       true,
       "functools.__spec__.loader.__class__.__name__.__eq__('SourceFileLoader') == True — functools uses SourceFileLoader; new to extra208"]
    - [spec_loader_class_module,
       __spec__.loader.__class__.__module__.__eq__,
       ["_frozen_importlib_external"],
       true,
       "functools.__spec__.loader.__class__.__module__.__eq__('_frozen_importlib_external') == True — SourceFileLoader is from _frozen_importlib_external; new to extra208"]

