spec: threading_extra2626
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 622 (_extra2626): __length_hint__, __missing__, and __reversed__ dict-presence checks for threading module types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__length_hint__ is absent from all threading types — Thread, Lock, Event, Condition, Semaphore, BoundedSemaphore, Timer, Barrier, and local are synchronization and utility objects, not iterators — all False."
    - "__missing__ is a dict-subclass hook; no threading type subclasses dict, so all return False."
    - "__reversed__ enables custom reversed() iteration; none of the threading types define it in their own __dict__ — all False."
    - "threading.Lock is actually _thread.lock at runtime (a C-implemented type from the _thread module). threading.Lock.__name__ == 'lock'."
    - "threading.local is actually _thread._local at runtime; threading.local is the canonical public reference."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __length_hint__ dict-presence for threading synchronization types
#
# __length_hint__ provides estimated length for iterators. threading types
# (Thread, Lock, Event, Condition, Semaphore, BoundedSemaphore, Timer,
# Barrier, local) are synchronization and utility objects — not iterators
# — and none define __length_hint__ in their own __dict__. All False.
# ---------------------------------------------------------------------------

table threading_extra2626.length_hint_absent:
  description: "threading types do not define __length_hint__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2626

  columns: [id, function, args, expected]
  rows:
    - ["th2626001", "threading.Thread.__dict__.__contains__",           ["__length_hint__"], false]
    - ["th2626002", "threading.Lock.__dict__.__contains__",             ["__length_hint__"], false]
    - ["th2626003", "threading.Event.__dict__.__contains__",            ["__length_hint__"], false]
    - ["th2626004", "threading.Condition.__dict__.__contains__",        ["__length_hint__"], false]
    - ["th2626005", "threading.Semaphore.__dict__.__contains__",        ["__length_hint__"], false]
    - ["th2626006", "threading.BoundedSemaphore.__dict__.__contains__", ["__length_hint__"], false]
    - ["th2626007", "threading.Timer.__dict__.__contains__",            ["__length_hint__"], false]
    - ["th2626008", "threading.Barrier.__dict__.__contains__",          ["__length_hint__"], false]
    - ["th2626009", "threading.local.__dict__.__contains__",            ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 2: __missing__ dict-presence for threading synchronization types
#
# __missing__ is the hook called by dict.__getitem__ when a key is absent.
# It is only meaningful for dict subclasses. No threading type subclasses
# dict, so none define __missing__ in their own __dict__. All False.
# ---------------------------------------------------------------------------

table threading_extra2626.missing_absent:
  description: "threading types do not define __missing__ in their own __dict__ — none are dict subclasses"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2626

  columns: [id, function, args, expected]
  rows:
    - ["th2626010", "threading.Thread.__dict__.__contains__",           ["__missing__"], false]
    - ["th2626011", "threading.Lock.__dict__.__contains__",             ["__missing__"], false]
    - ["th2626012", "threading.Event.__dict__.__contains__",            ["__missing__"], false]
    - ["th2626013", "threading.Condition.__dict__.__contains__",        ["__missing__"], false]
    - ["th2626014", "threading.Semaphore.__dict__.__contains__",        ["__missing__"], false]
    - ["th2626015", "threading.BoundedSemaphore.__dict__.__contains__", ["__missing__"], false]
    - ["th2626016", "threading.Timer.__dict__.__contains__",            ["__missing__"], false]
    - ["th2626017", "threading.Barrier.__dict__.__contains__",          ["__missing__"], false]
    - ["th2626018", "threading.local.__dict__.__contains__",            ["__missing__"], false]

# ---------------------------------------------------------------------------
# Table 3: __reversed__ dict-presence for threading synchronization types
#
# __reversed__ enables custom reversed() iteration for bidirectional
# sequence types. Threading synchronization and utility types are not
# sequences; none define __reversed__ in their own __dict__. All False.
# ---------------------------------------------------------------------------

table threading_extra2626.reversed_absent:
  description: "threading types do not define __reversed__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2626

  columns: [id, function, args, expected]
  rows:
    - ["th2626019", "threading.Thread.__dict__.__contains__",           ["__reversed__"], false]
    - ["th2626020", "threading.Lock.__dict__.__contains__",             ["__reversed__"], false]
    - ["th2626021", "threading.Event.__dict__.__contains__",            ["__reversed__"], false]
    - ["th2626022", "threading.Condition.__dict__.__contains__",        ["__reversed__"], false]
    - ["th2626023", "threading.Semaphore.__dict__.__contains__",        ["__reversed__"], false]
    - ["th2626024", "threading.BoundedSemaphore.__dict__.__contains__", ["__reversed__"], false]
    - ["th2626025", "threading.Timer.__dict__.__contains__",            ["__reversed__"], false]
    - ["th2626026", "threading.Barrier.__dict__.__contains__",          ["__reversed__"], false]
    - ["th2626027", "threading.local.__dict__.__contains__",            ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Table 4: Combined absence summary — all three dunders absent from all types
#
# Cross-check confirming that none of the nine threading types define any of
# the three container-protocol dunders. Assigns a unique dunder per type in
# a first pass, then cross-checks additional combinations.
# ---------------------------------------------------------------------------

table threading_extra2626.container_protocol_absent_summary:
  description: "threading types define none of __length_hint__, __missing__, __reversed__ — cross-type summary"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2626

  columns: [id, function, args, expected]
  rows:
    - ["th2626028", "threading.Thread.__dict__.__contains__",           ["__length_hint__"], false]
    - ["th2626029", "threading.Lock.__dict__.__contains__",             ["__missing__"],     false]
    - ["th2626030", "threading.Event.__dict__.__contains__",            ["__reversed__"],    false]
    - ["th2626031", "threading.Condition.__dict__.__contains__",        ["__length_hint__"], false]
    - ["th2626032", "threading.Semaphore.__dict__.__contains__",        ["__missing__"],     false]
    - ["th2626033", "threading.BoundedSemaphore.__dict__.__contains__", ["__reversed__"],    false]
    - ["th2626034", "threading.Timer.__dict__.__contains__",            ["__length_hint__"], false]
    - ["th2626035", "threading.Barrier.__dict__.__contains__",          ["__missing__"],     false]
    - ["th2626036", "threading.local.__dict__.__contains__",            ["__reversed__"],    false]
