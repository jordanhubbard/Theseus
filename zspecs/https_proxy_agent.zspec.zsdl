spec: https_proxy_agent
version: ">=7.0.0"
backend: node(https-proxy-agent)

docs: https://github.com/TooTallNate/proxy-agents/tree/main/packages/https-proxy-agent#readme

provenance:
  derived_from:
    - "https-proxy-agent README — https://github.com/TooTallNate/proxy-agents/tree/main/packages/https-proxy-agent#readme"
    - "Test vectors verified with https-proxy-agent via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "https-proxy-agent source"
  notes:
    - "https.Agent that tunnels HTTPS requests through an HTTP proxy via CONNECT."
    - "Install: npm install https-proxy-agent"
    - "v7 CJS; named export HttpsProxyAgent (extends agent-base.Agent)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "CONNECT failures (407, 502) propagate via the http request object."
  stderr: "null"
  stickiness: "Each agent instance owns its own connection-pool state."
  codes: {}

invariant https_proxy_agent.has_HttpsProxyAgent:
  description: "HttpsProxyAgent class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "HttpsProxyAgent.constructor.name"}
  expected: "Function"

invariant https_proxy_agent.HttpsProxyAgent_name:
  description: "HttpsProxyAgent.name is 'HttpsProxyAgent'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "HttpsProxyAgent.name"}
  expected: "HttpsProxyAgent"

invariant https_proxy_agent.proto_has_connect:
  description: "HttpsProxyAgent.prototype.connect defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "HttpsProxyAgent.prototype.connect.constructor.name"}
  expected: "AsyncFunction"
