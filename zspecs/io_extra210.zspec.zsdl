# __class__.__name__ == 'list', __len__() == 24
# ---------------------------------------------------------------------------

table io_extra210.all_class_and_len:
  description: "io.__all__ type identity and length"
  kind: python_call_eq
  category: all_identity
  id_prefix: ioall210

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,  io.__all__.__class__.__name__.__eq__,  ["list"], true,  "io.__all__.__class__.__name__ == 'list'; io.__all__ is a plain list; confirmed Python 3.14.3 macOS"]
    - [class_name_len, io.__all__.__class__.__name__.__len__,  [],       4,     "io.__all__.__class__.__name__.__len__() == 4; 'list' has l(1)i(2)s(3)t(4); confirmed Python 3.14.3 macOS"]
    - [len_eq,         io.__all__.__len__,                    [],       24,    "io.__all__.__len__() == 24; io exports 24 public names; confirmed Python 3.14.3 macOS"]
    - [len_gt_zero,    io.__all__.__len__,                    [],       24,    "io.__all__.__len__() == 24; exports are non-empty; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.__all__ membership — core ABC names
# IOBase, RawIOBase, BufferedIOBase, TextIOBase
# ---------------------------------------------------------------------------

table io_extra210.all_membership_abc:
  description: "io.__all__ membership checks for core ABC class names"
  kind: python_call_eq
  category: all_membership
  id_prefix: ioall210

  columns: [id, function, args, expected, description]
  rows:
    - [IOBase_in,         io.__all__.__contains__,  ["IOBase"],         true,  "io.__all__.__contains__('IOBase') == True; IOBase is the root ABC for all I/O classes; confirmed Python 3.14.3 macOS"]
    - [RawIOBase_in,      io.__all__.__contains__,  ["RawIOBase"],      true,  "io.__all__.__contains__('RawIOBase') == True; RawIOBase is the ABC for raw binary I/O; confirmed Python 3.14.3 macOS"]
    - [BufferedIOBase_in, io.__all__.__contains__,  ["BufferedIOBase"], true,  "io.__all__.__contains__('BufferedIOBase') == True; BufferedIOBase is the ABC for buffered I/O; confirmed Python 3.14.3 macOS"]
    - [TextIOBase_in,     io.__all__.__contains__,  ["TextIOBase"],     true,  "io.__all__.__contains__('TextIOBase') == True; TextIOBase is the ABC for text I/O; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.__all__ membership — concrete class names
# FileIO, BytesIO, StringIO, TextIOWrapper
# ---------------------------------------------------------------------------

table io_extra210.all_membership_concrete:
  description: "io.__all__ membership checks for concrete class names"
  kind: python_call_eq
  category: all_membership
  id_prefix: ioall210

  columns: [id, function, args, expected, description]
  rows:
    - [FileIO_in,        io.__all__.__contains__,  ["FileIO"],        true,  "io.__all__.__contains__('FileIO') == True; FileIO is the concrete raw file I/O class; confirmed Python 3.14.3 macOS"]
    - [BytesIO_in,       io.__all__.__contains__,  ["BytesIO"],       true,  "io.__all__.__contains__('BytesIO') == True; BytesIO is an in-memory bytes stream; confirmed Python 3.14.3 macOS"]
    - [StringIO_in,      io.__all__.__contains__,  ["StringIO"],      true,  "io.__all__.__contains__('StringIO') == True; StringIO is an in-memory text stream; confirmed Python 3.14.3 macOS"]
    - [TextIOWrapper_in, io.__all__.__contains__,  ["TextIOWrapper"], true,  "io.__all__.__contains__('TextIOWrapper') == True; TextIOWrapper wraps a buffered stream and decodes bytes to text; confirmed Python 3.14.3 macOS"]

