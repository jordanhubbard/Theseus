spec: io_extra210
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
    - "io_extra.zspec.zsdl — covers DEFAULT_BUFFER_SIZE, SEEK_* constants, TextIOWrapper, BufferedRandom, UnsupportedOperation class metadata"
  notes:
    - "io has __all__; io.__all__.__class__.__name__ == 'list'; confirmed Python 3.14.3 macOS."
    - "io.__all__.__len__() == 24; confirmed Python 3.14.3 macOS."
    - "All eight target names are present in io.__all__: IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO, BytesIO, StringIO, TextIOWrapper."
    - "io.__all__.__contains__(name) returns True for all eight names; confirmed Python 3.14.3 macOS."
    - "io.__all__ also contains: BlockingIOError, open, open_code, BufferedReader, BufferedWriter, BufferedRWPair, BufferedRandom, UnsupportedOperation, SEEK_SET, SEEK_CUR, SEEK_END, DEFAULT_BUFFER_SIZE, text_encoding, IncrementalNewlineDecoder, Reader, Writer."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

