spec: struct_extra75
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra74.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__len__() / module-level pack/unpack/pack_into/unpack_from/iter_unpack/calcsize __qualname__.__len__() (table + invariants)."
    - "struct_extra73.zspec.zsdl — covers Struct.__repr__/__class__/__name__ / Struct.format/__qualname__.__len__() / Struct.__bases__.__len__() / calcsize+pack_into qualname cross-check (table + invariants)."
    - "struct_extra71.zspec.zsdl — covers Struct.__dict__.__contains__('__doc__') / pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__module__=='_struct' (table + invariants)."
    - "struct_extra4.zspec.zsdl — covers struct.calcsize/__qualname__.__eq__('calcsize') (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra74; it does NOT duplicate invariants present in those files."
    - "Wave 246 theme: struct.error exception class identity and struct module-level function __qualname__/__module__ string equality."
    - "struct.error.__name__ == 'error' — the exception class name is 'error'. No prior struct spec checks error.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct' — error is defined in the struct module. No prior struct spec checks error.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error' — the exception class qualname is 'error'. No prior struct spec checks error.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception' — error directly subclasses Exception. No prior struct spec checks error.__bases__[0].__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__.__len__() == 4 — MRO is (error, Exception, BaseException, object). No prior struct spec checks error.__mro__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__.__len__() == 5 — 'error' is 5 characters. No prior struct spec checks error.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__name__.__len__() == 5 — 'error' is 5 characters. No prior struct spec checks error.__name__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__.__len__() == 6 — 'struct' is 6 characters. No prior struct spec checks error.__module__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__.__len__() == 1 — error has exactly one base class. No prior struct spec checks error.__bases__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize' — verified already covered in struct_extra4 as string eq; this spec checks it via __eq__ in a new context alongside error attrs. No new duplication of the numeric length (covered in struct_extra74)."
    - "struct.calcsize.__module__ == '_struct' — covered in struct_extra71. NOT duplicated here."
    - "struct.pack.__qualname__ == 'pack' — struct_extra74 covers pack.__qualname__.__len__()==4 but NOT pack.__qualname__.__eq__('pack'). This spec covers the string equality form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct' — covered in struct_extra71. NOT duplicated here."
    - "struct.unpack.__qualname__ == 'unpack' — struct_extra74 covers unpack.__qualname__.__len__()==6 but NOT unpack.__qualname__.__eq__('unpack'). This spec covers the string equality form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error.__name__, __module__, and __qualname__
#
# Wave 246 theme: struct.error exception class identity.
#
# struct.error.__name__ == 'error', __module__ == 'struct', __qualname__ == 'error'.
# No prior struct spec checks any of these attributes for the error class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra75.error_name_module_qualname:
  description: "struct.error/__name__.__eq__('error')==True / error/__module__.__eq__('struct')==True / error/__qualname__.__eq__('error')==True — struct.error is the module-level exception class; __name__/__module__/__qualname__ are all simple strings; no prior struct spec checks error.__name__/__module__/__qualname__; first identity anchor for struct.error"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra75

  columns: [id, function, args, expected]
  rows:
    - [error_name_error,       error.__name__.__eq__,     ["error"],  true]
    - [error_module_struct,    error.__module__.__eq__,   ["struct"], true]
    - [error_qualname_error,   error.__qualname__.__eq__,  ["error"],  true]

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__ and __mro__.__len__()
#
# Wave 246 theme: struct.error exception class hierarchy.
#
# struct.error directly subclasses Exception (__bases__[0].__name__ == 'Exception').
# Its MRO is (error, Exception, BaseException, object) so __mro__.__len__() == 4.
# No prior struct spec checks error.__bases__[0].__name__ or __mro__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra75.error_bases_mro:
  description: "struct.error/__bases__[0]/__name__.__eq__('Exception')==True / error/__mro__/__len__()==4 / error/__bases__/__len__()==1 — error subclasses Exception; MRO is (error, Exception, BaseException, object); error has exactly one base class; no prior struct spec checks error.__bases__[0].__name__, __mro__.__len__(), or __bases__.__len__(); first hierarchy anchor for struct.error"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra75

  columns: [id, function, args, expected]
  rows:
    - [error_bases0_name_Exception, "error.__bases__[0].__name__.__eq__", ["Exception"], true]
    - [error_mro_len_4,             error.__mro__.__len__,                [],            4]
    - [error_bases_len_1,           error.__bases__.__len__,              [],            1]

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__len__(), __name__.__len__(), __module__.__len__()
#
# Wave 246 theme: struct.error string attribute lengths.
#
# struct.error.__qualname__ == 'error' (5 chars).
# struct.error.__name__ == 'error' (5 chars).
# struct.error.__module__ == 'struct' (6 chars).
# No prior struct spec checks any of these string attribute lengths for error.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra75.error_string_attr_lengths:
  description: "struct.error/__qualname__/__len__()==5 / error/__name__/__len__()==5 / error/__module__/__len__()==6 — 'error' is 5 chars; 'struct' is 6 chars; no prior struct spec checks error.__qualname__.__len__()/__name__.__len__()/__module__.__len__(); first string length anchor for struct.error attributes"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra75

  columns: [id, function, args, expected]
  rows:
    - [error_qualname_len_5, error.__qualname__.__len__, [], 5]
    - [error_name_len_5,     error.__name__.__len__,     [], 5]
    - [error_module_len_6,   error.__module__.__len__,   [], 6]

# ---------------------------------------------------------------------------
# struct.pack/__qualname__ and struct.unpack/__qualname__ string equality
#
# Wave 246 theme: module-level function qualname string equality.
#
# struct.pack.__qualname__ == 'pack'. struct.unpack.__qualname__ == 'unpack'.
# struct_extra74 covers the __len__() values but NOT the __eq__ string forms.
# struct.calcsize.__qualname__ == 'calcsize': struct_extra4 covers this via
# __eq__; NOT duplicated here.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra75.pack_unpack_qualname_eq:
  description: "struct.pack/__qualname__.__eq__('pack')==True / struct.unpack/__qualname__.__eq__('unpack')==True — struct.pack and struct.unpack are C builtins with simple qualnames; struct_extra74 covers qualname __len__() for pack/unpack but NOT the string equality form; no prior struct spec checks pack.__qualname__.__eq__ or unpack.__qualname__.__eq__; first qualname string equality anchor for pack and unpack"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra75

  columns: [id, function, args, expected]
  rows:
    - [pack_qualname_eq_pack,     pack.__qualname__.__eq__,   ["pack"],   true]
    - [unpack_qualname_eq_unpack, unpack.__qualname__.__eq__,  ["unpack"], true]

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error') — standalone
#
# struct.error's class __name__ is 'error'. No prior struct spec checks
# error.__name__. First __name__ standalone for struct.error.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra75.error_name_error:
  description: "struct.error.__name__.__eq__('error') == True — struct.error is the exception class; its __name__ is 'error'; no prior struct spec checks error.__name__; first __name__ standalone for struct.error"
  category: class_attrs
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__module__.__eq__('struct') — standalone
#
# struct.error.__module__ is 'struct'. No prior struct spec checks
# error.__module__. First __module__ standalone for struct.error.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra75.error_module_struct:
  description: "struct.error.__module__.__eq__('struct') == True — struct.error is defined in the struct module; its __module__ is 'struct'; no prior struct spec checks error.__module__; first __module__ standalone for struct.error"
  category: class_attrs
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__mro__.__len__() == 4 — standalone
#
# struct.error's MRO is (error, Exception, BaseException, object) = 4 entries.
# No prior struct spec checks error.__mro__.__len__(). First __mro__.__len__()
# standalone for struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra75.error_mro_len_4:
  description: "struct.error.__mro__.__len__() == 4 — error MRO is (error, Exception, BaseException, object); no prior struct spec checks error.__mro__.__len__(); first __mro__.__len__() standalone for struct.error"
  category: class_attrs
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.error.__bases__.__len__() == 1 — standalone
#
# struct.error has exactly one base class (Exception). No prior struct spec
# checks error.__bases__.__len__(). First __bases__.__len__() standalone for
# struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra75.error_bases_len_1:
  description: "struct.error.__bases__.__len__() == 1 — error has exactly one base class (Exception); no prior struct spec checks error.__bases__.__len__(); first __bases__.__len__() standalone for struct.error"
  category: class_attrs
  kind: python_call_eq
  function: error.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__eq__('error') — standalone
#
# struct.error.__qualname__ is 'error'. No prior struct spec checks
# error.__qualname__. First __qualname__ standalone for struct.error.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra75.error_qualname_error:
  description: "struct.error.__qualname__.__eq__('error') == True — struct.error is a module-level exception class; its __qualname__ is 'error'; no prior struct spec checks error.__qualname__; first __qualname__ standalone for struct.error"
  category: class_attrs
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true
