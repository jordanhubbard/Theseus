spec: sqlite3_extra22
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra21.zspec.zsdl."
    - "sqlite3_extra14 covers: Connection/__qualname__; Cursor/__qualname__; Row/__qualname__; connect/__qualname__."
    - "sqlite3_extra19 covers: Connection.execute/executemany/executescript/cursor/commit/rollback/close __qualname__; Cursor.execute/fetchone/fetchall __qualname__."
    - "sqlite3_extra20 covers: Connection.create_function/__qualname__; Connection.create_aggregate/__qualname__; DatabaseError/__qualname__; Cursor.rowcount descriptor type."
    - "sqlite3_extra21 covers: Connection/__module__; Cursor/__module__; Row/__module__; Error/__bases__[0].__name__; OperationalError/__bases__[0].__name__; PARSE_DECLTYPES/__class__.__name__; PARSE_COLNAMES/__class__.__name__; connect/__module__; Warning/InterfaceError/NotSupportedError qualnames and bases."
    - "No prior spec covers Connection.__bases__[0].__name__ as a standalone invariant."
    - "No prior spec covers Cursor.__bases__[0].__name__ as a standalone invariant."
    - "No prior spec covers Row.__bases__[0].__name__ as a standalone invariant."
    - "No prior spec covers Cursor.fetchmany.__qualname__ as a standalone invariant."
    - "No prior spec covers Cursor.executemany.__qualname__ as a standalone invariant."
    - "No prior spec covers Cursor.executescript.__qualname__ as a standalone invariant."
    - "No prior spec covers Cursor.close.__qualname__ as a standalone invariant."
    - "sqlite3.Connection.__bases__[0].__name__ == 'object' — Connection is a C-extension type that directly subclasses object. Verified at runtime."
    - "sqlite3.Cursor.__bases__[0].__name__ == 'object' — Cursor is a C-extension type that directly subclasses object. Verified at runtime."
    - "sqlite3.Row.__bases__[0].__name__ == 'object' — Row is a C-extension type that directly subclasses object. Verified at runtime."
    - "sqlite3.Cursor.fetchmany.__qualname__ == 'Cursor.fetchmany' — C-accelerated method; compound dotted qualname. Verified at runtime."
    - "sqlite3.Cursor.executemany.__qualname__ == 'Cursor.executemany' — C-accelerated method; compound dotted qualname. Verified at runtime."
    - "sqlite3.Cursor.executescript.__qualname__ == 'Cursor.executescript' — C-accelerated method; compound dotted qualname. Verified at runtime."
    - "sqlite3.Cursor.close.__qualname__ == 'Cursor.close' — C-accelerated method; compound dotted qualname. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3.Connection — __bases__[0].__name__
#
# sqlite3_extra14 covers Connection.__qualname__ == 'Connection'. sqlite3_extra21
# covers Connection.__module__. No prior spec verifies Connection.__bases__[0].__name__
# as a standalone invariant. Connection is a C-extension type that directly
# subclasses object, so __bases__[0].__name__ == 'object'.
# Verified at runtime: 'object'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra22.Connection.base_name:
  description: "sqlite3.Connection.__bases__[0].__name__ == 'object' — Connection is a C-extension type that directly subclasses object"
  category: class_identity
  kind: python_call_eq
  function: "Connection.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Cursor — __bases__[0].__name__
#
# sqlite3_extra14 covers Cursor.__qualname__ == 'Cursor'. sqlite3_extra21
# covers Cursor.__module__. No prior spec verifies Cursor.__bases__[0].__name__
# as a standalone invariant. Cursor is a C-extension type that directly
# subclasses object, so __bases__[0].__name__ == 'object'.
# Verified at runtime: 'object'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra22.Cursor.base_name:
  description: "sqlite3.Cursor.__bases__[0].__name__ == 'object' — Cursor is a C-extension type that directly subclasses object"
  category: class_identity
  kind: python_call_eq
  function: "Cursor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Row — __bases__[0].__name__
#
# sqlite3_extra14 covers Row.__qualname__ == 'Row'. sqlite3_extra21 covers
# Row.__module__. No prior spec verifies Row.__bases__[0].__name__ as a
# standalone invariant. Row is a C-extension type that directly subclasses
# object, so __bases__[0].__name__ == 'object'.
# Verified at runtime: 'object'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra22.Row.base_name:
  description: "sqlite3.Row.__bases__[0].__name__ == 'object' — Row is a C-extension type that directly subclasses object"
  category: class_identity
  kind: python_call_eq
  function: "Row.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Cursor.fetchmany — __qualname__
#
# sqlite3_extra19 covers Cursor.fetchone and Cursor.fetchall __qualname__ but
# not fetchmany. No prior spec verifies Cursor.fetchmany.__qualname__ as a
# standalone invariant. For C-accelerated methods defined in class Cursor,
# __qualname__ uses the compound dotted form 'Cursor.fetchmany'.
# Verified at runtime: 'Cursor.fetchmany'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra22.Cursor.fetchmany_qualname:
  description: "sqlite3.Cursor.fetchmany.__qualname__ == 'Cursor.fetchmany' — C-accelerated method with compound dotted qualname"
  category: method_attrs
  kind: python_call_eq
  function: Cursor.fetchmany.__qualname__.__eq__
  args: ["Cursor.fetchmany"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Cursor.executemany — __qualname__
#
# sqlite3_extra19 covers Connection.executemany.__qualname__ but not
# Cursor.executemany.__qualname__. No prior spec verifies
# Cursor.executemany.__qualname__ as a standalone invariant.
# Verified at runtime: 'Cursor.executemany'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra22.Cursor.executemany_qualname:
  description: "sqlite3.Cursor.executemany.__qualname__ == 'Cursor.executemany' — C-accelerated method with compound dotted qualname"
  category: method_attrs
  kind: python_call_eq
  function: Cursor.executemany.__qualname__.__eq__
  args: ["Cursor.executemany"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Cursor.executescript — __qualname__
#
# sqlite3_extra19 covers Connection.executescript.__qualname__ but not
# Cursor.executescript.__qualname__. No prior spec verifies
# Cursor.executescript.__qualname__ as a standalone invariant.
# Verified at runtime: 'Cursor.executescript'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra22.Cursor.executescript_qualname:
  description: "sqlite3.Cursor.executescript.__qualname__ == 'Cursor.executescript' — C-accelerated method with compound dotted qualname"
  category: method_attrs
  kind: python_call_eq
  function: Cursor.executescript.__qualname__.__eq__
  args: ["Cursor.executescript"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Cursor.close — __qualname__
#
# sqlite3_extra19 covers Connection.close.__qualname__ but not
# Cursor.close.__qualname__. No prior spec verifies Cursor.close.__qualname__
# as a standalone invariant. Verified at runtime: 'Cursor.close'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra22.Cursor.close_qualname:
  description: "sqlite3.Cursor.close.__qualname__ == 'Cursor.close' — C-accelerated method with compound dotted qualname"
  category: method_attrs
  kind: python_call_eq
  function: Cursor.close.__qualname__.__eq__
  args: ["Cursor.close"]
  expected: true

# ---------------------------------------------------------------------------
# Table: Connection, Cursor, Row __bases__[0].__name__ values
#
# No prior spec groups Connection, Cursor, and Row __bases__[0].__name__ into
# a single table. All three C-extension types directly subclass object.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table sqlite3_extra22.class_base_names:
  description: "sqlite3 class __bases__[0].__name__ values — Connection, Cursor, Row each directly subclass object"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [Connection_base,
       "Connection.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "Connection.__bases__[0].__name__ == 'object'"]
    - [Cursor_base,
       "Cursor.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "Cursor.__bases__[0].__name__ == 'object'"]
    - [Row_base,
       "Row.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "Row.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# Table: Cursor additional method __qualname__ values
#
# No prior spec groups Cursor.fetchmany, Cursor.executemany,
# Cursor.executescript, and Cursor.close __qualname__ into a single table.
# All are C-accelerated methods using the compound dotted qualname form.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table sqlite3_extra22.cursor_additional_method_qualnames:
  description: "sqlite3.Cursor additional method __qualname__ values — fetchmany, executemany, executescript, close"
  kind: python_call_eq
  category: method_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [fetchmany,
       Cursor.fetchmany.__qualname__.__eq__,
       ["Cursor.fetchmany"],
       true,
       "Cursor.fetchmany.__qualname__ == 'Cursor.fetchmany'"]
    - [executemany,
       Cursor.executemany.__qualname__.__eq__,
       ["Cursor.executemany"],
       true,
       "Cursor.executemany.__qualname__ == 'Cursor.executemany'"]
    - [executescript,
       Cursor.executescript.__qualname__.__eq__,
       ["Cursor.executescript"],
       true,
       "Cursor.executescript.__qualname__ == 'Cursor.executescript'"]
    - [close,
       Cursor.close.__qualname__.__eq__,
       ["Cursor.close"],
       true,
       "Cursor.close.__qualname__ == 'Cursor.close'"]
