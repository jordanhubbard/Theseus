spec: zlib_checksum_rust
version: ">=3.9"
backend: rust_module(zlib_checksum_rust)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib documentation"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
  notes:
    - "Clean-room Rust reimplementation of Python zlib checksum functions, exposed via PyO3."
    - "crc32(data) computes CRC-32 checksum of data bytes."
    - "adler32(data) computes Adler-32 checksum of data bytes."
    - "crc32(b'hello') == 907060870."
    - "crc32(b'hello world') == 222957957."
    - "adler32(b'hello') == 103547413."
    - "adler32(b'hello world') == 436929629."
    - "adler32(b'') == 1 — Adler-32 of empty bytes is 1 by definition."
    - "All test vectors verified against Python 3.14.3 zlib module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# crc32 — CRC-32 checksum
table zlib_checksum_rust.crc32.vectors:
  kind: python_call_eq
  category: crc32
  id_prefix: crc32
  function: crc32

  columns: [id, args, expected]
  rows:
    - [hello,       [!b64 aGVsbG8=],         907060870]
    - [hello_world, [!b64 aGVsbG8gd29ybGQ=], 222957957]
    - [abc,         [!b64 YWJj],              891568578]

# adler32 — Adler-32 checksum
table zlib_checksum_rust.adler32.vectors:
  kind: python_call_eq
  category: adler32
  id_prefix: adler32
  function: adler32

  columns: [id, args, expected]
  rows:
    - [hello,       [!b64 aGVsbG8=],          103547413]
    - [hello_world, [!b64 aGVsbG8gd29ybGQ=],  436929629]
    - [abc,         [!b64 YWJj],               38600999]

