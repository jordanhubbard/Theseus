spec: code_extra
version: ">=3.0"
backend: python_module(code)

docs: https://docs.python.org/3/library/code.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/code.html — Python code module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/code.py"
  notes:
    - "Extends code.zspec.zsdl with additional class name, module, and hierarchy invariants."
    - "code.InteractiveConsole.__name__ == 'InteractiveConsole' — class for simulating an interactive console."
    - "code.InteractiveConsole.__module__ == 'code' — defined in the code module."
    - "code.InteractiveInterpreter.__name__ == 'InteractiveInterpreter' — base class for interactive interpreter sessions."
    - "code.InteractiveInterpreter.__module__ == 'code' — defined in the code module."
    - "code.InteractiveConsole.__bases__[0].__name__ == 'InteractiveInterpreter' — single direct inheritance."
    - "code.CommandCompiler.__name__ == 'CommandCompiler' — callable that remembers future-import flags across calls."
    - "code.CommandCompiler.__module__ == 'codeop' — CommandCompiler is defined in the codeop module and re-exported by code."
    - "code.compile_command.__name__ == 'compile_command' — top-level convenience function."
    - "code.interact.__name__ == 'interact' — launches an interactive console session."
    - "code.InteractiveInterpreter.runsource.__name__ == 'runsource' — compiles and runs a source string."
    - "code.InteractiveInterpreter.runcode.__name__ == 'runcode' — executes a compiled code object."
    - "code.InteractiveInterpreter.showtraceback.__name__ == 'showtraceback' — displays the last traceback."
    - "code.InteractiveInterpreter.showsyntaxerror.__name__ == 'showsyntaxerror' — displays a syntax error."
    - "code.InteractiveInterpreter.write.__name__ == 'write' — writes a string to sys.stderr."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# InteractiveConsole — class name and module
# ---------------------------------------------------------------------------

invariant code_extra.InteractiveConsole.name:
  description: "code.InteractiveConsole.__name__ == 'InteractiveConsole'"
  category: class_names
  kind: python_call_eq
  function: InteractiveConsole.__name__.__eq__
  args: ["InteractiveConsole"]
  expected: true

invariant code_extra.InteractiveConsole.module:
  description: "code.InteractiveConsole.__module__ == 'code'"
  category: class_modules
  kind: python_call_eq
  function: InteractiveConsole.__module__.__eq__
  args: ["code"]
  expected: true

# ---------------------------------------------------------------------------
# InteractiveInterpreter — class name and module
# ---------------------------------------------------------------------------

invariant code_extra.InteractiveInterpreter.name:
  description: "code.InteractiveInterpreter.__name__ == 'InteractiveInterpreter'"
  category: class_names
  kind: python_call_eq
  function: InteractiveInterpreter.__name__.__eq__
  args: ["InteractiveInterpreter"]
  expected: true

invariant code_extra.InteractiveInterpreter.module:
  description: "code.InteractiveInterpreter.__module__ == 'code'"
  category: class_modules
  kind: python_call_eq
  function: InteractiveInterpreter.__module__.__eq__
  args: ["code"]
  expected: true

# ---------------------------------------------------------------------------
# Inheritance hierarchy
# ---------------------------------------------------------------------------

invariant code_extra.hierarchy.InteractiveConsole_base:
  description: "code.InteractiveConsole.__bases__[0].__name__ == 'InteractiveInterpreter' — direct single inheritance"
  category: class_hierarchy
  kind: python_call_eq
  function: InteractiveConsole.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "InteractiveInterpreter"

# ---------------------------------------------------------------------------
# CommandCompiler — class name and module
# ---------------------------------------------------------------------------

invariant code_extra.CommandCompiler.name:
  description: "code.CommandCompiler.__name__ == 'CommandCompiler'"
  category: class_names
  kind: python_call_eq
  function: CommandCompiler.__name__.__eq__
  args: ["CommandCompiler"]
  expected: true

invariant code_extra.CommandCompiler.module:
  description: "code.CommandCompiler.__module__ == 'codeop' — CommandCompiler is defined in codeop and re-exported by code"
  category: class_modules
  kind: python_call_eq
  function: CommandCompiler.__module__.__eq__
  args: ["codeop"]
  expected: true

# ---------------------------------------------------------------------------
# Top-level function names
# ---------------------------------------------------------------------------

invariant code_extra.functions.compile_command_name:
  description: "code.compile_command.__name__ == 'compile_command'"
  category: function_names
  kind: python_call_eq
  function: compile_command.__name__.__eq__
  args: ["compile_command"]
  expected: true

invariant code_extra.functions.interact_name:
  description: "code.interact.__name__ == 'interact'"
  category: function_names
  kind: python_call_eq
  function: interact.__name__.__eq__
  args: ["interact"]
  expected: true

# ---------------------------------------------------------------------------
# InteractiveInterpreter method names
# ---------------------------------------------------------------------------

table code_extra.InteractiveInterpreter.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: method_name

  columns: [id, function, args, expected]
  rows:
    - [runsource,      InteractiveInterpreter.runsource.__name__.__eq__,      ["runsource"],      true]
    - [runcode,        InteractiveInterpreter.runcode.__name__.__eq__,        ["runcode"],        true]
    - [showtraceback,  InteractiveInterpreter.showtraceback.__name__.__eq__,  ["showtraceback"],  true]
    - [showsyntaxerror, InteractiveInterpreter.showsyntaxerror.__name__.__eq__, ["showsyntaxerror"], true]
    - [write,          InteractiveInterpreter.write.__name__.__eq__,          ["write"],          true]
