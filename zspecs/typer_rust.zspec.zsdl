spec: typer_rust
version: ">=3.9"
backend: rust_module(typer_rust)

docs: https://typer.tiangolo.com/

provenance:
  derived_from:
    - "https://typer.tiangolo.com/ — Typer library documentation"
  not_derived_from:
    - "typer source: typer/main.py"
  notes:
    - "Typer is a CLI app builder based on Python type hints."
    - "typer.Typer() creates an app instance."
    - "Expose typer_app_name() -> str: app.__class__.__name__ == 'Typer'."
    - "Expose typer_params_count(func) -> int: number of @app.command params."
    - "typer.Typer().__class__.__name__ == 'Typer'."
    - "Expose typer_echo_captured(msg) -> str: capture echo output."
    - "typer.echo('hello') outputs 'hello\\n' to stdout."
    - "Expose typer_colors_str() -> str: typer.colors.RED is a str."
    - "typer.colors.RED == 'red' — color constant."
    - "typer.colors.GREEN == 'green' — color constant."
    - "All test vectors verified against typer 0.15.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# typer app class name
invariant typer_rust.app.class_name:
  description: "typer.Typer().__class__.__name__ == 'Typer'"
  category: app
  kind: python_call_eq
  function: typer_app_classname
  args: []
  expected: "Typer"

# typer.colors — color constants
table typer_rust.colors.constants:
  kind: python_call_eq
  category: colors
  id_prefix: ty_col
  function: typer_color

  columns: [id, args, expected]
  rows:
    - [red,   ["RED"],   "red"]
    - [green, ["GREEN"], "green"]
    - [blue,  ["BLUE"],  "blue"]
    - [white, ["WHITE"], "white"]
    - [black, ["BLACK"], "black"]

# typer_echo_captured — capture echo output
table typer_rust.echo.captured:
  kind: python_call_eq
  category: echo
  id_prefix: ty_echo
  function: typer_echo_captured

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello"],  "hello"]
    - [world,  ["world"],  "world"]
    - [empty,  [""],       ""]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:32:02Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
