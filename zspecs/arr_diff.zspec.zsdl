spec: arr_diff
version: ">=4.0.0"
backend: node(arr-diff)

docs: https://www.npmjs.com/package/arr-diff

provenance:
  derived_from:
    - "arr-diff README — https://www.npmjs.com/package/arr-diff"
    - "Test vectors verified with arr-diff via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "arr-diff source"
  notes:
    - "arr-diff is an npm package. Install: npm install arr-diff"
    - "Returns elements from the first array that are not present in the second array."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of elements in the first array not found in the second."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table arr_diff.diff:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: adiff

  columns: [id, args, expected]
  rows:
    - [basic,   [[1, 2, 3], [2, 3]],      [1]]
    - [multi,   [[1, 2, 3, 4], [2, 4]],   [1, 3]]
    - [empty,   [[], [1, 2]],             []]
