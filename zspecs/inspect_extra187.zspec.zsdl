spec: inspect_extra187
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.BoundArguments.__name__ == 'BoundArguments' (len=14); __module__ == 'inspect'; __qualname__ == 'BoundArguments'; __bases__[0].__name__ == 'object'; verified with Python 3.14.3."
    - "inspect.Signature.__name__ == 'Signature' (len=9); __module__ == 'inspect'; __qualname__ == 'Signature'; __bases__[0].__name__ == 'object'; verified with Python 3.14.3."
    - "Both BoundArguments and Signature are pure-Python classes defined in Lib/inspect.py; their single base class is 'object'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.BoundArguments class identity
#
# inspect.BoundArguments.__name__ == 'BoundArguments' (len=14)
# inspect.BoundArguments.__module__ == 'inspect'
# inspect.BoundArguments.__qualname__ == 'BoundArguments'
#
# BoundArguments is a pure-Python class defined in Lib/inspect.py.
# Its __name__, __module__, and __qualname__ reflect standard class identity.
# New to extra187.
# ---------------------------------------------------------------------------

table inspect_extra187.bound_arguments_identity:
  description: "inspect.BoundArguments.__name__=='BoundArguments' (len=14); __module__=='inspect'; __qualname__=='BoundArguments'; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsig187

  columns: [id, function, args, expected, description]
  rows:
    - [ba_name_eq,
       BoundArguments.__name__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — the class name is 'BoundArguments'; str.__eq__('BoundArguments') returns True; verified with Python 3.14.3; new to extra187"]
    - [ba_name_len,
       BoundArguments.__name__.__len__,
       [],
       14,
       "inspect.BoundArguments.__name__.__len__() == 14 — 'BoundArguments' has 14 characters: B-o-u-n-d-A-r-g-u-m-e-n-t-s; str.__len__() returns 14; verified with Python 3.14.3; new to extra187"]
    - [ba_module_eq,
       BoundArguments.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py and reports __module__=='inspect'; str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra187"]
    - [ba_qualname_eq,
       BoundArguments.__qualname__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — __qualname__ matches __name__ for a top-level class; str.__eq__('BoundArguments') returns True; verified with Python 3.14.3; new to extra187"]

# ---------------------------------------------------------------------------
# Table 2: inspect.BoundArguments base class identity
#
# inspect.BoundArguments.__bases__[0].__name__ == 'object'
#
# BoundArguments inherits directly from object with no other base classes.
# The __bases__ tuple has exactly one entry: the built-in object class.
# New to extra187.
#
# NOTE: Any value containing '[' must be double-quoted per ZSDL rules.
# ---------------------------------------------------------------------------

table inspect_extra187.bound_arguments_bases:
  description: "inspect.BoundArguments.__bases__[0].__name__=='object'; single base class is object; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsig187

  columns: [id, function, args, expected, description]
  rows:
    - [ba_base_name_eq,
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments has a single base class: object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra187"]
    - [sig_name_eq,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — the class name is 'Signature'; str.__eq__('Signature') returns True; verified with Python 3.14.3; new to extra187"]
    - [sig_name_len,
       Signature.__name__.__len__,
       [],
       9,
       "inspect.Signature.__name__.__len__() == 9 — 'Signature' has 9 characters: S-i-g-n-a-t-u-r-e; str.__len__() returns 9; verified with Python 3.14.3; new to extra187"]
    - [sig_module_eq,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py and reports __module__=='inspect'; str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra187"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Signature class and base class identity
#
# inspect.Signature.__qualname__ == 'Signature'
# inspect.Signature.__bases__[0].__name__ == 'object'
#
# Signature is a pure-Python class defined in Lib/inspect.py.
# It inherits directly from object. New to extra187.
# ---------------------------------------------------------------------------

table inspect_extra187.signature_qualname_and_bases:
  description: "inspect.Signature.__qualname__=='Signature'; Signature.__bases__[0].__name__=='object'; new to extra187"
  kind: python_call_eq
  category: identity
  id_prefix: inspectsig187

  columns: [id, function, args, expected, description]
  rows:
    - [sig_qualname_eq,
       Signature.__qualname__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__qualname__.__eq__('Signature') == True — __qualname__ matches __name__ for a top-level class; str.__eq__('Signature') returns True; verified with Python 3.14.3; new to extra187"]
    - [sig_base_name_eq,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature has a single base class: object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra187"]
    - [sig_base_eq_ba_base,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — reconfirming Signature.__name__ is 'Signature' (len=9); mirrors BoundArguments pattern; str.__eq__('Signature') returns True; verified with Python 3.14.3; new to extra187"]
    - [ba_qualname_recheck,
       BoundArguments.__qualname__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — reconfirming BoundArguments.__qualname__ is 'BoundArguments' (len=14); str.__eq__('BoundArguments') returns True; verified with Python 3.14.3; new to extra187"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra187
# ---------------------------------------------------------------------------

invariant inspect_extra187.bound_arguments_name:
  description: "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — class name is 'BoundArguments' (len=14); verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: BoundArguments.__name__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra187.bound_arguments_module:
  description: "inspect.BoundArguments.__module__.__eq__('inspect') == True — class is defined in Lib/inspect.py; verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra187.bound_arguments_qualname:
  description: "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — top-level class: __qualname__ == __name__; verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: BoundArguments.__qualname__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra187.bound_arguments_base_is_object:
  description: "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments inherits directly from object with no other bases; verified with Python 3.14.3; new to extra187"
  category: identity
  kind: python_call_eq
  function: "BoundArguments.__bases__[0].__name__.__eq__"
  args: ["object"]
