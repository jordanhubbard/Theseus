spec: enum_extra33
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra32.zspec.zsdl."
    - "Prior specs covered: Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique/EnumType/EnumMeta __name__/__module__/__qualname__; all __mro__.__len__() values; __bases__[0].__name__ for all; Enum.__str__/__repr__/__new__ __qualname__.__len__() and __qualname__.__eq__; Enum._missing_/__qualname__.__len__ and _generate_next_value_/__qualname__.__len__; EnumType.__new__/__getitem__/__iter__ __qualname__.__eq__."
    - "This spec covers: Enum.__hash__/__format__ __qualname__.__len__(); EnumType.__call__/__prepare__/__repr__/__setattr__/__delattr__/__iter__ __qualname__.__len__(); IntEnum.__mro__.__len__() confirmations and __bases__[0].__name__; EnumType.__mro__.__len__() == 3 standalone."
    - "Enum.__hash__.__qualname__ == 'Enum.__hash__' (len=13) — matches Enum.__repr__ (13)."
    - "Enum.__format__.__qualname__ == 'Enum.__format__' (len=15) — matches Enum.__init__ (len reported via object.__init__)."
    - "EnumType.__call__.__qualname__ == 'EnumType.__call__' (len=17)."
    - "EnumType.__prepare__.__qualname__ == 'EnumType.__prepare__' (len=20)."
    - "EnumType.__repr__.__qualname__ == 'EnumType.__repr__' (len=17)."
    - "EnumType.__setattr__.__qualname__ == 'EnumType.__setattr__' (len=20)."
    - "EnumType.__delattr__.__qualname__ == 'EnumType.__delattr__' (len=20)."
    - "EnumType.__iter__.__qualname__ == 'EnumType.__iter__' (len=17)."
    - "EnumType.__mro__ == [EnumType, type, object] (len=3)."
    - "IntEnum.__bases__[0].__name__ == 'int' — confirmed."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Enum dunder method __qualname__.__len__() table (extra33 namespace)
#
# Prior specs covered Enum.__new__ (12), Enum.__str__ (12), Enum.__repr__ (13).
# This table adds the remaining dunder methods:
#   __hash__ -> 13 (matches __repr__), __format__ -> 15.
# Enum.__format__ is the longest among the five core Enum dunder method
# qualnames. No prior enum spec records __hash__ or __format__ qualname lengths
# together in the extra33 namespace.
# ---------------------------------------------------------------------------

table enum_extra33.Enum_dunder_qualname_lens:
  description: "__qualname__.__len__() for Enum.__hash__ and Enum.__format__"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: Enum_dunder_qualname_len

  columns: [id, function, args, expected]
  rows:
    - [hash,   Enum.__hash__.__qualname__.__len__,   [], 13]
    - [format, Enum.__format__.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# EnumType method __qualname__.__len__() table (extra33 namespace)
#
# EnumType is the metaclass for all enum classes. Its methods have qualnames
# of the form 'EnumType.<method>'. Prior specs covered __new__ (16),
# __getitem__ (20), and __iter__ (17) via __eq__ checks. This table records
# their lengths alongside previously uncovered methods:
#   __call__ -> 17, __prepare__ -> 20, __repr__ -> 17,
#   __setattr__ -> 20, __delattr__ -> 20, __iter__ -> 17.
# __prepare__, __setattr__, and __delattr__ are tied at 20 (the maximum).
# __call__, __repr__, and __iter__ are all 17. No prior enum spec records
# these qualname lengths in the extra33 namespace.
# ---------------------------------------------------------------------------

table enum_extra33.EnumType_method_qualname_lens:
  description: "__qualname__.__len__() for EnumType metaclass methods"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: EnumType_method_qualname_len

  columns: [id, function, args, expected]
  rows:
    - [call,      EnumType.__call__.__qualname__.__len__,      [], 17]
    - [prepare,   EnumType.__prepare__.__qualname__.__len__,   [], 20]
    - [repr,      EnumType.__repr__.__qualname__.__len__,      [], 17]
    - [setattr,   EnumType.__setattr__.__qualname__.__len__,   [], 20]
    - [delattr,   EnumType.__delattr__.__qualname__.__len__,   [], 20]
    - [iter,      EnumType.__iter__.__qualname__.__len__,      [], 17]

# ---------------------------------------------------------------------------
# EnumType.__mro__.__len__() == 3 — standalone (extra33 namespace)
#
# EnumType is a metaclass (a subclass of 'type'), so its MRO is
# [EnumType, type, object] — depth 3. This is shallower than enum value
# classes like IntEnum (5) or IntFlag (6) because EnumType sits in the
# metaclass hierarchy, not the value hierarchy. No prior enum spec records
# this standalone in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra33.EnumType.mro_len:
  description: "enum.EnumType.__mro__.__len__() == 3 — metaclass MRO: [EnumType, type, object]"
  category: mro_depths
  kind: python_call_eq
  function: EnumType.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Enum.__format__.__qualname__.__len__() == 15 — standalone (extra33 namespace)
#
# 'Enum.__format__' has 15 characters, making it the longest of the five
# core Enum dunder method qualnames (__new__=12, __str__=12, __repr__=13,
# __hash__=13, __format__=15). Enum.__format__ controls how enum members
# are formatted by format() and f-strings, defaulting to the member's value
# format. No prior enum spec records this standalone in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra33.Enum.format.qualname_len:
  description: "len(enum.Enum.__format__.__qualname__) == 15 — longest among Enum's five core dunder method qualnames"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Enum.__format__.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# EnumType.__prepare__.__qualname__.__len__() == 20 — standalone
# (extra33 namespace)
#
# 'EnumType.__prepare__' has 20 characters, tied with EnumType.__setattr__
# and EnumType.__delattr__ as the longest EnumType method qualnames.
# __prepare__ is a classmethod that returns the enum namespace dict, enabling
# enum metaclass customisation before class body execution. No prior enum spec
# records this standalone in the extra33 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra33.EnumType.prepare.qualname_len:
  description: "len(enum.EnumType.__prepare__.__qualname__) == 20 — tied for longest EnumType method qualname"
  category: method_qualname_lengths
  kind: python_call_eq
  function: EnumType.__prepare__.__qualname__.__len__
  args: []
  expected: 20
