spec: theseus_json_cr5
version: ">=3.9"
backend: python_cleanroom(theseus_json_cr5)
blocks: json

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html"
    - "RFC 8259 — JSON specification"
  notes:
    - "Clean-room extended JSON utilities. Do NOT import json."
    - "JSONDecodeError: exception raised on invalid JSON input."
    - "loads with sort_keys=True: serialize dict with keys sorted."
    - "loads nested structures: deeply nested JSON parsing."
    - "json5_decode_error(): loads('invalid json') raises JSONDecodeError — returns True."
    - "json5_sort_keys(): dumps({'b':2,'a':1}, sort_keys=True) == '{\"a\": 1, \"b\": 2}'."
    - "json5_nested(): loads('{\"a\":{\"b\":[1,2,3]}}')['a']['b'] == [1, 2, 3]."
    - "Zero-arg invariant signatures — def json5_decode_error(): return bool"
    - "JSONDecodeError: subclass of ValueError raised when JSON is malformed."
    - "sort_keys: sort the dict keys alphabetically in the output."
    - "Nested: JSON objects and arrays can be arbitrarily nested."
    - "Export: loads, dumps, JSONDecodeError, load, dump, JSONEncoder, JSONDecoder."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_json_cr5.decode_error:
  description: "loads('invalid json') raises JSONDecodeError"
  category: JSONDecodeError
  kind: python_call_eq
  function: json5_decode_error
  args: []
  expected: true

invariant theseus_json_cr5.sort_keys:
  description: "dumps({'b':2,'a':1}, sort_keys=True) == '{\"a\": 1, \"b\": 2}'"
  category: sort_keys
  kind: python_call_eq
  function: json5_sort_keys
  args: []
  expected: "{\"a\": 1, \"b\": 2}"

invariant theseus_json_cr5.nested:
  description: "loads nested JSON; access ['a']['b'] == [1,2,3]"
  category: nested
  kind: python_call_eq
  function: json5_nested
  args: []
  expected: [1, 2, 3]
