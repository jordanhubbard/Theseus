spec: tarfile_extra11
version: ">=3.9"
backend: python_module(tarfile)

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tarfile.html — Python tarfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/tarfile.py"
  notes:
    - "This spec extends tarfile.zspec.zsdl through tarfile_extra10.zspec.zsdl."
    - "tarfile_extra10 covers: ReadError/__mro__[1]/[2]; CompressionError/__mro__[1]/[2]; DEFAULT_FORMAT.__class__.__name__=='int'; open.__module__=='tarfile'; TarInfo default type byte b'0'."
    - "tarfile_extra9 covers: TarInfo devmajor/devminor/size/mtime defaults; AREGTYPE; TarError.__mro__[1]/[2]; ExFileObject; TarInfo.linkname default."
    - "No prior spec covers: tarfile.__all__.__len__() == 25 — the module exports 25 public names."
    - "No prior spec covers: tarfile.__all__.__class__.__name__.__len__() == 4 — __all__ is a list (len('list')==4)."
    - "No prior spec covers: tarfile.TarFile.__dict__.__class__.__name__.__len__() == 12 — __dict__ is a mappingproxy."
    - "No prior spec covers: tarfile.TarInfo.__dict__.__class__.__name__.__len__() == 12 — same mappingproxy pattern."
    - "No prior spec covers: tarfile.TarError.__dict__.__class__.__name__.__len__() == 12 — same mappingproxy pattern."
    - "No prior spec covers: tarfile.TarError.__bases__[0].__name__.__len__() == 9 — 'Exception' has 9 characters."
    - "No prior spec covers: tarfile.TarError.__mro__.__len__() == 4 — [TarError, Exception, BaseException, object]."
    - "No prior spec covers: tarfile.TarFile.__mro__.__len__() == 2 — [TarFile, object]."
    - "No prior spec covers: tarfile.TarFile.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters."
    - "No prior spec covers: TarFile method __qualname__.__len__() for open/add/extract/extractall/getmembers/getnames/close."
    - "No prior spec covers: is_tarfile.__qualname__.__len__() == 10 — 'is_tarfile' has 10 characters."
    - "Verified: tarfile.__all__.__len__() == 25."
    - "Verified: tarfile.__all__.__class__.__name__ == 'list'; len == 4."
    - "Verified: TarFile/TarInfo/TarError __dict__.__class__.__name__ == 'mappingproxy'; len == 12."
    - "Verified: TarError.__bases__[0].__name__ == 'Exception'; len == 9."
    - "Verified: TarError.__mro__.__len__() == 4; TarFile.__mro__.__len__() == 2."
    - "Verified: TarFile.__bases__[0].__name__ == 'object'; len == 6."
    - "Verified: TarFile.open.__qualname__ == 'TarFile.open' (len 12); TarFile.add.__qualname__ == 'TarFile.add' (len 11)."
    - "Verified: TarFile.extract.__qualname__ == 'TarFile.extract' (len 15); TarFile.extractall.__qualname__ == 'TarFile.extractall' (len 18)."
    - "Verified: TarFile.getmembers.__qualname__ == 'TarFile.getmembers' (len 18); TarFile.getnames.__qualname__ == 'TarFile.getnames' (len 16)."
    - "Verified: TarFile.close.__qualname__ == 'TarFile.close' (len 13); is_tarfile.__qualname__ == 'is_tarfile' (len 10)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# tarfile.__all__ length and class name
#
# No prior tarfile spec checks __all__.__len__() or __all__.__class__.__name__.__len__().
# tarfile.__all__ is a list of 25 public names. __class__.__name__ == 'list' (len 4).
# ---------------------------------------------------------------------------

invariant tarfile_extra11.all.len:
  description: "tarfile.__all__.__len__() == 25 — the module exports 25 public names"
  category: module_attrs
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 25

invariant tarfile_extra11.all.class_name_len:
  description: "tarfile.__all__.__class__.__name__.__len__() == 4 — __all__ is a list; 'list' has 4 characters"
  category: module_attrs
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() for TarFile, TarInfo, TarError
#
# All Python classes store their namespace in a mappingproxy object.
# len('mappingproxy') == 12. No prior tarfile spec checks this on any class.
# ---------------------------------------------------------------------------

table tarfile_extra11.dict_class_name_len:
  description: "TarFile/TarInfo/TarError __dict__.__class__.__name__.__len__() == 12 — all are mappingproxy"
  kind: python_call_eq
  category: class_attrs
  id_prefix: dcnlen11

  columns: [id, function, args, expected]
  rows:
    - [TarFile,  TarFile.__dict__.__class__.__name__.__len__,  [], 12]
    - [TarInfo,  TarInfo.__dict__.__class__.__name__.__len__,  [], 12]
    - [TarError, TarError.__dict__.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# TarError base class name length and MRO depth
#
# No prior tarfile spec checks TarError.__bases__[0].__name__.__len__().
# TarError.__bases__[0].__name__ == 'Exception' (len 9).
# No prior tarfile spec checks TarError.__mro__.__len__().
# TarError.__mro__: [TarError, Exception, BaseException, object] — depth 4.
# TarFile.__mro__: [TarFile, object] — depth 2.
# TarFile.__bases__[0].__name__ == 'object' (len 6) — length angle not covered.
# ---------------------------------------------------------------------------

invariant tarfile_extra11.TarError.base_name_len:
  description: "tarfile.TarError.__bases__[0].__name__.__len__() == 9 — 'Exception' has 9 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "TarError.__bases__[0].__name__.__len__"
  args: []
  expected: 9

invariant tarfile_extra11.TarError.mro_len:
  description: "tarfile.TarError.__mro__.__len__() == 4 — [TarError, Exception, BaseException, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: TarError.__mro__.__len__
  args: []
  expected: 4

invariant tarfile_extra11.TarFile.mro_len:
  description: "tarfile.TarFile.__mro__.__len__() == 2 — [TarFile, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: TarFile.__mro__.__len__
  args: []
  expected: 2

invariant tarfile_extra11.TarFile.base_name_len:
  description: "tarfile.TarFile.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "TarFile.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# TarFile method __qualname__.__len__() for core API methods
#
# No prior tarfile spec checks __qualname__.__len__() for any TarFile method.
# All qualnames follow the 'TarFile.METHOD' pattern:
#   open       -> 'TarFile.open'       len 12
#   add        -> 'TarFile.add'        len 11
#   extract    -> 'TarFile.extract'    len 15
#   extractall -> 'TarFile.extractall' len 18
#   getmembers -> 'TarFile.getmembers' len 18
#   getnames   -> 'TarFile.getnames'   len 16
#   close      -> 'TarFile.close'      len 13
# ---------------------------------------------------------------------------

table tarfile_extra11.TarFile_method_qualname_len:
  description: "TarFile method __qualname__.__len__() for open/add/extract/extractall/getmembers/getnames/close"
  kind: python_call_eq
  category: method_attrs
  id_prefix: mqlen11

  columns: [id, function, args, expected]
  rows:
    - [open,       TarFile.open.__qualname__.__len__,       [], 12]
    - [add,        TarFile.add.__qualname__.__len__,        [], 11]
    - [extract,    TarFile.extract.__qualname__.__len__,    [], 15]
    - [extractall, TarFile.extractall.__qualname__.__len__, [], 18]
    - [getmembers, TarFile.getmembers.__qualname__.__len__, [], 18]
    - [getnames,   TarFile.getnames.__qualname__.__len__,   [], 16]
    - [close,      TarFile.close.__qualname__.__len__,      [], 13]

# ---------------------------------------------------------------------------
# is_tarfile.__qualname__.__len__() == 10
#
# No prior tarfile spec checks is_tarfile.__qualname__.__len__().
# is_tarfile.__qualname__ == 'is_tarfile' (len 10).
# tarfile_extra4 covers is_tarfile.__qualname__ == 'is_tarfile' as a string.
# tarfile_extra8 covers is_tarfile.__module__ and is_tarfile.__class__.__name__.
# The length axis is new.
# ---------------------------------------------------------------------------

invariant tarfile_extra11.is_tarfile.qualname_len:
  description: "tarfile.is_tarfile.__qualname__.__len__() == 10 — 'is_tarfile' has 10 characters"
  category: functions
  kind: python_call_eq
  function: is_tarfile.__qualname__.__len__
  args: []
  expected: 10
