spec: unicodedata_extra24
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
    - "unicodedata_extra23.zspec.zsdl — covers all 13 function __qualname__.__len__() in table; ucd_3_2_0.unidata_version.__len__()==5; unidata_version.__class__.__name__.__len__()==3; unidata_version.__class__.__name__.__eq__('str')."
    - "unicodedata_extra22.zspec.zsdl — covers all 13 function __name__.__len__() in table; unidata_version.__len__()==6; ucd_3_2_0 class name/module/qualname lengths."
  notes:
    - "This spec extends unicodedata through unicodedata_extra23; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: unicodedata.__name__/__package__; all 13 function __name__/__module__/__qualname__; unidata_version string and class; ucd_3_2_0 class identity; __module__.__len__()==11 for all functions; __name__.__len__() for all 13 functions; unidata_version.__len__()==6; ucd_3_2_0.unidata_version.__len__()==5; unidata_version.__class__.__name__.__len__()==3; all 13 function __qualname__.__len__()."
    - "This spec covers: module-level function __class__.__name__.__len__()==26 (NOVEL — all unicodedata functions are builtin_function_or_method, which has 26 characters); ucd_3_2_0 method __qualname__.__len__() for all 13 methods (NOVEL — ucd_3_2_0 is a UCD instance; its methods have qualnames 'UCD.<name>', different lengths from bare module-level qualnames); unicodedata.__package__.__len__()==0 (NOVEL — unicodedata is a C extension with no parent package, __package__ is ''); unicodedata.__doc__.__class__.__name__.__len__()==3 (NOVEL — module docstring class is str)."
    - "unicodedata module-level functions (name, lookup, category, etc.) are all builtin_function_or_method objects. 'builtin_function_or_method' has 26 characters. No prior unicodedata spec checks this. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "unicodedata.ucd_3_2_0 is a UCD instance. Its methods (name, lookup, etc.) have __qualname__ == 'UCD.<fn_name>', giving lengths 8, 10, 12, etc. Prior specs only checked module-level flat qualnames. This is a distinct angle. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "unicodedata.__package__ == '' (len 0). unicodedata is a C extension module with no parent package. No prior spec checks __package__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "unicodedata.__doc__.__class__.__name__ == 'str' (len 3). Module docstring is a plain str. No prior spec checks this. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ucd_3_2_0.name.__qualname__ == 'UCD.name' (len 8). Verified at runtime."
    - "ucd_3_2_0.lookup.__qualname__ == 'UCD.lookup' (len 10). Verified at runtime."
    - "ucd_3_2_0.category.__qualname__ == 'UCD.category' (len 12). Verified at runtime."
    - "ucd_3_2_0.bidirectional.__qualname__ == 'UCD.bidirectional' (len 17). Verified at runtime."
    - "ucd_3_2_0.combining.__qualname__ == 'UCD.combining' (len 13). Verified at runtime."
    - "ucd_3_2_0.east_asian_width.__qualname__ == 'UCD.east_asian_width' (len 20). Verified at runtime."
    - "ucd_3_2_0.mirrored.__qualname__ == 'UCD.mirrored' (len 12). Verified at runtime."
    - "ucd_3_2_0.decomposition.__qualname__ == 'UCD.decomposition' (len 17). Verified at runtime."
    - "ucd_3_2_0.normalize.__qualname__ == 'UCD.normalize' (len 13). Verified at runtime."
    - "ucd_3_2_0.is_normalized.__qualname__ == 'UCD.is_normalized' (len 17). Verified at runtime."
    - "ucd_3_2_0.digit.__qualname__ == 'UCD.digit' (len 9). Verified at runtime."
    - "ucd_3_2_0.numeric.__qualname__ == 'UCD.numeric' (len 11). Verified at runtime."
    - "ucd_3_2_0.decimal.__qualname__ == 'UCD.decimal' (len 11). Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# unicodedata.__package__.__len__()
#
# unicodedata is a C extension module with no parent package. __package__ == ''
# (empty string), so len == 0. No prior unicodedata spec checks __package__.__len__().
# Novel standalone invariant.
# ---------------------------------------------------------------------------

invariant unicodedata_extra24.module.package_len:
  description: "unicodedata.__package__.__len__() == 0 — C extension, no parent package; __package__ is the empty string"
  category: module_structure
  kind: python_call_eq
  function: __package__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# unicodedata.__doc__.__class__.__name__.__len__()
#
# The module docstring is a plain str. __class__.__name__ == 'str' (3 chars).
# No prior unicodedata spec checks this. Novel standalone invariant.
# ---------------------------------------------------------------------------

invariant unicodedata_extra24.module.doc_class_name_len:
  description: "unicodedata.__doc__.__class__.__name__.__len__() == 3 — module docstring is a str; 'str' has 3 characters"
  category: string_length
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# unicodedata function __class__.__name__.__len__() — builtin_function_or_method
#
# All module-level unicodedata functions are implemented in C and exposed as
# builtin_function_or_method objects. 'builtin_function_or_method' has 26
# characters. No prior unicodedata spec checks __class__.__name__.__len__()
# for any of these functions. This standalone confirms the pattern for 'name'.
# ---------------------------------------------------------------------------

invariant unicodedata_extra24.name.class_name_len:
  description: "unicodedata.name.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' has 26 characters"
  category: function_identity
  kind: python_call_eq
  function: name.__class__.__name__.__len__
  args: []
  expected: 26

invariant unicodedata_extra24.lookup.class_name_len:
  description: "unicodedata.lookup.__class__.__name__.__len__() == 26 — 'builtin_function_or_method' has 26 characters"
  category: function_identity
  kind: python_call_eq
  function: lookup.__class__.__name__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# Table: module-level function __class__.__name__.__len__() — all 13 functions
#
# All 13 unicodedata module-level functions are builtin_function_or_method
# objects; their __class__.__name__.__len__() is uniformly 26. No prior spec
# verifies this for any of these functions. This table provides complete
# coverage of the class type dimension for the module's C-extension API.
# All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra24.module_func_class_name_lengths:
  description: "unicodedata module-level function __class__.__name__.__len__() == 26 — all 13 functions are builtin_function_or_method"
  kind: python_call_eq
  category: function_identity
  id_prefix: ud24fcnl

  columns: [id, function, args, expected]
  rows:
    - [name,             name.__class__.__name__.__len__,             [], 26]
    - [lookup,           lookup.__class__.__name__.__len__,           [], 26]
    - [decimal,          decimal.__class__.__name__.__len__,          [], 26]
    - [digit,            digit.__class__.__name__.__len__,            [], 26]
    - [numeric,          numeric.__class__.__name__.__len__,          [], 26]
    - [category,         category.__class__.__name__.__len__,         [], 26]
    - [bidirectional,    bidirectional.__class__.__name__.__len__,    [], 26]
    - [combining,        combining.__class__.__name__.__len__,        [], 26]
    - [east_asian_width, east_asian_width.__class__.__name__.__len__, [], 26]
    - [mirrored,         mirrored.__class__.__name__.__len__,         [], 26]
    - [decomposition,    decomposition.__class__.__name__.__len__,    [], 26]
    - [normalize,        normalize.__class__.__name__.__len__,        [], 26]
    - [is_normalized,    is_normalized.__class__.__name__.__len__,    [], 26]

# ---------------------------------------------------------------------------
# Table: ucd_3_2_0 method __qualname__.__len__()
#
# unicodedata.ucd_3_2_0 is a UCD (Unicode Character Database compatibility
# object) instance. Its methods have qualnames of the form 'UCD.<fn_name>',
# giving lengths 4 + 1 + len(fn_name). These differ from the flat qualnames
# of the module-level functions (covered in extra23). No prior unicodedata spec
# checks ucd_3_2_0 method __qualname__.__len__(). Novel for all 13 entries.
# All verified at runtime.
# ---------------------------------------------------------------------------

table unicodedata_extra24.ucd_3_2_0_method_qualname_lengths:
  description: "unicodedata.ucd_3_2_0 method __qualname__.__len__() — 'UCD.<name>' pattern, novel for all 13 methods"
  kind: python_call_eq
  category: method_identity
  id_prefix: ud24ucqln

  columns: [id, function, args, expected]
  rows:
    - [name,             ucd_3_2_0.name.__qualname__.__len__,             [], 8]
    - [lookup,           ucd_3_2_0.lookup.__qualname__.__len__,           [], 10]
    - [decimal,          ucd_3_2_0.decimal.__qualname__.__len__,          [], 11]
    - [digit,            ucd_3_2_0.digit.__qualname__.__len__,            [], 9]
    - [numeric,          ucd_3_2_0.numeric.__qualname__.__len__,          [], 11]
    - [category,         ucd_3_2_0.category.__qualname__.__len__,         [], 12]
    - [bidirectional,    ucd_3_2_0.bidirectional.__qualname__.__len__,    [], 17]
    - [combining,        ucd_3_2_0.combining.__qualname__.__len__,        [], 13]
    - [east_asian_width, ucd_3_2_0.east_asian_width.__qualname__.__len__, [], 20]
    - [mirrored,         ucd_3_2_0.mirrored.__qualname__.__len__,         [], 12]
    - [decomposition,    ucd_3_2_0.decomposition.__qualname__.__len__,    [], 17]
    - [normalize,        ucd_3_2_0.normalize.__qualname__.__len__,        [], 13]
    - [is_normalized,    ucd_3_2_0.is_normalized.__qualname__.__len__,    [], 17]
