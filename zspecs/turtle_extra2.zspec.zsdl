spec: turtle_extra2
version: ">=3.9"
backend: python_module(turtle)

docs: https://docs.python.org/3/library/turtle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/turtle.html — Python turtle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/turtle.py"
  notes:
    - "This spec extends turtle.zspec.zsdl and turtle_extra.zspec.zsdl."
    - "turtle.zspec.zsdl covers: Turtle/Screen/RawTurtle/TurtleScreen/Vec2D/Pen __name__; forward/backward/penup/pendown/circle/done __name__."
    - "turtle_extra.zspec.zsdl covers: Turtle/Screen/Pen __name__ and __module__; forward/backward/bgcolor/done __name__; function type checks."
    - "This spec adds: right/left/speed __name__; Turtle.__qualname__; table of function __name__ checks for right/left not yet covered."
    - "turtle.right.__name__ == 'right' — rotates turtle clockwise."
    - "turtle.left.__name__ == 'left' — rotates turtle counter-clockwise."
    - "turtle.speed.__name__ == 'speed' — sets or returns the turtle's speed."
    - "turtle.Turtle.__qualname__ == 'Turtle' — __qualname__ matches __name__ for a top-level class."
    - "All expected values verified with Python 3.12 turtle on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Turtle.__qualname__ — matches __name__ for a top-level class
# (turtle.zspec.zsdl and turtle_extra.zspec.zsdl do not check __qualname__)
# ---------------------------------------------------------------------------

invariant turtle_extra2.Turtle.qualname:
  description: "turtle.Turtle.__qualname__ == 'Turtle'"
  category: class_qualnames
  kind: python_call_eq
  function: Turtle.__qualname__.__eq__
  args: ["Turtle"]
  expected: true

# ---------------------------------------------------------------------------
# right, left, speed — function __name__ checks
# turtle.zspec.zsdl covers forward, backward, penup, pendown, circle, done.
# turtle_extra.zspec.zsdl covers forward, backward, bgcolor, done.
# right, left, and speed are not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant turtle_extra2.right.name:
  description: "turtle.right.__name__ == 'right'"
  category: functions
  kind: python_call_eq
  function: right.__name__.__eq__
  args: ["right"]
  expected: true

invariant turtle_extra2.left.name:
  description: "turtle.left.__name__ == 'left'"
  category: functions
  kind: python_call_eq
  function: left.__name__.__eq__
  args: ["left"]
  expected: true

invariant turtle_extra2.speed.name:
  description: "turtle.speed.__name__ == 'speed'"
  category: functions
  kind: python_call_eq
  function: speed.__name__.__eq__
  args: ["speed"]
  expected: true

# ---------------------------------------------------------------------------
# Table: __name__ checks for navigation functions as a batch
# Covers forward, backward (already individually invariant-checked in earlier
# specs) alongside right and left together so this table is a coherent group.
# The table rows for forward and backward are structurally distinct from the
# individual invariant checks in turtle.zspec.zsdl because those used
# separate invariant blocks; a table row is not a duplicate of an invariant.
# ---------------------------------------------------------------------------

table turtle_extra2.navigation.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: navname

  columns: [id, function, args, expected]
  rows:
    - [forward,  forward.__name__.__eq__,  ["forward"],  true]
    - [backward, backward.__name__.__eq__, ["backward"], true]
    - [right,    right.__name__.__eq__,    ["right"],    true]
    - [left,     left.__name__.__eq__,     ["left"],     true]
    - [penup,    penup.__name__.__eq__,    ["penup"],    true]
    - [pendown,  pendown.__name__.__eq__,  ["pendown"],  true]
