provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re class __dict__.__class__.__name__ (mappingproxy), __mro__.__class__.__name__ (tuple), and __bases__.__class__.__name__ checks for Pattern, Match, RegexFlag, error"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.Pattern.__dict__.__class__.__name__, re.Match.__dict__.__class__.__name__, re.RegexFlag.__dict__.__class__.__name__, re.error.__dict__.__class__.__name__ (all mappingproxy); re.Pattern.__mro__.__class__.__name__, re.error.__mro__.__class__.__name__, re.RegexFlag.__mro__.__class__.__name__ (tuple); re.RegexFlag.__bases__.__class__.__name__ (tuple); none of these __dict__.__class__.__name__, __mro__.__class__.__name__, or __bases__.__class__.__name__ checks were covered in _extra1156 or _extra1171"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

