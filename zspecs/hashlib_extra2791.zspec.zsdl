spec: hashlib_extra2791
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for HASH, blake2b, blake2s."
    - "hashlib_extra2761.zspec.zsdl — covers __matmul__, __truediv__, and __iadd__ absence for HASH, blake2b, blake2s."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "hashlib.HASH.__dict__.__contains__('__iand__') == False — HASH (the OpenSSL-backed C type) does not define in-place bitwise AND; cryptographic hash objects carry no bitwise arithmetic; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__ior__') == False — HASH does not define in-place bitwise OR; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__ixor__') == False — HASH does not define in-place bitwise XOR; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__iand__') == False — blake2b does not define in-place bitwise AND; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__ior__') == False — blake2b does not define in-place bitwise OR; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__ixor__') == False — blake2b does not define in-place bitwise XOR; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__iand__') == False — blake2s does not define in-place bitwise AND; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__ior__') == False — blake2s does not define in-place bitwise OR; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__ixor__') == False — blake2s does not define in-place bitwise XOR; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.HASH.__dict__ — __iand__, __ior__, __ixor__ absence
# HASH is the C type for OpenSSL-backed hash objects (sha256, md5, sha1, etc.).
# Hash digest objects are cryptographic primitives; in-place bitwise operators
# (&=, |=, ^=) have no meaning for them and are not defined.
# ---------------------------------------------------------------------------

table hashlib_extra2791.hash_dict_iand_ior_ixor:
  description: "hashlib.HASH.__dict__ does not contain __iand__, __ior__, or __ixor__ — in-place bitwise operators are not defined on hash digest objects; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2791

  columns: [id, function, args, expected]
  rows:
    - ["hl2791-hash-iand", hashlib.HASH.__dict__.__contains__, ["__iand__"], false]
    - ["hl2791-hash-ior",  hashlib.HASH.__dict__.__contains__, ["__ior__"],  false]
    - ["hl2791-hash-ixor", hashlib.HASH.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 2: hashlib.blake2b.__dict__ — __iand__, __ior__, __ixor__ absence
# blake2b is the C type for BLAKE2b hash objects.
# Like HASH, it defines no in-place bitwise operators.
# ---------------------------------------------------------------------------

table hashlib_extra2791.blake2b_dict_iand_ior_ixor:
  description: "hashlib.blake2b.__dict__ does not contain __iand__, __ior__, or __ixor__ — the BLAKE2b hash type defines no in-place bitwise operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2791

  columns: [id, function, args, expected]
  rows:
    - ["hl2791-b2b-iand", hashlib.blake2b.__dict__.__contains__, ["__iand__"], false]
    - ["hl2791-b2b-ior",  hashlib.blake2b.__dict__.__contains__, ["__ior__"],  false]
    - ["hl2791-b2b-ixor", hashlib.blake2b.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 3: hashlib.blake2s.__dict__ — __iand__, __ior__, __ixor__ absence
# blake2s is the C type for BLAKE2s hash objects.
# Like HASH and blake2b, it defines no in-place bitwise operators.
# ---------------------------------------------------------------------------

table hashlib_extra2791.blake2s_dict_iand_ior_ixor:
  description: "hashlib.blake2s.__dict__ does not contain __iand__, __ior__, or __ixor__ — the BLAKE2s hash type defines no in-place bitwise operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2791

  columns: [id, function, args, expected]
  rows:
    - ["hl2791-b2s-iand", hashlib.blake2s.__dict__.__contains__, ["__iand__"], false]
    - ["hl2791-b2s-ior",  hashlib.blake2s.__dict__.__contains__, ["__ior__"],  false]
    - ["hl2791-b2s-ixor", hashlib.blake2s.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — all three hash types absent for all three dunders
# Consolidates one row per (type, dunder) pair for easy cross-type comparison.
# ---------------------------------------------------------------------------

table hashlib_extra2791.all_types_all_dunders_absent:
  description: "HASH, blake2b, and blake2s all lack __iand__, __ior__, and __ixor__ in __dict__ — no hashlib hash type defines these in-place bitwise operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2791

  columns: [id, function, args, expected]
  rows:
    - ["hl2791-x-hash-iand", hashlib.HASH.__dict__.__contains__,    ["__iand__"], false]
    - ["hl2791-x-hash-ior",  hashlib.HASH.__dict__.__contains__,    ["__ior__"],  false]
    - ["hl2791-x-hash-ixor", hashlib.HASH.__dict__.__contains__,    ["__ixor__"], false]
    - ["hl2791-x-b2b-iand",  hashlib.blake2b.__dict__.__contains__, ["__iand__"], false]
    - ["hl2791-x-b2b-ior",   hashlib.blake2b.__dict__.__contains__, ["__ior__"],  false]
    - ["hl2791-x-b2b-ixor",  hashlib.blake2b.__dict__.__contains__, ["__ixor__"], false]
    - ["hl2791-x-b2s-iand",  hashlib.blake2s.__dict__.__contains__, ["__iand__"], false]
    - ["hl2791-x-b2s-ior",   hashlib.blake2s.__dict__.__contains__, ["__ior__"],  false]
    - ["hl2791-x-b2s-ixor",  hashlib.blake2s.__dict__.__contains__, ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra2791.hash_no_iand:
  description: "hashlib.HASH.__dict__.__contains__('__iand__') == False — HASH (OpenSSL-backed C type) does not define in-place bitwise AND; hash objects are cryptographic primitives, not integer operands; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__iand__"]
  expected: false

invariant hashlib_extra2791.hash_no_ior:
  description: "hashlib.HASH.__dict__.__contains__('__ior__') == False — HASH does not define in-place bitwise OR; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__ior__"]
  expected: false

invariant hashlib_extra2791.hash_no_ixor:
  description: "hashlib.HASH.__dict__.__contains__('__ixor__') == False — HASH does not define in-place bitwise XOR; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
