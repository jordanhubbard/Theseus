spec: socket_extra2101
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Wave extra2101 (socket_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks."
    - "socket.socket is a pure-Python class wrapping the _socket C extension type; its __dict__ contains accept, bind, close, connect, etc. — no protocol dunders."
    - "socket.error is an alias for OSError; its own __dict__ contains only __module__, __weakref__, __doc__."
    - "socket.timeout is an alias for TimeoutError (subclass of OSError); its own __dict__ is similarly minimal."
    - "socket.gaierror is a subclass of OSError; its own __dict__ is minimal."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; their MROs pass through IntEnum -> int -> ReprEnum -> Enum -> object."
    - "None of the six socket classes tested define __class_getitem__ in their own __dict__ — generic alias subscripting is unsupported."
    - "None define __init_subclass__ in their own __dict__ — hook is inherited via the normal MRO."
    - "None define __subclasshook__ in their own __dict__ — ABC virtual subclass customization is absent."
    - "None define __mro_entries__ in their own __dict__ — MRO resolution protocol is not present."
    - "All expected values verified by running Python 3.14.4 socket module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2101.class_getitem_protocol:
  description: "socket classes __class_getitem__ dict-presence checks — generic alias protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2101

  columns: [id, function, args, expected]
  rows:
    - ["sk2101001", "socket.socket.__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk2101002", "socket.error.__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk2101003", "socket.timeout.__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk2101004", "socket.gaierror.__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk2101005", "socket.AddressFamily.__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk2101006", "socket.SocketKind.__dict__.__contains__", ["__class_getitem__"], false]
    - ["sk2101007", "socket.socket.__dict__.__contains__", ["__class_getitem__"], false]

