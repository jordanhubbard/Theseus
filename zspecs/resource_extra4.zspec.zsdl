spec: resource_extra4
version: ">=3.9"
backend: python_module(resource)

docs: https://docs.python.org/3/library/resource.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/resource.html — Python resource module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, setrlimit/getrlimit and getrusage"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/resource.c"
  notes:
    - "This spec extends resource.zspec.zsdl through resource_extra3.zspec.zsdl with new, non-duplicate invariants."
    - "resource.zspec.zsdl covers: function __name__; RLIMIT_CPU/FSIZE/NOFILE/AS/RLIM_INFINITY type; RUSAGE_SELF/CHILDREN type; getpagesize behavior."
    - "resource_extra2 covers: struct_rusage __name__/__module__/is_type/bases tuple; RLIMIT_STACK/DATA type; rlimit type table; RUSAGE_SELF==0; RUSAGE_CHILDREN==-1; function __qualname__/type."
    - "resource_extra3 covers: module __name__; function __module__; RLIMIT_CPU/FSIZE/DATA/STACK exact values; RLIMIT_NOFILE value; RLIMIT_CORE/MEMLOCK/NPROC type+value; RLIM_INFINITY exact value; ordering invariants."
    - "New here: struct_rusage __qualname__, n_sequence_fields/n_fields/n_unnamed_fields, __bases__.__len__, MRO, __doc__ type, selected __match_args__ field names, getpagesize() alignment."
    - "resource is a POSIX-only module; not available on Windows."
    - "struct_rusage.n_sequence_fields == 16 and n_fields == 16 — sixteen rusage fields."
    - "struct_rusage.n_unnamed_fields == 0 — all 16 fields are named."
    - "struct_rusage.__mro__ == [struct_rusage, tuple, object] — length 3."
    - "struct_rusage.__bases__.__len__() == 1 — single-inheritance from tuple."
    - "struct_rusage.__doc__ is a str — C struct-sequence types expose a class docstring."
    - "getpagesize() % 4096 == 0 on any supported platform (page size is always a multiple of 4096)."
    - "struct_rusage.__match_args__[0] == 'ru_utime' and [1] == 'ru_stime' — first two rusage fields."
    - "struct_rusage.__match_args__[14] == 'ru_nvcsw' and [15] == 'ru_nivcsw' — last two fields."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct_rusage.__qualname__ — not covered in any prior resource spec
# For C struct-sequence types at module scope, __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant resource_extra4.struct_rusage.qualname:
  description: "resource.struct_rusage.__qualname__ == 'struct_rusage' — top-level class, not nested"
  category: class_identity
  kind: python_call_eq
  function: struct_rusage.__qualname__.__eq__
  args: ["struct_rusage"]
  expected: true

# ---------------------------------------------------------------------------
# struct_rusage field counts
# resource_extra2 covers __name__/__module__/is_type/bases tuple but not the
# n_sequence_fields, n_fields, or n_unnamed_fields attributes.
# ---------------------------------------------------------------------------

invariant resource_extra4.struct_rusage.n_sequence_fields:
  description: "resource.struct_rusage.n_sequence_fields == 16 — sixteen positional rusage fields"
  category: struct
  kind: python_call_eq
  function: struct_rusage.n_sequence_fields.__eq__
  args: [16]
  expected: true

invariant resource_extra4.struct_rusage.n_fields:
  description: "resource.struct_rusage.n_fields == 16 — total field count matches n_sequence_fields"
  category: struct
  kind: python_call_eq
  function: struct_rusage.n_fields.__eq__
  args: [16]
  expected: true

invariant resource_extra4.struct_rusage.n_unnamed_fields:
  description: "resource.struct_rusage.n_unnamed_fields == 0 — no anonymous tail fields"
  category: struct
  kind: python_call_eq
  function: struct_rusage.n_unnamed_fields.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# struct_rusage.__bases__.__len__ == 1 — single inheritance
# resource_extra2 checks __bases__[0].__name__=='tuple' but not the count.
# ---------------------------------------------------------------------------

invariant resource_extra4.struct_rusage.bases_len:
  description: "len(resource.struct_rusage.__bases__) == 1 — single-inheritance from tuple"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_rusage.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# struct_rusage.__mro__ — method resolution order
# resource_extra2 checks bases tuple; MRO positions are new here.
# MRO: [struct_rusage, tuple, object] — length 3.
# ---------------------------------------------------------------------------

invariant resource_extra4.struct_rusage.mro_len:
  description: "len(resource.struct_rusage.__mro__) == 3 — MRO is [struct_rusage, tuple, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_rusage.__mro__.__len__
  args: []
  expected: 3

invariant resource_extra4.struct_rusage.mro_0_is_self:
  description: "resource.struct_rusage.__mro__[0].__name__ == 'struct_rusage' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_rusage.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "struct_rusage"

invariant resource_extra4.struct_rusage.mro_1_is_tuple:
  description: "resource.struct_rusage.__mro__[1].__name__ == 'tuple' — MRO position 1 is tuple"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_rusage.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "tuple"

# ---------------------------------------------------------------------------
# struct_rusage.__doc__ type check
# C struct-sequence types expose a class docstring (type == 'str').
# Not covered in any prior resource spec.
# ---------------------------------------------------------------------------

invariant resource_extra4.struct_rusage.doc_type:
  description: "resource.struct_rusage.__doc__.__class__.__name__ == 'str' — struct_rusage has a class docstring"
  category: class_identity
  kind: python_call_eq
  function: struct_rusage.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct_rusage.__match_args__ — selected field names
# The 16 rusage fields are: ru_utime, ru_stime, ru_maxrss, ru_ixrss, ru_idrss,
# ru_isrss, ru_minflt, ru_majflt, ru_nswap, ru_inblock, ru_oublock, ru_msgsnd,
# ru_msgrcv, ru_nsignals, ru_nvcsw, ru_nivcsw.
# Not covered in any prior resource spec.
# ---------------------------------------------------------------------------

table resource_extra4.struct_rusage.match_args:
  kind: python_call_eq
  category: match_args
  id_prefix: rusage

  columns: [id, function, args, expected]
  rows:
    - [ru_utime,  struct_rusage.__match_args__.__getitem__, [0],  "ru_utime"]
    - [ru_stime,  struct_rusage.__match_args__.__getitem__, [1],  "ru_stime"]
    - [ru_maxrss, struct_rusage.__match_args__.__getitem__, [2],  "ru_maxrss"]
    - [ru_nvcsw,  struct_rusage.__match_args__.__getitem__, [14], "ru_nvcsw"]
    - [ru_nivcsw, struct_rusage.__match_args__.__getitem__, [15], "ru_nivcsw"]

# ---------------------------------------------------------------------------
# getpagesize() — page size is a multiple of 4096
# resource.zspec.zsdl checks getpagesize() >= 4096. New here: divisibility
# by 4096 (true on all POSIX platforms regardless of actual page size).
# ---------------------------------------------------------------------------

invariant resource_extra4.getpagesize.aligned_4096:
  description: "resource.getpagesize() % 4096 == 0 — page size is always a multiple of 4096"
  category: behavior
  kind: python_call_eq
  function: getpagesize
  args: []
  method: __mod__
  method_args: [4096]
  expected: 0
