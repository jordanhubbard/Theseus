spec: re_extra88
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra87."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error/__name__; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ values and lengths; PatternError hierarchy; re.compile/__qualname__/__module__; re.match/sub/findall/split __qualname__; Match.start/end class name and qualname; re module function __module__ values; Pattern/Match method __doc__.__class__.__name__; Match method __qualname__ values and lengths; re module function __code__ attributes; Pattern/Match identity (__name__/__module__/__bases__/__mro__); Pattern/Match __dict__.__class__.__name__; Pattern/Match __qualname__ and length; PatternError __name__ and __module__; Pattern/Match method __qualname__ string equality; PatternError/__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(); re.error alias; re.IGNORECASE/MULTILINE/DOTALL/__class__.__name__; re.RegexFlag/__name__/__module__; re.compile __qualname__/__module__/__qualname__.__len__(); re.IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE values and class names; re.RegexFlag.__bases__[0].__name__; re.RegexFlag.__mro__.__len__(); re.NOFLAG value; Pattern/Match method __doc__.__len__() for match/search/findall/finditer/sub/subn/split/fullmatch/group/groups/start/end/span."
    - "This spec covers: re.Pattern.__dict__.__contains__ for 'match', 'search', 'findall', 'finditer', 'sub', 'subn', 'split', 'fullmatch', 'flags', 'pattern' (all True); re.Match.__dict__.__contains__ for 'group', 'groups', 'start', 'end' (all True)."
    - "re.Pattern.__dict__.__contains__('match') == True — Pattern defines match at C level."
    - "re.Pattern.__dict__.__contains__('search') == True — Pattern defines search at C level."
    - "re.Pattern.__dict__.__contains__('findall') == True — Pattern defines findall at C level."
    - "re.Pattern.__dict__.__contains__('finditer') == True — Pattern defines finditer at C level."
    - "re.Pattern.__dict__.__contains__('sub') == True — Pattern defines sub at C level."
    - "re.Pattern.__dict__.__contains__('subn') == True — Pattern defines subn at C level."
    - "re.Pattern.__dict__.__contains__('split') == True — Pattern defines split at C level."
    - "re.Pattern.__dict__.__contains__('fullmatch') == True — Pattern defines fullmatch at C level."
    - "re.Pattern.__dict__.__contains__('flags') == True — 'flags' is a property/descriptor in Pattern.__dict__."
    - "re.Pattern.__dict__.__contains__('pattern') == True — 'pattern' is a property/descriptor in Pattern.__dict__."
    - "re.Match.__dict__.__contains__('group') == True — Match defines group at C level."
    - "re.Match.__dict__.__contains__('groups') == True — Match defines groups at C level."
    - "re.Match.__dict__.__contains__('start') == True — Match defines start at C level."
    - "re.Match.__dict__.__contains__('end') == True — Match defines end at C level."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern.__dict__.__contains__ for match, search, findall, finditer
# These methods are defined on Pattern at the C level (_sre.SRE_Pattern).
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra88.Pattern_dict_match_search_findall_finditer:
  description: "re.Pattern.__dict__.__contains__ for 'match', 'search', 'findall', 'finditer' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: reextra88

  columns: [id, function, args, expected]
  rows:
    - [pat_match,    Pattern.__dict__.__contains__, ["match"],    true]
    - [pat_search,   Pattern.__dict__.__contains__, ["search"],   true]
    - [pat_findall,  Pattern.__dict__.__contains__, ["findall"],  true]
    - [pat_finditer, Pattern.__dict__.__contains__, ["finditer"], true]

# ---------------------------------------------------------------------------
# re.Pattern.__dict__.__contains__ for sub, subn, split, fullmatch
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra88.Pattern_dict_sub_subn_split_fullmatch:
  description: "re.Pattern.__dict__.__contains__ for 'sub', 'subn', 'split', 'fullmatch' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: reextra88

  columns: [id, function, args, expected]
  rows:
    - [pat_sub,       Pattern.__dict__.__contains__, ["sub"],       true]
    - [pat_subn,      Pattern.__dict__.__contains__, ["subn"],      true]
    - [pat_split,     Pattern.__dict__.__contains__, ["split"],     true]
    - [pat_fullmatch, Pattern.__dict__.__contains__, ["fullmatch"], true]

# ---------------------------------------------------------------------------
# re.Pattern.__dict__.__contains__ for 'flags' and 'pattern'
# Both are read-only properties/descriptors that appear in Pattern.__dict__.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra88.Pattern_dict_flags_pattern:
  description: "re.Pattern.__dict__.__contains__ for 'flags', 'pattern' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: reextra88

  columns: [id, function, args, expected]
  rows:
    - [pat_flags,   Pattern.__dict__.__contains__, ["flags"],   true]
    - [pat_pattern, Pattern.__dict__.__contains__, ["pattern"], true]

# ---------------------------------------------------------------------------
# re.Match.__dict__.__contains__ for group, groups, start, end
# These methods are defined on Match at the C level.
# Not covered in any prior re spec at this specific table.
# ---------------------------------------------------------------------------

table re_extra88.Match_dict_group_groups_start_end:
  description: "re.Match.__dict__.__contains__ for 'group', 'groups', 'start', 'end' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: reextra88

  columns: [id, function, args, expected]
  rows:
    - [match_group,  Match.__dict__.__contains__, ["group"],  true]
    - [match_groups, Match.__dict__.__contains__, ["groups"], true]
    - [match_start,  Match.__dict__.__contains__, ["start"],  true]
    - [match_end,    Match.__dict__.__contains__, ["end"],    true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra88.Pattern_dict.contains_match:
  description: "re.Pattern.__dict__.__contains__('match') == True (Pattern defines match at C level)"
  category: dict_membership
  kind: python_call_eq
  function: Pattern.__dict__.__contains__
  args: ["match"]
  expected: true

invariant re_extra88.Pattern_dict.contains_search:
  description: "re.Pattern.__dict__.__contains__('search') == True (Pattern defines search at C level)"
  category: dict_membership
  kind: python_call_eq
  function: Pattern.__dict__.__contains__
  args: ["search"]
  expected: true

invariant re_extra88.Pattern_dict.contains_sub:
  description: "re.Pattern.__dict__.__contains__('sub') == True (Pattern defines sub at C level)"
  category: dict_membership
  kind: python_call_eq
  function: Pattern.__dict__.__contains__
  args: ["sub"]
  expected: true

invariant re_extra88.Pattern_dict.contains_flags:
  description: "re.Pattern.__dict__.__contains__('flags') == True ('flags' is a property/descriptor in Pattern.__dict__)"
  category: dict_membership
  kind: python_call_eq
  function: Pattern.__dict__.__contains__
  args: ["flags"]
  expected: true

invariant re_extra88.Match_dict.contains_group:
  description: "re.Match.__dict__.__contains__('group') == True (Match defines group at C level)"
  category: dict_membership
  kind: python_call_eq
  function: Match.__dict__.__contains__
  args: ["group"]
  expected: true
