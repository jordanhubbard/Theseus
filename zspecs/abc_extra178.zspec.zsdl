spec: abc_extra178
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc module-level function identity — abstractmethod.__name__=='abstractmethod'(len=14); abstractmethod.__module__=='abc'; abstractmethod.__qualname__=='abstractmethod'; abstractmethod.__class__.__name__=='function'; ABCMeta.register.__name__=='register'(len=8); ABC.__abstractmethods__.__class__.__name__=='frozenset' (ABC has no abstract methods, empty frozenset); abstractmethod.__code__.co_argcount.__eq__(1)==True (abstractmethod takes exactly one argument: funcobj)."
    - "abc.abstractmethod.__class__.__name__ == 'function'. abstractmethod is a plain function (not a class, not a descriptor), defined as def abstractmethod(funcobj): ... in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.register.__name__ == 'register'. ABCMeta.register is a method that registers a class as a virtual subclass; its __name__ is 'register' (8 chars). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset'. ABC defines no abstract methods, so __abstractmethods__ is an empty frozenset(). Note: abc.ABCMeta.__abstractmethods__ raises AttributeError in Python 3.14 — use abc.ABC.__abstractmethods__ instead. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__code__.co_argcount == 1. abstractmethod is defined as def abstractmethod(funcobj): — it takes exactly one positional argument (the function being decorated). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.abstractmethod function identity — __name__, __module__, __qualname__
#
# abc.abstractmethod.__name__ == 'abstractmethod' (len=14)
# abc.abstractmethod.__module__ == 'abc'
# abc.abstractmethod.__qualname__ == 'abstractmethod'
# abc.abstractmethod.__class__.__name__ == 'function'
#
# abstractmethod is a plain decorator function defined in abc.py.
# ---------------------------------------------------------------------------

table abc_extra178.abstractmethod_func_identity:
  description: "abc.abstractmethod function identity: __name__=='abstractmethod'(len=14), __module__=='abc', __qualname__=='abstractmethod', __class__.__name__=='function'; new to abc_extra178"
  kind: python_call_eq
  category: identity
  id_prefix: abcfuncs178

  columns: [id, function, args, expected, description]
  rows:
    - [am_name_eq,
       abstractmethod.__name__.__eq__,
       ["abstractmethod"],
       true,
       "abc.abstractmethod.__name__.__eq__('abstractmethod') == True — abstractmethod is the decorator marking a method as abstract; __name__ is 'abstractmethod' (14 chars); str.__eq__('abstractmethod') returns True; new to abc_extra178"]
    - [am_name_len_14,
       abstractmethod.__name__.__len__,
       [],
       14,
       "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 characters: a-b-s-t-r-a-c-t-m-e-t-h-o-d; NAME LENGTHS: register=8 < abstractmethod=14; str.__len__() returns 14; new to abc_extra178"]
    - [am_module_eq,
       abstractmethod.__module__.__eq__,
       ["abc"],
       true,
       "abc.abstractmethod.__module__.__eq__('abc') == True — abstractmethod is defined in the abc module; __module__ is 'abc'; str.__eq__('abc') returns True; new to abc_extra178"]
    - [am_qualname_eq,
       abstractmethod.__qualname__.__eq__,
       ["abstractmethod"],
       true,
       "abc.abstractmethod.__qualname__.__eq__('abstractmethod') == True — abstractmethod is a top-level function so __qualname__ equals __name__; str.__eq__('abstractmethod') returns True; new to abc_extra178"]
    - [am_class_name_eq,
       "abstractmethod.__class__.__name__.__eq__",
       ["function"],
       true,
       "abc.abstractmethod.__class__.__name__.__eq__('function') == True — abstractmethod is a plain Python function defined as def abstractmethod(funcobj): ...; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to abc_extra178"]

# ---------------------------------------------------------------------------
