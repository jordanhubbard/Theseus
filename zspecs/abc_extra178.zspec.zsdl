       "abc.ABCMeta.register.__module__.__len__() == 3 — 'abc' has 3 characters: a-b-c; same as abstractmethod.__module__; str.__len__() returns 3; new to abc_extra178"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABC.__abstractmethods__ and abstractmethod co_argcount
#
# abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset'
# abc.abstractmethod.__code__.co_argcount == 1
#
# ABC has no abstract methods so __abstractmethods__ is empty frozenset().
# abstractmethod takes exactly one argument (funcobj).
# Note: abc.ABCMeta.__abstractmethods__ raises AttributeError in Python 3.14.
# ---------------------------------------------------------------------------

table abc_extra178.abstract_methods_and_argcount:
  description: "abc.ABC.__abstractmethods__.__class__.__name__=='frozenset'; abstractmethod.__code__.co_argcount==1; new to abc_extra178"
