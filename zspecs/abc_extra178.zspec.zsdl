       true,
       "abc.abstractmethod.__code__.co_argcount.__eq__(1) == True — abstractmethod is defined as def abstractmethod(funcobj): — it takes exactly one positional argument; int.__eq__(1) returns True; new to abc_extra178"]
    - [am_module_len_3,
       abstractmethod.__module__.__len__,
       [],
       3,
       "abc.abstractmethod.__module__.__len__() == 3 — 'abc' has 3 characters: a-b-c; str.__len__() returns 3; new to abc_extra178"]
    - [reg_qualname_len_16,
