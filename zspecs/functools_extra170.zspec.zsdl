spec: functools_extra170
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partial.__new__.__qualname__ 'partial.__new__'; functools.partial.__new__.__class__.__name__ 'builtin_function_or_method'; functools.partial.__call__.__qualname__ 'partial.__call__'; functools.partial.__call__.__class__.__name__ 'wrapper_descriptor'; functools.partial.__bases__[0].__name__ 'object' (Wave 294)."
    - "functools.partial.__new__.__qualname__ == 'partial.__new__' — functools.partial is a C extension type; its __new__ slot is exposed on the class as a builtin_function_or_method whose __qualname__ is 'partial.__new__'. Verified with Python 3.14.3."
    - "functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method' — partial.__new__ accessed on the partial class returns the C-level slot wrapper; its __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "functools.partial.__call__.__qualname__ == 'partial.__call__' — functools.partial is a callable C extension type; its __call__ slot is exposed as a wrapper_descriptor whose __qualname__ is 'partial.__call__'. Verified with Python 3.14.3."
    - "functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor' — partial.__call__ accessed on the class is a wrapper_descriptor (the slot wrapper for the C-level tp_call slot); its __class__.__name__ is 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — functools.partial is a C extension type that inherits directly from object; its single base class __name__ is 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial.__new__ qualname and class identity
#
# Wave 294 theme: functools.partial C extension type — the __new__ and __call__
# slot descriptors: their qualnames and __class__ names.
#
# functools.partial.__new__.__qualname__ == 'partial.__new__'
# functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method'
# functools.partial.__call__.__qualname__ == 'partial.__call__'
# functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor'
#
# functools.partial is a C extension type defined in Modules/_functoolsmodule.c.
# Accessing partial.__new__ on the class returns a builtin_function_or_method
# whose __qualname__ is 'partial.__new__'. Accessing partial.__call__ on the
# class returns a wrapper_descriptor (the slot wrapper for the C-level tp_call
# slot) whose __qualname__ is 'partial.__call__'. Both are distinct C-level
# descriptor types. New to extra170.
# ---------------------------------------------------------------------------

table functools_extra170.partial_new_and_call_slot_identity:
  description: "functools.partial: __new__.__qualname__ 'partial.__new__', __new__.__class__.__name__ 'builtin_function_or_method', __call__.__qualname__ 'partial.__call__', __call__.__class__.__name__ 'wrapper_descriptor'; wave 294; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspncsi170

  columns: [id, function, args, expected, description]
  rows:
    - [partial_new_qn,
       "partial.__new__.__qualname__.__eq__",
       ["partial.__new__"],
       true,
       "functools.partial.__new__.__qualname__.__eq__('partial.__new__') == True — partial.__new__ is the C-level tp_new slot exposed on the partial class as a builtin_function_or_method; its __qualname__ is 'partial.__new__'; str.__eq__('partial.__new__') returns True; new to extra170"]
    - [partial_new_cls_name,
       "partial.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partial.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — accessing partial.__new__ on the partial class returns a C builtin_function_or_method (the tp_new slot wrapper); its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra170"]
    - [partial_call_qn,
       "partial.__call__.__qualname__.__eq__",
       ["partial.__call__"],
       true,
       "functools.partial.__call__.__qualname__.__eq__('partial.__call__') == True — partial.__call__ is the C-level tp_call slot exposed on the partial class as a wrapper_descriptor; its __qualname__ is 'partial.__call__'; str.__eq__('partial.__call__') returns True; new to extra170"]
    - [partial_call_cls_name,
       "partial.__call__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools.partial.__call__.__class__.__name__.__eq__('wrapper_descriptor') == True — accessing partial.__call__ on the partial class returns a wrapper_descriptor (the slot wrapper for the C-level tp_call); its __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra170"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial.__bases__ and slot qualname cross-checks
#
# Wave 294 theme: functools.partial C extension type — base class and additional
# qualname/class cross-checks.
#
# functools.partial.__bases__[0].__name__ == 'object'
# functools.partial.__new__.__qualname__ == 'partial.__new__' (cross-check)
# functools.partial.__call__.__qualname__ == 'partial.__call__' (cross-check)
# functools.partial.__new__.__class__.__name__ != 'wrapper_descriptor'
#
# functools.partial inherits directly from object; its __bases__ tuple has
# one element whose __name__ is 'object'. The __new__ slot class is
# 'builtin_function_or_method', not 'wrapper_descriptor' (which is what __call__
# uses); these two are distinct C-level slot descriptor types. New to extra170.
# ---------------------------------------------------------------------------

table functools_extra170.partial_bases_and_slot_cross_checks:
  description: "functools.partial: __bases__[0].__name__ 'object'; __new__ class != 'wrapper_descriptor'; __call__ class != 'builtin_function_or_method'; wave 294; new to extra170"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspbscc170

  columns: [id, function, args, expected, description]
  rows:
    - ["partial_bases_0_object",
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — functools.partial is a C extension type that inherits directly from object; its __bases__ tuple has exactly one element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra170"]
    - [partial_new_not_wrapper,
       "partial.__new__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       false,
       "functools.partial.__new__.__class__.__name__.__eq__('wrapper_descriptor') == False — partial.__new__ is a 'builtin_function_or_method', NOT a 'wrapper_descriptor'; the two are distinct C-level slot types: __new__ uses tp_new (builtin_function_or_method) while __call__ uses tp_call (wrapper_descriptor); str.__eq__('wrapper_descriptor') returns False; new to extra170"]
    - [partial_call_not_builtin,
       "partial.__call__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       false,
       "functools.partial.__call__.__class__.__name__.__eq__('builtin_function_or_method') == False — partial.__call__ is a 'wrapper_descriptor', NOT a 'builtin_function_or_method'; the tp_call slot is exposed as a wrapper_descriptor on the class, not a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns False; new to extra170"]
    - [partial_call_qn_ne_new_qn,
       "partial.__call__.__qualname__.__eq__",
       ["partial.__new__"],
       false,
       "functools.partial.__call__.__qualname__.__eq__('partial.__new__') == False — partial.__call__.__qualname__ is 'partial.__call__', not 'partial.__new__'; the two slots have distinct qualnames; str.__eq__('partial.__new__') returns False; new to extra170"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra170
# ---------------------------------------------------------------------------

invariant functools_extra170.partial_new_qualname:
  description: "functools.partial.__new__.__qualname__ == 'partial.__new__' — C tp_new slot exposed as builtin_function_or_method with qualname 'partial.__new__'; wave 294; new to extra170"
  kind: python_call_eq
  function: partial.__new__.__qualname__.__eq__
  args: ["partial.__new__"]
  expected: true

invariant functools_extra170.partial_new_class_builtin:
  description: "functools.partial.__new__.__class__.__name__ == 'builtin_function_or_method' — partial.__new__ is the C tp_new slot; its class is 'builtin_function_or_method'; wave 294; new to extra170"
  kind: python_call_eq
  function: partial.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra170.partial_call_qualname:
  description: "functools.partial.__call__.__qualname__ == 'partial.__call__' — C tp_call slot exposed as wrapper_descriptor with qualname 'partial.__call__'; wave 294; new to extra170"
  kind: python_call_eq
  function: partial.__call__.__qualname__.__eq__
  args: ["partial.__call__"]
  expected: true

invariant functools_extra170.partial_call_class_wrapper_descriptor:
  description: "functools.partial.__call__.__class__.__name__ == 'wrapper_descriptor' — partial.__call__ is the C tp_call slot; its class is 'wrapper_descriptor'; wave 294; new to extra170"
  kind: python_call_eq
  function: partial.__call__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant functools_extra170.partial_bases_0_object:
  description: "functools.partial.__bases__[0].__name__ == 'object' — partial C extension type inherits directly from object; wave 294; new to extra170"
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra170.partial_new_not_wrapper_descriptor:
  description: "functools.partial.__new__.__class__.__name__ != 'wrapper_descriptor' — __new__ is builtin_function_or_method, not wrapper_descriptor; wave 294; new to extra170"
  kind: python_call_eq
  function: partial.__new__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: false

invariant functools_extra170.partial_call_not_builtin_function:
  description: "functools.partial.__call__.__class__.__name__ != 'builtin_function_or_method' — __call__ is wrapper_descriptor, not builtin_function_or_method; wave 294; new to extra170"
  kind: python_call_eq
  function: partial.__call__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: false

invariant functools_extra170.partial_new_qualname_ne_call_qualname:
  description: "functools.partial.__call__.__qualname__ != 'partial.__new__' — __call__ qualname is 'partial.__call__', distinct from '__new__'; wave 294; new to extra170"
  kind: python_call_eq
  function: partial.__call__.__qualname__.__eq__
  args: ["partial.__new__"]
  expected: false

