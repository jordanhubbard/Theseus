spec: hashlib_extra1861
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
  notes:
    - "Wave 571: bitwise and in-place operators for hashlib module classes"
    - "hashlib hash objects do not define bitwise or in-place arithmetic operators in their own __dict__"
    - "hashlib module-level __dict__ does not contain operator dunder names"
  created_at: "2026-04-12"

table hashlib_extra1861.bitwise_operators:
  columns: [id, function, args, expected]
  rows:
    - ["hl1861-bit-001", "hashlib.sha256.__class__.__dict__.__contains__", ["__or__"], false]
    - ["hl1861-bit-002", "hashlib.sha256.__class__.__dict__.__contains__", ["__and__"], false]
    - ["hl1861-bit-003", "hashlib.sha256.__class__.__dict__.__contains__", ["__xor__"], false]
    - ["hl1861-bit-004", "hashlib.md5.__class__.__dict__.__contains__", ["__or__"], false]
    - ["hl1861-bit-005", "hashlib.__dict__.__contains__", ["__or__"], false]
    - ["hl1861-bit-006", "hashlib.__dict__.__contains__", ["__and__"], false]
    - ["hl1861-bit-007", "hashlib.__dict__.__contains__", ["__xor__"], false]
    - ["hl1861-bit-008", "hashlib.__dict__.__contains__", ["__invert__"], false]

table hashlib_extra1861.inplace_operators:
  columns: [id, function, args, expected]
  rows:
    - ["hl1861-iop-001", "hashlib.sha256.__class__.__dict__.__contains__", ["__iadd__"], false]
    - ["hl1861-iop-002", "hashlib.sha256.__class__.__dict__.__contains__", ["__ior__"], false]
    - ["hl1861-iop-003", "hashlib.md5.__class__.__dict__.__contains__", ["__iadd__"], false]
    - ["hl1861-iop-004", "hashlib.__dict__.__contains__", ["__iadd__"], false]
    - ["hl1861-iop-005", "hashlib.__dict__.__contains__", ["__ior__"], false]
    - ["hl1861-iop-006", "hashlib.__dict__.__contains__", ["__imul__"], false]
    - ["hl1861-iop-007", "hashlib.__dict__.__contains__", ["__isub__"], false]
    - ["hl1861-iop-008", "hashlib.__dict__.__contains__", ["__iand__"], false]

table hashlib_extra1861.hashlib_hash_constructors:
  columns: [id, function, args, expected]
  rows:
    - ["hl1861-con-001", "hashlib.__dict__.__contains__", ["sha256"], true]
    - ["hl1861-con-002", "hashlib.__dict__.__contains__", ["sha224"], true]
    - ["hl1861-con-003", "hashlib.__dict__.__contains__", ["sha384"], true]
    - ["hl1861-con-004", "hashlib.__dict__.__contains__", ["sha512"], true]
    - ["hl1861-con-005", "hashlib.__dict__.__contains__", ["sha1"], true]
    - ["hl1861-con-006", "hashlib.__dict__.__contains__", ["md5"], true]
    - ["hl1861-con-007", "hashlib.__dict__.__contains__", ["sha3_224"], true]
    - ["hl1861-con-008", "hashlib.__dict__.__contains__", ["sha3_256"], true]
    - ["hl1861-con-009", "hashlib.__dict__.__contains__", ["sha3_384"], true]
    - ["hl1861-con-010", "hashlib.__dict__.__contains__", ["sha3_512"], true]
