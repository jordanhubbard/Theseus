    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.socket/__doc__/__class__/__name__, socket.gethostname/getaddrinfo/getfqdn/setdefaulttimeout/getdefaulttimeout __doc__.__class__.__name__, socket.AF_INET/SOCK_STREAM __doc__ class attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1126.socket_class_doc_class_names:
  description: "socket.socket __doc__.__class__.__name__ and gethostname/getaddrinfo doc class name identity"
  kind: python_call_eq
  category: socket_class_doc_classnames
  id_prefix: sk1126sd
  columns: [id, function, args, expected]
  rows:
    - [sk1126sd001, socket.socket.__doc__.__class__.__name__.__eq__,              ["str"],      true]
    - [sk1126sd002, socket.gethostname.__doc__.__class__.__name__.__eq__,         ["str"],      true]
    - [sk1126sd003, socket.getaddrinfo.__doc__.__class__.__name__.__eq__,         ["str"],      true]
    - [sk1126sd004, socket.socket.__doc__.__class__.__qualname__.__eq__,          ["str"],      true]
    - [sk1126sd005, socket.gethostname.__doc__.__class__.__qualname__.__eq__,     ["str"],      true]
    - [sk1126sd006, socket.getaddrinfo.__doc__.__class__.__qualname__.__eq__,     ["str"],      true]
    - [sk1126sd007, socket.socket.__doc__.__class__.__module__.__eq__,            ["builtins"], true]
    - [sk1126sd008, socket.gethostname.__doc__.__class__.__module__.__eq__,       ["builtins"], true]
    - [sk1126sd009, socket.getaddrinfo.__doc__.__class__.__module__.__eq__,       ["builtins"], true]
    - [sk1126sd010, socket.getfqdn.__doc__.__class__.__name__.__eq__,             ["str"],      true]

