spec: asyncio_extra2656
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier __dict__ for __contains__, __add__, __mul__ presence (all false)"]
  created_at: "2026-04-13"
error_model: python_exceptions

table asyncio_extra2656.queue_task_future_dict_presence:
  description: "asyncio.Queue, asyncio.Task, asyncio.Future __dict__ does not contain __contains__, __add__, __mul__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2656qtf
  columns: [id, function, args, expected]
  rows:
    - ["as2656qtf001", asyncio.Queue.__dict__.__contains__, ["__contains__"], false]
    - ["as2656qtf002", asyncio.Queue.__dict__.__contains__, ["__add__"], false]
    - ["as2656qtf003", asyncio.Queue.__dict__.__contains__, ["__mul__"], false]
    - ["as2656qtf004", asyncio.Task.__dict__.__contains__, ["__contains__"], false]
    - ["as2656qtf005", asyncio.Task.__dict__.__contains__, ["__add__"], false]
    - ["as2656qtf006", asyncio.Task.__dict__.__contains__, ["__mul__"], false]
    - ["as2656qtf007", asyncio.Future.__dict__.__contains__, ["__contains__"], false]
    - ["as2656qtf008", asyncio.Future.__dict__.__contains__, ["__add__"], false]
    - ["as2656qtf009", asyncio.Future.__dict__.__contains__, ["__mul__"], false]

