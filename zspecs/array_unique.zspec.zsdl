spec: array_unique
version: ">=0.3.2"
backend: node(array-unique)

docs: https://www.npmjs.com/package/array-unique

provenance:
  derived_from:
    - "array-unique README — https://www.npmjs.com/package/array-unique"
    - "Test vectors verified with array-unique via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "array-unique source"
  notes:
    - "array-unique is an npm package. Install: npm install array-unique"
    - "Returns a new array with duplicate values removed, preserving first-seen order."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_unique.unique:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: auniq

  columns: [id, args, expected]
  rows:
    - [nums,     [[1, 2, 1, 3, 2]],         [1, 2, 3]]
    - [strings,  [["a", "b", "a"]],          ["a", "b"]]
    - [no_dups,  [[1, 2, 3]],                [1, 2, 3]]
