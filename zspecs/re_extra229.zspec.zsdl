spec: re_extra229
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module additional behavioral contracts — re.match start/end/span, re.search start/end, re.sub, re.subn, re.split, re.findall return value contracts."
    - "re.match(r'hello', 'hello world').start() == 0 — match anchors at start; verified Python 3.14.3 macOS."
    - "re.match(r'hello', 'hello world').end() == 5 — match ends after 5 characters; verified Python 3.14.3 macOS."
    - "re.match(r'hello', 'hello world').span().__eq__((0, 5)) == True — span returns (start, end) tuple; verified Python 3.14.3 macOS."
    - "re.search(r'world', 'hello world').start() == 6 — 'world' starts at index 6; verified Python 3.14.3 macOS."
    - "re.search(r'world', 'hello world').end() == 11 — 'world' ends at index 11; verified Python 3.14.3 macOS."
    - "re.sub(r'a', 'X', 'banana').__eq__('bXnXnX') == True — replaces 3 occurrences of 'a'; verified Python 3.14.3 macOS."
    - "re.subn(r'a', 'X', 'banana')[0].__eq__('bXnXnX') == True — subn returns (new_string, count); [0] is the new string; verified Python 3.14.3 macOS."
    - "re.subn(r'a', 'X', 'banana')[1].__eq__(3) == True — [1] is the replacement count (3 'a's in 'banana'); verified Python 3.14.3 macOS."
    - "re.split(r'\\s+', 'hello world foo').__len__() == 3 — splits into ['hello', 'world', 'foo']; verified Python 3.14.3 macOS."
    - "re.findall(r'[aeiou]', 'hello world').__len__() == 3 — finds 'e', 'o', 'o' (3 vowels); verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.match behavioral contracts
# match(r'hello', 'hello world') matches at position 0, ends at position 5.
# span() returns the (start, end) tuple (0, 5).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra229.match.start_eq_0:
  description: "re.match(r'hello', 'hello world').start() == 0 — match is anchored at the start of the string so start() is always 0; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: match
  args: ["hello", "hello world"]
  method: start
  expected: 0

invariant re_extra229.match.end_eq_5:
  description: "re.match(r'hello', 'hello world').end() == 5 — pattern 'hello' has 5 characters so end() is 5; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: match
  args: ["hello", "hello world"]
  method: end
  expected: 5

invariant re_extra229.match.span_eq_0_5:
  description: "re.match(r'hello', 'hello world').span().__eq__((0, 5)) == True — span() returns the (start, end) tuple; match at start=0, end=5; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: match
  args: ["hello", "hello world"]
  method: span().__eq__
  method_args: [[0, 5]]
  expected: true

# ---------------------------------------------------------------------------
# re.search behavioral contracts
# search(r'world', 'hello world') finds 'world' starting at index 6.
# 'hello world': h=0,e=1,l=2,l=3,o=4,' '=5,w=6,o=7,r=8,l=9,d=10 -> end=11.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra229.search.start_eq_6:
  description: "re.search(r'world', 'hello world').start() == 6 — 'world' begins at index 6 in 'hello world'; search scans the entire string unlike match; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: search
  args: ["world", "hello world"]
  method: start
  expected: 6

invariant re_extra229.search.end_eq_11:
  description: "re.search(r'world', 'hello world').end() == 11 — 'world' (5 chars) ends at index 11 in 'hello world' (11 chars total); verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: search
  args: ["world", "hello world"]
  method: end
  expected: 11

# ---------------------------------------------------------------------------
# re.sub behavioral contracts
# sub(r'a', 'X', 'banana') replaces all 3 occurrences of 'a' with 'X'.
# Result: 'bXnXnX'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra229.sub.banana_result_eq:
  description: "re.sub(r'a', 'X', 'banana').__eq__('bXnXnX') == True — sub replaces all 3 'a' occurrences in 'banana' with 'X' giving 'bXnXnX'; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: sub
  args: ["a", "X", "banana"]
  method: __eq__
  method_args: ["bXnXnX"]
  expected: true

# ---------------------------------------------------------------------------
# re.subn behavioral contracts
# subn(r'a', 'X', 'banana') returns ('bXnXnX', 3).
# [0] is the modified string; [1] is the substitution count.
# Values containing '[' must be double-quoted in ZSDL.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra229.subn.banana_string_eq:
  description: "re.subn(r'a', 'X', 'banana')[0].__eq__('bXnXnX') == True — subn returns a tuple; [0] is the modified string with all 'a' replaced by 'X'; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: subn
  args: ["a", "X", "banana"]
  method: "[0].__eq__"
  method_args: ["bXnXnX"]
  expected: true

invariant re_extra229.subn.banana_count_eq:
  description: "re.subn(r'a', 'X', 'banana')[1].__eq__(3) == True — subn returns a tuple; [1] is the count of substitutions made (3 'a' chars in 'banana'); verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: subn
  args: ["a", "X", "banana"]
  method: "[1].__eq__"
  method_args: [3]
  expected: true

# ---------------------------------------------------------------------------
# re.split behavioral contracts
# split(r'\s+', 'hello world foo') splits on whitespace into 3 tokens.
# Result: ['hello', 'world', 'foo'] — length 3.
# Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra229.split.whitespace_len_3:
  description: "re.split(r'\\s+', 'hello world foo').__len__() == 3 — splitting 'hello world foo' on \\s+ gives ['hello', 'world', 'foo'] (3 elements); verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: split
  args: ["\\s+", "hello world foo"]
  method: __len__
  expected: 3

# ---------------------------------------------------------------------------
# re.findall behavioral contracts
# findall(r'[aeiou]', 'hello world') finds vowels: 'e', 'o', 'o' = 3 matches.
# Values containing '[' must be double-quoted in ZSDL.
# Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra229.findall.vowels_len_3:
  description: "re.findall(r'[aeiou]', 'hello world').__len__() == 3 — 'hello world' contains 3 vowels: 'e' in 'hello', 'o' in 'hello', 'o' in 'world'; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: findall
  args: ["[aeiou]", "hello world"]
  method: __len__
  expected: 3
