spec: threading_extra2446
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave (_extra2446): __enter__/__exit__ context manager protocol dict-presence checks."
    - "threading.Lock (which is _thread.lock) defines __enter__ and __exit__ in its own __dict__ — it IS a context manager."
    - "threading.Condition defines __enter__ and __exit__ in its own __dict__ — it IS a context manager."
    - "threading.Semaphore defines __enter__ and __exit__ in its own __dict__ — it IS a context manager."
    - "threading.BoundedSemaphore does NOT define __enter__/__exit__ in its own __dict__ — it inherits them from Semaphore."
    - "threading.RLock is a factory function, not a class; the actual class is _thread.RLock which defines __enter__/__exit__. threading.RLock.__dict__ is not accessible directly via threading namespace, so we test via threading.Lock (the C type it returns)."
    - "threading.Barrier does NOT define __enter__ or __exit__ — it is NOT a context manager."
    - "threading.Thread does NOT define __enter__ or __exit__ — it is NOT a context manager."
    - "threading.Event does NOT define __enter__ or __exit__ — it is NOT a context manager."
    - "threading.Timer does NOT define __enter__ or __exit__ — it is NOT a context manager."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table threading_extra2446.enter_protocol_cm:
  description: "threading synchronization types that DO define __enter__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2446
  columns: [id, function, args, expected]
  rows:
    - ["th2446001", "threading.Lock.__dict__.__contains__",      ["__enter__"], true]
    - ["th2446002", "threading.Condition.__dict__.__contains__", ["__enter__"], true]
    - ["th2446003", "threading.Semaphore.__dict__.__contains__", ["__enter__"], true]

table threading_extra2446.exit_protocol_cm:
  description: "threading synchronization types that DO define __exit__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2446
  columns: [id, function, args, expected]
  rows:
    - ["th2446004", "threading.Lock.__dict__.__contains__",      ["__exit__"], true]
    - ["th2446005", "threading.Condition.__dict__.__contains__", ["__exit__"], true]
    - ["th2446006", "threading.Semaphore.__dict__.__contains__", ["__exit__"], true]

table threading_extra2446.enter_protocol_non_cm:
  description: "threading types that do NOT define __enter__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2446
  columns: [id, function, args, expected]
  rows:
    - ["th2446007", "threading.BoundedSemaphore.__dict__.__contains__", ["__enter__"], false]
    - ["th2446008", "threading.Barrier.__dict__.__contains__",          ["__enter__"], false]
    - ["th2446009", "threading.Thread.__dict__.__contains__",           ["__enter__"], false]
    - ["th2446010", "threading.Event.__dict__.__contains__",            ["__enter__"], false]
    - ["th2446011", "threading.Timer.__dict__.__contains__",            ["__enter__"], false]

table threading_extra2446.exit_protocol_non_cm:
  description: "threading types that do NOT define __exit__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2446
  columns: [id, function, args, expected]
  rows:
    - ["th2446012", "threading.BoundedSemaphore.__dict__.__contains__", ["__exit__"], false]
    - ["th2446013", "threading.Barrier.__dict__.__contains__",          ["__exit__"], false]
    - ["th2446014", "threading.Thread.__dict__.__contains__",           ["__exit__"], false]
    - ["th2446015", "threading.Event.__dict__.__contains__",            ["__exit__"], false]
    - ["th2446016", "threading.Timer.__dict__.__contains__",            ["__exit__"], false]

table threading_extra2446.cm_own_attrs:
  description: "threading context manager types also define their own synchronization methods"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2446
  columns: [id, function, args, expected]
  rows:
    - ["th2446017", "threading.Lock.__dict__.__contains__",      ["acquire"],  true]
    - ["th2446018", "threading.Lock.__dict__.__contains__",      ["release"],  true]
    - ["th2446019", "threading.Lock.__dict__.__contains__",      ["locked"],   true]
    - ["th2446020", "threading.Condition.__dict__.__contains__", ["wait"],     true]
    - ["th2446021", "threading.Condition.__dict__.__contains__", ["notify"],   true]
    - ["th2446022", "threading.Semaphore.__dict__.__contains__", ["acquire"],  true]
    - ["th2446023", "threading.Semaphore.__dict__.__contains__", ["release"],  true]
