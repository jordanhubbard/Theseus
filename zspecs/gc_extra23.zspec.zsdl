spec: gc_extra23
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra22.zspec.zsdl."
    - "gc_extra17 covers DEBUG_*.__class__.__name__ == 'int' via table."
    - "gc_extra15 and gc_extra18 cover garbage/callbacks.__class__.__name__ == 'list'."
    - "gc_extra21 covers get_stats/__qualname__/__module__/__class__.__name__ and DEBUG_* values as standalone invariants."
    - "Focus: gc.get_stats() return value structure — the list length (3 generations), per-element type (dict), and per-element key count (3 keys per generation dict). No prior gc spec verifies these structural invariants."
    - "gc.get_stats() returns a list of exactly 3 dicts — one per GC generation (gen0, gen1, gen2)."
    - "gc.get_stats().__class__.__name__ == 'list' — the return value is a plain Python list."
    - "gc.get_stats().__len__() == 3 — exactly 3 generation dicts are returned."
    - "gc.get_stats()[0].__class__.__name__ == 'dict' — each generation entry is a plain dict."
    - "gc.get_stats()[0].__len__() == 3 — each generation dict has exactly 3 keys: collections, collected, uncollectable."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# gc.get_stats() return type — list
#
# gc_extra21 covers get_stats.__qualname__/__module__/__class__.__name__ (the
# function object itself). No prior gc spec verifies the type of the *return
# value* of get_stats(). The return value is a plain Python list with one
# dict per GC generation.
# ---------------------------------------------------------------------------

invariant gc_extra23.get_stats.returns_list:
  description: "gc.get_stats().__class__.__name__ == 'list' — return value is a plain list"
  category: get_stats_structure
  kind: python_call_eq
  function: get_stats.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: false

invariant gc_extra23.get_stats.return_class:
  description: "type(gc.get_stats()).__name__ == 'list' — get_stats() returns a list"
  category: get_stats_structure
  kind: python_call_eq
  function: get_stats
  args: []
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# gc.get_stats() list length — exactly 3 generations
#
# The gc module tracks three generations (gen0, gen1, gen2).
# get_stats() returns one dict per generation, so the list length is always 3.
# No prior gc spec records this structural invariant.
# ---------------------------------------------------------------------------

invariant gc_extra23.get_stats.len_is_3:
  description: "gc.get_stats().__len__() == 3 — one dict per GC generation (gen0, gen1, gen2)"
  category: get_stats_structure
  kind: python_call_eq
  function: get_stats
  args: []
  method: __len__
  method_args: []
  expected: 3

# ---------------------------------------------------------------------------
# gc.get_stats()[0] — first generation dict type and key count
#
# Each element of the get_stats() list is a plain dict with exactly 3 keys:
# 'collections', 'collected', and 'uncollectable'. No prior gc spec verifies
# the type or key count of individual generation dicts.
# ---------------------------------------------------------------------------

invariant gc_extra23.get_stats.gen0_is_dict:
  description: "type(gc.get_stats()[0]).__name__ == 'dict' — each generation entry is a plain dict"
  category: get_stats_structure
  kind: python_call_eq
  function: "get_stats().__getitem__(0).__class__.__name__.__eq__"
  args: ["dict"]
  expected: true

invariant gc_extra23.get_stats.gen0_len:
  description: "len(gc.get_stats()[0]) == 3 — each generation dict has exactly 3 keys"
  category: get_stats_structure
  kind: python_call_eq
  function: "get_stats().__getitem__(0).__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# gc.callbacks.__class__.__name__ — extra23 namespace
#
# gc_extra15 and gc_extra18 cover this in their own namespaces. Re-anchored
# here in the extra23 namespace as a standalone module-attribute type check.
# ---------------------------------------------------------------------------

invariant gc_extra23.callbacks.class_is_list:
  description: "gc.callbacks.__class__.__name__ == 'list' — callbacks holds collection callback functions"
  category: module_attrs
  kind: python_call_eq
  function: callbacks.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# gc.garbage.__class__.__name__ — extra23 namespace
#
# gc_extra15 and gc_extra18 cover this in their own namespaces. Re-anchored
# here in the extra23 namespace as a standalone module-attribute type check.
# ---------------------------------------------------------------------------

invariant gc_extra23.garbage.class_is_list:
  description: "gc.garbage.__class__.__name__ == 'list' — garbage holds uncollectable objects"
  category: module_attrs
  kind: python_call_eq
  function: garbage.__class__.__name__.__eq__
  args: ["list"]
  expected: true
