# ---------------------------------------------------------------------------
# socket.AddressFamily.__module__.__eq__('socket') — standalone
#
# AddressFamily.__module__ is 'socket'. socket_extra86 anchors __qualname__.__eq__
# for AddressFamily but not __module__.__eq__. No prior socket spec checks
# AddressFamily.__module__.__eq__ as a call.
# First __module__.__eq__ standalone for socket.AddressFamily.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra88.addressfamily_module_eq:
  description: "socket.AddressFamily.__module__.__eq__('socket') == True — AddressFamily is defined in socket.py; its __module__ is 'socket'; socket_extra86 anchors __qualname__.__eq__ but not __module__.__eq__; first __module__.__eq__ standalone for socket.AddressFamily"
  category: class_attrs
  kind: python_call_eq
  function: AddressFamily.__module__.__eq__
  args: ["socket"]
  expected: true
