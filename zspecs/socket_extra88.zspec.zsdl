spec: socket_extra88
version: ">=3.9"
extends: socket_extra87
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra87.zspec.zsdl — covers socket.socket class __name__/__module__/__qualname__ identity / create_connection/create_server/getfqdn/getaddrinfo/gethostname/gethostbyname/setdefaulttimeout __qualname__.__eq__ / socket.socket __dict__ membership for __init__/accept/close/dup (table + invariants)."
    - "socket_extra86.zspec.zsdl — covers socket.socket/__module__/__qualname__/__mro__.__len__()==3/__bases__[0].__name__/__eq__ / AF_INET/SOCK_STREAM class identity / AddressFamily/SocketKind __bases__[0].__name__/__eq__/__qualname__.__eq__ (table + invariants)."
    - "socket_extra85.zspec.zsdl — covers socket.socket.__dict__.__contains__ for accept/close/__init__/makefile/detach/dup/sendfile/__enter__/__exit__/__repr__/family/type/get_inheritable/set_inheritable (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra87; it does NOT duplicate invariants present in those files."
    - "Wave 254 theme: socket.socket.__dict__ negative membership for C-level methods / AddressFamily and SocketKind MRO depths and identity."
    - "socket.socket.__dict__.__contains__('bind') == False — bind is a C-level method living in _socket.socket, not in the Python socket.socket wrapper. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('connect') == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('listen') == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('recv') == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('send') == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('sendall') == False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__mro__.__len__() == 6 (MRO: [AddressFamily, IntEnum, int, ReprEnum, Enum, object]). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__mro__.__len__() == 6 (MRO: [SocketKind, IntEnum, int, ReprEnum, Enum, object]). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__module__.__eq__('socket') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__module__.__eq__('socket') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__qualname__.__eq__('AddressFamily') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__qualname__.__eq__('SocketKind') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('bind') == False
# socket.socket.__dict__.__contains__('connect') == False
# socket.socket.__dict__.__contains__('listen') == False
# socket.socket.__dict__.__contains__('recv') == False
#
# Wave 254 theme: socket.socket __dict__ negative membership (group 1).
#
# bind/connect/listen/recv are C-level methods implemented in _socket.socket
# and are NOT present in the Python socket.socket wrapper class __dict__.
# The Python socket.socket inherits these from _socket.socket via MRO.
# socket_extra85 anchors __dict__.__contains__ for Python-level methods
# (True cases); this table anchors the False cases for C-level methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra88.socket_dict_negative_group1:
  description: "socket.socket/__dict__.__contains__('bind')==False / socket/__dict__.__contains__('connect')==False / socket/__dict__.__contains__('listen')==False / socket/__dict__.__contains__('recv')==False — bind/connect/listen/recv are C-level methods in _socket.socket that are NOT redefined in the Python socket.socket wrapper; socket_extra85 anchors True cases for Python methods; this table anchors the False cases for C-level methods; first socketdictmro88 anchor for socket.socket dict negative membership"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketdictmro88

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_no_bind,    "socket.__dict__.__contains__", ["bind"],    false]
    - [socket_dict_no_connect, "socket.__dict__.__contains__", ["connect"], false]
    - [socket_dict_no_listen,  "socket.__dict__.__contains__", ["listen"],  false]
    - [socket_dict_no_recv,    "socket.__dict__.__contains__", ["recv"],    false]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('send') == False
# socket.socket.__dict__.__contains__('sendall') == False
# socket.socket.__dict__.__contains__('bind') == False (cross-check)
# socket.socket.__dict__.__contains__('connect') == False (cross-check)
#
# Wave 254 theme: socket.socket __dict__ negative membership (group 2).
#
# send and sendall are also C-level methods in _socket.socket not present
# in the Python wrapper __dict__. Cross-checks from group 1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra88.socket_dict_negative_group2:
  description: "socket.socket/__dict__.__contains__('send')==False / socket/__dict__.__contains__('sendall')==False / socket/__dict__.__contains__('bind')==False / socket/__dict__.__contains__('connect')==False — send/sendall are C-level methods in _socket.socket not in Python socket wrapper __dict__; cross-checks repeat bind/connect from group 1; confirms that all six C-level network I/O methods are absent from socket.socket.__dict__; first socketdictmro88 anchor for send/sendall negative membership"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketdictmro88

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_no_send,     "socket.__dict__.__contains__", ["send"],    false]
    - [socket_dict_no_sendall,  "socket.__dict__.__contains__", ["sendall"], false]
    - [socket_dict_no_bind2,    "socket.__dict__.__contains__", ["bind"],    false]
    - [socket_dict_no_connect2, "socket.__dict__.__contains__", ["connect"], false]

# ---------------------------------------------------------------------------
# socket.AddressFamily/__qualname__/__eq__('AddressFamily')
# socket.AddressFamily/__module__/__eq__('socket')
# socket.AddressFamily/__mro__/__len__() == 6
# socket.AddressFamily/__name__/__eq__('AddressFamily')
#
# Wave 254 theme: AddressFamily class identity.
#
# AddressFamily is an IntEnum subclass defined in socket.py. Its MRO is
# [AddressFamily, IntEnum, int, ReprEnum, Enum, object] with 6 entries.
# socket_extra86 anchors AddressFamily.__bases__[0].__name__.__eq__ and
# __qualname__.__eq__ already; this table anchors __module__, __mro__.__len__,
# and __name__.__eq__ under the new id_prefix socketdictmro88.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra88.addressfamily_identity:
  description: "socket.AddressFamily/__qualname__/__eq__('AddressFamily')==True / AddressFamily/__module__/__eq__('socket')==True / AddressFamily/__mro__/__len__()==6 / AddressFamily/__name__/__eq__('AddressFamily')==True — AddressFamily is an IntEnum subclass in socket.py; MRO is [AddressFamily, IntEnum, int, ReprEnum, Enum, object] (6 entries); socket_extra86 anchors __qualname__.__eq__ and __bases__[0].__name__; this table anchors __module__/__mro__.__len__/__name__.__eq__ under socketdictmro88; first socketdictmro88 anchor for AddressFamily identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketdictmro88

  columns: [id, function, args, expected]
  rows:
    - [af_qualname_eq,  AddressFamily.__qualname__.__eq__,  ["AddressFamily"], true]
    - [af_module_eq,    AddressFamily.__module__.__eq__,    ["socket"],        true]
    - [af_mro_len_6,    AddressFamily.__mro__.__len__,      [],                6]
    - [af_name_eq,      AddressFamily.__name__.__eq__,      ["AddressFamily"], true]

# ---------------------------------------------------------------------------
# socket.SocketKind/__qualname__/__eq__('SocketKind')
# socket.SocketKind/__module__/__eq__('socket')
# socket.SocketKind/__mro__/__len__() == 6
# socket.SocketKind/__name__/__eq__('SocketKind')
#
# Wave 254 theme: SocketKind class identity.
#
# SocketKind is an IntEnum subclass defined in socket.py with the same MRO
# structure as AddressFamily. Its MRO is [SocketKind, IntEnum, int, ReprEnum,
# Enum, object] (6 entries). socket_extra86 anchors __qualname__.__eq__ and
# __bases__[0].__name__ for SocketKind; this table anchors __module__/
# __mro__.__len__/__name__.__eq__ under socketdictmro88.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra88.socketkind_identity:
  description: "socket.SocketKind/__qualname__/__eq__('SocketKind')==True / SocketKind/__module__/__eq__('socket')==True / SocketKind/__mro__/__len__()==6 / SocketKind/__name__/__eq__('SocketKind')==True — SocketKind is an IntEnum subclass in socket.py; MRO is [SocketKind, IntEnum, int, ReprEnum, Enum, object] (6 entries, same structure as AddressFamily); socket_extra86 anchors __qualname__.__eq__ and __bases__[0].__name__; this table anchors __module__/__mro__.__len__/__name__.__eq__ under socketdictmro88; first socketdictmro88 anchor for SocketKind identity"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketdictmro88

  columns: [id, function, args, expected]
  rows:
    - [sk_qualname_eq,  SocketKind.__qualname__.__eq__,  ["SocketKind"], true]
    - [sk_module_eq,    SocketKind.__module__.__eq__,    ["socket"],     true]
    - [sk_mro_len_6,    SocketKind.__mro__.__len__,      [],             6]
    - [sk_name_eq,      SocketKind.__name__.__eq__,      ["SocketKind"], true]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('bind') == False — standalone
#
# socket.socket.__dict__.__contains__('bind') is False. bind is a C-level
# method in _socket.socket. socket.socket.__dict__ only contains the Python-
# level overrides defined in socket.py. socket_extra85 anchors True cases
# for Python methods. No prior socket spec checks __contains__('bind') == False.
# First negative __dict__.__contains__ standalone for socket.socket.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra88.socket_dict_no_bind:
  description: "socket.socket.__dict__.__contains__('bind') == False — bind is a C-level method implemented in _socket.socket and is NOT present in the Python socket.socket wrapper class __dict__; socket_extra85 anchors True cases for Python-defined methods; this standalone anchors the first False case; first negative __dict__.__contains__ standalone for socket.socket"
  category: class_attrs
  kind: python_call_eq
  function: "socket.__dict__.__contains__"
  args: ["bind"]
  expected: false

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('recv') == False — standalone
#
# socket.socket.__dict__.__contains__('recv') is False. recv is a C-level
# method in _socket.socket. No prior socket spec checks __contains__('recv').
# First negative standalone for socket.socket.__dict__ recv.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra88.socket_dict_no_recv:
  description: "socket.socket.__dict__.__contains__('recv') == False — recv is a C-level method in _socket.socket not present in the Python socket.socket wrapper __dict__; no prior socket spec checks __dict__.__contains__('recv'); first standalone for recv negative membership"
  category: class_attrs
  kind: python_call_eq
  function: "socket.__dict__.__contains__"
  args: ["recv"]
  expected: false

# ---------------------------------------------------------------------------
# socket.AddressFamily.__mro__.__len__() == 6 — standalone
#
# AddressFamily.__mro__ is [AddressFamily, IntEnum, int, ReprEnum, Enum, object]
# with 6 entries. socket_extra86 anchors __qualname__.__eq__ but not __mro__.__len__.
# No prior socket spec checks AddressFamily.__mro__.__len__().
# First __mro__.__len__() standalone for socket.AddressFamily.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra88.addressfamily_mro_len:
  description: "socket.AddressFamily.__mro__.__len__() == 6 — AddressFamily is an IntEnum subclass; its MRO is [AddressFamily, IntEnum, int, ReprEnum, Enum, object] (6 entries); socket_extra86 anchors __qualname__.__eq__ but not __mro__.__len__; first __mro__.__len__() standalone for socket.AddressFamily"
  category: class_attrs
  kind: python_call_eq
  function: AddressFamily.__mro__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# socket.SocketKind.__mro__.__len__() == 6 — standalone
#
# SocketKind.__mro__ is [SocketKind, IntEnum, int, ReprEnum, Enum, object]
# with 6 entries. socket_extra86 anchors __qualname__.__eq__ but not __mro__.__len__.
# No prior socket spec checks SocketKind.__mro__.__len__().
# First __mro__.__len__() standalone for socket.SocketKind.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra88.socketkind_mro_len:
  description: "socket.SocketKind.__mro__.__len__() == 6 — SocketKind is an IntEnum subclass; its MRO is [SocketKind, IntEnum, int, ReprEnum, Enum, object] (6 entries, same structure as AddressFamily); socket_extra86 anchors __qualname__.__eq__ but not __mro__.__len__; first __mro__.__len__() standalone for socket.SocketKind"
  category: class_attrs
  kind: python_call_eq
  function: SocketKind.__mro__.__len__
  args: []
