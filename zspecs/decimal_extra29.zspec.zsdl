spec: decimal_extra29
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra28.zspec.zsdl — covers Decimal method __qualname__.__len__() for __add__/__mul__/__sub__/quantize/to_eng_string/__repr__/__str__/__neg__; Decimal/__mro__.__len__()==2; Decimal/__bases__[0].__name__; exception class __mro__.__len__() for all major exceptions."
    - "decimal_extra27.zspec.zsdl — covers exception class __module__/__name__/__qualname__ and their lengths for all decimal exceptions; getcontext/setcontext/localcontext __module__ (all '_decimal', len 8)."
    - "decimal_extra26.zspec.zsdl — covers Decimal/__module__/__name__/__qualname__ lengths; Context/__module__/__name__/__qualname__ lengths; getcontext/setcontext/localcontext __name__/__qualname__ values and lengths."
    - "decimal_extra25.zspec.zsdl — covers Context/__name__/__module__/__qualname__/__bases__[0].__name__; DefaultContext/BasicContext/ExtendedContext __class__.__name__; ROUND_* __class__.__name__."
  notes:
    - "This spec extends decimal_extra28.zspec.zsdl."
    - "Prior specs covered: Decimal/Context/__module__/__name__/__qualname__ and all their lengths, exception class __name__/__qualname__/__module__/__mro__.__len__(), getcontext/setcontext/localcontext __name__/__qualname__/__module__ and lengths, Decimal arithmetic method __qualname__.__len__() for __add__/__mul__/__sub__/quantize/to_eng_string/__repr__/__str__/__neg__, DefaultContext/BasicContext/ExtendedContext class names, ROUND_* class names."
    - "This spec covers: Context method __qualname__.__len__() for add/subtract/multiply/divide/sqrt/power/compare/abs (NOVEL — no prior decimal spec checks __qualname__.__len__() for any Context method); Decimal.compare/__qualname__.__len__()==15 (NOVEL — extra28 covers __add__/__mul__/__sub__/quantize/to_eng_string/__repr__/__str__/__neg__ but NOT compare/sqrt/ln/log10/normalize/fma/exp/remainder_near); Decimal.sqrt/__qualname__.__len__()==12 (NOVEL); Decimal.ln/__qualname__.__len__()==10 (NOVEL); Decimal.log10/__qualname__.__len__()==13 (NOVEL); Decimal.normalize/__qualname__.__len__()==17 (NOVEL); Decimal.fma/__qualname__.__len__()==11 (NOVEL); Decimal.exp/__qualname__.__len__()==11 (NOVEL); Decimal.remainder_near/__qualname__.__len__()==22 (NOVEL — longest Decimal method qualname); Context.__mro__.__len__()==2 (NOVEL — [Context, object]; no prior spec checks Context.__mro__.__len__()); Context.__dict__.__class__.__name__.__len__()==12 (NOVEL — 'mappingproxy' is 12 chars for Context, not checked by any prior spec)."
    - "Context.__mro__ == [Context, object] — length 2. Context is a standalone C-extension class with no Python-level parents beyond object. This mirrors Decimal.__mro__.__len__()==2 (covered in extra28). Novel for Context specifically. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Same as Decimal.__dict__.__class__.__name__ (which is implied by extra28's mappingproxy note for Decimal/Context pattern). Explicitly checking Context is novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.add.__qualname__ == 'Context.add' (len 11). No prior decimal spec checks __qualname__.__len__() for any Context method. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.subtract.__qualname__ == 'Context.subtract' (len 16). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.multiply.__qualname__ == 'Context.multiply' (len 16). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.divide.__qualname__ == 'Context.divide' (len 14). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.sqrt.__qualname__ == 'Context.sqrt' (len 12). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.power.__qualname__ == 'Context.power' (len 13). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.compare.__qualname__ == 'Context.compare' (len 15). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Context.abs.__qualname__ == 'Context.abs' (len 11). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.compare.__qualname__ == 'Decimal.compare' (len 15). extra28 covers __add__/__mul__/__sub__/quantize/to_eng_string/__repr__/__str__/__neg__; compare is not among them. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (len 12). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.ln.__qualname__ == 'Decimal.ln' (len 10). Note: 'ln' (2 chars) is the shortest method name; 'Decimal.' prefix (8 chars) gives total 10. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.log10.__qualname__ == 'Decimal.log10' (len 13). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.normalize.__qualname__ == 'Decimal.normalize' (len 17). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.fma.__qualname__ == 'Decimal.fma' (len 11). Novel. fma = fused multiply-add. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.exp.__qualname__ == 'Decimal.exp' (len 11). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.remainder_near.__qualname__ == 'Decimal.remainder_near' (len 22). This is the longest Decimal method qualname found so far — longer than to_eng_string (21 from extra28). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context.__mro__.__len__() and Context.__dict__.__class__.__name__.__len__()
#
# Context is a top-level C-extension class whose __mro__ == [Context, object]
# (depth 2). No prior decimal spec checks Context.__mro__.__len__(); extra28
# covers Decimal.__mro__.__len__()==2. Context.__dict__.__class__.__name__ ==
# 'mappingproxy' (len 12); no prior spec explicitly checks this for Context.
# Both are novel complements to the Decimal-level checks in extra28.
# ---------------------------------------------------------------------------

invariant decimal_extra29.Context.mro_len:
  description: "len(decimal.Context.__mro__) == 2 — [Context, object]; mirrors Decimal.__mro__.__len__()==2 covered in extra28"
  category: class_identity
  kind: python_call_eq
  function: Context.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra29.Context.dict_classname_len:
  description: "decimal.Context.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters; novel Context-specific check"
  category: class_structure
  kind: python_call_eq
  function: Context.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Table: Context method __qualname__.__len__()
#
# No prior decimal spec checks __qualname__.__len__() for any Context method.
# Context methods mirror corresponding Decimal operations but dispatch on an
# explicit Context instance. All qualnames follow 'Context.<method>' pattern.
#
#   Context.add      -> 'Context.add'      -> 11
#   Context.abs      -> 'Context.abs'      -> 11
#   Context.sqrt     -> 'Context.sqrt'     -> 12
#   Context.power    -> 'Context.power'    -> 13
#   Context.divide   -> 'Context.divide'   -> 14
#   Context.compare  -> 'Context.compare'  -> 15
#   Context.subtract -> 'Context.subtract' -> 16
#   Context.multiply -> 'Context.multiply' -> 16
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra29.context_method_qualname_lens:
  description: "Context method __qualname__.__len__() — all novel; no prior decimal spec checks Context method qualname lengths"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: cmql29

  columns: [id, function, args, expected]
  rows:
    - [add,      Context.add.__qualname__.__len__,      [], 11]
    - [abs,      Context.abs.__qualname__.__len__,      [], 11]
    - [sqrt,     Context.sqrt.__qualname__.__len__,     [], 12]
    - [power,    Context.power.__qualname__.__len__,    [], 13]
    - [divide,   Context.divide.__qualname__.__len__,   [], 14]
    - [compare,  Context.compare.__qualname__.__len__,  [], 15]
    - [subtract, Context.subtract.__qualname__.__len__, [], 16]
    - [multiply, Context.multiply.__qualname__.__len__, [], 16]

# ---------------------------------------------------------------------------
# Table: Decimal method __qualname__.__len__() — second batch
#
# extra28 covers: __add__(15), __mul__(15), __sub__(15), __str__(15),
# __neg__(15), __repr__(16), quantize(16), to_eng_string(21).
# This table covers the remaining Decimal methods not checked by extra28:
#
#   Decimal.ln             -> 'Decimal.ln'             -> 10
#   Decimal.sqrt           -> 'Decimal.sqrt'           -> 12
#   Decimal.log10          -> 'Decimal.log10'          -> 13
#   Decimal.compare        -> 'Decimal.compare'        -> 15
#   Decimal.fma            -> 'Decimal.fma'            -> 11
#   Decimal.exp            -> 'Decimal.exp'            -> 11
#   Decimal.normalize      -> 'Decimal.normalize'      -> 17
#   Decimal.remainder_near -> 'Decimal.remainder_near' -> 22
#
# remainder_near (22) surpasses to_eng_string (21) as the longest Decimal
# method qualname. All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra29.decimal_method_qualname_lens_batch2:
  description: "Decimal method __qualname__.__len__() — second batch; extra28 covers __add__/__mul__/__sub__/__str__/__neg__/__repr__/quantize/to_eng_string"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: dmql29

  columns: [id, function, args, expected]
  rows:
    - [ln,             "Decimal.ln.__qualname__.__len__",             [], 10]
    - [sqrt,           "Decimal.sqrt.__qualname__.__len__",           [], 12]
    - [log10,          "Decimal.log10.__qualname__.__len__",          [], 13]
    - [fma,            "Decimal.fma.__qualname__.__len__",            [], 11]
    - [exp,            "Decimal.exp.__qualname__.__len__",            [], 11]
    - [compare,        "Decimal.compare.__qualname__.__len__",        [], 15]
    - [normalize,      "Decimal.normalize.__qualname__.__len__",      [], 17]
    - [remainder_near, "Decimal.remainder_near.__qualname__.__len__", [], 22]

# ---------------------------------------------------------------------------
# Decimal.remainder_near.__qualname__.__len__() == 22 — standalone
#
# Decimal.remainder_near.__qualname__ == 'Decimal.remainder_near' (22 chars).
# This is the longest qualname of any Decimal method found so far, surpassing
# Decimal.to_eng_string (21 chars, covered in extra28). The verbose IEEE 754
# operation name is responsible for this length. Novel standalone invariant.
# ---------------------------------------------------------------------------

invariant decimal_extra29.Decimal.remainder_near_qualname_len:
  description: "len(decimal.Decimal.remainder_near.__qualname__) == 22 — 'Decimal.remainder_near' is 22 chars; longest Decimal method qualname, surpassing to_eng_string (21)"
  category: method_qualname_lengths
  kind: python_call_eq
  "function": "Decimal.remainder_near.__qualname__.__len__"
  args: []
  expected: 22
