spec: decimal_extra31
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra30.zspec.zsdl — covers Context method __qualname__.__len__() for ln/min/max/fma/exp/copy/plus/log10/minus/divmod/quantize/remainder/normalize/logical_and/to_sci_string/to_eng_string."
    - "decimal_extra29.zspec.zsdl — covers Decimal.compare(15)/sqrt(12)/ln(10)/log10(13)/normalize(17)/fma(11)/exp(11)/remainder_near(22) __qualname__.__len__(); Context.add/abs/sqrt/power/divide/compare/subtract/multiply __qualname__.__len__()."
    - "decimal_extra28.zspec.zsdl — covers Decimal.__add__/__mul__/__sub__/quantize(16)/to_eng_string(21)/__repr__/__str__/__neg__ __qualname__.__len__()."
  notes:
    - "This spec extends decimal_extra30.zspec.zsdl."
    - "Prior specs collectively covered: Decimal/Context/__module__/__name__/__qualname__ and all lengths; exception class __name__/__qualname__/__module__/__mro__.__len__(); getcontext/setcontext/localcontext __name__/__qualname__/__module__ and lengths; Decimal method __qualname__.__len__() for __add__/__mul__/__sub__/quantize/to_eng_string/__repr__/__str__/__neg__/compare/sqrt/ln/log10/normalize/fma/exp/remainder_near; all Context method __qualname__.__len__(); exception __name__.__len__() for all major exceptions."
    - "This spec covers: Decimal.to_integral_value/__qualname__.__len__()==25 (NOVEL — the longest Decimal method qualname after remainder_near; no prior decimal spec checks to_integral_value/__qualname__.__len__()); Decimal.as_integer_ratio(24)/as_tuple(16)/is_finite(17)/is_nan(14)/is_zero(15)/is_signed(17)/is_normal(17)/is_subnormal(20)/is_infinite(19) __qualname__.__len__() (NOVEL — no prior decimal spec checks any of these)."
    - "Decimal.to_integral_value.__qualname__ == 'Decimal.to_integral_value' — len 25. Only Decimal.remainder_near (22) and Decimal.to_integral_value (25) exceed 21 chars. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.as_integer_ratio.__qualname__ == 'Decimal.as_integer_ratio' — len 24. Novel. as_integer_ratio was added in Python 3.10. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.as_tuple.__qualname__ == 'Decimal.as_tuple' — len 16. Equals Decimal.quantize (16). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.is_finite.__qualname__ == 'Decimal.is_finite' — len 17. Equals Decimal.normalize/is_signed/is_normal (17). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.is_nan.__qualname__ == 'Decimal.is_nan' — len 14. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.is_zero.__qualname__ == 'Decimal.is_zero' — len 15. Equals Decimal.is_nan+1 char. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.is_signed.__qualname__ == 'Decimal.is_signed' — len 17. Equals Decimal.is_finite/is_normal (17). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.is_normal.__qualname__ == 'Decimal.is_normal' — len 17. Equals Decimal.is_finite/is_signed (17). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.is_subnormal.__qualname__ == 'Decimal.is_subnormal' — len 20. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Decimal.is_infinite.__qualname__ == 'Decimal.is_infinite' — len 19. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.to_integral_value and as_integer_ratio __qualname__.__len__()
#
# These are the two longest Decimal method qualnames after remainder_near (22):
#
#   Decimal.to_integral_value  -> 'Decimal.to_integral_value'  -> 25 (longest!)
#   Decimal.as_integer_ratio   -> 'Decimal.as_integer_ratio'   -> 24
#
# Decimal.to_integral_value surpasses remainder_near (22) as the longest
# Decimal method qualname. as_integer_ratio (Python 3.10+) is second-longest
# at 24. Both are novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra31.Decimal.to_integral_value_qualname_len:
  description: "len(decimal.Decimal.to_integral_value.__qualname__) == 25 — 'Decimal.to_integral_value' has 25 characters; longest Decimal method qualname (exceeds remainder_near at 22); novel"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Decimal.to_integral_value.__qualname__.__len__
  args: []
  expected: 25

invariant decimal_extra31.Decimal.as_integer_ratio_qualname_len:
  description: "len(decimal.Decimal.as_integer_ratio.__qualname__) == 24 — 'Decimal.as_integer_ratio' has 24 characters; second-longest Decimal method qualname; novel"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Decimal.as_integer_ratio.__qualname__.__len__
  args: []
  expected: 24

# ---------------------------------------------------------------------------
# Decimal.as_tuple __qualname__.__len__()
#
# Decimal.as_tuple returns a named tuple representation of the decimal value.
# Its qualname is 'Decimal.as_tuple' (16 chars), equal to Decimal.quantize.
# No prior decimal spec checks as_tuple.__qualname__.__len__(). Novel.
# ---------------------------------------------------------------------------

invariant decimal_extra31.Decimal.as_tuple_qualname_len:
  description: "len(decimal.Decimal.as_tuple.__qualname__) == 16 — 'Decimal.as_tuple' has 16 characters; equals Decimal.quantize (16); novel invariant"
  category: method_qualname_lengths
  kind: python_call_eq
  function: Decimal.as_tuple.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Decimal is_* predicate method __qualname__.__len__()
#
# Decimal exposes a rich set of is_* predicate methods for querying numeric
# properties. No prior decimal spec checks __qualname__.__len__() for any
# is_* method. All are novel. The qualnames follow 'Decimal.is_<name>' pattern.
#
#   Decimal.is_nan       -> 'Decimal.is_nan'       -> 14
#   Decimal.is_zero      -> 'Decimal.is_zero'      -> 15
#   Decimal.is_finite    -> 'Decimal.is_finite'    -> 17
#   Decimal.is_signed    -> 'Decimal.is_signed'    -> 17
#   Decimal.is_normal    -> 'Decimal.is_normal'    -> 17
#   Decimal.is_infinite  -> 'Decimal.is_infinite'  -> 19
#   Decimal.is_subnormal -> 'Decimal.is_subnormal' -> 20
#
# Clusters: is_finite/is_signed/is_normal all share len 17.
# is_subnormal is the longest is_* method qualname at 20.
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra31.Decimal_is_predicate_qualname_lens:
  description: "Decimal is_* predicate method __qualname__.__len__() — is_nan(14)/is_zero(15)/is_finite(17)/is_signed(17)/is_normal(17)/is_infinite(19)/is_subnormal(20); all novel"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: dipq31

  columns: [id, function, args, expected]
  rows:
    - [is_nan,       Decimal.is_nan.__qualname__.__len__,       [], 14]
    - [is_zero,      Decimal.is_zero.__qualname__.__len__,      [], 15]
    - [is_finite,    Decimal.is_finite.__qualname__.__len__,    [], 17]
    - [is_signed,    Decimal.is_signed.__qualname__.__len__,    [], 17]
    - [is_normal,    Decimal.is_normal.__qualname__.__len__,    [], 17]
    - [is_infinite,  Decimal.is_infinite.__qualname__.__len__,  [], 19]
    - [is_subnormal, Decimal.is_subnormal.__qualname__.__len__, [], 20]
