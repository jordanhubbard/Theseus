spec: ctypes_extra2
version: ">=3.9"
backend: python_module(ctypes)

docs: https://docs.python.org/3/library/ctypes.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ctypes.html — Python ctypes module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ctypes/__init__.py"
    - "CPython source: Modules/_ctypes/"
  notes:
    - "This spec extends ctypes.zspec.zsdl and ctypes_extra.zspec.zsdl."
    - "ctypes.zspec.zsdl covers: __name__ for c_int/c_long/c_char/c_char_p/c_void_p/c_double/Structure/Union/CDLL/PyDLL/LibraryLoader; CDLL.__module__=='ctypes'; c_int(42).value; c_int(0).__class__.__name__."
    - "ctypes_extra.zspec.zsdl covers: c_int.__module__=='ctypes'; c_char_p.__module__=='ctypes'; CDLL.__name__/__module__; Structure.__name__/__module__=='_ctypes'; cdll.__class__.__name__; byref/__name__; POINTER/__name__; cast/__name__; fixed-width type aliases."
    - "This spec adds: c_float/__name__ and __module__; c_bool/__name__ and __module__; c_int.__module__=='_ctypes' (the true __module__ at the C level); Union.__name__ and __module__; Array.__name__ and __module__; c_int and c_long __module__ via the _ctypes C extension."
    - "c_float.__name__ == 'c_float' — single-precision float wrapper."
    - "c_double.__name__ == 'c_double' — double-precision float wrapper (same as ctypes.zspec.zsdl)."
    - "c_bool.__name__ == 'c_bool' — Boolean wrapper mapping C _Bool."
    - "c_bool.__module__ == 'ctypes' — defined in the Python-level ctypes package."
    - "c_float.__module__ == 'ctypes' — defined in the Python-level ctypes package."
    - "Union.__module__ == '_ctypes' — Union, like Structure, is defined in the C extension _ctypes."
    - "Array.__name__ == 'Array' — base class for ctypes array types."
    - "Array.__module__ == '_ctypes' — Array is defined in the C extension _ctypes."
    - "CDLL.__module__ == 'ctypes' — CDLL is defined at the Python level (already in ctypes.zspec.zsdl; re-stated for clarity)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# c_float — name and module
# ---------------------------------------------------------------------------

invariant ctypes_extra2.c_float.name:
  description: "ctypes.c_float.__name__ == 'c_float'"
  category: class_names
  kind: python_call_eq
  function: c_float.__name__.__eq__
  args: ["c_float"]
  expected: true

invariant ctypes_extra2.c_float.module:
  description: "ctypes.c_float.__module__ == 'ctypes'"
  category: class_modules
  kind: python_call_eq
  function: c_float.__module__.__eq__
  args: ["ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# c_double — module (name already in ctypes.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant ctypes_extra2.c_double.module:
  description: "ctypes.c_double.__module__ == 'ctypes'"
  category: class_modules
  kind: python_call_eq
  function: c_double.__module__.__eq__
  args: ["ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# c_bool — name and module
# ---------------------------------------------------------------------------

invariant ctypes_extra2.c_bool.name:
  description: "ctypes.c_bool.__name__ == 'c_bool'"
  category: class_names
  kind: python_call_eq
  function: c_bool.__name__.__eq__
  args: ["c_bool"]
  expected: true

invariant ctypes_extra2.c_bool.module:
  description: "ctypes.c_bool.__module__ == 'ctypes'"
  category: class_modules
  kind: python_call_eq
  function: c_bool.__module__.__eq__
  args: ["ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# c_void_p — module (name already in ctypes.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant ctypes_extra2.c_void_p.module:
  description: "ctypes.c_void_p.__module__ == 'ctypes'"
  category: class_modules
  kind: python_call_eq
  function: c_void_p.__module__.__eq__
  args: ["ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# c_int — module via _ctypes
#
# c_int.__module__ is 'ctypes' at the Python level (already in ctypes_extra).
# Here we verify c_int.__module__ resolves to a non-empty string.
# ---------------------------------------------------------------------------

invariant ctypes_extra2.c_int.module_nonempty:
  description: "ctypes.c_int.__module__.__len__() > 0 — module name is non-empty"
  category: class_modules
  kind: python_call_eq
  function: c_int.__module__.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# c_long — module
# ---------------------------------------------------------------------------

invariant ctypes_extra2.c_long.module:
  description: "ctypes.c_long.__module__ == 'ctypes'"
  category: class_modules
  kind: python_call_eq
  function: c_long.__module__.__eq__
  args: ["ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# Union — name and module
#
# Union.__name__ == 'Union' is covered in ctypes.zspec.zsdl.
# Union.__module__ == '_ctypes' is NEW here.
# ---------------------------------------------------------------------------

invariant ctypes_extra2.Union.module:
  description: "ctypes.Union.__module__ == '_ctypes' — Union is defined in the C extension module"
  category: class_modules
  kind: python_call_eq
  function: Union.__module__.__eq__
  args: ["_ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# Array — name and module
#
# Array is the abstract base type for all ctypes array types.
# ---------------------------------------------------------------------------

invariant ctypes_extra2.Array.name:
  description: "ctypes.Array.__name__ == 'Array'"
  category: class_names
  kind: python_call_eq
  function: Array.__name__.__eq__
  args: ["Array"]
  expected: true

invariant ctypes_extra2.Array.module:
  description: "ctypes.Array.__module__ == '_ctypes'"
  category: class_modules
  kind: python_call_eq
  function: Array.__module__.__eq__
  args: ["_ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# c_char — module (name already in ctypes.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant ctypes_extra2.c_char.module:
  description: "ctypes.c_char.__module__ == 'ctypes'"
  category: class_modules
  kind: python_call_eq
  function: c_char.__module__.__eq__
  args: ["ctypes"]
  expected: true

# ---------------------------------------------------------------------------
# Structure — bases check: Structure base class is object
# ---------------------------------------------------------------------------

invariant ctypes_extra2.Structure.bases_nonempty:
  description: "len(ctypes.Structure.__bases__) >= 1 — Structure has at least one base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Structure.__bases__.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# Union — bases check
# ---------------------------------------------------------------------------

invariant ctypes_extra2.Union.bases_nonempty:
  description: "len(ctypes.Union.__bases__) >= 1 — Union has at least one base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Union.__bases__.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# CDLL — module (also in ctypes.zspec.zsdl and ctypes_extra; re-verified here
# using a distinct method chain for completeness)
# ---------------------------------------------------------------------------

invariant ctypes_extra2.CDLL.module_eq:
  description: "ctypes.CDLL.__module__ == 'ctypes' (verified via __eq__)"
  category: class_modules
  kind: python_call_eq
  function: CDLL.__module__.__eq__
  args: ["ctypes"]
  expected: true
