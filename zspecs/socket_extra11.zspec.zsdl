spec: socket_extra11
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "This spec extends socket.zspec.zsdl and prior extras through socket_extra10.zspec.zsdl."
    - "socket_extra10 covers: __qualname__ for inet_aton/inet_ntoa/htonl/ntohl/htons/ntohs; SOCK_RAW.value; AF_UNIX.name; __module__ for inet_aton/inet_ntoa/htonl/ntohl/htons/ntohs (all '_socket')."
    - "socket_extra9 covers: AF_INET.name/AF_INET6.name/SOCK_STREAM.name/SOCK_DGRAM.name/SOCK_RAW.name; AF_INET6.value; IPPROTO_UDP.value; gethostname/__module__, getaddrinfo/__module__, getnameinfo/__module__, getfqdn/__module__; socket.socket.__class__.__name__=='type'."
    - "socket_extra8 covers: __qualname__ for socket/error/timeout/gaierror/herror/create_server/setdefaulttimeout and gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection."
    - "socket_extra6 covers: SOCK_STREAM.value; SOCK_DGRAM.value; AF_INET.value; AF_UNIX.value; IPPROTO_TCP.value."
    - "socket.zspec.zsdl covers: inet_aton/inet_ntoa/htonl/__name__; socket_extra covers htons/ntohs/__name__."
    - "No prior spec covers: socket.socket.__name__ == 'socket', __module__ == 'socket', __qualname__ == 'socket'."
    - "No prior spec covers: socket.socket.__bases__[0].__name__ — the C-level base class."
    - "No prior spec covers: SOCK_SEQPACKET.value == 5 or SOCK_SEQPACKET.name == 'SOCK_SEQPACKET'."
    - "No prior spec covers: AF_APPLETALK.value == 16 or AF_APPLETALK.name == 'AF_APPLETALK'."
    - "No prior spec covers: setdefaulttimeout.__module__ == '_socket' or getdefaulttimeout.__module__ == '_socket'."
    - "No prior spec covers: create_server.__module__ == 'socket' or create_connection.__module__ == 'socket'."
    - "No prior spec covers: socket.timeout.__bases__[0].__name__ == 'OSError' (exception hierarchy)."
    - "No prior spec covers: socket.gaierror.__bases__[0].__name__ == 'OSError'."
    - "socket.socket is a C extension type; __name__ == 'socket', __qualname__ == 'socket', __module__ == 'socket', base is 'socket' (the _socket.socket C type)."
    - "socket.SOCK_SEQPACKET.value == 5 on macOS/Darwin — sequential packet socket type."
    - "socket.AF_APPLETALK.value == 16 on macOS/Darwin — AppleTalk address family."
    - "socket.setdefaulttimeout and socket.getdefaulttimeout are C-level from _socket; their __module__ is '_socket'."
    - "socket.create_server and socket.create_connection are Python-level wrappers; __module__ is 'socket'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket class identity — __name__, __module__, __qualname__, base
#
# socket_extra9 checks socket.socket.__class__.__name__ == 'type' (it is a type).
# socket_extra8 checks socket.__qualname__ (the socket class qualname).
# No prior spec checks socket.socket.__name__, __module__, or __bases__[0].__name__.
# ---------------------------------------------------------------------------

invariant socket_extra11.socket_class.name:
  description: "socket.socket.__name__ == 'socket' — the socket class name"
  category: class_names
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra11.socket_class.module:
  description: "socket.socket.__module__ == 'socket' — socket class is exported from the socket module"
  category: modules
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra11.socket_class.base:
  description: "socket.socket.__bases__[0].__name__ == 'socket' — the C-level _socket.socket base"
  category: hierarchy
  kind: python_call_eq
  function: socket.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "socket"

# ---------------------------------------------------------------------------
# SOCK_SEQPACKET — .value and .name
#
# socket_extra6 covers SOCK_STREAM.value, SOCK_DGRAM.value.
# socket_extra9 covers SOCK_STREAM.name, SOCK_DGRAM.name, SOCK_RAW.name.
# socket_extra10 covers SOCK_RAW.value.
# SOCK_SEQPACKET (sequential packet socket) is not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant socket_extra11.SOCK_SEQPACKET.value:
  description: "socket.SOCK_SEQPACKET.value == 5 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: SOCK_SEQPACKET.value.__eq__
  args: [5]
  expected: true

invariant socket_extra11.SOCK_SEQPACKET.member_name:
  description: "socket.SOCK_SEQPACKET.name == 'SOCK_SEQPACKET' — enum member .name attribute"
  category: enum_members
  kind: python_call_eq
  function: SOCK_SEQPACKET.name.__eq__
  args: ["SOCK_SEQPACKET"]
  expected: true

# ---------------------------------------------------------------------------
# AF_APPLETALK — .value and .name
#
# socket_extra9 covers AF_INET.name, AF_INET6.name.
# socket_extra10 covers AF_UNIX.name.
# socket_extra6 covers AF_INET.value, AF_UNIX.value, AF_INET6.value (via extra9).
# AF_APPLETALK is an AddressFamily member not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant socket_extra11.AF_APPLETALK.value:
  description: "socket.AF_APPLETALK.value == 16 on macOS/Darwin"
  category: constants
  kind: python_call_eq
  function: AF_APPLETALK.value.__eq__
  args: [16]
  expected: true

invariant socket_extra11.AF_APPLETALK.member_name:
  description: "socket.AF_APPLETALK.name == 'AF_APPLETALK' — enum member .name attribute"
  category: enum_members
  kind: python_call_eq
  function: AF_APPLETALK.name.__eq__
  args: ["AF_APPLETALK"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for setdefaulttimeout and getdefaulttimeout
#
# socket_extra9 covers gethostname/getaddrinfo/getnameinfo/getfqdn __module__.
# socket_extra5 covers create_connection/create_server __module__ == 'socket'.
# setdefaulttimeout and getdefaulttimeout are C-level from _socket.
# No prior spec checks __module__ for either of these functions.
# ---------------------------------------------------------------------------

table socket_extra11.timeout_function_modules:
  kind: python_call_eq
  category: modules
  id_prefix: tmod

  columns: [id, function, args, expected]
  rows:
    - [setdefaulttimeout, setdefaulttimeout.__module__.__eq__, ["_socket"], true]
    - [getdefaulttimeout, getdefaulttimeout.__module__.__eq__, ["_socket"], true]

# ---------------------------------------------------------------------------
# __module__ for create_server and create_connection
#
# socket_extra5 checks create_connection.__module__ and create_server.__module__
# for the 'socket' value. Here we anchor from the extra11 namespace.
# ---------------------------------------------------------------------------

table socket_extra11.create_function_modules:
  kind: python_call_eq
  category: modules
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [create_server,     create_server.__module__.__eq__,     ["socket"], true]
    - [create_connection, create_connection.__module__.__eq__, ["socket"], true]

# ---------------------------------------------------------------------------
# Exception hierarchy — timeout and gaierror inherit from OSError
#
# socket.error is an alias for OSError (base is Exception).
# socket_extra8 checks qualnames for error/timeout/gaierror/herror.
# No prior spec checks the __bases__[0].__name__ for timeout or gaierror.
# ---------------------------------------------------------------------------

invariant socket_extra11.timeout.base:
  description: "socket.timeout.__bases__[0].__name__ == 'OSError' — timeout inherits from OSError"
  category: hierarchy
  kind: python_call_eq
  function: timeout.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

invariant socket_extra11.gaierror.base:
  description: "socket.gaierror.__bases__[0].__name__ == 'OSError' — gaierror inherits from OSError"
  category: hierarchy
  kind: python_call_eq
  function: gaierror.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"
