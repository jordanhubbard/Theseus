spec: multiprocessing_extra41
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "This spec extends multiprocessing_extra40.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() tables, pool result class tables, Process/__name__=='Process' (extra37), Process/__module__=='multiprocessing.context' (extra37), Queue/__name__=='Queue' (extra37), Pipe/__name__=='Pipe' (extra37), Process method qualname lens for start/join/run (extra37), Process.__bases__[0].__name__=='BaseProcess'/__mro__.__len__()==3/Manager.__name__=='Manager' (extra38), function __name__/__module__ string equality for cpu_count/current_process/active_children (extra38), AuthenticationError/__name__/__module__/__bases__[0].__name__, ProcessError/__name__/__bases__[0].__name__, BufferTooShort/__name__, TimeoutError/__name__/__bases__[0].__name__, all four exception __module__ string equality (extra39), ProcessError/__mro__.__len__()==4, exception subclass MRO depths (5), Process/__qualname__=='Process', Process/__qualname__.__len__()==7, context.BaseContext/__name__=='BaseContext', get_start_method/__name__=='get_start_method' (extra40)."
    - "This spec covers: Process/__qualname__.__len__()==7 [already covered in extra40, confirmed here]; Queue/__qualname__=='BaseContext.Queue' (17 chars); Pipe/__qualname__=='BaseContext.Pipe' (16 chars); cpu_count/__qualname__=='BaseContext.cpu_count' (21 chars); current_process/__qualname__=='current_process' (15 chars); active_children/__qualname__=='active_children' (15 chars); get_start_method/__qualname__=='DefaultContext.get_start_method' (31 chars); set_start_method/__name__=='set_start_method' (16 chars)."
    - "multiprocessing.Queue.__qualname__ == 'BaseContext.Queue' (17 chars). Queue is not a standalone class but a bound method of BaseContext that creates queue objects; its __qualname__ reflects the owning class. 'BaseContext.Queue': B-a-s-e-C-o-n-t-e-x-t(11) + '.'(1) + Q-u-e-u-e(5) = 17 chars."
    - "multiprocessing.Pipe.__qualname__ == 'BaseContext.Pipe' (16 chars). Like Queue, Pipe is a bound method of BaseContext exposed at the module level. Its __qualname__ reflects the owning class. 'BaseContext.Pipe': B-a-s-e-C-o-n-t-e-x-t(11) + '.'(1) + P-i-p-e(4) = 16 chars."
    - "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count' (21 chars). cpu_count is a bound method of BaseContext; its __qualname__ is 'BaseContext.cpu_count'. 'BaseContext.cpu_count': B-a-s-e-C-o-n-t-e-x-t(11) + '.'(1) + c-p-u-_-c-o-u-n-t(9) = 21 chars."
    - "multiprocessing.current_process.__qualname__ == 'current_process' (15 chars). current_process is a module-level function (not a context method); its __qualname__ equals its __name__. len('current_process') == 15."
    - "multiprocessing.active_children.__qualname__ == 'active_children' (15 chars). active_children is a module-level function; its __qualname__ equals its __name__. len('active_children') == 15. Note that current_process and active_children share the same __qualname__ length of 15."
    - "multiprocessing.get_start_method.__qualname__ == 'DefaultContext.get_start_method' (31 chars). get_start_method is a bound method of DefaultContext (the default context singleton). 'DefaultContext.get_start_method': D-e-f-a-u-l-t-C-o-n-t-e-x-t(14) + '.'(1) + g-e-t-_-s-t-a-r-t-_-m-e-t-h-o-d(16) = 31 chars."
    - "multiprocessing.set_start_method.__name__ == 'set_start_method' (16 chars). Like get_start_method, set_start_method is a bound method of DefaultContext. Its __name__ attribute equals 'set_start_method' (16 chars). len('set_start_method') == 16."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing context-bound method __qualname__ — extra41 namespace
#
# Several multiprocessing module attributes are actually bound methods of the
# default context object, so their __qualname__ includes the owning class name:
#   Queue.__qualname__       == 'BaseContext.Queue'      (17 chars)
#   Pipe.__qualname__        == 'BaseContext.Pipe'       (16 chars)
#   cpu_count.__qualname__   == 'BaseContext.cpu_count'  (21 chars)
# This distinguishes them from module-level functions whose __qualname__ equals
# their __name__ (like current_process and active_children below).
# 'BaseContext' is 11 chars; adding '.' + method name gives the total length.
# ---------------------------------------------------------------------------

table multiprocessing_extra41.context_method_qualnames:
  description: "multiprocessing context-bound method __qualname__ string equality in extra41 namespace — Queue, Pipe, cpu_count"
  kind: python_call_eq
  category: function_names
  id_prefix: mpctxmethqn41

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,     Queue.__qualname__.__eq__,     ["BaseContext.Queue"],     true, "Queue.__qualname__ == 'BaseContext.Queue' — bound method of BaseContext, not a standalone class (17 chars)"]
    - [Pipe,      Pipe.__qualname__.__eq__,      ["BaseContext.Pipe"],      true, "Pipe.__qualname__ == 'BaseContext.Pipe' — bound method of BaseContext, not a standalone class (16 chars)"]
    - [cpu_count, cpu_count.__qualname__.__eq__, ["BaseContext.cpu_count"], true, "cpu_count.__qualname__ == 'BaseContext.cpu_count' — bound method of BaseContext (21 chars)"]

# ---------------------------------------------------------------------------
# multiprocessing module-level function __qualname__ — extra41 namespace
#
# Two functions are implemented at module level (not as context methods):
#   current_process.__qualname__ == 'current_process'  (15 chars)
#   active_children.__qualname__ == 'active_children'  (15 chars)
# For module-level functions, __qualname__ equals __name__. Both share the
# same qualname length of 15 characters. They manage the current process
# hierarchy rather than delegating to a context object.
# ---------------------------------------------------------------------------

table multiprocessing_extra41.module_func_qualnames:
  description: "multiprocessing module-level function __qualname__ string equality in extra41 namespace — current_process, active_children"
  kind: python_call_eq
  category: function_names
  id_prefix: mpmodfuncqn41

  columns: [id, function, args, expected, description]
  rows:
    - [current_process, current_process.__qualname__.__eq__, ["current_process"], true, "current_process.__qualname__ == 'current_process' — module-level function; qualname equals name (15 chars)"]
    - [active_children, active_children.__qualname__.__eq__, ["active_children"], true, "active_children.__qualname__ == 'active_children' — module-level function; qualname equals name (15 chars)"]

# ---------------------------------------------------------------------------
# multiprocessing DefaultContext method __qualname__ and __name__ — extra41
#
# get_start_method and set_start_method are bound methods of DefaultContext:
#   get_start_method.__qualname__ == 'DefaultContext.get_start_method' (31 chars)
#   set_start_method.__name__     == 'set_start_method'                (16 chars)
# DefaultContext inherits get_start_method from DefaultContext (not BaseContext);
# it is overridden in DefaultContext to return the platform default start method.
# 'DefaultContext.get_start_method': 'DefaultContext'(14) + '.'(1) + 'get_start_method'(16) = 31.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra41.get_start_method_qualname_eq:
  description: "multiprocessing.get_start_method.__qualname__ == 'DefaultContext.get_start_method' — bound method of DefaultContext singleton; 31 chars"
  category: function_names
  kind: python_call_eq
  function: get_start_method.__qualname__.__eq__
  args: ["DefaultContext.get_start_method"]
  expected: true

invariant multiprocessing_extra41.set_start_method_name_eq:
  description: "multiprocessing.set_start_method.__name__ == 'set_start_method' — bound method of DefaultContext; __name__ gives the bare method name (16 chars)"
  category: function_names
  kind: python_call_eq
  function: set_start_method.__name__.__eq__
  args: ["set_start_method"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — extra41
# ---------------------------------------------------------------------------

invariant multiprocessing_extra41.Queue_qualname_eq:
  description: "multiprocessing.Queue.__qualname__ == 'BaseContext.Queue' — Queue is a bound method of BaseContext, not a standalone class; 17 chars"
  category: function_names
  kind: python_call_eq
  function: Queue.__qualname__.__eq__
  args: ["BaseContext.Queue"]
  expected: true

invariant multiprocessing_extra41.Pipe_qualname_eq:
  description: "multiprocessing.Pipe.__qualname__ == 'BaseContext.Pipe' — Pipe is a bound method of BaseContext, not a standalone class; 16 chars"
  category: function_names
  kind: python_call_eq
  function: Pipe.__qualname__.__eq__
  args: ["BaseContext.Pipe"]
  expected: true

invariant multiprocessing_extra41.cpu_count_qualname_eq:
  description: "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count' — bound method of BaseContext; 21 chars"
  category: function_names
  kind: python_call_eq
  function: cpu_count.__qualname__.__eq__
  args: ["BaseContext.cpu_count"]
  expected: true

invariant multiprocessing_extra41.current_process_qualname_eq:
  description: "multiprocessing.current_process.__qualname__ == 'current_process' — module-level function; qualname equals name (15 chars)"
  category: function_names
  kind: python_call_eq
  function: current_process.__qualname__.__eq__
  args: ["current_process"]
  expected: true

invariant multiprocessing_extra41.active_children_qualname_eq:
  description: "multiprocessing.active_children.__qualname__ == 'active_children' — module-level function; qualname equals name (15 chars)"
  category: function_names
  kind: python_call_eq
  function: active_children.__qualname__.__eq__
  args: ["active_children"]
  expected: true
