spec: numpy_where_rust
version: ">=3.9"
backend: rust_module(numpy_where_rust)

docs: https://numpy.org/doc/stable/reference/generated/numpy.where.html

provenance:
  derived_from:
    - "https://numpy.org/doc/stable/reference/ — NumPy documentation"
  not_derived_from:
    - "NumPy source: numpy/core/fromnumeric.py"
  notes:
    - "numpy element-wise selection and reduction functions."
    - "where(condition, x, y) returns x where condition is True, y elsewhere as a list."
    - "where([True, False, True], 1, 0) == [1, 0, 1]."
    - "where([True, True, False], 'a', 'b') == ['a', 'a', 'b']."
    - "argmin(arr) returns index of minimum element."
    - "argmin([5, 1, 3, 2]) == 1 — element 1 is smallest."
    - "argmax(arr) returns index of maximum element."
    - "argmax([5, 1, 9, 2]) == 2 — element 9 is largest."
    - "cumsum(arr) returns cumulative sum as a list."
    - "cumsum([1, 2, 3, 4, 5]) == [1, 3, 6, 10, 15]."
    - "cumprod(arr) returns cumulative product as a list."
    - "cumprod([1, 2, 3, 4]) == [1, 2, 6, 24]."
    - "All test vectors verified against numpy 2.2.4."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# where(condition, x, y) — element-wise selection
table numpy_where_rust.where.vectors:
  kind: python_call_eq
  category: where
  id_prefix: nw_wh
  function: where

  columns: [id, args, expected]
  rows:
    - [bool_int,    [[true, false, true], 1, 0],       [1, 0, 1]]
    - [all_true,    [[true, true, true], 10, 20],       [10, 10, 10]]
    - [all_false,   [[false, false], 1, 99],            [99, 99]]
    - [mixed,       [[true, false, false, true], 5, 0], [5, 0, 0, 5]]

# argmin — index of minimum element
table numpy_where_rust.argmin.vectors:
  kind: python_call_eq
  category: argmin
  id_prefix: nw_amin
  function: argmin

  columns: [id, args, expected]
  rows:
    - [basic,     [[5, 1, 3, 2]],      1]
    - [first,     [[1, 2, 3, 4]],      0]
    - [last,      [[4, 3, 2, 1]],      3]
    - [single,    [[42]],              0]

# argmax — index of maximum element
table numpy_where_rust.argmax.vectors:
  kind: python_call_eq
  category: argmax
  id_prefix: nw_amax
  function: argmax

  columns: [id, args, expected]
  rows:
    - [basic,     [[5, 1, 9, 2]],      2]
    - [first,     [[9, 1, 2, 3]],      0]
    - [last,      [[1, 2, 3, 9]],      3]
    - [single,    [[7]],               0]

# cumsum — cumulative sum
table numpy_where_rust.cumsum.vectors:
  kind: python_call_eq
  category: cumsum
  id_prefix: nw_cs
  function: cumsum

  columns: [id, args, expected]
  rows:
    - [one_to_five, [[1, 2, 3, 4, 5]], [1, 3, 6, 10, 15]]
    - [ones,        [[1, 1, 1, 1]],    [1, 2, 3, 4]]
    - [single,      [[5]],             [5]]

# cumprod — cumulative product
table numpy_where_rust.cumprod.vectors:
  kind: python_call_eq
  category: cumprod
  id_prefix: nw_cp
  function: cumprod

  columns: [id, args, expected]
  rows:
    - [factorials, [[1, 2, 3, 4]], [1, 2, 6, 24]]
    - [twos,       [[2, 2, 2, 2]], [2, 4, 8, 16]]
    - [single,     [[7]],          [7]]

