spec: lodash_invertby
version: ">=4.0.0"
backend: node(lodash.invertby)

docs: https://lodash.com/docs/#invertBy

provenance:
  derived_from:
    - "lodash.invertby README — https://www.npmjs.com/package/lodash.invertby"
    - "Test vectors verified with lodash.invertby@4.7.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.invertby exports the _.invertBy function directly as module.exports."
    - "invertBy(object, iteratee) creates an object from value→[keys] groupings."
    - "Without iteratee, groups keys that share the same value."
    - "All result keys are strings (JS object key coercion)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns grouped inversion object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_invertby.invertby:
  kind: node_module_call_eq
  function: ~
  category: invertby
  id_prefix: liby

  columns: [id, args, expected]
  rows:
    - [shared_vals,  [{"a": 1, "b": 2, "c": 1}],  {"1": ["a", "c"], "2": ["b"]}]
    - [unique_vals,  [{"x": 1, "y": 2, "z": 3}],  {"1": ["x"], "2": ["y"], "3": ["z"]}]
