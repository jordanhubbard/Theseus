spec: re_extra871
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - re module CPython source
    - Python 3.9+ standard library documentation
  not_derived_from:
    - any third-party regex implementations
  notes:
    - Covers re module-level attributes and function class names
    - All expected values verified against CPython 3.9+ behavior
  created_at: "2026-04-12"

table re_extra871.module_attrs:
  description: re module-level attributes and function class name introspection
  kind: python_call_eq
  category: module_introspection
  id_prefix: re871xx
  columns: [id, function, args, expected]
  rows:
    - [re871xx001, re.__name__.__eq__, ["re"], true]
    - [re871xx002, re.__package__.__eq__, ["re"], true]
    - [re871xx003, re.__all__.__class__.__name__.__eq__, ["list"], true]
    - [re871xx004, re.__spec__.__class__.__name__.__eq__, ["ModuleSpec"], true]
    - [re871xx005, re.compile.__class__.__name__.__eq__, ["function"], true]
    - [re871xx006, re.match.__class__.__name__.__eq__, ["function"], true]
    - [re871xx007, re.search.__class__.__name__.__eq__, ["function"], true]
    - [re871xx008, re.sub.__class__.__name__.__eq__, ["function"], true]
    - [re871xx009, re.escape.__qualname__.__eq__, ["escape"], true]
    - [re871xx010, re.escape.__module__.__eq__, ["re"], true]
    - [re871xx011, re.purge.__qualname__.__eq__, ["purge"], true]
    - [re871xx012, re.purge.__module__.__eq__, ["re"], true]
