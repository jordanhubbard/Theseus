spec: concurrent_futures_extra233
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html#processpoolexecutor

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html#processpoolexecutor — ProcessPoolExecutor documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "concurrent.futures.ProcessPoolExecutor.submit.__name__ == 'submit' — 6 characters; qualname is 'ProcessPoolExecutor.submit'; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.map.__name__ == 'map' — 3 characters; qualname is 'ProcessPoolExecutor.map'; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.shutdown.__name__ == 'shutdown' — 8 characters; qualname is 'ProcessPoolExecutor.shutdown'; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__init__.__qualname__ == 'ProcessPoolExecutor.__init__' — own __init__; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__enter__.__qualname__ == 'Executor.__enter__' — inherited from Executor; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

