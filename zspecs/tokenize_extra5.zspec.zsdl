spec: tokenize_extra5
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tokenize.html — Python tokenize module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
  notes:
    - "This spec extends tokenize.zspec.zsdl, tokenize_extra.zspec.zsdl, tokenize_extra2.zspec.zsdl, tokenize_extra3.zspec.zsdl, and tokenize_extra4.zspec.zsdl."
    - "tokenize (base) covers: NAME/NUMBER/STRING/NEWLINE/INDENT/DEDENT/OP/COMMENT/ENCODING/NL int checks, function __name__ for tokenize/generate_tokens/detect_encoding."
    - "tokenize_extra covers: TokenInfo/__name__/__module__, TokenError/__name__/bases, function __name__ for tokenize/generate_tokens/detect_encoding/open/untokenize, ENCODING/COMMENT/NAME/NUMBER/STRING/NEWLINE/OP/ENDMARKER int class checks."
    - "tokenize_extra3 covers: function __module__ for tokenize/generate_tokens/untokenize/detect_encoding (table), TokenError/__module__, TokenInfo/__module__, COMMENT/STRING/NUMBER/NAME/ENCODING int class checks (table)."
    - "tokenize_extra4 covers: function __qualname__ for generate_tokens/tokenize/detect_encoding/untokenize (table), TokenInfo/__qualname__, TokenError/__qualname__, open.__module__."
    - "This spec adds: open.__qualname__ == 'open' (not covered in any prior spec), ERRORTOKEN.__class__.__name__ == 'int' (not covered in any tokenize spec), TYPE_COMMENT.__class__.__name__ == 'int' (not covered in any tokenize spec)."
    - "tokenize.ERRORTOKEN is re-exported from the token module and represents a tokenization error token."
    - "tokenize.TYPE_COMMENT is a token constant added in Python 3.8 for type comment support."
    - "tokenize.open.__qualname__ == 'open' — open is a module-level function so qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# open.__qualname__ — not covered in any prior tokenize spec
# tokenize_extra and tokenize_extra2 cover open.__name__ == 'open'
# tokenize_extra4 covers open.__module__ == 'tokenize'
# This adds open.__qualname__ == 'open'
# ---------------------------------------------------------------------------

invariant tokenize_extra5.open.qualname:
  description: "tokenize.open.__qualname__ == 'open'"
  category: function_qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# ERRORTOKEN and TYPE_COMMENT — int class checks not covered in any tokenize spec
# The base tokenize spec covers INDENT/DEDENT/NL/COMMENT/ENCODING/NAME/NUMBER/STRING/NEWLINE/OP.
# tokenize_extra covers ENCODING/COMMENT/NAME/NUMBER/STRING/NEWLINE/OP/ENDMARKER.
# Neither covers ERRORTOKEN or TYPE_COMMENT.
# ---------------------------------------------------------------------------

table tokenize_extra5.extra_token_constant_types:
  kind: python_call_eq
  category: constants
  id_prefix: exttok

  columns: [id, function, args, expected]
  rows:
    - [errortoken,    ERRORTOKEN.__class__.__name__.__eq__,   ["int"], true]
    - [type_comment,  TYPE_COMMENT.__class__.__name__.__eq__, ["int"], true]
