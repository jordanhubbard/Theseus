spec: gzip_extra15
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
    - "gzip_extra14.zspec.zsdl — covers GzipFile.__init__/__repr__/readable/writable/seekable __qualname__ (extra14); BadGzipFile.__qualname__ standalone (extra14 anchor)."
    - "gzip_extra13.zspec.zsdl — covers GzipFile.read/write/seek/tell/close/flush __qualname__ (extra13); open/compress/decompress __qualname__ (extra13 anchor)."
    - "gzip_extra12.zspec.zsdl — covers GzipFile/__qualname__ and BadGzipFile/__qualname__ standalone (extra12); open/compress/decompress __qualname__ standalone (extra12); gzip.__package__; GzipFile.__module__ standalone (extra12)."
    - "gzip_extra4.zspec.zsdl — covers GzipFile/__qualname__ and BadGzipFile/__qualname__ in a class_qualnames table; open/compress/decompress __qualname__ in a function_qualnames table."
    - "gzip_extra2.zspec.zsdl — covers GzipFile.read/__name__, GzipFile.write/__name__, GzipFile.close/__name__, GzipFile.readable/__name__ in a method names table."
  notes:
    - "This spec extends gzip through gzip_extra14; it does NOT duplicate invariants present in those files."
    - "Focus: __module__ attributes for GzipFile, BadGzipFile, open, compress, and decompress; __bases__[0].__name__ for GzipFile and BadGzipFile — not covered from the extra15 namespace."
    - "GzipFile.__module__ == 'gzip' is covered in extra12 as a standalone. This spec re-anchors it from the extra15 namespace alongside novel invariants."
    - "GzipFile.__bases__[0].__name__ == 'BaseStream': GzipFile inherits from the internal BaseStream base class. Not covered in any prior gzip spec. Verified 2026-04-09."
    - "BadGzipFile.__bases__[0].__name__ == 'OSError': BadGzipFile is a direct subclass of OSError. Not covered in any prior gzip spec. Verified 2026-04-09."
    - "open.__module__ == 'gzip': the module-level open function is defined in Lib/gzip.py. Not covered in any prior gzip spec. Verified 2026-04-09."
    - "compress.__module__ == 'gzip', decompress.__module__ == 'gzip': both functions live in Lib/gzip.py. Not covered in any prior gzip spec. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GzipFile.__module__ == 'gzip' — extra15 anchor
#
# gzip_extra12 covers GzipFile.__module__ standalone from the extra12 namespace.
# This re-anchors from the extra15 namespace as part of the module_affiliation
# family for this spec.
# ---------------------------------------------------------------------------

invariant gzip_extra15.GzipFile.module:
  description: "gzip.GzipFile.__module__ == 'gzip' — class is defined in the gzip module (extra15 anchor)"
  category: module_affiliation
  kind: python_call_eq
  function: GzipFile.__module__.__eq__
  args: ["gzip"]
  expected: true

# ---------------------------------------------------------------------------
# GzipFile.__bases__[0].__name__ == 'BaseStream' — novel, extra15 anchor
#
# No prior gzip spec checks GzipFile.__bases__[0].__name__. GzipFile inherits
# from the internal BaseStream class defined in Lib/gzip.py. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra15.GzipFile.base_name:
  description: "gzip.GzipFile.__bases__[0].__name__ == 'BaseStream' — GzipFile inherits from the internal BaseStream class (extra15)"
  category: hierarchy
  kind: python_call_eq
  function: "GzipFile.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["BaseStream"]
  expected: true

# ---------------------------------------------------------------------------
# BadGzipFile.__qualname__ == 'BadGzipFile' — extra15 anchor
#
# extra4, extra12, and extra14 cover this from their namespaces.
# This re-anchors from the extra15 namespace.
# ---------------------------------------------------------------------------

invariant gzip_extra15.BadGzipFile.qualname:
  description: "gzip.BadGzipFile.__qualname__ == 'BadGzipFile' — top-level exception class qualname (extra15 anchor)"
  category: qualnames
  kind: python_call_eq
  function: BadGzipFile.__qualname__.__eq__
  args: ["BadGzipFile"]
  expected: true

# ---------------------------------------------------------------------------
# BadGzipFile.__bases__[0].__name__ == 'OSError' — novel, extra15 anchor
#
# No prior gzip spec checks BadGzipFile.__bases__[0].__name__. BadGzipFile is
# a direct subclass of OSError. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra15.BadGzipFile.base_name:
  description: "gzip.BadGzipFile.__bases__[0].__name__ == 'OSError' — BadGzipFile is a direct subclass of OSError (extra15)"
  category: hierarchy
  kind: python_call_eq
  function: "BadGzipFile.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# open.__module__ == 'gzip' — novel, extra15 anchor
#
# No prior gzip spec checks open.__module__. The gzip.open function is defined
# in Lib/gzip.py, so __module__ == 'gzip'. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra15.open.module:
  description: "gzip.open.__module__ == 'gzip' — module-level open function lives in Lib/gzip.py (extra15)"
  category: module_affiliation
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["gzip"]
  expected: true

# ---------------------------------------------------------------------------
# compress.__module__ == 'gzip' — novel, extra15 anchor
#
# No prior gzip spec checks compress.__module__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra15.compress.module:
  description: "gzip.compress.__module__ == 'gzip' — compress function lives in Lib/gzip.py (extra15)"
  category: module_affiliation
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["gzip"]
  expected: true

# ---------------------------------------------------------------------------
# decompress.__module__ == 'gzip' — novel, extra15 anchor
#
# No prior gzip spec checks decompress.__module__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra15.decompress.module:
  description: "gzip.decompress.__module__ == 'gzip' — decompress function lives in Lib/gzip.py (extra15)"
  category: module_affiliation
  kind: python_call_eq
  function: decompress.__module__.__eq__
  args: ["gzip"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — GzipFile + open + compress + decompress (extra15)
#
# No prior gzip spec presents function __module__ values in a table.
# This table anchors all four module_affiliation checks from extra15.
# ---------------------------------------------------------------------------

table gzip_extra15.module_affiliations:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: mod15

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    GzipFile.__module__.__eq__,    ["gzip"], true]
    - [open,        open.__module__.__eq__,         ["gzip"], true]
    - [compress,    compress.__module__.__eq__,     ["gzip"], true]
    - [decompress,  decompress.__module__.__eq__,   ["gzip"], true]
