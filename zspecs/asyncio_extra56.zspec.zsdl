spec: asyncio_extra56
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio tasks and coroutines documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec extends asyncio_extra55.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ (extra/extra2/extra5), Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), BoundedSemaphore/__bases__[0].__qualname__=='Semaphore' (extra53), Condition/__bases__[0].__qualname__=='object' (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') for Queue/Lock/Event/Semaphore/Condition (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55)."
    - "This spec covers: asyncio class __repr__.__class__.__name__ — no prior asyncio spec has captured any __repr__.__class__ attribute. Queue/Lock/Event/Semaphore each define __repr__ as a plain Python function in Lib/asyncio, so __repr__.__class__.__name__ == 'function'. Also: Queue/Lock/Event/Semaphore __weakref__.__class__.__name__ — pure-Python classes defined in Lib/asyncio automatically receive a __weakref__ getset_descriptor; no prior asyncio spec captured __weakref__.__class__.__name__. Also: gather/sleep/wait __repr__.__class__.__name__ — for a module-level function object, its __repr__ is a method-wrapper (the bound __repr__ slot from the 'function' type), so __repr__.__class__.__name__ == 'method-wrapper'."
    - "asyncio.Queue.__repr__.__class__.__name__ == 'function'. Queue defines __repr__ directly in Lib/asyncio/queues.py as a plain Python function. Plain Python functions are objects of the built-in 'function' type, so Queue.__repr__.__class__.__name__ == 'function'. No prior asyncio spec has captured any __repr__.__class__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__repr__.__class__.__name__ == 'function'. Lock defines __repr__ in Lib/asyncio/locks.py as a plain Python function; its __repr__.__class__.__name__ == 'function'. Novel __repr__.__class__.__name__ check for Lock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__repr__.__class__.__name__ == 'function'. Event defines __repr__ in Lib/asyncio/locks.py as a plain Python function; its __repr__.__class__.__name__ == 'function'. Novel __repr__.__class__.__name__ check for Event. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__repr__.__class__.__name__ == 'function'. Semaphore defines __repr__ in Lib/asyncio/locks.py as a plain Python function; its __repr__.__class__.__name__ == 'function'. Novel __repr__.__class__.__name__ check for Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__weakref__.__class__.__name__ == 'getset_descriptor'. Pure-Python classes defined in Lib/asyncio automatically receive a __weakref__ slot managed by a getset_descriptor. Queue.__weakref__.__class__.__name__ == 'getset_descriptor'. No prior asyncio spec captured __weakref__.__class__.__name__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__weakref__.__class__.__name__ == 'getset_descriptor'. Lock is a pure-Python class defined in Lib/asyncio/locks.py; its __weakref__ slot is managed by a getset_descriptor. Novel __weakref__.__class__.__name__ check for Lock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__weakref__.__class__.__name__ == 'getset_descriptor'. Event is a pure-Python class in Lib/asyncio/locks.py; its __weakref__ slot is managed by a getset_descriptor. Novel __weakref__.__class__.__name__ check for Event. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__weakref__.__class__.__name__ == 'getset_descriptor'. Semaphore is a pure-Python class in Lib/asyncio/locks.py; its __weakref__ slot is managed by a getset_descriptor. Novel __weakref__.__class__.__name__ check for Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__repr__.__class__.__name__ == 'method-wrapper'. gather is a module-level function object (plain Python function). When you access func.__repr__ on a function instance, Python returns the bound __repr__ method-wrapper from the 'function' type — a C-level slot wrapper bound to the specific function object. Therefore gather.__repr__.__class__.__name__ == 'method-wrapper'. This is distinct from the class-level __repr__ (which would be 'function' or 'wrapper_descriptor'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__repr__.__class__.__name__ == 'method-wrapper'. sleep is a module-level coroutine function object; func.__repr__ is a bound method-wrapper from the 'function' type's C-level slot; __repr__.__class__.__name__ == 'method-wrapper'. Novel check for sleep. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.wait.__repr__.__class__.__name__ == 'method-wrapper'. wait is a module-level coroutine function object; func.__repr__ is a bound method-wrapper; __repr__.__class__.__name__ == 'method-wrapper'. Novel check for wait. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio class __repr__.__class__.__name__ string equality — extra56
#
# Queue, Lock, Event, and Semaphore each define __repr__ directly in Lib/asyncio
# as plain Python functions. A plain Python function is an object of the built-in
# 'function' type, so:
#   Queue.__repr__.__class__.__name__     == 'function'
#   Lock.__repr__.__class__.__name__      == 'function'
#   Event.__repr__.__class__.__name__     == 'function'
#   Semaphore.__repr__.__class__.__name__ == 'function'
#
# No prior asyncio spec has captured any __repr__.__class__ attribute.
# Extra56 introduces this dimension in the asynciorepr56 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra56.repr_class_name_eq:
  description: "asyncio class __repr__.__class__.__name__ string equality in asynciorepr56 namespace — Queue/Lock/Event/Semaphore define __repr__ as plain Python functions; no prior asyncio spec captured any __repr__.__class__ attribute"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciorepr56clsrepr

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,     Queue.__repr__.__class__.__name__.__eq__,     ["function"], true, "Queue.__repr__.__class__.__name__ == 'function' — Queue defines __repr__ in Lib/asyncio/queues.py as a plain Python function; the 'function' type is the built-in function type; first __repr__.__class__.__name__ check in any asyncio spec"]
    - [Lock,      Lock.__repr__.__class__.__name__.__eq__,      ["function"], true, "Lock.__repr__.__class__.__name__ == 'function' — Lock defines __repr__ in Lib/asyncio/locks.py as a plain Python function; __repr__.__class__.__name__ == 'function'"]
    - [Event,     Event.__repr__.__class__.__name__.__eq__,     ["function"], true, "Event.__repr__.__class__.__name__ == 'function' — Event defines __repr__ in Lib/asyncio/locks.py as a plain Python function; __repr__.__class__.__name__ == 'function'"]
    - [Semaphore, Semaphore.__repr__.__class__.__name__.__eq__, ["function"], true, "Semaphore.__repr__.__class__.__name__ == 'function' — Semaphore defines __repr__ in Lib/asyncio/locks.py as a plain Python function; __repr__.__class__.__name__ == 'function'"]

# ---------------------------------------------------------------------------
# asyncio class __weakref__.__class__.__name__ string equality — extra56
#
# Pure-Python classes defined in Lib/asyncio automatically receive a __weakref__
# slot. This slot is exposed as a getset_descriptor on the class. Therefore:
#   Queue.__weakref__.__class__.__name__     == 'getset_descriptor'
#   Lock.__weakref__.__class__.__name__      == 'getset_descriptor'
#   Event.__weakref__.__class__.__name__     == 'getset_descriptor'
#   Semaphore.__weakref__.__class__.__name__ == 'getset_descriptor'
#
# No prior asyncio spec has captured __weakref__.__class__.__name__.
# Extra56 introduces this dimension in the asynciorepr56 namespace.
# ---------------------------------------------------------------------------

table asyncio_extra56.weakref_class_name_eq:
  description: "asyncio class __weakref__.__class__.__name__ string equality in asynciorepr56 namespace — Queue/Lock/Event/Semaphore are pure-Python classes with __weakref__ getset_descriptor; no prior asyncio spec captured __weakref__.__class__.__name__"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciorepr56clsweakref

  columns: [id, function, args, expected, description]
  rows:
    - [Queue,     Queue.__weakref__.__class__.__name__.__eq__,     ["getset_descriptor"], true, "Queue.__weakref__.__class__.__name__ == 'getset_descriptor' — Queue is a pure-Python class; Python automatically provides a __weakref__ getset_descriptor for weakref support; first __weakref__.__class__.__name__ check in any asyncio spec"]
    - [Lock,      Lock.__weakref__.__class__.__name__.__eq__,      ["getset_descriptor"], true, "Lock.__weakref__.__class__.__name__ == 'getset_descriptor' — Lock is a pure-Python class in Lib/asyncio/locks.py; its __weakref__ is a getset_descriptor"]
    - [Event,     Event.__weakref__.__class__.__name__.__eq__,     ["getset_descriptor"], true, "Event.__weakref__.__class__.__name__ == 'getset_descriptor' — Event is a pure-Python class in Lib/asyncio/locks.py; its __weakref__ is a getset_descriptor"]
    - [Semaphore, Semaphore.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true, "Semaphore.__weakref__.__class__.__name__ == 'getset_descriptor' — Semaphore is a pure-Python class in Lib/asyncio/locks.py; its __weakref__ is a getset_descriptor"]

# ---------------------------------------------------------------------------
# asyncio function __repr__.__class__.__name__ string equality — extra56
#
# For a module-level function object f, f.__repr__ is not the class-level
# __repr__ descriptor but rather the bound method-wrapper produced by the
# 'function' type's C-level __repr__ slot bound to that specific function
# instance. Therefore:
#   gather.__repr__.__class__.__name__ == 'method-wrapper'
#   sleep.__repr__.__class__.__name__  == 'method-wrapper'
#   wait.__repr__.__class__.__name__   == 'method-wrapper'
#
# This is an instance-level access (method-wrapper) rather than a class-level
# access (which would be 'wrapper_descriptor'). No prior asyncio spec captured
# function __repr__.__class__.__name__.
# ---------------------------------------------------------------------------

table asyncio_extra56.function_repr_class_name_eq:
  description: "asyncio function __repr__.__class__.__name__ string equality in asynciorepr56 namespace — gather/sleep/wait are function instances; func.__repr__ is a bound method-wrapper from the function type's C-level slot; no prior asyncio spec captured function __repr__.__class__.__name__"
  kind: python_call_eq
  category: class_names
  id_prefix: asynciorepr56fnrepr

  columns: [id, function, args, expected, description]
  rows:
    - [gather, gather.__repr__.__class__.__name__.__eq__, ["method-wrapper"], true, "gather.__repr__.__class__.__name__ == 'method-wrapper' — gather is a function instance; func.__repr__ returns a bound C-level method-wrapper (not the class-level descriptor); __repr__.__class__.__name__ == 'method-wrapper'; first asyncio function __repr__.__class__.__name__ check"]
    - [sleep,  sleep.__repr__.__class__.__name__.__eq__,  ["method-wrapper"], true, "sleep.__repr__.__class__.__name__ == 'method-wrapper' — sleep is a coroutine function instance; func.__repr__ is a bound method-wrapper from the 'function' type's C slot; __repr__.__class__.__name__ == 'method-wrapper'"]
    - [wait,   wait.__repr__.__class__.__name__.__eq__,   ["method-wrapper"], true, "wait.__repr__.__class__.__name__ == 'method-wrapper' — wait is a coroutine function instance; func.__repr__ is a bound method-wrapper; __repr__.__class__.__name__ == 'method-wrapper'"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra56
# ---------------------------------------------------------------------------

invariant asyncio_extra56.Queue_repr_class_name_eq:
  description: "asyncio.Queue.__repr__.__class__.__name__ == 'function' — Queue defines __repr__ in Lib/asyncio/queues.py as a plain Python function; the 'function' type is the built-in function type; first __repr__.__class__.__name__ check in any asyncio spec"
  category: class_names
  kind: python_call_eq
  function: Queue.__repr__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra56.Lock_repr_class_name_eq:
  description: "asyncio.Lock.__repr__.__class__.__name__ == 'function' — Lock defines __repr__ in Lib/asyncio/locks.py as a plain Python function; __repr__.__class__.__name__ == 'function'; novel __repr__.__class__.__name__ check for Lock"
  category: class_names
  kind: python_call_eq
  function: Lock.__repr__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant asyncio_extra56.Queue_weakref_class_name_eq:
  description: "asyncio.Queue.__weakref__.__class__.__name__ == 'getset_descriptor' — Queue is a pure-Python class; Python automatically provides a __weakref__ getset_descriptor slot for weakref support; first __weakref__.__class__.__name__ check in any asyncio spec"
  category: class_names
  kind: python_call_eq
  function: Queue.__weakref__.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant asyncio_extra56.Lock_weakref_class_name_eq:
  description: "asyncio.Lock.__weakref__.__class__.__name__ == 'getset_descriptor' — Lock is a pure-Python class in Lib/asyncio/locks.py; its __weakref__ slot is managed by a getset_descriptor; novel __weakref__.__class__.__name__ check for Lock"
  category: class_names
  kind: python_call_eq
  function: Lock.__weakref__.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

invariant asyncio_extra56.gather_repr_class_name_eq:
  description: "asyncio.gather.__repr__.__class__.__name__ == 'method-wrapper' — gather is a module-level function instance; accessing __repr__ on a function instance yields a bound C-level method-wrapper (the 'function' type's __repr__ slot bound to the instance); __repr__.__class__.__name__ == 'method-wrapper'; first asyncio function __repr__.__class__.__name__ check"
  category: class_names
  kind: python_call_eq
  function: gather.__repr__.__class__.__name__.__eq__
  args: ["method-wrapper"]
  expected: true

invariant asyncio_extra56.sleep_repr_class_name_eq:
  description: "asyncio.sleep.__repr__.__class__.__name__ == 'method-wrapper' — sleep is a coroutine function instance; func.__repr__ is a bound method-wrapper from the 'function' type's C slot; __repr__.__class__.__name__ == 'method-wrapper'"
  category: class_names
  kind: python_call_eq
  function: sleep.__repr__.__class__.__name__.__eq__
  args: ["method-wrapper"]
  expected: true
