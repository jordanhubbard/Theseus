spec: it3016
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 648 (it3016): __iter__, __next__, __reversed__ dict-presence checks for itertools types."
    - "itertools types are lazy iterator classes implemented in C — all define __iter__ and __next__ in their own __dict__, none define __reversed__."
    - "Verified types: itertools.chain, itertools.cycle, itertools.count, itertools.islice, itertools.product, itertools.permutations, itertools.combinations, itertools.groupby, itertools.starmap, itertools.zip_longest, itertools.takewhile, itertools.dropwhile, itertools.filterfalse, itertools.compress, itertools.accumulate, itertools.repeat, itertools.combinations_with_replacement, itertools.pairwise."
    - "itertools.pairwise requires Python >= 3.10."
    - "All itertools iterator types are their own iterators (they define both __iter__ and __next__ directly)."
    - "None define __reversed__ as they are forward-only lazy iterators."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table it3016.iter:
  description: "itertools types __iter__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it3016
  columns: [id, function, args, expected]
  rows:
    - ["it3016001", operator.contains, [itertools.chain.__dict__,                        "__iter__"], true]
    - ["it3016002", operator.contains, [itertools.cycle.__dict__,                        "__iter__"], true]
    - ["it3016003", operator.contains, [itertools.count.__dict__,                        "__iter__"], true]
    - ["it3016004", operator.contains, [itertools.islice.__dict__,                       "__iter__"], true]
    - ["it3016005", operator.contains, [itertools.product.__dict__,                      "__iter__"], true]
    - ["it3016006", operator.contains, [itertools.permutations.__dict__,                 "__iter__"], true]

