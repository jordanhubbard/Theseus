spec: io_extra240
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io.open function behavioral contracts."
    - "io.open.__name__ == 'open' — the function is named 'open' (same as the builtin); verified Python 3.14.3 macOS."
    - "io.open.__module__ == '_io' — io.open is implemented in the _io C extension; verified Python 3.14.3 macOS."
    - "io.open.__qualname__ == 'open' — qualname equals name (top-level function); verified Python 3.14.3 macOS."
    - "type(io.open).__name__ == 'builtin_function_or_method' — io.open is a C builtin; verified Python 3.14.3 macOS."
    - "io.open.__doc__.__contains__('file') == True — docstring mentions 'file'; verified Python 3.14.3 macOS."
    - "io.open.__doc__.__contains__('stream') == True — docstring mentions 'stream'; verified Python 3.14.3 macOS."
    - "io.open.__name__.__len__() == 4 — 'open' has 4 characters; verified Python 3.14.3 macOS."
    - "io.open.__module__.__len__() == 3 — '_io' has 3 characters; verified Python 3.14.3 macOS."
    - "io.open.__name__.__eq__('open') is True — io.open is the same function as the builtin open; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.open function __name__ and __module__ contracts
# io.open is the same underlying function as the builtin open, defined in _io.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra240.open.name:
  description: "io.open.__name__ == 'open' — function name is 'open'; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant io_extra240.open.module:
  description: "io.open.__module__ == '_io' — io.open is implemented in _io C extension; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra240.open.qualname:
  description: "io.open.__qualname__ == 'open' — qualname equals name for top-level function; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant io_extra240.open.type_name:
  description: "type(io.open).__name__ == 'builtin_function_or_method' — io.open is a C builtin; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# io.open __doc__ content contracts
# The docstring must mention 'file' and 'stream' as expected for an open() doc.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra240.open.doc_contains_file:
  description: "io.open.__doc__.__contains__('file') == True — docstring mentions 'file'; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: open.__doc__.__contains__
  args: ["file"]
  expected: true

invariant io_extra240.open.doc_contains_stream:
  description: "io.open.__doc__.__contains__('stream') == True — docstring mentions 'stream'; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: open.__doc__.__contains__
  args: ["stream"]
  expected: true

# ---------------------------------------------------------------------------
# io.open function name length contracts
# Spot-check name and module string lengths.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra240.open.name_length:
  description: "io.open.__name__.__len__() == 4 — 'open' has 4 characters; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: open.__name__.__len__
  args: []
  expected: 4

invariant io_extra240.open.module_length:
  description: "io.open.__module__.__len__() == 3 — '_io' has 3 characters; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: open.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# io.open name equality checks
# Verify that the name does not equal other function names.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra240.open_name_checks:
  description: "io.open.__name__ equality checks — 'open' matches itself but not 'io' or 'Open'; verified Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: ioopenname240

  columns: [id, function, args, expected]
  rows:
    - [name_eq_open,    open.__name__.__eq__,  ["open"],   true]
    - [name_ne_io,      open.__name__.__eq__,  ["io"],     false]
    - [name_ne_Open,    open.__name__.__eq__,  ["Open"],   false]
    - [module_eq_io,    open.__module__.__eq__, ["_io"],   true]
    - [module_ne_io_py, open.__module__.__eq__, ["io"],    false]
