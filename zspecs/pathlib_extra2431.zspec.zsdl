spec: pathlib_extra2431
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/pathlib.html"
    - "CPython source — Lib/pathlib/__init__.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2431: __aiter__ and __anext__ async iteration protocol dict-presence for pathlib types."
    - "pathlib path classes are pure sync filesystem objects; none implement the async iteration protocol."
    - "PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath do not define __aiter__ or __anext__ in their class __dict__."
    - "pathlib.UnsupportedOperation, PathInfo, and DirEntryInfo are utility/info classes that also lack async iteration."
    - "The absence of __aiter__ and __anext__ is consistent with these classes also lacking __iter__ and __next__ — path objects are not iterators."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ===
# Table 1: __aiter__ in class __dict__ — pure path classes
# ===

table pathlib_extra2431.aiter_in_dict_pure:
  description: "__aiter__ dict-presence for pathlib pure path classes — none define async iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2431
  columns: [id, function, args, expected]
  rows:
    - ["pp2431001", "pathlib.PurePath.__dict__.__contains__", ["__aiter__"], false]
    - ["pp2431002", "pathlib.PurePosixPath.__dict__.__contains__", ["__aiter__"], false]
    - ["pp2431003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__aiter__"], false]
    - ["pp2431004", "pathlib.Path.__dict__.__contains__", ["__aiter__"], false]
    - ["pp2431005", "pathlib.PosixPath.__dict__.__contains__", ["__aiter__"], false]

