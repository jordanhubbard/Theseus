spec: py_compile_extra7
version: ">=3.9"
backend: python_module(py_compile)

docs: https://docs.python.org/3/library/py_compile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/py_compile.html — Python py_compile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/py_compile.py"
    - "py_compile.zspec.zsdl — covers compile/__name__/__module__, PyCompileError/__name__/base/__str__.__name__, PycInvalidationMode/__name__ and TIMESTAMP/CHECKED_HASH/UNCHECKED_HASH class names and values"
    - "py_compile_extra.zspec.zsdl — covers compile/__name__/__module__, PycInvalidationMode/__name__, PyCompileError/__name__/__module__/base, enum member class names/values, value ordering"
    - "py_compile_extra2.zspec.zsdl — covers PycInvalidationMode/__module__/__bases__[0]/__name__=='int', class_names table"
    - "py_compile_extra3.zspec.zsdl — covers compile/__qualname__, PycInvalidationMode/__qualname__, PyCompileError/__qualname__ via table"
    - "py_compile_extra4.zspec.zsdl — covers compile/__class__.__name__=='function', PyCompileError/__bases__/__len__()==1, PyCompileError/__str__.__module__, PycInvalidationMode/_member_names_ len/membership, PycInvalidationMode TIMESTAMP/CHECKED_HASH/UNCHECKED_HASH .name attribute"
    - "py_compile_extra5.zspec.zsdl — covers PycInvalidationMode/_value2member_map_ len/membership, UNCHECKED_HASH.value.__gt__(1), PyCompileError.__init__.__name__, compile/__doc__ is str, PyCompileError/__doc__ is str"
    - "py_compile_extra6.zspec.zsdl — covers PycInvalidationMode metaclass EnumType/__module__; PyCompileError.__init__/__str__ __qualname__; qualname string lengths; PycInvalidationMode.__doc__ is None; compile.__qualname__.__eq__"
  notes:
    - "This spec covers axes not tested in any prior py_compile spec."
    - "PyCompileError.__mro__[1].__name__ == 'Exception' — MRO entry not covered in any prior spec."
    - "PyCompileError.__mro__[2].__name__ == 'BaseException' — MRO entry not covered in any prior spec."
    - "PyCompileError.__mro__[3].__name__ == 'object' — MRO entry not covered in any prior spec."
    - "PyCompileError.__mro__.__len__() == 4 — MRO length not covered in any prior spec."
    - "PycInvalidationMode.__mro__[1].__name__ == 'Enum' — MRO entry not covered; py_compile_extra2 checks __bases__[0].__name__=='int' which is for the IntEnum mixin, but PycInvalidationMode is plain Enum in Python 3.12."
    - "PycInvalidationMode.__mro__.__len__() == 3 — MRO length not covered in any prior spec."
    - "PycInvalidationMode.TIMESTAMP.__class__.__name__ == 'PycInvalidationMode' — enum member class identity not covered."
    - "PycInvalidationMode.CHECKED_HASH.__class__.__name__ == 'PycInvalidationMode' — enum member class identity not covered."
    - "py_compile module __name__ attribute == 'py_compile' — module-level __name__ not covered in any prior spec."
    - "PyCompileError.__name__.__len__() == 14 — string length of class name not covered (extra6 checks __qualname__ length)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PyCompileError MRO entries
# py_compile_extra4 checks PyCompileError.__bases__.__len__() == 1 and
# PyCompileError.__bases__[0].__name__ (Exception) but not the full MRO chain.
# No prior spec checks MRO[1], MRO[2], MRO[3] for PyCompileError.
# ---------------------------------------------------------------------------

invariant py_compile_extra7.PyCompileError.mro1_name:
  description: "py_compile.PyCompileError.__mro__[1].__name__ == 'Exception'"
  category: PyCompileError
  kind: python_call_eq
  function: PyCompileError.__mro__.__getitem__
  args: [1]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

invariant py_compile_extra7.PyCompileError.mro2_name:
  description: "py_compile.PyCompileError.__mro__[2].__name__ == 'BaseException'"
  category: PyCompileError
  kind: python_call_eq
  function: PyCompileError.__mro__.__getitem__
  args: [2]
  method: __name__.__eq__
  method_args: ["BaseException"]
  expected: true

invariant py_compile_extra7.PyCompileError.mro3_name:
  description: "py_compile.PyCompileError.__mro__[3].__name__ == 'object'"
  category: PyCompileError
  kind: python_call_eq
  function: PyCompileError.__mro__.__getitem__
  args: [3]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant py_compile_extra7.PyCompileError.mro_len:
  description: "len(py_compile.PyCompileError.__mro__) == 4 — PyCompileError, Exception, BaseException, object"
  category: PyCompileError
  kind: python_call_eq
  function: PyCompileError.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# PycInvalidationMode MRO entries
# py_compile_extra2 checks __bases__[0].__name__; no prior spec checks MRO entries
# or the total MRO length for PycInvalidationMode.
# ---------------------------------------------------------------------------

invariant py_compile_extra7.PycInvalidationMode.mro1_name:
  description: "py_compile.PycInvalidationMode.__mro__[1].__name__ == 'Enum'"
  category: PycInvalidationMode
  kind: python_call_eq
  function: PycInvalidationMode.__mro__.__getitem__
  args: [1]
  method: __name__.__eq__
  method_args: ["Enum"]
  expected: true

invariant py_compile_extra7.PycInvalidationMode.mro_len:
  description: "len(py_compile.PycInvalidationMode.__mro__) == 3 — PycInvalidationMode, Enum, object"
  category: PycInvalidationMode
  kind: python_call_eq
  function: PycInvalidationMode.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Enum member class identity: TIMESTAMP and CHECKED_HASH __class__.__name__
# py_compile_extra1 checks member class names as string values.
# No prior spec uses the __class__.__name__.__eq__ chain for these members.
# ---------------------------------------------------------------------------

invariant py_compile_extra7.PycInvalidationMode.TIMESTAMP_class_name:
  description: "py_compile.PycInvalidationMode.TIMESTAMP.__class__.__name__ == 'PycInvalidationMode'"
  category: PycInvalidationMode
  kind: python_call_eq
  function: PycInvalidationMode.TIMESTAMP.__class__.__name__.__eq__
  args: ["PycInvalidationMode"]
  expected: true

invariant py_compile_extra7.PycInvalidationMode.CHECKED_HASH_class_name:
  description: "py_compile.PycInvalidationMode.CHECKED_HASH.__class__.__name__ == 'PycInvalidationMode'"
  category: PycInvalidationMode
  kind: python_call_eq
  function: PycInvalidationMode.CHECKED_HASH.__class__.__name__.__eq__
  args: ["PycInvalidationMode"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level __name__ attribute
# py_compile_extra5 does not check the module's own __name__ attribute.
# code_extra5 introduced this pattern for the code module; new here for py_compile.
# ---------------------------------------------------------------------------

invariant py_compile_extra7.module.name:
  description: "py_compile.__name__ == 'py_compile' — the module's own __name__ attribute"
  category: module_metadata
  kind: python_call_eq
  function: __name__.__eq__
  args: ["py_compile"]
  expected: true

# ---------------------------------------------------------------------------
# PyCompileError.__name__ string length
# py_compile_extra6 checks __qualname__.__len__() for various symbols.
# The class __name__ length (as distinct from __qualname__ length, which are
# identical for a top-level class) has not been explicitly checked.
# ---------------------------------------------------------------------------

invariant py_compile_extra7.PyCompileError.name_len:
  description: "len(py_compile.PyCompileError.__name__) == 14 — 'PyCompileError' has 14 characters"
  category: PyCompileError
  kind: python_call_eq
  function: PyCompileError.__name__.__len__
  args: []
  expected: 14
