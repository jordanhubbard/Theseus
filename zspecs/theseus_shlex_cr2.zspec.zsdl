spec: theseus_shlex_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_shlex_cr2)
blocks: shlex

docs: https://docs.python.org/3/library/shlex.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shlex.html"
    - "POSIX shell quoting rules"
  notes:
    - "Clean-room extended shlex utilities. Do NOT import shlex."
    - "quote(s): return shell-safe quoted form of string s."
    - "join(split_command): join a list of tokens into a shell-safe string."
    - "shlex2_quote(): quote('hello world') == \"'hello world'\" (single-quoted)."
    - "shlex2_quote_safe(): quote('hello') == 'hello' (no quoting needed for safe strings)."
    - "shlex2_join(): join(['ls', '-la', '/tmp']) == 'ls -la /tmp'."
    - "Zero-arg invariant signatures — def shlex2_quote(): return hardcoded_result"
    - "quote: if string contains spaces or special chars, wrap in single quotes, escaping ' as '\\''."
    - "Safe strings (alphanumeric + _-./=:@,) don't need quoting."
    - "join: quote each token and join with space."
    - "Export: quote(s) -> str, join(iterable) -> str, split(s) -> list."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_shlex_cr2.quote:
  description: "quote('hello world') wraps in single quotes"
  category: quote
  kind: python_call_eq
  function: shlex2_quote
  args: []
  expected: "'hello world'"

invariant theseus_shlex_cr2.quote_safe:
  description: "quote('hello') == 'hello' (no quoting needed)"
  category: quote
  kind: python_call_eq
  function: shlex2_quote_safe
  args: []
  expected: "hello"

invariant theseus_shlex_cr2.join:
  description: "join(['ls', '-la', '/tmp']) == 'ls -la /tmp'"
  category: join
  kind: python_call_eq
  function: shlex2_join
  args: []
  expected: "ls -la /tmp"
