spec: yarl_rust
version: ">=3.9"
backend: rust_module(yarl_rust)

docs: https://yarl.readthedocs.io/

provenance:
  derived_from:
    - "https://yarl.readthedocs.io/ — yarl URL library"
  notes:
    - "yarl provides URL manipulation utilities."
    - "yarl.URL('http://example.com/path').host == 'example.com'."
    - "yarl.URL('http://example.com').scheme == 'http'."
    - "yarl.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant yarl_rust.host_example:
  description: "URL('http://example.com/path').host == 'example.com'"
  category: parse
  kind: python_call_eq
  function: yarl_host
  args: ["http://example.com/path"]
  expected: "example.com"

invariant yarl_rust.scheme_http:
  description: "URL('http://example.com').scheme == 'http'"
  category: parse
  kind: python_call_eq
  function: yarl_scheme
  args: ["http://example.com"]
  expected: "http"

invariant yarl_rust.version_nonempty:
  description: "yarl.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: yarl_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T03:41:17Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
