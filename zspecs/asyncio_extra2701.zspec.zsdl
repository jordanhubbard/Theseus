spec: asyncio_extra2701
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 627 (_extra2701): __lshift__, __rshift__, __invert__ dict-presence checks."
    - "asyncio types (Queue, Task, Future, Lock, Event, Semaphore, Condition, Barrier) are concurrency primitives, not bitwise types."
    - "None of these types define left-shift, right-shift, or bitwise NOT protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __lshift__ dict-presence checks
#
# Wave 627 theme: asyncio concurrency types do not implement the left-shift
# operator. Neither __lshift__ nor its reflected variant __rlshift__ appear
# in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2701.lshift_protocol:
  description: "asyncio types __lshift__/__rlshift__ dict-presence checks — none define left-shift in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2701

  columns: [id, function, args, expected]
  rows:
    - ["as2701001", "asyncio.Queue.__dict__.__contains__",     ["__lshift__"],  false]
    - ["as2701002", "asyncio.Queue.__dict__.__contains__",     ["__rlshift__"], false]
    - ["as2701003", "asyncio.Task.__dict__.__contains__",      ["__lshift__"],  false]
    - ["as2701004", "asyncio.Task.__dict__.__contains__",      ["__rlshift__"], false]
    - ["as2701005", "asyncio.Future.__dict__.__contains__",    ["__lshift__"],  false]
    - ["as2701006", "asyncio.Future.__dict__.__contains__",    ["__rlshift__"], false]
    - ["as2701007", "asyncio.Lock.__dict__.__contains__",      ["__lshift__"],  false]
    - ["as2701008", "asyncio.Lock.__dict__.__contains__",      ["__rlshift__"], false]
    - ["as2701009", "asyncio.Event.__dict__.__contains__",     ["__lshift__"],  false]
    - ["as2701010", "asyncio.Event.__dict__.__contains__",     ["__rlshift__"], false]
    - ["as2701011", "asyncio.Semaphore.__dict__.__contains__", ["__lshift__"],  false]
    - ["as2701012", "asyncio.Semaphore.__dict__.__contains__", ["__rlshift__"], false]

# ---------------------------------------------------------------------------
# Table 2: __rshift__ dict-presence checks
#
# Wave 627 theme: asyncio concurrency types do not implement the right-shift
# operator. Neither __rshift__ nor its reflected variant __rrshift__ appear
# in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2701.rshift_protocol:
  description: "asyncio types __rshift__/__rrshift__ dict-presence checks — none define right-shift in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2701

  columns: [id, function, args, expected]
  rows:
    - ["as2701013", "asyncio.Queue.__dict__.__contains__",       ["__rshift__"],  false]
    - ["as2701014", "asyncio.Queue.__dict__.__contains__",       ["__rrshift__"], false]
    - ["as2701015", "asyncio.Task.__dict__.__contains__",        ["__rshift__"],  false]
    - ["as2701016", "asyncio.Task.__dict__.__contains__",        ["__rrshift__"], false]
    - ["as2701017", "asyncio.Future.__dict__.__contains__",      ["__rshift__"],  false]
    - ["as2701018", "asyncio.Future.__dict__.__contains__",      ["__rrshift__"], false]
    - ["as2701019", "asyncio.Lock.__dict__.__contains__",        ["__rshift__"],  false]
    - ["as2701020", "asyncio.Lock.__dict__.__contains__",        ["__rrshift__"], false]
    - ["as2701021", "asyncio.Condition.__dict__.__contains__",   ["__rshift__"],  false]
    - ["as2701022", "asyncio.Condition.__dict__.__contains__",   ["__rrshift__"], false]
    - ["as2701023", "asyncio.Barrier.__dict__.__contains__",     ["__rshift__"],  false]
    - ["as2701024", "asyncio.Barrier.__dict__.__contains__",     ["__rrshift__"], false]

# ---------------------------------------------------------------------------
# Table 3: __invert__ dict-presence checks
#
# Wave 627 theme: asyncio concurrency types do not implement the bitwise NOT
# (unary ~) operator. __invert__ does not appear in any of these classes'
# own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2701.invert_protocol:
  description: "asyncio types __invert__ dict-presence checks — none define bitwise NOT in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2701

  columns: [id, function, args, expected]
  rows:
    - ["as2701025", "asyncio.Queue.__dict__.__contains__",     ["__invert__"], false]
    - ["as2701026", "asyncio.Task.__dict__.__contains__",      ["__invert__"], false]
    - ["as2701027", "asyncio.Future.__dict__.__contains__",    ["__invert__"], false]
    - ["as2701028", "asyncio.Lock.__dict__.__contains__",      ["__invert__"], false]
    - ["as2701029", "asyncio.Event.__dict__.__contains__",     ["__invert__"], false]
    - ["as2701030", "asyncio.Semaphore.__dict__.__contains__", ["__invert__"], false]
    - ["as2701031", "asyncio.Condition.__dict__.__contains__", ["__invert__"], false]
    - ["as2701032", "asyncio.Barrier.__dict__.__contains__",   ["__invert__"], false]

# ---------------------------------------------------------------------------
# Table 4: combined lshift/rshift/invert checks for Event, Semaphore,
#          Condition, and Barrier
#
# Wave 627 theme: extended coverage for asyncio synchronization primitives
# that are new to this wave. Condition and Barrier are concurrency coordinators;
# Semaphore bounds concurrent access; Event signals readiness. None define
# any bitwise operator protocol in their own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra2701.sync_primitives_bitwise:
  description: "asyncio synchronization primitive __lshift__/__rshift__/__invert__ combined dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2701

  columns: [id, function, args, expected]
  rows:
    - ["as2701033", "asyncio.Semaphore.__dict__.__contains__", ["__rshift__"],  false]
    - ["as2701034", "asyncio.Semaphore.__dict__.__contains__", ["__rrshift__"], false]
    - ["as2701035", "asyncio.Event.__dict__.__contains__",     ["__rshift__"],  false]
    - ["as2701036", "asyncio.Event.__dict__.__contains__",     ["__rrshift__"], false]
    - ["as2701037", "asyncio.Condition.__dict__.__contains__", ["__lshift__"],  false]
    - ["as2701038", "asyncio.Condition.__dict__.__contains__", ["__rlshift__"], false]
    - ["as2701039", "asyncio.Barrier.__dict__.__contains__",   ["__lshift__"],  false]
    - ["as2701040", "asyncio.Barrier.__dict__.__contains__",   ["__rlshift__"], false]
    - ["as2701041", "asyncio.Barrier.__dict__.__contains__",   ["__invert__"],  false]
    - ["as2701042", "asyncio.Condition.__dict__.__contains__", ["__invert__"],  false]
