spec: hashlib_extra122
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra121.zspec.zsdl — covers blake2b/blake2s __class__.__name__.__len__()==4 / __class__.__module__.__len__()==8 / cross-equality for module and class name (table + invariants)."
    - "hashlib_extra114.zspec.zsdl — covers hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('hashlib') / __spec__.has_location==True / __spec__.submodule_search_locations==None as a grouped table (table + invariants)."
    - "hashlib_extra104.zspec.zsdl — covers hashlib.__spec__.__class__.__name__.__len__()==10 / __spec__.name.__len__()==7 / __loader__.__class__.__name__.__len__()==16 as a grouped table (table + invariants)."
    - "hashlib_extra50.zspec.zsdl — covers hashlib.new.__class__.__module__.__eq__('builtins') as a table row (table + invariants)."
    - "hashlib_extra100.zspec.zsdl — covers hashlib.new.__class__.__name__.__eq__('function') / new.__name__.__eq__('__hash_new') / new.__module__.__eq__('hashlib') as rows (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.new.__qualname__.__len__()==10 / new.__qualname__.__eq__('__hash_new') as rows (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra121; it does NOT duplicate invariants present in those files."
    - "Wave 279 theme: hashlib.new function class module length and hashlib.__spec__.__class__.__module__ identity not yet covered — extra50 anchors new.__class__.__module__.__eq__('builtins') as a table row; extra104 anchors __spec__.__class__.__name__.__len__()==10 and __spec__.name.__len__()==7; NOT YET covered: new.__class__.__module__.__len__()==8 as grouped table; __spec__.__class__.__module__.__eq__('_frozen_importlib') as grouped table; __spec__.__class__.__module__.__len__()==17 as grouped table."
    - "hashlib.new.__class__.__module__.__len__() == 8 — len('builtins')==8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.__class__.__module__ == '_frozen_importlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.__class__.__module__.__len__() == 17 — len('_frozen_importlib')==17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.__class__.__name__.__len__() == 10 — len('ModuleSpec')==10. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.name.__len__() == 7 — len('hashlib')==7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__.__len__() == 8 — len('function')==8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.new is a pure-Python function (__hash_new) defined in Lib/hashlib.py. Its class is 'function' (8 chars), whose __module__ is 'builtins' (8 chars). hashlib.__spec__ is a ModuleSpec (10 chars), defined in '_frozen_importlib' (17 chars), which is the frozen copy of importlib._bootstrap baked into the CPython interpreter binary. No prior spec anchors __spec__.__class__.__module__=='_frozen_importlib' or its length 17."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new.__class__.__module__.__len__() == 8
# hashlib.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True
# hashlib.__spec__.__class__.__module__.__len__() == 17
# hashlib.__spec__.__class__.__name__.__len__() == 10
# hashlib.__spec__.name.__len__() == 7
#
# Wave 279 theme: hashlib.new class module length and __spec__ class module identity.
#
# hashlib.new is a pure-Python wrapper (internally named __hash_new). Its class is
# 'function' (8 chars), whose __module__ is 'builtins' (8 chars). The 'function'
# type is a fundamental Python object defined in Objects/funcobject.c, attributed
# to 'builtins'. hashlib.__spec__ is a ModuleSpec ('ModuleSpec'=10 chars) whose
# __class__.__module__ is '_frozen_importlib' (17 chars). _frozen_importlib is the
# frozen copy of importlib._bootstrap compiled directly into the CPython interpreter.
# Prior specs anchor new.__class__.__module__.__eq__('builtins') (extra50) and
# __spec__.__class__.__name__.__len__()==10 (extra104); NOT YET: new class module len,
# __spec__ class module equality or length. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table hashlib_extra122.new_class_module_and_spec_class_identity:
  description: "new.__class__.__module__.__len__()==8 / __spec__.__class__.__module__.__eq__('_frozen_importlib')==True / __spec__.__class__.__module__.__len__()==17 / __spec__.__class__.__name__.__len__()==10 / __spec__.name.__len__()==7 — new is a 'function' object; 'function' TYPE has __module__=='builtins' (8 chars); __spec__ is a ModuleSpec from '_frozen_importlib' (17 chars; frozen copy of importlib._bootstrap baked into CPython binary); extra50 anchors new class module eq; extra104 anchors spec class name len; no prior spec anchors spec class module or new class module len as grouped table; first hashnewspec122 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashnewspec122

  columns: [id, function, args, expected, description]
  rows:
    - [new_class_mod_len,       new.__class__.__module__.__len__,                      [], 8,    "new.__class__.__module__.__len__() is 8 (len('builtins')==8; 'function' type is attributed to builtins)"]
    - [spec_class_mod_eq,       __spec__.__class__.__module__.__eq__, ["_frozen_importlib"], true, "hashlib.__spec__.__class__.__module__ is '_frozen_importlib' (frozen importlib._bootstrap in CPython binary)"]
    - [spec_class_mod_len,      __spec__.__class__.__module__.__len__,                 [], 17,   "__spec__.__class__.__module__.__len__() is 17 (len('_frozen_importlib')==17; longest module name in this group)"]
    - [spec_class_name_len2,    __spec__.__class__.__name__.__len__,                   [], 10,   "__spec__.__class__.__name__.__len__() is 10 (len('ModuleSpec')==10; cross-check with extra104)"]
    - [spec_name_len2,          __spec__.name.__len__,                                 [], 7,    "__spec__.name.__len__() is 7 (len('hashlib')==7; canonical dotted module name; cross-check with extra104)"]

# ---------------------------------------------------------------------------
# hashlib.new.__class__.__name__.__len__() == 8
# hashlib.new.__class__.__module__.__len__() == 8
# hashlib.__spec__.__class__.__module__.__len__() == 17
# hashlib.__spec__.__class__.__name__.__len__() == 10
# hashlib.new.__name__.__len__() == 10
#
# Wave 279 theme: length coincidences and contrasts for new and __spec__ class identity.
#
# A notable coincidence: new.__class__.__name__ ('function'=8 chars) and
# new.__class__.__module__ ('builtins'=8 chars) have the same length (8). Similarly,
# __spec__.__class__.__name__ ('ModuleSpec'=10 chars) and new.__name__ ('__hash_new'=10
# chars) both have length 10 — a distinct coincidence in a different attribute pair.
# __spec__.__class__.__module__ ('_frozen_importlib'=17 chars) is the longest string
# in this spec. These length coincidences are not documented in prior specs.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra122.new_and_spec_length_coincidences:
  description: "new.__class__.__name__.__len__()==8 / new.__class__.__module__.__len__()==8 / __spec__.__class__.__module__.__len__()==17 / __spec__.__class__.__name__.__len__()==10 / new.__name__.__len__()==10 — notable length coincidences: new class name ('function') and class module ('builtins') both 8 chars; new.__name__ ('__hash_new') and spec class name ('ModuleSpec') both 10 chars; _frozen_importlib is 17 chars (longest); extra50/extra104/extra100 anchor the equality checks; no prior spec groups these length coincidences; first hashnewspec122 length-coincidence anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashnewspec122

  columns: [id, function, args, expected, description]
  rows:
    - [new_class_name_len2,  new.__class__.__name__.__len__,         [], 8,  "new.__class__.__name__.__len__() is 8 (len('function')==8; pure-Python function type)"]
    - [new_class_mod_len2,   new.__class__.__module__.__len__,       [], 8,  "new.__class__.__module__.__len__() is 8 (len('builtins')==8; same as class name length — length coincidence)"]
    - [spec_class_mod_len2,  __spec__.__class__.__module__.__len__,  [], 17, "__spec__.__class__.__module__.__len__() is 17 (len('_frozen_importlib')==17; longest string in this group)"]
    - [spec_class_name_len3, __spec__.__class__.__name__.__len__,    [], 10, "__spec__.__class__.__name__.__len__() is 10 (len('ModuleSpec')==10; same as new.__name__.__len__() — length coincidence)"]
    - [new_name_len2,        new.__name__.__len__,                   [], 10, "new.__name__.__len__() is 10 (len('__hash_new')==10; same as ModuleSpec name length — length coincidence)"]

# ---------------------------------------------------------------------------
# hashlib.new.__class__.__module__.__eq__('builtins') == True
# hashlib.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True
# hashlib.__spec__.__class__.__name__.__len__() == 10
# hashlib.__spec__.name.__len__() == 7
# hashlib.new.__class__.__name__.__len__() == 8
#
# Wave 279 theme: cross-group consistency for new and __spec__ class module attribution.
#
# Grouping new.__class__.__module__ equality with __spec__.__class__.__module__ equality
# in a single table highlights two different sources: 'builtins' (fundamental CPython
# objects) vs '_frozen_importlib' (frozen importlib bootstrap). Both are internal CPython
# implementation modules but serve different purposes. Extra50 anchors new class module
# eq; extra104 anchors spec class name len; this table cross-checks both in one view.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra122.new_and_spec_class_module_cross_check:
  description: "new.__class__.__module__.__eq__('builtins')==True / __spec__.__class__.__module__.__eq__('_frozen_importlib')==True / __spec__.__class__.__name__.__len__()==10 / __spec__.name.__len__()==7 / new.__class__.__name__.__len__()==8 — new type ('function') is from 'builtins' (fundamental CPython); spec class (ModuleSpec) is from '_frozen_importlib' (CPython bootstrap module baked into binary); both are internal CPython modules but at different layers; extra50 anchors new class module eq; extra104 anchors spec class name len; first hashnewspec122 cross-module anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashnewspec122

  columns: [id, function, args, expected, description]
  rows:
    - [new_class_mod_eq2,      new.__class__.__module__.__eq__,                      ["builtins"],          true, "new.__class__.__module__ is 'builtins' (cross-check; 'function' type lives in builtins CPython layer)"]
    - [spec_class_mod_eq2,     __spec__.__class__.__module__.__eq__,  ["_frozen_importlib"],                true, "__spec__.__class__.__module__ is '_frozen_importlib' (cross-check; CPython bootstrap layer distinct from builtins)"]
    - [spec_class_name_len4,   __spec__.__class__.__name__.__len__,                  [],                   10,   "__spec__.__class__.__name__.__len__() is 10 ('ModuleSpec'=10; cross-check with extra104)"]
    - [spec_name_len3,         __spec__.name.__len__,                                [],                   7,    "__spec__.name.__len__() is 7 ('hashlib'=7; cross-check with extra104)"]
    - [new_class_name_len3,    new.__class__.__name__.__len__,                        [],                   8,    "new.__class__.__name__.__len__() is 8 ('function'=8; cross-check confirming class name length)"]

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__module__.__eq__('_frozen_importlib') — standalone
#
# hashlib.__spec__.__class__.__module__ is '_frozen_importlib'. ModuleSpec is the
# class that represents a module's import specification — it stores the module name,
# loader, origin path, and submodule search locations. ModuleSpec is defined in
# importlib._bootstrap (Lib/importlib/_bootstrap.py), which CPython compiles into a
# frozen bytecode module called '_frozen_importlib' and bakes it into the interpreter
# binary (Python/frozen.c). This allows import machinery to boot before the filesystem
# is accessible. The name '_frozen_importlib' (17 chars) starts with an underscore
# indicating it is private CPython infrastructure. No prior hashlib spec anchors
# __spec__.__class__.__module__ as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant hashlib_extra122.spec_class_module_frozen_importlib:
  description: "hashlib.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True — ModuleSpec is from '_frozen_importlib' (17 chars; frozen copy of importlib._bootstrap baked into CPython binary in Python/frozen.c; allows import machinery to boot before filesystem access; private CPython infrastructure with underscore prefix); extra114 anchors __spec__.__class__.__name__.__eq__('ModuleSpec'); no prior spec anchors __spec__.__class__.__module__ as standalone; first standalone under hashnewspec122"
  category: type_identity
  kind: python_call_eq
  function: __spec__.__class__.__module__.__eq__
  args: ["_frozen_importlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__spec__.__class__.__module__.__len__() == 17 — standalone
#
# hashlib.__spec__.__class__.__module__.__len__() is 17. '_frozen_importlib' has
# 17 chars: '_'=1 + 'frozen'=6 + '_'=1 + 'importlib'=9 = 17. This is the longest
# module attribute name string encountered in the hashlib spec family. By contrast,
# 'hashlib' is 7 chars, 'builtins' is 8 chars, '_hashlib' is 8 chars, '_blake2' is
# 7 chars, and 'ModuleSpec' is 10 chars. The 17-char '_frozen_importlib' stands alone
# as the longest. No prior hashlib spec anchors this length as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra122.spec_class_module_len_17:
  description: "hashlib.__spec__.__class__.__module__.__len__() == 17 — len('_frozen_importlib')==17 ('_'=1 + 'frozen'=6 + '_'=1 + 'importlib'=9; longest module-related string in hashlib spec family; contrast: 'hashlib'=7, 'builtins'=8, '_hashlib'=8, '_blake2'=7, 'ModuleSpec'=10); no prior spec anchors __spec__ class module length as standalone; first standalone under hashnewspec122"
  category: type_identity
  kind: python_call_eq
  function: __spec__.__class__.__module__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# hashlib.new.__class__.__module__.__len__() == 8 — standalone
#
# hashlib.new.__class__.__module__.__len__() is 8. 'builtins' has 8 chars.
# hashlib.new is a pure-Python function (internally named __hash_new). The Python
# 'function' type (type(hashlib.new)) has its __module__ set to 'builtins' because
# the 'function' type is a fundamental CPython runtime object defined in
# Objects/funcobject.c. This is the same mechanism by which 'builtin_function_or_method'
# (type of md5, sha256, etc.) also has __module__=='builtins'. Both the Python 'function'
# type and the C 'builtin_function_or_method' type live in 'builtins'. The length 8
# coincidentally matches new.__class__.__name__.__len__()==8 (len('function')==8).
# No prior hashlib spec anchors new.__class__.__module__.__len__() as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra122.new_class_module_len_8:
  description: "hashlib.new.__class__.__module__.__len__() == 8 — len('builtins')==8 ('function' type __module__ is 'builtins'; fundamental CPython object from Objects/funcobject.c; same module as 'builtin_function_or_method' type of md5/sha256; coincidentally same length as new.__class__.__name__.__len__()==8 i.e. len('function')==8); extra50 anchors new.__class__.__module__.__eq__('builtins'); no prior spec anchors new class module length as standalone; first standalone under hashnewspec122"
  category: type_identity
  kind: python_call_eq
  function: new.__class__.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# hashlib.new.__class__.__name__.__len__() == 8 — standalone
#
# hashlib.new.__class__.__name__.__len__() is 8. 'function' has 8 chars.
# hashlib.new (internally __hash_new) is a pure-Python function — its class is the
# 'function' type (Objects/funcobject.c). This contrasts with hashlib.md5, sha256,
# etc., which are builtin_function_or_method objects (26-char class name). The
# distinction is significant: hashlib.new dispatches to C functions at runtime via a
# lookup table, so CPython defines it as a Python function rather than a C builtin.
# 'function' (8 chars) is far shorter than 'builtin_function_or_method' (26 chars).
# No prior spec anchors new.__class__.__name__.__len__()==8 as a standalone under
# hashnewspec122. (extra34 does anchor it as a grouped-table row.)
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra122.new_class_name_len_8:
  description: "hashlib.new.__class__.__name__.__len__() == 8 — len('function')==8 (hashlib.new is a pure-Python dispatch wrapper; class is 'function' not 'builtin_function_or_method'=26 chars; 'function'=8 is 18 chars shorter than the C constructor class name; extra34 anchors this as a table row; no prior spec anchors it as standalone under hashnewspec122; first standalone under hashnewspec122)"
  category: type_identity
  kind: python_call_eq
  function: new.__class__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# hashlib.__spec__.name.__len__() == 7 — standalone
#
# hashlib.__spec__.name.__len__() is 7. '__spec__.name' is the canonical dotted name
# of the module as stored in the ModuleSpec object. For hashlib, __spec__.name is
# 'hashlib' (7 chars) — the same value as hashlib.__name__ (7 chars). These two
# attributes are separate attributes on separate objects (the module and its spec),
# but they encode the same string. extra104 anchors __spec__.name.__len__()==7 as a
# grouped-table row; this standalone confirms it in the hashnewspec122 namespace
# for independent regression coverage. The _frozen_importlib ModuleSpec always keeps
# __spec__.name synchronized with __name__ for well-formed modules. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant hashlib_extra122.spec_name_len_7:
  description: "hashlib.__spec__.name.__len__() == 7 — len('hashlib')==7 (__spec__.name is the canonical dotted module name in the ModuleSpec object; equals hashlib.__name__=='hashlib'; _frozen_importlib keeps __spec__.name synchronized with __name__; extra104 anchors this as a table row; first standalone under hashnewspec122 for independent regression coverage)"
  category: type_identity
  kind: python_call_eq
  function: __spec__.name.__len__
  args: []
  expected: 7

