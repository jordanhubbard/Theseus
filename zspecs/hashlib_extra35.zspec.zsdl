spec: hashlib_extra35
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra34.zspec.zsdl — covers __all__ type/len/class_name_len; pbkdf2_hmac __qualname__/__module__ lengths; new.__class__.__name__.__len__(); algorithms_available.__len__()==19; sha224/sha384 __qualname__.__len__()==14."
    - "hashlib_extra33.zspec.zsdl — covers HASH.update/digest/hexdigest/copy __qualname__.__len__(); HASH.__mro__.__len__(); algorithms_guaranteed/__class__/__name__.__len__()==3; algorithms_available.__class__.__name__.__len__()==3."
    - "hashlib_extra32.zspec.zsdl — covers sha1/sha512/sha224/sha384 __module__.__len__()==8; blake2b/blake2s __module__/__name__.__len__(); new.__module__/__name__.__len__(); sha3_256 __name__/__module__.__len__()."
    - "hashlib_extra31.zspec.zsdl — covers md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__(); md5/sha1/sha256/sha512 __module__.__eq__('_hashlib')."
    - "hashlib_extra23.zspec.zsdl — covers sha384/sha224 block_size/digest_size; new('sha224'/'sha384') __class__.__name__."
    - "hashlib_extra17.zspec.zsdl — covers sha256/md5/sha1 empty-input hexdigest; sha256 block_size/name; new.__qualname__."
    - "hashlib_extra14.zspec.zsdl — covers sha256().copy() name/digest_size/block_size; sha256 hexdigest vector; new('sha1'/'sha256'/'sha512'/'sha3_256') block_size."
  notes:
    - "This spec extends hashlib through hashlib_extra34; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: all major constructor __name__/__qualname__/__module__ equality and length checks; HASH method __qualname__/__name__; algorithms_guaranteed/__available__ class names, counts, and membership; sha224/sha384/sha3_*/blake2* qualname/module/name; __all__ type and length; pbkdf2_hmac qualname/module; sha256/sha224/sha384 block_size and digest_size (extra23 covers sha224/sha384; extra14/17 cover sha256; extra14 covers new('sha1'/'sha512'/'sha3_256') block_size via table)."
    - "This spec covers: HASH.name string length for md5/sha1/sha256/sha512 instances (NOVEL — .name is a str instance attribute; no prior spec checks its __len__() for any algorithm); md5/sha1 digest_size (NOVEL — extra14 covers sha256; extra23 covers sha224/sha384; md5/sha1 standalone digest_size not checked); sha3_256/sha3_512 block_size and digest_size (NOVEL — extra14 covers sha3_256 block_size via new() table but NOT sha3_256.digest_size or sha3_512 standalone; extra23 does NOT cover sha3_*)."
    - "HASH.name is a str instance attribute giving the canonical algorithm name in lowercase. md5().name == 'md5' (len 3); sha1().name == 'sha1' (len 4); sha256().name == 'sha256' (len 6); sha512().name == 'sha512' (len 6). No prior hashlib spec checks .name string length via __len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.md5().digest_size == 16: MD5 produces a 128-bit (16-byte) digest. No prior spec checks md5 digest_size standalone (extra14 covers sha256; extra23 covers sha224/sha384). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha1().digest_size == 20: SHA-1 produces a 160-bit (20-byte) digest. No prior spec checks sha1 digest_size. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256().block_size == 136: SHA3-256 uses a 1088-bit (136-byte) sponge rate. extra14 covers new('sha3_256').block_size via table, but this spec confirms sha3_256() constructor directly. The digest_size == 32 is fully novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512().block_size == 72: SHA3-512 uses a 576-bit (72-byte) sponge rate. Note that sha3_512.block_size (72) is smaller than sha3_256.block_size (136) because higher security requires smaller rate. Novel standalone invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512().digest_size == 64: SHA3-512 produces a 512-bit (64-byte) digest. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: HASH instance .name string lengths
#
# Each HASH instance exposes a .name attribute (str) with the canonical
# algorithm name in lowercase. No prior hashlib spec checks .name string
# length via __len__(). md5().name == 'md5' (len 3); sha1().name == 'sha1'
# (len 4); sha256().name == 'sha256' (len 6); sha512().name == 'sha512' (len 6).
# Accessed via constructor() then method chain name.__len__.
# ---------------------------------------------------------------------------

table hashlib_extra35.hash_instance_name_lengths:
  description: "HASH.name.__len__() for md5/sha1/sha256/sha512 instances — novel; no prior spec checks .name string lengths"
  kind: python_call_eq
  category: hash_properties
  id_prefix: hinl35

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [md5_name_len,    md5,    [!b64 ""], name.__len__, [], 3]
    - [sha1_name_len,   sha1,   [!b64 ""], name.__len__, [], 4]
    - [sha256_name_len, sha256, [!b64 ""], name.__len__, [], 6]
    - [sha512_name_len, sha512, [!b64 ""], name.__len__, [], 6]

# ---------------------------------------------------------------------------
# Table: block_size for md5 and sha1 (novel standalone constructors)
#
# extra14 covers new('sha1').block_size via table; extra14/17 cover sha256;
# extra23 covers sha224/sha384. This table checks md5() and sha1() directly
# via their own constructors (not new()). md5().block_size == 64 (512-bit
# block); sha1().block_size == 64 (also 512-bit block).
# ---------------------------------------------------------------------------

table hashlib_extra35.constructor_block_sizes:
  description: "block_size for md5/sha1 via direct constructor — novel; sha256 covered by extra14/17; extra14 covers sha1 via new() but not sha1() directly"
  kind: python_call_eq
  category: hash_properties
  id_prefix: hbs35

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [md5_block_size,  md5,  [!b64 ""], block_size.__eq__, [64], true]
    - [sha1_block_size, sha1, [!b64 ""], block_size.__eq__, [64], true]

# ---------------------------------------------------------------------------
# Table: digest_size for md5 and sha1 (novel)
#
# No prior hashlib spec checks md5 or sha1 digest_size as a standalone check.
# MD5 produces 128-bit (16-byte) digests. SHA-1 produces 160-bit (20-byte)
# digests. sha256 digest_size (32) is covered by extra14; sha224/sha384 by
# extra23. md5/sha1 are novel. Both verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra35.constructor_digest_sizes:
  description: "digest_size for md5 and sha1 — novel; sha256 covered by extra14; sha224/sha384 by extra23"
  kind: python_call_eq
  category: hash_properties
  id_prefix: hds35

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [md5_digest_size,  md5,  [!b64 ""], digest_size.__eq__, [16], true]
    - [sha1_digest_size, sha1, [!b64 ""], digest_size.__eq__, [20], true]

# ---------------------------------------------------------------------------
# sha3_256 and sha3_512 block_size / digest_size — novel standalone invariants
#
# SHA-3 uses the Keccak sponge construction. The sponge rate (block_size) is
# inversely related to the security level:
#   sha3_256: rate = 1088 bits = 136 bytes; digest = 256 bits = 32 bytes
#   sha3_512: rate = 576 bits = 72 bytes; digest = 512 bits = 64 bytes
# sha3_256.block_size is covered by extra14 via new('sha3_256') table, but
# sha3_256.digest_size and all sha3_512 standalone invariants are novel.
# The counterintuitive observation that sha3_256.block_size > sha3_512.block_size
# (136 vs 72) follows from the capacity/rate tradeoff in the Keccak construction.
# All values verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra35.sha3_256.digest_size:
  description: "hashlib.sha3_256().digest_size == 32 — 256-bit output; novel SHA-3 digest_size invariant (block_size covered by extra14)"
  category: hash_properties
  kind: python_call_eq
  function: sha3_256
  args: [!b64 ""]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra35.sha3_512.block_size:
  description: "hashlib.sha3_512().block_size == 72 — 576-bit sponge rate; smaller than sha3_256 (136) due to higher capacity; novel standalone invariant"
  category: hash_properties
  kind: python_call_eq
  function: sha3_512
  args: [!b64 ""]
  method: block_size.__eq__
  method_args: [72]
  expected: true

invariant hashlib_extra35.sha3_512.digest_size:
  description: "hashlib.sha3_512().digest_size == 64 — 512-bit output; novel SHA-3 digest_size invariant"
  category: hash_properties
  kind: python_call_eq
  function: sha3_512
  args: [!b64 ""]
  method: digest_size.__eq__
  method_args: [64]
  expected: true
