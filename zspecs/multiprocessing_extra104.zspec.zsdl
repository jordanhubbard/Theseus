spec: multiprocessing_extra104
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra103.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing exception hierarchy class identity. NEW in extra104: multiprocessing.ProcessError.__name__=='ProcessError', __bases__[0].__name__=='Exception', __mro__.__len__()==4 (MRO=[ProcessError, Exception, BaseException, object]); multiprocessing.AuthenticationError.__name__=='AuthenticationError', __bases__[0].__name__=='ProcessError', __mro__.__len__()==5; multiprocessing.BufferTooShort.__name__=='BufferTooShort', __bases__[0].__name__=='ProcessError', __mro__.__len__()==5; multiprocessing.TimeoutError.__name__=='TimeoutError', __bases__[0].__name__=='ProcessError', __mro__.__len__()==5; all four exception classes have __module__=='multiprocessing.context'. Note: multiprocessing.ProcessLookupError does not exist as a module attribute (verified with Python 3.14.3). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'. ProcessError inherits directly from Exception (not RuntimeError), giving MRO [ProcessError, Exception, BaseException, object] (length=4). All other multiprocessing exceptions in this spec inherit from ProcessError (length=5). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "AuthenticationError, BufferTooShort, and TimeoutError all have __bases__[0].__name__=='ProcessError' and __mro__.__len__()==5. Their MRO is [<ExcClass>, ProcessError, Exception, BaseException, object]. All are defined in Lib/multiprocessing/context.py (__module__=='multiprocessing.context'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__qualname__ == 'TimeoutError'. Despite sharing a name with the built-in TimeoutError, this is a distinct class in the multiprocessing hierarchy that inherits from ProcessError, not from OSError. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.ProcessError class identity — extra104
#
# Wave 254 theme: multiprocessing exception hierarchy.
#
# multiprocessing.ProcessError.__name__         == 'ProcessError'   (mro len=4)
# multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'
# multiprocessing.ProcessError.__module__       == 'multiprocessing.context'
# ---------------------------------------------------------------------------

table multiprocessing_extra104.mp_process_error_identity:
  description: "multiprocessing.ProcessError class identity checks in mpexc104 namespace — wave 254 theme: ProcessError.__name__.__eq__('ProcessError')==True (len=12: 'ProcessError'=12); ProcessError.__bases__[0].__name__.__eq__('Exception')==True (inherits directly from Exception, not RuntimeError); ProcessError.__mro__.__len__()==4 (MRO=[ProcessError, Exception, BaseException, object]); ProcessError.__module__.__eq__('multiprocessing.context')==True (defined in Lib/multiprocessing/context.py); compare: AuthenticationError.__mro__.__len__()==5 (one deeper); ProcessError is the base for all multiprocessing exceptions (AuthenticationError, BufferTooShort, TimeoutError all inherit from it); ProcessError.__qualname__.__eq__('ProcessError')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mpexc104

  columns: [id, function, args, expected, description]
  rows:
    - [pe_name_eq,    multiprocessing.ProcessError.__name__.__eq__,              ["ProcessError"],          true, "multiprocessing.ProcessError.__name__ == 'ProcessError' (len=12); verified with Python 3.14.3"]
    - [pe_base_eq,    "multiprocessing.ProcessError.__bases__[0].__name__.__eq__", ["Exception"],           true, "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' (inherits directly from Exception); verified with Python 3.14.3"]
    - [pe_mro_len,    multiprocessing.ProcessError.__mro__.__len__,              [],                        4,    "multiprocessing.ProcessError.__mro__.__len__() == 4 ([ProcessError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [pe_module,     multiprocessing.ProcessError.__module__.__eq__,            ["multiprocessing.context"], true, "multiprocessing.ProcessError.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [pe_qn_eq,      multiprocessing.ProcessError.__qualname__.__eq__,          ["ProcessError"],          true, "multiprocessing.ProcessError.__qualname__ == 'ProcessError' (len=12); verified with Python 3.14.3"]
    - [pe_qn_len,     multiprocessing.ProcessError.__qualname__.__len__,         [],                        12,   "multiprocessing.ProcessError.__qualname__.__len__() == 12 ('ProcessError'=12); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.AuthenticationError and BufferTooShort hierarchy — extra104
#
# Wave 254 theme: ProcessError subclass hierarchy.
#
# multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'  (mro len=5)
# multiprocessing.BufferTooShort.__bases__[0].__name__      == 'ProcessError'  (mro len=5)
# both have __module__ == 'multiprocessing.context'
# ---------------------------------------------------------------------------

table multiprocessing_extra104.mp_auth_buffer_hierarchy:
  description: "multiprocessing.AuthenticationError and BufferTooShort hierarchy checks in mpexc104 namespace — wave 254 theme: both AuthenticationError and BufferTooShort inherit directly from ProcessError (not from Exception directly); AuthenticationError.__name__.__eq__('AuthenticationError')==True (len=19, longest class name in this spec); AuthenticationError.__bases__[0].__name__.__eq__('ProcessError')==True; AuthenticationError.__mro__.__len__()==5 (MRO=[AuthenticationError, ProcessError, Exception, BaseException, object]); AuthenticationError.__module__.__eq__('multiprocessing.context')==True; BufferTooShort.__name__.__eq__('BufferTooShort')==True (len=13); BufferTooShort.__bases__[0].__name__.__eq__('ProcessError')==True; BufferTooShort.__mro__.__len__()==5 (same depth as AuthenticationError); BufferTooShort.__module__.__eq__('multiprocessing.context')==True; compare: ProcessError.__mro__.__len__()==4 (one shallower); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mpexc104a

  columns: [id, function, args, expected, description]
  rows:
    - [ae_name_eq,    multiprocessing.AuthenticationError.__name__.__eq__,               ["AuthenticationError"],      true, "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError' (len=19, longest class name); verified with Python 3.14.3"]
    - [ae_base_eq,    "multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__", ["ProcessError"],            true, "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'; verified with Python 3.14.3"]
    - [ae_mro_len,    multiprocessing.AuthenticationError.__mro__.__len__,               [],                           5,    "multiprocessing.AuthenticationError.__mro__.__len__() == 5 ([AuthenticationError, ProcessError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [ae_module,     multiprocessing.AuthenticationError.__module__.__eq__,             ["multiprocessing.context"],  true, "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [bts_name_eq,   multiprocessing.BufferTooShort.__name__.__eq__,                   ["BufferTooShort"],            true, "multiprocessing.BufferTooShort.__name__ == 'BufferTooShort' (len=13); verified with Python 3.14.3"]
    - [bts_base_eq,   "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__",    ["ProcessError"],              true, "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'; verified with Python 3.14.3"]
    - [bts_mro_len,   multiprocessing.BufferTooShort.__mro__.__len__,                   [],                            5,    "multiprocessing.BufferTooShort.__mro__.__len__() == 5 ([BufferTooShort, ProcessError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [bts_module,    multiprocessing.BufferTooShort.__module__.__eq__,                 ["multiprocessing.context"],   true, "multiprocessing.BufferTooShort.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.TimeoutError hierarchy and qualname — extra104
#
# Wave 254 theme: TimeoutError as a ProcessError subclass.
#
# multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'  (mro len=5)
# multiprocessing.TimeoutError.__qualname__          == 'TimeoutError'  (len=12)
# multiprocessing.TimeoutError.__module__            == 'multiprocessing.context'
# ---------------------------------------------------------------------------

table multiprocessing_extra104.mp_timeout_error_hierarchy:
  description: "multiprocessing.TimeoutError hierarchy checks in mpexc104 namespace — wave 254 theme: TimeoutError.__name__.__eq__('TimeoutError')==True (len=12: 'TimeoutError'=12; same length as ProcessError=12); TimeoutError.__bases__[0].__name__.__eq__('ProcessError')==True (inherits from ProcessError, not from the built-in TimeoutError/OSError); TimeoutError.__mro__.__len__()==5 (MRO=[TimeoutError, ProcessError, Exception, BaseException, object]); TimeoutError.__module__.__eq__('multiprocessing.context')==True; TimeoutError.__qualname__.__eq__('TimeoutError')==True; compare: ProcessError.__mro__.__len__()==4 (one shallower); all four subclass exceptions in this spec (AuthenticationError, BufferTooShort, TimeoutError) share MRO length=5; note multiprocessing.TimeoutError is a distinct class from the built-in TimeoutError (which inherits from OSError); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mpexc104b

  columns: [id, function, args, expected, description]
  rows:
    - [te_name_eq,    multiprocessing.TimeoutError.__name__.__eq__,               ["TimeoutError"],           true, "multiprocessing.TimeoutError.__name__ == 'TimeoutError' (len=12); verified with Python 3.14.3"]
    - [te_base_eq,    "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__", ["ProcessError"],          true, "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError' (inherits from ProcessError, not built-in TimeoutError); verified with Python 3.14.3"]
    - [te_mro_len,    multiprocessing.TimeoutError.__mro__.__len__,               [],                         5,    "multiprocessing.TimeoutError.__mro__.__len__() == 5 ([TimeoutError, ProcessError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [te_module,     multiprocessing.TimeoutError.__module__.__eq__,             ["multiprocessing.context"], true, "multiprocessing.TimeoutError.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [te_qn_eq,      multiprocessing.TimeoutError.__qualname__.__eq__,           ["TimeoutError"],           true, "multiprocessing.TimeoutError.__qualname__ == 'TimeoutError' (len=12); verified with Python 3.14.3"]
    - [te_qn_len,     multiprocessing.TimeoutError.__qualname__.__len__,          [],                         12,   "multiprocessing.TimeoutError.__qualname__.__len__() == 12 ('TimeoutError'=12); verified with Python 3.14.3"]
    - [ae_qn_len,     multiprocessing.AuthenticationError.__qualname__.__len__,   [],                         19,   "multiprocessing.AuthenticationError.__qualname__.__len__() == 19 (longest class name in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra104
# ---------------------------------------------------------------------------

invariant multiprocessing_extra104.ProcessError_base_is_Exception:
  description: "multiprocessing.ProcessError.__bases__[0].__name__.__eq__('Exception') returns True — ProcessError inherits directly from Exception (not RuntimeError or OSError); its MRO is [ProcessError, Exception, BaseException, object] (length=4); ProcessError is the root of the multiprocessing exception hierarchy: AuthenticationError, BufferTooShort, and TimeoutError all inherit from it; ProcessError.__module__=='multiprocessing.context'; ProcessError.__qualname__=='ProcessError' (len=12); compare: BrokenExecutor (in concurrent.futures) inherits from RuntimeError, while ProcessError inherits from Exception — a different branch; NEW in extra104: first standalone ProcessError base invariant in mpexc104 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.ProcessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant multiprocessing_extra104.AuthenticationError_mro_len_5:
  description: "multiprocessing.AuthenticationError.__mro__.__len__() == 5 — AuthenticationError's MRO is [AuthenticationError, ProcessError, Exception, BaseException, object] (5 elements); compare: ProcessError.__mro__.__len__()==4 (one shallower — AuthenticationError's base); AuthenticationError.__bases__[0].__name__=='ProcessError'; AuthenticationError.__module__=='multiprocessing.context'; AuthenticationError.__qualname__=='AuthenticationError' (len=19, the longest class name in this spec); AuthenticationError is raised when a connection uses the wrong authentication key; all three ProcessError subclasses in this spec (AuthenticationError, BufferTooShort, TimeoutError) share MRO length=5; NEW in extra104: first standalone AuthenticationError MRO length invariant in mpexc104 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: multiprocessing.AuthenticationError.__mro__.__len__
  args: []
  expected: 5

invariant multiprocessing_extra104.BufferTooShort_base_is_ProcessError:
  description: "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__('ProcessError') returns True — BufferTooShort inherits from ProcessError; its MRO is [BufferTooShort, ProcessError, Exception, BaseException, object] (length=5); BufferTooShort.__module__=='multiprocessing.context'; BufferTooShort.__qualname__=='BufferTooShort' (len=13); BufferTooShort is raised by Connection.recv_bytes_into() when the supplied buffer is too small for the message; both BufferTooShort and AuthenticationError share the same base (ProcessError) and MRO length (5), but their qualnames differ: BufferTooShort=13, AuthenticationError=19; NEW in extra104: first standalone BufferTooShort base invariant in mpexc104 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.BufferTooShort.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra104.TimeoutError_base_is_ProcessError:
  description: "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__('ProcessError') returns True — multiprocessing.TimeoutError inherits from ProcessError (not from the built-in TimeoutError, which inherits from OSError); its MRO is [TimeoutError, ProcessError, Exception, BaseException, object] (length=5); this distinguishes it from the built-in TimeoutError whose MRO is [TimeoutError, OSError, Exception, BaseException, object]; multiprocessing.TimeoutError.__module__=='multiprocessing.context'; TimeoutError.__qualname__=='TimeoutError' (len=12, same as ProcessError len=12); NEW in extra104: first standalone TimeoutError base invariant in mpexc104 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra104.AuthenticationError_qualname_len_19:
  description: "multiprocessing.AuthenticationError.__qualname__.__len__() == 19 — 'AuthenticationError' = 19 chars: 'Authentication'=14 + 'Error'=5 = 19; this is the longest class qualname in this spec; compare qualname lengths: ProcessError=12, TimeoutError=12, BufferTooShort=13, AuthenticationError=19 (longest); multiprocessing.AuthenticationError.__module__=='multiprocessing.context'; AuthenticationError.__mro__.__len__()==5; AuthenticationError is one of three direct subclasses of ProcessError (along with BufferTooShort and TimeoutError) in the multiprocessing exception hierarchy; NEW in extra104: first standalone AuthenticationError qualname length invariant in mpexc104 namespace; wave 254; verified with Python 3.14.3"
  category: class_hierarchy
  kind: python_call_eq
  function: multiprocessing.AuthenticationError.__qualname__.__len__
  args: []
  expected: 19
