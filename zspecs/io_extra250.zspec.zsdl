# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra250.TextIOBase.name_eq:
  description: "io.TextIOBase.__name__ == 'TextIOBase' — the class name string; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOBase.__name__.__eq__
  args: ["TextIOBase"]
  expected: true

invariant io_extra250.TextIOBase.module_is_io:
  description: "io.TextIOBase.__module__ == 'io' — TextIOBase is a pure Python ABC defined in io.py, not a C extension type; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra250.TextIOBase.module_not_underscore_io:
  description: "io.TextIOBase.__module__ != '_io' — unlike concrete C types, TextIOBase is the Python ABC wrapper whose __module__ is 'io'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOBase.__module__.__eq__
  args: ["_io"]
  expected: false

invariant io_extra250.TextIOBase.base_name_eq:
  description: "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' — TextIOBase directly extends the C type _TextIOBase from the _io extension; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "TextIOBase.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra250.TextIOBase.class_is_abcmeta:
  description: "io.TextIOBase.__class__.__name__ == 'ABCMeta' — TextIOBase is an abstract base class; its metaclass is ABCMeta, distinguishing it from concrete C extension types; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOBase.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant io_extra250.TextIOBase.name_len:
  description: "len(io.TextIOBase.__name__) == 10 — 'TextIOBase' has 10 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOBase.__name__.__len__
  args: []
  expected: 10

invariant io_extra250.BufferedIOBase.name_eq:
  description: "io.BufferedIOBase.__name__ == 'BufferedIOBase' — the class name string; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedIOBase.__name__.__eq__
  args: ["BufferedIOBase"]
  expected: true

invariant io_extra250.BufferedIOBase.module_is_io:
  description: "io.BufferedIOBase.__module__ == 'io' — BufferedIOBase is a pure Python ABC defined in io.py, not a C extension type; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra250.BufferedIOBase.module_not_underscore_io:
  description: "io.BufferedIOBase.__module__ != '_io' — unlike concrete C types (e.g. BufferedReader), BufferedIOBase is the Python ABC with __module__ == 'io'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedIOBase.__module__.__eq__
  args: ["_io"]
  expected: false

invariant io_extra250.BufferedIOBase.base_name_eq:
  description: "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — BufferedIOBase directly extends the C type _BufferedIOBase from the _io extension; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "BufferedIOBase.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
