spec: io_extra250
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bufferedio.c"
    - "CPython source: Modules/_io/textio.c"
    - "CPython source: Lib/io.py"
    - "io_extra249.zspec.zsdl — covers io.BufferedRandom and io.IncrementalNewlineDecoder class identity"
    - "_io_extra.zspec.zsdl — covers _io-backend types"
  notes:
    - "This spec covers: io.TextIOBase and io.BufferedIOBase class identity — __name__, __module__, __bases__[0].__name__."
    - "io.TextIOBase.__module__ == 'io' — TextIOBase is a pure Python ABC defined in io.py (not a C extension); verified Python 3.14.3 macOS."
    - "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' — TextIOBase directly extends the C type _TextIOBase from _io; verified Python 3.14.3 macOS."
    - "io.TextIOBase.__class__.__name__ == 'ABCMeta' — TextIOBase is an ABC; its metaclass is ABCMeta, not plain type; verified Python 3.14.3 macOS."
    - "io.BufferedIOBase.__module__ == 'io' — BufferedIOBase is also a pure Python ABC defined in io.py; verified Python 3.14.3 macOS."
    - "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — BufferedIOBase directly extends the C type _BufferedIOBase from _io; verified Python 3.14.3 macOS."
    - "io.BufferedIOBase.__class__.__name__ == 'ABCMeta' — BufferedIOBase metaclass is ABCMeta; verified Python 3.14.3 macOS."
    - "TextIOBase.__name__ == 'TextIOBase' — length 10; verified Python 3.14.3 macOS."
    - "TextIOBase.__module__ == 'io' — length 2; verified Python 3.14.3 macOS."
    - "TextIOBase.__bases__[0].__name__ == '_TextIOBase' — length 11; verified Python 3.14.3 macOS."
    - "BufferedIOBase.__name__ == 'BufferedIOBase' — length 14; verified Python 3.14.3 macOS."
    - "BufferedIOBase.__module__ == 'io' — length 2; verified Python 3.14.3 macOS."
    - "BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — length 15; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOBase class identity — __name__, __module__, __qualname__
# TextIOBase is a pure Python ABC; __module__ == 'io', metaclass is ABCMeta.
# Its base is the C type _TextIOBase (from _io).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra250.TextIOBase_name_module_qualname:
  description: "io.TextIOBase class identity: __name__, __module__, __qualname__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iotextbase250

  columns: [id, function, args, expected]
  rows:
    - [textbase_name_eq,      TextIOBase.__name__.__eq__,      ["TextIOBase"],      true]
    - [textbase_name_not_buf, TextIOBase.__name__.__eq__,      ["BufferedIOBase"],  false]
    - [textbase_module_eq,    TextIOBase.__module__.__eq__,    ["io"],              true]
    - [textbase_module_not,   TextIOBase.__module__.__eq__,    ["_io"],             false]
    - [textbase_qualname_eq,  TextIOBase.__qualname__.__eq__,  ["TextIOBase"],      true]

# ---------------------------------------------------------------------------
# io.TextIOBase __name__, __module__, __bases__[0].__name__ string lengths
# __name__='TextIOBase' len=10, __module__='io' len=2,
# __bases__[0].__name__='_TextIOBase' len=11.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra250.TextIOBase_name_module_lengths:
  description: "io.TextIOBase string lengths: __name__=10, __module__=2, __qualname__=10; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iotextbase250

  columns: [id, function, args, expected]
  rows:
    - [textbase_name_len,     TextIOBase.__name__.__len__,     [], 10]
    - [textbase_module_len,   TextIOBase.__module__.__len__,   [], 2]
    - [textbase_qualname_len, TextIOBase.__qualname__.__len__, [], 10]

# ---------------------------------------------------------------------------
# io.TextIOBase base class name and metaclass name
# __bases__[0].__name__ == '_TextIOBase' (the C extension base),
# __class__.__name__ == 'ABCMeta' (TextIOBase is an ABC).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra250.TextIOBase_base_meta:
  description: "io.TextIOBase base class and metaclass: __bases__[0].__name__, __class__.__name__; verified Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iotextbase250

  columns: [id, function, args, expected]
  rows:
    - [textbase_base_eq,      "TextIOBase.__bases__[0].__name__.__eq__",  ["_TextIOBase"], true]
    - [textbase_base_not_obj, "TextIOBase.__bases__[0].__name__.__eq__",  ["object"],      false]
    - [textbase_meta_eq,      TextIOBase.__class__.__name__.__eq__,       ["ABCMeta"],     true]
    - [textbase_meta_not_tp,  TextIOBase.__class__.__name__.__eq__,       ["type"],        false]
    - [textbase_base_len,     "TextIOBase.__bases__[0].__name__.__len__", [],              11]

