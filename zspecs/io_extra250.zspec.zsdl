    - [buffbase_name_eq,      BufferedIOBase.__name__.__eq__,      ["BufferedIOBase"],  true]
    - [buffbase_name_not_txt, BufferedIOBase.__name__.__eq__,      ["TextIOBase"],      false]
    - [buffbase_module_eq,    BufferedIOBase.__module__.__eq__,    ["io"],              true]
    - [buffbase_module_not,   BufferedIOBase.__module__.__eq__,    ["_io"],             false]
    - [buffbase_qualname_eq,  BufferedIOBase.__qualname__.__eq__,  ["BufferedIOBase"],  true]

