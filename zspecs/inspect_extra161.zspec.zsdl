spec: inspect_extra161
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter.POSITIONAL_ONLY.value 0; inspect.Parameter.POSITIONAL_OR_KEYWORD.value 1; inspect.Parameter.VAR_POSITIONAL.value 2; inspect.Parameter.KEYWORD_ONLY.value 3; inspect.Parameter.VAR_KEYWORD.value 4; inspect.Parameter.__name__ 'Parameter'; inspect.Parameter.__module__ 'inspect'; inspect.Parameter.__bases__[0].__name__ 'object' (Wave 290)."
    - "inspect.Parameter.POSITIONAL_ONLY.value == 0 — POSITIONAL_ONLY is an enum member on the ParameterKind IntEnum; it represents parameters that can only be supplied positionally (before a bare /); its integer value is 0. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1 — POSITIONAL_OR_KEYWORD is the default parameter kind; it represents parameters that may be supplied positionally or as keyword arguments; its integer value is 1. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.value == 2 — VAR_POSITIONAL represents *args parameters that capture excess positional arguments; its integer value is 2. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.value == 3 — KEYWORD_ONLY represents parameters that appear after a bare * and must be supplied as keyword arguments; its integer value is 3. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.value == 4 — VAR_KEYWORD represents **kwargs parameters that capture excess keyword arguments; its integer value is 4. Verified with Python 3.14.3."
    - "inspect.Parameter.__name__ == 'Parameter' — Parameter is a Python class defined in Lib/inspect.py; its simple class name is 'Parameter'. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object; its __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter ParameterKind enum integer values
#
# Wave 290 theme: inspect.Parameter enum member integer values for all five
# parameter kinds.
#
# inspect.Parameter.POSITIONAL_ONLY.value == 0
# inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1
# inspect.Parameter.VAR_POSITIONAL.value == 2
# inspect.Parameter.KEYWORD_ONLY.value == 3
# inspect.Parameter.VAR_KEYWORD.value == 4
#
# inspect.Parameter.kind attributes are members of the ParameterKind IntEnum
# defined in Lib/inspect.py. Each enum member has an integer .value attribute
# corresponding to its ordinal position in the enum definition. POSITIONAL_ONLY
# (0) covers parameters before a bare /. POSITIONAL_OR_KEYWORD (1) is the
# default for ordinary parameters. VAR_POSITIONAL (2) covers *args. KEYWORD_ONLY
# (3) covers parameters after a bare *. VAR_KEYWORD (4) covers **kwargs.
# New to extra161.
# ---------------------------------------------------------------------------

table inspect_extra161.parameter_kind_enum_values:
  description: "inspect.Parameter: POSITIONAL_ONLY.value 0, POSITIONAL_OR_KEYWORD.value 1, VAR_POSITIONAL.value 2, KEYWORD_ONLY.value 3, VAR_KEYWORD.value 4; wave 290; new to extra161"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpkev161

  columns: [id, function, args, expected, description]
  rows:
    - [param_pos_only_value_eq_0,
       "Parameter.POSITIONAL_ONLY.value.__eq__",
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.value.__eq__(0) == True — POSITIONAL_ONLY is a ParameterKind IntEnum member for parameters that can only be supplied positionally (defined before a bare / in the signature); its integer value is 0; int.__eq__(0) returns True; new to extra161"]
    - [param_pos_or_kw_value_eq_1,
       "Parameter.POSITIONAL_OR_KEYWORD.value.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.value.__eq__(1) == True — POSITIONAL_OR_KEYWORD is the default ParameterKind for ordinary parameters that may be supplied either positionally or as keyword arguments; its integer value is 1; int.__eq__(1) returns True; new to extra161"]
    - [param_var_pos_value_eq_2,
       "Parameter.VAR_POSITIONAL.value.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.value.__eq__(2) == True — VAR_POSITIONAL is the ParameterKind for *args parameters that capture all remaining positional arguments into a tuple; its integer value is 2; int.__eq__(2) returns True; new to extra161"]
    - [param_kw_only_value_eq_3,
       "Parameter.KEYWORD_ONLY.value.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.value.__eq__(3) == True — KEYWORD_ONLY is the ParameterKind for parameters that appear after a bare * and must be supplied as keyword arguments; its integer value is 3; int.__eq__(3) returns True; new to extra161"]
    - [param_var_kw_value_eq_4,
       "Parameter.VAR_KEYWORD.value.__eq__",
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.value.__eq__(4) == True — VAR_KEYWORD is the ParameterKind for **kwargs parameters that capture all remaining keyword arguments into a dict; its integer value is 4; int.__eq__(4) returns True; new to extra161"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter class identity
#
# Wave 290 theme: inspect.Parameter class identity — name, module, and base
# class.
#
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__bases__[0].__name__ == 'object'
#
# inspect.Parameter is a Python class defined in Lib/inspect.py that represents
# a parameter of a callable object. Each Parameter instance describes one
# function parameter including its name, default value, annotation, and kind
# (one of the ParameterKind enum members). Parameter inherits directly from
# object; its __module__ is 'inspect'. New to extra161.
# ---------------------------------------------------------------------------

table inspect_extra161.parameter_class_identity:
  description: "inspect.Parameter: __name__ 'Parameter', __module__ 'inspect', __bases__[0].__name__ 'object'; wave 290; new to extra161"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparamci161

  columns: [id, function, args, expected, description]
  rows:
    - [param_name_eq_parameter,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — Parameter is a Python class in Lib/inspect.py representing a callable parameter; it holds the parameter name, default, annotation, and kind; its class name is 'Parameter'; str.__eq__('Parameter') returns True; new to extra161"]
    - [param_module_eq_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra161"]
    - ["param_bases_0_name_eq_object",
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter inherits directly from object; its __bases__ tuple has a single element (object) whose __name__ is 'object'; str.__eq__('object') returns True; new to extra161"]
    - [param_pos_only_int_eq_0,
       "Parameter.POSITIONAL_ONLY.__int__",
       [],
       0,
       "inspect.Parameter.POSITIONAL_ONLY.__int__() == 0 — POSITIONAL_ONLY is a ParameterKind IntEnum member; as an IntEnum it supports __int__(); int(POSITIONAL_ONLY) is 0; new to extra161"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra161
# ---------------------------------------------------------------------------

invariant inspect_extra161.param_positional_only_value_0:
  description: "inspect.Parameter.POSITIONAL_ONLY.value == 0 — parameters before bare / that can only be supplied positionally; wave 290; new to extra161"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.value.__eq__
  args: [0]
  expected: true

invariant inspect_extra161.param_positional_or_keyword_value_1:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.value == 1 — default kind for ordinary parameters that accept both positional and keyword supply; wave 290; new to extra161"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.value.__eq__
  args: [1]
  expected: true

invariant inspect_extra161.param_var_positional_value_2:
  description: "inspect.Parameter.VAR_POSITIONAL.value == 2 — *args parameters capturing excess positional arguments; wave 290; new to extra161"
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.value.__eq__
  args: [2]
  expected: true

invariant inspect_extra161.param_keyword_only_value_3:
  description: "inspect.Parameter.KEYWORD_ONLY.value == 3 — parameters after bare * that must be supplied as keywords; wave 290; new to extra161"
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.value.__eq__
  args: [3]
  expected: true

invariant inspect_extra161.param_var_keyword_value_4:
  description: "inspect.Parameter.VAR_KEYWORD.value == 4 — **kwargs parameters capturing excess keyword arguments; wave 290; new to extra161"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.value.__eq__
  args: [4]
  expected: true

invariant inspect_extra161.parameter_module_inspect:
  description: "inspect.Parameter.__module__ == 'inspect' — Parameter class defined in Lib/inspect.py; wave 290; new to extra161"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true
