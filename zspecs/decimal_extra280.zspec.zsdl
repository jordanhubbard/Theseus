spec: decimal_extra280
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic Specification, Version 1.72"
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra279.zspec.zsdl — covers Decimal.as_tuple() sign and exponent fields for regular numbers"
    - "decimal.zspec.zsdl — covers str repr, predicates, as_tuple sign/exponent for regular values"
  notes:
    - "This spec focuses on Decimal special values: Infinity, -Infinity, NaN, and sNaN."
    - "Decimal('Infinity').__str__() == 'Infinity' — the canonical string form uses a capital I."
    - "Decimal('-Infinity').__str__() == '-Infinity' — negative infinity uses a leading minus sign."
    - "Decimal('NaN').__str__() == 'NaN' — quiet NaN string form."
    - "Decimal('sNaN').__str__() == 'sNaN' — signaling NaN uses lowercase 's' prefix."
    - "Decimal('Inf').__str__() == 'Infinity' — 'Inf' is an accepted input alias; output is always 'Infinity'."
    - "Decimal('-Inf').__str__() == '-Infinity' — '-Inf' normalizes to '-Infinity' on output."
    - "Decimal('Infinity').is_infinite() == True; Decimal('Infinity').is_finite() == False."
    - "Decimal('-Infinity').is_infinite() == True; Decimal('-Infinity').is_signed() == True."
    - "Decimal('Infinity').is_signed() == False — positive infinity has sign bit 0."
    - "Decimal('NaN').is_nan() == True; Decimal('NaN').is_snan() == False — NaN is a quiet NaN."
    - "Decimal('sNaN').is_snan() == True; Decimal('sNaN').is_nan() == True — is_nan() returns True for both NaN and sNaN."
    - "Decimal('Infinity').as_tuple().exponent == 'F' — the IBM GDA spec uses 'F' for infinity exponent."
    - "Decimal('NaN').as_tuple().exponent == 'n' — quiet NaN exponent is the string 'n'."
    - "Decimal('sNaN').as_tuple().exponent == 'N' — signaling NaN exponent is the string 'N'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Special value __str__() representations
#
# The canonical string forms for Infinity, -Infinity, NaN, and sNaN are
# normalised by Decimal; input aliases like 'Inf' are canonicalized on output.
# ---------------------------------------------------------------------------

table decimal_extra280.special_str_repr:
  description: "Decimal special values: canonical __str__() output forms"
  kind: python_call_eq
  category: special_str
  id_prefix: sstr280

  columns: [id, function, args, expected, description]
  rows:
    - [infinity,        "Decimal('Infinity').__str__",  [], "Infinity",   "Decimal('Infinity').__str__() == 'Infinity' — canonical capitalized form"]
    - [neg_infinity,    "Decimal('-Infinity').__str__", [], "-Infinity",  "Decimal('-Infinity').__str__() == '-Infinity' — negative infinity"]
    - [nan,             "Decimal('NaN').__str__",       [], "NaN",        "Decimal('NaN').__str__() == 'NaN' — quiet NaN"]
    - [snan,            "Decimal('sNaN').__str__",      [], "sNaN",       "Decimal('sNaN').__str__() == 'sNaN' — signaling NaN with lowercase 's'"]
    - [inf_alias,       "Decimal('Inf').__str__",       [], "Infinity",   "Decimal('Inf').__str__() == 'Infinity' — 'Inf' input alias canonicalized"]
    - [neg_inf_alias,   "Decimal('-Inf').__str__",      [], "-Infinity",  "Decimal('-Inf').__str__() == '-Infinity' — '-Inf' input alias canonicalized"]

# ---------------------------------------------------------------------------
# Special value predicates — is_infinite, is_nan, is_snan, is_signed, is_finite
#
# These predicates allow callers to test for each class of special value.
# is_nan() returns True for both quiet NaN and signaling NaN.
# is_snan() returns True only for signaling NaN.
# ---------------------------------------------------------------------------

table decimal_extra280.special_predicates:
  description: "Decimal special value predicates: is_infinite, is_finite, is_signed, is_nan, is_snan"
  kind: python_call_eq
  category: special_predicates
  id_prefix: spred280

  columns: [id, function, args, expected, description]
  rows:
    - [inf_is_infinite,        "Decimal('Infinity').is_infinite",   [], true,  "Decimal('Infinity').is_infinite() == True"]
    - [neg_inf_is_infinite,    "Decimal('-Infinity').is_infinite",  [], true,  "Decimal('-Infinity').is_infinite() == True"]
    - [inf_not_finite,         "Decimal('Infinity').is_finite",     [], false, "Decimal('Infinity').is_finite() == False — infinity is not finite"]
    - [inf_not_signed,         "Decimal('Infinity').is_signed",     [], false, "Decimal('Infinity').is_signed() == False — positive infinity has sign bit 0"]
    - [neg_inf_is_signed,      "Decimal('-Infinity').is_signed",    [], true,  "Decimal('-Infinity').is_signed() == True — negative infinity has sign bit 1"]
    - [nan_is_nan,             "Decimal('NaN').is_nan",             [], true,  "Decimal('NaN').is_nan() == True — quiet NaN"]
    - [nan_not_snan,           "Decimal('NaN').is_snan",            [], false, "Decimal('NaN').is_snan() == False — quiet NaN is not a signaling NaN"]
    - [snan_is_snan,           "Decimal('sNaN').is_snan",           [], true,  "Decimal('sNaN').is_snan() == True — signaling NaN"]
    - [snan_is_nan,            "Decimal('sNaN').is_nan",            [], true,  "Decimal('sNaN').is_nan() == True — is_nan() returns True for both NaN types"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra280.Decimal.infinity_str:
  description: "Decimal('Infinity').__str__() == 'Infinity' — positive infinity canonical string representation"
  category: special_str
  kind: python_call_eq
  function: "Decimal('Infinity').__str__"
  args: []
  expected: "Infinity"

invariant decimal_extra280.Decimal.neg_infinity_str:
  description: "Decimal('-Infinity').__str__() == '-Infinity' — negative infinity canonical string representation"
  category: special_str
  kind: python_call_eq
  function: "Decimal('-Infinity').__str__"
  args: []
  expected: "-Infinity"

invariant decimal_extra280.Decimal.nan_str:
  description: "Decimal('NaN').__str__() == 'NaN' — quiet NaN canonical string representation"
  category: special_str
  kind: python_call_eq
  function: "Decimal('NaN').__str__"
  args: []
  expected: "NaN"

invariant decimal_extra280.Decimal.snan_str:
  description: "Decimal('sNaN').__str__() == 'sNaN' — signaling NaN canonical string representation with lowercase 's' prefix"
  category: special_str
  kind: python_call_eq
  function: "Decimal('sNaN').__str__"
  args: []
  expected: "sNaN"

invariant decimal_extra280.Decimal.infinity_exponent_is_F:
  description: "Decimal('Infinity').as_tuple().exponent == 'F' — the IBM GDA spec encodes infinity exponent as the string 'F'"
  category: special_as_tuple
  kind: python_call_eq
  function: "Decimal('Infinity').as_tuple().exponent"
  args: []
  expected: "F"

invariant decimal_extra280.Decimal.nan_exponent_is_n:
  description: "Decimal('NaN').as_tuple().exponent == 'n' — quiet NaN exponent is the lowercase string 'n'"
  category: special_as_tuple
  kind: python_call_eq
  function: "Decimal('NaN').as_tuple().exponent"
  args: []
  expected: "n"

invariant decimal_extra280.Decimal.snan_exponent_is_N:
  description: "Decimal('sNaN').as_tuple().exponent == 'N' — signaling NaN exponent is the uppercase string 'N'"
  category: special_as_tuple
  kind: python_call_eq
  function: "Decimal('sNaN').as_tuple().exponent"
  args: []
  expected: "N"
