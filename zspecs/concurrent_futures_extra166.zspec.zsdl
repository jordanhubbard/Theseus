spec: concurrent_futures_extra166
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.Future.__dict__.__contains__ checks for 'result', 'add_done_callback', 'cancel', 'done', 'running'; concurrent.futures.Future.__dict__.__class__.__name__=='mappingproxy'. KEY FINDINGS: all five method names are present in Future.__dict__ (True); Future.__dict__.__class__.__name__=='mappingproxy' (the class dict is a read-only mappingproxy, not a plain dict); Future.__dict__.__len__()==21 (21 entries in the class dict as of Python 3.14.3). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.__dict__.__contains__('result')==True; Future.__dict__.__contains__('add_done_callback')==True; Future.__dict__.__contains__('cancel')==True; Future.__dict__.__contains__('done')==True; Future.__dict__.__contains__('running')==True. All five are defined directly in Future's class dict (not inherited). Verified with Python 3.14.3."
    - "concurrent.futures.Future.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); all class __dict__ attributes in Python return a mappingproxy (a read-only view of the class namespace); Future.__dict__.__len__()==21 (21 entries: '__module__', '__firstlineno__', '__doc__', '__init__', '_invoke_callbacks', '__repr__', 'cancel', 'cancelled', 'running', 'done', '_Future__get_result', 'add_done_callback', 'result', 'exception', 'set_running_or_notify_cancel', 'set_result', 'set_exception', '__class_getitem__', '__static_attributes__', '__dict__', '__weakref__'). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future.__dict__.__contains__ — result and add_done_callback — extra166
#
# concurrent.futures.Future.__dict__.__contains__('result')             == True
# concurrent.futures.Future.__dict__.__contains__('add_done_callback')  == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra166.cf_future_dict_result_and_callback:
  description: "concurrent.futures.Future.__dict__.__contains__ checks for 'result' and 'add_done_callback' in cffuturedict166a namespace — concurrent.futures.Future.__dict__.__contains__('result')==True ('result' is directly in Future.__dict__; Future.result(timeout=None) returns the value set by set_result() or raises the exception set by set_exception(); if the future is not yet done, result() blocks until it completes or timeout elapses; the method is defined directly in Future's class body, NOT inherited from a base class; Future.__bases__[0].__name__=='object' (Future inherits from object directly — all Future methods are in its own __dict__)); concurrent.futures.Future.__dict__.__contains__('add_done_callback')==True ('add_done_callback' is directly in Future.__dict__; Future.add_done_callback(fn) schedules fn to be called when the future completes — fn is called with the future as its single argument; callbacks are called in the thread that resolves the future or in the calling thread if the future is already done when add_done_callback is called); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffuturedict166a

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_result,            concurrent.futures.Future.__dict__.__contains__,  ["result"],            true,  "Future.__dict__.__contains__('result') == True (Future.result() returns value or raises); verified with Python 3.14.3"]
    - [dict_has_add_done_callback, concurrent.futures.Future.__dict__.__contains__,  ["add_done_callback"], true,  "Future.__dict__.__contains__('add_done_callback') == True (schedule callback on completion); verified with Python 3.14.3"]
    - [dict_has_result2,           concurrent.futures.Future.__dict__.__contains__,  ["result"],            true,  "Future.__dict__.__contains__('result') == True (cross-check; 'result' is the primary consumer API); verified with Python 3.14.3"]
    - [dict_has_adc2,              concurrent.futures.Future.__dict__.__contains__,  ["add_done_callback"], true,  "Future.__dict__.__contains__('add_done_callback') == True (cross-check; callbacks fire in completion thread); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future.__dict__.__contains__ — cancel and done — extra166
#
# concurrent.futures.Future.__dict__.__contains__('cancel')  == True
# concurrent.futures.Future.__dict__.__contains__('done')    == True
# concurrent.futures.Future.__dict__.__contains__('running') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra166.cf_future_dict_cancel_done_running:
  description: "concurrent.futures.Future.__dict__.__contains__ checks for 'cancel', 'done', and 'running' in cffuturedict166b namespace — concurrent.futures.Future.__dict__.__contains__('cancel')==True ('cancel' is directly in Future.__dict__; Future.cancel() attempts to cancel the future: returns True if successful (future transitions to CANCELLED state), False if the future is already running or done; cancellation is advisory — a running future continues executing but result() raises CancelledError); concurrent.futures.Future.__dict__.__contains__('done')==True ('done' is directly in Future.__dict__; Future.done() returns True if the future has completed — either finished normally, raised an exception, or was cancelled; done() returns False while the future is still PENDING or RUNNING); concurrent.futures.Future.__dict__.__contains__('running')==True ('running' is directly in Future.__dict__; Future.running() returns True only while the future is in the RUNNING state — i.e., the callable is being executed by an executor thread/process but has not yet finished); KEY PATTERN: 'cancel' (6), 'done' (4), 'running' (7) — all state-query and state-transition methods are in Future.__dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffuturedict166b

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_cancel,  concurrent.futures.Future.__dict__.__contains__,  ["cancel"],  true,  "Future.__dict__.__contains__('cancel') == True (cancel() attempts to cancel the future); verified with Python 3.14.3"]
    - [dict_has_done,    concurrent.futures.Future.__dict__.__contains__,  ["done"],    true,  "Future.__dict__.__contains__('done') == True (done() returns True when future is complete); verified with Python 3.14.3"]
    - [dict_has_running, concurrent.futures.Future.__dict__.__contains__,  ["running"], true,  "Future.__dict__.__contains__('running') == True (running() returns True while executor is executing); verified with Python 3.14.3"]
    - [dict_has_cancel2, concurrent.futures.Future.__dict__.__contains__,  ["cancel"],  true,  "Future.__dict__.__contains__('cancel') == True (cross-check; returns False if already running/done); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future.__dict__.__class__.__name__ — extra166
#
# concurrent.futures.Future.__dict__.__class__.__name__.__eq__('mappingproxy') == True
# concurrent.futures.Future.__dict__.__class__.__name__.__len__()               == 12
# ---------------------------------------------------------------------------

table concurrent_futures_extra166.cf_future_dict_class_name:
  description: "concurrent.futures.Future.__dict__.__class__.__name__ identity checks in cffuturedictcls166 namespace — concurrent.futures.Future.__dict__.__class__.__name__.__eq__('mappingproxy')==True (Future.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); every Python class's __dict__ attribute returns a mappingproxy, not a plain dict; mappingproxy is a read-only view of the class namespace — you cannot do Future.__dict__['key'] = value directly; mappingproxy is defined in CPython as types.MappingProxyType; the mappingproxy wraps the actual internal dict and prevents direct mutation of the class namespace from outside — class attributes must be set via setattr() or by assignment through the class object itself); concurrent.futures.Future.__dict__.__class__.__name__.__len__()==12 ('mappingproxy'=12: 'mapping'=7+'proxy'=5=12; 'mappingproxy' is the Python type name for read-only class namespace views); future_dict_len cross-check: Future.__dict__.__len__()==21 (21 entries in Future's class dict as of Python 3.14.3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffuturedictcls166

  columns: [id, function, args, expected, description]
  rows:
    - [dict_cls_name_eq,  concurrent.futures.Future.__dict__.__class__.__name__.__eq__,  ["mappingproxy"],  true,  "Future.__dict__.__class__.__name__ == 'mappingproxy' (read-only class namespace view; len=12); verified with Python 3.14.3"]
    - [dict_cls_name_len, concurrent.futures.Future.__dict__.__class__.__name__.__len__, [],                12,    "Future.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12: 'mapping'=7+'proxy'=5=12); verified with Python 3.14.3"]
    - [dict_len,          concurrent.futures.Future.__dict__.__len__,                    [],                21,    "Future.__dict__.__len__() == 21 (21 entries in Future class dict as of Python 3.14.3); verified with Python 3.14.3"]
    - [dict_has_result3,  concurrent.futures.Future.__dict__.__contains__,               ["result"],        true,  "Future.__dict__.__contains__('result') == True (cross-check: 'result' is among the 21 entries); verified with Python 3.14.3"]

