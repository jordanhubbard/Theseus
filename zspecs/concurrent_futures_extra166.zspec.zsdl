table concurrent_futures_extra166.cf_future_dict_comprehensive:
  description: "concurrent.futures.Future.__dict__ comprehensive membership cross-checks in cffuturexcheck166 namespace — all five target methods ('result', 'add_done_callback', 'cancel', 'done', 'running') are confirmed present in Future.__dict__; Future.__dict__.__len__()==21 (21 total entries including the five target methods plus: '__module__', '__firstlineno__', '__doc__', '__init__', '_invoke_callbacks', '__repr__', 'cancelled', '_Future__get_result', 'exception', 'set_running_or_notify_cancel', 'set_result', 'set_exception', '__class_getitem__', '__static_attributes__', '__dict__', '__weakref__'); KEY: Future.__dict__.__contains__('result')==True AND Future.__dict__.__contains__('done')==True — both state accessors are directly defined; KEY: Future.__dict__.__contains__('cancel')==True — the cancel() method is directly defined (cancellation is optional and advisory in concurrent.futures); KEY: Future.__dict__.__contains__('running')==True — distinct from 'done': running() returns True only during execution, done() returns True after all completion states; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffuturexcheck166

  columns: [id, function, args, expected, description]
  rows:
    - [xcheck_result,   concurrent.futures.Future.__dict__.__contains__,  ["result"],            true,  "Future.__dict__.__contains__('result') == True (cross-check; result() is the primary consumer API); verified with Python 3.14.3"]
    - [xcheck_adc,      concurrent.futures.Future.__dict__.__contains__,  ["add_done_callback"], true,  "Future.__dict__.__contains__('add_done_callback') == True (cross-check; callback registration); verified with Python 3.14.3"]
    - [xcheck_cancel,   concurrent.futures.Future.__dict__.__contains__,  ["cancel"],            true,  "Future.__dict__.__contains__('cancel') == True (cross-check; cancellation control); verified with Python 3.14.3"]
