# ---------------------------------------------------------------------------
# Standalone invariants — extra166
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra166.cf_Future_dict_has_result:
  description: "concurrent.futures.Future.__dict__.__contains__('result') returns True — concurrent.futures.Future.__dict__.__contains__('result')==True; Future.result(timeout=None) is the primary method for obtaining the value from a completed future; it blocks until the future is done (or timeout expires), then: returns the value if set_result() was called; raises the exception if set_exception() was called; raises CancelledError if the future was cancelled; raises TimeoutError if the timeout expires before completion; 'result' is defined directly in Future's class body (not inherited from object) — this is confirmed by it appearing in Future.__dict__; compare: asyncio.Future (the asyncio counterpart) has a similar result() method but is C-accelerated in _asyncio; concurrent.futures.Future.result() is pure Python in _base.py; Future.__dict__.__len__()==21 — 'result' is one of 21 entries in the class dict; NEW in extra166: first standalone Future.__dict__.__contains__('result') invariant in cffuturedict166a namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["result"]
  expected: true

invariant concurrent_futures_extra166.cf_Future_dict_has_add_done_callback:
  description: "concurrent.futures.Future.__dict__.__contains__('add_done_callback') returns True — concurrent.futures.Future.__dict__.__contains__('add_done_callback')==True; Future.add_done_callback(fn) registers fn to be called when the future completes; fn is called with the future object as its sole argument; if the future is already done when add_done_callback is called, fn is called immediately in the calling thread; callbacks are called in the thread that set the result/exception/cancellation — this is important for thread-safety; multiple callbacks can be registered and are called in the order they were added; 'add_done_callback' is directly in Future.__dict__ (not inherited); the method name 'add_done_callback' is 17 chars long: 'add'=3+'_'=1+'done'=4+'_'=1+'callback'=8=17; compare: 'result'=6 is 11 chars shorter than 'add_done_callback'=17; Future.__dict__.__contains__('add_done_callback')==True establishes that callback registration is a core Future responsibility defined in the class itself; NEW in extra166: first standalone Future.__dict__.__contains__('add_done_callback') invariant in cffuturedict166a namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["add_done_callback"]
  expected: true

invariant concurrent_futures_extra166.cf_Future_dict_has_cancel:
  description: "concurrent.futures.Future.__dict__.__contains__('cancel') returns True — concurrent.futures.Future.__dict__.__contains__('cancel')==True; Future.cancel() attempts to cancel the future; it returns True if the future was successfully cancelled (transitioned from PENDING to CANCELLED state), or False if the future is already running or done (cancellation of a running future is not possible in concurrent.futures — the executor thread continues running even if cancel() returns False); 'cancel' is directly defined in Future.__dict__; Future.cancel() is the advisory cancellation method — callers should check the return value; compare: asyncio's Task.cancel() is different — it schedules a CancelledError to be thrown into the task on the next iteration; concurrent.futures.Future.cancel() cannot interrupt a running future; 'cancel'=6 chars; compare: 'done'=4 is 2 shorter; 'running'=7 is 1 longer than 'cancel'=6; LENGTH ORDERING among state methods: done(4) < result(6)==cancel(6) < running(7) < add_done_callback(17); NEW in extra166: first standalone Future.__dict__.__contains__('cancel') invariant in cffuturedict166b namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["cancel"]
  expected: true

invariant concurrent_futures_extra166.cf_Future_dict_has_done:
  description: "concurrent.futures.Future.__dict__.__contains__('done') returns True — concurrent.futures.Future.__dict__.__contains__('done')==True; Future.done() returns True if the future has completed in any final state: FINISHED (result or exception set), or CANCELLED; done() returns False if the future is still PENDING or RUNNING; 'done' is defined directly in Future.__dict__; 'done'=4 chars is the shortest method name among the five target methods: done(4) < result=cancel(6) < running(7) < add_done_callback(17); compare: 'done' in asyncio.Future (asyncio's C-accelerated counterpart) — both libraries have a done() method for checking completion; compare: Future.__dict__.__contains__('running')==True (running() is distinct from done(): running() returns True only during execution, not after; done() returns True after all completion including cancellation); Future.__dict__.__len__()==21 — 'done' is one of 21 entries; NEW in extra166: first standalone Future.__dict__.__contains__('done') invariant in cffuturedict166b namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["done"]
  expected: true

invariant concurrent_futures_extra166.cf_Future_dict_has_running:
  description: "concurrent.futures.Future.__dict__.__contains__('running') returns True — concurrent.futures.Future.__dict__.__contains__('running')==True; Future.running() returns True only while the future is in the RUNNING state — i.e., the callable is currently being executed by the executor (thread or process) but has not yet finished; once the callable returns (or raises), the future transitions to FINISHED and running() returns False; after cancellation, running() returns False (cancelled futures are not running); 'running' is directly in Future.__dict__; compare 'running'(True) vs 'done'(True) vs 'cancel'(True) — all three state-related methods are in Future.__dict__; 'running'=7 chars is the longest state-query method name among the single-word methods: done(4) < result=cancel(6) < running(7); Future.__dict__.__class__.__name__=='mappingproxy' — the class dict is a read-only mappingproxy (covered in this spec); Future.__dict__.__len__()==21; NEW in extra166: first standalone Future.__dict__.__contains__('running') invariant in cffuturedict166b namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__contains__
  args: ["running"]
  expected: true

invariant concurrent_futures_extra166.cf_Future_dict_class_name_eq:
  description: "concurrent.futures.Future.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — concurrent.futures.Future.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); every Python class's __dict__ is a mappingproxy (types.MappingProxyType), not a plain dict; the mappingproxy is a read-only wrapper around the class's internal namespace dict that prevents direct external mutation; to add a class attribute you must use setattr(Future, 'attr', value) or assignment via the class object, not via Future.__dict__['attr'] = value (which raises TypeError); mappingproxy supports all read operations: __contains__, __getitem__, __len__, __iter__, keys(), values(), items(); Future.__dict__.__class__.__name__=='mappingproxy' (len=12) == abc.ABC.__dict__.__class__.__name__=='mappingproxy' (confirmed by abc_extra164 verification — all class dicts are mappingproxies); the name 'mappingproxy'=12 is longer than 'dict'=4 by 8 — the full type name emphasizes its proxy (read-only) nature; NEW in extra166: first standalone Future.__dict__.__class__.__name__ invariant in cffuturedictcls166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant concurrent_futures_extra166.cf_Future_dict_len:
  description: "concurrent.futures.Future.__dict__.__len__() returns 21 — concurrent.futures.Future.__dict__.__len__()==21 (21 entries in Future's class dict as of Python 3.14.3 on macOS/Darwin 25.4.0); the 21 entries are: '__module__', '__firstlineno__', '__doc__', '__init__', '_invoke_callbacks', '__repr__', 'cancel', 'cancelled', 'running', 'done', '_Future__get_result', 'add_done_callback', 'result', 'exception', 'set_running_or_notify_cancel', 'set_result', 'set_exception', '__class_getitem__', '__static_attributes__', '__dict__', '__weakref__'; the five target methods ('result', 'add_done_callback', 'cancel', 'done', 'running') are 5 of the 21 entries; note the name-mangled method '_Future__get_result' (Python name mangling converts __get_result to _Future__get_result); compare: abc.ABCMeta.__dict__.__len__()==11 (established in abc_extra164) — ABCMeta's dict is roughly half the size of Future's dict (11 vs 21) because Future defines more public methods; abc.ABC.__dict__.__len__()==7 (abc_extra164) — ABC's dict is much smaller; concurrent.futures.Future.__dict__.__len__()==21 is the largest dict count established so far in this module series; NEW in extra166: first standalone Future.__dict__.__len__ invariant in cffuturedictcls166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__dict__.__len__
  args: []
  expected: 21

