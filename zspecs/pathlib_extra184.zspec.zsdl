spec: pathlib_extra184
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec covers: pathlib.Path resolve/rename/unlink method names — resolve, rename, replace, unlink, rmdir, touch, symlink_to, hardlink_to — all are Python functions defined on Path."
    - "pathlib.Path.resolve.__name__ == 'resolve' (len=7); pathlib.Path.rename.__name__ == 'rename' (len=6); pathlib.Path.replace.__name__ == 'replace' (len=7)."
    - "pathlib.Path.unlink.__name__ == 'unlink' (len=6); pathlib.Path.rmdir.__name__ == 'rmdir' (len=5); pathlib.Path.touch.__name__ == 'touch' (len=5)."
    - "pathlib.Path.symlink_to.__name__ == 'symlink_to' (len=10); pathlib.Path.hardlink_to.__name__ == 'hardlink_to' (len=11)."
    - "Name length groupings: rmdir==touch (5); rename==unlink (6); resolve==replace (7); symlink_to (10); hardlink_to (11)."
    - "rmdir==touch (5): a 2-way tie at length 5 — the shortest method names covered."
    - "rename==unlink (6): a 2-way tie at length 6."
    - "resolve==replace (7): a 2-way tie at length 7."
    - "hardlink_to (11) > symlink_to (10) by 1: hardlink_to is the longest method name covered."
    - "Length ordering: rmdir==touch (5) < rename==unlink (6) < resolve==replace (7) < symlink_to (10) < hardlink_to (11)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.Path short-name methods (rmdir, touch, rename, unlink)
# rmdir==touch (5); rename==unlink (6)
# ---------------------------------------------------------------------------

table pathlib_extra184.short_method_names:
  description: "pathlib.Path short-name filesystem methods: rmdir.__name__=='rmdir' (len=5); touch.__name__=='touch' (len=5); rename.__name__=='rename' (len=6); unlink.__name__=='unlink' (len=6); rmdir==touch (5) < rename==unlink (6)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmodify184

  columns: [id, function, args, expected, description]
  rows:
    - [rmdir_name,     Path.rmdir.__name__.__eq__,    ["rmdir"],  true, "pathlib.Path.rmdir.__name__ == 'rmdir' — rmdir() removes an empty directory; 'rmdir' has 5 characters: r(1)m(2)d(3)i(4)r(5); rmdir (5) == touch (5): a 2-way tie at length 5 — the shortest method names covered; confirmed Python 3.14.3 macOS"]
    - [rmdir_name_len, Path.rmdir.__name__.__len__,   [],         5,    "pathlib.Path.rmdir.__name__.__len__() == 5 — 'rmdir' has 5 characters; rmdir (5) == touch (5): both share length 5; rmdir==touch (5) < rename==unlink (6) < resolve==replace (7) < symlink_to (10) < hardlink_to (11): full ordering; confirmed Python 3.14.3 macOS"]
    - [touch_name,     Path.touch.__name__.__eq__,    ["touch"],  true, "pathlib.Path.touch.__name__ == 'touch' — touch() creates the file if it does not exist, or updates its modification time; 'touch' has 5 characters: t(1)o(2)u(3)c(4)h(5); touch (5) == rmdir (5): a 2-way tie at length 5; confirmed Python 3.14.3 macOS"]
    - [touch_name_len, Path.touch.__name__.__len__,   [],         5,    "pathlib.Path.touch.__name__.__len__() == 5 — 'touch' has 5 characters; touch (5) == rmdir (5): both are in the 2-way tie at length 5; rmdir==touch (5) < rename==unlink (6): the length-5 group is shorter than the length-6 group; confirmed Python 3.14.3 macOS"]
    - [rename_name,    Path.rename.__name__.__eq__,   ["rename"], true, "pathlib.Path.rename.__name__ == 'rename' — rename() renames the file or directory to the target path; 'rename' has 6 characters: r(1)e(2)n(3)a(4)m(5)e(6); rename (6) == unlink (6): a 2-way tie at length 6; confirmed Python 3.14.3 macOS"]
    - [rename_name_len, Path.rename.__name__.__len__, [],         6,    "pathlib.Path.rename.__name__.__len__() == 6 — 'rename' has 6 characters; rename (6) == unlink (6): both share length 6; rmdir==touch (5) < rename==unlink (6): the length-6 group is longer than the length-5 group by 1; confirmed Python 3.14.3 macOS"]
    - [unlink_name,    Path.unlink.__name__.__eq__,   ["unlink"], true, "pathlib.Path.unlink.__name__ == 'unlink' — unlink() removes the file (as opposed to rmdir for directories); 'unlink' has 6 characters: u(1)n(2)l(3)i(4)n(5)k(6); unlink (6) == rename (6): a 2-way tie at length 6; confirmed Python 3.14.3 macOS"]
    - [unlink_name_len, Path.unlink.__name__.__len__, [],         6,    "pathlib.Path.unlink.__name__.__len__() == 6 — 'unlink' has 6 characters; unlink (6) == rename (6): both share length 6; rmdir==touch (5) < rename==unlink (6) < resolve==replace (7): unlink is in the middle length group; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.Path medium-name methods (resolve, replace)
# resolve==replace (7) — a 2-way tie at length 7
# ---------------------------------------------------------------------------

table pathlib_extra184.medium_method_names:
  description: "pathlib.Path medium-name methods: resolve.__name__=='resolve' (len=7); replace.__name__=='replace' (len=7); resolve==replace (7) — a 2-way tie at length 7; rename==unlink (6) < resolve==replace (7)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmodify184

  columns: [id, function, args, expected, description]
  rows:
    - [resolve_name,      Path.resolve.__name__.__eq__,   ["resolve"], true, "pathlib.Path.resolve.__name__ == 'resolve' — resolve() makes the path absolute, resolving any symlinks; 'resolve' has 7 characters: r(1)e(2)s(3)o(4)l(5)v(6)e(7); resolve (7) == replace (7): a 2-way tie at length 7; confirmed Python 3.14.3 macOS"]
    - [resolve_name_len,  Path.resolve.__name__.__len__,  [],          7,    "pathlib.Path.resolve.__name__.__len__() == 7 — 'resolve' has 7 characters; resolve (7) == replace (7): both share length 7; rename==unlink (6) < resolve==replace (7) < symlink_to (10): resolve is in the middle length tier; confirmed Python 3.14.3 macOS"]
    - [replace_name,      Path.replace.__name__.__eq__,   ["replace"], true, "pathlib.Path.replace.__name__ == 'replace' — replace() renames the path to target, overwriting it if it exists (unlike rename which may not overwrite); 'replace' has 7 characters: r(1)e(2)p(3)l(4)a(5)c(6)e(7); replace (7) == resolve (7): a 2-way tie at length 7; confirmed Python 3.14.3 macOS"]
    - [replace_name_len,  Path.replace.__name__.__len__,  [],          7,    "pathlib.Path.replace.__name__.__len__() == 7 — 'replace' has 7 characters; replace (7) == resolve (7): both share length 7; rename==unlink (6) < resolve==replace (7) < symlink_to (10); confirmed Python 3.14.3 macOS"]
    - [resolve_class,     Path.resolve.__class__.__name__.__eq__, ["function"], true, "pathlib.Path.resolve.__class__.__name__ == 'function' — Path.resolve is a Python function (not a C method_descriptor); all Path filesystem methods in this spec are Python functions defined in pathlib; confirmed Python 3.14.3 macOS"]
    - [replace_class,     Path.replace.__class__.__name__.__eq__, ["function"], true, "pathlib.Path.replace.__class__.__name__ == 'function' — Path.replace is a Python function, same class as resolve; all covered Path methods are Python functions; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.Path link methods (symlink_to, hardlink_to)
# symlink_to (10) < hardlink_to (11): hardlink_to is the longest covered name
# ---------------------------------------------------------------------------

table pathlib_extra184.link_method_names:
  description: "pathlib.Path link-creation method names: symlink_to.__name__=='symlink_to' (len=10); hardlink_to.__name__=='hardlink_to' (len=11); symlink_to (10) < hardlink_to (11) by 1; hardlink_to (11) is the longest covered method name"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmodify184

  columns: [id, function, args, expected, description]
  rows:
    - [symlink_to_name,      Path.symlink_to.__name__.__eq__,   ["symlink_to"],  true, "pathlib.Path.symlink_to.__name__ == 'symlink_to' — symlink_to() creates a symbolic link pointing to the target; 'symlink_to' has 10 characters: s(1)y(2)m(3)l(4)i(5)n(6)k(7)_(8)t(9)o(10); symlink_to (10) < hardlink_to (11): hardlink_to is 1 character longer; confirmed Python 3.14.3 macOS"]
    - [symlink_to_name_len,  Path.symlink_to.__name__.__len__,  [],              10,   "pathlib.Path.symlink_to.__name__.__len__() == 10 — 'symlink_to' has 10 characters; resolve==replace (7) < symlink_to (10) < hardlink_to (11): symlink_to is between the 7-character group and the longest name; confirmed Python 3.14.3 macOS"]
    - [hardlink_to_name,     Path.hardlink_to.__name__.__eq__,  ["hardlink_to"], true, "pathlib.Path.hardlink_to.__name__ == 'hardlink_to' — hardlink_to() creates a hard link pointing to the target (new in Python 3.10); 'hardlink_to' has 11 characters: h(1)a(2)r(3)d(4)l(5)i(6)n(7)k(8)_(9)t(10)o(11); hardlink_to (11) is the longest covered method name; confirmed Python 3.14.3 macOS"]
    - [hardlink_to_name_len, Path.hardlink_to.__name__.__len__, [],              11,   "pathlib.Path.hardlink_to.__name__.__len__() == 11 — 'hardlink_to' has 11 characters; hardlink_to (11) > symlink_to (10) by 1: the 'hard' prefix vs 'sym' prefix adds 1 net character; hardlink_to (11) is the maximum length in the full ordering: rmdir==touch (5) < rename==unlink (6) < resolve==replace (7) < symlink_to (10) < hardlink_to (11); confirmed Python 3.14.3 macOS"]
    - [symlink_to_class,     Path.symlink_to.__class__.__name__.__eq__,  ["function"], true, "pathlib.Path.symlink_to.__class__.__name__ == 'function' — symlink_to is a Python function; confirmed Python 3.14.3 macOS"]
    - [hardlink_to_class,    Path.hardlink_to.__class__.__name__.__eq__, ["function"], true, "pathlib.Path.hardlink_to.__class__.__name__ == 'function' — hardlink_to is a Python function; hardlink_to (11) > symlink_to (10) by 1: both are Python functions but hardlink_to has the longer name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra184.resolve_name_is_resolve:
  description: "pathlib.Path.resolve.__name__ == 'resolve' — resolve() makes the path absolute resolving symlinks; len=7; resolve (7) == replace (7): a 2-way tie at length 7; rename==unlink (6) < resolve==replace (7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.resolve.__name__.__eq__
  args: ["resolve"]
  expected: true

invariant pathlib_extra184.rename_name_len_is_6:
  description: "pathlib.Path.rename.__name__.__len__() == 6 — 'rename' has 6 characters; rename (6) == unlink (6): a 2-way tie at length 6; rmdir==touch (5) < rename==unlink (6): the length-6 group is longer than the length-5 group by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.rename.__name__.__len__
  args: []
  expected: 6

invariant pathlib_extra184.replace_name_len_is_7:
  description: "pathlib.Path.replace.__name__.__len__() == 7 — 'replace' has 7 characters; replace (7) == resolve (7): a 2-way tie at length 7; rename==unlink (6) < resolve==replace (7) < symlink_to (10); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.replace.__name__.__len__
  args: []
  expected: 7

invariant pathlib_extra184.unlink_name_is_unlink:
  description: "pathlib.Path.unlink.__name__ == 'unlink' — unlink() removes the file; len=6; unlink (6) == rename (6): a 2-way tie at length 6; rmdir==touch (5) < rename==unlink (6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.unlink.__name__.__eq__
  args: ["unlink"]
  expected: true

invariant pathlib_extra184.rmdir_name_len_is_5:
  description: "pathlib.Path.rmdir.__name__.__len__() == 5 — 'rmdir' has 5 characters; rmdir (5) == touch (5): a 2-way tie at length 5 — the shortest covered method names; rmdir==touch (5) < rename==unlink (6); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.rmdir.__name__.__len__
  args: []
  expected: 5

invariant pathlib_extra184.symlink_to_name_len_is_10:
  description: "pathlib.Path.symlink_to.__name__.__len__() == 10 — 'symlink_to' has 10 characters; resolve==replace (7) < symlink_to (10) < hardlink_to (11): symlink_to is between the 7-character group and the maximum; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.symlink_to.__name__.__len__
  args: []
  expected: 10

invariant pathlib_extra184.hardlink_to_name_len_is_11:
  description: "pathlib.Path.hardlink_to.__name__.__len__() == 11 — 'hardlink_to' has 11 characters; hardlink_to (11) is the longest covered method name; hardlink_to (11) > symlink_to (10) by 1; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.hardlink_to.__name__.__len__
  args: []
  expected: 11

invariant pathlib_extra184.touch_name_is_touch:
  description: "pathlib.Path.touch.__name__ == 'touch' — touch() creates the file or updates its mtime; len=5; touch (5) == rmdir (5): a 2-way tie at length 5; rmdir==touch (5) is the minimum length group; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Path.touch.__name__.__eq__
  args: ["touch"]
  expected: true

