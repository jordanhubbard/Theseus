spec: deepmerge
version: ">=4.0.0"
backend: node(deepmerge)

docs: https://github.com/TehShrike/deepmerge#readme

provenance:
  derived_from:
    - "deepmerge README — https://github.com/TehShrike/deepmerge#readme"
    - "Test vectors verified with deepmerge@4.3.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "deepmerge source: dist/es.js"
  notes:
    - "deepmerge exports the merge function as the module default (CJS)."
    - "merge(obj1, obj2) returns a new object with obj1 and obj2 deep-merged."
    - "For nested objects, properties are recursively merged (not replaced)."
    - "Arrays from obj2 overwrite arrays from obj1 by default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a new merged object. No errors for plain object inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table deepmerge.merge:
  kind: node_module_call_eq
  function: ~
  category: merge
  id_prefix: dm

  columns: [id, args, expected]
  rows:
    - [flat,    [{"a": 1}, {"b": 2}],              {"a": 1, "b": 2}]
    - [nested,  [{"a": {"x": 1}}, {"a": {"y": 2}}], {"a": {"x": 1, "y": 2}}]
    - [overlap, [{"a": 1}, {"a": 2}],              {"a": 2}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:08:37Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
