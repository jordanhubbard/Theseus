spec: theseus_decimal
version: ">=3.9"
backend: python_cleanroom(theseus_decimal)
blocks: decimal

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html"
    - "https://speleotrove.com/decimal/ — General Decimal Arithmetic specification"
  notes:
    - "Clean-room fixed-precision decimal arithmetic. Do NOT import decimal or fractions."
    - "Decimal('0.1') + Decimal('0.2') == Decimal('0.3') (no floating-point error)."
    - "Decimal('1') / Decimal('3') with precision 28 gives '0.3333333333333333333333333333'."
    - "Decimal('1.005').quantize('0.01') rounds to Decimal('1.01') using ROUND_HALF_UP."
    - "Export: Decimal class with +/-/* /operators, quantize(places, rounding)."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_decimal.add_exact:
  description: "Decimal('0.1') + Decimal('0.2') == Decimal('0.3')"
  category: arithmetic
  kind: python_call_eq
  function: decimal_add_exact
  args: []
  expected: true

invariant theseus_decimal.string_repr:
  description: "str(Decimal('1.23')) == '1.23'"
  category: string
  kind: python_call_eq
  function: decimal_str_repr
  args: []
  expected: "1.23"

invariant theseus_decimal.compare:
  description: "Decimal('0.10') == Decimal('0.1')"
  category: compare
  kind: python_call_eq
  function: decimal_compare_equal
  args: []
  expected: true
