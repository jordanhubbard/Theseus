spec: enum_extra20
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra19.zspec.zsdl."
    - "enum_extra19 covers: __name__.__len__() for unique/nonmember/member; auto/unique/StrEnum MRO[0]; IntEnum MRO[3]/MRO[4]; unique.__mro__.__len__() and unique.__mro__[1]."
    - "enum_extra18 covers: __qualname__.__len__() for Enum/Flag/IntFlag/auto/unique/nonmember/member; EnumType/__qualname__.__eq__/__len__; EnumMeta/__qualname__==EnumType; IntFlag/__qualname__.__eq__; StrEnum/__qualname__.__eq__."
    - "enum_extra17 covers: StrEnum/IntEnum/__qualname__.__len__; StrEnum/__bases__[1]; IntEnum/__bases__[1]; IntEnum/__mro__[2]; Flag/__mro__[1]; EnumMeta/__mro__[1]; StrEnum/__mro__[3]."
    - "enum_extra15 covers: Enum/__module__/__qualname__/__name__.__len__; auto/__module__/__qualname__; EnumMeta/__qualname__; name_lengths table for auto/Enum/Flag/IntEnum."
    - "Focus of this spec: functional Enum API — Enum('Color', ['RED', 'GREEN', 'BLUE']).__len__() etc.; __qualname__ for auto/unique/Enum/IntEnum/Flag/IntFlag/EnumMeta as standalone __eq__ checks — filling gaps left by prior table-only coverage."
    - "NOT yet covered (entering this spec): Enum('Color', ['RED', 'GREEN', 'BLUE']).__len__() == 3; Enum('Status', ['OK', 'ERROR']).__len__() == 2; Enum('Prio', ['LOW', 'MED', 'HIGH']).__len__() == 3; IntEnum('Flags', ['A', 'B', 'C']).__len__() == 3; auto.__qualname__.__eq__('auto') standalone; Enum.__qualname__.__eq__('Enum') standalone; IntEnum.__qualname__.__eq__('IntEnum') standalone; Flag.__qualname__.__eq__('Flag') standalone."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Functional Enum API — Enum(name, members) class creation
#
# The functional API lets you create Enum classes dynamically: Enum('Color', [..])
# returns an Enum subclass. No prior spec exercises __len__() on functionally
# created Enum classes. The created class has one member per name in the list.
# Enum('Color', ['RED', 'GREEN', 'BLUE']) => 3 members.
# Enum('Status', ['OK', 'ERROR']) => 2 members.
# Enum('Prio', ['LOW', 'MED', 'HIGH']) => 3 members.
# ---------------------------------------------------------------------------

invariant enum_extra20.Enum.color_len:
  description: "enum.Enum('Color', ['RED', 'GREEN', 'BLUE']).__len__() == 3 — three members"
  category: functional_api
  kind: python_call_eq
  function: Enum
  args: ["Color", ["RED", "GREEN", "BLUE"]]
  method: __len__
  method_args: []
  expected: 3

invariant enum_extra20.Enum.status_len:
  description: "enum.Enum('Status', ['OK', 'ERROR']).__len__() == 2 — two members"
  category: functional_api
  kind: python_call_eq
  function: Enum
  args: ["Status", ["OK", "ERROR"]]
  method: __len__
  method_args: []
  expected: 2

invariant enum_extra20.Enum.prio_len:
  description: "enum.Enum('Prio', ['LOW', 'MED', 'HIGH']).__len__() == 3 — three members"
  category: functional_api
  kind: python_call_eq
  function: Enum
  args: ["Prio", ["LOW", "MED", "HIGH"]]
  method: __len__
  method_args: []
  expected: 3

invariant enum_extra20.Enum.color_name:
  description: "enum.Enum('Color', ['RED', 'GREEN', 'BLUE']).__name__ == 'Color'"
  category: functional_api
  kind: python_call_eq
  function: Enum
  args: ["Color", ["RED", "GREEN", "BLUE"]]
  method: __name__
  expected: "Color"

# ---------------------------------------------------------------------------
# Functional IntEnum API — IntEnum(name, members) class creation
#
# IntEnum also supports the functional API. No prior spec checks __len__() on
# functionally created IntEnum classes. Three members yields length 3.
# ---------------------------------------------------------------------------

invariant enum_extra20.IntEnum.flags_len:
  description: "enum.IntEnum('Flags', ['A', 'B', 'C']).__len__() == 3 — three members"
  category: functional_api
  kind: python_call_eq
  function: IntEnum
  args: ["Flags", ["A", "B", "C"]]
  method: __len__
  method_args: []
  expected: 3

# ---------------------------------------------------------------------------
# __qualname__.__eq__ standalone for auto and unique
#
# enum_extra18 table covers Enum/Flag/IntFlag/auto/unique __qualname__.__len__.
# enum_extra15 covers Enum/__qualname__.__eq__ and auto/__qualname__.__eq__
# as part of a combined table. No prior spec has them as individual standalone
# boolean invariants outside a table.
# ---------------------------------------------------------------------------

invariant enum_extra20.auto.qualname_eq:
  description: "enum.auto.__qualname__ == 'auto' — top-level class qualname (standalone)"
  category: qualnames
  kind: python_call_eq
  function: auto.__qualname__.__eq__
  args: ["auto"]
  expected: true

invariant enum_extra20.unique.qualname_eq:
  description: "enum.unique.__qualname__ == 'unique' — top-level class qualname (standalone)"
  category: qualnames
  kind: python_call_eq
  function: unique.__qualname__.__eq__
  args: ["unique"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__.__eq__ standalone for Enum, IntEnum, Flag
#
# enum_extra15 covers these via table; no prior spec has each as a standalone
# boolean invariant for isolated machine-readable indexing.
# ---------------------------------------------------------------------------

invariant enum_extra20.Enum.qualname_eq:
  description: "enum.Enum.__qualname__ == 'Enum' — top-level class qualname (standalone)"
  category: qualnames
  kind: python_call_eq
  function: Enum.__qualname__.__eq__
  args: ["Enum"]
  expected: true

invariant enum_extra20.IntEnum.qualname_eq:
  description: "enum.IntEnum.__qualname__ == 'IntEnum' — top-level class qualname (standalone)"
  category: qualnames
  kind: python_call_eq
  function: IntEnum.__qualname__.__eq__
  args: ["IntEnum"]
  expected: true

invariant enum_extra20.Flag.qualname_eq:
  description: "enum.Flag.__qualname__ == 'Flag' — top-level class qualname (standalone)"
  category: qualnames
  kind: python_call_eq
  function: Flag.__qualname__.__eq__
  args: ["Flag"]
  expected: true

# ---------------------------------------------------------------------------
# EnumMeta.__qualname__.__len__() — 8 characters ('EnumType' on Python 3.11+)
#
# enum_extra18 covers EnumType.__qualname__.__len__() == 8 as a standalone.
# No prior spec checks EnumMeta.__qualname__.__len__() as a standalone invariant.
# On Python 3.11+ EnumMeta.__qualname__ == 'EnumType' (8 chars), not 'EnumMeta'.
# ---------------------------------------------------------------------------

invariant enum_extra20.EnumMeta.qualname_len:
  description: "enum.EnumMeta.__qualname__.__len__() == 8 — 'EnumType' is 8 characters (Python 3.11+)"
  category: qualnames
  kind: python_call_eq
  function: EnumMeta.__qualname__.__len__
  args: []
  expected: 8
