spec: uuid_extra2761
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra276.zspec.zsdl — covers UUID namespace constants, versions, and function __name__ identity."
    - "uuid_extra275.zspec.zsdl — covers uuid.UUID and uuid.SafeUUID class identity."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "uuid.UUID.__dict__.__contains__('__matmul__') == False — UUID does not define matrix multiplication; UUID objects represent identifiers, not numeric operands for @; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__truediv__') == False — UUID does not define true division; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.UUID.__dict__.__contains__('__iadd__') == False — UUID is immutable and does not define in-place addition; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__matmul__') == False — SafeUUID (an IntEnum subclass) does not define matrix multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__truediv__') == False — SafeUUID does not define true division; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "uuid.SafeUUID.__dict__.__contains__('__iadd__') == False — SafeUUID does not define in-place addition; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: uuid.UUID.__dict__ — __matmul__, __truediv__, __iadd__ absence
# UUID is a pure-Python class representing a universally unique identifier.
# It supports comparison operators (__eq__, __lt__, etc.) and __hash__, but
# not arithmetic or matrix operators.
# ---------------------------------------------------------------------------

table uuid_extra2761.uuid_dict_matmul_truediv_iadd:
  description: "uuid.UUID.__dict__ does not contain __matmul__, __truediv__, or __iadd__ — UUID defines no arithmetic or matrix operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2761

  columns: [id, function, args, expected]
  rows:
    - ["uu2761-uuid-matmul",  uuid.UUID.__dict__.__contains__,  ["__matmul__"],  false]
    - ["uu2761-uuid-truediv", uuid.UUID.__dict__.__contains__,  ["__truediv__"], false]
    - ["uu2761-uuid-iadd",    uuid.UUID.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Table 2: uuid.SafeUUID.__dict__ — __matmul__, __truediv__, __iadd__ absence
# SafeUUID is an IntEnum subclass with values -1 (unsafe) and 0 (safe).
# It does not add new arithmetic operators beyond those inherited from IntEnum.
# ---------------------------------------------------------------------------

table uuid_extra2761.safeuuid_dict_matmul_truediv_iadd:
  description: "uuid.SafeUUID.__dict__ does not contain __matmul__, __truediv__, or __iadd__ — SafeUUID (IntEnum subclass) defines no additional arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2761

  columns: [id, function, args, expected]
  rows:
    - ["uu2761-safe-matmul",  uuid.SafeUUID.__dict__.__contains__,  ["__matmul__"],  false]
    - ["uu2761-safe-truediv", uuid.SafeUUID.__dict__.__contains__,  ["__truediv__"], false]
    - ["uu2761-safe-iadd",    uuid.SafeUUID.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Table 3: uuid.UUID.__dict__ — __matmul__ and __truediv__ absence (detail)
# Explicit per-dunder rows with descriptions for documentation purposes.
# ---------------------------------------------------------------------------

table uuid_extra2761.uuid_dict_detail:
  description: "uuid.UUID.__dict__ operator absence detail — __matmul__ and __truediv__ are not defined because UUID is an identifier type, not a numeric type; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2761

  columns: [id, function, args, expected, description]
  rows:
    - ["uu2761-d-matmul",  uuid.UUID.__dict__.__contains__, ["__matmul__"],  false, "uuid.UUID does not support the @ (matmul) operator — UUIDs are identifiers, not matrices"]
    - ["uu2761-d-truediv", uuid.UUID.__dict__.__contains__, ["__truediv__"], false, "uuid.UUID does not support the / (truediv) operator — division is undefined for UUIDs"]
    - ["uu2761-d-iadd",    uuid.UUID.__dict__.__contains__, ["__iadd__"],    false, "uuid.UUID does not support the += (iadd) operator — UUID objects are immutable"]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — UUID and SafeUUID both lack all three dunders
# ---------------------------------------------------------------------------

table uuid_extra2761.all_types_all_dunders_absent:
  description: "uuid.UUID and uuid.SafeUUID both lack __matmul__, __truediv__, and __iadd__ in __dict__ — neither uuid type defines arithmetic or matrix operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: uu2761

  columns: [id, function, args, expected]
  rows:
    - ["uu2761-x-uuid-matmul",  uuid.UUID.__dict__.__contains__,     ["__matmul__"],  false]
    - ["uu2761-x-uuid-truediv", uuid.UUID.__dict__.__contains__,     ["__truediv__"], false]
    - ["uu2761-x-uuid-iadd",    uuid.UUID.__dict__.__contains__,     ["__iadd__"],    false]
    - ["uu2761-x-safe-matmul",  uuid.SafeUUID.__dict__.__contains__,  ["__matmul__"],  false]
    - ["uu2761-x-safe-truediv", uuid.SafeUUID.__dict__.__contains__,  ["__truediv__"], false]
    - ["uu2761-x-safe-iadd",    uuid.SafeUUID.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuid_extra2761.uuid_no_matmul:
  description: "uuid.UUID.__dict__.__contains__('__matmul__') == False — UUID does not define the @ operator; UUIDs are identifier objects, not numeric types subject to matrix multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant uuid_extra2761.uuid_no_truediv:
  description: "uuid.UUID.__dict__.__contains__('__truediv__') == False — UUID does not define the / operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__truediv__"]
  expected: false

invariant uuid_extra2761.uuid_no_iadd:
  description: "uuid.UUID.__dict__.__contains__('__iadd__') == False — UUID does not define += ; UUID objects are immutable (int field is set once in __init__); confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.UUID.__dict__.__contains__
  args: ["__iadd__"]
  expected: false

invariant uuid_extra2761.safeuuid_no_matmul:
  description: "uuid.SafeUUID.__dict__.__contains__('__matmul__') == False — SafeUUID is an IntEnum subclass and does not add __matmul__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant uuid_extra2761.safeuuid_no_truediv:
  description: "uuid.SafeUUID.__dict__.__contains__('__truediv__') == False — SafeUUID does not add __truediv__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__truediv__"]
  expected: false

invariant uuid_extra2761.safeuuid_no_iadd:
  description: "uuid.SafeUUID.__dict__.__contains__('__iadd__') == False — SafeUUID does not add __iadd__ to its own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: uuid.SafeUUID.__dict__.__contains__
  args: ["__iadd__"]
  expected: false
