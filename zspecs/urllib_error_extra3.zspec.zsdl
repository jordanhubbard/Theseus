spec: urllib_error_extra3
version: ">=3.0"
backend: python_module(urllib.error)

docs: https://docs.python.org/3/library/urllib.error.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/urllib.error.html — Python urllib.error module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/error.py"
  notes:
    - "This spec extends urllib_error.zspec.zsdl, urllib_error_extra.zspec.zsdl, and urllib_error_extra2.zspec.zsdl."
    - "urllib_error.zspec.zsdl covers: class_names table (URLError/HTTPError/ContentTooShortError __name__), modules table (all three __module__ == 'urllib.error'), URLError reason, URLError.__bases__[0].__name__ == 'OSError', HTTPError code 404/reason/url/code 500, HTTPError.__bases__[0].__name__ == 'URLError'."
    - "urllib_error_extra.zspec.zsdl covers: URLError.__name__, HTTPError.__name__, HTTPError.__bases__[0].__name__ == 'URLError' (duplicate axis)."
    - "urllib_error_extra2.zspec.zsdl covers: __qualname__ table (URLError/HTTPError/ContentTooShortError), ContentTooShortError.__bases__[0].__name__ == 'URLError', qualname_is_str for all three, HTTPError code 403 and msg 403."
    - "Focus: new axes not present in any prior urllib.error spec."
    - "HTTPError.__bases__.__len__() == 2 — HTTPError has two direct bases (URLError and addinfourl); the count has never been tested."
    - "HTTPError.__bases__[1].__name__ — the second base of HTTPError is addinfourl from urllib.response; not tested in any prior spec."
    - "URLError/HTTPError/ContentTooShortError type identity (__class__.__name__ == 'type') — not tested in any prior spec."
    - "HTTPError construction with code 301: code attribute and msg attribute for a redirect error — extra2 adds 403; 301 is new."
    - "HTTPError code 500 msg — base spec checks code 500 but not the corresponding msg ('Internal Server Error'); new axis."
    - "ContentTooShortError.__bases__.__len__() == 1 — single base class; not tested in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Exception classes; raised by urllib.request operations on network failures or HTTP errors."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Type identity — URLError, HTTPError, ContentTooShortError are proper types
# No prior spec checks __class__.__name__ == 'type' for these exception classes.
# ---------------------------------------------------------------------------

table urllib_error_extra3.class_type_identity:
  kind: python_call_eq
  category: type_identity
  id_prefix: typeid

  columns: [id, function, args, expected]
  rows:
    - [URLError,             URLError.__class__.__name__.__eq__,             ["type"], true]
    - [HTTPError,            HTTPError.__class__.__name__.__eq__,            ["type"], true]
    - [ContentTooShortError, ContentTooShortError.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# HTTPError.__bases__ — count and second base
# urllib_error.zspec.zsdl checks __bases__[0].__name__ == 'URLError'.
# The total number of bases (2) and the second base (addinfourl) are new.
# ---------------------------------------------------------------------------

invariant urllib_error_extra3.HTTPError.bases_len:
  description: "len(urllib.error.HTTPError.__bases__) == 2 — HTTPError has two direct bases"
  category: hierarchy
  kind: python_call_eq
  function: HTTPError.__bases__.__len__
  args: []
  expected: 2

invariant urllib_error_extra3.HTTPError.base1_name:
  description: "urllib.error.HTTPError.__bases__[1].__name__ == 'addinfourl' — second base is addinfourl"
  category: hierarchy
  kind: python_call_eq
  function: HTTPError.__bases__.__getitem__
  args: [1]
  method: __name__
  expected: "addinfourl"

# ---------------------------------------------------------------------------
# URLError.__bases__ — count check
# urllib_error.zspec.zsdl checks __bases__[0].__name__ == 'OSError'.
# The total number of bases (1) has not been verified.
# ---------------------------------------------------------------------------

invariant urllib_error_extra3.URLError.bases_len:
  description: "len(urllib.error.URLError.__bases__) == 1 — URLError has exactly one direct base"
  category: hierarchy
  kind: python_call_eq
  function: URLError.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# ContentTooShortError.__bases__ — count check
# urllib_error_extra2 checks __bases__[0].__name__ == 'URLError'.
# The total number of bases (1) has not been verified.
# ---------------------------------------------------------------------------

invariant urllib_error_extra3.ContentTooShortError.bases_len:
  description: "len(urllib.error.ContentTooShortError.__bases__) == 1 — ContentTooShortError has exactly one direct base"
  category: hierarchy
  kind: python_call_eq
  function: ContentTooShortError.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# HTTPError construction — additional code/msg vectors
# urllib_error.zspec.zsdl: code 404 msg/reason/url, code 500 code only.
# urllib_error_extra2.zspec.zsdl: code 403 code and msg.
# New: code 301 (redirect) code and msg; code 500 msg (never checked before).
# ---------------------------------------------------------------------------

invariant urllib_error_extra3.httperror_301_code:
  description: "HTTPError('http://example.com', 301, 'Moved Permanently', {}, None).code == 301"
  category: httperror
  kind: python_call_eq
  function: HTTPError
  args: ["http://example.com", 301, "Moved Permanently", {}, null]
  method: code
  expected: 301

invariant urllib_error_extra3.httperror_301_msg:
  description: "HTTPError('http://example.com', 301, 'Moved Permanently', {}, None).msg == 'Moved Permanently'"
  category: httperror
  kind: python_call_eq
  function: HTTPError
  args: ["http://example.com", 301, "Moved Permanently", {}, null]
  method: msg
  expected: "Moved Permanently"

invariant urllib_error_extra3.httperror_500_msg:
  description: "HTTPError('http://example.com', 500, 'Internal Server Error', {}, None).msg == 'Internal Server Error'"
  category: httperror
  kind: python_call_eq
  function: HTTPError
  args: ["http://example.com", 500, "Internal Server Error", {}, null]
  method: msg
  expected: "Internal Server Error"

# ---------------------------------------------------------------------------
# HTTPError.url attribute for additional construction vectors
# urllib_error.zspec.zsdl checks url for the 404 case.
# The url attribute for a 403 or 500 construction has not been verified.
# ---------------------------------------------------------------------------

invariant urllib_error_extra3.httperror_500_url:
  description: "HTTPError('http://example.com', 500, 'Internal Server Error', {}, None).url == 'http://example.com'"
  category: httperror
  kind: python_call_eq
  function: HTTPError
  args: ["http://example.com", 500, "Internal Server Error", {}, null]
  method: url
  expected: "http://example.com"
