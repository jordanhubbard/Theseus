spec: zlib_extra12
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib_extra11.zspec.zsdl — covers compress/decompress/compressobj/decompressobj/crc32/adler32 __qualname__ standalone (extra11); error.__qualname__ standalone (extra11); zlib.__package__ (extra11); zlib._ZlibDecompressor.__qualname__ (extra11)."
    - "zlib_extra10.zspec.zsdl — covers compress/decompress/compressobj/decompressobj/crc32/adler32 __qualname__ standalone (extra10); error.__qualname__ standalone (extra10); zlib.__name__ standalone (extra10)."
    - "zlib_extra7.zspec.zsdl — covers Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int' (extra7 anchor)."
    - "zlib_extra3.zspec.zsdl — covers DEF_BUF_SIZE.__class__.__name__ == 'int'; DEF_BUF_SIZE value == 16384; DEFLATED value == 8."
    - "zlib_extra2.zspec.zsdl — covers Compress/Decompress type __name__; Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int'; Z_BEST_COMPRESSION value == 9; Z_BEST_SPEED value == 1."
    - "zlib_extra.zspec.zsdl — covers DEFLATED.__class__.__name__ == 'int'; Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int'; function __name__ attrs; roundtrip."
  notes:
    - "This spec extends zlib through zlib_extra11; it does NOT duplicate invariants present in those files."
    - "Focus: method __qualname__ invariants for Compress.compress, Compress.flush, Compress.copy, Decompress.decompress, Decompress.flush, and Decompress.copy — not covered by any prior zlib spec."
    - "Also adds Z_BEST_COMPRESSION.__class__.__name__ == 'int' and Z_BEST_SPEED.__class__.__name__ == 'int' as novel type-identity invariants; prior specs cover only their values (== 9 and == 1) but not their __class__.__name__. Verified 2026-04-09."
    - "Compress and Decompress are the internal C-level types returned by zlib.compressobj() and zlib.decompressobj(). Their method __qualname__ values are of the form 'Compress.<method>' and 'Decompress.<method>'. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Compress.compress __qualname__ — standalone, extra12 anchor
#
# No prior zlib spec checks Compress.compress.__qualname__. The Compress type
# is the internal C-level object returned by zlib.compressobj().
# ---------------------------------------------------------------------------

invariant zlib_extra12.Compress.compress.qualname:
  description: "zlib.Compress.compress.__qualname__ == 'Compress.compress' — C-level compressor method qualname (extra12)"
  category: qualnames
  kind: python_call_eq
  function: Compress.compress.__qualname__.__eq__
  args: ["Compress.compress"]
  expected: true

# ---------------------------------------------------------------------------
# Compress.flush __qualname__ — standalone, extra12 anchor
#
# No prior zlib spec checks Compress.flush.__qualname__.
# ---------------------------------------------------------------------------

invariant zlib_extra12.Compress.flush.qualname:
  description: "zlib.Compress.flush.__qualname__ == 'Compress.flush' — C-level compressor method qualname (extra12)"
  category: qualnames
  kind: python_call_eq
  function: Compress.flush.__qualname__.__eq__
  args: ["Compress.flush"]
  expected: true

# ---------------------------------------------------------------------------
# Compress.copy __qualname__ — standalone, extra12 anchor
#
# No prior zlib spec checks Compress.copy.__qualname__.
# ---------------------------------------------------------------------------

invariant zlib_extra12.Compress.copy.qualname:
  description: "zlib.Compress.copy.__qualname__ == 'Compress.copy' — C-level compressor method qualname (extra12)"
  category: qualnames
  kind: python_call_eq
  function: Compress.copy.__qualname__.__eq__
  args: ["Compress.copy"]
  expected: true

# ---------------------------------------------------------------------------
# Decompress.decompress __qualname__ — standalone, extra12 anchor
#
# No prior zlib spec checks Decompress.decompress.__qualname__.
# ---------------------------------------------------------------------------

invariant zlib_extra12.Decompress.decompress.qualname:
  description: "zlib.Decompress.decompress.__qualname__ == 'Decompress.decompress' — C-level decompressor method qualname (extra12)"
  category: qualnames
  kind: python_call_eq
  function: Decompress.decompress.__qualname__.__eq__
  args: ["Decompress.decompress"]
  expected: true

# ---------------------------------------------------------------------------
# Decompress.flush __qualname__ — standalone, extra12 anchor
#
# No prior zlib spec checks Decompress.flush.__qualname__.
# ---------------------------------------------------------------------------

invariant zlib_extra12.Decompress.flush.qualname:
  description: "zlib.Decompress.flush.__qualname__ == 'Decompress.flush' — C-level decompressor method qualname (extra12)"
  category: qualnames
  kind: python_call_eq
  function: Decompress.flush.__qualname__.__eq__
  args: ["Decompress.flush"]
  expected: true

# ---------------------------------------------------------------------------
# Decompress.copy __qualname__ — standalone, extra12 anchor
#
# No prior zlib spec checks Decompress.copy.__qualname__.
# ---------------------------------------------------------------------------

invariant zlib_extra12.Decompress.copy.qualname:
  description: "zlib.Decompress.copy.__qualname__ == 'Decompress.copy' — C-level decompressor method qualname (extra12)"
  category: qualnames
  kind: python_call_eq
  function: Decompress.copy.__qualname__.__eq__
  args: ["Decompress.copy"]
  expected: true

# ---------------------------------------------------------------------------
# Z_BEST_COMPRESSION.__class__.__name__ == 'int' — extra12 anchor
#
# zlib_extra2 covers Z_BEST_COMPRESSION value == 9 but not its __class__.__name__.
# zlib_extra covers DEFLATED and Z_DEFAULT_COMPRESSION as int types; extra2/extra7
# add Z_DEFAULT_COMPRESSION re-anchors; extra3 adds DEF_BUF_SIZE int type.
# Z_BEST_COMPRESSION.__class__.__name__ == 'int' is not in any prior zlib spec.
# ---------------------------------------------------------------------------

invariant zlib_extra12.Z_BEST_COMPRESSION.class_is_int:
  description: "zlib.Z_BEST_COMPRESSION.__class__.__name__ == 'int' — constant is a plain Python int (extra12)"
  category: type_identity
  kind: python_call_eq
  function: Z_BEST_COMPRESSION.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Z_BEST_SPEED.__class__.__name__ == 'int' — extra12 anchor
#
# zlib_extra2 covers Z_BEST_SPEED value == 1 but not its __class__.__name__.
# No prior zlib spec checks Z_BEST_SPEED.__class__.__name__.
# ---------------------------------------------------------------------------

invariant zlib_extra12.Z_BEST_SPEED.class_is_int:
  description: "zlib.Z_BEST_SPEED.__class__.__name__ == 'int' — constant is a plain Python int (extra12)"
  category: type_identity
  kind: python_call_eq
  function: Z_BEST_SPEED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — Compress + Decompress methods (extra12)
#
# No prior zlib spec presents Compress/Decompress method __qualname__ values
# in any table. This table anchors all six method qualnames from extra12.
# ---------------------------------------------------------------------------

table zlib_extra12.compress_decompress_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn12

  columns: [id, function, args, expected]
  rows:
    - [Compress.compress,    Compress.compress.__qualname__.__eq__,    ["Compress.compress"],    true]
    - [Compress.flush,       Compress.flush.__qualname__.__eq__,       ["Compress.flush"],       true]
    - [Compress.copy,        Compress.copy.__qualname__.__eq__,        ["Compress.copy"],        true]
    - [Decompress.decompress, Decompress.decompress.__qualname__.__eq__, ["Decompress.decompress"], true]
    - [Decompress.flush,     Decompress.flush.__qualname__.__eq__,     ["Decompress.flush"],     true]
    - [Decompress.copy,      Decompress.copy.__qualname__.__eq__,      ["Decompress.copy"],      true]

# ---------------------------------------------------------------------------
# int type identity table — Z_BEST_COMPRESSION, Z_BEST_SPEED (extra12)
#
# No prior zlib spec presents these as int-type-identity checks in a table.
# ---------------------------------------------------------------------------

table zlib_extra12.constant_int_types:
  kind: python_call_eq
  category: type_identity
  id_prefix: ci12

  columns: [id, function, args, expected]
  rows:
    - [Z_BEST_COMPRESSION, Z_BEST_COMPRESSION.__class__.__name__.__eq__, ["int"], true]
    - [Z_BEST_SPEED,       Z_BEST_SPEED.__class__.__name__.__eq__,       ["int"], true]
