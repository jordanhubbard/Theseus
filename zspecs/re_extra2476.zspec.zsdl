spec: re_extra2476
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — checking whether re classes define membership test and item access protocol in their class __dict__."
    - "re.Match.__dict__ DOES contain '__getitem__' (True) — Match supports subscript access: match[0], match[1], match['group_name'] are valid."
    - "re.Match.__dict__ does NOT contain '__contains__' (False) — Match does not support 'x in match'."
    - "re.Pattern.__dict__ does NOT contain '__contains__' (False) — Pattern is not a container."
    - "re.Pattern.__dict__ does NOT contain '__getitem__' (False) — Pattern does not support subscript access."
    - "The presence of '__getitem__' in re.Match.__dict__ is a notable asymmetry: Match supports indexed group access but not membership testing."
    - "re.Match.__dict__ contains 'group', 'groups', 'span', 'start', 'end', 'expand', 'lastgroup', 'lastindex', 'regs', 'string', 'groupdict', '__doc__' (all True)."
    - "re.Match.__dict__ does NOT contain '__init__' (False) — __init__ is inherited, not overridden on Match."
    - "re.Pattern.__dict__ DOES contain 'match', 'search', 'findall', 'finditer', 'sub', 'subn', 'split', 'fullmatch', 'flags', 'pattern' (all True)."
    - "Accessing a missing key via re.Match.__dict__.__getitem__ raises KeyError."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match.__dict__.__contains__ — __getitem__ IS present, __contains__ is not
# Match supports subscript access (match[0], match['name']) via __getitem__,
# but does not implement the membership test protocol (__contains__).
# This is a notable asymmetry in the re.Match class design.
# ---------------------------------------------------------------------------

table re_extra2476.Match_dict_protocol_presence:
  description: "re.Match.__dict__: __getitem__ is present (True), __contains__ is absent (False)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: re2476

  columns: [id, function, args, expected]
  rows:
    - ["re2476001", re.Match.__dict__.__contains__, ["__getitem__"],  true]
    - ["re2476002", re.Match.__dict__.__contains__, ["__contains__"], false]

# ---------------------------------------------------------------------------
# re.Match.__dict__.__contains__ — core group-access methods present
# group, groups, groupdict, span, start, end, expand are all C-level methods
# defined directly on re.Match.
# ---------------------------------------------------------------------------

table re_extra2476.Match_dict_method_presence:
  description: "re.Match.__dict__ contains its core methods: group, groups, groupdict, span, start, end, expand"
  kind: python_call_eq
  category: dict_membership
  id_prefix: re2476

  columns: [id, function, args, expected]
  rows:
    - ["re2476003", re.Match.__dict__.__contains__, ["group"],     true]
    - ["re2476004", re.Match.__dict__.__contains__, ["groups"],    true]
    - ["re2476005", re.Match.__dict__.__contains__, ["groupdict"], true]
    - ["re2476006", re.Match.__dict__.__contains__, ["span"],      true]
    - ["re2476007", re.Match.__dict__.__contains__, ["start"],     true]
    - ["re2476008", re.Match.__dict__.__contains__, ["end"],       true]
    - ["re2476009", re.Match.__dict__.__contains__, ["expand"],    true]

# ---------------------------------------------------------------------------
# re.Match.__dict__.__contains__ — attributes and absent inherited dunder
# string, regs, lastindex, lastgroup are C-level descriptors on Match.
# __init__ is NOT in Match.__dict__ — it is inherited, not overridden.
# ---------------------------------------------------------------------------

table re_extra2476.Match_dict_attrs_and_absent_init:
  description: "re.Match.__dict__: string, regs, lastindex, lastgroup present; __init__ absent"
  kind: python_call_eq
  category: dict_membership
  id_prefix: re2476

  columns: [id, function, args, expected]
  rows:
    - ["re2476010", re.Match.__dict__.__contains__, ["string"],     true]
    - ["re2476011", re.Match.__dict__.__contains__, ["regs"],       true]
    - ["re2476012", re.Match.__dict__.__contains__, ["lastindex"],  true]
    - ["re2476013", re.Match.__dict__.__contains__, ["lastgroup"],  true]
    - ["re2476014", re.Match.__dict__.__contains__, ["__init__"],   false]

# ---------------------------------------------------------------------------
# re.Match.__dict__.__getitem__ — retrieval of __getitem__ itself and KeyError
# Verifies that re.Match.__dict__['__getitem__'] is accessible (since it IS
# defined on Match), and that absent keys raise KeyError.
# ---------------------------------------------------------------------------

table re_extra2476.Match_dict_getitem_access:
  description: "re.Match.__dict__.__getitem__ for present key succeeds; absent key raises KeyError"
  kind: python_call_raises
  category: dict_membership
  id_prefix: re2476

  columns: [id, function, args, expected]
  rows:
    - ["re2476015", re.Match.__dict__.__getitem__, ["__contains__"], KeyError]
    - ["re2476016", re.Match.__dict__.__getitem__, ["__init__"],     KeyError]

# ---------------------------------------------------------------------------
# re.Pattern.__dict__.__contains__ — no __contains__ or __getitem__
# Pattern defines regex methods but participates in neither the membership
# test nor the subscript access protocol.
# ---------------------------------------------------------------------------

table re_extra2476.Pattern_dict_protocol_absence:
  description: "re.Pattern.__dict__ does not contain __contains__ or __getitem__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: re2476

  columns: [id, function, args, expected]
  rows:
    - ["re2476017", re.Pattern.__dict__.__contains__, ["__contains__"], false]
    - ["re2476018", re.Pattern.__dict__.__contains__, ["__getitem__"],  false]
    - ["re2476019", re.Pattern.__dict__.__contains__, ["match"],        true]
    - ["re2476020", re.Pattern.__dict__.__contains__, ["search"],       true]
    - ["re2476021", re.Pattern.__dict__.__contains__, ["findall"],      true]
    - ["re2476022", re.Pattern.__dict__.__contains__, ["flags"],        true]
    - ["re2476023", re.Pattern.__dict__.__contains__, ["pattern"],      true]
