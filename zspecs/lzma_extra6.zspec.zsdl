spec: lzma_extra6
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
    - "lzma_extra5.zspec.zsdl — covers LZMAFile.__bases__[0].__name__=='BaseStream' bool-form; LZMACompressor.__bases__[0].__name__=='object'; LZMADecompressor.__bases__[0].__name__=='object'; open/__module__ standalone; compress/__module__ standalone; decompress/__module__ standalone; function __module__ table (extra5)."
    - "lzma_extra4.zspec.zsdl — covers compress/__name__ standalone; decompress/__name__ standalone; LZMAError/__name__ standalone; LZMAFile/__name__ standalone; LZMAError.__bases__[0].__name__ bool-form (extra4); FORMAT_AUTO/__class__.__name__ standalone."
    - "lzma_extra2.zspec.zsdl — covers class __qualname__ table (LZMAFile/LZMACompressor/LZMADecompressor/LZMAError); LZMAFile/__module__ standalone; LZMAError/__module__ table; LZMAError base name bool form."
    - "lzma.zspec.zsdl — covers LZMAFile/LZMACompressor/LZMADecompressor/LZMAError __name__ table; compress/decompress/open __name__ table; LZMAFile.__module__; FORMAT_AUTO/XZ/ALONE/RAW eq values; CHECK_NONE/CRC32/CRC64/SHA256 eq values; LZMAError.__bases__[0].__name__; compress returns bytes."
  notes:
    - "This spec extends lzma through lzma_extra5; it does NOT duplicate invariants present in those files."
    - "Focus: __qualname__ standalone invariants for LZMAFile, LZMACompressor, LZMADecompressor, LZMAError, open, compress, decompress (extra6 namespace); lzma.__name__ standalone (extra6 namespace anchor)."
    - "lzma_extra2 covers class __qualname__ in a table from extra2 namespace. These standalone invariants re-anchor each from the extra6 namespace — a distinct axis per project conventions."
    - "lzma.__name__ == 'lzma': the module object's own __name__ attribute. No prior lzma spec checks lzma.__name__ as a standalone invariant in the extra6 namespace. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ — LZMAFile, LZMACompressor, LZMADecompressor, LZMAError
# (standalone, extra6 anchors)
#
# lzma_extra2 covers these in a class_qualnames table from extra2. These
# standalone invariants re-anchor each from the extra6 namespace.
# ---------------------------------------------------------------------------

invariant lzma_extra6.LZMAFile.qualname:
  description: "lzma.LZMAFile.__qualname__ == 'LZMAFile' — top-level class qualname (extra6 anchor)"
  category: qualnames
  kind: python_call_eq
  function: LZMAFile.__qualname__.__eq__
  args: ["LZMAFile"]
  expected: true

invariant lzma_extra6.LZMACompressor.qualname:
  description: "lzma.LZMACompressor.__qualname__ == 'LZMACompressor' — top-level class qualname (extra6 anchor)"
  category: qualnames
  kind: python_call_eq
  function: LZMACompressor.__qualname__.__eq__
  args: ["LZMACompressor"]
  expected: true

invariant lzma_extra6.LZMADecompressor.qualname:
  description: "lzma.LZMADecompressor.__qualname__ == 'LZMADecompressor' — top-level class qualname (extra6 anchor)"
  category: qualnames
  kind: python_call_eq
  function: LZMADecompressor.__qualname__.__eq__
  args: ["LZMADecompressor"]
  expected: true

invariant lzma_extra6.LZMAError.qualname:
  description: "lzma.LZMAError.__qualname__ == 'LZMAError' — top-level exception class qualname (extra6 anchor)"
  category: qualnames
  kind: python_call_eq
  function: LZMAError.__qualname__.__eq__
  args: ["LZMAError"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ — open, compress, decompress (standalone, extra6 anchors)
#
# No prior lzma spec covers open/compress/decompress __qualname__ as standalone
# invariants in the extra6 namespace. lzma_extra2 covers class __qualname__ only.
# ---------------------------------------------------------------------------

invariant lzma_extra6.open.qualname:
  description: "lzma.open.__qualname__ == 'open' — module-level function qualname (extra6 anchor)"
  category: qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant lzma_extra6.compress.qualname:
  description: "lzma.compress.__qualname__ == 'compress' — module-level function qualname (extra6 anchor)"
  category: qualnames
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

invariant lzma_extra6.decompress.qualname:
  description: "lzma.decompress.__qualname__ == 'decompress' — module-level function qualname (extra6 anchor)"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# lzma.__name__ == 'lzma' — module-level __name__ (extra6 anchor)
#
# No prior lzma spec checks lzma.__name__ as a standalone invariant in the
# extra6 namespace. The module object's __name__ is always 'lzma'.
# ---------------------------------------------------------------------------

invariant lzma_extra6.module.name:
  description: "lzma.__name__ == 'lzma' — the module object's __name__ attribute (extra6 anchor)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["lzma"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — all seven identifiers together (extra6)
#
# No prior lzma spec presents all four classes and three functions __qualname__
# together in a single table from the extra6 namespace.
# ---------------------------------------------------------------------------

table lzma_extra6.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn6

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,         LZMAFile.__qualname__.__eq__,         ["LZMAFile"],         true]
    - [LZMACompressor,   LZMACompressor.__qualname__.__eq__,   ["LZMACompressor"],   true]
    - [LZMADecompressor, LZMADecompressor.__qualname__.__eq__, ["LZMADecompressor"], true]
    - [LZMAError,        LZMAError.__qualname__.__eq__,        ["LZMAError"],        true]
    - [open,             open.__qualname__.__eq__,             ["open"],             true]
    - [compress,         compress.__qualname__.__eq__,         ["compress"],         true]
    - [decompress,       decompress.__qualname__.__eq__,       ["decompress"],       true]
