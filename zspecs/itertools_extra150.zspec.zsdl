spec: itertools_extra150
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.__dict__.__contains__ membership checks — chain True, product True, cycle True, repeat True, count True, tee True, zip_longest True, combinations True, permutations True, compress True, islice True, groupby True (Wave 279)."
    - "itertools.__dict__.__contains__('chain') == True — chain is a C extension type in the itertools module dict. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('product') == True — product is a C extension type in the itertools module dict. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('cycle') == True — cycle is a C extension type in the itertools module dict. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('repeat') == True — repeat is a C extension type in the itertools module dict. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('count') == True — count is a C extension type in the itertools module dict. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('tee') == True — tee is a builtin_function_or_method in the itertools module dict; __qualname__ == 'tee' (len 3), __module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('zip_longest') == True — zip_longest is a C extension type; __name__ == 'zip_longest', __module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('combinations') == True; itertools.__dict__.__contains__('permutations') == True; itertools.__dict__.__contains__('compress') == True; itertools.__dict__.__contains__('islice') == True; itertools.__dict__.__contains__('groupby') == True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.__dict__.__contains__ — core iterator types
#
# Wave 279 theme: itertools module dict membership checks for core types.
#
# itertools.__dict__.__contains__('chain') == True
# itertools.__dict__.__contains__('product') == True
# itertools.__dict__.__contains__('cycle') == True
# itertools.__dict__.__contains__('repeat') == True
# itertools.__dict__.__contains__('count') == True
#
# These are all C extension types defined in Modules/itertoolsmodule.c
# and registered in the itertools module dict. New to extra150.
# ---------------------------------------------------------------------------

table itertools_extra150.module_dict_contains_core_types:
  description: "itertools.__dict__.__contains__: chain True, product True, cycle True, repeat True, count True; core C extension types in module dict; wave 279; new to extra150"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsmdccore150

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_chain,
       "__dict__.__contains__",
       ["chain"],
       true,
       "itertools.__dict__.__contains__('chain') == True — chain is a C extension type (itertoolsmodule.c) registered in the itertools module dict; dict.__contains__('chain') returns True; new to extra150"]
    - [dict_contains_product,
       "__dict__.__contains__",
       ["product"],
       true,
       "itertools.__dict__.__contains__('product') == True — product is a C extension type registered in the itertools module dict; dict.__contains__('product') returns True; new to extra150"]
    - [dict_contains_cycle,
       "__dict__.__contains__",
       ["cycle"],
       true,
       "itertools.__dict__.__contains__('cycle') == True — cycle is a C extension type registered in the itertools module dict; dict.__contains__('cycle') returns True; new to extra150"]
    - [dict_contains_repeat,
       "__dict__.__contains__",
       ["repeat"],
       true,
       "itertools.__dict__.__contains__('repeat') == True — repeat is a C extension type registered in the itertools module dict; dict.__contains__('repeat') returns True; new to extra150"]
    - [dict_contains_count,
       "__dict__.__contains__",
       ["count"],
       true,
       "itertools.__dict__.__contains__('count') == True — count is a C extension type registered in the itertools module dict; dict.__contains__('count') returns True; new to extra150"]

# ---------------------------------------------------------------------------
# Table 2: itertools.__dict__.__contains__ — tee, zip_longest, combinations
#
# Wave 279 theme: itertools module dict membership checks for additional types.
#
# itertools.__dict__.__contains__('tee') == True
# itertools.__dict__.__contains__('zip_longest') == True
# itertools.__dict__.__contains__('combinations') == True
# itertools.__dict__.__contains__('permutations') == True
# itertools.__dict__.__contains__('compress') == True
#
# tee is a builtin_function_or_method; the others are C extension types.
# New to extra150.
# ---------------------------------------------------------------------------

table itertools_extra150.module_dict_contains_extra_types:
  description: "itertools.__dict__.__contains__: tee True, zip_longest True, combinations True, permutations True, compress True; wave 279; new to extra150"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsmdcextra150

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_tee,
       "__dict__.__contains__",
       ["tee"],
       true,
       "itertools.__dict__.__contains__('tee') == True — tee is a builtin_function_or_method registered in the itertools module dict; tee.__qualname__ is 'tee'; dict.__contains__('tee') returns True; new to extra150"]
    - [dict_contains_zip_longest,
       "__dict__.__contains__",
       ["zip_longest"],
       true,
       "itertools.__dict__.__contains__('zip_longest') == True — zip_longest is a C extension type registered in the itertools module dict; dict.__contains__('zip_longest') returns True; new to extra150"]
    - [dict_contains_combinations,
       "__dict__.__contains__",
       ["combinations"],
       true,
       "itertools.__dict__.__contains__('combinations') == True — combinations is a C extension type registered in the itertools module dict; dict.__contains__('combinations') returns True; new to extra150"]
    - [dict_contains_permutations,
       "__dict__.__contains__",
       ["permutations"],
       true,
       "itertools.__dict__.__contains__('permutations') == True — permutations is a C extension type registered in the itertools module dict; dict.__contains__('permutations') returns True; new to extra150"]
    - [dict_contains_compress,
       "__dict__.__contains__",
       ["compress"],
       true,
       "itertools.__dict__.__contains__('compress') == True — compress is a C extension type registered in the itertools module dict; dict.__contains__('compress') returns True; new to extra150"]

# ---------------------------------------------------------------------------
# Table 3: itertools.__dict__.__contains__ — islice, groupby, accumulate
#
# Wave 279 theme: itertools module dict membership checks for filtering types.
#
# itertools.__dict__.__contains__('islice') == True
# itertools.__dict__.__contains__('groupby') == True
# itertools.__dict__.__contains__('accumulate') == True
#
# tee identity: __class__.__name__ == 'builtin_function_or_method',
#               __qualname__ == 'tee', __module__ == 'itertools'
#
# New to extra150.
# ---------------------------------------------------------------------------

table itertools_extra150.module_dict_contains_filter_types:
  description: "itertools.__dict__.__contains__: islice True, groupby True, accumulate True; tee class 'builtin_function_or_method', qualname 'tee', module 'itertools'; wave 279; new to extra150"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsmdcfilt150

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_islice,
       "__dict__.__contains__",
       ["islice"],
       true,
       "itertools.__dict__.__contains__('islice') == True — islice is a C extension type registered in the itertools module dict; dict.__contains__('islice') returns True; new to extra150"]
    - [dict_contains_groupby,
       "__dict__.__contains__",
       ["groupby"],
       true,
       "itertools.__dict__.__contains__('groupby') == True — groupby is a C extension type registered in the itertools module dict; dict.__contains__('groupby') returns True; new to extra150"]
    - [dict_contains_accumulate,
       "__dict__.__contains__",
       ["accumulate"],
       true,
       "itertools.__dict__.__contains__('accumulate') == True — accumulate is a C extension type registered in the itertools module dict; dict.__contains__('accumulate') returns True; new to extra150"]
    - [tee_class_eq_builtin_function_or_method,
       "tee.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.tee.__class__.__name__.__eq__('builtin_function_or_method') == True — unlike most itertools objects which are C extension types, tee is exposed as a builtin_function_or_method; __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra150"]
    - [tee_qualname_eq,
       "tee.__qualname__.__eq__",
       ["tee"],
       true,
       "itertools.tee.__qualname__.__eq__('tee') == True — tee is defined at module scope; __qualname__ is 'tee'; str.__eq__('tee') returns True; new to extra150"]
    - [tee_module_eq_itertools,
       "tee.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.tee.__module__.__eq__('itertools') == True — tee is a builtin_function_or_method in the itertools C module; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra150"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra150
# ---------------------------------------------------------------------------

invariant itertools_extra150.dict_contains_chain:
  description: "itertools.__dict__.__contains__('chain') == True — chain is in module dict; wave 279; new to extra150"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["chain"]
  expected: true

