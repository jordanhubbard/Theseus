spec: poplib_extra4
version: ">=3.9"
backend: python_module(poplib)

docs: https://docs.python.org/3/library/poplib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/poplib.html — Python poplib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/poplib.py"
  notes:
    - "This spec extends poplib.zspec.zsdl, poplib_extra.zspec.zsdl, poplib_extra2.zspec.zsdl, and poplib_extra3.zspec.zsdl."
    - "poplib.zspec.zsdl covers: POP3/POP3_SSL/error_proto __name__, POP3.__module__, POP3.port==110, POP3_SSL.port==995, error_proto hierarchy, method names."
    - "poplib_extra.zspec.zsdl covers: class names table, type checks (metaclass 'type'), module affiliations, error_proto hierarchy, qualnames table, POP3_SSL hierarchy."
    - "poplib_extra2.zspec.zsdl covers: POP3/POP3_SSL port type checks, port value table, error_proto base name, POP3_SSL base name."
    - "poplib_extra3.zspec.zsdl covers: POP3.__bases__[0].__name__=='object', POP3 method qualnames, error_proto.__name__ standalone, POP3/POP3_SSL metaclass standalone invariants."
    - "This spec adds: poplib module __name__ attribute; POP3.__name__ length; POP3_SSL.__name__ length; error_proto.__name__ length; POP3_SSL.__module__ standalone invariant."
    - "poplib.__name__ == 'poplib' — the module's own __name__ dunder when imported."
    - "POP3.__name__ has 4 characters; POP3_SSL.__name__ has 8 characters; error_proto.__name__ has 11 characters."
    - "poplib_extra covers POP3_SSL.__module__ in its module table; this spec adds a standalone invariant form."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# poplib module __name__
# The module's own __name__ dunder equals 'poplib' when imported normally.
# No prior poplib spec has checked the module-level __name__ attribute.
# ---------------------------------------------------------------------------

invariant poplib_extra4.module.__name__:
  description: "poplib.__name__ == 'poplib' — module __name__ dunder"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["poplib"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ length checks — POP3, POP3_SSL, error_proto
# No prior poplib spec has verified the character length of any class __name__.
# ---------------------------------------------------------------------------

invariant poplib_extra4.POP3.name_len:
  description: "poplib.POP3.__name__.__len__() == 4 — 'POP3' has 4 characters"
  category: class_identity
  kind: python_call_eq
  function: POP3.__name__.__len__
  args: []
  expected: 4

invariant poplib_extra4.POP3_SSL.name_len:
  description: "poplib.POP3_SSL.__name__.__len__() == 8 — 'POP3_SSL' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: POP3_SSL.__name__.__len__
  args: []
  expected: 8

invariant poplib_extra4.error_proto.name_len:
  description: "poplib.error_proto.__name__.__len__() == 11 — 'error_proto' has 11 characters"
  category: class_identity
  kind: python_call_eq
  function: error_proto.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# POP3_SSL.__module__ standalone invariant
# poplib_extra covers POP3_SSL.__module__ in its module table.
# No prior spec provides this as a standalone invariant.
# ---------------------------------------------------------------------------

invariant poplib_extra4.POP3_SSL.module_standalone:
  description: "poplib.POP3_SSL.__module__ == 'poplib' — POP3_SSL is defined in the poplib module"
  category: class_modules
  kind: python_call_eq
  function: POP3_SSL.__module__.__eq__
  args: ["poplib"]
  expected: true
