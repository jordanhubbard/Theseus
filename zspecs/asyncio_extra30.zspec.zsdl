spec: asyncio_extra30
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/exceptions.html — Python built-in exceptions"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/exceptions.py"
  notes:
    - "This spec extends asyncio_extra29.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__() (C extension)."
    - "This spec covers: Queue method __qualname__.__len__() for put/get/put_nowait/get_nowait/join/task_done; Lock method __qualname__.__len__() for acquire/release; InvalidStateError.__bases__[0].__name__; TimeoutError.__bases__[0].__name__; CancelledError.__bases__[0].__name__; exception __mro__.__len__() for InvalidStateError/TimeoutError/CancelledError."
    - "Queue.put.__qualname__ == 'Queue.put' — length 9."
    - "Queue.get.__qualname__ == 'Queue.get' — length 9."
    - "Queue.put_nowait.__qualname__ == 'Queue.put_nowait' — length 16."
    - "Queue.get_nowait.__qualname__ == 'Queue.get_nowait' — length 16."
    - "Queue.join.__qualname__ == 'Queue.join' — length 10."
    - "Queue.task_done.__qualname__ == 'Queue.task_done' — length 15."
    - "Lock.acquire.__qualname__ == 'Lock.acquire' — length 12."
    - "Lock.release.__qualname__ == 'Lock.release' — length 12."
    - "asyncio.InvalidStateError.__bases__[0].__name__ == 'Exception' — direct subclass of Exception."
    - "asyncio.TimeoutError.__bases__[0].__name__ == 'OSError' — TimeoutError is a subclass of OSError (built-in)."
    - "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException' — CancelledError is a direct subclass of BaseException."
    - "InvalidStateError.__mro__.__len__() == 4 — [InvalidStateError, Exception, BaseException, object]."
    - "TimeoutError.__mro__.__len__() == 5 — [TimeoutError, OSError, Exception, BaseException, object]."
    - "CancelledError.__mro__.__len__() == 3 — [CancelledError, BaseException, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Queue method __qualname__ length table — extra30 namespace
#
# asyncio.Queue methods carry 'Queue.' as their __qualname__ prefix.
# The total lengths depend on the method name:
#   put        — 'Queue.put'        (9)
#   get        — 'Queue.get'        (9)
#   put_nowait — 'Queue.put_nowait' (16)
#   get_nowait — 'Queue.get_nowait' (16)
#   join       — 'Queue.join'       (10)
#   task_done  — 'Queue.task_done'  (15)
# No prior spec has measured __qualname__.__len__() for Queue instance methods.
# ---------------------------------------------------------------------------

table asyncio_extra30.queue_method_qualname_lengths:
  description: "asyncio.Queue method __qualname__ lengths for put/get/put_nowait/get_nowait/join/task_done in extra30 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: queuemqualnamelen30

  columns: [id, function, args, expected]
  rows:
    - [put,        Queue.put.__qualname__.__len__,        [], 9]
    - [get,        Queue.get.__qualname__.__len__,        [], 9]
    - [put_nowait, Queue.put_nowait.__qualname__.__len__, [], 16]
    - [get_nowait, Queue.get_nowait.__qualname__.__len__, [], 16]
    - [join,       Queue.join.__qualname__.__len__,       [], 10]
    - [task_done,  Queue.task_done.__qualname__.__len__,  [], 15]

# ---------------------------------------------------------------------------
# Lock method __qualname__ length table — extra30 namespace
#
# asyncio.Lock methods carry 'Lock.' as their __qualname__ prefix.
#   acquire — 'Lock.acquire' (12)
#   release — 'Lock.release' (12)
# Both acquire and release are 7 characters, giving the same total length 12.
# No prior spec has measured __qualname__.__len__() for Lock instance methods.
# ---------------------------------------------------------------------------

table asyncio_extra30.lock_method_qualname_lengths:
  description: "asyncio.Lock method __qualname__ lengths for acquire/release in extra30 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: lockmqualnamelen30

  columns: [id, function, args, expected]
  rows:
    - [acquire, Lock.acquire.__qualname__.__len__, [], 12]
    - [release, Lock.release.__qualname__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Exception __bases__[0].__name__ table — extra30 namespace
#
# asyncio exception hierarchy via __bases__[0].__name__:
#   InvalidStateError.__bases__[0].__name__ == 'Exception'    — direct subclass of Exception
#   TimeoutError.__bases__[0].__name__      == 'OSError'      — inherits from built-in OSError
#   CancelledError.__bases__[0].__name__    == 'BaseException' — direct subclass of BaseException
# These three exceptions have different base types, distinguishing their
# positions in the exception hierarchy. No prior spec measures
# __bases__[0].__name__ for these asyncio exceptions.
# ---------------------------------------------------------------------------

table asyncio_extra30.exception_bases_names:
  description: "asyncio exception __bases__[0].__name__ for InvalidStateError/TimeoutError/CancelledError in extra30 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: excbasename30

  columns: [id, function, args, expected]
  rows:
    - [InvalidStateError, "InvalidStateError.__bases__[0].__name__.__eq__", ["Exception"],     true]
    - [TimeoutError,      "TimeoutError.__bases__[0].__name__.__eq__",      ["OSError"],       true]
    - [CancelledError,    "CancelledError.__bases__[0].__name__.__eq__",    ["BaseException"], true]

# ---------------------------------------------------------------------------
# Exception __mro__.__len__() table — extra30 namespace
#
# MRO lengths confirm the hierarchy depth for each exception class:
#   InvalidStateError — MRO length 4: [InvalidStateError, Exception, BaseException, object]
#   TimeoutError      — MRO length 5: [TimeoutError, OSError, Exception, BaseException, object]
#   CancelledError    — MRO length 3: [CancelledError, BaseException, object]
# TimeoutError's longer MRO reflects the extra OSError intermediate node.
# CancelledError's shorter MRO reflects its direct BaseException parentage.
# ---------------------------------------------------------------------------

table asyncio_extra30.exception_mro_lengths:
  description: "asyncio exception __mro__.__len__() for InvalidStateError/TimeoutError/CancelledError in extra30 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: excmrolen30

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [InvalidStateError, InvalidStateError.__mro__, [], !ascii "", __len__, [], "asyncio.InvalidStateError MRO depth == 4"]
    - [TimeoutError,      TimeoutError.__mro__,      [], !ascii "", __len__, [], "asyncio.TimeoutError MRO depth == 5"]
    - [CancelledError,    CancelledError.__mro__,    [], !ascii "", __len__, [], "asyncio.CancelledError MRO depth == 3"]

# ---------------------------------------------------------------------------
# Queue.put_nowait qualname string equality — extra30 standalone invariant
#
# Confirms the full __qualname__ string 'Queue.put_nowait' for the
# put_nowait method, complementing the length check in the table above.
# ---------------------------------------------------------------------------

invariant asyncio_extra30.Queue.put_nowait_qualname_eq:
  description: "asyncio.Queue.put_nowait.__qualname__ == 'Queue.put_nowait' — method defined on Queue"
  category: method_names
  kind: python_call_eq
  function: Queue.put_nowait.__qualname__.__eq__
  args: ["Queue.put_nowait"]
  expected: true

# ---------------------------------------------------------------------------
# InvalidStateError.__bases__[0].__name__ string equality — extra30 standalone
#
# Confirms that asyncio.InvalidStateError directly subclasses Exception,
# not OSError or BaseException. This is the direct-parent name check
# complementing the table row above.
# ---------------------------------------------------------------------------

invariant asyncio_extra30.InvalidStateError.base_name_eq:
  description: "asyncio.InvalidStateError.__bases__[0].__name__ == 'Exception' — InvalidStateError is a direct subclass of Exception"
  category: class_hierarchy
  kind: python_call_eq
  function: InvalidStateError.__bases__[0].__name__.__eq__
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# CancelledError MRO length — extra30 standalone invariant
#
# asyncio.CancelledError has an unusually short MRO (length 3) because it
# inherits directly from BaseException, skipping Exception entirely.
# This invariant calls __len__ on the __mro__ tuple via method chaining.
# ---------------------------------------------------------------------------

invariant asyncio_extra30.CancelledError.mro_len:
  description: "asyncio.CancelledError.__mro__.__len__() == 3 — short MRO reflects direct BaseException parentage"
  category: class_hierarchy
  kind: python_call_eq
  function: CancelledError.__mro__.__len__
  args: []
  expected: 3
