spec: multiprocessing_extra1696
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/pickle.html — Python pickle protocol documentation"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 560 (_extra1696): pickling protocol dict-presence checks."
    - "multiprocessing uses pickling internally to pass arguments to worker processes, but the Process and Pool classes themselves do not define __reduce__, __getstate__, or related dunders in their own __dict__."
    - "multiprocessing.Process.__dict__ does not contain __reduce__, __getstate__, __setstate__, __getnewargs__, or __getnewargs_ex__."
    - "multiprocessing.Pool.__dict__ likewise contains none of the pickle protocol dunders."
    - "multiprocessing.process.BaseProcess.__dict__ also defines none of the pickle or copy protocol dunders in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Pickling protocol methods absent from multiprocessing.Process __dict__
#
# Although multiprocessing relies on pickle to transfer objects to worker
# processes, the Process class itself does not implement pickling hooks.
# Process objects cannot be sent through a Queue or Pipe as pickle payloads.
# ---------------------------------------------------------------------------

table multiprocessing_extra1696.process_pickling_protocol:
  description: "multiprocessing.Process class pickling protocol dict-presence checks — Process defines none of __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__ in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1696

  columns: [id, function, args, expected]
  rows:
    - ["mp1696001", "Process.__dict__.__contains__", ["__reduce__"],        false]
    - ["mp1696002", "Process.__dict__.__contains__", ["__getstate__"],      false]
    - ["mp1696003", "Process.__dict__.__contains__", ["__setstate__"],      false]
    - ["mp1696004", "Process.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["mp1696005", "Process.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["mp1696006", "Process.__dict__.__contains__", ["__copy__"],          false]
    - ["mp1696007", "Process.__dict__.__contains__", ["__deepcopy__"],      false]

# ---------------------------------------------------------------------------
# Table 2: Pickling protocol methods absent from multiprocessing.Pool __dict__
#
# Pool manages a pool of worker processes.  Its internal state (threads,
# worker processes, queues) cannot be serialized.  Pool defines none of the
# pickle protocol dunders in its own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra1696.pool_pickling_protocol:
  description: "multiprocessing.Pool class pickling protocol dict-presence checks — Pool defines none of __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__ in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1696

  columns: [id, function, args, expected]
  rows:
    - ["mp1696008",  "Pool.__dict__.__contains__", ["__reduce__"],        false]
    - ["mp1696009",  "Pool.__dict__.__contains__", ["__getstate__"],      false]
    - ["mp1696010",  "Pool.__dict__.__contains__", ["__setstate__"],      false]
    - ["mp1696011",  "Pool.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["mp1696012",  "Pool.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["mp1696013",  "Pool.__dict__.__contains__", ["__copy__"],          false]
    - ["mp1696014",  "Pool.__dict__.__contains__", ["__deepcopy__"],      false]

# ---------------------------------------------------------------------------
# Table 3: Pickling protocol methods absent from BaseProcess __dict__
#
# multiprocessing.process.BaseProcess is the abstract base for all process
# types.  It defines lifecycle methods (start, join, terminate, kill,
# is_alive) but none of the pickle or copy protocol dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra1696.baseprocess_pickling_protocol:
  description: "multiprocessing.process.BaseProcess pickling protocol dict-presence checks — BaseProcess defines none of the pickle or copy protocol dunders in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1696

  columns: [id, function, args, expected]
  rows:
    - ["mp1696015", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__reduce__"],        false]
    - ["mp1696016", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__getstate__"],      false]
    - ["mp1696017", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__setstate__"],      false]
    - ["mp1696018", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["mp1696019", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["mp1696020", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__copy__"],          false]
    - ["mp1696021", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__deepcopy__"],      false]
