spec: tldts
version: ">=1.0.0"
backend: node(tldts)

docs: https://www.npmjs.com/package/tldts

provenance:
  derived_from:
    - "tldts README — https://www.npmjs.com/package/tldts"
    - "Test vectors verified with tldts via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "tldts source"
  notes:
    - "tldts is an npm package. Install: npm install tldts"
    - "tldts.parse(hostname) parses a hostname and returns domain, subdomain, publicSuffix, and related fields."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns parsed hostname object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table tldts.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: tldts

  columns: [id, args, expected]
  rows:
    - [com, ["www.example.com"],
       {"domain": "example.com", "domainWithoutSuffix": "example",
        "hostname": "www.example.com", "isIcann": true, "isIp": false,
        "isPrivate": false, "publicSuffix": "com", "subdomain": "www"}]
    - [co_uk, ["shop.example.co.uk"],
       {"domain": "example.co.uk", "domainWithoutSuffix": "example",
        "hostname": "shop.example.co.uk", "isIcann": true, "isIp": false,
        "isPrivate": false, "publicSuffix": "co.uk", "subdomain": "shop"}]

