    - ["hl2281005", "hashlib.blake2s.__bases__.__len__", [], 1]
    - ["hl2281006", "hashlib.blake2s.__dict__.__len__", [], 14]

table hashlib_extra2281.hashlib_hash_hierarchy:
  description: "_hashlib.HASH MRO depth, base count, and dict size (underlying C HASH type)"
  kind: python_call_eq
  category: mro_depth
  id_prefix: hl2281

  columns: [id, function, args, expected]
  rows:
    - ["hl2281007", "_hashlib.HASH.__mro__.__len__", [], 2]
    - ["hl2281008", "_hashlib.HASH.__bases__.__len__", [], 1]
    - ["hl2281009", "_hashlib.HASH.__dict__.__len__", [], 10]

table hashlib_extra2281.abstractmethods_raises:
  description: "C extension types do not expose __abstractmethods__ — AttributeError expected"
  kind: python_call_raises
  category: attribute_error
  id_prefix: hl2281

  columns: [id, function, args, expected]
  rows:
    - ["hl2281010", "hashlib.blake2b.__abstractmethods__.__len__", [], "AttributeError"]
    - ["hl2281011", "hashlib.blake2s.__abstractmethods__.__len__", [], "AttributeError"]
    - ["hl2281012", "_hashlib.HASH.__abstractmethods__.__len__", [], "AttributeError"]

