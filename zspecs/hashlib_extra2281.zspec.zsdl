spec: hashlib_extra2281
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count, dict size."
    - "Covers hashlib.blake2b, hashlib.blake2s (C extension types from _blake2), and _hashlib.HASH."
    - "Both blake2b and blake2s inherit directly from object (MRO length 2, bases length 1)."
    - "C extension types do not carry __abstractmethods__; accessing it raises AttributeError."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table hashlib_extra2281.blake2b_hierarchy:
  description: "hashlib.blake2b MRO depth, base count, and dict size"
  kind: python_call_eq
  category: mro_depth
  id_prefix: hl2281

  columns: [id, function, args, expected]
  rows:
    - ["hl2281001", "hashlib.blake2b.__mro__.__len__", [], 2]
    - ["hl2281002", "hashlib.blake2b.__bases__.__len__", [], 1]
    - ["hl2281003", "hashlib.blake2b.__dict__.__len__", [], 14]

table hashlib_extra2281.blake2s_hierarchy:
  description: "hashlib.blake2s MRO depth, base count, and dict size"
