spec: theseus_concurrent_futures_cr
version: ">=3.2"
backend: python_cleanroom(theseus_concurrent_futures_cr)
blocks: concurrent.futures

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "Clean-room concurrent.futures module. Do NOT import concurrent.futures."

error_model: python_exceptions

invariant theseus_concurrent_futures_cr.futures2_executor:
  description: "ThreadPoolExecutor can submit work and get a Future"
  category: behavior
  kind: python_call_eq
  function: futures2_executor
  args: []
  expected: true

invariant theseus_concurrent_futures_cr.futures2_future:
  description: "Future class has result() and done() methods"
  category: behavior
  kind: python_call_eq
  function: futures2_future
  args: []
  expected: true

invariant theseus_concurrent_futures_cr.futures2_as_completed:
  description: "as_completed() yields futures as they complete"
  category: behavior
  kind: python_call_eq
  function: futures2_as_completed
  args: []
  expected: true
