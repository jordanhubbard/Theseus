spec: hashlib_extra31
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra30.zspec.zsdl — covers sha224.__name__=='openssl_sha224'; sha384.__name__=='openssl_sha384'; md5/sha1/sha256/sha512 __name__ re-anchor; algorithms_guaranteed len/membership/class re-anchors."
    - "hashlib_extra29.zspec.zsdl — covers sha3_256/sha3_512/blake2b/blake2s __name__; new.__module__; algorithms_guaranteed sha224/sha384/sha3_224/sha3_384 membership."
    - "hashlib_extra28.zspec.zsdl — covers sha3_256/sha3_512/blake2b/blake2s __qualname__.__eq__ and __qualname__.__len__."
    - "hashlib_extra27.zspec.zsdl — covers HASH instance method qualnames (update/digest/hexdigest/copy) via md5() and sha256()."
    - "hashlib_extra26.zspec.zsdl — covers sha224/sha384 __qualname__.__eq__; new.__qualname__.__eq__; algorithms_guaranteed/available __class__.__name__.__eq__."
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512 __name__; algorithms_available/__class__/__name__.__eq__; algorithms_guaranteed contains sha256/sha1/md5."
  notes:
    - "This spec extends hashlib through hashlib_extra30; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: md5/sha1/sha256/sha512/sha224/sha384/blake2b/blake2s __name__ (extra20, extra29, extra30); algorithms_available/algorithms_guaranteed type and membership (extra20, extra25, extra26, extra29, extra30); hashlib.__name__/__package__ (hashlib.zspec); new().__class__.__name__ (various); sha224.__name__=='openssl_sha224' (extra30); sha384.__name__=='openssl_sha384' (extra30); algorithms_guaranteed.__class__.__name__=='set' (extra26, extra30)."
    - "This spec covers: hashlib.md5.__name__.__len__() (NOVEL — no prior spec checks __name__.__len__() for md5); hashlib.sha1.__name__.__len__() (NOVEL); hashlib.sha256.__name__.__len__() (NOVEL); hashlib.sha512.__name__.__len__() (NOVEL); hashlib.sha224.__name__.__len__() (NOVEL); hashlib.sha384.__name__.__len__() (NOVEL); hashlib.md5.__module__ (NOVEL — no prior spec checks md5.__module__ directly); hashlib.sha1.__module__ (NOVEL); hashlib.sha256.__module__ (NOVEL); hashlib.sha512.__module__ (NOVEL); hashlib.md5.__module__.__len__() (NOVEL); hashlib.sha256.__module__.__len__() (NOVEL)."
    - "hashlib.md5.__name__.__len__() == 11: 'openssl_md5' has 11 characters. No prior spec checks __name__.__len__() for md5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__name__.__len__() == 12: 'openssl_sha1' has 12 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__name__.__len__() == 14: 'openssl_sha256' has 14 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__name__.__len__() == 14: 'openssl_sha512' has 14 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__name__.__len__() == 14: 'openssl_sha224' has 14 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__name__.__len__() == 14: 'openssl_sha384' has 14 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__ == '_hashlib': All OpenSSL-backed constructors are implemented in the _hashlib C extension. No prior spec checks md5.__module__ directly. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__module__ == '_hashlib': Same C extension module. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__ == '_hashlib': Same C extension module. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__module__ == '_hashlib': Same C extension module. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__.__len__() == 8: '_hashlib' has 8 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__.__len__() == 8: '_hashlib' has 8 characters. NOVEL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for md5, sha1, sha256, sha512, sha224, sha384 — novel
#
# Prior specs (extra20, extra29, extra30) cover __name__.__eq__ for all six.
# No prior spec checks __name__.__len__() for any of these six constructors.
# On CPython 3.12 all use the OpenSSL backend, so names are 'openssl_XXX'.
# Lengths: md5=11, sha1=12, sha256=14, sha512=14, sha224=14, sha384=14.
# ---------------------------------------------------------------------------

table hashlib_extra31.constructor_name_lengths:
  description: "md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__() — novel invariants, no prior spec covers these lengths"
  kind: python_call_eq
  category: function_names
  id_prefix: hlnl31

  columns: [id, function, args, expected]
  rows:
    - [md5,    md5.__name__.__len__,    [], 11]
    - [sha1,   sha1.__name__.__len__,   [], 12]
    - [sha256, sha256.__name__.__len__, [], 14]
    - [sha512, sha512.__name__.__len__, [], 14]
    - [sha224, sha224.__name__.__len__, [], 14]
    - [sha384, sha384.__name__.__len__, [], 14]

# ---------------------------------------------------------------------------
# __module__ for md5, sha1, sha256, sha512 — novel invariants
#
# No prior spec checks __module__ for md5, sha1, sha256, or sha512 directly.
# All four OpenSSL-backed constructors are defined in the _hashlib C extension.
# Their __module__ attribute is '_hashlib', not 'hashlib'.
# ---------------------------------------------------------------------------

table hashlib_extra31.constructor_modules:
  description: "md5/sha1/sha256/sha512 __module__ == '_hashlib' — OpenSSL-backed constructors defined in C extension, novel invariants"
  kind: python_call_eq
  category: module_metadata
  id_prefix: hlmod31

  columns: [id, function, args, expected]
  rows:
    - [md5,    md5.__module__.__eq__,    ["_hashlib"], true]
    - [sha1,   sha1.__module__.__eq__,   ["_hashlib"], true]
    - [sha256, sha256.__module__.__eq__, ["_hashlib"], true]
    - [sha512, sha512.__module__.__eq__, ["_hashlib"], true]

# ---------------------------------------------------------------------------
# md5.__module__.__len__() and sha256.__module__.__len__() — novel
#
# No prior spec checks __module__.__len__() for any hashlib constructor.
# '_hashlib' has 8 characters. These two anchor the length from the extra31
# namespace; sha1 and sha512 share the same value and are covered by the
# constructor_modules table above.
# ---------------------------------------------------------------------------

invariant hashlib_extra31.md5.module_len:
  description: "hashlib.md5.__module__.__len__() == 8 — '_hashlib' has 8 characters, novel invariant"
  category: module_metadata
  kind: python_call_eq
  function: md5.__module__.__len__
  args: []
  expected: 8

invariant hashlib_extra31.sha256.module_len:
  description: "hashlib.sha256.__module__.__len__() == 8 — '_hashlib' has 8 characters, novel invariant"
  category: module_metadata
  kind: python_call_eq
  function: sha256.__module__.__len__
  args: []
  expected: 8
