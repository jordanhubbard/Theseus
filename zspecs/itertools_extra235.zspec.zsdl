spec: itertools_extra235
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.chain.from_iterable and itertools.islice output contracts."
    - "itertools.chain.__name__ == 'chain' (len=5) — the C extension type name. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools' (len=9) — chain is defined in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable' (len=13) — the classmethod name. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' — from_iterable is a C-level classmethod. Verified with Python 3.14.3."
    - "itertools.islice.__name__ == 'islice' (len=6) — the C extension type name. Verified with Python 3.14.3."
    - "itertools.islice.__module__ == 'itertools' (len=9) — islice is defined in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.islice.__class__.__name__ == 'type' — islice is a C extension type. Verified with Python 3.14.3."
    - "itertools.islice.__bases__[0].__name__ == 'object' — islice inherits directly from object. Verified with Python 3.14.3."
    - "itertools.chain.__class__.__name__ == 'type' — chain is a C extension type. Verified with Python 3.14.3."
    - "itertools.chain.__bases__[0].__name__ == 'object' — chain inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain class identity contracts
#
# itertools.chain.__name__ == 'chain' (len=5)
# itertools.chain.__module__ == 'itertools' (len=9)
# itertools.chain.__qualname__ == 'chain'
# itertools.chain.__class__.__name__ == 'type'
# itertools.chain.__bases__[0].__name__ == 'object'
#
# chain is a C extension type in itertoolsmodule.c. New to extra235.
# ---------------------------------------------------------------------------

table itertools_extra235.chain_class_identity:
  description: "itertools.chain class identity contracts: name, module, qualname, metaclass, base; new to extra235"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra235chainclassid

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_eq,
       chain.__name__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — chain is a C extension type in itertoolsmodule.c that chains multiple iterables together; __name__ is 'chain' (len=5); new to extra235"]
    - [chain_name_len_5,
       chain.__name__.__len__,
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — 'chain' has exactly 5 characters (c-h-a-i-n); str.__len__() returns 5; new to extra235"]
    - [chain_module_eq,
       chain.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is defined in the itertools C extension module; __module__ is 'itertools' (len=9); new to extra235"]
    - [chain_qualname_eq,
       chain.__qualname__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — chain is a top-level C extension type with unqualified qualname 'chain'; new to extra235"]
    - [chain_class_is_type,
       chain.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — chain is a C extension type; its metaclass is the built-in type; new to extra235"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain base, MRO, and from_iterable classmethod contracts
#
# itertools.chain.__bases__[0].__name__ == 'object'
# itertools.chain.__mro__[0].__name__ == 'chain'
# itertools.chain.__mro__[1].__name__ == 'object'
# itertools.chain.from_iterable.__name__ == 'from_iterable' (len=13)
# itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'
#
# chain has a two-element MRO and a from_iterable classmethod. New to extra235.
# ---------------------------------------------------------------------------

table itertools_extra235.chain_mro_and_from_iterable:
  description: "itertools.chain base is object; MRO slots; from_iterable name and class contracts; new to extra235"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra235chainmroid

  columns: [id, function, args, expected, description]
  rows:
    - [chain_base_is_object,
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__.__eq__('object') == True — chain inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; new to extra235"]
    - [chain_mro0_eq,
       "chain.__mro__[0].__name__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__mro__[0].__name__.__eq__('chain') == True — chain MRO slot 0 is the class itself; __mro__[0].__name__ is 'chain'; new to extra235"]
    - [chain_mro1_eq,
       "chain.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__mro__[1].__name__.__eq__('object') == True — chain MRO slot 1 is object; chain has a two-element MRO; new to extra235"]
    - [from_iterable_name_eq,
       chain.from_iterable.__name__.__eq__,
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — from_iterable is a classmethod on chain that chains nested iterables; __name__ is 'from_iterable' (len=13); new to extra235"]
    - [from_iterable_class_is_builtin,
       chain.from_iterable.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — from_iterable is a C-level classmethod descriptor; __class__.__name__ is 'builtin_function_or_method'; new to extra235"]

# ---------------------------------------------------------------------------
# Table 3: itertools.islice class identity contracts
#
# itertools.islice.__name__ == 'islice' (len=6)
# itertools.islice.__module__ == 'itertools' (len=9)
# itertools.islice.__qualname__ == 'islice'
# itertools.islice.__class__.__name__ == 'type'
# itertools.islice.__bases__[0].__name__ == 'object'
#
# islice is a C extension type in itertoolsmodule.c. New to extra235.
# ---------------------------------------------------------------------------

table itertools_extra235.islice_class_identity:
  description: "itertools.islice class identity contracts: name, module, qualname, metaclass, base; new to extra235"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra235isliceclassid

  columns: [id, function, args, expected, description]
  rows:
    - [islice_name_eq,
       islice.__name__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — islice is a C extension type in itertoolsmodule.c that slices an iterator; __name__ is 'islice' (len=6); new to extra235"]
    - [islice_name_len_6,
       islice.__name__.__len__,
       [],
       6,
       "itertools.islice.__name__.__len__() == 6 — 'islice' has exactly 6 characters (i-s-l-i-c-e); str.__len__() returns 6; new to extra235"]
    - [islice_module_eq,
       islice.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — islice is defined in the itertools C extension module; __module__ is 'itertools' (len=9); new to extra235"]
    - [islice_class_is_type,
       islice.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.islice.__class__.__name__.__eq__('type') == True — islice is a C extension type; its metaclass is the built-in type; new to extra235"]
    - [islice_base_is_object,
       "islice.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.islice.__bases__[0].__name__.__eq__('object') == True — islice inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; new to extra235"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra235
# ---------------------------------------------------------------------------

invariant itertools_extra235.chain_name_eq:
  description: "itertools.chain.__name__ == 'chain' (len=5); new to extra235"
  kind: python_call_eq
  function: chain.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra235.chain_name_len_5:
  description: "itertools.chain.__name__.__len__() == 5 — 'chain' has 5 characters; new to extra235"
  kind: python_call_eq
  function: chain.__name__.__len__
  args: []
  expected: 5

invariant itertools_extra235.chain_module_eq:
  description: "itertools.chain.__module__ == 'itertools'; new to extra235"
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra235.chain_qualname_eq:
  description: "itertools.chain.__qualname__ == 'chain'; new to extra235"
  kind: python_call_eq
  function: chain.__qualname__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra235.chain_class_is_type:
  description: "itertools.chain.__class__.__name__ == 'type'; new to extra235"
  kind: python_call_eq
  function: chain.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra235.chain_base_is_object:
  description: "itertools.chain.__bases__[0].__name__ == 'object'; new to extra235"
  kind: python_call_eq
  function: "chain.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra235.chain_mro0_eq:
  description: "itertools.chain.__mro__[0].__name__ == 'chain'; new to extra235"
  kind: python_call_eq
  function: "chain.__mro__[0].__name__.__eq__"
  args: ["chain"]
  expected: true

invariant itertools_extra235.chain_mro1_eq:
  description: "itertools.chain.__mro__[1].__name__ == 'object'; new to extra235"
  kind: python_call_eq
  function: "chain.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra235.from_iterable_name_eq:
  description: "itertools.chain.from_iterable.__name__ == 'from_iterable' (len=13); new to extra235"
  kind: python_call_eq
  function: chain.from_iterable.__name__.__eq__
  args: ["from_iterable"]
  expected: true

invariant itertools_extra235.from_iterable_name_len_13:
  description: "itertools.chain.from_iterable.__name__.__len__() == 13 — 'from_iterable' has 13 characters; new to extra235"
  kind: python_call_eq
  function: chain.from_iterable.__name__.__len__
  args: []
  expected: 13

invariant itertools_extra235.from_iterable_class_is_builtin:
  description: "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'; new to extra235"
  kind: python_call_eq
  function: chain.from_iterable.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra235.islice_name_eq:
  description: "itertools.islice.__name__ == 'islice' (len=6); new to extra235"
  kind: python_call_eq
  function: islice.__name__.__eq__
  args: ["islice"]
  expected: true

invariant itertools_extra235.islice_name_len_6:
  description: "itertools.islice.__name__.__len__() == 6 — 'islice' has 6 characters; new to extra235"
  kind: python_call_eq
  function: islice.__name__.__len__
  args: []
  expected: 6

invariant itertools_extra235.islice_module_eq:
  description: "itertools.islice.__module__ == 'itertools'; new to extra235"
  kind: python_call_eq
  function: islice.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra235.islice_class_is_type:
  description: "itertools.islice.__class__.__name__ == 'type'; new to extra235"
  kind: python_call_eq
  function: islice.__class__.__name__.__eq__
  args: ["type"]
  expected: true
