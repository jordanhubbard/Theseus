spec: re_extra1261
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "Wave 531 spec: focuses on re.__all__.__contains__ membership checks."
    - "re has __all__ (a list of 31 names); type confirmed as list via __all__.__class__.__name__=='list'."
    - "re.__all__.__len__() == 31 (the largest __all__ of the four wave-531 modules)."
    - "re.__all__ includes: match, fullmatch, search, sub, subn, split, findall, finditer, compile, purge, escape (functions); error, Pattern, Match, RegexFlag, PatternError (types/exceptions); A, I, L, M, S, X, U, NOFLAG (single-char flag aliases); ASCII, IGNORECASE, LOCALE, MULTILINE, DOTALL, VERBOSE, UNICODE (full-name flags)."
    - "Table re1261aa covers __all__.__class__.__name__ type check and IN-membership for core regex functions."
    - "Table re1261bb covers __all__.__contains__ for flag constants (single-char and full-name aliases)."
    - "Table re1261cc covers __all__.__contains__ for types/exceptions and NOT-in checks for internal modules."
    - "re.__all__.__contains__('match') == True (position 0)."
    - "re.__all__.__contains__('fullmatch') == True (position 1)."
    - "re.__all__.__contains__('search') == True (position 2)."
    - "re.__all__.__contains__('compile') == True (position 8)."
    - "re.__all__.__contains__('Pattern') == True (position 12)."
    - "re.__all__.__contains__('Match') == True (position 13)."
    - "re.__all__.__contains__('PatternError') == True (position 30); added in Python 3.13 alongside 'error'."
    - "re.__all__.__contains__('NOFLAG') == True (position 28); added in Python 3.11."
    - "re.__all__.__contains__('RegexFlag') == True (position 29); the enum class backing all flag constants."
    - "re.__all__.__contains__('sre_compile') == False (internal submodule; not re-exported)."
    - "re.__all__.__contains__('copyreg') == False (internal dependency; not exported)."
    - "re.__all__.__contains__('functools') == False (used for caching; not exported)."
    - "re.__all__.__contains__('RegexError') == False ('PatternError' is the canonical name; 'RegexError' does not exist in re)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.__all__ type check and IN-membership for core regex functions
# Functions: match(0), fullmatch(1), search(2), sub(3), subn(4), split(5),
# findall(6), finditer(7), compile(8), purge(9), escape(10).
# re.__all__.__class__.__name__ == 'list'.
# re.__all__.__len__() == 31: the largest of the wave-531 modules.
# ---------------------------------------------------------------------------

table re_extra1261.all_type_and_functions_in:
  description: "re.__all__ type is 'list' with 31 entries; core regex functions match/fullmatch/search/sub/subn/compile/purge/escape confirmed IN __all__; wave-531 novel contains checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: re1261aa

  columns: [id, function, args, expected, description]
  rows:
    - [re1261aa001, "__all__.__class__.__name__.__eq__", ["list"],      true,  "re.__all__.__class__.__name__ == 'list' (re.__all__ is a plain Python list with 31 entries; the largest __all__ of the four wave-531 modules)"]
    - [re1261aa002, "__all__.__contains__",              ["match"],     true,  "re.__all__.__contains__('match') == True (position 0; re.match() checks for a match at the beginning of the string; the first entry in re.__all__)"]
    - [re1261aa003, "__all__.__contains__",              ["fullmatch"], true,  "re.__all__.__contains__('fullmatch') == True (position 1; re.fullmatch() requires the entire string to match the pattern; added in Python 3.4)"]
    - [re1261aa004, "__all__.__contains__",              ["search"],    true,  "re.__all__.__contains__('search') == True (position 2; re.search() scans through the string looking for a match anywhere in it)"]
    - [re1261aa005, "__all__.__contains__",              ["compile"],   true,  "re.__all__.__contains__('compile') == True (position 8; re.compile() compiles a regex pattern into a Pattern object for repeated use)"]
    - [re1261aa006, "__all__.__contains__",              ["purge"],     true,  "re.__all__.__contains__('purge') == True (position 9; re.purge() clears the compiled regex cache; useful in tests that check cache behavior)"]
    - [re1261aa007, "__all__.__contains__",              ["escape"],    true,  "re.__all__.__contains__('escape') == True (position 10; re.escape() escapes all non-alphanumeric characters in a string for literal matching)"]
    - [re1261aa008, "__all__.__contains__",              ["split"],     true,  "re.__all__.__contains__('split') == True (position 5; re.split() splits a string at each match of the pattern; can return substrings and captured groups)"]

# ---------------------------------------------------------------------------
# re.__all__ membership for flag constants
# Single-char aliases: A(14), I(15), L(16), M(17), S(18), X(19), U(20), NOFLAG(28).
# Full-name aliases: ASCII(21), IGNORECASE(22), LOCALE(23), MULTILINE(24),
#   DOTALL(25), VERBOSE(26), UNICODE(27).
# NOFLAG was added in Python 3.11; RegexFlag is the underlying enum.
# ---------------------------------------------------------------------------

table re_extra1261.all_flag_constants_in:
  description: "re.__all__ contains single-char flag aliases A/I/L/M/S/X/U (positions 14-20) and full-name aliases ASCII/IGNORECASE/LOCALE/MULTILINE/DOTALL/VERBOSE/UNICODE (21-27) and NOFLAG(28); all wave-531 novel contains checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: re1261bb

  columns: [id, function, args, expected, description]
  rows:
    - [re1261bb001, "__all__.__contains__", ["A"],          true,  "re.__all__.__contains__('A') == True (position 14; single-char alias for re.ASCII; makes \\w \\d \\s match ASCII-only)"]
    - [re1261bb002, "__all__.__contains__", ["I"],          true,  "re.__all__.__contains__('I') == True (position 15; single-char alias for re.IGNORECASE; makes pattern case-insensitive)"]
    - [re1261bb003, "__all__.__contains__", ["IGNORECASE"], true,  "re.__all__.__contains__('IGNORECASE') == True (position 22; full-name flag for case-insensitive matching; length 10; same value as re.I)"]
    - [re1261bb004, "__all__.__contains__", ["MULTILINE"],  true,  "re.__all__.__contains__('MULTILINE') == True (position 24; makes ^ and $ match at line boundaries within the string; length 9)"]
    - [re1261bb005, "__all__.__contains__", ["DOTALL"],     true,  "re.__all__.__contains__('DOTALL') == True (position 25; makes . match any character including newline; length 6; same value as re.S)"]
    - [re1261bb006, "__all__.__contains__", ["VERBOSE"],    true,  "re.__all__.__contains__('VERBOSE') == True (position 26; enables verbose mode allowing whitespace and comments in patterns; length 7)"]
    - [re1261bb007, "__all__.__contains__", ["NOFLAG"],     true,  "re.__all__.__contains__('NOFLAG') == True (position 28; zero-value flag constant added in Python 3.11; represents the absence of any flag; length 6)"]
    - [re1261bb008, "__all__.__contains__", ["UNICODE"],    true,  "re.__all__.__contains__('UNICODE') == True (position 27; makes \\w \\d \\s match Unicode characters; this is the default in Python 3; length 7)"]

# ---------------------------------------------------------------------------
# re.__all__ membership for types/exceptions and NOT-in checks
# Types: Pattern(12), Match(13), RegexFlag(29), PatternError(30).
# error(11): the exception alias for PatternError (both are in __all__).
# NOT in __all__: sre_compile, copyreg, functools, os, RegexError, FULLMATCH (uppercase).
# ---------------------------------------------------------------------------

table re_extra1261.all_types_exceptions_and_not_in:
  description: "re.__all__ contains Pattern(12), Match(13), error(11), RegexFlag(29), PatternError(30); NOT in __all__: sre_compile, copyreg, functools, RegexError, pattern (lowercase); wave-531 novel checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: re1261cc

  columns: [id, function, args, expected, description]
  rows:
    - [re1261cc001, "__all__.__contains__", ["Pattern"],      true,  "re.__all__.__contains__('Pattern') == True (position 12; the compiled regular expression type returned by re.compile(); a C extension type from _sre)"]
    - [re1261cc002, "__all__.__contains__", ["Match"],        true,  "re.__all__.__contains__('Match') == True (position 13; the match object type returned by re.match()/search()/fullmatch(); a C extension type from _sre)"]
    - [re1261cc003, "__all__.__contains__", ["error"],        true,  "re.__all__.__contains__('error') == True (position 11; the exception raised for invalid regex patterns; aliased as PatternError since Python 3.13)"]
    - [re1261cc004, "__all__.__contains__", ["RegexFlag"],    true,  "re.__all__.__contains__('RegexFlag') == True (position 29; the IntFlag enum class from which all re flag constants (A, I, L, M, S, X, U, NOFLAG) are derived)"]
    - [re1261cc005, "__all__.__contains__", ["PatternError"], true,  "re.__all__.__contains__('PatternError') == True (position 30; the canonical name for re.error since Python 3.13; both 'error' and 'PatternError' are in __all__)"]
    - [re1261cc006, "__all__.__contains__", ["sre_compile"],  false, "re.__all__.__contains__('sre_compile') == False ('sre_compile' is a private internal submodule that re delegates to; it is not part of the public re API)"]
    - [re1261cc007, "__all__.__contains__", ["copyreg"],      false, "re.__all__.__contains__('copyreg') == False ('copyreg' is imported by re for pickling support of Pattern objects; not a public re export)"]
    - [re1261cc008, "__all__.__contains__", ["functools"],    false, "re.__all__.__contains__('functools') == False ('functools' is imported by re for the lru_cache that backs the compiled regex cache; not exported)"]
