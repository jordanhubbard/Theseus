spec: functools_extra2521
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: __bool__, __index__, and __int__ dict-presence checks for functools classes."
    - "Theme: truthiness, integer coercion, and indexing protocol dict-presence — checking whether classes define __bool__, __index__, or __int__ in their class __dict__."
    - "functools.partial, functools.partialmethod, functools.cached_property, functools.singledispatchmethod, functools.singledispatch, functools.lru_cache, functools.itemgetter — none define __bool__, __index__, or __int__."
    - "functools.partial is a C extension type that wraps a callable with pre-applied positional args and keyword args; it carries no truthiness override (truth-testing falls through to the default object protocol), no integer coercion, and no index protocol. Verified with Python 3.14."
    - "functools.partialmethod is a pure-Python descriptor for use in class bodies; it wraps a callable to produce partially-applied methods but itself defines no __bool__, __index__, or __int__. Verified with Python 3.14."
    - "functools.cached_property is a pure-Python non-data descriptor that caches a computed value in the instance __dict__; it is a caching mechanism with no numeric or truthiness semantics of its own. Verified with Python 3.14."
    - "functools.singledispatchmethod is a pure-Python descriptor that dispatches method calls based on the first non-self argument type; it defines no truthiness, integer coercion, or index protocol. Verified with Python 3.14."
    - "functools.singledispatch (the function decorator variant) wraps a callable for type-based dispatch; its underlying class defines no __bool__, __index__, or __int__. Verified with Python 3.14."
    - "functools.lru_cache is a callable wrapper that memoizes results in a bounded cache; it has no numeric or truthiness protocol. Verified with Python 3.14."
    - "functools.itemgetter is a C extension type that retrieves items from target objects via __getitem__; it is a retrieval utility with no integer coercion or indexing protocol. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — truthiness/int/index protocol absence
#
# Theme: __bool__, __index__, __int__ absent from functools.partial.__dict__.
# partial is a C extension type wrapping a callable; it has no numeric role
# and defers all truthiness testing to the default object protocol.
# ---------------------------------------------------------------------------

table functools_extra2521.partial_bool_index_int:
  description: "__bool__, __index__, __int__ absent from functools.partial.__dict__; wave 2521"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: ft2521

  columns: [id, function, args, expected]
  rows:
    - ["ft2521-001", "partial.__dict__.__contains__", ["__bool__"], false]
    - ["ft2521-002", "partial.__dict__.__contains__", ["__index__"], false]
    - ["ft2521-003", "partial.__dict__.__contains__", ["__int__"], false]

