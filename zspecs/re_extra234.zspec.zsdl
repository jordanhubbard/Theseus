spec: re_extra234
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Match object method __name__ contracts."
    - "re.Match.group.__name__ == 'group' — Match.group method name; verified Python 3.14.3 macOS."
    - "re.Match.groups.__name__ == 'groups' — Match.groups method name; verified Python 3.14.3 macOS."
    - "re.Match.start.__name__ == 'start' — Match.start method name; verified Python 3.14.3 macOS."
    - "re.Match.end.__name__ == 'end' — Match.end method name; length 3; verified Python 3.14.3 macOS."
    - "re.Match.span.__name__ == 'span' — Match.span method name; length 4; verified Python 3.14.3 macOS."
    - "re.Match.groupdict.__name__ == 'groupdict' — Match.groupdict method name; length 9; verified Python 3.14.3 macOS."
    - "re.Match.expand.__name__ == 'expand' — Match.expand method name; length 6; verified Python 3.14.3 macOS."
    - "re.Match.__name__ == 'Match' — the Match class name; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match method __name__ contracts
# All standard Match methods carry their canonical name as __name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra234.Match_method_names:
  description: "re.Match method __name__ contracts — group, groups, start, end, span, groupdict, expand; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_name
  id_prefix: rematchmnames234

  columns: [id, function, args, expected]
  rows:
    - [match_group_name,     Match.group.__name__.__eq__,     ["group"],     true]
    - [match_groups_name,    Match.groups.__name__.__eq__,    ["groups"],    true]
    - [match_start_name,     Match.start.__name__.__eq__,     ["start"],     true]
    - [match_end_name,       Match.end.__name__.__eq__,       ["end"],       true]
    - [match_span_name,      Match.span.__name__.__eq__,      ["span"],      true]
    - [match_groupdict_name, Match.groupdict.__name__.__eq__, ["groupdict"], true]
    - [match_expand_name,    Match.expand.__name__.__eq__,    ["expand"],    true]

# ---------------------------------------------------------------------------
# re.Match class __name__ contract
# The Match class itself carries the canonical name 'Match'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra234.Match.class_name:
  description: "re.Match.__name__ == 'Match' — the Match class name is 'Match'; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

# ---------------------------------------------------------------------------
# re.Match method name length contracts
# Spot-check selected method name lengths.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra234.Match.end.name_length:
  description: "re.Match.end.__name__.__len__() == 3 — 'end' has 3 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Match.end.__name__.__len__
  args: []
  expected: 3

invariant re_extra234.Match.span.name_length:
  description: "re.Match.span.__name__.__len__() == 4 — 'span' has 4 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Match.span.__name__.__len__
  args: []
  expected: 4

invariant re_extra234.Match.groupdict.name_length:
  description: "re.Match.groupdict.__name__.__len__() == 9 — 'groupdict' has 9 characters; verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Match.groupdict.__name__.__len__
  args: []
  expected: 9

invariant re_extra234.Match.group.qualname:
  description: "re.Match.group.__qualname__ == 'Match.group' — verified Python 3.14.3 macOS"
  category: method_name
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true
