spec: lodash_values
version: ">=4.0.0"
backend: node(lodash.values)

docs: https://lodash.com/docs/#values

provenance:
  derived_from:
    - "lodash.values README — https://www.npmjs.com/package/lodash.values"
    - "Test vectors verified with lodash.values@4.3.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.values exports the _.values function directly as module.exports."
    - "values(object) returns an array of the object's own enumerable property values."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of own enumerable values."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_values.values:
  kind: node_module_call_eq
  function: ~
  category: values
  id_prefix: lvals

  columns: [id, args, expected]
  rows:
    - [basic,  [{"a": 1, "b": 2, "c": 3}],  [1, 2, 3]]
    - [one,    [{"x": 42}],                   [42]]
    - [empty,  [{}],                           []]
