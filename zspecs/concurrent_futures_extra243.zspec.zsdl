spec: concurrent_futures_extra243
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.Future — Future class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py (internal implementation)"
  notes:
    - "This spec covers concurrent.futures.Future behavioral state checks on a new Future."
    - "Future().running() == False immediately after creation (not yet submitted to executor)."
    - "Future().cancelled() == False immediately after creation (never cancelled)."
    - "Future().done() == False immediately after creation (no result or exception set)."
    - "All three state methods return bool — __class__.__name__ == 'bool' (len=4)."
    - "Future.running.__module__ == 'concurrent.futures._base' (len=24)."
    - "Future.running.__qualname__ == 'Future.running' (len=14)."
    - "Future.cancelled.__qualname__ == 'Future.cancelled' (len=16)."
    - "Future.done.__qualname__ == 'Future.done' (len=11)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future().running(), cancelled(), done() return type checks
#
# A new Future has state PENDING — none of running/cancelled/done is True.
# All three return bool with value False.
# ---------------------------------------------------------------------------

table concurrent_futures_extra243.future_state_types:
  description: "concurrent.futures.Future state method return types on a new Future — Future().running().__class__.__name__.__eq__('bool')==True; Future().cancelled().__class__.__name__.__eq__('bool')==True; Future().done().__class__.__name__.__eq__('bool')==True; all three state methods return bool (len=4); a new Future is in PENDING state so none of running/cancelled/done returns True; Future().running().__eq__(False)==True; Future().cancelled().__eq__(False)==True; Future().done().__eq__(False)==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: future_state_types
  id_prefix: cf243futbeh

  columns: [id, function, args, expected, description]
  rows:
    - [run_cls,  Future().running().__class__.__name__.__eq__,   ["bool"], true, "Future().running().__class__.__name__ == 'bool'; verified with Python 3.14.3"]
    - [can_cls,  Future().cancelled().__class__.__name__.__eq__, ["bool"], true, "Future().cancelled().__class__.__name__ == 'bool'; verified with Python 3.14.3"]
    - [don_cls,  Future().done().__class__.__name__.__eq__,      ["bool"], true, "Future().done().__class__.__name__ == 'bool'; verified with Python 3.14.3"]
    - [run_false, Future().running().__eq__,   [false], true, "Future().running().__eq__(False) == True (new Future not running); verified with Python 3.14.3"]
    - [can_false, Future().cancelled().__eq__, [false], true, "Future().cancelled().__eq__(False) == True (new Future not cancelled); verified with Python 3.14.3"]
    - [don_false, Future().done().__eq__,      [false], true, "Future().done().__eq__(False) == True (new Future not done); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Future.running, cancelled, done method identity
#
# Future.running.__name__ == 'running' (len=7)
# Future.running.__module__ == 'concurrent.futures._base' (len=24)
# Future.running.__qualname__ == 'Future.running' (len=14)
# Future.running.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table concurrent_futures_extra243.state_method_identity:
  description: "Future.running, Future.cancelled, Future.done method identity — running.__name__.__eq__('running')==True (len=7); cancelled.__name__.__eq__('cancelled')==True (len=9); done.__name__.__eq__('done')==True (len=4); all three share __module__.__eq__('concurrent.futures._base')==True (len=24); running.__qualname__.__eq__('Future.running')==True (len=14); cancelled.__qualname__.__eq__('Future.cancelled')==True (len=16); done.__qualname__.__eq__('Future.done')==True (len=11); all have __class__.__name__.__eq__('function')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: state_method_identity
  id_prefix: cf243futbeh

  columns: [id, function, args, expected, description]
  rows:
    - [run_name_eq,   Future.running.__name__.__eq__,           ["running"],                    true, "Future.running.__name__ == 'running'; verified with Python 3.14.3"]
    - [run_name_len,  Future.running.__name__.__len__,          [],                             7,    "Future.running.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [run_mod_eq,    Future.running.__module__.__eq__,         ["concurrent.futures._base"],   true, "Future.running.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [run_qname_eq,  Future.running.__qualname__.__eq__,       ["Future.running"],             true, "Future.running.__qualname__ == 'Future.running'; verified with Python 3.14.3"]
    - [can_name_eq,   Future.cancelled.__name__.__eq__,         ["cancelled"],                  true, "Future.cancelled.__name__ == 'cancelled'; verified with Python 3.14.3"]
    - [can_name_len,  Future.cancelled.__name__.__len__,        [],                             9,    "Future.cancelled.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [can_qname_eq,  Future.cancelled.__qualname__.__eq__,     ["Future.cancelled"],           true, "Future.cancelled.__qualname__ == 'Future.cancelled'; verified with Python 3.14.3"]
    - [don_name_eq,   Future.done.__name__.__eq__,              ["done"],                       true, "Future.done.__name__ == 'done'; verified with Python 3.14.3"]
    - [don_name_len,  Future.done.__name__.__len__,             [],                             4,    "Future.done.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [don_qname_eq,  Future.done.__qualname__.__eq__,          ["Future.done"],                true, "Future.done.__qualname__ == 'Future.done'; verified with Python 3.14.3"]
    - [run_cls_nm,    Future.running.__class__.__name__.__eq__, ["function"],                   true, "Future.running.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra243
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra243.future_running_is_false:
  description: "Future().running().__eq__(False) returns True — a new concurrent.futures.Future starts in PENDING state; running() returns False because the future has not been submitted to an executor or started execution; running().__class__.__name__ == 'bool'; running().__eq__(False)==True; contrast running().__eq__(True)==False; Future.running.__module__ == 'concurrent.futures._base' (len=24); NEW in extra243: first standalone future_running_is_false invariant in cf243futbeh namespace; verified with Python 3.14.3"
  category: future_state_types
  kind: python_call_eq
  function: Future().running().__eq__
  args: [false]
  expected: true

invariant concurrent_futures_extra243.future_cancelled_is_false:
  description: "Future().cancelled().__eq__(False) returns True — a new concurrent.futures.Future is not cancelled on creation; cancelled() returns False because cancel() has not been called; cancelled().__class__.__name__ == 'bool'; cancelled().__eq__(False)==True; Future.cancelled.__module__ == 'concurrent.futures._base' (len=24); Future.cancelled.__qualname__ == 'Future.cancelled' (len=16); NEW in extra243: first standalone future_cancelled_is_false invariant; verified with Python 3.14.3"
  category: future_state_types
  kind: python_call_eq
  function: Future().cancelled().__eq__
  args: [false]
  expected: true

invariant concurrent_futures_extra243.future_done_is_false:
  description: "Future().done().__eq__(False) returns True — a new concurrent.futures.Future is not done on creation; done() returns False because no result or exception has been set; done().__class__.__name__ == 'bool'; done().__eq__(False)==True; Future.done.__module__ == 'concurrent.futures._base' (len=24); Future.done.__qualname__ == 'Future.done' (len=11); Future.done.__name__ == 'done' (len=4, shortest name among the three state methods); NEW in extra243: first standalone future_done_is_false invariant; verified with Python 3.14.3"
  category: future_state_types
  kind: python_call_eq
  function: Future().done().__eq__
  args: [false]
  expected: true

invariant concurrent_futures_extra243.running_module_len_24:
  description: "Future.running.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters: 'concurrent'=10 + '.'=1 + 'futures'=7 + '.'=1 + '_base'=5 = 24; all three state methods (running, cancelled, done) share this module; Future.running.__qualname__.__len__()==14 ('Future.running'); Future.running.__name__.__len__()==7 ('running'); NEW in extra243: first standalone running module length invariant; verified with Python 3.14.3"
  category: state_method_identity
  kind: python_call_eq
  function: Future.running.__module__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra243.running_qualname_len_14:
  description: "Future.running.__qualname__.__len__() == 14 — 'Future.running' has 14 chars: 'Future.'=7 + 'running'=7 = 14; Future.cancelled.__qualname__.__len__()==16 ('Future.cancelled'=7+9); Future.done.__qualname__.__len__()==11 ('Future.done'=7+4); running qualname len (14) < cancelled qualname len (16) > done qualname len (11); Future.running.__name__.__len__()==7; NEW in extra243: first standalone running qualname length invariant; verified with Python 3.14.3"
  category: state_method_identity
  kind: python_call_eq
  function: Future.running.__qualname__.__len__
  args: []
  expected: 14

invariant concurrent_futures_extra243.state_return_class_is_bool:
  description: "Future().running().__class__.__name__.__eq__('bool') returns True — all three state methods (running, cancelled, done) return bool values; bool.__name__ == 'bool' (len=4); a new Future is in PENDING state so all three return False; False.__class__.__name__ == 'bool'; the methods are defined in Lib/concurrent/futures/_base.py; Future.running.__class__.__name__ == 'function'; NEW in extra243: first standalone state_return_class_is_bool invariant; verified with Python 3.14.3"
  category: future_state_types
  kind: python_call_eq
  function: Future().running().__class__.__name__.__eq__
  args: ["bool"]
  expected: true
