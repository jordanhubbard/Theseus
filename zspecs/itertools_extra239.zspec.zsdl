spec: itertools_extra239
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.product and itertools.permutations class identity."
    - "itertools.product.__name__ == 'product' (len=7) — product is a C class in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools' (len=9) — defined in the itertools C extension. Verified with Python 3.14.3."
    - "itertools.product.__bases__[0].__name__ == 'object' — product inherits directly from object. Verified with Python 3.14.3."
    - "itertools.product.__doc__ contains 'Cartesian' == True — docstring says 'Cartesian product of input iterables'. Verified with Python 3.14.3."
    - "itertools.permutations.__name__ == 'permutations' (len=12) — permutations is a C class in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.permutations.__module__ == 'itertools' (len=9) — defined in the itertools C extension. Verified with Python 3.14.3."
    - "itertools.permutations.__bases__[0].__name__ == 'object' — permutations inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.product class identity contracts
#
# itertools.product.__name__ == 'product' (len=7)
# itertools.product.__module__ == 'itertools' (len=9)
# itertools.product.__bases__[0].__name__ == 'object'
# itertools.product.__class__.__name__ == 'type'
# itertools.product.__qualname__ == 'product' (len=7)
#
# product is a C class in itertoolsmodule.c. New to extra239.
# ---------------------------------------------------------------------------

table itertools_extra239.product239_identity:
  description: "itertools.product class identity: name, module, bases, class, qualname; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: product239

  columns: [id, function, args, expected, description]
  rows:
    - [product_name_eq,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — product is a C class in itertoolsmodule.c; __name__ is 'product' (len=7); new to extra239"]
    - [product_name_len_7,
       product.__name__.__len__,
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — 'product' has exactly 7 characters (p-r-o-d-u-c-t); str.__len__() returns 7; new to extra239"]
    - [product_module_eq,
       product.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — product is defined in the itertools C extension; __module__ is 'itertools' (len=9); new to extra239"]
    - [product_module_len_9,
       product.__module__.__len__,
       [],
       9,
       "itertools.product.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra239"]
    - [product_bases_0_is_object,
       "product.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.product.__bases__[0].__name__.__eq__('object') == True — product inherits directly from object; __bases__[0] is object; new to extra239"]

# ---------------------------------------------------------------------------
# Table 2: itertools.product class and doc contracts
#
# itertools.product.__class__.__name__ == 'type'
# itertools.product.__qualname__ == 'product' (len=7)
# itertools.product.__doc__.__contains__('Cartesian') == True
# itertools.product.__doc__.__contains__('product') == True
# itertools.product.__doc__.__class__.__name__ == 'str'
#
# product docstring describes Cartesian product of input iterables. New to extra239.
# ---------------------------------------------------------------------------

table itertools_extra239.product239_class_doc:
  description: "itertools.product class, qualname, doc checks; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: product239doc

  columns: [id, function, args, expected, description]
  rows:
    - [product_class_is_type,
       product.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.product.__class__.__name__.__eq__('type') == True — product is a class; its metaclass is the built-in type type; new to extra239"]
    - [product_qualname_eq,
       product.__qualname__.__eq__,
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — __qualname__ is 'product' (len=7); same as __name__ for top-level class; new to extra239"]
    - [product_qualname_len_7,
       product.__qualname__.__len__,
       [],
       7,
       "itertools.product.__qualname__.__len__() == 7 — 'product' has exactly 7 characters; str.__len__() returns 7; new to extra239"]
    - [product_doc_contains_cartesian,
       product.__doc__.__contains__,
       ["Cartesian"],
       true,
       "itertools.product.__doc__.__contains__('Cartesian') == True — docstring says 'Cartesian product of input iterables'; new to extra239"]
    - [product_doc_class_is_str,
       product.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.product.__doc__.__class__.__name__.__eq__('str') == True — the product docstring is a plain Python str object; new to extra239"]

# ---------------------------------------------------------------------------
# Table 3: itertools.permutations class identity contracts
#
# itertools.permutations.__name__ == 'permutations' (len=12)
# itertools.permutations.__module__ == 'itertools' (len=9)
# itertools.permutations.__bases__[0].__name__ == 'object'
# itertools.permutations.__class__.__name__ == 'type'
# itertools.permutations.__qualname__ == 'permutations' (len=12)
#
# permutations is a C class in itertoolsmodule.c. New to extra239.
# ---------------------------------------------------------------------------

table itertools_extra239.perms239_identity:
  description: "itertools.permutations class identity: name, module, bases, class, qualname; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: perms239

  columns: [id, function, args, expected, description]
  rows:
    - [perms_name_eq,
       permutations.__name__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations is a C class in itertoolsmodule.c; __name__ is 'permutations' (len=12); new to extra239"]
    - [perms_name_len_12,
       permutations.__name__.__len__,
       [],
       12,
       "itertools.permutations.__name__.__len__() == 12 — 'permutations' has exactly 12 characters; str.__len__() returns 12; new to extra239"]
    - [perms_module_eq,
       permutations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — permutations is defined in the itertools C extension; __module__ is 'itertools' (len=9); new to extra239"]
    - [perms_module_len_9,
       permutations.__module__.__len__,
       [],
       9,
       "itertools.permutations.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra239"]
    - [perms_bases_0_is_object,
       "permutations.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.permutations.__bases__[0].__name__.__eq__('object') == True — permutations inherits directly from object; __bases__[0] is object; new to extra239"]

# ---------------------------------------------------------------------------
# Table 4: itertools.permutations class and doc contracts
#
# itertools.permutations.__class__.__name__ == 'type'
# itertools.permutations.__qualname__ == 'permutations' (len=12)
# itertools.permutations.__doc__.__contains__('permutations') == True
# itertools.permutations.__doc__.__contains__('elements') == True
# itertools.permutations.__doc__.__class__.__name__ == 'str'
#
# permutations docstring describes successive r-length permutations. New to extra239.
# ---------------------------------------------------------------------------

table itertools_extra239.perms239_class_doc:
  description: "itertools.permutations class, qualname, doc checks; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: perms239doc

  columns: [id, function, args, expected, description]
  rows:
    - [perms_class_is_type,
       permutations.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.permutations.__class__.__name__.__eq__('type') == True — permutations is a class; its metaclass is the built-in type type; new to extra239"]
    - [perms_qualname_eq,
       permutations.__qualname__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — __qualname__ is 'permutations' (len=12); same as __name__ for top-level class; new to extra239"]
    - [perms_qualname_len_12,
       permutations.__qualname__.__len__,
       [],
       12,
       "itertools.permutations.__qualname__.__len__() == 12 — 'permutations' has exactly 12 characters; str.__len__() returns 12; new to extra239"]
    - [perms_doc_contains_permutations,
       permutations.__doc__.__contains__,
       ["permutations"],
       true,
       "itertools.permutations.__doc__.__contains__('permutations') == True — docstring says 'Return successive r-length permutations of elements'; new to extra239"]
    - [perms_doc_class_is_str,
       permutations.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.permutations.__doc__.__class__.__name__.__eq__('str') == True — the permutations docstring is a plain Python str object; new to extra239"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra239
# ---------------------------------------------------------------------------

invariant itertools_extra239.product_name_eq:
  description: "itertools.product.__name__ == 'product' (len=7); new to extra239"
  kind: python_call_eq
  function: product.__name__.__eq__
  args: ["product"]
  expected: true

invariant itertools_extra239.product_name_len_7:
  description: "itertools.product.__name__.__len__() == 7 — 'product' has 7 characters; new to extra239"
  kind: python_call_eq
  function: product.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra239.product_module_eq:
  description: "itertools.product.__module__ == 'itertools'; new to extra239"
  kind: python_call_eq
  function: product.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra239.product_bases_0_is_object:
  description: "itertools.product.__bases__[0].__name__ == 'object'; new to extra239"
  kind: python_call_eq
  function: "product.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra239.product_class_is_type:
  description: "itertools.product.__class__.__name__ == 'type'; new to extra239"
  kind: python_call_eq
  function: product.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra239.product_doc_contains_cartesian:
  description: "itertools.product.__doc__.__contains__('Cartesian') == True; new to extra239"
  kind: python_call_eq
  function: product.__doc__.__contains__
  args: ["Cartesian"]
  expected: true

invariant itertools_extra239.perms_name_eq:
  description: "itertools.permutations.__name__ == 'permutations' (len=12); new to extra239"
  kind: python_call_eq
  function: permutations.__name__.__eq__
  args: ["permutations"]
  expected: true

invariant itertools_extra239.perms_name_len_12:
  description: "itertools.permutations.__name__.__len__() == 12 — 'permutations' has 12 characters; new to extra239"
  kind: python_call_eq
  function: permutations.__name__.__len__
  args: []
  expected: 12

invariant itertools_extra239.perms_module_eq:
  description: "itertools.permutations.__module__ == 'itertools'; new to extra239"
  kind: python_call_eq
  function: permutations.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra239.perms_bases_0_is_object:
  description: "itertools.permutations.__bases__[0].__name__ == 'object'; new to extra239"
  kind: python_call_eq
  function: "permutations.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra239.perms_class_is_type:
  description: "itertools.permutations.__class__.__name__ == 'type'; new to extra239"
  kind: python_call_eq
  function: permutations.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra239.perms_doc_contains_permutations:
  description: "itertools.permutations.__doc__.__contains__('permutations') == True; new to extra239"
  kind: python_call_eq
  function: permutations.__doc__.__contains__
  args: ["permutations"]
  expected: true
