spec: audioop_extra2
version: ">=3.9,<3.13"
backend: python_module(audioop)

docs: https://docs.python.org/3/library/audioop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/audioop.html — Python audioop module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/audioop.c"
    - "audioop.zspec.zsdl — covers error.__name__, error.__module__, error.__bases__[0].__name__, max/__name__, avg/__name__, rms/__name__, bias/__name__, reverse/__name__, silent-fragment behavioral checks"
    - "audioop_extra.zspec.zsdl — covers __qualname__ for max/min/avg/add/mul and error; max.__module__"
  notes:
    - "This spec extends audioop.zspec.zsdl and audioop_extra.zspec.zsdl."
    - "Deprecated since Python 3.11; removed in Python 3.13. Version constraint: >=3.9,<3.13."
    - "Focus: type-identity of audioop.error (is_type), __module__ for avg and rms, __class__.__name__ for C extension functions."
    - "audioop.error is a class object: error.__class__.__name__ == 'type'."
    - "audioop C extension functions have __class__.__name__ == 'builtin_function_or_method'."
    - "avg.__module__ and rms.__module__ are not covered by any prior spec (only max.__module__ is covered in audioop_extra)."
    - "error.__class__.__name__ is not covered by any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "audioop.error is raised when arguments are invalid (e.g. wrong fragment size, bad width). It is a direct subclass of Exception."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Type-identity check for audioop.error
# Prior specs cover error.__name__, __module__, __bases__[0].__name__, __qualname__.
# error.__class__.__name__ is a new axis not covered by any prior spec.
# ---------------------------------------------------------------------------

invariant audioop_extra2.error.is_type:
  description: "audioop.error.__class__.__name__ == 'type' — error is a class object"
  category: class_identity
  kind: python_call_eq
  function: error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks for avg and rms
# audioop_extra covers max.__module__; avg.__module__ and rms.__module__ are new.
# C extension functions in audioop report __module__ == 'audioop'.
# ---------------------------------------------------------------------------

invariant audioop_extra2.avg.module:
  description: "audioop.avg.__module__ == 'audioop'"
  category: modules
  kind: python_call_eq
  function: avg.__module__.__eq__
  args: ["audioop"]
  expected: true

invariant audioop_extra2.rms.module:
  description: "audioop.rms.__module__ == 'audioop'"
  category: modules
  kind: python_call_eq
  function: rms.__module__.__eq__
  args: ["audioop"]
  expected: true

# ---------------------------------------------------------------------------
# Type-identity checks for audioop C extension functions
# All are builtin_function_or_method objects (C extension functions).
# No prior spec checks __class__.__name__ for any audioop function.
# ---------------------------------------------------------------------------

table audioop_extra2.function_types:
  kind: python_call_eq
  category: function_identity
  id_prefix: functype

  columns: [id, function, args, expected]
  rows:
    - [max,     max.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [avg,     avg.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [rms,     rms.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [bias,    bias.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [reverse, reverse.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
