spec: just_mean
version: ">=2.2.0"
backend: node(just-mean)

docs: https://www.npmjs.com/package/just-mean

provenance:
  derived_from:
    - "just-mean README — https://www.npmjs.com/package/just-mean"
    - "Test vectors verified with just-mean via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-mean source"
  notes:
    - "just-mean is an npm package. Install: npm install just-mean"
    - "The module exports a single function that returns the arithmetic mean."
    - "Accepts either variadic numeric arguments or a single array argument."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_mean.mean:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: jmean

  columns: [id, args, expected]
  rows:
    - [variadic,  [1, 2, 3, 4, 5],  3]
    - [array,     [[10, 20, 30]],    20]
