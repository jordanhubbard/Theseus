spec: socket_extra271
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "socket_extra270.zspec.zsdl — covers socket.socket __init__/__repr__/__str__ method identity and socket.timeout/error exception identity."
    - "socket_extra269.zspec.zsdl — covers socket.inet_aton/inet_ntoa/inet_pton/inet_ntop function identity."
  notes:
    - "socket.__name__ == 'socket' — the pure-Python socket module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.__package__ == '' — socket is a top-level module with empty package string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.__spec__.name == 'socket' — ModuleSpec.name matches the module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is an importlib.machinery.ModuleSpec. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.__loader__.__class__.__name__ == 'SourceFileLoader' — socket is loaded from a .py source file. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "_socket.__name__ == '_socket' — the C extension backing module name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "_socket.__package__ == '' — _socket is a top-level C extension with empty package string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "_socket.__spec__.name == '_socket' — ModuleSpec.name for the C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "_socket.__loader__.__class__.__name__ == 'ExtensionFileLoader' — C extension modules use ExtensionFileLoader. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "type(socket.has_ipv6).__name__ == 'bool' — has_ipv6 is a plain Python bool constant. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.AddressFamily.__name__ == 'AddressFamily' — the IntEnum subclass name. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.AddressFamily.__module__ == 'socket' — AddressFamily is defined in the socket module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum' — AddressFamily inherits from IntEnum. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module __spec__ and __loader__ identity
# socket is a pure-Python wrapper (SourceFileLoader) around the _socket
# C extension (ExtensionFileLoader). __package__ is '' for both.
# ---------------------------------------------------------------------------

table socket_extra271.socket_module_spec_identity:
  description: "socket module __spec__ and __loader__ identity — __name__/'socket', __package__/'', __spec__.name/'socket', __spec__.__class__.__name__/'ModuleSpec', __loader__.__class__.__name__/'SourceFileLoader'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockspec271

  columns: [id, function, args, expected, description]
  rows:
    - [sock_name,       __name__.__eq__,                          ["socket"],           true, "socket.__name__ == 'socket' — pure-Python wrapper module name"]
    - [sock_package,    __package__.__eq__,                       [""],                 true, "socket.__package__ == '' — top-level module has empty package string"]
    - [sock_spec_name,  __spec__.name.__eq__,                     ["socket"],           true, "socket.__spec__.name == 'socket' — ModuleSpec.name matches module name"]
    - [sock_spec_cls,   __spec__.__class__.__name__.__eq__,       ["ModuleSpec"],       true, "socket.__spec__.__class__.__name__ == 'ModuleSpec' — importlib.machinery.ModuleSpec instance"]
    - [sock_loader,     __loader__.__class__.__name__.__eq__,     ["SourceFileLoader"], true, "socket.__loader__.__class__.__name__ == 'SourceFileLoader' — pure-Python source loaded via SourceFileLoader"]

# ---------------------------------------------------------------------------
# _socket C extension identity and socket.AddressFamily enum identity
# _socket is the C extension providing the underlying socket implementation.
# socket.AddressFamily is an IntEnum subclass defined in the socket module.
# socket.has_ipv6 is a bool constant.
# ---------------------------------------------------------------------------

table socket_extra271.socket_csocket_and_enum_identity:
  description: "_socket C extension identity and socket.AddressFamily enum identity — _socket.__loader__/'ExtensionFileLoader'; has_ipv6 is 'bool'; AddressFamily.__name__/'AddressFamily'; AddressFamily.__module__/'socket'; AddressFamily.__bases__[0].__name__/'IntEnum'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockcenum271

  columns: [id, function, args, expected, description]
  rows:
    - [csock_name,      _socket.__name__.__eq__,                            ["_socket"],            true, "_socket.__name__ == '_socket' — C extension backing module name"]
    - [csock_loader,    _socket.__loader__.__class__.__name__.__eq__,       ["ExtensionFileLoader"], true, "_socket.__loader__.__class__.__name__ == 'ExtensionFileLoader' — C extension uses ExtensionFileLoader"]
    - [ipv6_type,       has_ipv6.__class__.__name__.__eq__,                 ["bool"],               true, "type(socket.has_ipv6).__name__ == 'bool' — has_ipv6 is a plain Python bool constant"]
    - [af_name,         AddressFamily.__name__.__eq__,                      ["AddressFamily"],      true, "socket.AddressFamily.__name__ == 'AddressFamily' — the IntEnum subclass name"]
    - [af_module,       AddressFamily.__module__.__eq__,                    ["socket"],             true, "socket.AddressFamily.__module__ == 'socket' — AddressFamily is defined in the socket module"]

# ---------------------------------------------------------------------------
# Standalone invariants — socket module spec and _socket extension identity
# ---------------------------------------------------------------------------

invariant socket_extra271.socket_name_eq:
  description: "socket.__name__ == 'socket' — the module name attribute of the socket module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra271.socket_package_eq:
  description: "socket.__package__ == '' — socket is a top-level module so __package__ is the empty string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant socket_extra271.socket_spec_name_eq:
  description: "socket.__spec__.name == 'socket' — the ModuleSpec.name attribute for the socket module; mirrors __name__; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra271.socket_spec_class_eq:
  description: "socket.__spec__.__class__.__name__ == 'ModuleSpec' — the module spec is an importlib.machinery.ModuleSpec; set by the import system for all Python modules; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant socket_extra271.socket_loader_class_eq:
  description: "socket.__loader__.__class__.__name__ == 'SourceFileLoader' — socket.py is loaded from source by SourceFileLoader; contrasts with _socket's ExtensionFileLoader; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant socket_extra271._socket_name_eq:
  description: "_socket.__name__ == '_socket' — the C extension module that provides the actual socket implementation; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: _socket.__name__.__eq__
  args: ["_socket"]
  expected: true

invariant socket_extra271._socket_package_eq:
  description: "_socket.__package__ == '' — _socket is a top-level C extension module with empty package string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: _socket.__package__.__eq__
  args: [""]
  expected: true

invariant socket_extra271._socket_spec_name_eq:
  description: "_socket.__spec__.name == '_socket' — the ModuleSpec.name for the _socket C extension; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: _socket.__spec__.name.__eq__
  args: ["_socket"]
  expected: true

invariant socket_extra271._socket_loader_class_eq:
  description: "_socket.__loader__.__class__.__name__ == 'ExtensionFileLoader' — C extension modules use ExtensionFileLoader from importlib._bootstrap_external; contrasts with SourceFileLoader used for socket.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: _socket.__loader__.__class__.__name__.__eq__
  args: ["ExtensionFileLoader"]
  expected: true

invariant socket_extra271.has_ipv6_type_eq:
  description: "type(socket.has_ipv6).__name__ == 'bool' — socket.has_ipv6 is a plain Python bool constant set at module load time; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: has_ipv6.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

invariant socket_extra271.AddressFamily_name_eq:
  description: "socket.AddressFamily.__name__ == 'AddressFamily' — the IntEnum subclass for socket address families; defined in socket.py using enum.IntEnum; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: AddressFamily.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra271.AddressFamily_module_eq:
  description: "socket.AddressFamily.__module__ == 'socket' — AddressFamily is defined in the socket module's Lib/socket.py; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: AddressFamily.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra271.AddressFamily_bases0_name_eq:
  description: "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum' — AddressFamily inherits from IntEnum; this allows integer comparisons with socket constants; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: "AddressFamily.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true
