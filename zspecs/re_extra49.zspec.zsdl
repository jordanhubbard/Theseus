spec: re_extra49
version: ">=3.11"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra48.zspec.zsdl — covers re.RegexFlag member ._name_ equality and ._name_.__len__() for IGNORECASE/ASCII/MULTILINE/DOTALL/VERBOSE/UNICODE/LOCALE."
    - "re_extra47.zspec.zsdl — covers re.error.__qualname__.__len__()==12; re.PatternError identity attributes."
    - "re_extra35.zspec.zsdl — covers RegexFlag.__name__.__len__()==9; RegexFlag.__mro__.__len__()==7."
    - "re_extra27.zspec.zsdl — covers RegexFlag.__module__.__eq__('re'); RegexFlag.__bases__[0].__name__.__eq__('IntFlag')."
    - "re_extra22.zspec.zsdl — covers Pattern.__name__/__module__/__bases__[0].__name__; Match.__name__/__module__/__bases__[0].__name__; function __name__ attributes table."
    - "re_extra9.zspec.zsdl — covers error.__qualname__; Pattern.__qualname__; Match.__qualname__."
    - "re_extra8.zspec.zsdl — covers IGNORECASE/MULTILINE __class__.__name__.__eq__('RegexFlag')."
    - "re_extra33.zspec.zsdl — covers IGNORECASE.__class__.__name__.__len__()==9."
  notes:
    - "This spec extends re_extra48.zspec.zsdl."
    - "Prior specs collectively covered: all RegexFlag class identity attributes; all flag ._value_ and .value attributes; all flag __class__.__name__=='RegexFlag' checks; all flag ._name_ attributes (re_extra48); Pattern/__name__/__qualname__/__module__/__bases__[0].__name__ equality (re_extra22); Pattern/__qualname__/__name__/__module__ lengths (re_extra35/re_extra_series); Match same attributes; re.error (PatternError) identity. NO prior re spec checks Pattern.__class__.__name__, Match.__class__.__name__, RegexFlag.__class__.__name__, re.search.__class__.__name__, re.compile.__class__.__name__, re.sub.__class__.__name__, or re.error.__class__.__name__ at all."
    - "This spec covers: re.Pattern.__class__.__name__.__eq__('type') (NOVEL — Pattern is a C-extension type; its metaclass is 'type'; no prior re spec checks Pattern.__class__.__name__; novel); re.Match.__class__.__name__.__eq__('type') (NOVEL — Match is a C-extension type; same reasoning; novel); re.RegexFlag.__class__.__name__.__eq__('EnumType') (NOVEL — RegexFlag is an IntFlag enum; its metaclass is EnumType, not plain 'type'; no prior re spec checks RegexFlag.__class__.__name__; novel); re.search.__class__.__name__.__eq__('function') (NOVEL — re.search is a Python-level function in re/__init__.py; its type is 'function'; no prior re spec checks search.__class__.__name__; novel); re.compile.__class__.__name__.__eq__('function') (NOVEL); re.sub.__class__.__name__.__eq__('function') (NOVEL); re.error.__class__.__name__.__eq__('type') (NOVEL — re.error is an alias for PatternError, a class object whose metaclass is 'type'; no prior re spec checks error.__class__.__name__; novel)."
    - "re.Pattern.__class__.__name__ == 'type'. Pattern is a C-extension type (from _sre). Its metaclass is the standard 'type'. No prior re spec checks Pattern.__class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Match.__class__.__name__ == 'type'. Match is a C-extension type (from _sre). Its metaclass is the standard 'type'. No prior re spec checks Match.__class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.RegexFlag.__class__.__name__ == 'EnumType'. RegexFlag is an IntFlag subclass. Its metaclass is EnumType (the metaclass for all enum types in Python 3.11+). This is distinct from 'type'. No prior re spec checks RegexFlag.__class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.search.__class__.__name__ == 'function'. re.search is a regular Python function defined in re/__init__.py. Its type is 'function'. No prior re spec checks search.__class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.error.__class__.__name__ == 'type'. re.error is an alias for re.PatternError, which is a regular exception class. Its metaclass is 'type'. No prior re spec checks error.__class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern and re.Match __class__.__name__
#
# Pattern and Match are C-extension types exported from the _sre module.
# As regular types, their metaclass is the standard 'type':
#
#   Pattern.__class__.__name__  == 'type'
#   Match.__class__.__name__    == 'type'
#
# Prior specs cover Pattern/__name__/__qualname__/__module__ and Match same
# (re_extra22, re_extra9 etc.), but NO prior re spec checks
# Pattern.__class__.__name__ or Match.__class__.__name__.
# Both equality anchors are novel in the re_extra49 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra49.Pattern_class_name_eq:
  description: "re.Pattern.__class__.__name__ == 'type' — Pattern is a C-extension type from _sre; its metaclass is the standard 'type'; no prior re spec checks Pattern.__class__.__name__; novel equality anchor in re_extra49 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant re_extra49.Match_class_name_eq:
  description: "re.Match.__class__.__name__ == 'type' — Match is a C-extension type from _sre; its metaclass is the standard 'type'; no prior re spec checks Match.__class__.__name__; novel equality anchor in re_extra49 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Match.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# re.RegexFlag.__class__.__name__ — EnumType metaclass
#
# RegexFlag is an IntFlag subclass. In Python 3.11+, enum types use the
# EnumType metaclass (formerly EnumMeta). Its __class__.__name__ is:
#
#   RegexFlag.__class__.__name__  == 'EnumType'
#
# This is distinct from the plain 'type' metaclass used by non-enum classes.
# re_extra27 covers RegexFlag.__module__/__bases__[0].__name__;
# re_extra35 covers RegexFlag.__name__.__len__()==9.
# No prior re spec checks RegexFlag.__class__.__name__.
# Novel equality anchor in the re_extra49 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra49.RegexFlag_class_name_eq:
  description: "re.RegexFlag.__class__.__name__ == 'EnumType' — RegexFlag is an IntFlag subclass; its metaclass is EnumType (Python 3.11+ enum metaclass), not plain 'type'; no prior re spec checks RegexFlag.__class__.__name__; novel equality anchor in re_extra49 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# re module function __class__.__name__ equality
#
# The core re module functions (search, compile, sub) are regular Python
# functions defined in re/__init__.py. Their __class__.__name__ is 'function':
#
#   search.__class__.__name__   == 'function'
#   compile.__class__.__name__  == 'function'
#   sub.__class__.__name__      == 'function'
#
# No prior re spec checks __class__.__name__ for any of these functions.
# All three equality anchors are novel in the re_extra49 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra49.function_class_names:
  description: "re module function __class__.__name__.__eq__('function') for search/compile/sub — all are regular Python functions in re/__init__.py; no prior re spec checks __class__.__name__ for any re function; all three novel equality anchors in re_extra49 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: rfcn49

  columns: [id, function, args, expected]
  rows:
    - [search_class_name,  search.__class__.__name__.__eq__,  ["function"], true]
    - [compile_class_name, compile.__class__.__name__.__eq__, ["function"], true]
    - [sub_class_name,     sub.__class__.__name__.__eq__,     ["function"], true]

# ---------------------------------------------------------------------------
# re.error.__class__.__name__
#
# re.error is an alias for re.PatternError (the exception class for regex
# errors). As a regular exception class, its metaclass is 'type':
#
#   error.__class__.__name__  == 'type'
#
# re_extra47 covers re.PatternError identity attributes (name, qualname,
# module, bases, mro). No prior re spec checks re.error.__class__.__name__.
# Novel equality anchor in the re_extra49 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra49.error_class_name_eq:
  description: "re.error.__class__.__name__ == 'type' — re.error is an alias for PatternError, a regular exception class whose metaclass is 'type'; re_extra47 covers PatternError identity attributes but no prior re spec checks re.error.__class__.__name__; novel equality anchor in re_extra49 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: error.__class__.__name__.__eq__
  args: ["type"]
  expected: true
