spec: celery_rust
version: ">=3.9"
backend: rust_module(celery_rust)

docs: https://docs.celeryq.dev/en/stable/reference/

provenance:
  derived_from:
    - "https://docs.celeryq.dev/en/stable/reference/ — Celery reference"
  not_derived_from:
    - "celery source: celery/app/__init__.py"
  notes:
    - "Celery is a distributed task queue for Python."
    - "Celery('myapp').main == 'myapp'."
    - "Celery('tasks').main == 'tasks'."
    - "celery.__version__ is a non-empty string."
    - "int(celery.__version__.split('.')[0]) >= 5."
    - "Expose celery_main_name(name) -> str: Celery(name).main."
    - "Expose celery_version_major() -> int: int(celery.__version__.split('.')[0])."
    - "Expose celery_has_task_decorator() -> bool: hasattr(celery, 'task')."
    - "All test vectors verified against celery 5.4.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# celery_main_name — Celery app main name
table celery_rust.app.main_name:
  kind: python_call_eq
  category: main_name
  id_prefix: cel_mn
  function: celery_main_name

  columns: [id, args, expected]
  rows:
    - [myapp, ["myapp"], "myapp"]
    - [tasks, ["tasks"], "tasks"]

# celery_version_major — major version is 5
invariant celery_rust.version.major:
  description: "Celery major version == 5"
  category: version
  kind: python_call_eq
  function: celery_version_major
  args: []
  expected: 5

# celery_has_task_decorator — task decorator present
invariant celery_rust.decorators.has_task:
  description: "celery has task attribute"
  category: decorators
  kind: python_call_eq
  function: celery_has_task_decorator
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:17:20Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
