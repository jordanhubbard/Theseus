spec: asyncio_extra1306
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad argument types and values."
    - "asyncio.Semaphore(-1) raises ValueError — initial value must be >= 0."
    - "asyncio.BoundedSemaphore(-1) raises ValueError — initial value must be >= 0."
    - "asyncio.Barrier(0) raises ValueError — parties must be >= 1."
    - "asyncio.Barrier(-1) raises ValueError — parties must be >= 1."
    - "asyncio.Semaphore('x') raises TypeError — comparison '<' not supported between str and int."
    - "asyncio.Barrier('x') raises TypeError — comparison '<' not supported between str and int."
    - "asyncio.Lock(42) raises TypeError — Lock.__init__() takes 1 positional argument but 2 were given."
    - "asyncio.Event(42) raises TypeError — Event.__init__() takes 1 positional argument but 2 were given."
    - "asyncio.Condition(42) raises AttributeError — 'int' object has no attribute 'locked'."
    - "asyncio.iscoroutinefunction() raises TypeError — missing required argument 'func'."
    - "asyncio.iscoroutine() raises TypeError — missing required argument 'obj'."
    - "asyncio.isfuture() raises TypeError — missing required argument 'obj'."
    - "asyncio.ensure_future(42) raises TypeError — requires Future, coroutine, or awaitable."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra1306.semaphore_value_errors:
  description: "asyncio.Semaphore and asyncio.BoundedSemaphore raise ValueError for negative initial values"
  kind: python_call_raises
  category: value_errors
  id_prefix: as1306sv
  columns: [id, function, args, exception]
  rows:
    - [as1306sv001, asyncio.Semaphore,        [-1],  "ValueError"]
    - [as1306sv002, asyncio.Semaphore,        [-2],  "ValueError"]
    - [as1306sv003, asyncio.Semaphore,        [-100],"ValueError"]
    - [as1306sv004, asyncio.BoundedSemaphore, [-1],  "ValueError"]
    - [as1306sv005, asyncio.BoundedSemaphore, [-2],  "ValueError"]
    - [as1306sv006, asyncio.BoundedSemaphore, [-100],"ValueError"]

table asyncio_extra1306.barrier_value_errors:
  description: "asyncio.Barrier raises ValueError when parties is zero or negative, and TypeError when parties is a non-numeric type"
  kind: python_call_raises
  category: value_errors
  id_prefix: as1306bv
  columns: [id, function, args, exception]
  rows:
    - [as1306bv001, asyncio.Barrier, [0],   "ValueError"]
    - [as1306bv002, asyncio.Barrier, [-1],  "ValueError"]
    - [as1306bv003, asyncio.Barrier, [-10], "ValueError"]
    - [as1306bv004, asyncio.Barrier, ["x"], "TypeError"]
    - [as1306bv005, asyncio.Barrier, ["0"], "TypeError"]
    - [as1306bv006, asyncio.Semaphore, ["x"], "TypeError"]

table asyncio_extra1306.lock_and_inspect_errors:
  description: "asyncio.Lock and asyncio.Event reject unexpected positional arguments; inspection helpers require arguments"
  kind: python_call_raises
  category: type_errors
  id_prefix: as1306le
  columns: [id, function, args, exception]
  rows:
    - [as1306le001, asyncio.Lock,               [42],   "TypeError"]
    - [as1306le002, asyncio.Event,              [42],   "TypeError"]
    - [as1306le003, asyncio.iscoroutinefunction, [],    "TypeError"]
    - [as1306le004, asyncio.iscoroutine,         [],    "TypeError"]
    - [as1306le005, asyncio.isfuture,            [],    "TypeError"]
    - [as1306le006, asyncio.ensure_future,       [42],  "TypeError"]
