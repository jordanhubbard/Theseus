spec: typing_extra6
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends prior typing specs."
    - "Focus: TypeVar, Generic, and typing special forms not yet covered."
    - "typing.TypeVar('T').__name__ == 'T'."
    - "typing.TypeVar('T').__class__.__name__ == 'TypeVar'."
    - "typing.TypeVar('T').__bound__ is None (no bound by default)."
    - "typing.TypeVar('T').__constraints__ == () (no constraints by default)."
    - "typing.TypeVar('T', bound=int).__bound__ is int."
    - "typing.Union.__class__.__name__ == '_SpecialForm'."
    - "typing.Optional.__class__.__name__ == '_SpecialForm'."
    - "typing.ClassVar.__class__.__name__ == '_SpecialForm'."
    - "typing.Final.__class__.__name__ == '_SpecialForm'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table typing_extra6.special_forms:
  kind: python_call_eq
  category: special_forms
  id_prefix: sf

  columns: [id, function, args, expected]
  rows:
    - [Union,     Union.__class__.__name__.__eq__,     ["_SpecialForm"], true]
    - [Optional,  Optional.__class__.__name__.__eq__,  ["_SpecialForm"], true]
    - [ClassVar,  ClassVar.__class__.__name__.__eq__,  ["_SpecialForm"], true]
    - [Final,     Final.__class__.__name__.__eq__,     ["_SpecialForm"], true]
    - [Literal,   Literal.__class__.__name__.__eq__,   ["_SpecialForm"], true]
    - [Annotated, Annotated.__class__.__name__.__eq__, ["_SpecialForm"], true]

table typing_extra6.special_form_names:
  kind: python_call_eq
  category: special_form_names
  id_prefix: sfn

  columns: [id, function, args, expected]
  rows:
    - [Union,    Union._name.__eq__,    ["Union"],    true]
    - [Optional, Optional._name.__eq__, ["Optional"], true]
    - [ClassVar, ClassVar._name.__eq__, ["ClassVar"], true]
    - [Final,    Final._name.__eq__,    ["Final"],    true]
    - [Literal,  Literal._name.__eq__,  ["Literal"],  true]

invariant typing_extra6.TypeVar.name_attr:
  description: "typing.TypeVar('T').__name__ == 'T'"
  category: TypeVar
  kind: python_call_eq
  function: TypeVar
  args: ["T"]
  method: __name__
  expected: "T"

invariant typing_extra6.TypeVar.class_name:
  description: "typing.TypeVar('T').__class__.__name__ == 'TypeVar'"
  category: TypeVar
  kind: python_call_eq
  function: TypeVar
  args: ["T"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["TypeVar"]
  expected: true

invariant typing_extra6.TypeVar.no_bound:
  description: "typing.TypeVar('T').__bound__ is None"
  category: TypeVar
  kind: python_call_eq
  function: TypeVar
  args: ["T"]
  method: __bound__.__class__
  method_chain: __name__.__eq__
  method_chain_args: ["NoneType"]
  expected: true

invariant typing_extra6.TypeVar.no_constraints:
  description: "typing.TypeVar('T').__constraints__ == ()"
  category: TypeVar
  kind: python_call_eq
  function: TypeVar
  args: ["T"]
  method: __constraints__.__eq__
  method_args: [[]]
  expected: true

invariant typing_extra6.TypeVar.module:
  description: "typing.TypeVar.__module__ == 'typing'"
  category: TypeVar
  kind: python_call_eq
  function: TypeVar.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_extra6.Generic.module:
  description: "typing.Generic.__module__ == 'typing'"
  category: Generic
  kind: python_call_eq
  function: Generic.__module__.__eq__
  args: ["typing"]
  expected: true
