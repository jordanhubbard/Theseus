spec: re_extra201
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers re module __name__ lengths not covered by prior re_extra specs."
    - "re.__name__ == 're' (len=2); the module's own __name__ attribute; confirmed Python 3.14.3 macOS."
    - "re.Pattern.__name__ == 'Pattern' (len=7); the compiled pattern class; confirmed Python 3.14.3 macOS."
    - "re.Match.__name__ == 'Match' (len=5); the match object class; confirmed Python 3.14.3 macOS."
    - "re.error.__name__ == 'PatternError' (len=12); re.error was renamed to PatternError in Python 3.13; re.error is now an alias; confirmed Python 3.14.3 macOS."
    - "re.RegexFlag.__name__ == 'RegexFlag' (len=9); the enum class for regex flags; confirmed Python 3.14.3 macOS."
    - "re.compile.__name__ == 'compile' (len=7); the function that compiles a pattern into a Pattern object; confirmed Python 3.14.3 macOS."
    - "re.match.__name__ == 'match' (len=5); matches at the beginning of the string; confirmed Python 3.14.3 macOS."
    - "re.search.__name__ == 'search' (len=6); searches anywhere in the string; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re module and type __name__ lengths
# re.__name__(2), Pattern(7), Match(5)
# ---------------------------------------------------------------------------

table re_extra201.module_and_type_name_lengths:
  description: "re module and type __name__ lengths: re.__name__(2), Pattern(7), Match(5)"
  kind: python_call_eq
  category: identity
  id_prefix: renamelens201

  columns: [id, function, args, expected, description]
  rows:
    - [re_name_len,      re.__name__.__len__,      [], 2, "re.__name__.__len__() == 2 — r(1)e(2); the module's own __name__ attribute; confirmed Python 3.14.3 macOS"]
    - [pattern_name_len, re.Pattern.__name__.__len__, [], 7, "re.Pattern.__name__.__len__() == 7 — P(1)a(2)t(3)t(4)e(5)r(6)n(7); the compiled regex pattern class; confirmed Python 3.14.3 macOS"]
    - [match_name_len,   re.Match.__name__.__len__,   [], 5, "re.Match.__name__.__len__() == 5 — M(1)a(2)t(3)c(4)h(5); the match object class; confirmed Python 3.14.3 macOS"]
    - [re_name_eq,       re.__name__.__eq__,           ["re"], true, "re.__name__ == 're' (len=2); confirmed Python 3.14.3 macOS"]
    - [pattern_name_eq,  re.Pattern.__name__.__eq__,   ["Pattern"], true, "re.Pattern.__name__ == 'Pattern' (len=7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.error and re.RegexFlag __name__ lengths
# re.error.__name__(PatternError,12), RegexFlag(9)
# ---------------------------------------------------------------------------

table re_extra201.error_and_flag_name_lengths:
  description: "re.error and re.RegexFlag __name__ lengths: error.__name__='PatternError'(12), RegexFlag(9)"
  kind: python_call_eq
  category: identity
  id_prefix: renamelens201

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_len,     re.error.__name__.__len__,     [], 12, "re.error.__name__.__len__() == 12 — re.error was renamed PatternError in Python 3.13; re.error is now an alias; 'PatternError' has 12 chars; confirmed Python 3.14.3 macOS"]
    - [error_name_eq,      re.error.__name__.__eq__,      ["PatternError"], true, "re.error.__name__ == 'PatternError' (len=12); PatternError is the canonical name since Python 3.13; confirmed Python 3.14.3 macOS"]
    - [regexflag_name_len, re.RegexFlag.__name__.__len__, [], 9, "re.RegexFlag.__name__.__len__() == 9 — R(1)e(2)g(3)e(4)x(5)F(6)l(7)a(8)g(9); the enum class for regex flags; confirmed Python 3.14.3 macOS"]
    - [regexflag_name_eq,  re.RegexFlag.__name__.__eq__,  ["RegexFlag"], true, "re.RegexFlag.__name__ == 'RegexFlag' (len=9); confirmed Python 3.14.3 macOS"]
    - [match_name_eq,      re.Match.__name__.__eq__,      ["Match"], true, "re.Match.__name__ == 'Match' (len=5); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re function __name__ lengths
# compile(7), match(5), search(6)
# ---------------------------------------------------------------------------

table re_extra201.function_name_lengths:
  description: "re function __name__ lengths: compile(7), match(5), search(6)"
  kind: python_call_eq
  category: identity
  id_prefix: renamelens201

  columns: [id, function, args, expected, description]
  rows:
    - [compile_name_len, re.compile.__name__.__len__, [], 7, "re.compile.__name__.__len__() == 7 — c(1)o(2)m(3)p(4)i(5)l(6)e(7); compile() converts a pattern string into a Pattern object; confirmed Python 3.14.3 macOS"]
    - [match_fn_name_len, re.match.__name__.__len__,   [], 5, "re.match.__name__.__len__() == 5 — m(1)a(2)t(3)c(4)h(5); match() tries to match at the beginning of the string; confirmed Python 3.14.3 macOS"]
    - [search_name_len,  re.search.__name__.__len__,  [], 6, "re.search.__name__.__len__() == 6 — s(1)e(2)a(3)r(4)c(5)h(6); search() scans through the string for the first match; confirmed Python 3.14.3 macOS"]
    - [compile_name_eq,  re.compile.__name__.__eq__,  ["compile"], true, "re.compile.__name__ == 'compile' (len=7); confirmed Python 3.14.3 macOS"]
    - [search_name_eq,   re.search.__name__.__eq__,   ["search"], true, "re.search.__name__ == 'search' (len=6); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra201.re_name_len:
  description: "re.__name__.__len__() == 2 — 're' has 2 characters: r(1)e(2); the module's own __name__ is the shortest of all the re names covered; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.__name__.__len__
  args: []
  expected: 2

invariant re_extra201.pattern_name_len:
  description: "re.Pattern.__name__.__len__() == 7 — 'Pattern' has 7 characters: P(1)a(2)t(3)t(4)e(5)r(6)n(7); Pattern is the compiled regex class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Pattern.__name__.__len__
  args: []
  expected: 7

invariant re_extra201.match_name_len:
  description: "re.Match.__name__.__len__() == 5 — 'Match' has 5 characters: M(1)a(2)t(3)c(4)h(5); Match is the object returned by re.match() and re.search(); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.Match.__name__.__len__
  args: []
  expected: 5

invariant re_extra201.error_name_len:
  description: "re.error.__name__.__len__() == 12 — re.error was renamed to PatternError in Python 3.13; re.error is an alias; 'PatternError' has 12 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.error.__name__.__len__
  args: []
  expected: 12

invariant re_extra201.regexflag_name_len:
  description: "re.RegexFlag.__name__.__len__() == 9 — 'RegexFlag' has 9 characters: R(1)e(2)g(3)e(4)x(5)F(6)l(7)a(8)g(9); RegexFlag is the enum class for all re flag constants; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.RegexFlag.__name__.__len__
  args: []
  expected: 9

invariant re_extra201.compile_name_len:
  description: "re.compile.__name__.__len__() == 7 — 'compile' has 7 characters; re.compile() compiles a pattern string into a Pattern object for reuse; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__name__.__len__
  args: []
  expected: 7

invariant re_extra201.match_fn_name_len:
  description: "re.match.__name__.__len__() == 5 — 'match' has 5 characters: m(1)a(2)t(3)c(4)h(5); re.match() matches at the beginning of the string only; tied in length with re.Match.__name__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.match.__name__.__len__
  args: []
  expected: 5

invariant re_extra201.search_name_len:
  description: "re.search.__name__.__len__() == 6 — 'search' has 6 characters: s(1)e(2)a(3)r(4)c(5)h(6); re.search() scans through the string for the first location where the pattern produces a match; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.search.__name__.__len__
  args: []
  expected: 6

