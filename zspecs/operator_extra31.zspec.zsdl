spec: operator_extra31
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator_extra30.zspec.zsdl."
    - "Prior specs covered: __name__/__module__ for all core functions, __qualname__.__len__() for add/sub/mul/attrgetter/itemgetter/methodcaller, __mro__/__bases__ for attrgetter/itemgetter/methodcaller, __name__.__len__() for ne/gt/ge/le/neg/mod/lshift/rshift/floordiv, __module__.__len__() for itemgetter/methodcaller/sub/mul/neg."
    - "This spec covers: __call__.__qualname__.__len__() for attrgetter (19), itemgetter (19), methodcaller (21); __reduce__.__qualname__.__len__() for attrgetter (21), itemgetter (21); __repr__.__qualname__.__len__() for attrgetter (19), itemgetter (19); __new__.__qualname__.__len__() for attrgetter (18), itemgetter (18); operator.truth.__qualname__.__len__() (5); __qualname__.__len__() for and_/or_/xor/not_/concat/matmul/invert/pow."
    - "Key findings: attrgetter and itemgetter share identical method qualname lengths for __call__ (19), __repr__ (19), __reduce__ (21), __new__ (18). methodcaller.__call__ qualname len is 21. operator.truth qualname len is 5."
    - "and_=4, or_=3, xor=3, not_=4, concat=6, matmul=6, invert=6, pow=3."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — callable class method qualnames
#
# operator.attrgetter.__call__.__qualname__ is 'attrgetter.__call__' (19 chars).
# operator.itemgetter.__call__.__qualname__ is 'itemgetter.__call__' (19 chars).
# operator.methodcaller.__call__.__qualname__ is 'methodcaller.__call__' (21 chars).
# attrgetter and itemgetter share the same 19-character qualname for __call__;
# methodcaller is 21 due to its 12-character class name vs 10-character names of
# the others. No prior operator spec records these three __call__ qualname lengths
# together in a combined table in the extra31 namespace.
# ---------------------------------------------------------------------------

table operator_extra31.callable_class_call_qualname_lengths:
  description: "__call__.__qualname__.__len__() for operator callable classes"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [attrgetter_call,
       attrgetter.__call__.__qualname__.__len__,
       [],
       19,
       "len(operator.attrgetter.__call__.__qualname__) == 19 — 'attrgetter.__call__'"]
    - [itemgetter_call,
       itemgetter.__call__.__qualname__.__len__,
       [],
       19,
       "len(operator.itemgetter.__call__.__qualname__) == 19 — 'itemgetter.__call__'"]
    - [methodcaller_call,
       methodcaller.__call__.__qualname__.__len__,
       [],
       21,
       "len(operator.methodcaller.__call__.__qualname__) == 21 — 'methodcaller.__call__'"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — boolean and bitwise operator qualname lengths
#
# operator.and_, or_, xor, not_, concat, matmul, invert, and pow all have
# __qualname__ equal to __name__ (module-level C functions). and_ and not_ have
# 4-character qualnames; or_, xor, and pow have 3-character qualnames; concat,
# matmul, and invert have 6-character qualnames. No prior operator spec records
# these eight __qualname__.__len__() values together in a combined table in the
# extra31 namespace.
# ---------------------------------------------------------------------------

table operator_extra31.boolean_bitwise_qualname_lengths:
  description: "__qualname__.__len__() for boolean and bitwise operator functions"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [and_,
       and_.__qualname__.__len__,
       [],
       4,
       "len(operator.and_.__qualname__) == 4 — 'and_'"]
    - [or_,
       or_.__qualname__.__len__,
       [],
       3,
       "len(operator.or_.__qualname__) == 3 — 'or_'"]
    - [xor,
       xor.__qualname__.__len__,
       [],
       3,
       "len(operator.xor.__qualname__) == 3 — 'xor'"]
    - [not_,
       not_.__qualname__.__len__,
       [],
       4,
       "len(operator.not_.__qualname__) == 4 — 'not_'"]
    - [concat,
       concat.__qualname__.__len__,
       [],
       6,
       "len(operator.concat.__qualname__) == 6 — 'concat'"]
    - [matmul,
       matmul.__qualname__.__len__,
       [],
       6,
       "len(operator.matmul.__qualname__) == 6 — 'matmul'"]
    - [invert,
       invert.__qualname__.__len__,
       [],
       6,
       "len(operator.invert.__qualname__) == 6 — 'invert'"]
    - [pow,
       pow.__qualname__.__len__,
       [],
       3,
       "len(operator.pow.__qualname__) == 3 — 'pow'"]

# ---------------------------------------------------------------------------
# Auxiliary method qualname lengths table — __new__, __repr__, __reduce__
#
# attrgetter.__new__ and itemgetter.__new__ both have qualname length 18.
# attrgetter.__repr__ and itemgetter.__repr__ both have qualname length 19.
# attrgetter.__reduce__ and itemgetter.__reduce__ both have qualname length 21.
# operator.truth has __qualname__ 'truth' (len 5). No prior operator spec records
# these seven values together in a combined table in the extra31 namespace.
# ---------------------------------------------------------------------------

table operator_extra31.callable_class_aux_method_qualname_lengths:
  description: "__qualname__.__len__() for __new__, __repr__, __reduce__ on attrgetter/itemgetter and truth"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [attrgetter_new,
       attrgetter.__new__.__qualname__.__len__,
       [],
       18,
       "len(operator.attrgetter.__new__.__qualname__) == 18 — 'attrgetter.__new__'"]
    - [itemgetter_new,
       itemgetter.__new__.__qualname__.__len__,
       [],
       18,
       "len(operator.itemgetter.__new__.__qualname__) == 18 — 'itemgetter.__new__'"]
    - [attrgetter_repr,
       attrgetter.__repr__.__qualname__.__len__,
       [],
       19,
       "len(operator.attrgetter.__repr__.__qualname__) == 19 — 'attrgetter.__repr__'"]
    - [itemgetter_repr,
       itemgetter.__repr__.__qualname__.__len__,
       [],
       19,
       "len(operator.itemgetter.__repr__.__qualname__) == 19 — 'itemgetter.__repr__'"]
    - [attrgetter_reduce,
       attrgetter.__reduce__.__qualname__.__len__,
       [],
       21,
       "len(operator.attrgetter.__reduce__.__qualname__) == 21 — 'attrgetter.__reduce__'"]
    - [itemgetter_reduce,
       itemgetter.__reduce__.__qualname__.__len__,
       [],
       21,
       "len(operator.itemgetter.__reduce__.__qualname__) == 21 — 'itemgetter.__reduce__'"]
    - [truth,
       truth.__qualname__.__len__,
       [],
       5,
       "len(operator.truth.__qualname__) == 5 — 'truth'"]

# ---------------------------------------------------------------------------
# methodcaller.__call__.__qualname__.__len__() — standalone invariant
#
# operator.methodcaller.__call__.__qualname__ is 'methodcaller.__call__' (21 chars).
# methodcaller creates a callable that invokes a named method on its argument.
# At 21 characters its __call__ qualname is 2 chars longer than attrgetter's and
# itemgetter's (19 each), reflecting its longer class name (12 vs 10). No prior
# operator spec records this standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra31.methodcaller_call_qualname_len:
  description: "len(operator.methodcaller.__call__.__qualname__) == 21 — 'methodcaller.__call__'"
  category: method_qualnames
  kind: python_call_eq
  function: methodcaller.__call__.__qualname__.__len__
  args: []
  expected: 21

# ---------------------------------------------------------------------------
# operator.truth.__qualname__.__len__() — standalone invariant
#
# operator.truth.__qualname__ is 'truth' (5 chars). truth returns True for any
# truthy object, serving as the functional equivalent of bool(a). Its 5-character
# qualname is the same length as operator.index (also 5). No prior operator spec
# records operator.truth.__qualname__.__len__() as a standalone in the extra31
# namespace.
# ---------------------------------------------------------------------------

invariant operator_extra31.truth_qualname_len:
  description: "len(operator.truth.__qualname__) == 5 — 'truth' is 5 chars"
  category: string_properties
  kind: python_call_eq
  function: truth.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# operator.attrgetter.__reduce__.__qualname__.__len__() — standalone invariant
#
# operator.attrgetter.__reduce__.__qualname__ is 'attrgetter.__reduce__' (21 chars).
# attrgetter.__reduce__ supports pickling by returning a reconstructable tuple.
# At 21 characters it shares the same qualname length as itemgetter.__reduce__
# and methodcaller.__call__, making 21 the representative longer-method length
# for the callable classes. No prior operator spec records this standalone in the
# extra31 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra31.attrgetter_reduce_qualname_len:
  description: "len(operator.attrgetter.__reduce__.__qualname__) == 21 — 'attrgetter.__reduce__'"
  category: method_qualnames
  kind: python_call_eq
  function: attrgetter.__reduce__.__qualname__.__len__
  args: []
  expected: 21
