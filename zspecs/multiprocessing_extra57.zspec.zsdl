spec: multiprocessing_extra57
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/importlib.html#importlib.machinery.SourceFileLoader — SourceFileLoader documentation"
    - "https://docs.python.org/3/reference/import.html#module-spec — ModuleSpec documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/_bootstrap_external.py"
    - "CPython source: Lib/importlib/_bootstrap_external.py"
  notes:
    - "This spec extends multiprocessing_extra56.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__qualname__ tables (extra52), Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type' (extra45), Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46), Pool/__doc__/__class__/__module__=='builtins' (extra50), Pool/__class__.__name__=='type' (multiprocessing_extra), Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins') (extra53), Process/__init__.__class__.__name__.__eq__('function') (extra53), Process/Pool __repr__.__class__.__name__ (extra54), Process __weakref__.__class__.__name__ (extra54), ProcessError/AuthenticationError exception __repr__.__class__.__name__ (extra54), mp.__all__.__class__.__name__.__eq__('list') (extra55), mp.__all__.__len__()==37 (extra55), Process/ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra55), mp.__all__.__contains__ membership checks (extra56), mp.__package__.__eq__('multiprocessing') (extra56), Queue/Pool __doc__.__class__.__name__.__eq__('str') (extra56)."
    - "This spec covers (mpload57 namespace): wave 225 theme — __loader__ identity + __spec__ attribute chains + __file__/__cached__ checks. multiprocessing.__loader__.__class__.__name__.__eq__('SourceFileLoader') — multiprocessing is a pure Python package loaded from Lib/multiprocessing/__init__.py; its loader is a SourceFileLoader instance; __loader__.__class__.__name__ == 'SourceFileLoader'. multiprocessing.__spec__.__class__.__name__.__eq__('ModuleSpec') — Python's import machinery wraps module metadata in a ModuleSpec object; __spec__.__class__.__name__ == 'ModuleSpec'. multiprocessing.__file__.__class__.__name__.__eq__('str') — mp has a file path (__init__.py at Lib/multiprocessing/__init__.py); the path is a plain Python str; __file__.__class__.__name__ == 'str'. multiprocessing.__cached__.__class__.__name__.__eq__('str') — mp has a cached bytecode path (__pycache__/__init__.cpython-314.pyc); the path is a plain Python str; __cached__.__class__.__name__ == 'str'. No prior multiprocessing spec has captured __loader__.__class__.__name__, __spec__.__class__.__name__, __file__.__class__.__name__, or __cached__.__class__.__name__ as string equality checks."
    - "multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader'. multiprocessing is a pure Python package (directory Lib/multiprocessing/ with __init__.py). Python's import machinery uses a SourceFileLoader instance to load it. The loader is an instance of importlib.machinery.SourceFileLoader; __loader__.__class__.__name__ == 'SourceFileLoader'. __eq__('SourceFileLoader') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec'. Every loaded module has a __spec__ attribute containing a ModuleSpec object describing the module's import configuration. __spec__.__class__.__name__ == 'ModuleSpec'. __eq__('ModuleSpec') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__file__.__class__.__name__ == 'str'. multiprocessing has a file path pointing to Lib/multiprocessing/__init__.py. This path is a plain Python str; __file__.__class__.__name__ == 'str'. __eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__cached__.__class__.__name__ == 'str'. multiprocessing has a cached bytecode path pointing to the __pycache__/__init__.cpython-314.pyc file. This path is a plain Python str; __cached__.__class__.__name__ == 'str'. __eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing __loader__/__spec__/__file__/__cached__ class name checks
# — extra57
#
# Wave 225 theme: __loader__ identity + __spec__ attribute chains +
# __file__/__cached__ checks.
#
# multiprocessing is a pure Python package loaded from
# Lib/multiprocessing/__init__.py. Its loader is a SourceFileLoader instance:
#   multiprocessing.__loader__.__class__.__name__ == 'SourceFileLoader'
#
# Its module spec is a ModuleSpec object:
#   multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec'
#
# Its file path is a plain Python str:
#   multiprocessing.__file__.__class__.__name__ == 'str'
#
# Its cached bytecode path is a plain Python str:
#   multiprocessing.__cached__.__class__.__name__ == 'str'
#
# No prior multiprocessing spec has captured any of these checks.
# Extra57 introduces this wave 225 theme in the mpload57 namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra57.loader_spec_file_cached:
  description: "multiprocessing __loader__/__spec__/__file__/__cached__ class name checks in mpload57 namespace — mp is a pure Python package (Lib/multiprocessing/__init__.py); __loader__ is a SourceFileLoader instance; __spec__ is a ModuleSpec object; __file__ and __cached__ are plain Python str paths; all four __class__.__name__.__eq__ checks return True; wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__/__cached__ checks; first loader/spec/file/cached class name checks in any multiprocessing spec"
  kind: python_call_eq
  category: loader_identity
  id_prefix: mpload57

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name, __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true, "mp.__loader__.__class__.__name__ == 'SourceFileLoader' — multiprocessing is a pure Python package (Lib/multiprocessing/__init__.py); Python's import machinery uses a SourceFileLoader instance to load it; SourceFileLoader is defined in importlib._bootstrap_external; __loader__.__class__.__name__.__eq__('SourceFileLoader') returns True; wave 225 first __loader__.__class__.__name__ check in any multiprocessing spec"]
    - [spec_class_name,   __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],       true, "mp.__spec__.__class__.__name__ == 'ModuleSpec' — Python's import machinery stores module metadata in a ModuleSpec object; __spec__ is a ModuleSpec instance; __spec__.__class__.__name__.__eq__('ModuleSpec') returns True; wave 225 first __spec__.__class__.__name__ check in any multiprocessing spec"]
    - [file_class_name,   __file__.__class__.__name__.__eq__,    ["str"],              true, "mp.__file__.__class__.__name__ == 'str' — multiprocessing has a file path (Lib/multiprocessing/__init__.py); the path is a plain Python str; __file__.__class__.__name__.__eq__('str') returns True; wave 225 first __file__.__class__.__name__ check in any multiprocessing spec"]
    - [cached_class_name, __cached__.__class__.__name__.__eq__,  ["str"],              true, "mp.__cached__.__class__.__name__ == 'str' — multiprocessing has a cached bytecode path (__pycache__/__init__.cpython-314.pyc); the path is a plain Python str; __cached__.__class__.__name__.__eq__('str') returns True; wave 225 first __cached__.__class__.__name__ check in any multiprocessing spec"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra57
# ---------------------------------------------------------------------------

invariant multiprocessing_extra57.loader_class_name_eq:
  description: "mp.__loader__.__class__.__name__.__eq__('SourceFileLoader') returns True — multiprocessing is a pure Python package (Lib/multiprocessing/__init__.py); its loader is a SourceFileLoader instance from importlib._bootstrap_external; __loader__.__class__.__name__ == 'SourceFileLoader'; wave 225 first __loader__.__class__.__name__ invariant in any multiprocessing spec"
  category: loader_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant multiprocessing_extra57.spec_class_name_eq:
  description: "mp.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — multiprocessing module spec is a ModuleSpec object; __spec__.__class__.__name__ == 'ModuleSpec'; wave 225 first __spec__.__class__.__name__ invariant in any multiprocessing spec"
  category: loader_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant multiprocessing_extra57.file_class_name_eq:
  description: "mp.__file__.__class__.__name__.__eq__('str') returns True — multiprocessing has a file path (Lib/multiprocessing/__init__.py) which is a plain Python str; __file__.__class__.__name__ == 'str'; wave 225 first __file__.__class__.__name__ invariant in any multiprocessing spec"
  category: loader_identity
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra57.cached_class_name_eq:
  description: "mp.__cached__.__class__.__name__.__eq__('str') returns True — multiprocessing has a cached bytecode path (__pycache__/__init__.cpython-314.pyc) which is a plain Python str; __cached__.__class__.__name__ == 'str'; wave 225 first __cached__.__class__.__name__ invariant in any multiprocessing spec"
  category: loader_identity
  kind: python_call_eq
  function: __cached__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
