spec: agent_base
version: ">=4.0.0"
backend: node(agent-base)

docs: https://github.com/TooTallNate/proxy-agents#readme

provenance:
  derived_from:
    - "agent-base README — https://github.com/TooTallNate/proxy-agents#readme"
    - "Node.js http.Agent docs — https://nodejs.org/api/http.html#class-httpagent"
    - "Test vectors verified with agent-base via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "agent-base source"
  notes:
    - "Base class for HTTP/HTTPS agents that need an async createConnection — used by http-proxy-agent / https-proxy-agent / socks-proxy-agent."
    - "Install: npm install agent-base"
    - "v4 CJS; named export Agent class extending http.Agent."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws if subclass forgets to override callback() / connect()."
  stderr: "null"
  stickiness: "Each Agent instance carries its own connection-pool state."
  codes: {}

invariant agent_base.has_Agent:
  description: "Agent class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Agent.constructor.name"}
  expected: "Function"

invariant agent_base.Agent_name:
  description: "Agent.name is 'Agent'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Agent.name"}
  expected: "Agent"

invariant agent_base.Agent_proto_isSecureEndpoint:
  description: "Agent.prototype.isSecureEndpoint defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Agent.prototype.isSecureEndpoint.constructor.name"}
  expected: "Function"

invariant agent_base.Agent_proto_createSocket:
  description: "Agent.prototype.createSocket defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Agent.prototype.createSocket.constructor.name"}
  expected: "Function"

invariant agent_base.Agent_proto_createConnection:
  description: "Agent.prototype.createConnection defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Agent.prototype.createConnection.constructor.name"}
  expected: "Function"

invariant agent_base.Agent_proto_getName:
  description: "Agent.prototype.getName defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Agent.prototype.getName.constructor.name"}
  expected: "Function"
