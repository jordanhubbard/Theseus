spec: nturl2path_extra
version: ">=3.9"
backend: python_module(nturl2path)

docs: https://docs.python.org/3/library/nturl2path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/nturl2path.html — Python nturl2path module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/nturl2path.py"
  notes:
    - "Extends nturl2path.zspec.zsdl with function name, qualname, module, and type invariants."
    - "nturl2path.url2pathname.__name__ == 'url2pathname' — function name as a string."
    - "nturl2path.url2pathname.__qualname__ == 'url2pathname' — qualname equals name (top-level function)."
    - "nturl2path.url2pathname.__module__ == 'nturl2path' — function is defined in the nturl2path module."
    - "nturl2path.pathname2url.__name__ == 'pathname2url' — function name as a string."
    - "nturl2path.pathname2url.__qualname__ == 'pathname2url' — qualname equals name (top-level function)."
    - "nturl2path.pathname2url.__module__ == 'nturl2path' — function is defined in the nturl2path module."
    - "Both functions have __class__.__name__ == 'function' — they are plain Python function objects."
    - "nturl2path is deprecated since Python 3.12; replacement is urllib.request.url2pathname."
    - "All expected values verified by running Python 3.12 nturl2path module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# url2pathname — name, qualname, module, and type
# ---------------------------------------------------------------------------

invariant nturl2path_extra.url2pathname.name:
  description: "nturl2path.url2pathname.__name__ == 'url2pathname'"
  category: functions
  kind: python_call_eq
  function: url2pathname.__name__.__eq__
  args: ["url2pathname"]
  expected: true

invariant nturl2path_extra.url2pathname.qualname:
  description: "nturl2path.url2pathname.__qualname__ == 'url2pathname'"
  category: functions
  kind: python_call_eq
  function: url2pathname.__qualname__.__eq__
  args: ["url2pathname"]
  expected: true

invariant nturl2path_extra.url2pathname.module:
  description: "nturl2path.url2pathname.__module__ == 'nturl2path'"
  category: functions
  kind: python_call_eq
  function: url2pathname.__module__.__eq__
  args: ["nturl2path"]
  expected: true

invariant nturl2path_extra.url2pathname.is_function:
  description: "nturl2path.url2pathname.__class__.__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: url2pathname.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# pathname2url — name, qualname, module, and type
# ---------------------------------------------------------------------------

invariant nturl2path_extra.pathname2url.name:
  description: "nturl2path.pathname2url.__name__ == 'pathname2url'"
  category: functions
  kind: python_call_eq
  function: pathname2url.__name__.__eq__
  args: ["pathname2url"]
  expected: true

invariant nturl2path_extra.pathname2url.qualname:
  description: "nturl2path.pathname2url.__qualname__ == 'pathname2url'"
  category: functions
  kind: python_call_eq
  function: pathname2url.__qualname__.__eq__
  args: ["pathname2url"]
  expected: true

invariant nturl2path_extra.pathname2url.module:
  description: "nturl2path.pathname2url.__module__ == 'nturl2path'"
  category: functions
  kind: python_call_eq
  function: pathname2url.__module__.__eq__
  args: ["nturl2path"]
  expected: true

invariant nturl2path_extra.pathname2url.is_function:
  description: "nturl2path.pathname2url.__class__.__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: pathname2url.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — both functions live in the same module
# ---------------------------------------------------------------------------

invariant nturl2path_extra.module_affiliation.url2pathname_eq_pathname2url:
  description: "url2pathname.__module__ == pathname2url.__module__ — both belong to nturl2path"
  category: module
  kind: python_call_eq
  function: url2pathname.__module__.__eq__
  args: ["nturl2path"]
  expected: true

# ---------------------------------------------------------------------------
# Qualname type checks — __qualname__ is a str for both functions
# ---------------------------------------------------------------------------

table nturl2path_extra.qualname_type_checks:
  kind: python_call_eq
  category: types
  id_prefix: qtype

  columns: [id, function, args, expected]
  rows:
    - [url2pathname_qualname_is_str,  url2pathname.__qualname__.__class__.__name__.__eq__,  ["str"],  true]
    - [pathname2url_qualname_is_str,  pathname2url.__qualname__.__class__.__name__.__eq__,  ["str"],  true]
