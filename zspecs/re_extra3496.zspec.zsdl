spec: re3496
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 680 (io3496): __aenter__, __aexit__, __await__ dict-presence checks for io/pathlib/re/decimal types."
    - "All values False — these types are synchronous and do not implement the async context manager or awaitable protocols."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __aenter__/__aexit__/__await__ dict-presence (async context manager / awaitable protocol)."
    - "re.Pattern, re.Match, and re.RegexFlag do not define __aenter__ or __aexit__ in their own __dict__s: re types are not async context managers."
    - "re.Pattern, re.Match, and re.RegexFlag do not define __await__ in their own __dict__s: re types are not awaitable objects."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# No re class defines __aenter__ in its own __dict__; all false.
# re.Pattern, re.Match, and re.RegexFlag are not async context managers;
# __aenter__ is absent from all re class __dict__s.
# ---------------------------------------------------------------------------

table re3496.aenter:
  description: "re types __aenter__ dict-presence checks; wave 680"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3496

  columns: [id, function, args, expected]
  rows:
    - ["re3496001", operator.contains, [re.Pattern.__dict__,   "__aenter__"], false]
    - ["re3496002", operator.contains, [re.Match.__dict__,     "__aenter__"], false]
    - ["re3496003", operator.contains, [re.RegexFlag.__dict__, "__aenter__"], false]

