spec: tabulate_rust
version: ">=3.9"
backend: rust_module(tabulate_rust)

docs: https://github.com/astanin/python-tabulate

provenance:
  derived_from:
    - "https://github.com/astanin/python-tabulate — tabulate library"
  notes:
    - "tabulate formats tabular data as text tables."
    - "tabulate([[1,2],[3,4]], headers=['a','b']) contains 'a'."
    - "tabulate.tabulate_formats is a list."
    - "tabulate.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant tabulate_rust.has_tabulate:
  description: "tabulate module has tabulate function"
  category: presence
  kind: python_call_eq
  function: tabulate_has_tabulate
  args: []
  expected: true

invariant tabulate_rust.has_formats:
  description: "tabulate.tabulate_formats is non-empty list"
  category: presence
  kind: python_call_eq
  function: tabulate_formats_nonempty
  args: []
  expected: true

invariant tabulate_rust.version_nonempty:
  description: "tabulate.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: tabulate_version_nonempty
  args: []
  expected: true

