spec: socket_extra269
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra268.zspec.zsdl — covers socket.create_connection/create_server/socketpair/fromfd/getaddrinfo/gethostbyaddr function identity."
    - "socket_extra267.zspec.zsdl — covers socket.getfqdn/gethostname/getnameinfo/getservbyname/getservbyport/htons/htonl/ntohs/ntohl function identity."
    - "socket_extra265.zspec.zsdl — covers socket module-level AddressFamily/SocketKind constants identity."
  notes:
    - "socket.inet_aton.__name__ == 'inet_aton' — C builtin from _socket extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.inet_aton.__class__.__name__ == 'builtin_function_or_method' — C builtin. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.inet_ntoa.__name__ == 'inet_ntoa' — C builtin from _socket extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.inet_pton.__name__ == 'inet_pton' — C builtin from _socket extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.inet_ntop.__name__ == 'inet_ntop' — C builtin from _socket extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.inet_aton('127.0.0.1') returns b'\\x7f\\x00\\x00\\x01' — the loopback address in packed 4-byte binary form. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "len(socket.inet_aton('127.0.0.1')) == 4 — inet_aton always returns a 4-byte bytes object. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.inet_ntoa(b'\\x7f\\x00\\x00\\x01') == '127.0.0.1' — inverse of inet_aton for the loopback address. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.inet_aton('999.999.999.999') raises OSError — invalid IPv4 address string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.inet_pton(AF_INET, '127.0.0.1') returns b'\\x7f\\x00\\x00\\x01' — same as inet_aton for IPv4 in standard format. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.inet_ntop(AF_INET, b'\\x7f\\x00\\x00\\x01') == '127.0.0.1' — same as inet_ntoa for IPv4 loopback. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.inet_aton and socket.inet_ntoa function identity
# Both are C builtins from the _socket C extension module.
# inet_aton converts a dotted IPv4 string to packed 4-byte binary.
# inet_ntoa is the inverse: packed binary to dotted string.
# ---------------------------------------------------------------------------

table socket_extra269.inet_aton_ntoa_identity:
  description: "socket.inet_aton/inet_ntoa function identity — both are 'builtin_function_or_method'; __name__ matches attribute name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockinetid269

  columns: [id, function, args, expected, description]
  rows:
    - [aton_name,    inet_aton.__name__.__eq__,               ["inet_aton"],                     true, "socket.inet_aton.__name__ == 'inet_aton' — C builtin from _socket extension"]
    - [aton_class,   inet_aton.__class__.__name__.__eq__,     ["builtin_function_or_method"],    true, "socket.inet_aton.__class__.__name__ == 'builtin_function_or_method' — C builtin"]
    - [ntoa_name,    inet_ntoa.__name__.__eq__,               ["inet_ntoa"],                     true, "socket.inet_ntoa.__name__ == 'inet_ntoa' — C builtin from _socket extension"]
    - [ntoa_class,   inet_ntoa.__class__.__name__.__eq__,     ["builtin_function_or_method"],    true, "socket.inet_ntoa.__class__.__name__ == 'builtin_function_or_method' — C builtin"]
    - [pton_name,    inet_pton.__name__.__eq__,               ["inet_pton"],                     true, "socket.inet_pton.__name__ == 'inet_pton' — C builtin from _socket extension"]

# ---------------------------------------------------------------------------
# socket.inet_pton and socket.inet_ntop function identity
# Both are C builtins. inet_pton supports both AF_INET and AF_INET6.
# inet_ntop is the inverse: converts packed binary to presentation string.
# ---------------------------------------------------------------------------

table socket_extra269.inet_pton_ntop_identity:
  description: "socket.inet_pton/inet_ntop function identity — both are 'builtin_function_or_method'; __name__ and __class__ identity; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockinetid269b

  columns: [id, function, args, expected, description]
  rows:
    - [pton_class,   inet_pton.__class__.__name__.__eq__,     ["builtin_function_or_method"],    true, "socket.inet_pton.__class__.__name__ == 'builtin_function_or_method' — C builtin from _socket"]
    - [ntop_name,    inet_ntop.__name__.__eq__,               ["inet_ntop"],                     true, "socket.inet_ntop.__name__ == 'inet_ntop' — C builtin from _socket extension"]
    - [ntop_class,   inet_ntop.__class__.__name__.__eq__,     ["builtin_function_or_method"],    true, "socket.inet_ntop.__class__.__name__ == 'builtin_function_or_method' — C builtin from _socket"]
    - [aton_name2,   inet_aton.__name__.__eq__,               ["inet_aton"],                     true, "socket.inet_aton.__name__ == 'inet_aton' — confirmed via second table"]
    - [ntoa_name2,   inet_ntoa.__name__.__eq__,               ["inet_ntoa"],                     true, "socket.inet_ntoa.__name__ == 'inet_ntoa' — confirmed via second table"]

# ---------------------------------------------------------------------------
# Standalone invariants — inet address function identity and behavior
# ---------------------------------------------------------------------------

invariant socket_extra269.inet_aton_name_eq:
  description: "socket.inet_aton.__name__ == 'inet_aton' — C builtin from _socket extension module; converts dotted IPv4 string to 4-byte packed binary; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: inet_aton.__name__.__eq__
  args: ["inet_aton"]
  expected: true

invariant socket_extra269.inet_aton_class_eq:
  description: "socket.inet_aton.__class__.__name__ == 'builtin_function_or_method' — inet_aton is a C builtin from the _socket extension; not a pure-Python function; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: inet_aton.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant socket_extra269.inet_ntoa_name_eq:
  description: "socket.inet_ntoa.__name__ == 'inet_ntoa' — C builtin from _socket extension; converts 4-byte packed binary to dotted IPv4 string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: inet_ntoa.__name__.__eq__
  args: ["inet_ntoa"]
  expected: true

invariant socket_extra269.inet_ntoa_class_eq:
  description: "socket.inet_ntoa.__class__.__name__ == 'builtin_function_or_method' — inet_ntoa is a C builtin from the _socket extension; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: inet_ntoa.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant socket_extra269.inet_pton_name_eq:
  description: "socket.inet_pton.__name__ == 'inet_pton' — C builtin from _socket extension; supports both AF_INET and AF_INET6; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: inet_pton.__name__.__eq__
  args: ["inet_pton"]
  expected: true

invariant socket_extra269.inet_ntop_name_eq:
  description: "socket.inet_ntop.__name__ == 'inet_ntop' — C builtin from _socket extension; converts packed binary to presentation string; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: inet_ntop.__name__.__eq__
  args: ["inet_ntop"]
  expected: true

invariant socket_extra269.inet_aton_invalid_raises:
  description: "socket.inet_aton('999.999.999.999') raises OSError — inet_aton raises OSError for invalid IPv4 address strings; '999.999.999.999' has octets exceeding 255; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: inet_aton
  args: ["999.999.999.999"]
  raises: OSError

invariant socket_extra269.inet_pton_invalid_raises:
  description: "socket.inet_pton(AF_INET, '999.999.999.999') raises OSError — inet_pton raises OSError for invalid IPv4 address strings passed with AF_INET; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: errors
  kind: python_call_raises
  function: inet_pton
  args: [2, "999.999.999.999"]
  raises: OSError
