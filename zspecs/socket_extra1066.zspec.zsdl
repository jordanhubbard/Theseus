spec: socket_extra1066
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks AddressFamily and SocketKind enum module and class, socket.socket send/recv/shutdown method class names, and error hierarchy"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra1066.enum_module_and_class:
  description: "socket.AddressFamily and socket.SocketKind enum module and class identity"
  kind: python_call_eq
  category: enum_module_class
  id_prefix: sk1066em
  columns: [id, function, args, expected]
  rows:
    - [sk1066em001, socket.AddressFamily.__module__.__eq__,                   ["socket"],     true]
    - [sk1066em002, socket.SocketKind.__module__.__eq__,                      ["socket"],     true]
    - [sk1066em003, socket.AddressFamily.__class__.__name__.__eq__,           ["EnumType"],   true]
    - [sk1066em004, socket.SocketKind.__class__.__name__.__eq__,              ["EnumType"],   true]
    - [sk1066em005, socket.AddressFamily.__qualname__.__eq__,                 ["AddressFamily"], true]
    - [sk1066em006, socket.SocketKind.__qualname__.__eq__,                    ["SocketKind"],    true]
    - [sk1066em007, socket.AddressFamily.__module__.__class__.__name__.__eq__, ["str"],        true]
    - [sk1066em008, socket.SocketKind.__module__.__class__.__name__.__eq__,   ["str"],        true]

table socket_extra1066.socket_io_method_class_names:
  description: "socket.socket I/O and lifecycle method __class__.__name__ identity"
  kind: python_call_eq
  category: io_method_classnames
  id_prefix: sk1066ic
  columns: [id, function, args, expected]
  rows:
    - [sk1066ic001, socket.socket.send.__class__.__name__.__eq__,       ["slot_wrapper"],  true]
    - [sk1066ic002, socket.socket.recv.__class__.__name__.__eq__,       ["slot_wrapper"],  true]
    - [sk1066ic003, socket.socket.shutdown.__class__.__name__.__eq__,   ["slot_wrapper"],  true]
    - [sk1066ic004, socket.socket.bind.__class__.__name__.__eq__,       ["slot_wrapper"],  true]
    - [sk1066ic005, socket.socket.listen.__class__.__name__.__eq__,     ["slot_wrapper"],  true]
    - [sk1066ic006, socket.socket.accept.__class__.__name__.__eq__,     ["slot_wrapper"],  true]
    - [sk1066ic007, socket.socket.connect.__class__.__name__.__eq__,    ["slot_wrapper"],  true]
    - [sk1066ic008, socket.socket.close.__class__.__name__.__eq__,      ["slot_wrapper"],  true]
    - [sk1066ic009, socket.socket.send.__qualname__.__class__.__name__.__eq__,     ["str"], true]
    - [sk1066ic010, socket.socket.recv.__qualname__.__class__.__name__.__eq__,     ["str"], true]
    - [sk1066ic011, socket.socket.shutdown.__qualname__.__class__.__name__.__eq__, ["str"], true]

table socket_extra1066.socket_error_class_identity:
  description: "socket error class hierarchy and module identity"
  kind: python_call_eq
  category: error_class_identity
  id_prefix: sk1066er
  columns: [id, function, args, expected]
  rows:
    - [sk1066er001, socket.error.__module__.__eq__,                   ["builtins"],  true]
    - [sk1066er002, socket.timeout.__module__.__eq__,                 ["builtins"],  true]
    - [sk1066er003, socket.herror.__module__.__eq__,                  ["socket"],    true]
    - [sk1066er004, socket.gaierror.__module__.__eq__,                ["socket"],    true]
    - [sk1066er005, socket.herror.__class__.__name__.__eq__,          ["type"],      true]
    - [sk1066er006, socket.gaierror.__class__.__name__.__eq__,        ["type"],      true]
    - [sk1066er007, socket.herror.__qualname__.__eq__,                ["herror"],    true]
    - [sk1066er008, socket.gaierror.__qualname__.__eq__,              ["gaierror"],  true]
