    - "len(functools.singledispatch.__doc__) == 339 — the docstring has 339 characters. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__.__class__.__name__ == 'str' — the doc is a plain Python string. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_argcount == 1 — takes one positional-or-keyword argument: func. Verified with Python 3.14.3."
    - "len(functools.singledispatch.__code__.co_varnames) == 3 — co_varnames: func, weakref, wrapper. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__class__.__name__ == 'type' — singledispatchmethod is a Python class. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod' (len 20). Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__module__ == 'functools' (len 9). Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — directly inherits object. Verified with Python 3.14.3."
    - "len(functools.singledispatchmethod.__mro__) == 2 — MRO is [singledispatchmethod, object]. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__init__.__qualname__ == 'singledispatchmethod.__init__' (len 29). Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__init__.__code__.co_argcount == 2 (self, func). Verified with Python 3.14.3."
    - "functools.singledispatchmethod.register.__qualname__ == 'singledispatchmethod.register' (len 29). Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__get__.__qualname__ == 'singledispatchmethod.__get__' (len 28). Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__repr__.__qualname__ == 'singledispatchmethod.__repr__' (len 29). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
