spec: itertools_extra87
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra86

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra86.zspec.zsdl."
    - "This spec covers: itertools C-type MRO depth (__mro__.__len__()) and base class name (__bases__[0].__name__) — all itertools C types inherit directly from object (Wave 250)."
    - "itertools.chain.__mro__.__len__() == 2 — MRO is [chain, object]. Verified with Python 3.14.3."
    - "itertools.chain.__bases__[0].__name__ == 'object' — chain inherits directly from object. Verified with Python 3.14.3."
    - "itertools.product.__mro__.__len__() == 2 — MRO is [product, object]. Verified with Python 3.14.3."
    - "itertools.product.__bases__[0].__name__ == 'object' — product inherits directly from object. Verified with Python 3.14.3."
    - "itertools.combinations.__mro__.__len__() == 2 — MRO is [combinations, object]. Verified with Python 3.14.3."
    - "itertools.combinations.__bases__[0].__name__ == 'object' — combinations inherits directly from object. Verified with Python 3.14.3."
    - "itertools.permutations.__mro__.__len__() == 2 — MRO is [permutations, object]. Verified with Python 3.14.3."
    - "itertools.permutations.__bases__[0].__name__ == 'object' — permutations inherits directly from object. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__mro__.__len__() == 2 — MRO is [combinations_with_replacement, object]. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__bases__[0].__name__ == 'object' — combinations_with_replacement inherits directly from object. Verified with Python 3.14.3."
    - "itertools.accumulate.__mro__.__len__() == 2 — MRO is [accumulate, object]. Verified with Python 3.14.3."
    - "itertools.accumulate.__bases__[0].__name__ == 'object' — accumulate inherits directly from object. Verified with Python 3.14.3."
    - "itertools.groupby.__mro__.__len__() == 2 — MRO is [groupby, object]. Verified with Python 3.14.3."
    - "itertools.groupby.__bases__[0].__name__ == 'object' — groupby inherits directly from object. Verified with Python 3.14.3."
    - "itertools.islice.__mro__.__len__() == 2 — MRO is [islice, object]. Verified with Python 3.14.3."
    - "itertools.islice.__bases__[0].__name__ == 'object' — islice inherits directly from object. Verified with Python 3.14.3."
    - "itertools.starmap.__mro__.__len__() == 2 — MRO is [starmap, object]. Verified with Python 3.14.3."
    - "itertools.starmap.__bases__[0].__name__ == 'object' — starmap inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO depths: chain, product, combinations, permutations
# All itertools C types have a flat MRO: [type, object], so __mro__.__len__() == 2.
#
# Wave 250 theme: itertools C-type MRO depth.
#
# itertools.chain.__mro__.__len__()        == 2
# itertools.product.__mro__.__len__()      == 2
# itertools.combinations.__mro__.__len__() == 2
# itertools.permutations.__mro__.__len__() == 2
#
# No prior itertools spec checks __mro__.__len__() for these types via itertoolsmrod87. New to extra87.
# ---------------------------------------------------------------------------

table itertools_extra87.mro_depths_group1:
  description: "chain/product/combinations/permutations __mro__.__len__()==2; all inherit directly from object; wave 250; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolsmrod87

  columns: [id, function, args, expected, description]
  rows:
    - [chain_mro_len_eq_2,
       chain.__mro__.__len__,
       [],
       2,
       "itertools.chain.__mro__.__len__() == 2 — chain is a C extension type in Modules/itertoolsmodule.c; its MRO is [chain, object] (depth 2); all itertools C types inherit directly from object with no intermediate classes; tuple.__len__() returns 2; no prior itertools spec checks chain.__mro__.__len__ via itertoolsmrod87; new to extra87"]
    - [product_mro_len_eq_2,
       product.__mro__.__len__,
       [],
       2,
       "itertools.product.__mro__.__len__() == 2 — product is a C extension type in Modules/itertoolsmodule.c; its MRO is [product, object] (depth 2); all itertools C types inherit directly from object; tuple.__len__() returns 2; no prior itertools spec checks product.__mro__.__len__ via itertoolsmrod87; new to extra87"]
    - [combinations_mro_len_eq_2,
       combinations.__mro__.__len__,
       [],
       2,
       "itertools.combinations.__mro__.__len__() == 2 — combinations is a C extension type in Modules/itertoolsmodule.c; its MRO is [combinations, object] (depth 2); all itertools C types inherit directly from object; tuple.__len__() returns 2; no prior itertools spec checks combinations.__mro__.__len__ via itertoolsmrod87; new to extra87"]
    - [permutations_mro_len_eq_2,
       permutations.__mro__.__len__,
       [],
       2,
       "itertools.permutations.__mro__.__len__() == 2 — permutations is a C extension type in Modules/itertoolsmodule.c; its MRO is [permutations, object] (depth 2); all itertools C types inherit directly from object; tuple.__len__() returns 2; no prior itertools spec checks permutations.__mro__.__len__ via itertoolsmrod87; new to extra87"]

# ---------------------------------------------------------------------------
# Base class names: chain, product, combinations, permutations
# All have __bases__[0].__name__ == 'object'.
#
# Wave 250 theme: itertools C-type direct base class.
#
# itertools.chain.__bases__[0].__name__        == 'object'
# itertools.product.__bases__[0].__name__      == 'object'
# itertools.combinations.__bases__[0].__name__ == 'object'
# itertools.permutations.__bases__[0].__name__ == 'object'
#
# No prior itertools spec checks __bases__[0].__name__ via itertoolsmrod87. New to extra87.
# ---------------------------------------------------------------------------

table itertools_extra87.base_names_group1:
  description: "chain/product/combinations/permutations __bases__[0].__name__==object; direct base is object; wave 250; new to extra87"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolsmrod87

  columns: [id, function, args, expected, description]
  rows:
    - [chain_base_name_eq_object,
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__.__eq__('object') == True — chain is a C extension type that inherits directly from object; __bases__ is a tuple containing exactly one entry (object); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior itertools spec checks chain.__bases__[0].__name__ via itertoolsmrod87; new to extra87"]
    - [product_base_name_eq_object,
