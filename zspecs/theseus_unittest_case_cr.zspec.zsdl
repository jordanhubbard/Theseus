spec: theseus_unittest_case_cr
version: ">=3.0"
backend: python_cleanroom(theseus_unittest_case_cr)
blocks: unittest.case

docs: https://docs.python.org/3/library/unittest.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/unittest.html"
  not_derived_from:
    - "CPython source: Lib/unittest/case.py"
  notes:
    - "Clean-room unittest.case module. Do NOT import unittest.case."

error_model: python_exceptions

invariant theseus_unittest_case_cr.utcase2_testcase:
  description: "TestCase class can be subclassed"
  category: behavior
  kind: python_call_eq
  function: utcase2_testcase
  args: []
  expected: true

invariant theseus_unittest_case_cr.utcase2_assertions:
  description: "assertEqual, assertTrue, assertFalse work correctly"
  category: behavior
  kind: python_call_eq
  function: utcase2_assertions
  args: []
  expected: true

invariant theseus_unittest_case_cr.utcase2_skip:
  description: "skip and skipIf decorators exist"
  category: behavior
  kind: python_call_eq
  function: utcase2_skip
  args: []
  expected: true
