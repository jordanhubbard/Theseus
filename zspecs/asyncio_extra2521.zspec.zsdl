spec: asyncio_extra2521
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __bool__, __index__, __int__ dict-presence checks — truthiness, integer coercion, and indexing protocol."
    - "asyncio.Queue, asyncio.Task, asyncio.Future, asyncio.Lock, asyncio.Event define none of these dunder methods."
    - "__dict__.__contains__ returns False for __bool__, __index__, __int__ on all five classes."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue — bool/index/int dict-presence
# ---------------------------------------------------------------------------

table asyncio_extra2521.queue_bool_int_index:
  description: "asyncio.Queue.__dict__ contains no __bool__, __index__, or __int__; all __dict__.__contains__ calls return False; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2521

  columns: [id, function, args, expected]
  rows:
    - ["as2521001", asyncio.Queue.__dict__.__contains__, ["__bool__"], false]
    - ["as2521002", asyncio.Queue.__dict__.__contains__, ["__index__"], false]
    - ["as2521003", asyncio.Queue.__dict__.__contains__, ["__int__"], false]

