spec: threading_extra121
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra120.zspec.zsdl."
    - "This spec covers: threading module-level constants not yet covered — threading.__all__.__class__.__name__ ('list'), threading.__all__.__len__() (28), threading.__all__[0] ('get_ident', len 9), threading.__all__.index('TIMEOUT_MAX') (6), threading.__all__.__contains__('Barrier') (True), threading.active_count.__qualname__ ('active_count', len 12); wave 271."
    - "Prior specs covered: TIMEOUT_MAX.__class__.__name__ == 'float' (threading_extra), TIMEOUT_MAX value 9223372036.0 (threading_extra100). New here: __all__ list membership, element access, and active_count qualname."
    - "threading.__all__.__class__.__name__ == 'list'. Verified with Python 3.14.3."
    - "threading.__all__.__len__() == 28. Verified with Python 3.14.3."
    - "threading.__all__[0] == 'get_ident' (len 9). Verified with Python 3.14.3."
    - "threading.__all__.index('TIMEOUT_MAX') == 6. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('Barrier') == True. Verified with Python 3.14.3."
    - "threading.__all__.__contains__('TIMEOUT_MAX') == True. Verified with Python 3.14.3."
    - "threading.active_count.__qualname__ == 'active_count' (len 12). Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__class__.__name__.__len__() == 5 ('float' has 5 chars). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.__all__ type and length
#
# Wave 271 theme: threading.__all__ is a plain Python list (not a tuple like
# functools.__all__ or a frozenset). Its __class__.__name__ is 'list' (4 chars).
# The list has 28 entries — more than functools (15) and itertools (which has
# no __all__). This count (28) reflects threading's breadth: synchronisation
# primitives (Lock, RLock, Condition, Semaphore, BoundedSemaphore, Event,
# Barrier), thread control (Thread, Timer, local), utility functions
# (active_count, current_thread, main_thread, enumerate, get_ident, get_native_id,
# stack_size), error types (ThreadError, BrokenBarrierError), and hooks
# (excepthook, setprofile, settrace, gettrace, getprofile,
# setprofile_all_threads, settrace_all_threads, ExceptHookArgs).
# None of these __all__ attributes have been covered in prior threading specs.
#
# __all__.__class__.__name__ == 'list'
# __all__.__len__() == 28
#
# New to extra121.
# ---------------------------------------------------------------------------

table threading_extra121.all_type_and_len:
  description: "threading.__all__ type and length: __class__.__name__='list'(4), __len__()=28; 28 exported names covering sync primitives, thread control, utilities, hooks; prior specs covered TIMEOUT_MAX type/value; wave 271; new to extra121"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingalt121

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name_eq,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "threading.__all__.__class__.__name__.__eq__('list') == True — threading.__all__ is a plain Python list (not a tuple); str.__eq__('list') returns True; new to extra121"]
    - [all_class_name_len,
       "__all__.__class__.__name__.__len__",
       [],
       4,
       "threading.__all__.__class__.__name__.__len__() == 4 — 'list' has 4 chars: l-i-s-t; the type name for Python list objects; str.__len__() returns 4; new to extra121"]
    - [all_len,
       "__all__.__len__",
       [],
       28,
       "threading.__all__.__len__() == 28 — threading exports 28 names covering sync primitives, thread classes, utility functions, error types, and hooks; list.__len__() returns 28; new to extra121"]
    - [all_elem0_eq,
       "__all__.__getitem__",
       [0],
       "get_ident",
       "threading.__all__[0] == 'get_ident' — the first exported name; get_ident() returns the thread identifier of the current thread; list.__getitem__(0) returns 'get_ident'; new to extra121"]
    - [all_elem0_len,
       "__all__.__getitem__(0).__len__",
       [],
       9,
       "threading.__all__[0].__len__() == 9 — 'get_ident' has 9 chars: g-e-t-_-i-d-e-n-t; str.__len__() returns 9; new to extra121"]

# ---------------------------------------------------------------------------
# Table 2: threading.__all__ membership tests
#
# Wave 271 theme: threading.__all__ exports both TIMEOUT_MAX (a constant) and
# Barrier (a class), among others. __contains__('TIMEOUT_MAX') == True —
# TIMEOUT_MAX is exported at index 6. __contains__('Barrier') == True —
# Barrier is exported at index 13. The __all__ list explicitly includes the
# TIMEOUT_MAX float constant as an exported public API item, not just the
# class and function names. Prior threading specs covered TIMEOUT_MAX as a
# constant value and type; new here is confirming its presence in __all__.
#
# __all__.__contains__('TIMEOUT_MAX') == True
# __all__.__contains__('Barrier')     == True
# __all__.__contains__('Lock')        == True
#
# New to extra121.
# ---------------------------------------------------------------------------

table threading_extra121.all_membership:
  description: "threading.__all__ membership: 'TIMEOUT_MAX' in __all__=True (index 6), 'Barrier' in __all__=True (index 13), 'Lock' in __all__=True (index 8); prior specs covered TIMEOUT_MAX value/type; wave 271; new to extra121"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingalmem121

  columns: [id, function, args, expected, description]
  rows:
    - [all_contains_timeout_max,
       "__all__.__contains__",
       ["TIMEOUT_MAX"],
       true,
       "threading.__all__.__contains__('TIMEOUT_MAX') == True — TIMEOUT_MAX is an exported public constant at index 6; list.__contains__('TIMEOUT_MAX') returns True; new to extra121"]
    - [all_contains_barrier,
       "__all__.__contains__",
       ["Barrier"],
       true,
       "threading.__all__.__contains__('Barrier') == True — Barrier is an exported synchronization primitive at index 13; it is a reusable barrier for coordinating N threads; list.__contains__('Barrier') returns True; new to extra121"]
    - [all_contains_lock,
       "__all__.__contains__",
       ["Lock"],
       true,
       "threading.__all__.__contains__('Lock') == True — Lock is an exported primitive mutex at index 8; it is the basic mutual-exclusion lock; list.__contains__('Lock') returns True; new to extra121"]
    - [all_index_timeout_max,
       "__all__.index",
       ["TIMEOUT_MAX"],
       6,
       "threading.__all__.index('TIMEOUT_MAX') == 6 — TIMEOUT_MAX is the 7th exported name (0-indexed position 6); list.index('TIMEOUT_MAX') returns 6; new to extra121"]
    - [all_count_lock,
       "__all__.count",
       ["Lock"],
       1,
       "threading.__all__.count('Lock') == 1 — 'Lock' appears exactly once in __all__; RLock is a separate entry; list.count('Lock') returns 1; new to extra121"]

# ---------------------------------------------------------------------------
# Table 3: threading.TIMEOUT_MAX type name length and active_count qualname
#
# Wave 271 theme: threading.TIMEOUT_MAX.__class__.__name__ is 'float' (covered
# in prior specs as True). New here: the length of the type name — 'float' has
# 5 chars. Also new: threading.active_count.__qualname__ is 'active_count'
# (12 chars). active_count is a pure-Python function defined in Lib/threading.py
# that returns the number of Thread objects currently alive. Its qualname
# 'active_count' (12 chars) equals the length of 'Barrier.wait' (also 12, from
# extra120) — a coincidence between a function qualname and a method qualname.
#
# TIMEOUT_MAX.__class__.__name__.__len__()    == 5
# active_count.__qualname__.__eq__('active_count') == True
# active_count.__qualname__.__len__()         == 12
#
# New to extra121.
# ---------------------------------------------------------------------------

table threading_extra121.timeout_max_type_len_and_active_count:
  description: "threading TIMEOUT_MAX type name len and active_count qualname: 'float'.__len__()=5, active_count.__qualname__='active_count'(12); qualname len 12 equals Barrier.wait qualname len (extra120); wave 271; new to extra121"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtmac121

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_class_name_len,
       "TIMEOUT_MAX.__class__.__name__.__len__",
       [],
       5,
       "threading.TIMEOUT_MAX.__class__.__name__.__len__() == 5 — 'float' has 5 chars: f-l-o-a-t; the type name of the TIMEOUT_MAX constant; str.__len__() returns 5; new to extra121"]
    - [active_count_qualname_eq,
       "active_count.__qualname__.__eq__",
       ["active_count"],
       true,
       "threading.active_count.__qualname__.__eq__('active_count') == True — active_count is a module-level function (not a method); its qualname is 'active_count' (12 chars); str.__eq__('active_count') returns True; new to extra121"]
    - [active_count_qualname_len,
       "active_count.__qualname__.__len__",
       [],
       12,
       "threading.active_count.__qualname__.__len__() == 12 — 'active_count' has 12 chars: a-c-t-i-v-e-_-c-o-u-n-t; same length as 'Barrier.wait' (from extra120); str.__len__() returns 12; new to extra121"]
    - [active_count_module_eq,
       "active_count.__module__.__eq__",
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — active_count is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra121"]
    - [timeout_max_class_name_eq,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — confirming prior coverage from threading_extra and threading_extra100; TIMEOUT_MAX is a float; str.__eq__('float') returns True; new to extra121"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra121
# ---------------------------------------------------------------------------

invariant threading_extra121.all_len:
  description: "threading.__all__.__len__() == 28 — 28 exported names; covers sync primitives, thread control, hooks; more than functools (15); wave 271; new to extra121"
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 28

invariant threading_extra121.all_elem0_eq:
  description: "threading.__all__[0] == 'get_ident' — first exported name; returns thread identifier; 9 chars; wave 271; new to extra121"
  kind: python_call_eq
  function: "__all__.__getitem__"
  args: [0]
  expected: "get_ident"

invariant threading_extra121.all_contains_timeout_max:
  description: "threading.__all__.__contains__('TIMEOUT_MAX') == True — TIMEOUT_MAX is exported at index 6; float constant for max blocking timeout; wave 271; new to extra121"
  kind: python_call_eq
  function: __all__.__contains__
  args: ["TIMEOUT_MAX"]
  expected: true

invariant threading_extra121.all_index_timeout_max:
  description: "threading.__all__.index('TIMEOUT_MAX') == 6 — TIMEOUT_MAX is at index 6 in __all__; seventh exported name; wave 271; new to extra121"
  kind: python_call_eq
  function: __all__.index
  args: ["TIMEOUT_MAX"]
  expected: 6

invariant threading_extra121.active_count_qualname:
  description: "threading.active_count.__qualname__ == 'active_count' — module-level function; qualname len=12; same length as 'Barrier.wait'; wave 271; new to extra121"
  kind: python_call_eq
  function: active_count.__qualname__.__eq__
  args: ["active_count"]
  expected: true

