# ---------------------------------------------------------------------------
# Table 1: functools.partial instance class and module attributes
#
# Wave 265 theme: functools.partial is a C-extension type defined in
# Modules/_functoolsmodule.c. When you call partial(int), the resulting
# instance has __class__.__name__ == 'partial' (length 7) and
# __module__ == 'functools' (length 9). The wrapped function is accessible
# via .func: partial(int).func.__name__ == 'int' (length 3 — the built-in
# integer type). The instance __class__.__module__ is also 'functools'.
#
# functools.partial(int).__class__.__name__ == 'partial'
# functools.partial(int).__module__ == 'functools'
# functools.partial(int).func.__name__ == 'int'
# functools.partial(int).__class__.__module__ == 'functools'
#
# New to extra119.
# ---------------------------------------------------------------------------

table functools_extra119.partial_instance_class_attrs:
  description: "functools.partial instance: __class__.__name__='partial'(7), __module__='functools'(9), .func.__name__='int'(3), __class__.__module__='functools'; C-extension type; wave 265; new to extra119"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolspica119

  columns: [id, function, args, expected, description]
  rows:
    - [partial_int_class_name,
       "partial.__class__.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial(int).__class__.__name__.__eq__('partial') == True — the instance class is functools.partial; its __name__ is 'partial'; str.__eq__('partial') returns True; new to extra119"]
    - [partial_int_class_name_len,
       "partial.__class__.__name__.__len__",
       [],
       7,
       "functools.partial(int).__class__.__name__.__len__() == 7 — 'partial' has 7 characters: p-a-r-t-i-a-l; str.__len__() returns 7; new to extra119"]
    - [partial_int_module,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial(int).__module__.__eq__('functools') == True — the partial instance module attribute is 'functools'; str.__eq__('functools') returns True; new to extra119"]
    - [partial_int_module_len,
       "partial.__module__.__len__",
       [],
       9,
       "functools.partial(int).__module__.__len__() == 9 — 'functools' has 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; new to extra119"]
    - [partial_int_func_name,
       "partial.func.__name__.__eq__",
       ["int"],
       true,
       "functools.partial(int).func.__name__.__eq__('int') == True — .func stores the wrapped callable; int.__name__ is 'int' (len 3); str.__eq__('int') returns True; new to extra119"]
    - [partial_int_class_module,
       "partial.__class__.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial(int).__class__.__module__.__eq__('functools') == True — the partial type is defined in the functools module; __class__.__module__ is 'functools'; str.__eq__('functools') returns True; new to extra119"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial method qualnames
#
# Wave 265 theme: functools.partial is a C-extension type. Its methods
# (__call__, __reduce__, __repr__, __setstate__) all follow the
# 'partial.<method>' qualname pattern. Lengths: __call__ => 'partial.__call__'
# (16), __reduce__ => 'partial.__reduce__' (18), __repr__ => 'partial.__repr__'
# (16), __setstate__ => 'partial.__setstate__' (20). The __call__ and __repr__
# qualnames share the same length (16), while __setstate__ is longest (20).
#
# functools.partial.__call__.__qualname__ == 'partial.__call__'      (len 16)
# functools.partial.__reduce__.__qualname__ == 'partial.__reduce__'  (len 18)
# functools.partial.__repr__.__qualname__ == 'partial.__repr__'      (len 16)
# functools.partial.__setstate__.__qualname__ == 'partial.__setstate__' (len 20)
#
# New to extra119.
# ---------------------------------------------------------------------------

table functools_extra119.partial_method_qualnames:
  description: "functools.partial method qualnames: __call__='partial.__call__'(16), __reduce__='partial.__reduce__'(18), __repr__='partial.__repr__'(16), __setstate__='partial.__setstate__'(20); C-extension methods; wave 265; new to extra119"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspmq119

  columns: [id, function, args, expected, description]
  rows:
    - [partial_call_qualname,
       "partial.__call__.__qualname__.__eq__",
       ["partial.__call__"],
       true,
       "functools.partial.__call__.__qualname__.__eq__('partial.__call__') == True — C-extension method qualname follows 'TypeName.__method__' pattern; str.__eq__('partial.__call__') returns True; new to extra119"]
    - [partial_call_qualname_len,
       "partial.__call__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__call__.__qualname__.__len__() == 16 — 'partial.__call__' has 16 chars: p-a-r-t-i-a-l(7) + dot(1) + __call__(8); str.__len__() returns 16; new to extra119"]
    - [partial_reduce_qualname,
       "partial.__reduce__.__qualname__.__eq__",
       ["partial.__reduce__"],
       true,
       "functools.partial.__reduce__.__qualname__.__eq__('partial.__reduce__') == True — __reduce__ is used for pickling partial objects; its qualname is 'partial.__reduce__'; str.__eq__('partial.__reduce__') returns True; new to extra119"]
    - [partial_reduce_qualname_len,
       "partial.__reduce__.__qualname__.__len__",
       [],
       18,
       "functools.partial.__reduce__.__qualname__.__len__() == 18 — 'partial.__reduce__' has 18 chars: p-a-r-t-i-a-l(7) + dot(1) + __reduce__(10); str.__len__() returns 18; new to extra119"]
    - [partial_repr_qualname,
       "partial.__repr__.__qualname__.__eq__",
       ["partial.__repr__"],
       true,
       "functools.partial.__repr__.__qualname__.__eq__('partial.__repr__') == True — __repr__ provides string representation of partial objects; its qualname is 'partial.__repr__'; str.__eq__('partial.__repr__') returns True; new to extra119"]
    - [partial_repr_qualname_len,
       "partial.__repr__.__qualname__.__len__",
       [],
       16,
       "functools.partial.__repr__.__qualname__.__len__() == 16 — 'partial.__repr__' has 16 chars: same length as 'partial.__call__'; str.__len__() returns 16; new to extra119"]
    - [partial_setstate_qualname,
       "partial.__setstate__.__qualname__.__eq__",
       ["partial.__setstate__"],
       true,
       "functools.partial.__setstate__.__qualname__.__eq__('partial.__setstate__') == True — __setstate__ is used during unpickling; its qualname is 'partial.__setstate__'; str.__eq__('partial.__setstate__') returns True; new to extra119"]
    - [partial_setstate_qualname_len,
       "partial.__setstate__.__qualname__.__len__",
       [],
       20,
       "functools.partial.__setstate__.__qualname__.__len__() == 20 — 'partial.__setstate__' has 20 chars: p-a-r-t-i-a-l(7) + dot(1) + __setstate__(12); the longest of the four method qualnames; str.__len__() returns 20; new to extra119"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial instance args and keywords types
#
# Wave 265 theme: A functools.partial instance stores pre-filled positional
# arguments in .args (a tuple) and keyword arguments in .keywords (a dict).
# For partial(int) with no extra arguments, .args is an empty tuple and
# .keywords is an empty dict. The type names are 'tuple' and 'dict'
# respectively. Verifying len(.args) == 0 and .keywords == {} confirms
# the default state of a freshly created partial with no frozen args.
#
# type(functools.partial(int).args).__name__ == 'tuple'
# type(functools.partial(int).keywords).__name__ == 'dict'
# len(functools.partial(int).args) == 0
# functools.partial(int).keywords == {}
#
# New to extra119.
# ---------------------------------------------------------------------------

table functools_extra119.partial_instance_args_keywords:
  description: "functools.partial instance .args type='tuple', .keywords type='dict', len(.args)==0, .keywords=={} for partial(int); wave 265; new to extra119"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolspiak119

  columns: [id, function, args, expected, description]
  rows:
    - [partial_args_type,
       "partial.args.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.partial(int).args.__class__.__name__.__eq__('tuple') == True — .args stores pre-filled positional arguments as a tuple; type(partial(int).args).__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra119"]
    - [partial_keywords_type,
       "partial.keywords.__class__.__name__.__eq__",
       ["dict"],
       true,
       "functools.partial(int).keywords.__class__.__name__.__eq__('dict') == True — .keywords stores pre-filled keyword arguments as a dict; type(partial(int).keywords).__name__ is 'dict'; str.__eq__('dict') returns True; new to extra119"]
    - [partial_args_len_zero,
       "partial.args.__len__",
       [],
       0,
       "functools.partial(int).args.__len__() == 0 — partial(int) was created with no pre-filled positional args; .args is an empty tuple; tuple.__len__() returns 0; new to extra119"]
    - [partial_keywords_eq_empty,
       "partial.keywords.__eq__",
       [{}],
       true,
       "functools.partial(int).keywords.__eq__({}) == True — partial(int) was created with no pre-filled keyword args; .keywords is an empty dict; dict.__eq__({}) returns True; new to extra119"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra119
# ---------------------------------------------------------------------------

invariant functools_extra119.partial_int_class_name:
  description: "functools.partial(int).__class__.__name__ == 'partial' — instance class name is 'partial'; length 7; wave 265; new to extra119"
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra119.partial_int_module:
  description: "functools.partial(int).__module__ == 'functools' — instance module is 'functools'; length 9; wave 265; new to extra119"
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra119.partial_call_qualname_len:
  description: "len(functools.partial.__call__.__qualname__) == 16 — 'partial.__call__' is 16 chars; same length as 'partial.__repr__'; wave 265; new to extra119"
  kind: python_call_eq
  function: partial.__call__.__qualname__.__len__
  args: []
  expected: 16

invariant functools_extra119.partial_setstate_qualname_len:
  description: "len(functools.partial.__setstate__.__qualname__) == 20 — 'partial.__setstate__' is longest method qualname; 20 chars; wave 265; new to extra119"
  kind: python_call_eq
  function: partial.__setstate__.__qualname__.__len__
  args: []
  expected: 20

invariant functools_extra119.partial_args_len_zero:
  description: "len(functools.partial(int).args) == 0 — no pre-filled positional args; .args is an empty tuple; wave 265; new to extra119"
  kind: python_call_eq
  function: partial.args.__len__
  args: []
  expected: 0

