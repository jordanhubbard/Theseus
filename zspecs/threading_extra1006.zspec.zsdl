spec: threading_extra1006
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks qualnames and class names for RLock and Lock synchronization primitives; Lock() returns a lock object not threading.lock class directly"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1006.rlock_qualnames:
  description: "threading.RLock method __qualname__ checks"
  kind: python_call_eq
  category: rlock_qualnames
  id_prefix: th1006rq
  columns: [id, function, args, expected]
  rows:
    - [th1006rq001, threading.RLock.__class__.__name__.__eq__,         ["type"],    true]
    - [th1006rq002, threading.RLock.__module__.__eq__,                 ["threading"], true]
    - [th1006rq003, threading.RLock.acquire.__qualname__.__eq__,       ["RLock.acquire"], true]
    - [th1006rq004, threading.RLock.release.__qualname__.__eq__,       ["RLock.release"], true]
    - [th1006rq005, threading.RLock.__enter__.__qualname__.__eq__,     ["RLock.__enter__"], true]
    - [th1006rq006, threading.RLock.__exit__.__qualname__.__eq__,      ["RLock.__exit__"],  true]

table threading_extra1006.lock_class_identity:
  description: "threading.Lock factory class name and module checks"
  kind: python_call_eq
  category: lock_class_identity
  id_prefix: th1006lc
  columns: [id, function, args, expected]
  rows:
    - [th1006lc001, threading.Lock.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [th1006lc002, threading.Lock.__module__.__eq__,                  ["_thread"],                    true]
    - [th1006lc003, threading.Lock.__name__.__eq__,                    ["allocate_lock"],              true]
    - [th1006lc004, threading.RLock.__qualname__.__eq__,               ["RLock"],                      true]
    - [th1006lc005, threading.Semaphore.__module__.__eq__,             ["threading"],                  true]
    - [th1006lc006, threading.Semaphore.__qualname__.__eq__,           ["Semaphore"],                  true]

table threading_extra1006.rlock_condition_qualnames:
  description: "threading.RLock, Condition, and Event method qualname checks"
  kind: python_call_eq
  category: rlock_condition_qualnames
  id_prefix: th1006rc
  columns: [id, function, args, expected]
  rows:
    - [th1006rc001, threading.Condition.acquire.__qualname__.__eq__,   ["Condition.acquire"],   true]
    - [th1006rc002, threading.Condition.release.__qualname__.__eq__,   ["Condition.release"],   true]
    - [th1006rc003, threading.Condition.__enter__.__qualname__.__eq__, ["Condition.__enter__"], true]
    - [th1006rc004, threading.Condition.__exit__.__qualname__.__eq__,  ["Condition.__exit__"],  true]
    - [th1006rc005, threading.Event.set.__qualname__.__eq__,           ["Event.set"],           true]
    - [th1006rc006, threading.Event.clear.__qualname__.__eq__,         ["Event.clear"],         true]
