spec: cattrs_rust
version: ">=3.9"
backend: rust_module(cattrs_rust)

docs: https://catt.rs/en/stable/

provenance:
  derived_from:
    - "https://catt.rs/en/stable/ — cattrs documentation"
  not_derived_from:
    - "cattrs source: src/cattrs/__init__.py"
  notes:
    - "cattrs provides structured data conversion for attrs classes."
    - "import cattrs; converter = cattrs.Converter()."
    - "converter.unstructure({'a': 1}) == {'a': 1} — dict passthrough."
    - "cattrs.structure([1,2,3], list) == [1,2,3]."
    - "cattrs.unstructure([1,2,3]) == [1,2,3]."
    - "Expose cattrs_unstructure_list(lst) -> list: cattrs.unstructure(lst)."
    - "Expose cattrs_structure_list(lst) -> list: cattrs.structure(lst, list)."
    - "Expose cattrs_has_converter() -> bool: hasattr(cattrs, 'Converter')."
    - "All test vectors verified against cattrs 24.1.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# cattrs_unstructure_list — list passthrough
table cattrs_rust.convert.unstructure:
  kind: python_call_eq
  category: unstructure
  id_prefix: cat_u
  function: cattrs_unstructure_list

  columns: [id, args, expected]
  rows:
    - [ints,  [[1, 2, 3]],  [1, 2, 3]]
    - [empty, [[]], []]

# cattrs_structure_list — structure list
table cattrs_rust.convert.structure:
  kind: python_call_eq
  category: structure
  id_prefix: cat_s
  function: cattrs_structure_list

  columns: [id, args, expected]
  rows:
    - [ints, [[1, 2, 3]], [1, 2, 3]]

# cattrs_has_converter — Converter class present
invariant cattrs_rust.module.has_converter:
  description: "cattrs.Converter is available"
  category: module
  kind: python_call_eq
  function: cattrs_has_converter
  args: []
  expected: true

