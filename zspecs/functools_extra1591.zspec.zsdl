spec: functools_extra1591
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — descriptor protocol checks via __dict__.__contains__ for functools.partial, functools.partialmethod, functools.cached_property, and built-in descriptor reference types (property, classmethod, staticmethod)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Behavioral invariants for descriptor protocol: which functools classes define __get__, __set__, __delete__, __set_name__ in their own __dict__. partial is a non-data descriptor (has __get__ only). partialmethod is a non-data descriptor (has __get__ only). cached_property is a non-data descriptor (has __get__ and __set_name__ but not __set__ or __delete__). property is a full data descriptor. classmethod and staticmethod are non-data descriptors."]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1591.partial_descriptor_protocol:
  description: "functools.partial descriptor protocol: partial is a C extension non-data descriptor defining __get__ but not __set__ or __delete__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1591pa

  columns: [id, function, args, expected]
  rows:
    - [fu1591pa001, functools.partial.__dict__.__contains__, ["__get__"],           true]
    - [fu1591pa002, functools.partial.__dict__.__contains__, ["__set__"],           false]
    - [fu1591pa003, functools.partial.__dict__.__contains__, ["__delete__"],        false]
    - [fu1591pa004, functools.partial.__dict__.__contains__, ["__set_name__"],      false]
    - [fu1591pa005, functools.partial.__dict__.__contains__, ["__call__"],          true]
    - [fu1591pa006, functools.partial.__dict__.__contains__, ["__new__"],           true]
    - [fu1591pa007, functools.partial.__dict__.__contains__, ["__reduce__"],        true]
    - [fu1591pa008, functools.partial.__dict__.__contains__, ["func"],              true]
    - [fu1591pa009, functools.partial.__dict__.__contains__, ["args"],              true]
    - [fu1591pa010, functools.partial.__dict__.__contains__, ["keywords"],          true]
    - [fu1591pa011, functools.partial.__dict__.__contains__, ["__repr__"],          true]
    - [fu1591pa012, functools.partial.__dict__.__contains__, ["__doc__"],           true]
    - [fu1591pa013, functools.partial.__dict__.__contains__, ["__dict__"],          true]
    - [fu1591pa014, functools.partial.__dict__.__contains__, ["__module__"],        true]
    - [fu1591pa015, functools.partial.__dict__.__contains__, ["__init__"],          false]
    - [fu1591pa016, functools.partial.__dict__.__contains__, ["__weakref__"],       false]
    - [fu1591pa017, functools.partial.__class__.__name__.__eq__, ["type"],          true]
    - [fu1591pa018, functools.partial.__name__.__eq__,           ["partial"],       true]
    - [fu1591pa019, functools.partial.__module__.__eq__,         ["functools"],     true]
    - [fu1591pa020, functools.partial.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [fu1591pa021, functools.partial.__mro__.__class__.__name__.__eq__,  ["tuple"],        true]
    - [fu1591pa022, functools.partial.__bases__.__len__, [],                        1]

table functools_extra1591.partialmethod_descriptor_protocol:
  description: "functools.partialmethod descriptor protocol: defines __get__ (non-data descriptor) but not __set__, __delete__, or __set_name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1591pm

  columns: [id, function, args, expected]
  rows:
    - [fu1591pm001, functools.partialmethod.__dict__.__contains__, ["__get__"],      true]
    - [fu1591pm002, functools.partialmethod.__dict__.__contains__, ["__set__"],      false]
    - [fu1591pm003, functools.partialmethod.__dict__.__contains__, ["__delete__"],   false]
    - [fu1591pm004, functools.partialmethod.__dict__.__contains__, ["__set_name__"], false]
    - [fu1591pm005, functools.partialmethod.__dict__.__contains__, ["__repr__"],     true]
    - [fu1591pm006, functools.partialmethod.__dict__.__contains__, ["__new__"],      true]
    - [fu1591pm007, functools.partialmethod.__dict__.__contains__, ["__dict__"],     true]
    - [fu1591pm008, functools.partialmethod.__dict__.__contains__, ["__weakref__"],  true]
    - [fu1591pm009, functools.partialmethod.__dict__.__contains__, ["__isabstractmethod__"], true]
    - [fu1591pm010, functools.partialmethod.__dict__.__contains__, ["_make_unbound_method"], true]
    - [fu1591pm011, functools.partialmethod.__dict__.__contains__, ["__doc__"],      true]
    - [fu1591pm012, functools.partialmethod.__dict__.__contains__, ["__module__"],   true]
    - [fu1591pm013, functools.partialmethod.__class__.__name__.__eq__,  ["type"],         true]
    - [fu1591pm014, functools.partialmethod.__name__.__eq__,            ["partialmethod"], true]
    - [fu1591pm015, functools.partialmethod.__module__.__eq__,          ["functools"],     true]
    - [fu1591pm016, functools.partialmethod.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [fu1591pm017, functools.partialmethod.__mro__.__class__.__name__.__eq__,  ["tuple"],        true]
    - [fu1591pm018, functools.partialmethod.__bases__.__len__, [],               1]
    - [fu1591pm019, functools.partialmethod.__dict__.__contains__, ["__init__"],          false]
    - [fu1591pm020, functools.partialmethod.__dict__.__contains__, ["__call__"],          false]
    - [fu1591pm021, functools.partialmethod.__dict__.__contains__, ["__firstlineno__"],   true]
    - [fu1591pm022, functools.partialmethod.__dict__.__contains__, ["__static_attributes__"], true]

table functools_extra1591.cached_property_descriptor_protocol:
  description: "functools.cached_property descriptor protocol: defines __get__ and __set_name__ (non-data descriptor — no __set__ or __delete__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1591cp

  columns: [id, function, args, expected]
  rows:
    - [fu1591cp001, functools.cached_property.__dict__.__contains__, ["__get__"],      true]
    - [fu1591cp002, functools.cached_property.__dict__.__contains__, ["__set__"],      false]
    - [fu1591cp003, functools.cached_property.__dict__.__contains__, ["__delete__"],   false]
    - [fu1591cp004, functools.cached_property.__dict__.__contains__, ["__set_name__"], true]
    - [fu1591cp005, functools.cached_property.__dict__.__contains__, ["__init__"],     true]
    - [fu1591cp006, functools.cached_property.__dict__.__contains__, ["__dict__"],     true]
    - [fu1591cp007, functools.cached_property.__dict__.__contains__, ["__weakref__"],  true]
    - [fu1591cp008, functools.cached_property.__dict__.__contains__, ["__doc__"],      true]
    - [fu1591cp009, functools.cached_property.__dict__.__contains__, ["__module__"],   true]
    - [fu1591cp010, functools.cached_property.__dict__.__contains__, ["__call__"],     false]
    - [fu1591cp011, functools.cached_property.__dict__.__contains__, ["__repr__"],     false]
    - [fu1591cp012, functools.cached_property.__dict__.__contains__, ["attrname"],     false]
    - [fu1591cp013, functools.cached_property.__class__.__name__.__eq__,  ["type"],            true]
    - [fu1591cp014, functools.cached_property.__name__.__eq__,            ["cached_property"], true]
    - [fu1591cp015, functools.cached_property.__module__.__eq__,          ["functools"],        true]
    - [fu1591cp016, functools.cached_property.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [fu1591cp017, functools.cached_property.__mro__.__class__.__name__.__eq__,  ["tuple"],        true]
    - [fu1591cp018, functools.cached_property.__bases__.__len__, [],               1]
    - [fu1591cp019, functools.cached_property.__get__.__qualname__.__eq__,      ["cached_property.__get__"],      true]
    - [fu1591cp020, functools.cached_property.__set_name__.__qualname__.__eq__,  ["cached_property.__set_name__"], true]
    - [fu1591cp021, functools.cached_property.__init__.__qualname__.__eq__,      ["cached_property.__init__"],     true]
    - [fu1591cp022, functools.cached_property.__dict__.__contains__, ["__class_getitem__"], true]

table functools_extra1591.builtin_descriptor_reference:
  description: "Reference invariants for built-in descriptor types: property (data descriptor), classmethod and staticmethod (non-data descriptors)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1591bd

  columns: [id, function, args, expected]
  rows:
    - [fu1591bd001, property.__dict__.__contains__,     ["__get__"],    true]
    - [fu1591bd002, property.__dict__.__contains__,     ["__set__"],    true]
    - [fu1591bd003, property.__dict__.__contains__,     ["__delete__"], true]
    - [fu1591bd004, property.__dict__.__contains__,     ["__set_name__"], false]
    - [fu1591bd005, classmethod.__dict__.__contains__,  ["__get__"],    true]
    - [fu1591bd006, classmethod.__dict__.__contains__,  ["__set__"],    false]
    - [fu1591bd007, classmethod.__dict__.__contains__,  ["__delete__"], false]
    - [fu1591bd008, classmethod.__dict__.__contains__,  ["__set_name__"], false]
    - [fu1591bd009, staticmethod.__dict__.__contains__, ["__get__"],    true]
    - [fu1591bd010, staticmethod.__dict__.__contains__, ["__set__"],    false]
    - [fu1591bd011, staticmethod.__dict__.__contains__, ["__delete__"], false]
    - [fu1591bd012, staticmethod.__dict__.__contains__, ["__set_name__"], false]
    - [fu1591bd013, property.__dict__.__class__.__name__.__eq__,     ["mappingproxy"], true]
    - [fu1591bd014, classmethod.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]
    - [fu1591bd015, staticmethod.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [fu1591bd016, property.__name__.__eq__,     ["property"],     true]
    - [fu1591bd017, classmethod.__name__.__eq__,  ["classmethod"],  true]
    - [fu1591bd018, staticmethod.__name__.__eq__, ["staticmethod"], true]
    - [fu1591bd019, property.__dict__.__contains__,    ["fget"],        true]
    - [fu1591bd020, property.__dict__.__contains__,    ["fset"],        true]
    - [fu1591bd021, property.__dict__.__contains__,    ["fdel"],        true]
    - [fu1591bd022, property.__dict__.__contains__,    ["getter"],      true]
    - [fu1591bd023, property.__dict__.__contains__,    ["setter"],      true]
    - [fu1591bd024, property.__dict__.__contains__,    ["deleter"],     true]
    - [fu1591bd025, property.__dict__.__contains__,    ["__set_name__"], true]
    - [fu1591bd026, classmethod.__dict__.__contains__,  ["__func__"],    true]
    - [fu1591bd027, staticmethod.__dict__.__contains__, ["__func__"],    true]
    - [fu1591bd028, classmethod.__dict__.__contains__,  ["__wrapped__"], true]
    - [fu1591bd029, staticmethod.__dict__.__contains__, ["__wrapped__"], true]
    - [fu1591bd030, classmethod.__dict__.__contains__,  ["__isabstractmethod__"], true]
    - [fu1591bd031, staticmethod.__dict__.__contains__, ["__isabstractmethod__"], true]
