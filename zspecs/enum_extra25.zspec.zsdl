spec: enum_extra25
version: ">=3.11"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum_extra24.zspec.zsdl."
    - "enum_extra24 covers: combined __qualname__ table for unique/global_enum/member/nonmember/property/show_flag_values; combined __module__ table for same six; member/__mro__.__len__ == 2; nonmember/__mro__.__len__ == 2; enum.property.__mro__.__len__ == 3; member/__qualname__.__len__ == 6; nonmember/__qualname__.__len__ == 9."
    - "enum_extra21 covers: combined __qualname__ table for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique; EnumMeta.__qualname__ == 'EnumType' standalone; combined __module__ table for all seven."
    - "No prior enum spec records __qualname__.__len__() for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique/EnumType together in the extra25 namespace."
    - "Focus: string length of __qualname__ for core enum classes and helpers. EnumMeta.__qualname__ == 'EnumType' on Python 3.11+, so len == 8."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — eight enum classes and helpers
#
# Verifies the string length of each name's __qualname__. All are defined at
# module level. EnumMeta.__qualname__ is 'EnumType' on Python 3.11+.
# No prior enum spec records all eight qualname lengths together in one table
# in the extra25 namespace.
# ---------------------------------------------------------------------------

table enum_extra25.qualname_lengths:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [Enum,     Enum.__qualname__.__len__,     [], 4]
    - [IntEnum,  IntEnum.__qualname__.__len__,  [], 7]
    - [Flag,     Flag.__qualname__.__len__,     [], 4]
    - [IntFlag,  IntFlag.__qualname__.__len__,  [], 7]
    - [StrEnum,  StrEnum.__qualname__.__len__,  [], 7]
    - [auto,     auto.__qualname__.__len__,     [], 4]
    - [unique,   unique.__qualname__.__len__,   [], 6]
    - [EnumMeta, EnumMeta.__qualname__.__len__, [], 8]

# ---------------------------------------------------------------------------
# Enum.__qualname__.__len__() == 4 — standalone qualname length
#
# The qualname string 'Enum' has 4 characters.
# No prior enum spec records this invariant in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra25.Enum.qualname.len:
  description: "len(enum.Enum.__qualname__) == 4 — len('Enum') == 4"
  category: qualnames
  kind: python_call_eq
  function: Enum.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# IntEnum.__qualname__.__len__() == 7 — standalone qualname length
#
# The qualname string 'IntEnum' has 7 characters.
# No prior enum spec records this invariant in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra25.IntEnum.qualname.len:
  description: "len(enum.IntEnum.__qualname__) == 7 — len('IntEnum') == 7"
  category: qualnames
  kind: python_call_eq
  function: IntEnum.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# StrEnum.__qualname__.__len__() == 7 — standalone qualname length
#
# The qualname string 'StrEnum' has 7 characters. StrEnum was added in Python
# 3.11.
# No prior enum spec records this invariant in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra25.StrEnum.qualname.len:
  description: "len(enum.StrEnum.__qualname__) == 7 — len('StrEnum') == 7"
  category: qualnames
  kind: python_call_eq
  function: StrEnum.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# EnumMeta.__qualname__.__len__() == 8 — standalone qualname length
#
# On Python 3.11+ enum.EnumMeta.__qualname__ is 'EnumType' (8 characters).
# enum_extra18 covers EnumMeta/__qualname__.__len__ == 8 as a related check
# but not as a standalone invariant in the extra25 namespace.
# No prior enum spec records this invariant in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant enum_extra25.EnumMeta.qualname.len:
  description: "len(enum.EnumMeta.__qualname__) == 8 — EnumMeta.__qualname__ is 'EnumType' on Python 3.11+"
  category: qualnames
  kind: python_call_eq
  function: EnumMeta.__qualname__.__len__
  args: []
  expected: 8
