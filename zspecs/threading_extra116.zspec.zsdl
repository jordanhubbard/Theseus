spec: threading_extra116
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra115.zspec.zsdl."
    - "This spec covers: threading.Timer class attributes not yet covered — __name__, __module__, __qualname__, __init__.__qualname__, run.__qualname__, cancel.__qualname__, cancel co_argcount, __init__ co_argcount, __mro__[0].__name__, __mro__[2].__name__; wave 266."
    - "threading.Timer.__name__ == 'Timer'. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Timer.__qualname__ == 'Timer'. Verified with Python 3.14.3."
    - "threading.Timer.__init__.__qualname__ == 'Timer.__init__'. Verified with Python 3.14.3."
    - "threading.Timer.run.__qualname__ == 'Timer.run'. Verified with Python 3.14.3."
    - "threading.Timer.cancel.__qualname__ == 'Timer.cancel'. Verified with Python 3.14.3."
    - "threading.Timer.cancel.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "threading.Timer.__init__.__code__.co_argcount == 5. Verified with Python 3.14.3."
    - "threading.Timer.__mro__[0].__name__ == 'Timer'. Verified with Python 3.14.3."
    - "threading.Timer.__mro__[2].__name__ == 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Timer class identity attributes
#
# Wave 266 theme: threading.Timer is a pure-Python subclass of Thread defined
# in Lib/threading.py. It inherits from Thread (__bases__[0].__name__ ==
# 'Thread'). Its __name__ is 'Timer' (length 5), __qualname__ is 'Timer'
# (top-level class), and __module__ is 'threading'. The MRO has 3 entries:
# Timer, Thread, object. Previously covered: __mro__.__len__, __mro__.__getitem__,
# run.__class__.__name__ (in extra112/113). New here: __name__, __module__,
# __qualname__, __mro__[0].__name__, __mro__[2].__name__.
#
# Timer.__name__ == 'Timer'       (len 5)
# Timer.__module__ == 'threading'
# Timer.__qualname__ == 'Timer'
# Timer.__mro__[0].__name__ == 'Timer'
# Timer.__mro__[2].__name__ == 'object'
#
# New to extra116.
# ---------------------------------------------------------------------------

table threading_extra116.timer_class_identity:
  description: "threading.Timer class identity: __name__='Timer'(5), __module__='threading', __qualname__='Timer', __mro__[0]='Timer', __mro__[2]='object'; Thread subclass; wave 266; new to extra116"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingtci116

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name,
       "Timer.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a pure-Python Thread subclass; its __name__ is 'Timer' (len 5); str.__eq__('Timer') returns True; new to extra116"]
    - [timer_name_len,
       "Timer.__name__.__len__",
       [],
       5,
       "threading.Timer.__name__.__len__() == 5 — 'Timer' has 5 chars: T-i-m-e-r; str.__len__() returns 5; new to extra116"]
    - [timer_module,
       "Timer.__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in the threading module; str.__eq__('threading') returns True; new to extra116"]
    - [timer_qualname,
       "Timer.__qualname__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__qualname__.__eq__('Timer') == True — Timer is a top-level class; __qualname__ equals __name__; str.__eq__('Timer') returns True; new to extra116"]
    - [timer_mro0_name,
       "Timer.__mro__.__getitem__",
       [0],
       "Timer",
       "threading.Timer.__mro__[0].__name__ == 'Timer' — first MRO entry is the class itself; tuple.__getitem__(0).__name__ returns 'Timer'; new to extra116"]
    - [timer_mro2_name,
       "Timer.__mro__.__getitem__",
       [2],
       "object",
       "threading.Timer.__mro__[2].__name__ == 'object' — third MRO entry is the root base class object; Timer -> Thread -> object; tuple.__getitem__(2).__name__ returns 'object'; new to extra116"]

# ---------------------------------------------------------------------------
# Table 2: threading.Timer method __qualname__ attributes
#
# Wave 266 theme: threading.Timer defines three methods: __init__, run, and
# cancel. Each follows the 'Timer.<method>' qualname pattern. Lengths:
# Timer.__init__ => 'Timer.__init__' (14), Timer.run => 'Timer.run' (9),
# Timer.cancel => 'Timer.cancel' (12). Previously covered: run.__class__.__name__
# (in extra113). New here: __init__.__qualname__, run.__qualname__,
# cancel.__qualname__ and their lengths.
#
# Timer.__init__.__qualname__ == 'Timer.__init__'  (len 14)
# Timer.run.__qualname__ == 'Timer.run'            (len 9)
# Timer.cancel.__qualname__ == 'Timer.cancel'      (len 12)
#
# New to extra116.
# ---------------------------------------------------------------------------

table threading_extra116.timer_method_qualnames:
  description: "threading.Timer method qualnames: __init__='Timer.__init__'(14), run='Timer.run'(9), cancel='Timer.cancel'(12); run is shortest; __init__ is longest; wave 266; new to extra116"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtmq116

  columns: [id, function, args, expected, description]
  rows:
    - [timer_init_qualname,
       "Timer.__init__.__qualname__.__eq__",
       ["Timer.__init__"],
       true,
       "threading.Timer.__init__.__qualname__.__eq__('Timer.__init__') == True — __init__ qualname follows 'ClassName.__init__' pattern; str.__eq__('Timer.__init__') returns True; new to extra116"]
    - [timer_init_qualname_len,
       "Timer.__init__.__qualname__.__len__",
       [],
       14,
       "threading.Timer.__init__.__qualname__.__len__() == 14 — 'Timer.__init__' has 14 chars: T-i-m-e-r(5)+dot(1)+__init__(8); longest of the three Timer method qualnames; str.__len__() returns 14; new to extra116"]
    - [timer_run_qualname,
       "Timer.run.__qualname__.__eq__",
       ["Timer.run"],
       true,
       "threading.Timer.run.__qualname__.__eq__('Timer.run') == True — run qualname is 'Timer.run'; Timer overrides Thread.run to execute the timer function; str.__eq__('Timer.run') returns True; new to extra116"]
    - [timer_run_qualname_len,
       "Timer.run.__qualname__.__len__",
       [],
       9,
       "threading.Timer.run.__qualname__.__len__() == 9 — 'Timer.run' has 9 chars: T-i-m-e-r(5)+dot(1)+r-u-n(3); shortest of the three Timer method qualnames; str.__len__() returns 9; new to extra116"]
    - [timer_cancel_qualname,
       "Timer.cancel.__qualname__.__eq__",
       ["Timer.cancel"],
       true,
       "threading.Timer.cancel.__qualname__.__eq__('Timer.cancel') == True — cancel qualname is 'Timer.cancel'; cancel sets an event to abort the pending timer; str.__eq__('Timer.cancel') returns True; new to extra116"]
    - [timer_cancel_qualname_len,
       "Timer.cancel.__qualname__.__len__",
       [],
       12,
       "threading.Timer.cancel.__qualname__.__len__() == 12 — 'Timer.cancel' has 12 chars: T-i-m-e-r(5)+dot(1)+c-a-n-c-e-l(6); str.__len__() returns 12; new to extra116"]

# ---------------------------------------------------------------------------
# Table 3: threading.Timer method co_argcount and co_name values
#
# Wave 266 theme: threading.Timer method co_argcount values: __init__ takes
# self + interval + function + args + kwargs = 5 positional-or-keyword params;
# run and cancel each take only self (co_argcount == 1). The co_name values
# match the short method names: '__init__', 'run', 'cancel'.
#
# Timer.__init__.__code__.co_argcount == 5
# Timer.run.__code__.co_argcount == 1
# Timer.cancel.__code__.co_argcount == 1
# Timer.run.__code__.co_name == 'run'
# Timer.cancel.__code__.co_name == 'cancel'
#
# New to extra116.
# ---------------------------------------------------------------------------

table threading_extra116.timer_method_co_attrs:
  description: "threading.Timer method code attrs: __init__ co_argcount=5 (self+interval+function+args+kwargs), run co_argcount=1, cancel co_argcount=1; co_name values match method names; wave 266; new to extra116"
  kind: python_call_eq
  category: code_identity
  id_prefix: threadingtmc116

  columns: [id, function, args, expected, description]
  rows:
    - [timer_init_co_argcount,
       "Timer.__init__.__code__.co_argcount.__eq__",
       [5],
       true,
       "threading.Timer.__init__.__code__.co_argcount.__eq__(5) == True — Timer.__init__(self, interval, function, args, kwargs) has 5 positional-or-keyword params; int.__eq__(5) returns True; new to extra116"]
    - [timer_run_co_argcount,
       "Timer.run.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Timer.run.__code__.co_argcount.__eq__(1) == True — Timer.run(self) takes only self; waits then calls the function; int.__eq__(1) returns True; new to extra116"]
    - [timer_cancel_co_argcount,
       "Timer.cancel.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Timer.cancel.__code__.co_argcount.__eq__(1) == True — Timer.cancel(self) takes only self; sets an event to prevent the timer firing; int.__eq__(1) returns True; new to extra116"]
    - [timer_run_co_name,
       "Timer.run.__code__.co_name.__eq__",
       ["run"],
       true,
       "threading.Timer.run.__code__.co_name.__eq__('run') == True — co_name is the bare function name from the def statement; str.__eq__('run') returns True; new to extra116"]
    - [timer_cancel_co_name,
       "Timer.cancel.__code__.co_name.__eq__",
       ["cancel"],
       true,
       "threading.Timer.cancel.__code__.co_name.__eq__('cancel') == True — co_name is 'cancel'; str.__eq__('cancel') returns True; new to extra116"]
    - [timer_init_co_name,
       "Timer.__init__.__code__.co_name.__eq__",
       ["__init__"],
       true,
       "threading.Timer.__init__.__code__.co_name.__eq__('__init__') == True — co_name is '__init__' for the constructor method; str.__eq__('__init__') returns True; new to extra116"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra116
# ---------------------------------------------------------------------------

invariant threading_extra116.timer_name:
  description: "threading.Timer.__name__ == 'Timer' — Thread subclass name; length 5; wave 266; new to extra116"
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra116.timer_run_qualname:
  description: "threading.Timer.run.__qualname__ == 'Timer.run' — run qualname follows ClassName.method pattern; length 9; wave 266; new to extra116"
  kind: python_call_eq
  function: Timer.run.__qualname__.__eq__
  args: ["Timer.run"]
  expected: true

invariant threading_extra116.timer_init_co_argcount:
  description: "threading.Timer.__init__.__code__.co_argcount == 5 — takes self+interval+function+args+kwargs; wave 266; new to extra116"
  kind: python_call_eq
  function: Timer.__init__.__code__.co_argcount.__eq__
  args: [5]
  expected: true

invariant threading_extra116.timer_cancel_qualname:
  description: "threading.Timer.cancel.__qualname__ == 'Timer.cancel' — cancel method qualname; length 12; wave 266; new to extra116"
  kind: python_call_eq
  function: Timer.cancel.__qualname__.__eq__
  args: ["Timer.cancel"]
  expected: true

invariant threading_extra116.timer_mro2_object:
  description: "threading.Timer.__mro__[2].__name__ == 'object' — Timer MRO is Timer -> Thread -> object; third entry is object; wave 266; new to extra116"
  kind: python_call_eq
  function: "Timer.__mro__.__getitem__"
  args: [2]
  expected: "object"

