spec: decimal_extra469
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal arithmetic exception class identity and inheritance"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All signal classes inherit from DecimalException, except ConversionSyntax, DivisionImpossible, and DivisionUndefined which inherit from InvalidOperation"
    - "FloatOperation inherits from both DecimalException and TypeError; only __bases__[0] is checked here"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra469.exception_names:
  description: "decimal exception class __name__ identity checks"
  kind: python_call_eq
  category: exception_identity
  id_prefix: DEN

  columns: [id, function, args, expected]
  rows:
    - [DEN001, decimal.Clamped.__name__.__eq__, ["Clamped"], true]
    - [DEN002, decimal.Rounded.__name__.__eq__, ["Rounded"], true]
    - [DEN003, decimal.Subnormal.__name__.__eq__, ["Subnormal"], true]
    - [DEN004, decimal.Inexact.__name__.__eq__, ["Inexact"], true]
    - [DEN005, decimal.ConversionSyntax.__name__.__eq__, ["ConversionSyntax"], true]
    - [DEN006, decimal.DivisionImpossible.__name__.__eq__, ["DivisionImpossible"], true]
    - [DEN007, decimal.DivisionUndefined.__name__.__eq__, ["DivisionUndefined"], true]
    - [DEN008, decimal.FloatOperation.__name__.__eq__, ["FloatOperation"], true]

table decimal_extra469.exception_modules:
  description: "decimal exception class __module__ identity checks"
  kind: python_call_eq
  category: exception_identity
  id_prefix: DEM

  columns: [id, function, args, expected]
  rows:
    - [DEM001, decimal.Clamped.__module__.__eq__, ["decimal"], true]

table decimal_extra469.exception_bases:
  description: "decimal exception class __bases__[0] inheritance checks"
  kind: python_call_eq
  category: exception_identity
  id_prefix: DEB

  columns: [id, function, args, expected]
  rows:
    - [DEB001, "decimal.Clamped.__bases__[0].__name__.__eq__", ["DecimalException"], true]
    - [DEB002, "decimal.Rounded.__bases__[0].__name__.__eq__", ["DecimalException"], true]
    - [DEB003, "decimal.Subnormal.__bases__[0].__name__.__eq__", ["DecimalException"], true]
    - [DEB004, "decimal.Inexact.__bases__[0].__name__.__eq__", ["DecimalException"], true]
    - [DEB005, "decimal.ConversionSyntax.__bases__[0].__name__.__eq__", ["InvalidOperation"], true]
    - [DEB006, "decimal.DivisionImpossible.__bases__[0].__name__.__eq__", ["InvalidOperation"], true]
    - [DEB007, "decimal.DivisionUndefined.__bases__[0].__name__.__eq__", ["InvalidOperation"], true]
