spec: _pickle_extra
version: ">=3.9"
backend: python_module(_pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl, pickle_extra.zspec.zsdl, and _pickle.zspec.zsdl."
    - "_pickle is the C accelerator for the pickle stdlib module."
    - "_pickle.Pickler.__name__ == 'Pickler'; _pickle.Pickler.__module__ == 'pickle' (public module name)."
    - "_pickle.Unpickler.__name__ == 'Unpickler'; _pickle.Unpickler.__module__ == 'pickle'."
    - "_pickle.PickleError.__name__ == 'PickleError'; base class is Exception."
    - "_pickle.PicklingError.__name__ == 'PicklingError'; base class is PickleError."
    - "_pickle.UnpicklingError.__name__ == 'UnpicklingError'; base class is PickleError."
    - "All five names and all hierarchy links are verified against the C extension directly."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — Pickler and Unpickler
# ---------------------------------------------------------------------------

invariant _pickle_extra.Pickler.name:
  description: "_pickle.Pickler.__name__ == 'Pickler'"
  category: classnames
  kind: python_call_eq
  function: Pickler.__name__.__eq__
  args: ["Pickler"]
  expected: true

invariant _pickle_extra.Unpickler.name:
  description: "_pickle.Unpickler.__name__ == 'Unpickler'"
  category: classnames
  kind: python_call_eq
  function: Unpickler.__name__.__eq__
  args: ["Unpickler"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ checks — Pickler and Unpickler report 'pickle', not '_pickle'
# CPython sets __module__ to the public module name for correct pickling/repr.
# ---------------------------------------------------------------------------

invariant _pickle_extra.Pickler.module:
  description: "_pickle.Pickler.__module__ == 'pickle' (public module name, not '_pickle')"
  category: classnames
  kind: python_call_eq
  function: Pickler.__module__.__eq__
  args: ["pickle"]
  expected: true

invariant _pickle_extra.Unpickler.module:
  description: "_pickle.Unpickler.__module__ == 'pickle' (public module name, not '_pickle')"
  category: classnames
  kind: python_call_eq
  function: Unpickler.__module__.__eq__
  args: ["pickle"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class __name__ checks
# ---------------------------------------------------------------------------

invariant _pickle_extra.PickleError.name:
  description: "_pickle.PickleError.__name__ == 'PickleError'"
  category: classnames
  kind: python_call_eq
  function: PickleError.__name__.__eq__
  args: ["PickleError"]
  expected: true

invariant _pickle_extra.PicklingError.name:
  description: "_pickle.PicklingError.__name__ == 'PicklingError'"
  category: classnames
  kind: python_call_eq
  function: PicklingError.__name__.__eq__
  args: ["PicklingError"]
  expected: true

invariant _pickle_extra.UnpicklingError.name:
  description: "_pickle.UnpicklingError.__name__ == 'UnpicklingError'"
  category: classnames
  kind: python_call_eq
  function: UnpicklingError.__name__.__eq__
  args: ["UnpicklingError"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — PickleError inherits from Exception
# ---------------------------------------------------------------------------

invariant _pickle_extra.PickleError.base:
  description: "_pickle.PickleError.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: PickleError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Exception hierarchy — PicklingError and UnpicklingError inherit from PickleError
# ---------------------------------------------------------------------------

table _pickle_extra.pickling_error_bases:
  kind: python_call_eq
  category: hierarchy
  id_prefix: base

  columns: [id, function, args, method, expected]
  rows:
    - [PicklingError,   PicklingError.__bases__.__getitem__,   [0], __name__, "PickleError"]
    - [UnpicklingError, UnpicklingError.__bases__.__getitem__, [0], __name__, "PickleError"]

# ---------------------------------------------------------------------------
# Metatype — exception classes are class objects (type instances)
# ---------------------------------------------------------------------------

table _pickle_extra.exception_metatypes:
  kind: python_call_eq
  category: classnames
  id_prefix: metatype

  columns: [id, function, args, expected]
  rows:
    - [PickleError,     PickleError.__class__.__name__.__eq__,     ["type"], true]
    - [PicklingError,   PicklingError.__class__.__name__.__eq__,   ["type"], true]
    - [UnpicklingError, UnpicklingError.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# Pickler and Unpickler are class objects (type instances)
# ---------------------------------------------------------------------------

table _pickle_extra.pickler_metatypes:
  kind: python_call_eq
  category: classnames
  id_prefix: pickler_metatype

  columns: [id, function, args, expected]
  rows:
    - [Pickler,   Pickler.__class__.__name__.__eq__,   ["type"], true]
    - [Unpickler, Unpickler.__class__.__name__.__eq__, ["type"], true]
