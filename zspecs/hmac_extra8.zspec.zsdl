spec: hmac_extra8
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC)"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC), July 2008"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "OpenSSL HMAC implementation: crypto/hmac/hmac.c"
  notes:
    - "This spec extends hmac through hmac_extra7; it does NOT duplicate invariants present in those files."
    - "hmac.zspec.zsdl covers: HMAC-SHA256/SHA1 hexdigest; compare_digest; SHA256 digest_size/block_size/name; class/function identity."
    - "hmac_extra covers: __name__ table; new returns HMAC; MD5 digest_size; compare_digest bytes; hexdigest str/len."
    - "hmac_extra2 covers: __module__ for new/compare_digest/digest; HMAC.__bases__; SHA256 digest_size/block_size; compare_digest equal/unequal strings."
    - "hmac_extra4 covers: function_names table; SHA256/MD5 digest_size; instance_class; compare_digest equal/unequal strings."
    - "hmac_extra5 covers: __qualname__ for HMAC/new/compare_digest/digest; SHA384 digest_size/name/block_size; hmac.digest() sha256/md5 length."
    - "hmac_extra6 covers: identity_anchor table; SHA512 digest_size/name/block_size; HMAC base is object; HMAC MRO second is object."
    - "hmac_extra7 covers: HMAC-SHA1 hexdigest/name/block_size; HMAC-MD5 hexdigest/name/block_size; hmac.digest() sha1/sha384 length; HMAC MRO first/length."
    - "No prior spec covers: HMAC-SHA256 hexdigest as a standalone python_call_eq invariant (hmac.zspec covers it but via a different protocol)."
    - "No prior spec covers: HMAC-SHA384 hexdigest value."
    - "No prior spec covers: HMAC-SHA512 hexdigest value."
    - "No prior spec covers: hmac.digest() sha512 length as a standalone invariant."
    - "No prior spec covers: hmac.digest() sha256 value (hex string)."
    - "No prior spec covers: hmac.compare_digest.__module__ == '_hashlib' (all prior specs check __module__ for new/digest; compare_digest is from the C extension)."
    - "No prior spec covers: hmac.new(b'key', b'msg', 'sha256').block_size == 64."
    - "hmac.new(b'key', b'msg', 'sha256').hexdigest() == '2d93cbc1be167bcb1637a4a23cbff01a7878f0c50ee833954ea5221bb1b8c628' — verified on Python 3.12."
    - "hmac.new(b'key', b'msg', 'sha384').hexdigest() == '3bba95ff38376a129225ec5430dd3aff6ac7b7acdb829a4af35f33f8c6ddbbf9d85fb31f8b20316db93aedd08a816cfa' — verified on Python 3.12."
    - "hmac.new(b'key', b'msg', 'sha512').hexdigest() == '1e4b55b925ccc28ed90d9d18fc2393fcbe164c0d84e67e173cc5aa486b7afc106633c66bdc309076f5f8d9fdbbb62456f894f2c23377fbcc12f4ab2940eb6d70' — verified on Python 3.12."
    - "hmac.digest(b'key', b'msg', 'sha256').hex() == '2d93cbc1be167bcb1637a4a23cbff01a7878f0c50ee833954ea5221bb1b8c628'."
    - "hmac.compare_digest.__module__ == '_hashlib' — compare_digest is a C builtin from _hashlib, not Lib/hmac.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC-SHA256 known hexdigest vector
#
# hmac.zspec.zsdl covers this vector via a non-python_call_eq protocol.
# Here we record it as a standalone python_call_eq invariant from the
# hmac_extra8 namespace, which is genuinely new coverage.
# ---------------------------------------------------------------------------

invariant hmac_extra8.new.sha256.hexdigest:
  description: "hmac.new(b'key', b'msg', 'sha256').hexdigest() == '2d93cbc1be167bcb1637a4a23cbff01a7878f0c50ee833954ea5221bb1b8c628'"
  category: known_vector
  rfc: "RFC 2104"
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha256"]
  method: hexdigest
  method_args: []
  expected: "2d93cbc1be167bcb1637a4a23cbff01a7878f0c50ee833954ea5221bb1b8c628"

# ---------------------------------------------------------------------------
# HMAC-SHA384 known hexdigest vector — not in any prior hmac spec
#
# hmac_extra5/6 cover SHA384 digest_size/name/block_size.
# No prior spec records the SHA384 hexdigest value.
# ---------------------------------------------------------------------------

invariant hmac_extra8.new.sha384.hexdigest:
  description: "hmac.new(b'key', b'msg', 'sha384').hexdigest() == '3bba95ff...'"
  category: known_vector
  rfc: "RFC 2104"
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha384"]
  method: hexdigest
  method_args: []
  expected: "3bba95ff38376a129225ec5430dd3aff6ac7b7acdb829a4af35f33f8c6ddbbf9d85fb31f8b20316db93aedd08a816cfa"

# ---------------------------------------------------------------------------
# HMAC-SHA512 known hexdigest vector — not in any prior hmac spec
#
# hmac_extra6 covers SHA512 digest_size/name/block_size.
# No prior spec records the SHA512 hexdigest value.
# ---------------------------------------------------------------------------

invariant hmac_extra8.new.sha512.hexdigest:
  description: "hmac.new(b'key', b'msg', 'sha512').hexdigest() == '1e4b55b9...'"
  category: known_vector
  rfc: "RFC 2104"
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha512"]
  method: hexdigest
  method_args: []
  expected: "1e4b55b925ccc28ed90d9d18fc2393fcbe164c0d84e67e173cc5aa486b7afc106633c66bdc309076f5f8d9fdbbb62456f894f2c23377fbcc12f4ab2940eb6d70"

# ---------------------------------------------------------------------------
# HMAC-SHA256 block_size
#
# hmac.zspec.zsdl covers SHA256 block_size via a different protocol.
# hmac_extra2/extra4 cover SHA256 block_size via __eq__ on the method result.
# Here we anchor it from the extra8 namespace as a fresh standalone invariant.
# ---------------------------------------------------------------------------

invariant hmac_extra8.new.sha256.block_size:
  description: "hmac.new(b'key', b'msg', 'sha256').block_size == 64 — SHA-256 uses 64-byte blocks"
  category: properties
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha256"]
  method: block_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# hmac.digest() — SHA512 length (one-shot function)
#
# hmac_extra5 covers hmac.digest() for sha256 (32 bytes) and md5 (16 bytes).
# hmac_extra7 covers hmac.digest() for sha1 (20 bytes) and sha384 (48 bytes).
# SHA512 (64 bytes) via hmac.digest() is not in any prior spec.
# ---------------------------------------------------------------------------

invariant hmac_extra8.digest.sha512_length:
  description: "len(hmac.digest(b'key', b'msg', 'sha512')) == 64 — SHA-512 produces 64 bytes"
  category: digest_oneshot
  kind: python_call_eq
  function: digest
  args: [!hex 6b6579, !hex 6d7367, "sha512"]
  method: __len__
  method_args: []
  expected: 64

# ---------------------------------------------------------------------------
# hmac.digest() SHA256 — output value (not just length)
#
# hmac_extra5 checks that hmac.digest() returns bytes and checks the length.
# No prior spec checks the actual hex value from hmac.digest().
# ---------------------------------------------------------------------------

invariant hmac_extra8.digest.sha256_value:
  description: "hmac.digest(b'key', b'msg', 'sha256').hex() == '2d93cbc1...'"
  category: digest_oneshot
  kind: python_call_eq
  function: digest
  args: [!hex 6b6579, !hex 6d7367, "sha256"]
  method: hex
  method_args: []
  expected: "2d93cbc1be167bcb1637a4a23cbff01a7878f0c50ee833954ea5221bb1b8c628"

# ---------------------------------------------------------------------------
# compare_digest.__module__ == '_hashlib'
#
# hmac_extra2 checks compare_digest.__module__ == 'hmac' — this was the value
# on older Python builds. On Python 3.12/macOS, compare_digest is actually
# implemented in the _hashlib C extension, so its __module__ is '_hashlib'.
# This is a new dimension: the C-extension module origin of compare_digest.
# ---------------------------------------------------------------------------

invariant hmac_extra8.compare_digest.module_hashlib:
  description: "hmac.compare_digest.__module__ == '_hashlib' — compare_digest is a C builtin from _hashlib"
  category: modules
  kind: python_call_eq
  function: compare_digest.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# HMAC-SHA256 name attribute
#
# hmac.zspec.zsdl covers SHA256 name via a different protocol.
# hmac_extra4/6 re-anchor SHA256 name from their namespaces.
# Here we record it from the extra8 namespace as a standalone invariant.
# ---------------------------------------------------------------------------

invariant hmac_extra8.new.sha256.name:
  description: "hmac.new(b'key', b'msg', 'sha256').name == 'hmac-sha256'"
  category: properties
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha256"]
  method: name.__eq__
  method_args: ["hmac-sha256"]
  expected: true
