spec: is_typedarray
version: ">=1.0.0"
backend: node(is-typedarray)

docs: https://github.com/hughsk/is-typedarray#readme

provenance:
  derived_from:
    - "is-typedarray README — https://github.com/hughsk/is-typedarray#readme"
    - "ECMA-262 §22.2 — TypedArray objects"
    - "Test vectors verified with is-typedarray via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "is-typedarray source"
  notes:
    - "Detects whether an argument is one of the JS TypedArray subclasses (Uint8Array, Int16Array, ...)."
    - "Install: npm install is-typedarray"
    - "v1 CJS; module export IS the predicate (loose by default), with .strict and .loose attached."
    - "Note: returns undefined (not false) for plain objects/arrays/null — falsy semantics rather than strict boolean."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant is_typedarray.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant is_typedarray.has_strict:
  description: ".strict variant exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "strict.constructor.name"}
  expected: "Function"

invariant is_typedarray.has_loose:
  description: ".loose variant exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "loose.constructor.name"}
  expected: "Function"

invariant is_typedarray.module_arity:
  description: "Module function declared length is 1"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant is_typedarray.plain_array_falsy:
  description: "Plain Array is not a TypedArray (returns falsy/undefined)"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [[1, 2, 3]]
  chain: []
  expected: null

invariant is_typedarray.plain_object_falsy:
  description: "Plain object is not a TypedArray (returns falsy/undefined)"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{}]
  chain: []
  expected: null

invariant is_typedarray.string_falsy:
  description: "String is not a TypedArray"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: ["hello"]
  chain: []
  expected: null

invariant is_typedarray.number_falsy:
  description: "Number is not a TypedArray"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [42]
  chain: []
  expected: null
