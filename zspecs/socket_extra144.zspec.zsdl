spec: socket_extra144
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra143.zspec.zsdl — covers socket.socket.connect/bind/listen/accept/recv __qualname__ string equality / __qualname__ length grouping (bind/recv=11, listen/accept=13, connect=14) / accept/__class__.__name__=='function' vs connect/bind/listen/recv/__class__.__name__=='method_descriptor' (table + invariants)."
    - "socket_extra142.zspec.zsdl — covers socket.AF_INET/AF_INET6 enum member .name values and lengths / SOCK_STREAM/SOCK_DGRAM .name values and lengths / AddressFamily/SocketKind class __name__ values and lengths and __bases__[0].__name__ == 'IntEnum' / socket.error/__name__/__len__()==7 / socket.timeout/__name__/__len__()==12 / timeout/__bases__[0].__name__=='OSError' (table + invariants)."
    - "socket_extra141.zspec.zsdl — covers socket.socket/__doc__/__len__()==58 / gethostname/__doc__/__len__()==54 / gethostbyname/__doc__/__len__()==106 / getaddrinfo/__doc__/__len__()==658 / setdefaulttimeout/__doc__/__len__()==224 / getdefaulttimeout/__doc__/__len__()==232 / __doc__.__class__.__name__ checks."
    - "socket_extra140.zspec.zsdl — covers socket.socket method_descriptor __doc__ lengths (recv/send/bind/connect/listen/setsockopt/getsockopt/sendall/recvfrom/accept) / socket.socket method __qualname__ lengths."
    - "socket_extra139.zspec.zsdl — covers socket.socket.__eq__/__hash__ qualnames / socket.socket.family and type as property descriptors / socket.socket class __name__/__module__/__mro__ / socket.getfqdn and create_connection __doc__ lengths."
    - "socket_extra138.zspec.zsdl — covers socket.socket.__doc__ identity / __spec__ and __loader__ attribute identity / herror and gaierror exception class identity / getfqdn and create_connection qualnames."
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO class identity."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values."
    - "socket_extra97.zspec.zsdl — covers socket.socket.send/sendall/fileno __qualname__.__eq__ / socket.socket.__init__/accept/makefile/close __class__.__name__=='function'."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout __class__.__name__=='builtin_function_or_method'."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra143."
    - "Wave 305 theme: socket.socket class identity at a deeper level — socket.socket.__module__.__eq__('socket') / __module__.__len__()==6 / socket.socket.__qualname__.__eq__('socket') / __qualname__.__len__()==6 / socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') / __dict__.__class__.__name__.__len__()==12 / socket.socket.__mro__.__len__()==3 / AF_INET.__class__.__name__.__eq__('AddressFamily') / SOCK_STREAM.__class__.__name__.__eq__('SocketKind')."
    - "socket.socket.__module__ == 'socket' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__qualname__ == 'socket' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__.__len__() == 3 (socket.socket -> _socket.socket -> object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__name__ == 'socket' (the C-level _socket.socket class, NOT 'object'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' (len 10). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET6.__class__.__name__ == 'AddressFamily' (same as AF_INET; both AddressFamily members). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' (same as SOCK_STREAM; both SocketKind members). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.__module__ is 'socket' (6 chars) and socket.socket.__qualname__ is also 'socket' (6 chars). Both the module and the qualname are the plain string 'socket' — the Python-level socket.socket class reports its module as 'socket' and its qualname as 'socket' (not 'socket.socket'), because the class name within the module is 'socket', making the qualname just 'socket'."
    - "Note: socket.socket.__bases__[0].__name__ is 'socket' (6 chars), referring to the C-level _socket.socket class (from Modules/socketmodule.c). This is NOT 'object' — socket.socket has a two-level inheritance chain: socket.socket -> _socket.socket -> object. The MRO therefore has 3 entries. This is an important architectural detail: the public socket.socket adds Python-level methods (accept, makefile, etc.) on top of the C-level _socket.socket."
    - "Note: socket.socket.__dict__.__class__.__name__ is 'mappingproxy' (12 chars). Class __dict__ attributes in Python are always exposed as mappingproxy objects (read-only views of the underlying dict), preventing external code from modifying the class namespace directly."
    - "Note: socket.AF_INET.__class__.__name__ is 'AddressFamily' (13 chars) — the enum class name, not 'int' or 'IntEnum'. IntEnum members report their __class__.__name__ as the enum class name (AddressFamily or SocketKind), not as the base type. extra96 anchors AF_INET class names via a different path; this spec anchors the IntEnum member __class__.__name__ values."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__module__.__eq__('socket')
# socket.socket.__module__.__len__()==6
# socket.socket.__qualname__.__eq__('socket')
# socket.socket.__qualname__.__len__()==6
#
# Wave 305 theme: socket.socket class __module__ and __qualname__ both equal 'socket'.
#
# socket.socket's __module__ and __qualname__ are both the plain string 'socket'
# (6 chars). The __qualname__ is not 'socket.socket' but just 'socket' because
# the class is named 'socket' within the 'socket' module. extra139 anchors
# socket.socket.__name__/__module__/__mro__; no prior socket spec anchors
# __module__ and __qualname__ equality strings as a table under sockclass144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra144.socket_class_module_and_qualname:
  description: "socket.socket.__module__.__eq__('socket')==True / __module__.__len__()==6 / socket.socket.__qualname__.__eq__('socket')==True / __qualname__.__len__()==6 — both __module__ and __qualname__ are the plain string 'socket' (6 chars); qualname is not 'socket.socket' because the class named 'socket' in module 'socket' gives qualname 'socket'; extra139 anchors __name__/__module__/__mro__; first sockclass144 anchor for __module__ and __qualname__ equality strings"
  kind: python_call_eq
  category: identity
  id_prefix: sockclass144

  columns: [id, function, args, expected, description]
  rows:
    - [socket_module_eq,      socket.__module__.__eq__,      ["socket"], true, "socket.socket.__module__ == 'socket' (6 chars; Python-level class in the socket module)"]
    - [socket_module_len,     socket.__module__.__len__,     [],         6,    "socket.socket.__module__.__len__() is 6 ('socket' = 6 chars)"]
    - [socket_qualname_eq,    socket.__qualname__.__eq__,    ["socket"], true, "socket.socket.__qualname__ == 'socket' (6 chars; not 'socket.socket' — class name is 'socket')"]
    - [socket_qualname_len,   socket.__qualname__.__len__,   [],         6,    "socket.socket.__qualname__.__len__() is 6 ('socket' = 6 chars; same length as __module__)"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy')
# socket.socket.__dict__.__class__.__name__.__len__()==12
# socket.socket.__mro__.__len__()==3
# socket.socket.__bases__[0].__name__.__eq__('socket')
#
# Wave 305 theme: socket.socket __dict__ is mappingproxy; MRO has 3 entries.
#
# socket.socket.__dict__ is a mappingproxy (12 chars). The MRO has 3 entries:
# socket.socket -> _socket.socket -> object. socket.socket.__bases__[0].__name__
# is 'socket' (the C-level _socket.socket class), NOT 'object'. No prior socket
# spec anchors socket.socket.__dict__.__class__.__name__ or the 3-entry MRO
# as a table under sockclass144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra144.socket_class_dict_and_mro:
  description: "socket.socket.__dict__/__class__.__name__.__eq__('mappingproxy')==True / __class__.__name__.__len__()==12 / socket.socket.__mro__/__len__()==3 / socket.socket.__bases__[0].__name__.__eq__('socket')==True — __dict__ is a 12-char mappingproxy (read-only class namespace view); MRO has 3 entries (socket.socket, _socket.socket, object); __bases__[0].__name__ is 'socket' (the C-level _socket.socket class, not 'object'); no prior socket spec anchors these under sockclass144"
  kind: python_call_eq
  category: identity
  id_prefix: sockclass144

  columns: [id, function, args, expected, description]
  rows:
    - [dict_class_mappingproxy,  socket.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "socket.socket.__dict__.__class__.__name__ == 'mappingproxy' (read-only class namespace view)"]
    - [dict_class_name_len,      socket.__dict__.__class__.__name__.__len__, [],              12,   "socket.socket.__dict__.__class__.__name__.__len__() is 12 ('mappingproxy' = 12 chars)"]
    - [mro_len_3,                socket.__mro__.__len__,                    [],              3,    "socket.socket.__mro__.__len__() is 3 (socket.socket -> _socket.socket -> object)"]
    - [bases_0_name_socket,      "socket.__bases__[0].__name__.__eq__",    ["socket"],      true, "socket.socket.__bases__[0].__name__ == 'socket' (C-level _socket.socket class; NOT 'object')"]

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily')
# socket.AF_INET.__class__.__name__.__len__()==13
# socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind')
# socket.SOCK_STREAM.__class__.__name__.__len__()==10
# socket.AF_INET6.__class__.__name__.__eq__('AddressFamily')
# socket.SOCK_DGRAM.__class__.__name__.__eq__('SocketKind')
#
# Wave 305 theme: IntEnum members report __class__.__name__ as their enum class name.
#
# AF_INET and AF_INET6 are AddressFamily members (class name 13 chars).
# SOCK_STREAM and SOCK_DGRAM are SocketKind members (class name 10 chars).
# extra96 anchors AF_INET/SOCK_STREAM member class names via a different path;
# no prior socket spec anchors all four together via __class__.__name__ as a
# table under sockclass144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra144.IntEnum_member_class_names:
  description: "socket.AF_INET/__class__.__name__.__eq__('AddressFamily')==True / __class__.__name__.__len__()==13 / SOCK_STREAM/__class__.__name__.__eq__('SocketKind')==True / __class__.__name__.__len__()==10 / AF_INET6/__class__.__name__.__eq__('AddressFamily')==True / SOCK_DGRAM/__class__.__name__.__eq__('SocketKind')==True — IntEnum members report __class__.__name__ as their enum class name (not 'int' or 'IntEnum'); AddressFamily (13) is 3 chars longer than SocketKind (10); extra96 anchors via different path; first sockclass144 anchor for all four via __class__.__name__"
  kind: python_call_eq
  category: identity
  id_prefix: sockclass144

  columns: [id, function, args, expected, description]
  rows:
    - [AF_INET_class_AddressFamily,  AF_INET.__class__.__name__.__eq__,   ["AddressFamily"], true, "socket.AF_INET.__class__.__name__ == 'AddressFamily' (13 chars; AddressFamily IntEnum member)"]
    - [AF_INET_class_name_len,       AF_INET.__class__.__name__.__len__,  [],                13,   "socket.AF_INET.__class__.__name__.__len__() is 13 ('AddressFamily' = 13 chars)"]
    - [SOCK_STREAM_class_SocketKind, SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"],  true, "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' (10 chars; SocketKind IntEnum member)"]
    - [SOCK_STREAM_class_name_len,   SOCK_STREAM.__class__.__name__.__len__, [],             10,   "socket.SOCK_STREAM.__class__.__name__.__len__() is 10 ('SocketKind' = 10 chars)"]
    - [AF_INET6_class_AddressFamily, AF_INET6.__class__.__name__.__eq__,  ["AddressFamily"], true, "socket.AF_INET6.__class__.__name__ == 'AddressFamily' (same as AF_INET; both AddressFamily members)"]
    - [SOCK_DGRAM_class_SocketKind,  SOCK_DGRAM.__class__.__name__.__eq__, ["SocketKind"],  true, "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' (same as SOCK_STREAM; both SocketKind members)"]

# ---------------------------------------------------------------------------
# socket.socket.__module__.__eq__('socket') — standalone
#
# socket.socket.__module__ is 'socket' (6 chars). The Python-level socket.socket
# class reports itself as belonging to the 'socket' module (without underscore),
# even though the C-level base class _socket.socket has __module__ == '_socket'.
# The public socket.socket class is defined in Lib/socket.py with the 'socket'
# module identity, making it easier for users to identify and import.
# extra139 anchors socket.socket.__module__ broadly; no prior socket spec anchors
# socket.__module__.__eq__('socket') as a standalone under sockclass144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra144.socket_module_eq_socket:
  description: "socket.socket.__module__.__eq__('socket') == True — 'socket' (6 chars); Python-level class reports module as 'socket' (without underscore); C-level base _socket.socket reports '_socket'; Lib/socket.py defines the public class; extra139 anchors broadly; first standalone under sockclass144"
  category: identity
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__qualname__.__eq__('socket') — standalone
#
# socket.socket.__qualname__ is 'socket' (6 chars), not 'socket.socket'. The
# qualname is computed as the class name within the module, and since the class
# is named 'socket' (not 'Socket' or 'SocketClient'), its qualname is just
# 'socket'. This is an unusual case where the module name ('socket') and the
# class qualname ('socket') are the same string. No prior socket spec anchors
# socket.socket.__qualname__.__eq__('socket') as a standalone under sockclass144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra144.socket_qualname_eq_socket:
  description: "socket.socket.__qualname__.__eq__('socket') == True — 'socket' (6 chars); qualname is not 'socket.socket' because the class named 'socket' in module 'socket' gives qualname 'socket'; unusual case where module name and class qualname are the same string; no prior socket spec anchors this as a standalone; first standalone under sockclass144"
  category: identity
  kind: python_call_eq
  function: socket.__qualname__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# socket.socket.__dict__.__class__.__name__ is 'mappingproxy' (12 chars). All
# Python class __dict__ attributes are exposed as mappingproxy objects — read-only
# views that prevent external code from modifying the class namespace directly
# (without going through type.__setattr__ or similar mechanisms). The 12-char
# 'mappingproxy' name is the same for all Python classes. No prior socket spec
# anchors socket.socket.__dict__.__class__.__name__ == 'mappingproxy' as a
# standalone under sockclass144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra144.socket_dict_class_mappingproxy:
  description: "socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') == True — 'mappingproxy' (12 chars); all Python class __dict__ attributes are mappingproxy (read-only view of class namespace); prevents direct external modification; same for all classes; no prior socket spec anchors this as a standalone; first standalone under sockclass144"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__mro__.__len__()==3 — standalone
#
# socket.socket.__mro__.__len__() is 3. The MRO is: (socket.socket, _socket.socket,
# object). The 3-entry MRO reflects the two-level inheritance: the Python-level
# socket.socket (Lib/socket.py) extends the C-level _socket.socket (socketmodule.c),
# which in turn extends object. This two-level architecture separates Python-level
# convenience methods (accept, makefile) from C-level socket operations (connect,
# bind, recv). No prior socket spec anchors socket.socket.__mro__.__len__()==3
# as a standalone under sockclass144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra144.socket_mro_len_3:
  description: "socket.socket.__mro__.__len__() == 3 — MRO is (socket.socket, _socket.socket, object); 3 entries reflecting two-level inheritance; Python-level socket.socket extends C-level _socket.socket; separates Python convenience methods from C-level socket operations; no prior socket spec anchors this as a standalone; first standalone under sockclass144"
  category: identity
  kind: python_call_eq
  function: socket.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# socket.AF_INET.__class__.__name__.__eq__('AddressFamily') — standalone
#
# socket.AF_INET.__class__.__name__ is 'AddressFamily' (13 chars). IntEnum members
# report their __class__.__name__ as the name of the enum class they belong to
# (AddressFamily), not as 'int' or 'IntEnum'. This is because the actual type
# of AF_INET is AddressFamily (a subclass of IntEnum and int), and __class__
# returns the most-derived type. extra96 anchors AF_INET class names via a
# different path (type(AF_INET).__name__); no prior socket spec anchors
# AF_INET.__class__.__name__.__eq__('AddressFamily') as a standalone under
# sockclass144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra144.AF_INET_class_AddressFamily:
  description: "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — 'AddressFamily' (13 chars); IntEnum member reports its enum class name (not 'int' or 'IntEnum'); __class__ returns most-derived type; extra96 anchors via type(AF_INET).__name__ path; first standalone for AF_INET.__class__.__name__ equality under sockclass144"
  category: identity
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') — standalone
#
# socket.SOCK_STREAM.__class__.__name__ is 'SocketKind' (10 chars). Like AF_INET,
# SOCK_STREAM is an IntEnum member that reports its enum class name via __class__
# .__name__. SocketKind (10 chars) is 3 chars shorter than AddressFamily (13 chars).
# SOCK_STREAM is the most common socket type for TCP connections. No prior socket
# spec anchors SOCK_STREAM.__class__.__name__.__eq__('SocketKind') as a standalone
# under sockclass144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra144.SOCK_STREAM_class_SocketKind:
  description: "socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') == True — 'SocketKind' (10 chars); IntEnum member reports its enum class name (not 'int' or 'IntEnum'); SocketKind (10) is 3 chars shorter than AddressFamily (13); SOCK_STREAM is the most common socket type for TCP; no prior socket spec anchors this as a standalone; first standalone under sockclass144"
  category: identity
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

