spec: functools_extra273
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a pure Python decorator."
    - "functools.cache.__class__.__name__ == 'function' — cache is a pure Python wrapper around lru_cache."
    - "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a pure Python function."
    - "functools.singledispatchmethod.__class__.__name__ == 'type' — singledispatchmethod is a class (type), unlike the others."
    - "lru_cache.__name__ (9) == module name 'functools'[-9:] length — both are 9."
    - "singledispatch.__name__ (14) < singledispatchmethod.__name__ (20) — method variant is longer."
    - "cache.__name__ (5) is shortest in spec."
    - "All four have __module__ == 'functools' (len=9)."
    - "All qualnames equal names (module-level, no nesting)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.lru_cache and functools.cache decorator identity
#
# Both are pure Python functions with __module__ == 'functools'.
# cache.__name__ (5) is shortest in spec.
# lru_cache.__name__ (9) == len('functools').
# ---------------------------------------------------------------------------

table functools_extra273.lru_cache_cache_identity:
  description: "functools.lru_cache(9) and cache(5) decorator identity — both pure Python functions in functools(9); lru_cache(9) name len equals module len; cache(5) shortest name in spec; all qualnames equal names; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex273lc

  columns: [id, function, args, expected, description]
  rows:
    - [lc_name_eq,         lru_cache.__name__.__eq__,                   ["lru_cache"],                  true, "functools.lru_cache.__name__ == 'lru_cache'; verified with Python 3.14.3"]
    - [lc_name_len,        lru_cache.__name__.__len__,                  [],                             9,    "functools.lru_cache.__name__.__len__() == 9 — equals module name 'functools' length; verified with Python 3.14.3"]
    - [lc_qn_eq,           lru_cache.__qualname__.__eq__,               ["lru_cache"],                  true, "functools.lru_cache.__qualname__ == 'lru_cache' — qualname equals name; verified with Python 3.14.3"]
    - [lc_mod_eq,          lru_cache.__module__.__eq__,                 ["functools"],                  true, "functools.lru_cache.__module__ == 'functools'; verified with Python 3.14.3"]
    - [lc_mod_len,         lru_cache.__module__.__len__,                [],                             9,    "functools.lru_cache.__module__.__len__() == 9; verified with Python 3.14.3"]
    - [lc_cls_eq,          lru_cache.__class__.__name__.__eq__,         ["function"],                   true, "functools.lru_cache.__class__.__name__ == 'function' — pure Python decorator; verified with Python 3.14.3"]
    - [ca_name_eq,         cache.__name__.__eq__,                       ["cache"],                      true, "functools.cache.__name__ == 'cache'; verified with Python 3.14.3"]
    - [ca_name_len,        cache.__name__.__len__,                      [],                             5,    "functools.cache.__name__.__len__() == 5 — shortest name in spec; verified with Python 3.14.3"]
    - [ca_qn_eq,           cache.__qualname__.__eq__,                   ["cache"],                      true, "functools.cache.__qualname__ == 'cache' — qualname equals name; verified with Python 3.14.3"]
    - [ca_mod_eq,          cache.__module__.__eq__,                     ["functools"],                  true, "functools.cache.__module__ == 'functools'; verified with Python 3.14.3"]
    - [ca_cls_eq,          cache.__class__.__name__.__eq__,             ["function"],                   true, "functools.cache.__class__.__name__ == 'function' — pure Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.singledispatch and functools.singledispatchmethod identity
#
# singledispatch is a plain Python function.
# singledispatchmethod is a class (type) — different from the others.
# singledispatch.__name__ (14) < singledispatchmethod.__name__ (20).
# singledispatchmethod is longest name in spec.
# ---------------------------------------------------------------------------

table functools_extra273.singledispatch_singledispatchmethod_identity:
  description: "functools.singledispatch(14) and singledispatchmethod(20) identity — singledispatch is a pure Python function; singledispatchmethod is a class(type); singledispatchmethod(20) longest name in spec; all in functools(9); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex273sd

  columns: [id, function, args, expected, description]
  rows:
    - [sd_name_eq,         singledispatch.__name__.__eq__,              ["singledispatch"],              true, "functools.singledispatch.__name__ == 'singledispatch'; verified with Python 3.14.3"]
    - [sd_name_len,        singledispatch.__name__.__len__,             [],                             14,   "functools.singledispatch.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [sd_qn_eq,           singledispatch.__qualname__.__eq__,          ["singledispatch"],              true, "functools.singledispatch.__qualname__ == 'singledispatch' — qualname equals name; verified with Python 3.14.3"]
    - [sd_mod_eq,          singledispatch.__module__.__eq__,            ["functools"],                  true, "functools.singledispatch.__module__ == 'functools'; verified with Python 3.14.3"]
    - [sd_cls_eq,          singledispatch.__class__.__name__.__eq__,    ["function"],                   true, "functools.singledispatch.__class__.__name__ == 'function' — pure Python function; verified with Python 3.14.3"]
    - [sm_name_eq,         singledispatchmethod.__name__.__eq__,        ["singledispatchmethod"],        true, "functools.singledispatchmethod.__name__ == 'singledispatchmethod'; verified with Python 3.14.3"]
    - [sm_name_len,        singledispatchmethod.__name__.__len__,       [],                             20,   "functools.singledispatchmethod.__name__.__len__() == 20 — longest name in spec; verified with Python 3.14.3"]
    - [sm_qn_eq,           singledispatchmethod.__qualname__.__eq__,    ["singledispatchmethod"],        true, "functools.singledispatchmethod.__qualname__ == 'singledispatchmethod' — qualname equals name; verified with Python 3.14.3"]
    - [sm_mod_eq,          singledispatchmethod.__module__.__eq__,      ["functools"],                  true, "functools.singledispatchmethod.__module__ == 'functools'; verified with Python 3.14.3"]
    - [sm_cls_eq,          singledispatchmethod.__class__.__name__.__eq__, ["type"],                    true, "functools.singledispatchmethod.__class__.__name__ == 'type' — singledispatchmethod is a class, unlike singledispatch which is a function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra273
# ---------------------------------------------------------------------------

invariant functools_extra273.lru_cache_is_pure_python_function:
  description: "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a pure Python decorator function, unlike e.g. reduce which is a C builtin; both lru_cache and cache are plain functions"
  category: identity
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra273.cache_name_is_shortest:
  description: "functools.cache.__name__.__len__() == 5 — shortest name in spec; shorter than lru_cache(9), singledispatch(14), singledispatchmethod(20)"
  category: identity
  kind: python_call_eq
  function: cache.__name__.__len__
  args: []
  expected: 5

invariant functools_extra273.singledispatchmethod_is_type:
  description: "functools.singledispatchmethod.__class__.__name__ == 'type' — singledispatchmethod is a class (descriptor), unlike singledispatch which is a plain function; only singledispatchmethod has __class__.__name__ == 'type' in this spec"
  category: identity
  kind: python_call_eq
  function: singledispatchmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra273.singledispatchmethod_name_is_longest:
  description: "functools.singledispatchmethod.__name__.__len__() == 20 — longest name in spec; singledispatch(14) + 'method'(6) = 20"
  category: identity
  kind: python_call_eq
  function: singledispatchmethod.__name__.__len__
  args: []
  expected: 20

invariant functools_extra273.lru_cache_name_len_equals_module_len:
  description: "functools.lru_cache.__name__.__len__() == 9 == functools.lru_cache.__module__.__len__() — lru_cache name length equals module name 'functools' length, both are 9"
  category: identity
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9
