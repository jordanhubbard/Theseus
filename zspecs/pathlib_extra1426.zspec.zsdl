spec: pathlib_extra1426
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec covers __format__ and __dir__ method type/presence for pathlib module classes. All pathlib classes in this batch (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath) have __format__.__class__.__name__=='method_descriptor' (inherited from object; pathlib classes are pure-Python but do not override __format__). None of the pathlib classes in this batch define '__format__' in their own __dict__. Similarly, all classes have __dir__.__class__.__name__=='method_descriptor' and none define '__dir__' in their own __dict__. All verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
    - "pathlib.PurePath.__format__.__class__.__name__=='method_descriptor' — PurePath is a pure-Python class that inherits __format__ from object without override. pathlib.PosixPath.__dict__.__contains__('__format__')==False — PosixPath (concrete class for POSIX paths) also does not define __format__ in its own dict. pathlib.Path.__dict__.__contains__('__dir__')==False — Path likewise inherits __dir__. All verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __format__ type and dict presence checks — extra1426
#
# pathlib.PurePath.__format__.__class__.__name__                   == 'method_descriptor'
# pathlib.PurePath.__dict__.__contains__('__format__')            == False
# pathlib.PurePosixPath.__format__.__class__.__name__              == 'method_descriptor'
# pathlib.PurePosixPath.__dict__.__contains__('__format__')       == False
# pathlib.Path.__format__.__class__.__name__                       == 'method_descriptor'
# pathlib.PosixPath.__dict__.__contains__('__format__')           == False
# ---------------------------------------------------------------------------

table pathlib_extra1426.pathlib_format_type:
  description: "pathlib class __format__ method type and __dict__ presence checks — wave 542 extra1426 theme. pathlib.PurePath.__format__.__class__.__name__=='method_descriptor' (PurePath is a pure-Python class but inherits __format__ from object without overriding it; the descriptor type is 'method_descriptor' for the C-level object.__format__). All pathlib classes in this batch (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath) follow the same pattern: __format__.__class__.__name__=='method_descriptor' and '__format__' not in own __dict__. pathlib.PureWindowsPath is always constructible as a class even on non-Windows platforms (though instantiation raises NotImplementedError on POSIX). All verified with Python 3.14.4."
  kind: python_call_eq
  category: format_introspection
  id_prefix: pl1426fm

  columns: [id, function, args, expected, description]
  rows:
    - [pl1426fm001, pathlib.PurePath.__format__.__class__.__name__.__eq__,         ["method_descriptor"], true,  "pathlib.PurePath.__format__.__class__.__name__ == 'method_descriptor' (inherits object.__format__); verified with Python 3.14.4"]
    - [pl1426fm002, pathlib.PurePath.__dict__.__contains__,                         ["__format__"],         false, "pathlib.PurePath.__dict__.__contains__('__format__') == False (not defined in own dict); verified with Python 3.14.4"]
    - [pl1426fm003, pathlib.PurePosixPath.__format__.__class__.__name__.__eq__,    ["method_descriptor"], true,  "pathlib.PurePosixPath.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426fm004, pathlib.PurePosixPath.__dict__.__contains__,                   ["__format__"],         false, "pathlib.PurePosixPath.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [pl1426fm005, pathlib.PureWindowsPath.__format__.__class__.__name__.__eq__,  ["method_descriptor"], true,  "pathlib.PureWindowsPath.__format__.__class__.__name__ == 'method_descriptor' (class always accessible; instantiation raises NotImplementedError on POSIX); verified with Python 3.14.4"]
    - [pl1426fm006, pathlib.PureWindowsPath.__dict__.__contains__,                 ["__format__"],         false, "pathlib.PureWindowsPath.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [pl1426fm007, pathlib.Path.__format__.__class__.__name__.__eq__,             ["method_descriptor"], true,  "pathlib.Path.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426fm008, pathlib.Path.__dict__.__contains__,                            ["__format__"],         false, "pathlib.Path.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [pl1426fm009, pathlib.PosixPath.__format__.__class__.__name__.__eq__,        ["method_descriptor"], true,  "pathlib.PosixPath.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426fm010, pathlib.PosixPath.__dict__.__contains__,                       ["__format__"],         false, "pathlib.PosixPath.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# pathlib class __dir__ type and dict presence checks — extra1426
#
# pathlib.PurePath.__dir__.__class__.__name__                   == 'method_descriptor'
# pathlib.PurePath.__dict__.__contains__('__dir__')            == False
# pathlib.Path.__dir__.__class__.__name__                       == 'method_descriptor'
# pathlib.Path.__dict__.__contains__('__dir__')                == False
# pathlib.PosixPath.__dir__.__class__.__name__                  == 'method_descriptor'
# pathlib.PurePosixPath.__dict__.__contains__('__dir__')       == False
# ---------------------------------------------------------------------------

table pathlib_extra1426.pathlib_dir_type:
  description: "pathlib class __dir__ method type and __dict__ presence checks — wave 542 extra1426 theme. pathlib.PurePath.__dir__.__class__.__name__=='method_descriptor' (PurePath inherits __dir__ from object without overriding it). All pathlib classes in this batch (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath) have __dir__.__class__.__name__=='method_descriptor' and none define '__dir__' in their own __dict__. pathlib.Path.__dict__.__contains__('__dir__')==False (Path is the concrete abstract-platform class; it inherits __dir__ just like the Pure variants). pathlib.PosixPath.__dict__.__contains__('__dir__')==False (PosixPath is the concrete POSIX class). All verified with Python 3.14.4."
  kind: python_call_eq
  category: dir_introspection
  id_prefix: pl1426dr

  columns: [id, function, args, expected, description]
  rows:
    - [pl1426dr001, pathlib.PurePath.__dir__.__class__.__name__.__eq__,        ["method_descriptor"], true,  "pathlib.PurePath.__dir__.__class__.__name__ == 'method_descriptor' (inherits object.__dir__); verified with Python 3.14.4"]
    - [pl1426dr002, pathlib.PurePath.__dict__.__contains__,                     ["__dir__"],            false, "pathlib.PurePath.__dict__.__contains__('__dir__') == False (not defined in own dict); verified with Python 3.14.4"]
    - [pl1426dr003, pathlib.PurePosixPath.__dir__.__class__.__name__.__eq__,   ["method_descriptor"], true,  "pathlib.PurePosixPath.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426dr004, pathlib.PurePosixPath.__dict__.__contains__,               ["__dir__"],            false, "pathlib.PurePosixPath.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [pl1426dr005, pathlib.PureWindowsPath.__dir__.__class__.__name__.__eq__, ["method_descriptor"], true,  "pathlib.PureWindowsPath.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426dr006, pathlib.PureWindowsPath.__dict__.__contains__,             ["__dir__"],            false, "pathlib.PureWindowsPath.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [pl1426dr007, pathlib.Path.__dir__.__class__.__name__.__eq__,            ["method_descriptor"], true,  "pathlib.Path.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426dr008, pathlib.Path.__dict__.__contains__,                        ["__dir__"],            false, "pathlib.Path.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [pl1426dr009, pathlib.PosixPath.__dir__.__class__.__name__.__eq__,       ["method_descriptor"], true,  "pathlib.PosixPath.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426dr010, pathlib.PosixPath.__dict__.__contains__,                   ["__dir__"],            false, "pathlib.PosixPath.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]

# ---------------------------------------------------------------------------
# pathlib class __format__ and __dir__ cross-checks — extra1426
#
# All pathlib classes uniformly inherit both __format__ and __dir__ from object.
# Neither is ever found in any class's own __dict__.
# ---------------------------------------------------------------------------

table pathlib_extra1426.pathlib_format_dir_cross:
  description: "pathlib class __format__ and __dir__ cross-checks — wave 542 extra1426. Confirms that across all five pathlib classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath), both __format__ and __dir__ are always 'method_descriptor' and are never present in the class's own __dict__. This uniform inheritance pattern from object holds across the entire pathlib class hierarchy: pure path classes (PurePath, PurePosixPath, PureWindowsPath) and concrete path classes (Path, PosixPath) alike. All verified with Python 3.14.4."
  kind: python_call_eq
  category: format_dir_cross
  id_prefix: pl1426cx

  columns: [id, function, args, expected, description]
  rows:
    - [pl1426cx001, pathlib.PurePath.__format__.__class__.__name__.__eq__,        ["method_descriptor"], true,  "pathlib.PurePath.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426cx002, pathlib.PurePath.__dir__.__class__.__name__.__eq__,           ["method_descriptor"], true,  "pathlib.PurePath.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426cx003, pathlib.PurePosixPath.__format__.__class__.__name__.__eq__,   ["method_descriptor"], true,  "pathlib.PurePosixPath.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426cx004, pathlib.PurePosixPath.__dir__.__class__.__name__.__eq__,      ["method_descriptor"], true,  "pathlib.PurePosixPath.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426cx005, pathlib.PureWindowsPath.__format__.__class__.__name__.__eq__, ["method_descriptor"], true,  "pathlib.PureWindowsPath.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426cx006, pathlib.PureWindowsPath.__dir__.__class__.__name__.__eq__,    ["method_descriptor"], true,  "pathlib.PureWindowsPath.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426cx007, pathlib.Path.__format__.__class__.__name__.__eq__,            ["method_descriptor"], true,  "pathlib.Path.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426cx008, pathlib.Path.__dir__.__class__.__name__.__eq__,               ["method_descriptor"], true,  "pathlib.Path.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426cx009, pathlib.PosixPath.__format__.__class__.__name__.__eq__,       ["method_descriptor"], true,  "pathlib.PosixPath.__format__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426cx010, pathlib.PosixPath.__dir__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "pathlib.PosixPath.__dir__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.4"]
    - [pl1426cx011, pathlib.PurePath.__dict__.__contains__,                       ["__format__"],         false, "pathlib.PurePath.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [pl1426cx012, pathlib.PurePath.__dict__.__contains__,                       ["__dir__"],            false, "pathlib.PurePath.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
    - [pl1426cx013, pathlib.Path.__dict__.__contains__,                           ["__format__"],         false, "pathlib.Path.__dict__.__contains__('__format__') == False; verified with Python 3.14.4"]
    - [pl1426cx014, pathlib.Path.__dict__.__contains__,                           ["__dir__"],            false, "pathlib.Path.__dict__.__contains__('__dir__') == False; verified with Python 3.14.4"]
