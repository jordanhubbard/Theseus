spec: theseus_logging_handlers_cr
version: ">=3.0"
backend: python_cleanroom(theseus_logging_handlers_cr)
blocks: logging.handlers

docs: https://docs.python.org/3/library/logging.handlers.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/logging.handlers.html"
  not_derived_from:
    - "CPython source: Lib/logging/handlers.py"
  notes:
    - "Clean-room logging.handlers module. Do NOT import logging.handlers."

error_model: python_exceptions

invariant theseus_logging_handlers_cr.loghandlers2_rotating:
  description: "RotatingFileHandler can be instantiated"
  category: behavior
  kind: python_call_eq
  function: loghandlers2_rotating
  args: []
  expected: true

invariant theseus_logging_handlers_cr.loghandlers2_memory:
  description: "MemoryHandler buffers records"
  category: behavior
  kind: python_call_eq
  function: loghandlers2_memory
  args: []
  expected: true

invariant theseus_logging_handlers_cr.loghandlers2_queue:
  description: "QueueHandler enqueues log records"
  category: behavior
  kind: python_call_eq
  function: loghandlers2_queue
  args: []
  expected: true
