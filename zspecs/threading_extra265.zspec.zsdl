spec: threading_extra265
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread class identity; threading.Thread method qualnames (start, join, is_alive, run); threading.Thread unstarted state contracts."
    - "threading.Thread.__name__ == 'Thread'; __module__ == 'threading'; __bases__[0].__name__ == 'object'; __mro__ len == 2. Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start'; join.__qualname__ == 'Thread.join'; is_alive.__qualname__ == 'Thread.is_alive'; run.__qualname__ == 'Thread.run'. Verified with Python 3.14.3."
    - "A freshly created unstarted Thread: is_alive() == False; ident == None; native_id == None; daemon == False (inherits from non-daemon main thread). Verified with Python 3.14.3."
    - "A freshly created Thread: name.__class__.__name__ == 'str'; name.startswith('Thread-') == True. Names follow the pattern 'Thread-N' where N is a monotonically increasing integer. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__name__ == 'is_alive'; Thread.start.__name__ == 'start'; Thread.join.__name__ == 'join'; Thread.run.__name__ == 'run'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread class identity
#
# threading.Thread.__name__ == 'Thread'
# threading.Thread.__module__ == 'threading'
# threading.Thread.__bases__[0].__name__ == 'object'
# threading.Thread.__mro__.__len__() == 2
# threading.Thread.__name__.__len__() == 6
#
# Thread is a pure Python class in Lib/threading.py. Its MRO is
# (Thread, object), length 2. New to extra265.
# ---------------------------------------------------------------------------

table threading_extra265.thread_class_identity:
  description: "threading.Thread class __name__, __module__, __bases__, __mro__ identity; new to extra265"
  kind: python_call_eq
  category: identity
  id_prefix: threadingthread265

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_eq,
       Thread.__name__.__eq__,
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — Thread is a class in Lib/threading.py; its __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra265"]
    - [thread_module_eq,
       Thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in the threading module; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra265"]
    - [thread_base_name_eq,
       Thread.__bases__.__getitem__(0).__name__.__eq__,
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — Thread inherits directly from object; its first base class is object; str.__eq__('object') returns True; new to extra265"]
    - [thread_mro_len_2,
       Thread.__mro__.__len__,
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — Thread's MRO is (Thread, object), a tuple of length 2; tuple.__len__() returns 2; new to extra265"]
    - [thread_name_len_6,
       Thread.__name__.__len__,
       [],
       6,
       "threading.Thread.__name__.__len__() == 6 — the name 'Thread' has exactly 6 characters: T-h-r-e-a-d; str.__len__() returns 6; new to extra265"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread method qualnames
#
# threading.Thread.start.__qualname__ == 'Thread.start'
# threading.Thread.join.__qualname__ == 'Thread.join'
# threading.Thread.is_alive.__qualname__ == 'Thread.is_alive'
# threading.Thread.run.__qualname__ == 'Thread.run'
#
# All are pure Python methods defined in Lib/threading.py. New to extra265.
# ---------------------------------------------------------------------------

table threading_extra265.thread_method_qualnames:
  description: "threading.Thread method start, join, is_alive, run __qualname__ and __name__ identity; new to extra265"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmeth265

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_qualname_eq,
       Thread.start.__qualname__.__eq__,
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — start is a method of Thread in Lib/threading.py; its __qualname__ is 'Thread.start'; str.__eq__('Thread.start') returns True; new to extra265"]
    - [thread_join_qualname_eq,
       Thread.join.__qualname__.__eq__,
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — join is a method of Thread in Lib/threading.py; its __qualname__ is 'Thread.join'; str.__eq__('Thread.join') returns True; new to extra265"]
    - [thread_is_alive_qualname_eq,
       Thread.is_alive.__qualname__.__eq__,
       ["Thread.is_alive"],
       true,
       "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True — is_alive is a method of Thread in Lib/threading.py; its __qualname__ is 'Thread.is_alive'; str.__eq__('Thread.is_alive') returns True; new to extra265"]
    - [thread_run_qualname_eq,
       Thread.run.__qualname__.__eq__,
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — run is the method Thread subclasses override; its __qualname__ is 'Thread.run'; str.__eq__('Thread.run') returns True; new to extra265"]
    - [thread_is_alive_name_eq,
       Thread.is_alive.__name__.__eq__,
       ["is_alive"],
       true,
       "threading.Thread.is_alive.__name__.__eq__('is_alive') == True — is_alive method __name__ is 'is_alive'; str.__eq__('is_alive') returns True; new to extra265"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread method __name__ values
#
# threading.Thread.start.__name__ == 'start'
# threading.Thread.join.__name__ == 'join'
# threading.Thread.run.__name__ == 'run'
# threading.Thread.__module__.__len__() == 9
# threading.Thread.start.__module__ == 'threading'
#
# New to extra265.
# ---------------------------------------------------------------------------

table threading_extra265.thread_method_names:
  description: "threading.Thread method start, join, run __name__ values and module length; new to extra265"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmn265

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_name_eq,
       Thread.start.__name__.__eq__,
       ["start"],
       true,
       "threading.Thread.start.__name__.__eq__('start') == True — start method __name__ is 'start'; str.__eq__('start') returns True; new to extra265"]
    - [thread_join_name_eq,
       Thread.join.__name__.__eq__,
       ["join"],
       true,
       "threading.Thread.join.__name__.__eq__('join') == True — join method __name__ is 'join'; str.__eq__('join') returns True; new to extra265"]
    - [thread_run_name_eq,
       Thread.run.__name__.__eq__,
       ["run"],
       true,
       "threading.Thread.run.__name__.__eq__('run') == True — run method __name__ is 'run'; str.__eq__('run') returns True; new to extra265"]
    - [thread_module_len_9,
       Thread.__module__.__len__,
       [],
       9,
       "threading.Thread.__module__.__len__() == 9 — the module name 'threading' has exactly 9 characters; str.__len__() returns 9; new to extra265"]
    - [thread_start_module_eq,
       Thread.start.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.start.__module__.__eq__('threading') == True — Thread.start is defined in the threading module; str.__eq__('threading') returns True; new to extra265"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra265
# ---------------------------------------------------------------------------

invariant threading_extra265.Thread.name_eq:
  description: "threading.Thread.__name__.__eq__('Thread') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: Thread.__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra265.Thread.module_eq:
  description: "threading.Thread.__module__.__eq__('threading') == True — defined in Lib/threading.py; new to extra265"
  category: identity
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra265.Thread.base_is_object:
  description: "threading.Thread.__bases__[0].__name__.__eq__('object') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: Thread.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant threading_extra265.Thread.mro_len_2:
  description: "threading.Thread.__mro__.__len__() == 2 — MRO is (Thread, object); new to extra265"
  category: identity
  kind: python_call_eq
  function: Thread.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra265.Thread.start_qualname_eq:
  description: "threading.Thread.start.__qualname__.__eq__('Thread.start') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: Thread.start.__qualname__.__eq__
  args: ["Thread.start"]
  expected: true

invariant threading_extra265.Thread.join_qualname_eq:
  description: "threading.Thread.join.__qualname__.__eq__('Thread.join') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: Thread.join.__qualname__.__eq__
  args: ["Thread.join"]
  expected: true

invariant threading_extra265.Thread.is_alive_qualname_eq:
  description: "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: Thread.is_alive.__qualname__.__eq__
  args: ["Thread.is_alive"]
  expected: true

invariant threading_extra265.Thread.run_qualname_eq:
  description: "threading.Thread.run.__qualname__.__eq__('Thread.run') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: Thread.run.__qualname__.__eq__
  args: ["Thread.run"]
  expected: true

invariant threading_extra265.Thread.start_name_eq:
  description: "threading.Thread.start.__name__.__eq__('start') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: Thread.start.__name__.__eq__
  args: ["start"]
  expected: true

invariant threading_extra265.Thread.is_alive_name_eq:
  description: "threading.Thread.is_alive.__name__.__eq__('is_alive') == True; new to extra265"
  category: identity
  kind: python_call_eq
  function: Thread.is_alive.__name__.__eq__
  args: ["is_alive"]
  expected: true
