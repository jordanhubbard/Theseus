spec: object_values
version: ">=2.0.0"
backend: node(object-values)

docs: https://www.npmjs.com/package/object-values

provenance:
  derived_from:
    - "object-values README — https://www.npmjs.com/package/object-values"
    - "Test vectors verified with object-values via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "object-values source"
  notes:
    - "object-values is an npm package. Install: npm install object-values"
    - "Returns an array of an object's own enumerable property values."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_values.values:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: ovals

  columns: [id, args, expected]
  rows:
    - [two,    [{"a": 1, "b": 2}],  [1, 2]]
    - [empty,  [{}],                []]
    - [one,    [{"x": 42}],         [42]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:15:42Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
