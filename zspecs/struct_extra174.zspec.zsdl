spec: struct_extra174
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "This spec covers: struct module identity attributes — __name__=='struct' (len=6); __package__=='' (struct is a C extension module, not a package, so __package__ is empty string); struct.pack.__class__.__name__=='builtin_function_or_method'; struct.unpack.__class__.__name__=='builtin_function_or_method'; struct.pack_into.__name__=='pack_into' (len=9); struct.unpack_from.__name__=='unpack_from' (len=11); struct.iter_unpack.__name__=='iter_unpack' (len=11; same length as unpack_from); struct.calcsize.__class__.__name__=='builtin_function_or_method'."
    - "struct.__package__ == '' — struct is a C extension module (_struct.so/.pyd); the import system sets __package__ to '' for top-level non-package modules."
    - "struct.pack_into.__name__ len is 9, not 8: 'pack_into' = p-a-c-k-_-i-n-t-o (9 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct module __name__ and __package__ identity
#
# struct.__name__ == 'struct' (len 6)
# struct.__package__ == '' (C extension, not a package)
# struct.__name__.__eq__('struct') == True
# struct.__package__.__eq__('') == True
#
# struct is implemented as Modules/_struct.c (a C extension).  Because it is
# a top-level module (not a directory), __package__ is '' not 'struct'.
# __name__ is 'struct', the name used at import time. New to extra174.
# ---------------------------------------------------------------------------

table struct_extra174.module_name_and_package:
  description: "struct.__name__=='struct' (len=6); __package__=='' (C extension, not a package); new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: structmodule174

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq_struct,
       "__name__.__eq__",
       ["struct"],
       true,
       "struct.__name__.__eq__('struct') == True — struct.__name__ is the string 'struct', the module's fully-qualified name as registered in sys.modules; str.__eq__('struct') returns True; new to extra174"]
    - [name_len_6,
       "__name__.__len__",
       [],
       6,
       "struct.__name__.__len__() == 6 — the string 'struct' has 6 characters (s-t-r-u-c-t); str.__len__() returns 6; new to extra174"]
    - [package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "struct.__package__.__eq__('') == True — struct is a C extension module (_struct.so/.pyd), not a package directory; the import system sets __package__ to '' for top-level non-package modules; str.__eq__('') returns True; new to extra174"]
    - [package_not_struct,
       "__package__.__eq__",
       ["struct"],
       false,
       "struct.__package__.__eq__('struct') == False — struct is a C extension module (not a package), so __package__ is '' not 'struct'; str.__eq__('struct') returns False; new to extra174"]

# ---------------------------------------------------------------------------
# Table 2: struct.pack and struct.unpack class identity
#
# struct.pack.__class__.__name__ == 'builtin_function_or_method'
# struct.unpack.__class__.__name__ == 'builtin_function_or_method'
# struct.calcsize.__class__.__name__ == 'builtin_function_or_method'
# struct.pack.__class__.__name__ != 'function'
#
# pack, unpack, and calcsize are all C-level functions defined in
# Modules/_struct.c and exposed directly in the struct namespace as
# builtin_function_or_method objects. New to extra174.
# ---------------------------------------------------------------------------

table struct_extra174.pack_unpack_calcsize_class:
  description: "struct.pack, unpack, calcsize are all builtin_function_or_method; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: structmodule174

  columns: [id, function, args, expected, description]
  rows:
    - [pack_class_builtin,
       "pack.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "struct.pack.__class__.__name__.__eq__('builtin_function_or_method') == True — struct.pack is a C-level function defined in Modules/_struct.c; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra174"]
    - [unpack_class_builtin,
       "unpack.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "struct.unpack.__class__.__name__.__eq__('builtin_function_or_method') == True — struct.unpack is a C-level function defined in Modules/_struct.c; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra174"]
    - [calcsize_class_builtin,
       "calcsize.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "struct.calcsize.__class__.__name__.__eq__('builtin_function_or_method') == True — struct.calcsize is a C-level function defined in Modules/_struct.c; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra174"]
    - [pack_class_not_function,
       "pack.__class__.__name__.__eq__",
       ["function"],
       false,
       "struct.pack.__class__.__name__.__eq__('function') == False — struct.pack is a C builtin, not a Python-level function; its __class__.__name__ is 'builtin_function_or_method', not 'function'; str.__eq__('function') returns False; new to extra174"]

# ---------------------------------------------------------------------------
# Table 3: struct.pack_into, struct.unpack_from, struct.iter_unpack __name__
#
# struct.pack_into.__name__ == 'pack_into' (len 9)
# struct.unpack_from.__name__ == 'unpack_from' (len 11)
# struct.iter_unpack.__name__ == 'iter_unpack' (len 11)
# struct.unpack_from.__name__.__len__() == struct.iter_unpack.__name__.__len__()
#
# These three C-level functions expose their __name__ attribute as the bare
# function name string.  pack_into has 9 characters; both unpack_from and
# iter_unpack have 11 characters (same length, different names). New to extra174.
# ---------------------------------------------------------------------------

table struct_extra174.function_names_and_lengths:
  description: "struct.pack_into.__name__=='pack_into' (len=9); unpack_from.__name__=='unpack_from' (len=11); iter_unpack.__name__=='iter_unpack' (len=11); new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: structmodule174

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_name_eq,
       "pack_into.__name__.__eq__",
       ["pack_into"],
       true,
       "struct.pack_into.__name__.__eq__('pack_into') == True — struct.pack_into is a C-level function; its __name__ attribute is the string 'pack_into'; str.__eq__('pack_into') returns True; new to extra174"]
    - [pack_into_name_len_9,
       "pack_into.__name__.__len__",
       [],
       9,
       "struct.pack_into.__name__.__len__() == 9 — 'pack_into' has 9 characters (p-a-c-k-_-i-n-t-o); str.__len__() returns 9; new to extra174"]
    - [unpack_from_name_eq,
       "unpack_from.__name__.__eq__",
       ["unpack_from"],
       true,
       "struct.unpack_from.__name__.__eq__('unpack_from') == True — struct.unpack_from is a C-level function; its __name__ attribute is the string 'unpack_from'; str.__eq__('unpack_from') returns True; new to extra174"]
    - [unpack_from_name_len_11,
       "unpack_from.__name__.__len__",
       [],
       11,
       "struct.unpack_from.__name__.__len__() == 11 — 'unpack_from' has 11 characters (u-n-p-a-c-k-_-f-r-o-m); str.__len__() returns 11; new to extra174"]
    - [iter_unpack_name_eq,
       "iter_unpack.__name__.__eq__",
       ["iter_unpack"],
       true,
       "struct.iter_unpack.__name__.__eq__('iter_unpack') == True — struct.iter_unpack is a C-level function; its __name__ attribute is the string 'iter_unpack'; str.__eq__('iter_unpack') returns True; new to extra174"]
    - [iter_unpack_name_len_11,
       "iter_unpack.__name__.__len__",
       [],
       11,
       "struct.iter_unpack.__name__.__len__() == 11 — 'iter_unpack' has 11 characters (i-t-e-r-_-u-n-p-a-c-k); str.__len__() returns 11 — the same length as 'unpack_from'; new to extra174"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra174
# ---------------------------------------------------------------------------

invariant struct_extra174.name_eq_struct:
  description: "struct.__name__ == 'struct' — the module's fully-qualified name; new to extra174"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra174.name_len_6:
  description: "struct.__name__.__len__() == 6 — 'struct' is a 6-character string; new to extra174"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 6

invariant struct_extra174.package_empty:
  description: "struct.__package__ == '' — struct is a C extension module (not a package directory), so __package__ is empty string; new to extra174"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant struct_extra174.pack_is_builtin:
  description: "struct.pack.__class__.__name__ == 'builtin_function_or_method' — pack is a C-level function in Modules/_struct.c; new to extra174"
  kind: python_call_eq
  function: pack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant struct_extra174.unpack_is_builtin:
  description: "struct.unpack.__class__.__name__ == 'builtin_function_or_method' — unpack is a C-level function in Modules/_struct.c; new to extra174"
  kind: python_call_eq
  function: unpack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant struct_extra174.pack_into_name_len_9:
  description: "struct.pack_into.__name__.__len__() == 9 — 'pack_into' has 9 characters; new to extra174"
  kind: python_call_eq
  function: pack_into.__name__.__len__
  args: []
  expected: 9

invariant struct_extra174.iter_unpack_name_len_11:
  description: "struct.iter_unpack.__name__.__len__() == 11 — 'iter_unpack' has 11 characters, the same as 'unpack_from'; new to extra174"
  kind: python_call_eq
  function: iter_unpack.__name__.__len__
  args: []
  expected: 11
