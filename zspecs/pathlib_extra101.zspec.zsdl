spec: pathlib_extra101
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra100

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra100.zspec.zsdl."
    - "This spec covers: pathlib.Path and PurePath method __qualname__ equality for key methods."
    - "pathlib.Path is a pure Python class; its methods have __qualname__ of the form 'Path.method_name'."
    - "pathlib.PurePath methods have __qualname__ of the form 'PurePath.method_name'."
    - "Path.is_file.__qualname__ = 'Path.is_file', Path.mkdir.__qualname__ = 'Path.mkdir', etc."
    - "Path.read_text.__qualname__ = 'Path.read_text', Path.open.__qualname__ = 'Path.open', etc."
    - "Path.absolute.__qualname__ = 'Path.absolute', Path.glob.__qualname__ = 'Path.glob', etc."
    - "PurePath.with_name.__qualname__ = 'PurePath.with_name', PurePath.joinpath.__qualname__ = 'PurePath.joinpath', etc."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__ for file operations
# is_file, is_dir, exists, mkdir, rmdir, unlink, touch
# All have __qualname__ == 'Path.<method_name>'
# ---------------------------------------------------------------------------

table pathlib_extra101.Path_file_ops_qualname:
  description: "pathlib.Path method __qualname__ for file operations: is_file, is_dir, exists, mkdir, rmdir, unlink, touch"
  kind: python_call_eq
  category: method_qualname
  id_prefix: pathlibpathqualname101

  columns: [id, function, args, expected]
  rows:
    - [path_isfile_qn,   Path.is_file.__qualname__.__eq__,  ["Path.is_file"],  true]
    - [path_isdir_qn,    Path.is_dir.__qualname__.__eq__,   ["Path.is_dir"],   true]
    - [path_exists_qn,   Path.exists.__qualname__.__eq__,   ["Path.exists"],   true]
    - [path_mkdir_qn,    Path.mkdir.__qualname__.__eq__,    ["Path.mkdir"],    true]
    - [path_rmdir_qn,    Path.rmdir.__qualname__.__eq__,    ["Path.rmdir"],    true]
    - [path_unlink_qn,   Path.unlink.__qualname__.__eq__,   ["Path.unlink"],   true]
    - [path_touch_qn,    Path.touch.__qualname__.__eq__,    ["Path.touch"],    true]
    - [path_isfile_not,  Path.is_file.__qualname__.__eq__,  ["is_file"],       false]

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__ for I/O operations
# read_text, write_text, read_bytes, write_bytes, open, stat
# All have __qualname__ == 'Path.<method_name>'
# ---------------------------------------------------------------------------

table pathlib_extra101.Path_io_qualname:
  description: "pathlib.Path method __qualname__ for I/O operations: read_text, write_text, read_bytes, write_bytes, open, stat"
  kind: python_call_eq
  category: method_qualname
  id_prefix: pathlibpathqualname101

  columns: [id, function, args, expected]
  rows:
    - [path_readtext_qn,   Path.read_text.__qualname__.__eq__,   ["Path.read_text"],   true]
    - [path_writetext_qn,  Path.write_text.__qualname__.__eq__,  ["Path.write_text"],  true]
    - [path_readbytes_qn,  Path.read_bytes.__qualname__.__eq__,  ["Path.read_bytes"],  true]
    - [path_writebytes_qn, Path.write_bytes.__qualname__.__eq__, ["Path.write_bytes"], true]
    - [path_open_qn,       Path.open.__qualname__.__eq__,        ["Path.open"],        true]
    - [path_stat_qn,       Path.stat.__qualname__.__eq__,        ["Path.stat"],        true]
    - [path_open_not_bare, Path.open.__qualname__.__eq__,        ["open"],             false]

# ---------------------------------------------------------------------------
# pathlib.Path method __qualname__ for navigation
# absolute, resolve, iterdir, glob, rglob
# All have __qualname__ == 'Path.<method_name>'
# ---------------------------------------------------------------------------

table pathlib_extra101.Path_navigation_qualname:
  description: "pathlib.Path method __qualname__ for navigation: absolute, resolve, iterdir, glob, rglob"
  kind: python_call_eq
  category: method_qualname
  id_prefix: pathlibpathqualname101

  columns: [id, function, args, expected]
  rows:
    - [path_absolute_qn, Path.absolute.__qualname__.__eq__, ["Path.absolute"], true]
    - [path_resolve_qn,  Path.resolve.__qualname__.__eq__,  ["Path.resolve"],  true]
    - [path_iterdir_qn,  Path.iterdir.__qualname__.__eq__,  ["Path.iterdir"],  true]
    - [path_glob_qn,     Path.glob.__qualname__.__eq__,     ["Path.glob"],     true]
    - [path_rglob_qn,    Path.rglob.__qualname__.__eq__,    ["Path.rglob"],    true]
    - [path_glob_not_pp, Path.glob.__qualname__.__eq__,     ["PurePath.glob"], false]

# ---------------------------------------------------------------------------
# pathlib.PurePath method __qualname__
# with_name, with_stem, with_suffix, joinpath, relative_to
# All have __qualname__ == 'PurePath.<method_name>'
# ---------------------------------------------------------------------------

table pathlib_extra101.PurePath_qualname:
  description: "pathlib.PurePath method __qualname__: with_name, with_stem, with_suffix, joinpath, relative_to"
  kind: python_call_eq
  category: method_qualname
  id_prefix: pathlibpathqualname101

  columns: [id, function, args, expected]
  rows:
    - [pp_withname_qn,    PurePath.with_name.__qualname__.__eq__,      ["PurePath.with_name"],      true]
    - [pp_withstem_qn,    PurePath.with_stem.__qualname__.__eq__,      ["PurePath.with_stem"],      true]
    - [pp_withsuffix_qn,  PurePath.with_suffix.__qualname__.__eq__,    ["PurePath.with_suffix"],    true]
    - [pp_joinpath_qn,    PurePath.joinpath.__qualname__.__eq__,       ["PurePath.joinpath"],       true]
    - [pp_relativeto_qn,  PurePath.relative_to.__qualname__.__eq__,    ["PurePath.relative_to"],    true]
    - [pp_withname_not,   PurePath.with_name.__qualname__.__eq__,      ["Path.with_name"],          false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra101.Path.is_file_qualname:
  description: "pathlib.Path.is_file.__qualname__ == 'Path.is_file' (pure Python class methods have a dotted __qualname__ of class.method)"
  category: method_qualname
  kind: python_call_eq
  function: Path.is_file.__qualname__.__eq__
  args: ["Path.is_file"]
  expected: true

invariant pathlib_extra101.Path.read_text_qualname:
  description: "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (I/O methods defined in Path have Path-qualified __qualname__)"
  category: method_qualname
  kind: python_call_eq
  function: Path.read_text.__qualname__.__eq__
  args: ["Path.read_text"]
  expected: true

invariant pathlib_extra101.Path.glob_qualname:
  description: "pathlib.Path.glob.__qualname__ == 'Path.glob' (navigation methods defined in Path have Path-qualified __qualname__)"
  category: method_qualname
  kind: python_call_eq
  function: Path.glob.__qualname__.__eq__
  args: ["Path.glob"]
  expected: true

invariant pathlib_extra101.PurePath.joinpath_qualname:
  description: "pathlib.PurePath.joinpath.__qualname__ == 'PurePath.joinpath' (PurePath methods have PurePath-qualified __qualname__)"
  category: method_qualname
  kind: python_call_eq
  function: PurePath.joinpath.__qualname__.__eq__
  args: ["PurePath.joinpath"]
  expected: true

invariant pathlib_extra101.PurePath.with_suffix_qualname:
  description: "pathlib.PurePath.with_suffix.__qualname__ == 'PurePath.with_suffix' (with_suffix is defined in PurePath, not in Path)"
  category: method_qualname
  kind: python_call_eq
  function: PurePath.with_suffix.__qualname__.__eq__
  args: ["PurePath.with_suffix"]
  expected: true

