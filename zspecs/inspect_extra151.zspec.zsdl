spec: inspect_extra151
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.__dict__.__len__() 182; inspect.__dict__.__class__.__name__ 'dict'; inspect is* predicate __doc__ lengths — isclass 37, ismodule 38, isfunction 817, ismethod 48, isbuiltin 284, iscoroutinefunction 163, isabstract 58, iscode 1718, isframe 772, istraceback 334, isgenerator 847 (Wave 280)."
    - "inspect.__dict__.__len__() == 182 — the inspect module dict has 182 entries in Python 3.14.3; inspect is a large module with many functions, classes, and constants. Verified with Python 3.14.3."
    - "inspect.__dict__.__class__.__name__ == 'dict' — the module __dict__ of a pure-Python module is a plain dict. Verified with Python 3.14.3."
    - "inspect.isclass.__doc__.__len__() == 37. Verified with Python 3.14.3."
    - "inspect.ismodule.__doc__.__len__() == 38. Verified with Python 3.14.3."
    - "inspect.isfunction.__doc__.__len__() == 817. Verified with Python 3.14.3."
    - "inspect.ismethod.__doc__.__len__() == 48. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__doc__.__len__() == 284. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__doc__.__len__() == 163. Verified with Python 3.14.3."
    - "inspect.isabstract.__doc__.__len__() == 58. Verified with Python 3.14.3."
    - "inspect.iscode.__doc__.__len__() == 1718. Verified with Python 3.14.3."
    - "inspect.isframe.__doc__.__len__() == 772. Verified with Python 3.14.3."
    - "inspect.istraceback.__doc__.__len__() == 334. Verified with Python 3.14.3."
    - "inspect.isgenerator.__doc__.__len__() == 847. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.__dict__ — module dict identity (plain dict, len 182)
#
# Wave 280 theme: inspect module dict type and size.
#
# inspect.__dict__.__class__.__name__ == 'dict'
# inspect.__dict__.__len__() == 182
#
# inspect is a large pure-Python module; its module __dict__ is a plain dict.
# In Python 3.14.3 it has 182 entries. New to extra151.
# ---------------------------------------------------------------------------

table inspect_extra151.module_dict_identity:
  description: "inspect.__dict__: plain dict, len 182; large pure-Python module dict; wave 280; new to extra151"
  kind: python_call_eq
  category: identity
  id_prefix: inspectmoddict151

  columns: [id, function, args, expected, description]
  rows:
    - [module_dict_class_eq_dict,
       "__dict__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "inspect.__dict__.__class__.__name__.__eq__('dict') == True — the module __dict__ of a pure-Python module is a plain Python dict, not a mappingproxy; __class__.__name__ is 'dict'; str.__eq__('dict') returns True; new to extra151"]
    - [module_dict_len_eq_182,
       "__dict__.__len__",
       [],
       182,
       "inspect.__dict__.__len__() == 182 — the inspect module dict has 182 entries in Python 3.14.3; inspect is one of the larger stdlib modules providing introspection functions, classes, and constants; len == 182; verified with Python 3.14.3; new to extra151"]

# ---------------------------------------------------------------------------
# Table 2: inspect is* predicate __doc__ lengths — short docstrings
#
# Wave 280 theme: inspect is* predicate docstring length ordering.
#
# inspect.isclass.__doc__.__len__() == 37
# inspect.ismodule.__doc__.__len__() == 38
# inspect.ismethod.__doc__.__len__() == 48
# inspect.isabstract.__doc__.__len__() == 58
#
# The short predicates (isclass, ismodule, ismethod, isabstract) have compact
# docstrings in the range 37-58 characters. New to extra151.
# ---------------------------------------------------------------------------

table inspect_extra151.is_pred_doc_lengths_short:
  description: "inspect is* predicate short docstring lengths: isclass 37, ismodule 38, ismethod 48, isabstract 58; wave 280; new to extra151"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectisdocshort151

  columns: [id, function, args, expected, description]
  rows:
    - [isclass_doc_len_eq_37,
       "isclass.__doc__.__len__",
       [],
       37,
       "inspect.isclass.__doc__.__len__() == 37 — the docstring of isclass is 'Return true if the object is a class.' which is 37 characters long; a concise one-line docstring for a simple predicate; len(__doc__) == 37; verified with Python 3.14.3; new to extra151"]
    - [ismodule_doc_len_eq_38,
       "ismodule.__doc__.__len__",
       [],
       38,
       "inspect.ismodule.__doc__.__len__() == 38 — the docstring of ismodule is 'Return true if the object is a module.' which is 38 characters long; slightly longer than isclass due to the word 'module'; len(__doc__) == 38; verified with Python 3.14.3; new to extra151"]
    - [ismethod_doc_len_eq_48,
       "ismethod.__doc__.__len__",
       [],
       48,
       "inspect.ismethod.__doc__.__len__() == 48 — the docstring of ismethod has 48 characters; longer than isclass/ismodule as it mentions bound methods; len(__doc__) == 48; verified with Python 3.14.3; new to extra151"]
    - [isabstract_doc_len_eq_58,
       "isabstract.__doc__.__len__",
       [],
       58,
       "inspect.isabstract.__doc__.__len__() == 58 — the docstring of isabstract has 58 characters; the longest among the short-docstring predicates; len(__doc__) == 58; verified with Python 3.14.3; new to extra151"]

# ---------------------------------------------------------------------------
# Table 3: inspect is* predicate __doc__ lengths — long docstrings
#
# Wave 280 theme: inspect is* predicates with longer docstrings.
#
# inspect.iscoroutinefunction.__doc__.__len__() == 163
# inspect.isbuiltin.__doc__.__len__() == 284
# inspect.istraceback.__doc__.__len__() == 334
# inspect.isframe.__doc__.__len__() == 772
# inspect.isfunction.__doc__.__len__() == 817
# inspect.isgenerator.__doc__.__len__() == 847
# inspect.iscode.__doc__.__len__() == 1718
#
# These predicates have longer docstrings that explain more complex concepts.
# iscode has the longest at 1718 characters. New to extra151.
# ---------------------------------------------------------------------------

table inspect_extra151.is_pred_doc_lengths_long:
  description: "inspect is* predicate long docstring lengths: iscoroutinefunction 163, isbuiltin 284, istraceback 334, isframe 772, isfunction 817, isgenerator 847, iscode 1718; wave 280; new to extra151"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectisdoclong151

  columns: [id, function, args, expected, description]
  rows:
    - [iscoroutinefunction_doc_len_eq_163,
       "iscoroutinefunction.__doc__.__len__",
       [],
       163,
       "inspect.iscoroutinefunction.__doc__.__len__() == 163 — the docstring of iscoroutinefunction has 163 characters; it explains detection of async def functions and decorated coroutines; len(__doc__) == 163; verified with Python 3.14.3; new to extra151"]
    - [isbuiltin_doc_len_eq_284,
       "isbuiltin.__doc__.__len__",
       [],
       284,
       "inspect.isbuiltin.__doc__.__len__() == 284 — the docstring of isbuiltin has 284 characters; it covers C-level builtin functions and methods; len(__doc__) == 284; verified with Python 3.14.3; new to extra151"]
    - [istraceback_doc_len_eq_334,
       "istraceback.__doc__.__len__",
       [],
       334,
       "inspect.istraceback.__doc__.__len__() == 334 — the docstring of istraceback has 334 characters; it explains traceback objects; len(__doc__) == 334; verified with Python 3.14.3; new to extra151"]
    - [isframe_doc_len_eq_772,
       "isframe.__doc__.__len__",
       [],
       772,
       "inspect.isframe.__doc__.__len__() == 772 — the docstring of isframe has 772 characters; it explains frame objects and their attributes; len(__doc__) == 772; verified with Python 3.14.3; new to extra151"]
    - [isfunction_doc_len_eq_817,
       "isfunction.__doc__.__len__",
       [],
       817,
       "inspect.isfunction.__doc__.__len__() == 817 — the docstring of isfunction has 817 characters; it covers Python function objects and their many attributes; len(__doc__) == 817; verified with Python 3.14.3; new to extra151"]
    - [isgenerator_doc_len_eq_847,
       "isgenerator.__doc__.__len__",
       [],
       847,
       "inspect.isgenerator.__doc__.__len__() == 847 — the docstring of isgenerator has 847 characters; it explains generator objects and their lifecycle attributes; len(__doc__) == 847; verified with Python 3.14.3; new to extra151"]
    - [iscode_doc_len_eq_1718,
       "iscode.__doc__.__len__",
       [],
       1718,
       "inspect.iscode.__doc__.__len__() == 1718 — the docstring of iscode has 1718 characters; it is the longest among the is* predicates, documenting the many attributes of code objects; len(__doc__) == 1718; verified with Python 3.14.3; new to extra151"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra151
# ---------------------------------------------------------------------------

invariant inspect_extra151.module_dict_class_dict:
  description: "inspect.__dict__.__class__.__name__ == 'dict' — module __dict__ of a pure-Python module is a plain dict; wave 280; new to extra151"
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant inspect_extra151.module_dict_len:
  description: "len(inspect.__dict__) == 182 — inspect module dict has 182 entries in Python 3.14.3; wave 280; new to extra151"
  kind: python_call_eq
  function: __dict__.__len__
  args: []
  expected: 182

invariant inspect_extra151.isclass_doc_len:
  description: "len(inspect.isclass.__doc__) == 37 — shortest is* predicate docstring; wave 280; new to extra151"
  kind: python_call_eq
  function: isclass.__doc__.__len__
  args: []
  expected: 37

invariant inspect_extra151.ismodule_doc_len:
  description: "len(inspect.ismodule.__doc__) == 38 — second shortest is* predicate docstring; wave 280; new to extra151"
  kind: python_call_eq
  function: ismodule.__doc__.__len__
  args: []
  expected: 38

invariant inspect_extra151.ismethod_doc_len:
  description: "len(inspect.ismethod.__doc__) == 48 — ismethod predicate docstring length; wave 280; new to extra151"
  kind: python_call_eq
  function: ismethod.__doc__.__len__
  args: []
  expected: 48

invariant inspect_extra151.isabstract_doc_len:
  description: "len(inspect.isabstract.__doc__) == 58 — isabstract predicate docstring length; wave 280; new to extra151"
  kind: python_call_eq
  function: isabstract.__doc__.__len__
  args: []
  expected: 58

invariant inspect_extra151.isfunction_doc_len:
  description: "len(inspect.isfunction.__doc__) == 817 — isfunction has the second-longest is* docstring; wave 280; new to extra151"
  kind: python_call_eq
  function: isfunction.__doc__.__len__
  args: []
  expected: 817

invariant inspect_extra151.iscode_doc_len:
  description: "len(inspect.iscode.__doc__) == 1718 — iscode has the longest is* predicate docstring; wave 280; new to extra151"
  kind: python_call_eq
  function: iscode.__doc__.__len__
  args: []
  expected: 1718
