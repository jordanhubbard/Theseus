spec: multiprocessing_extra150
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers: multiprocessing.Process class identity and code attributes. Process.__name__=='Process' (len=7); Process.__module__=='multiprocessing.context' (the context-bound subclass is defined in context.py, len=23); Process.__bases__[0].__name__=='BaseProcess' (Process inherits from BaseProcess in process.py, len=11); Process.__init__.__code__.co_argcount==6 (positional args: self, group, target, name, args, kwargs — note: daemon is a keyword-only arg so it does NOT count toward co_argcount); AuthenticationError.__name__=='AuthenticationError' (len=19); AuthenticationError.__module__=='multiprocessing.context' (defined in context.py); AuthenticationError.__bases__[0].__name__=='ProcessError' (inherits from multiprocessing.context.ProcessError). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Process.__module__=='multiprocessing.context' — the Process class visible in multiprocessing.__dict__ is the context-bound subclass defined in Lib/multiprocessing/context.py (not the BaseProcess in process.py); Process.__bases__[0].__name__=='BaseProcess' confirms BaseProcess (from process.py) is its parent; BaseProcess.__module__=='multiprocessing.process'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Process.__init__.__code__.co_argcount==6 — the positional args are (self, group, target, name, args, kwargs); the 'daemon' parameter is keyword-only (co_kwonlyargcount==1) so it does NOT count toward co_argcount; total co_varnames includes 'count' as an internal local variable. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process class identity — extra150
#
# multiprocessing.Process.__name__.__eq__('Process')                         == True
# multiprocessing.Process.__module__.__eq__('multiprocessing.context')       == True
# multiprocessing.Process.__bases__[0].__name__.__eq__('BaseProcess')        == True
# ---------------------------------------------------------------------------

table multiprocessing_extra150.mp_process_class_identity:
  description: "multiprocessing.Process class identity checks in mpprocess150 namespace — multiprocessing.Process.__name__=='Process' (len=7; the multiprocessing Process class used to spawn and manage child processes); multiprocessing.Process.__module__=='multiprocessing.context' (len=23; the context-bound subclass is defined in Lib/multiprocessing/context.py, NOT in process.py — on macOS/Darwin the default context is 'spawn' and the Process class is a context-aware subclass); multiprocessing.Process.__bases__[0].__name__=='BaseProcess' (len=11; BaseProcess is defined in Lib/multiprocessing/process.py and contains all the core process management logic: start, run, join, kill, terminate, close, pid, exitcode, is_alive, name, daemon properties); name length ordering: BaseProcess(11) > Process(7); module 'multiprocessing.context' has len=23; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocess150

  columns: [id, function, args, expected, description]
  rows:
    - [proc_name_eq,   multiprocessing.Process.__name__.__eq__,                  ["Process"],                  true,  "multiprocessing.Process.__name__ == 'Process' (len=7); verified with Python 3.14.3"]
    - [proc_mod_eq,    multiprocessing.Process.__module__.__eq__,                 ["multiprocessing.context"], true,  "multiprocessing.Process.__module__ == 'multiprocessing.context' (len=23; context-bound subclass); verified with Python 3.14.3"]
    - [proc_base_eq,  "multiprocessing.Process.__bases__[0].__name__.__eq__",    ["BaseProcess"],              true,  "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess' (len=11; from process.py); verified with Python 3.14.3"]
    - [proc_name_len,  multiprocessing.Process.__name__.__len__,                  [],                           7,     "multiprocessing.Process.__name__.__len__() == 7 ('Process'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Process.__init__ code attributes — extra150
#
# multiprocessing.Process.__init__.__code__.co_argcount == 6
# ---------------------------------------------------------------------------

table multiprocessing_extra150.mp_process_init_code:
  description: "multiprocessing.Process.__init__ code object attribute checks in mpproccode150 namespace — multiprocessing.Process.__init__.__code__.co_argcount==6 (the positional argument count for Process.__init__: self, group, target, name, args, kwargs — these are the 6 positional parameters; 'daemon' is a keyword-only parameter so it is counted in co_kwonlyargcount==1 but NOT in co_argcount; 'count' is an internal local variable); multiprocessing.Process.__init__.__code__.co_kwonlyargcount==1 (only 'daemon' is keyword-only); multiprocessing.Process.__init__.__qualname__=='BaseProcess.__init__' (len=20: the qualname uses 'BaseProcess.' prefix because Process inherits __init__ from BaseProcess, not defining its own); multiprocessing.Process.__init__.__module__=='multiprocessing.process' (the function is defined in process.py even though Process.__module__=='multiprocessing.context'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpproccode150

  columns: [id, function, args, expected, description]
  rows:
    - [init_argcount,    multiprocessing.Process.__init__.__code__.co_argcount.__eq__,       [6],                         true,  "multiprocessing.Process.__init__.__code__.co_argcount == 6 (self, group, target, name, args, kwargs); verified with Python 3.14.3"]
    - [init_kwonly,      multiprocessing.Process.__init__.__code__.co_kwonlyargcount.__eq__,  [1],                         true,  "multiprocessing.Process.__init__.__code__.co_kwonlyargcount == 1 ('daemon' is the only keyword-only parameter); verified with Python 3.14.3"]
    - [init_qualname,    multiprocessing.Process.__init__.__qualname__.__eq__,                ["BaseProcess.__init__"],    true,  "multiprocessing.Process.__init__.__qualname__ == 'BaseProcess.__init__' (len=20; uses BaseProcess. prefix — inherited from BaseProcess); verified with Python 3.14.3"]
    - [init_module,      multiprocessing.Process.__init__.__module__.__eq__,                  ["multiprocessing.process"], true,  "multiprocessing.Process.__init__.__module__ == 'multiprocessing.process' (defined in process.py, not context.py); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.AuthenticationError class identity — extra150
#
# multiprocessing.AuthenticationError.__name__.__eq__('AuthenticationError')         == True
# multiprocessing.AuthenticationError.__module__.__eq__('multiprocessing.context')   == True
# multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__('ProcessError')   == True
# ---------------------------------------------------------------------------

table multiprocessing_extra150.mp_authentication_error_identity:
  description: "multiprocessing.AuthenticationError class identity checks in mpauthexc150 namespace — multiprocessing.AuthenticationError.__name__=='AuthenticationError' (len=19; raised when an authentication challenge fails during multiprocessing manager/client connections); multiprocessing.AuthenticationError.__module__=='multiprocessing.context' (len=23; defined in Lib/multiprocessing/context.py alongside Process and other context-bound classes); multiprocessing.AuthenticationError.__bases__[0].__name__=='ProcessError' (inherits from multiprocessing.context.ProcessError, the base exception class for the multiprocessing package; ProcessError.__bases__[0].__name__=='Exception'); AuthenticationError is in the exception hierarchy: AuthenticationError > ProcessError > Exception; name length 'AuthenticationError'.__len__()==19 (longest name in this spec, 5 chars longer than 'ProcessError'.__len__()==12); module 'multiprocessing.context'.__len__()==23; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpauthexc150

  columns: [id, function, args, expected, description]
  rows:
    - [auth_name_eq,   multiprocessing.AuthenticationError.__name__.__eq__,     ["AuthenticationError"],        true,  "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError' (len=19); verified with Python 3.14.3"]
    - [auth_mod_eq,    multiprocessing.AuthenticationError.__module__.__eq__,    ["multiprocessing.context"],    true,  "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context' (len=23); verified with Python 3.14.3"]
    - [auth_base_eq,  "multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__",  ["ProcessError"],               true,  "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError' (len=12; base exception for multiprocessing package); verified with Python 3.14.3"]
    - [auth_name_len,  multiprocessing.AuthenticationError.__name__.__len__,     [],                             19,    "multiprocessing.AuthenticationError.__name__.__len__() == 19 ('AuthenticationError'; longest name in this spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra150
# ---------------------------------------------------------------------------

invariant multiprocessing_extra150.mp_Process_name_eq:
  description: "multiprocessing.Process.__name__.__eq__('Process') returns True — multiprocessing.Process is the primary class used to spawn child processes; it is accessible as multiprocessing.Process (re-exported through multiprocessing/__init__.py from context.py); Process.__name__=='Process' (len=7); Process.__module__=='multiprocessing.context' (the context-bound subclass, not the base class in process.py); Process.__bases__[0].__name__=='BaseProcess' (BaseProcess from multiprocessing.process contains all the core implementation); multiprocessing.__dict__.__contains__('Process')==True (from extra148: Process is in multiprocessing.__dict__); NEW in extra150: first standalone multiprocessing.Process.__name__ identity invariant in mpprocess150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__name__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra150.mp_Process_module_eq:
  description: "multiprocessing.Process.__module__.__eq__('multiprocessing.context') returns True — the Process class accessible via multiprocessing.Process is a context-bound subclass defined in Lib/multiprocessing/context.py (not the BaseProcess in process.py); on macOS/Darwin the default start method is 'spawn' and the context system creates context-aware Process subclasses; Process.__module__=='multiprocessing.context' (len=23); BaseProcess (the parent class) has BaseProcess.__module__=='multiprocessing.process' (also len=23 — both context.py and process.py have the same module name length); NEW in extra150: first standalone multiprocessing.Process.__module__ identity invariant in mpprocess150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra150.mp_Process_bases0_is_BaseProcess:
  description: "multiprocessing.Process.__bases__[0].__name__.__eq__('BaseProcess') returns True — multiprocessing.Process inherits from BaseProcess (single inheritance); BaseProcess is defined in Lib/multiprocessing/process.py and contains the full implementation of process lifecycle management: start(), run(), join(), kill(), terminate(), close(), and properties pid, exitcode, is_alive(), name, daemon, authkey, sentinel; Process (the context-bound subclass in context.py) inherits all of this and adds context awareness for the start method; BaseProcess.__module__=='multiprocessing.process'; NEW in extra150: first standalone multiprocessing.Process.__bases__[0] name identity invariant in mpprocess150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.Process.__bases__[0].__name__.__eq__"
  args: ["BaseProcess"]
  expected: true

invariant multiprocessing_extra150.mp_Process_init_co_argcount_6:
  description: "multiprocessing.Process.__init__.__code__.co_argcount == 6 — Process.__init__ takes 6 positional parameters: self, group, target, name, args, kwargs; the 'daemon' parameter is keyword-only (co_kwonlyargcount==1) and does NOT count toward co_argcount; co_argcount counts positional parameters only (including positional-with-defaults); the signature is Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None); 'count' is an internal local variable not a parameter; this 6-argument count is notable: self makes it 5 user-facing positional params plus 1 keyword-only; NEW in extra150: first standalone multiprocessing.Process.__init__.__code__.co_argcount invariant in mpproccode150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant multiprocessing_extra150.mp_AuthenticationError_bases0_is_ProcessError:
  description: "multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__('ProcessError') returns True — multiprocessing.AuthenticationError inherits from multiprocessing.context.ProcessError; ProcessError is the base exception class for all multiprocessing-specific exceptions; ProcessError.__bases__[0].__name__=='Exception' (ProcessError directly inherits from Exception); the inheritance chain is: AuthenticationError > ProcessError > Exception > BaseException; AuthenticationError is raised when connection authentication fails (e.g. when a Manager client connects with the wrong authkey); AuthenticationError.__name__.__len__()==19 (len=19: the longest exception name in the multiprocessing exception hierarchy visible in this spec); NEW in extra150: first standalone multiprocessing.AuthenticationError.__bases__[0] name identity invariant in mpauthexc150 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true
