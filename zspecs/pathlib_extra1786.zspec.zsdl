spec: pathlib_extra1786
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/parts/parent/joinpath/str/as_posix/relative_to"
    - "pathlib_extra.zspec.zsdl — covers Path/PurePosixPath class names, components, joining, parts"
    - "pathlib_extra1771.zspec.zsdl — covers async protocol and PurePath dict property membership"
  notes:
    - "Wave 566, theme: __class_getitem__ and __init_subclass__ class creation hooks."
    - "PurePath is a pure Python class (not a C type); it does NOT define __class_getitem__ — pathlib paths are not generic types."
    - "None of PurePath, PurePosixPath, PureWindowsPath, or Path define __init_subclass__ in their own __dict__."
    - "PurePath defines __truediv__, __rtruediv__, and __fspath__ directly in its own __dict__."
    - "Path defines filesystem-access methods (stat, open, read_text, write_text, mkdir, etc.) directly in its own __dict__."
    - "All expected values verified by running Python 3.14 pathlib module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Wave 566 theme: __class_getitem__ — absent from all pathlib types
# pathlib paths are not generic types; Path[str] is not valid syntax
# ---------------------------------------------------------------------------

table pathlib_extra1786.class_getitem:
  description: "__class_getitem__ absent from all pathlib type __dict__ — pathlib types do not support generic subscript"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: pl1786

  columns: [id, function, args, expected]
  rows:
    - ["pl1786001", pathlib.PurePath.__dict__.__contains__,       ["__class_getitem__"], false]
    - ["pl1786002", pathlib.PurePosixPath.__dict__.__contains__,  ["__class_getitem__"], false]
    - ["pl1786003", pathlib.PureWindowsPath.__dict__.__contains__, ["__class_getitem__"], false]
    - ["pl1786004", pathlib.Path.__dict__.__contains__,           ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Wave 566 theme: __init_subclass__ — absent from all pathlib types
# ---------------------------------------------------------------------------

table pathlib_extra1786.init_subclass:
  description: "__init_subclass__ absent from all pathlib type __dict__ — not overridden anywhere in the hierarchy"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: pl1786

  columns: [id, function, args, expected]
  rows:
    - ["pl1786005", pathlib.PurePath.__dict__.__contains__,       ["__init_subclass__"], false]
    - ["pl1786006", pathlib.PurePosixPath.__dict__.__contains__,  ["__init_subclass__"], false]
    - ["pl1786007", pathlib.PureWindowsPath.__dict__.__contains__, ["__init_subclass__"], false]
    - ["pl1786008", pathlib.Path.__dict__.__contains__,           ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Complementary: PurePath defines operator and fspath methods directly
# __truediv__ (/) and __rtruediv__ (rpathlib /) and __fspath__ are defined on PurePath itself
# ---------------------------------------------------------------------------

table pathlib_extra1786.purepath_operator_dict:
  description: "PurePath defines __truediv__, __rtruediv__, __fspath__ in its own __dict__; Path does NOT redefine them"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pl1786

  columns: [id, function, args, expected]
  rows:
    - ["pl1786009",  pathlib.PurePath.__dict__.__contains__, ["__truediv__"],  true]
    - ["pl1786010",  pathlib.PurePath.__dict__.__contains__, ["__rtruediv__"], true]
    - ["pl1786011",  pathlib.PurePath.__dict__.__contains__, ["__fspath__"],   true]
    - ["pl1786012",  pathlib.Path.__dict__.__contains__,     ["__truediv__"],  false]
    - ["pl1786013",  pathlib.Path.__dict__.__contains__,     ["__rtruediv__"], false]
    - ["pl1786014",  pathlib.Path.__dict__.__contains__,     ["__fspath__"],   false]

# ---------------------------------------------------------------------------
# Complementary: Path defines filesystem-access methods directly in its __dict__
# These are NOT on PurePath (which is filesystem-agnostic)
# ---------------------------------------------------------------------------

table pathlib_extra1786.path_filesystem_dict:
  description: "Path defines stat, open, read_text, write_text, mkdir, iterdir, glob, exists, is_file, is_dir in its own __dict__; PurePath does NOT"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pl1786

  columns: [id, function, args, expected]
  rows:
    - ["pl1786015", pathlib.Path.__dict__.__contains__,     ["stat"],      true]
    - ["pl1786016", pathlib.Path.__dict__.__contains__,     ["open"],      true]
    - ["pl1786017", pathlib.Path.__dict__.__contains__,     ["read_text"], true]
    - ["pl1786018", pathlib.Path.__dict__.__contains__,     ["mkdir"],     true]
    - ["pl1786019", pathlib.Path.__dict__.__contains__,     ["iterdir"],   true]
    - ["pl1786020", pathlib.Path.__dict__.__contains__,     ["exists"],    true]
    - ["pl1786021", pathlib.Path.__dict__.__contains__,     ["is_file"],   true]
    - ["pl1786022", pathlib.Path.__dict__.__contains__,     ["is_dir"],    true]
    - ["pl1786023", pathlib.PurePath.__dict__.__contains__, ["stat"],      false]
    - ["pl1786024", pathlib.PurePath.__dict__.__contains__, ["open"],      false]
    - ["pl1786025", pathlib.PurePath.__dict__.__contains__, ["exists"],    false]
