spec: concurrent_futures_extra225
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "concurrent.futures.Executor.__name__.__len__() == 8 — 'Executor' has 8 characters; verified with Python 3.14.3."
    - "concurrent.futures.Future.__name__.__len__() == 6 — 'Future' has 6 characters; verified with Python 3.14.3."
    - "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 — 'BrokenExecutor' has 14 characters; verified with Python 3.14.3."
    - "concurrent.futures.InvalidStateError.__name__.__len__() == 17 — 'InvalidStateError' has 17 characters; verified with Python 3.14.3."
    - "concurrent.futures.CancelledError.__name__.__len__() == 14 — 'CancelledError' has 14 characters; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18 — 'ThreadPoolExecutor' has 18 characters; verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19 — 'ProcessPoolExecutor' has 19 characters; verified with Python 3.14.3."
    - "concurrent.futures.TimeoutError.__name__.__len__() == 12 — 'TimeoutError' has 12 characters; verified with Python 3.14.3."
    - "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base' — all base classes live in _base submodule; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures exception class name length contracts — extra225 namespace
#
# Exception class name lengths: CancelledError=14, InvalidStateError=17,
# BrokenExecutor=14, TimeoutError=12; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table concurrent_futures_extra225.exception_name_lengths:
  description: "concurrent.futures exception class __name__.__len__() contracts in cf225enl namespace"
  kind: python_call_eq
  category: string_length
  id_prefix: cf225enl

  columns: [id, function, args, expected, description]
  rows:
    - [CancelledError_name_len_14,    CancelledError.__name__.__len__,    [], 14, "concurrent.futures.CancelledError.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [InvalidStateError_name_len_17, InvalidStateError.__name__.__len__, [], 17, "concurrent.futures.InvalidStateError.__name__.__len__() == 17; verified with Python 3.14.3"]
    - [BrokenExecutor_name_len_14,    BrokenExecutor.__name__.__len__,    [], 14, "concurrent.futures.BrokenExecutor.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [TimeoutError_name_len_12,      TimeoutError.__name__.__len__,      [], 12, "concurrent.futures.TimeoutError.__name__.__len__() == 12; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures executor class name length contracts — extra225 namespace
#
# Executor=8, Future=6, ThreadPoolExecutor=18, ProcessPoolExecutor=19 chars;
# verified Python 3.14.3.
# ---------------------------------------------------------------------------

table concurrent_futures_extra225.executor_name_lengths:
  description: "concurrent.futures executor class __name__.__len__() contracts in cf225xl namespace"
  kind: python_call_eq
  category: string_length
  id_prefix: cf225xl

  columns: [id, function, args, expected, description]
  rows:
    - [Executor_name_len_8,            Executor.__name__.__len__,            [], 8,  "concurrent.futures.Executor.__name__.__len__() == 8 — 'Executor' has 8 characters; verified with Python 3.14.3"]
    - [Future_name_len_6,              Future.__name__.__len__,              [], 6,  "concurrent.futures.Future.__name__.__len__() == 6 — 'Future' has 6 characters; verified with Python 3.14.3"]
    - [ThreadPoolExecutor_name_len_18, ThreadPoolExecutor.__name__.__len__,  [], 18, "concurrent.futures.ThreadPoolExecutor.__name__.__len__() == 18; verified with Python 3.14.3"]
    - [ProcessPoolExecutor_name_len_19, ProcessPoolExecutor.__name__.__len__, [], 19, "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures class __module__ contracts — extra225 namespace
#
# BrokenExecutor, InvalidStateError, CancelledError, Executor all live in
# concurrent.futures._base; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table concurrent_futures_extra225.module_checks:
  description: "concurrent.futures class __module__ contracts in cf225mod namespace"
  kind: python_call_eq
  category: module_identity
  id_prefix: cf225mod

  columns: [id, function, args, expected, description]
  rows:
    - [BrokenExecutor_module_eq,     BrokenExecutor.__module__.__eq__,     ["concurrent.futures._base"], true, "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [InvalidStateError_module_eq,  InvalidStateError.__module__.__eq__,  ["concurrent.futures._base"], true, "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [CancelledError_module_eq,     CancelledError.__module__.__eq__,     ["concurrent.futures._base"], true, "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [Executor_module_sw_concurrent, Executor.__module__.__startswith__,  ["concurrent"],               true, "concurrent.futures.Executor.__module__.__startswith__('concurrent') == True; verified with Python 3.14.3"]
