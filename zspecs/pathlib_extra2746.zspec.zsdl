spec: pathlib_extra2746
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "pathlib_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 630 (pathlib_extra2746) theme: __round__, __divmod__, and __pow__ dict-presence checks."
    - "None of the pathlib classes define __round__, __divmod__, or __pow__ in their own __dict__."
    - "__round__ supports the built-in round(); pathlib path objects are filesystem path types, not numeric types."
    - "__divmod__ supports divmod(); pathlib path objects do not implement quotient-remainder numeric semantics."
    - "__pow__ supports the ** operator; pathlib path objects do not implement exponentiation semantics."
    - "pathlib uses __truediv__ (the / operator) for path joining — none of __round__, __divmod__, or __pow__ are used."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2746.no_round_in_pathlib_classes:
  description: "__round__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the round() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2746

  columns: [id, function, args, expected]
  rows:
    - ["pp2746001", "pathlib.PurePath.__dict__.__contains__",        ["__round__"], false]
    - ["pp2746002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__round__"], false]
    - ["pp2746003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__round__"], false]
    - ["pp2746004", "pathlib.Path.__dict__.__contains__",            ["__round__"], false]

# ---------------------------------------------------------------------------
# __divmod__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2746.no_divmod_in_pathlib_classes:
  description: "__divmod__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the divmod() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2746

  columns: [id, function, args, expected]
  rows:
    - ["pp2746005", "pathlib.PurePath.__dict__.__contains__",        ["__divmod__"], false]
    - ["pp2746006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__divmod__"], false]
    - ["pp2746007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__divmod__"], false]
    - ["pp2746008", "pathlib.Path.__dict__.__contains__",            ["__divmod__"], false]

# ---------------------------------------------------------------------------
# __pow__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2746.no_pow_in_pathlib_classes:
  description: "__pow__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the ** exponentiation protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2746

  columns: [id, function, args, expected]
  rows:
    - ["pp2746009", "pathlib.PurePath.__dict__.__contains__",        ["__pow__"], false]
    - ["pp2746010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__pow__"], false]
    - ["pp2746011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__pow__"], false]
    - ["pp2746012", "pathlib.Path.__dict__.__contains__",            ["__pow__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib classes have path-manipulation methods but not arithmetic numeric hooks
# Confirms that path objects use __truediv__ for joining and have no __round__/__divmod__/__pow__ semantics
# ---------------------------------------------------------------------------

table pathlib_extra2746.pathlib_has_path_methods_not_arithmetic_numeric_hooks:
  description: "pathlib.PurePath defines __str__/__truediv__/__fspath__ but NOT __round__/__divmod__/__pow__; pathlib.Path defines stat/exists/open but NOT __round__/__divmod__/__pow__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2746

  columns: [id, function, args, expected]
  rows:
    - ["pp2746013", "pathlib.PurePath.__dict__.__contains__", ["__str__"],     true]
    - ["pp2746014", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"], true]
    - ["pp2746015", "pathlib.PurePath.__dict__.__contains__", ["__fspath__"],  true]
    - ["pp2746016", "pathlib.PurePath.__dict__.__contains__", ["__round__"],   false]
    - ["pp2746017", "pathlib.PurePath.__dict__.__contains__", ["__divmod__"],  false]
    - ["pp2746018", "pathlib.PurePath.__dict__.__contains__", ["__pow__"],     false]
    - ["pp2746019", "pathlib.Path.__dict__.__contains__",     ["stat"],        true]
    - ["pp2746020", "pathlib.Path.__dict__.__contains__",     ["exists"],      true]
    - ["pp2746021", "pathlib.Path.__dict__.__contains__",     ["open"],        true]
    - ["pp2746022", "pathlib.Path.__dict__.__contains__",     ["__round__"],   false]
    - ["pp2746023", "pathlib.Path.__dict__.__contains__",     ["__divmod__"],  false]
    - ["pp2746024", "pathlib.Path.__dict__.__contains__",     ["__pow__"],     false]
