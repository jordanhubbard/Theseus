spec: is_letter
version: ">=1.3.10"
backend: node(is-letter)

docs: https://www.npmjs.com/package/is-letter

provenance:
  derived_from:
    - "is-letter README — https://www.npmjs.com/package/is-letter"
    - "Test vectors verified with is-letter via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "is-letter source"
  notes:
    - "is-letter is an npm package. Install: npm install is-letter"
    - "Returns true if the single character is a letter (a-z, A-Z). Multi-character strings and digits return false."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_letter.check:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: islet

  columns: [id, args, expected]
  rows:
    - [lower,  ["a"], true]
    - [upper,  ["Z"], true]
    - [digit,  ["1"], false]
    - [multi,  ["hello"], false]
