spec: statistics_extra2_rust
version: ">=3.9"
backend: rust_module(statistics_extra2_rust)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics documentation"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "Additional statistics functions beyond statistics_rust (mean, median, mode, stdev, variance)."
    - "geometric_mean(data) returns the geometric mean; exact for perfect powers."
    - "geometric_mean([4, 9]) == 6.0 — sqrt(36) = 6."
    - "geometric_mean([2, 8]) == 4.0 — sqrt(16) = 4."
    - "geometric_mean([1, 4, 16]) == 4.0 — cbrt(64) = 4."
    - "harmonic_mean(data) returns the harmonic mean n / sum(1/xi)."
    - "harmonic_mean([2, 2]) == 2.0 — all equal, harmonic mean equals value."
    - "harmonic_mean([1, 4]) == 1.6 — 2/(1 + 1/4) = 2/(5/4) = 8/5 = 1.6."
    - "median_low(data) returns the lower of two middle values for even-length data."
    - "median_high(data) returns the higher of two middle values for even-length data."
    - "median_low([1, 3, 5, 7]) == 3, median_high([1, 3, 5, 7]) == 5."
    - "For odd-length data, median_low and median_high both return the middle value."
    - "All test vectors verified against Python 3.14.3 statistics module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# geometric_mean — exact values for perfect squares/cubes
table statistics_extra2_rust.geometric_mean.vectors:
  kind: python_call_eq
  category: geometric_mean
  id_prefix: st2_gm
  function: geometric_mean

  columns: [id, args, expected]
  rows:
    - [sqrt_36,   [[4, 9]],      6.0]
    - [sqrt_16,   [[2, 8]],      4.0]
    - [cbrt_64,   [[1, 4, 16]], 4.0]
    - [all_one,   [[1, 1, 1]],   1.0]
    - [single,    [[25]],        25.0]

# harmonic_mean — exact fractional values
table statistics_extra2_rust.harmonic_mean.vectors:
  kind: python_call_eq
  category: harmonic_mean
  id_prefix: st2_hm
  function: harmonic_mean

  columns: [id, args, expected]
  rows:
    - [equal_two,   [[2, 2]],     2.0]
    - [equal_four,  [[4, 4, 4]], 4.0]
    - [one_four,    [[1, 4]],     1.6]
    - [all_one,     [[1, 1, 1]], 1.0]

# median_low — lower middle value for even-length data
table statistics_extra2_rust.median_low.vectors:
  kind: python_call_eq
  category: median_low
  id_prefix: st2_ml
  function: median_low

  columns: [id, args, expected]
  rows:
    - [even_four,  [[1, 3, 5, 7]], 3]
    - [even_six,   [[2, 4, 6, 8, 10, 12]], 6]
    - [odd_three,  [[1, 2, 3]],    2]
    - [odd_five,   [[1, 2, 3, 4, 5]], 3]

# median_high — higher middle value for even-length data
table statistics_extra2_rust.median_high.vectors:
  kind: python_call_eq
  category: median_high
  id_prefix: st2_mh
  function: median_high

  columns: [id, args, expected]
  rows:
    - [even_four,  [[1, 3, 5, 7]], 5]
    - [even_six,   [[2, 4, 6, 8, 10, 12]], 8]
    - [odd_three,  [[1, 2, 3]],    2]
    - [odd_five,   [[1, 2, 3, 4, 5]], 3]

