table asyncio_extra169.asyncio_event_identity_and_base:
  description: "asyncio.Event class name, module, base class, and MRO checks in asyncioevent169 namespace — asyncio.Event.__name__.__eq__('Event')==True (Event.__name__=='Event' (len=5: 'E'+'v'+'e'+'n'+'t'=5); asyncio.Event() is an async notification flag: set() sets the event, clear() unsets it, wait() blocks until the event is set, is_set() returns the current state; Event does NOT support 'async with' — it is not a context manager); asyncio.Event.__name__.__len__()==5 ('Event'=5; compare: asyncio.Queue.__name__.__len__()==5 from extra168 — both 'Event' and 'Queue' are 5-char asyncio names; Lock(4) < Event=Queue(5) < Semaphore=Condition(9)); asyncio.Event.__module__.__eq__('asyncio.locks')==True (__module__=='asyncio.locks' (len=13; same as Lock, Semaphore, Condition)); KEY FINDING: asyncio.Event.__bases__[0].__name__.__eq__('_LoopBoundMixin')==True (Event's direct base is '_LoopBoundMixin', NOT '_ContextManagerMixin'; Events do not support async context manager protocol; asyncio.Event.__mro__.__len__()==3 (Event->_LoopBoundMixin->object; 3 entries; 1 shorter than Lock/Semaphore/Condition MRO=4 because Event skips _ContextManagerMixin)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioevent169

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,       asyncio.Event.__name__.__eq__,                   ["Event"],            true,  "Event.__name__ == 'Event' (len=5: 'Event'=5; no async context manager support); verified with Python 3.14.3"]
    - [event_name_len,      asyncio.Event.__name__.__len__,                  [],                   5,     "Event.__name__.__len__() == 5 ('Event'=5; same len as asyncio.Queue=5 from extra168); verified with Python 3.14.3"]
    - [event_mod_eq,        asyncio.Event.__module__.__eq__,                 ["asyncio.locks"],    true,  "Event.__module__ == 'asyncio.locks' (len=13; same as Lock/Semaphore/Condition); verified with Python 3.14.3"]
    - [event_base_name_eq,  "asyncio.Event.__bases__[0].__name__.__eq__",    ["_LoopBoundMixin"],  true,  "Event.__bases__[0].__name__ == '_LoopBoundMixin' (NOT _ContextManagerMixin; Event is not an async context manager); verified with Python 3.14.3"]
    - [event_mro_len,       asyncio.Event.__mro__.__len__,                   [],                   3,     "Event.__mro__.__len__() == 3 (Event->_LoopBoundMixin->object; 1 shorter than Lock/Semaphore=4); verified with Python 3.14.3"]

