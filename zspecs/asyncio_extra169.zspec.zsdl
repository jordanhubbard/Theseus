table asyncio_extra169.asyncio_lock_identity_and_base:
  description: "asyncio.Lock class name, module, base class, and MRO checks in asynciolock169 namespace — asyncio.Lock.__name__.__eq__('Lock')==True (Lock.__name__=='Lock' (len=4: 'L'+'o'+'c'+'k'=4); asyncio.Lock() is the async mutual exclusion lock — only one coroutine can hold the lock at a time; Lock.acquire() is a coroutine that blocks until the lock is free; Lock.release() releases the lock; Lock supports 'async with' via _ContextManagerMixin); asyncio.Lock.__name__.__len__()==4 ('Lock'=4; the shortest name among asyncio sync primitives: Lock(4) < Event(5) < Semaphore=Condition(9)); asyncio.Lock.__module__.__eq__('asyncio.locks')==True (__module__=='asyncio.locks' (len=13; same as Semaphore, Event, Condition — all in asyncio/locks.py)); asyncio.Lock.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (Lock's direct base is _ContextManagerMixin, same as Semaphore; asyncio.Lock.__mro__.__len__()==4 (Lock->_ContextManagerMixin->_LoopBoundMixin->object; 4 entries; same MRO length as Semaphore=4)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolock169

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,       asyncio.Lock.__name__.__eq__,                  ["Lock"],                  true,  "Lock.__name__ == 'Lock' (len=4: shortest asyncio sync primitive name); verified with Python 3.14.3"]
    - [lock_name_len,      asyncio.Lock.__name__.__len__,                 [],                        4,     "Lock.__name__.__len__() == 4 ('Lock'=4; Lock(4) < Event(5) < Semaphore=Condition(9)); verified with Python 3.14.3"]
    - [lock_mod_eq,        asyncio.Lock.__module__.__eq__,                ["asyncio.locks"],         true,  "Lock.__module__ == 'asyncio.locks' (len=13; same module as Semaphore/Event/Condition); verified with Python 3.14.3"]
    - [lock_base_name_eq,  "asyncio.Lock.__bases__[0].__name__.__eq__",   ["_ContextManagerMixin"],  true,  "Lock.__bases__[0].__name__ == '_ContextManagerMixin' (same as Semaphore; supports async with); verified with Python 3.14.3"]
    - [lock_mro_len,       asyncio.Lock.__mro__.__len__,                  [],                        4,     "Lock.__mro__.__len__() == 4 (Lock->_ContextManagerMixin->_LoopBoundMixin->object); verified with Python 3.14.3"]

