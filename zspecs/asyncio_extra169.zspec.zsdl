spec: asyncio_extra169
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/mixins.py"
  notes:
    - "This spec covers: asyncio.Semaphore class name, module, and base class identity; asyncio.Lock class name, module, and base class identity; asyncio.Event class name, module, and base class identity; asyncio.Condition class name, module, and base class identity. KEY FINDING: asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (NOT '_LoopBoundMixin' — Semaphore, Lock, and Condition all have _ContextManagerMixin as their DIRECT base; _ContextManagerMixin itself inherits from _LoopBoundMixin, making the MRO 4 entries: cls -> _ContextManagerMixin -> _LoopBoundMixin -> object); asyncio.Event.__bases__[0].__name__=='_LoopBoundMixin' (Event does NOT use _ContextManagerMixin — it inherits from _LoopBoundMixin directly, giving a 3-entry MRO: Event -> _LoopBoundMixin -> object). All classes have __module__=='asyncio.locks' (len=13). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Semaphore.__name__=='Semaphore' (len=9: 'Semaphore'=9); asyncio.Semaphore.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (len=19: '_'=1+'Context'=7+'Manager'=7+'Mixin'=4... wait: '_ContextManagerMixin'=19: '_'=1+'Context'=7+'Manager'=7+'Mixin'=4=19); MRO len=4. Verified with Python 3.14.3."
    - "asyncio.Lock.__name__=='Lock' (len=4: 'L'+'o'+'c'+'k'=4); asyncio.Lock.__module__=='asyncio.locks' (len=13; same as Semaphore); Lock.__bases__[0].__name__=='_ContextManagerMixin' (same as Semaphore; both Lock and Semaphore support async context manager protocol via _ContextManagerMixin); Lock MRO len=4 (Lock->_ContextManagerMixin->_LoopBoundMixin->object). Verified with Python 3.14.3."
    - "asyncio.Event.__name__=='Event' (len=5: 'E'+'v'+'e'+'n'+'t'=5); asyncio.Event.__module__=='asyncio.locks' (len=13; same module); Event.__bases__[0].__name__=='_LoopBoundMixin' (Event does NOT inherit from _ContextManagerMixin — Events do not support the async context manager protocol: you cannot use 'async with event'; Event MRO len=3: Event->_LoopBoundMixin->object — shorter than Lock/Semaphore/Condition MRO len=4). Verified with Python 3.14.3."
    - "asyncio.Condition.__name__=='Condition' (len=9: 'Condition'=9; same length as Semaphore=9); asyncio.Condition.__module__=='asyncio.locks' (len=13); Condition.__bases__[0].__name__=='_ContextManagerMixin' (Condition supports async context manager via _ContextManagerMixin; MRO len=4). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Semaphore class identity — extra169
#
# asyncio.Semaphore.__name__.__eq__('Semaphore')          == True
# asyncio.Semaphore.__name__.__len__()                    == 9
# asyncio.Semaphore.__module__.__eq__('asyncio.locks')    == True
# asyncio.Semaphore.__module__.__len__()                  == 13
# ---------------------------------------------------------------------------

table asyncio_extra169.asyncio_semaphore_identity:
  description: "asyncio.Semaphore class name and module identity checks in asynciosem169 namespace — asyncio.Semaphore.__name__.__eq__('Semaphore')==True (Semaphore.__name__=='Semaphore' (len=9: 'Semaphore'=9); asyncio.Semaphore(value=1) is the async-safe counting semaphore; acquire() blocks when the internal counter is 0; release() increments the counter and wakes a waiting coroutine; Semaphore supports async context manager protocol: 'async with sem' is equivalent to 'await sem.acquire()' / 'sem.release()'); asyncio.Semaphore.__name__.__len__()==9 ('Semaphore'=9; same length as 'Condition'=9 — both are 9-char lock type names; compare: 'Lock'=4, 'Event'=5 are shorter); asyncio.Semaphore.__module__.__eq__('asyncio.locks')==True (__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); note: asyncio.locks=13 is 1 shorter than asyncio.queues=14 from extra168 because 'locks'=5 < 'queues'=6 by 1); asyncio.Semaphore.__module__.__len__()==13 ('asyncio.locks'=13; same for Lock, Event, Condition — all four synchronization primitives share this module); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosem169

  columns: [id, function, args, expected, description]
  rows:
    - [sem_name_eq,  asyncio.Semaphore.__name__.__eq__,    ["Semaphore"],       true,  "Semaphore.__name__ == 'Semaphore' (len=9: 'Semaphore'=9; counting semaphore); verified with Python 3.14.3"]
    - [sem_name_len, asyncio.Semaphore.__name__.__len__,   [],                  9,     "Semaphore.__name__.__len__() == 9 ('Semaphore'=9; same as Condition=9; Lock=4 < Event=5 < Semaphore=9); verified with Python 3.14.3"]
    - [sem_mod_eq,   asyncio.Semaphore.__module__.__eq__,  ["asyncio.locks"],   true,  "Semaphore.__module__ == 'asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); verified with Python 3.14.3"]
    - [sem_mod_len,  asyncio.Semaphore.__module__.__len__, [],                  13,    "Semaphore.__module__.__len__() == 13 ('asyncio.locks'=13; 1 shorter than asyncio.queues=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Semaphore base class — extra169
#
# KEY: asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'
# asyncio.Semaphore.__mro__.__len__() == 4
# ---------------------------------------------------------------------------

table asyncio_extra169.asyncio_semaphore_base_class:
  description: "asyncio.Semaphore base class and MRO checks in asynciosembase169 namespace — KEY FINDING: asyncio.Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (len=19: '_'=1+'Context'=7+'Manager'=7+'Mixin'=4=19); Semaphore's DIRECT base is _ContextManagerMixin, NOT _LoopBoundMixin; _ContextManagerMixin itself inherits from _LoopBoundMixin; the full MRO is Semaphore -> _ContextManagerMixin -> _LoopBoundMixin -> object (len=4); _ContextManagerMixin provides __aenter__ and __aexit__ enabling 'async with sem' syntax; compare: asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (from extra168) — Queue does NOT use _ContextManagerMixin because queues are not used as context managers; asyncio.Semaphore.__mro__.__len__()==4 (4 entries: Semaphore, _ContextManagerMixin, _LoopBoundMixin, object; one more than Queue MRO=3 because _ContextManagerMixin adds an extra level)); asyncio.Semaphore.__mro__.__len__()==4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosembase169

  columns: [id, function, args, expected, description]
  rows:
    - [sem_base_name_eq,  "asyncio.Semaphore.__bases__[0].__name__.__eq__",  ["_ContextManagerMixin"],  true,  "Semaphore.__bases__[0].__name__ == '_ContextManagerMixin' (NOT _LoopBoundMixin; provides async with support); verified with Python 3.14.3"]
    - [sem_base_name_len, "asyncio.Semaphore.__bases__[0].__name__.__len__", [],                        19,    "Semaphore.__bases__[0].__name__.__len__() == 19 ('_ContextManagerMixin'=19); verified with Python 3.14.3"]
    - [sem_mro_len,       asyncio.Semaphore.__mro__.__len__,                 [],                        4,     "Semaphore.__mro__.__len__() == 4 (Semaphore->_ContextManagerMixin->_LoopBoundMixin->object); verified with Python 3.14.3"]
    - [sem_name_len2,     asyncio.Semaphore.__name__.__len__,                [],                        9,     "Semaphore.__name__.__len__() == 9 (cross-check; 'Semaphore'=9); verified with Python 3.14.3"]

