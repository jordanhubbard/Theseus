# asyncio.Condition.__mro__.__len__()                             == 4
# ---------------------------------------------------------------------------

table asyncio_extra169.asyncio_condition_identity_and_base:
  description: "asyncio.Condition class name, module, base class, and MRO checks in asynciocond169 namespace — asyncio.Condition.__name__.__eq__('Condition')==True (Condition.__name__=='Condition' (len=9: 'Condition'=9; same length as Semaphore=9 — both are 9-char sync primitive names); asyncio.Condition(lock=None) implements the classic condition variable: wait() atomically releases the underlying lock and blocks until notify() or notify_all() is called; acquire()/release() manage the underlying lock; Condition supports 'async with' via _ContextManagerMixin); asyncio.Condition.__name__.__len__()==9 ('Condition'=9; same as 'Semaphore'=9: LENGTH EQUALITY: Semaphore.__name__.__len__()==Condition.__name__.__len__()==9); asyncio.Condition.__module__.__eq__('asyncio.locks')==True (__module__=='asyncio.locks' (len=13; all four sync primitives share this module)); asyncio.Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (same base as Lock and Semaphore; asyncio.Condition.__mro__.__len__()==4 (Condition->_ContextManagerMixin->_LoopBoundMixin->object; 4 entries; same as Lock and Semaphore)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocond169

  columns: [id, function, args, expected, description]
  rows:
    - [cond_name_eq,       asyncio.Condition.__name__.__eq__,                   ["Condition"],             true,  "Condition.__name__ == 'Condition' (len=9: same as Semaphore=9; supports async with); verified with Python 3.14.3"]
    - [cond_name_len,      asyncio.Condition.__name__.__len__,                  [],                        9,     "Condition.__name__.__len__() == 9 ('Condition'=9; same as Semaphore=9; Lock(4) < Event(5) < Cond=Sem(9)); verified with Python 3.14.3"]
    - [cond_mod_eq,        asyncio.Condition.__module__.__eq__,                 ["asyncio.locks"],         true,  "Condition.__module__ == 'asyncio.locks' (len=13; same as Lock/Event/Semaphore); verified with Python 3.14.3"]
    - [cond_base_name_eq,  "asyncio.Condition.__bases__[0].__name__.__eq__",    ["_ContextManagerMixin"],  true,  "Condition.__bases__[0].__name__ == '_ContextManagerMixin' (same as Lock/Semaphore; supports async with); verified with Python 3.14.3"]
    - [cond_mro_len,       asyncio.Condition.__mro__.__len__,                   [],                        4,     "Condition.__mro__.__len__() == 4 (Condition->_ContextManagerMixin->_LoopBoundMixin->object); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra169
# ---------------------------------------------------------------------------

invariant asyncio_extra169.asyncio_Semaphore_name_eq:
  description: "asyncio.Semaphore.__name__.__eq__('Semaphore') returns True — asyncio.Semaphore.__name__=='Semaphore' (len=9: 'Semaphore'=9); asyncio.Semaphore is the async-safe counting semaphore used to limit concurrent access to a resource: Semaphore(value=N) allows at most N concurrent holders; acquire() decrements the counter (blocks when 0); release() increments it (wakes one waiter if any); Semaphore supports 'async with sem:' syntax via _ContextManagerMixin; Semaphore.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13; 1 shorter than asyncio.queues=14 from extra168 because 'locks'=5 < 'queues'=6); KEY: Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (NOT '_LoopBoundMixin' — this is a KEY DISTINCTION from asyncio.Queue which has _LoopBoundMixin as its direct base; Semaphore adds one more level in its MRO via _ContextManagerMixin giving MRO len=4); compare: Semaphore(9)==Condition(9) in name length; Lock(4) < Event(5) < Semaphore=Condition(9) in length ordering; NEW in extra169: first standalone Semaphore.__name__ identity invariant in asynciosem169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra169.asyncio_Semaphore_module_eq:
  description: "asyncio.Semaphore.__module__.__eq__('asyncio.locks') returns True — asyncio.Semaphore.__module__=='asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13); all four asyncio synchronization primitives (Lock, Event, Semaphore, Condition) are defined in Lib/asyncio/locks.py and share __module__=='asyncio.locks' (len=13); compare module path lengths: asyncio.locks(13) < asyncio.queues(14) < asyncio.streams(15) — locks submodule name 'locks'=5 is shorter than 'queues'=6 and 'streams'=7; asyncio.locks module defines: Lock, Event, Condition, Semaphore, BoundedSemaphore, and the internal mixins _ContextManagerMixin and _LoopBoundMixin; Semaphore.__module__.__len__()==13 == Lock.__module__.__len__()==13 == Event.__module__.__len__()==13 == Condition.__module__.__len__()==13 — all four primitives share the same 13-char module path; NEW in extra169: first standalone Semaphore.__module__ identity invariant in asynciosem169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra169.asyncio_Semaphore_base_is_ContextManagerMixin:
  description: "asyncio.Semaphore.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — KEY FINDING: asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin' (len=19: '_'=1+'Context'=7+'Manager'=7+'Mixin'=4=19); Semaphore's DIRECT base class is _ContextManagerMixin, NOT _LoopBoundMixin; the full MRO is Semaphore -> _ContextManagerMixin -> _LoopBoundMixin -> object (4 entries); _ContextManagerMixin provides __aenter__(self) which calls self.acquire() and __aexit__(self, ...) which calls self.release(), enabling 'async with sem:' usage; _LoopBoundMixin is still in the MRO at position 2 (accessed via _ContextManagerMixin's inheritance); compare: asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin' (from extra168: Queue's direct base IS _LoopBoundMixin, not _ContextManagerMixin — Queues are not async context managers); compare: asyncio.Event.__bases__[0].__name__=='_LoopBoundMixin' (Event also inherits from _LoopBoundMixin directly — Events are not async context managers either); PATTERN: Lock, Semaphore, Condition all use _ContextManagerMixin as their direct base (they are context managers); Event does NOT; NEW in extra169; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Semaphore.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra169.asyncio_Lock_name_eq:
  description: "asyncio.Lock.__name__.__eq__('Lock') returns True — asyncio.Lock.__name__=='Lock' (len=4: 'L'+'o'+'c'+'k'=4); asyncio.Lock is the mutual exclusion lock for coroutines; it provides mutual exclusion: only one coroutine can hold the lock at a time; once held, any other coroutine calling acquire() is suspended until release() is called; Lock is non-reentrant — a coroutine trying to acquire a Lock it already holds will deadlock; compare asyncio.Lock with threading.Lock: asyncio.Lock is NOT thread-safe and must be used only within a single event loop; Lock.__bases__[0].__name__=='_ContextManagerMixin' (Lock supports 'async with lock:' syntax); Lock.__mro__.__len__()==4 (Lock->_ContextManagerMixin->_LoopBoundMixin->object); Lock.__name__.__len__()==4 is the shortest async lock name: Lock(4) < Event(5) < Semaphore=Condition(9); compare: asyncio.Task.__name__.__len__()==4 (from extra166) — both 'Task' and 'Lock' are 4-char asyncio names; NEW in extra169: first standalone Lock.__name__ identity invariant in asynciolock169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant asyncio_extra169.asyncio_Lock_base_is_ContextManagerMixin:
  description: "asyncio.Lock.__bases__[0].__name__.__eq__('_ContextManagerMixin') returns True — asyncio.Lock.__bases__[0].__name__=='_ContextManagerMixin' (len=19: same as Semaphore's base); Lock's direct base is _ContextManagerMixin, enabling 'async with lock:' syntax; the full Lock MRO is Lock -> _ContextManagerMixin -> _LoopBoundMixin -> object (4 entries); Lock.__mro__.__len__()==4 == Semaphore.__mro__.__len__()==4 (both 4-entry MROs because both use _ContextManagerMixin as their direct base); compare: asyncio.Event.__bases__[0].__name__=='_LoopBoundMixin' (Event skips _ContextManagerMixin — a KEY CONTRAST to Lock and Semaphore); Lock.__bases__[0].__name__ == Semaphore.__bases__[0].__name__ == '_ContextManagerMixin' — Lock and Semaphore share the same direct base class; NEW in extra169: first standalone Lock.__bases__[0].__name__ invariant in asynciolock169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Lock.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra169.asyncio_Event_name_eq:
  description: "asyncio.Event.__name__.__eq__('Event') returns True — asyncio.Event.__name__=='Event' (len=5: 'E'+'v'+'e'+'n'+'t'=5); asyncio.Event is a notification flag for coroutines; set() marks the event; clear() unmarks it; wait() is a coroutine that returns immediately if the event is set or blocks until set() is called; is_set() returns the current flag state without blocking; Event does NOT support 'async with event:' — it is NOT an async context manager; compare: asyncio.Queue.__name__.__len__()==5 (from extra168 — 'Queue' and 'Event' are both 5-char asyncio names); Event.__bases__[0].__name__=='_LoopBoundMixin' (unlike Lock/Semaphore/Condition which have _ContextManagerMixin as their direct base, Event uses _LoopBoundMixin directly — giving Event a shorter 3-entry MRO vs the 4-entry MRO of context-manager-capable sync primitives); Event.__mro__.__len__()==3 (Event->_LoopBoundMixin->object; 1 shorter than Lock/Semaphore/Condition MRO=4); NEW in extra169: first standalone Event.__name__ identity invariant in asyncioevent169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant asyncio_extra169.asyncio_Event_base_is_LoopBoundMixin:
  description: "asyncio.Event.__bases__[0].__name__.__eq__('_LoopBoundMixin') returns True — KEY CONTRAST: asyncio.Event.__bases__[0].__name__=='_LoopBoundMixin' (len=15: '_'=1+'Loop'=4+'Bound'=5+'Mixin'=5=15); Event's direct base is '_LoopBoundMixin', which is the SAME direct base that asyncio.Queue uses (from extra168); Event does NOT have _ContextManagerMixin in its __bases__ — it cannot be used with 'async with event:'; the full Event MRO is Event -> _LoopBoundMixin -> object (3 entries); compare: Lock.__bases__[0].__name__=='_ContextManagerMixin' (Lock's direct base is _ContextManagerMixin, NOT _LoopBoundMixin — Lock is an async context manager); PATTERN in asyncio.locks: Lock, Semaphore, Condition use _ContextManagerMixin (4-entry MRO); Event uses _LoopBoundMixin directly (3-entry MRO); Event.__mro__.__len__()==3 == asyncio.Queue.__mro__.__len__()==3 (both have the same minimal 3-entry MRO without _ContextManagerMixin); NEW in extra169: first standalone Event.__bases__[0].__name__ invariant in asyncioevent169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Event.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra169.asyncio_Condition_name_eq:
  description: "asyncio.Condition.__name__.__eq__('Condition') returns True — asyncio.Condition.__name__=='Condition' (len=9: 'Condition'=9; same length as Semaphore=9); asyncio.Condition(lock=None) implements the classic monitor/condition-variable pattern for coroutines: acquire() acquires the underlying lock; wait() atomically releases the lock and waits for notify()/notify_all(); notify(n=1) wakes n waiters; notify_all() wakes all waiters; Condition supports 'async with cond:' via _ContextManagerMixin; Condition.__bases__[0].__name__=='_ContextManagerMixin' (same as Lock and Semaphore); Condition.__mro__.__len__()==4 (Condition->_ContextManagerMixin->_LoopBoundMixin->object; same 4-entry MRO as Lock and Semaphore); LENGTH EQUALITY: Condition.__name__.__len__()==9 == Semaphore.__name__.__len__()==9 — both are 9-char names; compare: Lock(4) < Event(5) < Condition=Semaphore(9) in asyncio.locks name length ordering; NEW in extra169: first standalone Condition.__name__ identity invariant in asynciocond169 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__name__.__eq__
  args: ["Condition"]
  expected: true
