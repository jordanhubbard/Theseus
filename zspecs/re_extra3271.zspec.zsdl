    - ["re3271005", operator.contains, [re.Match.__dict__,     "__ror__"], false]
    - ["re3271006", operator.contains, [re.RegexFlag.__dict__, "__ror__"], false]

# ---------------------------------------------------------------------------
# __rxor__ dict-presence — operator.contains(Cls.__dict__, '__rxor__')
#
# No re class defines __rxor__ in its own __dict__; all false.
