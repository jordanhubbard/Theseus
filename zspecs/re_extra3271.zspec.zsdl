spec: re3271
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 665 (re3271): __rand__, __ror__, __rxor__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __rand__, __ror__, __rxor__ dict-presence (reflected bitwise logical)."
    - "No re class defines __rand__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; bitwise AND is not part of their protocol."
    - "No re class defines __ror__ in its own __dict__: re types are not integer operands; reflected bitwise OR is not defined on any re type."
    - "No re class defines __rxor__ in its own __dict__: reflected bitwise XOR is not defined on any re type."
    - "re.RegexFlag is defined as class RegexFlag(enum.IntFlag): the reflected bitwise logical methods __rand__, __ror__, __rxor__ are not defined in re.RegexFlag.__dict__ itself; they are inherited from IntFlag/int but not overridden in re.RegexFlag."
    - "operator.contains(re.RegexFlag.__dict__, '__ror__') = False: __ror__ is not stored in re.RegexFlag's own __dict__ even though IntFlag supports | for flag composition."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rand__ dict-presence — operator.contains(Cls.__dict__, '__rand__')
#
# No re class defines __rand__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but reflected bitwise AND is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3271.rand:
  description: "re types __rand__ dict-presence checks; wave 665"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3271

  columns: [id, function, args, expected]
  rows:
    - ["re3271001", operator.contains, [re.Pattern.__dict__,   "__rand__"], false]
    - ["re3271002", operator.contains, [re.Match.__dict__,     "__rand__"], false]
    - ["re3271003", operator.contains, [re.RegexFlag.__dict__, "__rand__"], false]

# ---------------------------------------------------------------------------
# __ror__ dict-presence — operator.contains(Cls.__dict__, '__ror__')
#
# No re class defines __ror__ in its own __dict__; all false.
# re types are not integer operands; reflected bitwise OR is not part of the
# re type protocol. re.RegexFlag (IntFlag) does not define __ror__ in its own
# __dict__ even though | is used for flag composition at the IntFlag level.
# ---------------------------------------------------------------------------

table re3271.ror:
  description: "re types __ror__ dict-presence checks; wave 665"
