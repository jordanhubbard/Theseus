spec: hl3136
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 656 (hl3136): __call__, __len__, __getitem__ dict-presence checks for hashlib types."
    - "type(hashlib.md5()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "type(hashlib.blake2s(b'')) is _blake2.blake2s — distinct from HASH and blake2b."
    - "None of the hashlib types define __call__, __len__, or __getitem__ in their own __dict__."
    - "Hash objects are not callable (no __call__), not sized (no __len__), and not subscriptable (no __getitem__) — they expose a digest/update API only."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3136.call:
  description: "hashlib types __call__ dict-presence checks; wave 656"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl3136
  columns: [id, function, args, expected]
  rows:
    - ["hl3136001", operator.contains, [type(hashlib.md5()).__dict__,        "__call__"], false]
    - ["hl3136002", operator.contains, [type(hashlib.sha256()).__dict__,     "__call__"], false]
    - ["hl3136003", operator.contains, [type(hashlib.sha512()).__dict__,     "__call__"], false]
    - ["hl3136004", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__call__"], false]
    - ["hl3136005", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__call__"], false]

