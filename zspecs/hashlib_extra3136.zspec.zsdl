    - ["hl3136008", operator.contains, [type(hashlib.sha512()).__dict__,     "__len__"], false]
    - ["hl3136009", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__len__"], false]
    - ["hl3136010", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__len__"], false]

