spec: re_extra2461
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "Python re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl"
  notes:
    - "Wave 2461, theme: __len__ and __length_hint__ dict-presence — re module classes do not define length protocol."
    - "re.Pattern is a compiled regex object; it defines match, search, sub etc. but not __len__ or __length_hint__."
    - "re.Match holds match results and defines group, groups, start, end, span — no length protocol."
    - "re.Scanner (internal class) also has no length protocol in its __dict__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# re.Pattern — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table re_extra2461.pattern_length_protocol:
  description: "re.Pattern.__dict__ does not define __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2461

  columns: [id, function, args, expected]
  rows:
    - ["re2461001", "re.Pattern.__dict__.__contains__", ["__len__"],         false]
    - ["re2461002", "re.Pattern.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# re.Match — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table re_extra2461.match_length_protocol:
  description: "re.Match.__dict__ does not define __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2461

  columns: [id, function, args, expected]
  rows:
    - ["re2461003", "re.Match.__dict__.__contains__", ["__len__"],         false]
    - ["re2461004", "re.Match.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# re.Scanner — length protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table re_extra2461.scanner_length_protocol:
  description: "re.Scanner.__dict__ does not define __len__ or __length_hint__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2461

  columns: [id, function, args, expected]
  rows:
    - ["re2461005", "re.Scanner.__dict__.__contains__", ["__len__"],         false]
    - ["re2461006", "re.Scanner.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Complementary: methods that ARE in re class __dict__
# ---------------------------------------------------------------------------

table re_extra2461.class_own_methods:
  description: "Methods that ARE present in re class __dict__ (not length protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2461

  columns: [id, function, args, expected]
  rows:
    - ["re2461007", "re.Pattern.__dict__.__contains__", ["match"],     true]
    - ["re2461008", "re.Pattern.__dict__.__contains__", ["fullmatch"], true]
    - ["re2461009", "re.Pattern.__dict__.__contains__", ["search"],    true]
    - ["re2461010", "re.Pattern.__dict__.__contains__", ["sub"],       true]
    - ["re2461011", "re.Pattern.__dict__.__contains__", ["findall"],   true]
    - ["re2461012", "re.Pattern.__dict__.__contains__", ["split"],     true]
    - ["re2461013", "re.Match.__dict__.__contains__",   ["group"],     true]
    - ["re2461014", "re.Match.__dict__.__contains__",   ["groups"],    true]
    - ["re2461015", "re.Match.__dict__.__contains__",   ["start"],     true]
    - ["re2461016", "re.Match.__dict__.__contains__",   ["end"],       true]
    - ["re2461017", "re.Match.__dict__.__contains__",   ["span"],      true]
