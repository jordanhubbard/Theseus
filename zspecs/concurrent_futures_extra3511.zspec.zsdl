spec: cf3511
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (cf3511): __get__, __set__, __delete__ dict-presence checks for concurrent.futures types."
    - "All values false — concurrent.futures types implement context manager protocol but not the descriptor protocol."
    - "concurrent.futures.Future, ThreadPoolExecutor, ProcessPoolExecutor: none define __get__, __set__, or __delete__ in their own __dict__."
    - "ThreadPoolExecutor defines __enter__/__exit__ (true in prior waves) but NOT __get__/__set__/__delete__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table cf3511.get:
  description: "concurrent.futures types __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3511
  columns: [id, function, args, expected]
  rows:
    - ["cf3511001", operator.contains, [concurrent.futures.Future.__dict__,              "__get__"], false]
    - ["cf3511002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__get__"], false]
    - ["cf3511003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__get__"], false]

