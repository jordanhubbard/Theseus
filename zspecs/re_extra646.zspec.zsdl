spec: re_extra646
version: ">=3.9"
backend: python_module(re)
docs: "Behavioral spec for re.Pattern and re.Match __doc__ class identity and __qualname__ values."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module class and method reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Pattern and re.Match are the public type aliases exposed since Python 3.7."
    - "__qualname__ on these classes reflects the canonical short name without module prefix."
  created_at: "2026-04-12T00:00:00Z"

table re_extra646.pattern_doc_class_names:
  description: "Class name of __doc__ for re.Pattern and its methods."
  kind: python_call_eq
  category: doc_type
  id_prefix: re646pt
  columns: [id, function, args, expected]
  rows:
    - [re646pt001, re.Pattern.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re646pt002, re.Pattern.match.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re646pt003, re.Pattern.search.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re646pt004, re.Pattern.findall.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re646pt005, re.Pattern.sub.__doc__.__class__.__name__.__eq__, ["str"], true]

table re_extra646.match_doc_class_names:
  description: "Class name of __doc__ for re.Match and its methods."
  kind: python_call_eq
  category: doc_type
  id_prefix: re646mt
  columns: [id, function, args, expected]
  rows:
    - [re646mt001, re.Match.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re646mt002, re.Match.group.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re646mt003, re.Match.groups.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re646mt004, re.Match.start.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re646mt005, re.Match.end.__doc__.__class__.__name__.__eq__, ["str"], true]

table re_extra646.class_qualnames:
  description: "Qualnames of re.Pattern and re.Match public type objects."
  kind: python_call_eq
  category: qualname
  id_prefix: re646qn
  columns: [id, function, args, expected]
  rows:
    - [re646qn001, re.Pattern.__qualname__.__eq__, ["Pattern"], true]
    - [re646qn002, re.Match.__qualname__.__eq__, ["Match"], true]
