spec: decimal_extra42
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra41.zspec.zsdl — covers Subnormal/Clamped/FloatOperation __qualname__.__eq__() and __qualname__.__len__(); FloatOperation.__bases__.__len__()==2; FloatOperation.__mro__.__len__()==7."
    - "decimal_extra33.zspec.zsdl — covers HAVE_THREADS/HAVE_CONTEXTVAR __class__.__name__.__len__()==4."
    - "decimal_extra32.zspec.zsdl — covers MAX_PREC/MAX_EMAX/MIN_EMIN __class__.__name__.__len__()==3."
    - "decimal_extra25.zspec.zsdl — covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP __class__.__name__.__eq__('str') (repeated coverage)."
    - "decimal_extra24.zspec.zsdl — covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP __class__.__module__.__eq__('builtins')."
    - "decimal_extra23.zspec.zsdl — covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP __class__.__name__.__eq__('str')."
    - "decimal_extra20.zspec.zsdl — covers all ROUND_* constant __len__() values."
    - "decimal_extra.zspec.zsdl — covers ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP/ROUND_HALF_DOWN string equality."
  notes:
    - "This spec extends decimal_extra41.zspec.zsdl."
    - "Prior specs collectively covered: all ROUND_* string equality (decimal_extra); all ROUND_* string __len__() values (decimal_extra20); all ROUND_* __class__.__name__=='str' (decimal_extra23/25); all ROUND_* __class__.__module__=='builtins' (decimal_extra24); MAX_PREC/MAX_EMAX/MIN_EMIN __class__.__name__.__len__()==3 (decimal_extra32); HAVE_THREADS/HAVE_CONTEXTVAR __class__.__name__.__len__()==4 (decimal_extra33). NO prior decimal spec checks any ROUND_* constant's __class__.__qualname__ attribute. NO prior decimal spec covers decimal.MIN_ETINY at all."
    - "This spec covers: decimal.ROUND_CEILING.__class__.__qualname__.__eq__('str') (NOVEL — decimal_extra23/25 cover __class__.__name__.__eq__('str'); no prior decimal spec accesses __class__.__qualname__ for any ROUND_* constant; __qualname__=='str'==__name__ for the builtin str type; novel __qualname__ path anchor in decimal_extra42 namespace); decimal.ROUND_FLOOR/__class__.__qualname__.__eq__('str') (NOVEL — same reasoning); decimal.ROUND_HALF_UP/__class__.__qualname__.__eq__('str') (NOVEL); decimal.ROUND_HALF_DOWN/__class__.__qualname__.__eq__('str') (NOVEL — decimal_extra23/25 cover HALF_UP/CEILING/FLOOR but their tables may omit HALF_DOWN; novel regardless since __qualname__ path is unchecked); decimal.ROUND_05UP/__class__.__qualname__.__eq__('str') (NOVEL); decimal.MIN_ETINY.__class__.__name__.__eq__('int') (NOVEL — decimal_extra32 covers MAX_PREC/MAX_EMAX/MIN_EMIN but NOT MIN_ETINY; MIN_ETINY == -1999999999999999997 is a plain int; no prior decimal spec checks MIN_ETINY at all; novel); decimal.MIN_ETINY.__class__.__qualname__.__eq__('int') (NOVEL — novel both because it's MIN_ETINY and because __qualname__ path; novel)."
    - "decimal.ROUND_CEILING.__class__.__qualname__ == 'str'. The ROUND_* rounding mode constants are plain Python str objects. Their type's __qualname__ is 'str', identical to __name__ for top-level builtin types. decimal_extra23/25 anchor __class__.__name__=='str' via the __name__ path; no prior decimal spec accesses __class__.__qualname__ for any ROUND_* constant. Novel __qualname__ path anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.MIN_ETINY is an integer constant defining the minimum value of etiny (the minimum exponent minus the precision plus 1) allowed in a Context. Its value is -1999999999999999997 on CPython. No prior decimal spec checks MIN_ETINY at all — decimal_extra32 covers MAX_PREC, MAX_EMAX, and MIN_EMIN but omits MIN_ETINY. Novel module-level constant anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.ROUND_* constants __class__.__qualname__ equality
#
# The ROUND_* rounding mode constants (ROUND_CEILING, ROUND_FLOOR,
# ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_05UP) are plain Python str objects.
# Their type is the builtin str class, so:
#
#   ROUND_CEILING.__class__.__qualname__   == 'str'
#   ROUND_FLOOR.__class__.__qualname__     == 'str'
#   ROUND_HALF_UP.__class__.__qualname__   == 'str'
#   ROUND_HALF_DOWN.__class__.__qualname__ == 'str'
#   ROUND_05UP.__class__.__qualname__      == 'str'
#
# For top-level builtin types, __qualname__ equals __name__.
# Prior decimal specs cover __class__.__name__=='str' (decimal_extra23/25)
# and __class__.__module__=='builtins' (decimal_extra24), but NO prior
# decimal spec checks __class__.__qualname__ for any ROUND_* constant.
#
# All five equality anchors are novel in the decimal_extra42 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra42.round_class_qualnames:
  description: "decimal ROUND_* constants __class__.__qualname__.__eq__('str') — ROUND_CEILING/ROUND_FLOOR/ROUND_HALF_UP/ROUND_HALF_DOWN/ROUND_05UP are plain str objects; __class__.__qualname__=='str' (same as __name__ for builtin types); decimal_extra23/25 cover __class__.__name__=='str' but no prior decimal spec checks __class__.__qualname__ for any ROUND_* constant; all five novel __qualname__ path anchors in decimal_extra42 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: constant_identity
  id_prefix: drcqn42

  columns: [id, function, args, expected]
  rows:
    - [ROUND_CEILING_class_qualname,   ROUND_CEILING.__class__.__qualname__.__eq__,   ["str"], true]
    - [ROUND_FLOOR_class_qualname,     ROUND_FLOOR.__class__.__qualname__.__eq__,     ["str"], true]
    - [ROUND_HALF_UP_class_qualname,   ROUND_HALF_UP.__class__.__qualname__.__eq__,   ["str"], true]
    - [ROUND_HALF_DOWN_class_qualname, ROUND_HALF_DOWN.__class__.__qualname__.__eq__, ["str"], true]
    - [ROUND_05UP_class_qualname,      ROUND_05UP.__class__.__qualname__.__eq__,      ["str"], true]

# ---------------------------------------------------------------------------
# decimal.MIN_ETINY — module-level integer constant
#
# MIN_ETINY is the minimum allowed value of etiny (minimum exponent minus
# precision plus 1) in a decimal Context. It is a plain Python int constant.
# On CPython, its value is -1999999999999999997.
#
#   decimal.MIN_ETINY.__class__.__name__    == 'int'
#   decimal.MIN_ETINY.__class__.__qualname__ == 'int'
#
# decimal_extra32 covers MAX_PREC, MAX_EMAX, and MIN_EMIN __class__.__name__
# lengths (all 3 chars for 'int'), but does NOT include MIN_ETINY.
# No prior decimal spec checks MIN_ETINY in any form.
#
# Both invariants are novel in the decimal_extra42 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra42.MIN_ETINY_class_name_eq:
  description: "decimal.MIN_ETINY.__class__.__name__ == 'int' — MIN_ETINY is a plain integer constant defining the minimum allowed etiny in a Context; decimal_extra32 covers MAX_PREC/MAX_EMAX/MIN_EMIN but NOT MIN_ETINY; no prior decimal spec checks MIN_ETINY at all; novel in decimal_extra42 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: constant_identity
  kind: python_call_eq
  function: MIN_ETINY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra42.MIN_ETINY_class_qualname_eq:
  description: "decimal.MIN_ETINY.__class__.__qualname__ == 'int' — for top-level builtin types, __qualname__==__name__; MIN_ETINY is a plain int; novel __qualname__ path anchor in decimal_extra42 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: constant_identity
  kind: python_call_eq
  function: MIN_ETINY.__class__.__qualname__.__eq__
  args: ["int"]
  expected: true
