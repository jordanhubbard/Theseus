invariant asyncio_extra134.Semaphore_init_qualname_len_18:
  description: "asyncio.Semaphore.__init__.__qualname__.__len__() == 18 — asyncio.Semaphore.__init__.__qualname__ is 'Semaphore.__init__' (18 chars: 'Semaphore'=9 + '.'=1 + '__init__'=8 = 18); Semaphore.__init__ takes 2 positional arguments (self + value, where value defaults to 1) — co_argcount==2; compare with asyncio.Event.__init__.__qualname__ which is 'Event.__init__' (len=14); the 9-char class name 'Semaphore' makes these qualnames longer than the 5-char 'Event' methods; Semaphore is in Lib/asyncio/locks.py; Semaphore.__module__ is 'asyncio.locks' (len=13); NEW in extra134: first standalone Semaphore.__init__ qualname length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__init__.__qualname__.__len__
  args: []
  expected: 18

invariant asyncio_extra134.Semaphore_mro_len_4:
  description: "asyncio.Semaphore.__mro__.__len__() == 4 — asyncio.Semaphore's MRO is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (length=4); contrast with asyncio.Event.__mro__ which is [Event, _LoopBoundMixin, object] (length=3) — Semaphore has an extra _ContextManagerMixin level enabling use as an async context manager; asyncio.BoundedSemaphore.__mro__.__len__() is 5 (adds BoundedSemaphore on top of Semaphore's 4-element MRO); Semaphore.__bases__[0].__name__ is '_ContextManagerMixin'; Semaphore.__module__ is 'asyncio.locks' (len=13); NEW in extra134: first standalone Semaphore MRO length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra134.Semaphore_module_eq_asyncio_locks:
  description: "asyncio.Semaphore.__module__.__eq__('asyncio.locks') returns True — asyncio.Semaphore.__module__ is 'asyncio.locks' (13 chars: 'asyncio'=7 + '.'=1 + 'locks'=5 = 13); Semaphore is defined in Lib/asyncio/locks.py alongside Lock, Event, Condition, Barrier, and BoundedSemaphore; all these classes share the same __module__ of 'asyncio.locks' (len=13); asyncio.BoundedSemaphore.__module__ is also 'asyncio.locks' (same len=13); NEW in extra134: first standalone Semaphore module equality invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra134.BoundedSemaphore_mro_len_5:
  description: "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — asyncio.BoundedSemaphore's MRO is [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object] (length=5); this is one longer than Semaphore (len=4) because BoundedSemaphore directly subclasses Semaphore; BoundedSemaphore.__bases__[0].__name__ is 'Semaphore'; BoundedSemaphore.release is overridden (qualname=='BoundedSemaphore.release', len=24) while BoundedSemaphore.acquire is inherited (qualname=='Semaphore.acquire', len=17); BoundedSemaphore.__module__ is 'asyncio.locks' (len=13); NEW in extra134: first standalone BoundedSemaphore MRO length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__mro__.__len__
  args: []
  expected: 5

invariant asyncio_extra134.BoundedSemaphore_release_qualname_len_24:
  description: "asyncio.BoundedSemaphore.release.__qualname__.__len__() == 24 — asyncio.BoundedSemaphore.release.__qualname__ is 'BoundedSemaphore.release' (24 chars: 'BoundedSemaphore'=16 + '.'=1 + 'release'=7 = 24); BoundedSemaphore overrides release to raise ValueError if the semaphore count would exceed its bound; by contrast, BoundedSemaphore.acquire is NOT overridden — its qualname is 'Semaphore.acquire' (17 chars); BoundedSemaphore.__init__ qualname is 'BoundedSemaphore.__init__' (25 chars, one more than release); BoundedSemaphore.release.__code__.co_argcount is 1 (self only); NEW in extra134: first standalone BoundedSemaphore.release qualname length invariant; wave 257; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.release.__qualname__.__len__
  args: []
  expected: 24

