spec: http_client_extra3
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
  notes:
    - "This spec extends http_client.zspec.zsdl, http_client_extra.zspec.zsdl, and http_client_extra2.zspec.zsdl."
    - "http_client.zspec.zsdl covers: status codes (OK=200, NOT_FOUND=404, etc.); HTTP_PORT==80, HTTPS_PORT==443; class __name__ table for HTTPResponse/HTTPConnection/HTTPSConnection/HTTPException/InvalidURL/BadStatusLine; responses dict."
    - "http_client_extra.zspec.zsdl covers: HTTPConnection/HTTPSConnection/HTTPException/HTTPResponse/NotConnected/InvalidURL/RemoteDisconnected __name__; HTTPConnection/HTTPSConnection __module__; HTTPException __bases__[0].__name__=='Exception'; NotConnected/InvalidURL __bases__[0].__name__=='HTTPException'; HTTPConnection/HTTPSConnection/HTTPResponse type identity."
    - "http_client_extra2.zspec.zsdl covers: __qualname__ for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected/InvalidURL; __module__ for HTTPException/HTTPResponse/NotConnected/InvalidURL; HTTP_PORT/__class__.__name__=='int'; HTTPS_PORT/__class__.__name__=='int'; HTTP_PORT.__eq__(80); HTTPS_PORT.__eq__(443)."
    - "Focus: BadStatusLine and RemoteDisconnected __qualname__ and __module__ (extra2 covers other exception qualnames but not these two); BadStatusLine __bases__[0].__name__=='HTTPException'; RemoteDisconnected __bases__[0].__name__=='BadStatusLine'; OK.value == 200 (HTTPStatus .value accessor, not yet tested); OK.__class__.__name__ == 'HTTPStatus'."
    - "http.client.BadStatusLine.__qualname__ == 'BadStatusLine' — top-level class so qualname == name."
    - "http.client.RemoteDisconnected.__bases__[0].__name__ == 'BadStatusLine' — RemoteDisconnected inherits from BadStatusLine."
    - "http.client.OK is an HTTPStatus enum member; OK.__class__.__name__ == 'HTTPStatus' and OK.value == 200."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BadStatusLine and RemoteDisconnected — __qualname__ checks
# http_client_extra2 covers __qualname__ for HTTPConnection/HTTPSConnection/
# HTTPResponse/HTTPException/NotConnected/InvalidURL, but NOT BadStatusLine
# or RemoteDisconnected.
# ---------------------------------------------------------------------------

invariant http_client_extra3.BadStatusLine.qualname:
  description: "http.client.BadStatusLine.__qualname__ == 'BadStatusLine'"
  category: qualnames
  kind: python_call_eq
  function: BadStatusLine.__qualname__.__eq__
  args: ["BadStatusLine"]
  expected: true

invariant http_client_extra3.RemoteDisconnected.qualname:
  description: "http.client.RemoteDisconnected.__qualname__ == 'RemoteDisconnected'"
  category: qualnames
  kind: python_call_eq
  function: RemoteDisconnected.__qualname__.__eq__
  args: ["RemoteDisconnected"]
  expected: true

# ---------------------------------------------------------------------------
# BadStatusLine and RemoteDisconnected — __module__ checks
# http_client_extra2 covers __module__ for HTTPException/HTTPResponse/
# NotConnected/InvalidURL. BadStatusLine and RemoteDisconnected are new here.
# ---------------------------------------------------------------------------

invariant http_client_extra3.BadStatusLine.module:
  description: "http.client.BadStatusLine.__module__ == 'http.client'"
  category: modules
  kind: python_call_eq
  function: BadStatusLine.__module__.__eq__
  args: ["http.client"]
  expected: true

invariant http_client_extra3.RemoteDisconnected.module:
  description: "http.client.RemoteDisconnected.__module__ == 'http.client'"
  category: modules
  kind: python_call_eq
  function: RemoteDisconnected.__module__.__eq__
  args: ["http.client"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy — BadStatusLine and RemoteDisconnected bases
# http_client_extra covers: HTTPException base == 'Exception';
#   NotConnected/InvalidURL base == 'HTTPException'.
# BadStatusLine.__bases__[0].__name__ and RemoteDisconnected.__bases__[0].__name__
# are not covered by any prior spec.
# ---------------------------------------------------------------------------

invariant http_client_extra3.BadStatusLine.base:
  description: "http.client.BadStatusLine.__bases__[0].__name__ == 'HTTPException'"
  category: hierarchy
  kind: python_call_eq
  function: BadStatusLine.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "HTTPException"

invariant http_client_extra3.RemoteDisconnected.base:
  description: "http.client.RemoteDisconnected.__bases__[0].__name__ == 'BadStatusLine'"
  category: hierarchy
  kind: python_call_eq
  function: RemoteDisconnected.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BadStatusLine"

# ---------------------------------------------------------------------------
# HTTPStatus enum instance type — OK.__class__.__name__ == 'HTTPStatus'
# http_client.zspec.zsdl checks OK == 200 as integer equality.
# No prior spec checks the enum instance's __class__.__name__.
# ---------------------------------------------------------------------------

invariant http_client_extra3.OK.class_name:
  description: "http.client.OK.__class__.__name__ == 'HTTPStatus' — OK is an HTTPStatus enum member"
  category: status_types
  kind: python_call_eq
  function: OK.__class__.__name__.__eq__
  args: ["HTTPStatus"]
  expected: true

invariant http_client_extra3.NOT_FOUND.class_name:
  description: "http.client.NOT_FOUND.__class__.__name__ == 'HTTPStatus'"
  category: status_types
  kind: python_call_eq
  function: NOT_FOUND.__class__.__name__.__eq__
  args: ["HTTPStatus"]
  expected: true

# ---------------------------------------------------------------------------
# HTTPStatus enum .value accessor — OK.value, NOT_FOUND.value
# http_client.zspec.zsdl checks OK.__eq__(200) as integer equality.
# The .value accessor (IntEnum convention) is a distinct axis not yet tested.
# ---------------------------------------------------------------------------

invariant http_client_extra3.OK.value:
  description: "http.client.OK.value == 200 — HTTPStatus enum .value accessor"
  category: status_values
  kind: python_call_eq
  function: OK.value.__eq__
  args: [200]
  expected: true

invariant http_client_extra3.NOT_FOUND.value:
  description: "http.client.NOT_FOUND.value == 404 — HTTPStatus enum .value accessor"
  category: status_values
  kind: python_call_eq
  function: NOT_FOUND.value.__eq__
  args: [404]
  expected: true

invariant http_client_extra3.INTERNAL_SERVER_ERROR.value:
  description: "http.client.INTERNAL_SERVER_ERROR.value == 500 — HTTPStatus enum .value accessor"
  category: status_values
  kind: python_call_eq
  function: INTERNAL_SERVER_ERROR.value.__eq__
  args: [500]
  expected: true
