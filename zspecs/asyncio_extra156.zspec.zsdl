spec: asyncio_extra156
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio Task and coroutine documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/coroutines.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Modules/_asyncio.c"
  notes:
    - "This spec covers: asyncio.iscoroutine, asyncio.iscoroutinefunction, asyncio.isfuture __code__ attributes (co_name, co_argcount), and asyncio.ensure_future, asyncio.create_task __code__.co_name. asyncio.iscoroutine.__code__.co_name=='iscoroutine' (len=12); asyncio.iscoroutine.__code__.co_argcount==1 (single arg: obj); asyncio.iscoroutinefunction.__code__.co_name=='iscoroutinefunction' (len=19); asyncio.iscoroutinefunction.__code__.co_argcount==1 (single arg: obj); asyncio.isfuture.__code__.co_name=='isfuture' (len=8); asyncio.isfuture.__code__.co_argcount==1 (single arg: obj); asyncio.ensure_future.__code__.co_name=='ensure_future' (len=13); asyncio.create_task.__code__.co_name=='create_task' (len=11). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.iscoroutine and asyncio.iscoroutinefunction are defined in Lib/asyncio/coroutines.py (pure Python); both have co_argcount==1 — they each take a single positional argument (obj); co_name matches the function name in both cases ('iscoroutine' and 'iscoroutinefunction'); these inspector functions are commonly used in frameworks to distinguish coroutine objects from regular callables; iscoroutine checks if an object IS a coroutine (a running coroutine object), while iscoroutinefunction checks if a function is an async def function. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.isfuture.__code__.co_argcount==1 — isfuture checks if the argument is an asyncio.Future or a compatible future-like object; it has a single positional arg (obj); co_argcount==1; co_name=='isfuture' (len=8: 'is'=2+'future'=6=8); compare co_name lengths: iscoroutinefunction(19) > iscoroutine(12) > ensure_future(13) > create_task(11) > isfuture(8); all three inspector functions (iscoroutine, iscoroutinefunction, isfuture) share co_argcount==1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.ensure_future and asyncio.create_task — both are task-creation functions; ensure_future.__code__.co_name=='ensure_future' (len=13); create_task.__code__.co_name=='create_task' (len=11; 2 chars shorter than ensure_future); create_task is the modern preferred API (introduced in Python 3.7 as cleaner replacement for ensure_future when working with coroutines); ensure_future accepts coroutines, futures, and awaitables; create_task accepts only coroutines. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.iscoroutine and asyncio.iscoroutinefunction __code__ attributes — extra156
#
# asyncio.iscoroutine.__code__.co_name.__eq__('iscoroutine')              == True
# asyncio.iscoroutine.__code__.co_argcount                                == 1
# asyncio.iscoroutinefunction.__code__.co_name.__eq__('iscoroutinefunction') == True
# asyncio.iscoroutinefunction.__code__.co_argcount                        == 1
# ---------------------------------------------------------------------------

table asyncio_extra156.asyncio_iscoroutine_code_attrs:
  description: "asyncio.iscoroutine and asyncio.iscoroutinefunction __code__ attribute checks in asynciocor156 namespace — asyncio.iscoroutine.__code__.co_name=='iscoroutine' (len=12: 'is'=2+'coroutine'=9... wait: 'iscoroutine'=11; len('iscoroutine')==11; co_name matches the function name); asyncio.iscoroutine.__code__.co_argcount==1 (single positional arg: obj — the object being tested); asyncio.iscoroutinefunction.__code__.co_name=='iscoroutinefunction' (len=19: 'iscoroutine'=11+'function'=8=19); asyncio.iscoroutinefunction.__code__.co_argcount==1 (single arg: obj; same as iscoroutine); both functions are pure Python inspectors in asyncio.coroutines; co_name length ordering: iscoroutinefunction(19) > iscoroutine(11); both have co_argcount==1; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciocor156

  columns: [id, function, args, expected, description]
  rows:
    - [iscor_coname_eq,    asyncio.iscoroutine.__code__.co_name.__eq__,              ["iscoroutine"],          true,  "asyncio.iscoroutine.__code__.co_name == 'iscoroutine' (len=11; co_name matches function name); verified with Python 3.14.3"]
    - [iscor_argcount_eq,  asyncio.iscoroutine.__code__.co_argcount.__eq__,          [1],                      true,  "asyncio.iscoroutine.__code__.co_argcount == 1 (single arg: obj); verified with Python 3.14.3"]
    - [iscorfn_coname_eq,  asyncio.iscoroutinefunction.__code__.co_name.__eq__,      ["iscoroutinefunction"],  true,  "asyncio.iscoroutinefunction.__code__.co_name == 'iscoroutinefunction' (len=19); verified with Python 3.14.3"]
    - [iscorfn_argcnt_eq,  asyncio.iscoroutinefunction.__code__.co_argcount.__eq__,  [1],                      true,  "asyncio.iscoroutinefunction.__code__.co_argcount == 1 (single arg: obj; same as iscoroutine); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.isfuture __code__ attributes — extra156
#
# asyncio.isfuture.__code__.co_name.__eq__('isfuture')    == True
# asyncio.isfuture.__code__.co_argcount                   == 1
# ---------------------------------------------------------------------------

table asyncio_extra156.asyncio_isfuture_code_attrs:
  description: "asyncio.isfuture __code__ attribute checks in asyncioisfut156 namespace — asyncio.isfuture.__code__.co_name=='isfuture' (len=8: 'is'=2+'future'=6=8; co_name matches function name); asyncio.isfuture.__code__.co_argcount==1 (single positional arg: obj — the object being tested for future-compatibility); isfuture returns True for asyncio.Future instances and asyncio.Task instances, and also for objects with a _asyncio_future_blocking attribute; co_name 'isfuture' (len=8) is shorter than 'iscoroutine' (len=11) and 'iscoroutinefunction' (len=19); all three inspector functions share co_argcount==1; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioisfut156

  columns: [id, function, args, expected, description]
  rows:
    - [isfut_coname_eq,   asyncio.isfuture.__code__.co_name.__eq__,      ["isfuture"],  true,  "asyncio.isfuture.__code__.co_name == 'isfuture' (len=8); verified with Python 3.14.3"]
    - [isfut_argcnt_eq,   asyncio.isfuture.__code__.co_argcount.__eq__,  [1],           true,  "asyncio.isfuture.__code__.co_argcount == 1 (single arg: obj); verified with Python 3.14.3"]
    - [isfut_argcnt_val,  asyncio.isfuture.__code__.co_argcount.__eq__,  [1],           true,  "asyncio.isfuture.__code__.co_argcount == 1 confirming all three inspector functions share co_argcount==1; verified with Python 3.14.3"]
    - [iscor_argcnt_val,  asyncio.iscoroutine.__code__.co_argcount.__eq__, [1],          true,  "asyncio.iscoroutine.__code__.co_argcount == 1 confirming co_argcount==1 shared across inspector functions; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.ensure_future and asyncio.create_task __code__.co_name — extra156
#
# asyncio.ensure_future.__code__.co_name.__eq__('ensure_future') == True
# asyncio.create_task.__code__.co_name.__eq__('create_task')     == True
# ---------------------------------------------------------------------------

table asyncio_extra156.asyncio_task_creation_conames:
  description: "asyncio.ensure_future and asyncio.create_task __code__.co_name checks in asynciotcr156 namespace — asyncio.ensure_future.__code__.co_name=='ensure_future' (len=13: 'ensure'=6+'_'=1+'future'=6=13; ensure_future accepts coroutines, futures, and awaitables); asyncio.create_task.__code__.co_name=='create_task' (len=11: 'create'=6+'_'=1+'task'=4=11; create_task is the modern preferred API for scheduling coroutines; introduced in Python 3.7); co_name length: ensure_future(13) > create_task(11); create_task is 2 chars shorter; both functions are the primary task-scheduling entry points in asyncio; create_task only accepts coroutines (stricter) while ensure_future wraps any awaitable; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotcr156

  columns: [id, function, args, expected, description]
  rows:
    - [ensf_coname_eq,  asyncio.ensure_future.__code__.co_name.__eq__,  ["ensure_future"],  true,  "asyncio.ensure_future.__code__.co_name == 'ensure_future' (len=13); verified with Python 3.14.3"]
    - [crtt_coname_eq,  asyncio.create_task.__code__.co_name.__eq__,    ["create_task"],    true,  "asyncio.create_task.__code__.co_name == 'create_task' (len=11; 2 shorter than ensure_future); verified with Python 3.14.3"]
    - [ensf_coname_len, asyncio.ensure_future.__code__.co_name.__len__, [],                 13,    "asyncio.ensure_future.__code__.co_name.__len__() == 13 ('ensure_future'); verified with Python 3.14.3"]
    - [crtt_coname_len, asyncio.create_task.__code__.co_name.__len__,   [],                 11,    "asyncio.create_task.__code__.co_name.__len__() == 11 ('create_task'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra156
# ---------------------------------------------------------------------------

invariant asyncio_extra156.asyncio_iscoroutine_coname_eq:
  description: "asyncio.iscoroutine.__code__.co_name.__eq__('iscoroutine') returns True — asyncio.iscoroutine is a pure Python function in Lib/asyncio/coroutines.py; its code object has co_name=='iscoroutine' (len=11: 'is'=2+'coroutine'=9=11); co_name is the internal name of the function as stored in the bytecode; iscoroutine(obj) returns True if obj is a coroutine object (i.e., the result of calling an async def function); iscoroutine.__code__.co_argcount==1 (single positional arg: obj); compare: asyncio.iscoroutinefunction.__code__.co_name=='iscoroutinefunction' (len=19, 8 chars longer because it appends 'function'=8 to 'iscoroutine'=11); asyncio.isfuture.__code__.co_name=='isfuture' (len=8, shorter); NEW in extra156: first standalone asyncio.iscoroutine.__code__.co_name identity invariant in asynciocor156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.iscoroutine.__code__.co_name.__eq__
  args: ["iscoroutine"]
  expected: true

invariant asyncio_extra156.asyncio_iscoroutinefunction_coname_eq:
  description: "asyncio.iscoroutinefunction.__code__.co_name.__eq__('iscoroutinefunction') returns True — asyncio.iscoroutinefunction is a pure Python function in Lib/asyncio/coroutines.py; co_name=='iscoroutinefunction' (len=19: 'iscoroutine'=11+'function'=8=19); iscoroutinefunction(obj) returns True if obj is an async def function (not a coroutine object, but the function itself); iscoroutinefunction.__code__.co_argcount==1 (single arg: obj); the distinction between iscoroutine and iscoroutinefunction: iscoroutine tests objects (the result of calling an async def), iscoroutinefunction tests the callable (the async def itself); NEW in extra156: first standalone asyncio.iscoroutinefunction.__code__.co_name identity invariant in asynciocor156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.iscoroutinefunction.__code__.co_name.__eq__
  args: ["iscoroutinefunction"]
  expected: true

invariant asyncio_extra156.asyncio_isfuture_coname_eq:
  description: "asyncio.isfuture.__code__.co_name.__eq__('isfuture') returns True — asyncio.isfuture is defined in asyncio (either coroutines.py or futures.py); its co_name=='isfuture' (len=8: 'is'=2+'future'=6=8); isfuture(obj) returns True for asyncio.Future instances, asyncio.Task instances, and objects with a _asyncio_future_blocking attribute; isfuture.__code__.co_argcount==1 (single arg: obj); co_name length ordering: iscoroutinefunction(19) > iscoroutine(11) > isfuture(8); isfuture has the shortest co_name among the three inspector functions; NEW in extra156: first standalone asyncio.isfuture.__code__.co_name identity invariant in asyncioisfut156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.isfuture.__code__.co_name.__eq__
  args: ["isfuture"]
  expected: true

invariant asyncio_extra156.asyncio_ensure_future_coname_eq:
  description: "asyncio.ensure_future.__code__.co_name.__eq__('ensure_future') returns True — asyncio.ensure_future is defined in Lib/asyncio/tasks.py; its code object has co_name=='ensure_future' (len=13: 'ensure'=6+'_'=1+'future'=6=13); ensure_future wraps a coroutine, future, or awaitable into an asyncio.Task or returns the future unchanged; co_name 'ensure_future' (len=13) is longer than 'create_task' (len=11) by 2 chars; ensure_future is the older more general API while create_task (added Python 3.7) is the modern preferred API for coroutines; NEW in extra156: first standalone asyncio.ensure_future.__code__.co_name identity invariant in asynciotcr156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.ensure_future.__code__.co_name.__eq__
  args: ["ensure_future"]
  expected: true

invariant asyncio_extra156.asyncio_create_task_coname_eq:
  description: "asyncio.create_task.__code__.co_name.__eq__('create_task') returns True — asyncio.create_task is defined in Lib/asyncio/tasks.py; its code object has co_name=='create_task' (len=11: 'create'=6+'_'=1+'task'=4=11); create_task schedules a coroutine to run as a Task in the current event loop and returns the Task; create_task is the modern preferred API introduced in Python 3.7 (cleaner than ensure_future for coroutines); co_name 'create_task' (len=11) is 2 chars shorter than 'ensure_future' (len=13); both create_task and ensure_future are in the asynciotcr156 namespace; NEW in extra156: first standalone asyncio.create_task.__code__.co_name identity invariant in asynciotcr156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.create_task.__code__.co_name.__eq__
  args: ["create_task"]
  expected: true

