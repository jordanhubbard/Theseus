spec: threading_extra90
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra89

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra89.zspec.zsdl."
    - "This spec covers: threading class method __qualname__ string equality for Thread, Semaphore, Condition, Event, and Barrier (Wave 250)."
    - "threading.Thread.start.__qualname__ == 'Thread.start' — pure-Python method in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__ == 'Thread.run' — pure-Python method. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join' — pure-Python method. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' — pure-Python method. Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' — pure-Python method. Verified with Python 3.14.3."
    - "threading.Semaphore.release.__qualname__ == 'Semaphore.release' — pure-Python method. Verified with Python 3.14.3."
    - "threading.Condition.wait.__qualname__ == 'Condition.wait' — pure-Python method in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Condition.notify.__qualname__ == 'Condition.notify' — pure-Python method. Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all' — pure-Python method. Verified with Python 3.14.3."
    - "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for' — pure-Python method. Verified with Python 3.14.3."
    - "threading.Event.wait.__qualname__ == 'Event.wait' — pure-Python method. Verified with Python 3.14.3."
    - "threading.Event.set.__qualname__ == 'Event.set' — pure-Python method. Verified with Python 3.14.3."
    - "threading.Event.clear.__qualname__ == 'Event.clear' — pure-Python method. Verified with Python 3.14.3."
    - "threading.Barrier.wait.__qualname__ == 'Barrier.wait' — pure-Python method. Verified with Python 3.14.3."
    - "Note: threading.Condition does not have acquire/release as regular methods (it uses __enter__/__exit__); Condition.wait and Condition.notify are the primary API. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread method __qualname__ strings
#
# Wave 250 theme: threading class method __qualname__ string equality — Thread methods.
#
# threading.Thread.start.__qualname__.__eq__('Thread.start')     == True
# threading.Thread.run.__qualname__.__eq__('Thread.run')         == True
# threading.Thread.join.__qualname__.__eq__('Thread.join')       == True
# threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True
#
# Prior spec extra89 checked Thread.__name__ and Thread.__qualname__. This spec (extra90) checks method __qualname__. New to extra90.
# ---------------------------------------------------------------------------

table threading_extra90.thread_method_qualnames:
  description: "Thread.start/run/join/is_alive method __qualname__ strings; pure-Python methods in Lib/threading.py; wave 250; new to extra90"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmethodqual90

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_start_qualname_eq_Thread_start,
       Thread.start.__qualname__.__eq__,
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — Thread.start is a pure-Python method defined in Lib/threading.py that starts the thread's activity; as a method of Thread the __qualname__ is 'Thread.start'; str.__eq__('Thread.start') returns True; prior spec extra89 checked Thread.__name__ and Thread.__qualname__; this spec (extra90) checks method __qualname__; new to extra90"]
    - [Thread_run_qualname_eq_Thread_run,
       Thread.run.__qualname__.__eq__,
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — Thread.run is the method representing the thread's activity, defined in Lib/threading.py; __qualname__ is 'Thread.run'; str.__eq__('Thread.run') returns True; new to extra90"]
    - [Thread_join_qualname_eq_Thread_join,
       Thread.join.__qualname__.__eq__,
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — Thread.join is a pure-Python method that blocks until the thread terminates, defined in Lib/threading.py; __qualname__ is 'Thread.join'; str.__eq__('Thread.join') returns True; new to extra90"]
    - [Thread_is_alive_qualname_eq_Thread_is_alive,
       Thread.is_alive.__qualname__.__eq__,
       ["Thread.is_alive"],
       true,
       "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True — Thread.is_alive is a pure-Python method that returns True if the thread is alive, defined in Lib/threading.py; __qualname__ is 'Thread.is_alive'; str.__eq__('Thread.is_alive') returns True; new to extra90"]

# ---------------------------------------------------------------------------
# Semaphore method __qualname__ strings
#
# Wave 250 theme: threading class method __qualname__ string equality — Semaphore methods.
#
# threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') == True
# threading.Semaphore.release.__qualname__.__eq__('Semaphore.release') == True
# threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.release') == False (cross-check)
# threading.Semaphore.__init__.__qualname__.__eq__('Semaphore.__init__') == True
#
# No prior threading spec checks Semaphore method __qualname__ via threadingmethodqual90. New to extra90.
# ---------------------------------------------------------------------------

table threading_extra90.semaphore_method_qualnames:
  description: "Semaphore.acquire/release/__init__ method __qualname__ strings + cross-check; pure-Python methods in Lib/threading.py; wave 250; new to extra90"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmethodqual90

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_acquire_qualname_eq_Semaphore_acquire,
       Semaphore.acquire.__qualname__.__eq__,
       ["Semaphore.acquire"],
       true,
       "threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') == True — Semaphore.acquire is a pure-Python method in Lib/threading.py that acquires the semaphore; __qualname__ is 'Semaphore.acquire'; str.__eq__('Semaphore.acquire') returns True; no prior threading spec checks Semaphore method __qualname__ via threadingmethodqual90; new to extra90"]
    - [Semaphore_release_qualname_eq_Semaphore_release,
       Semaphore.release.__qualname__.__eq__,
       ["Semaphore.release"],
       true,
       "threading.Semaphore.release.__qualname__.__eq__('Semaphore.release') == True — Semaphore.release is a pure-Python method in Lib/threading.py that releases the semaphore; __qualname__ is 'Semaphore.release'; str.__eq__('Semaphore.release') returns True; new to extra90"]
    - [Semaphore_acquire_qualname_ne_Semaphore_release,
       Semaphore.acquire.__qualname__.__eq__,
       ["Semaphore.release"],
       false,
       "threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.release') == False — Semaphore.acquire.__qualname__ is 'Semaphore.acquire', not 'Semaphore.release'; each method has a unique __qualname__; str.__eq__('Semaphore.release') returns False; new to extra90"]
    - [Semaphore_init_qualname_eq_Semaphore_init,
       Semaphore.__init__.__qualname__.__eq__,
       ["Semaphore.__init__"],
       true,
       "threading.Semaphore.__init__.__qualname__.__eq__('Semaphore.__init__') == True — Semaphore.__init__ is a pure-Python method in Lib/threading.py that initializes the semaphore counter; __qualname__ is 'Semaphore.__init__'; str.__eq__('Semaphore.__init__') returns True; new to extra90"]

# ---------------------------------------------------------------------------
# Condition method __qualname__ strings
#
# Wave 250 theme: threading class method __qualname__ string equality — Condition methods.
#
# threading.Condition.wait.__qualname__.__eq__('Condition.wait')         == True
# threading.Condition.notify.__qualname__.__eq__('Condition.notify')     == True
# threading.Condition.notify_all.__qualname__.__eq__('Condition.notify_all') == True
# threading.Condition.wait_for.__qualname__.__eq__('Condition.wait_for') == True
#
# No prior threading spec checks Condition method __qualname__ via threadingmethodqual90. New to extra90.
# ---------------------------------------------------------------------------

table threading_extra90.condition_method_qualnames:
  description: "Condition.wait/notify/notify_all/wait_for method __qualname__ strings; pure-Python methods in Lib/threading.py; wave 250; new to extra90"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmethodqual90

  columns: [id, function, args, expected, description]
  rows:
    - [Condition_wait_qualname_eq_Condition_wait,
       Condition.wait.__qualname__.__eq__,
       ["Condition.wait"],
       true,
       "threading.Condition.wait.__qualname__.__eq__('Condition.wait') == True — Condition.wait is a pure-Python method in Lib/threading.py that blocks until notified or timed out; __qualname__ is 'Condition.wait'; str.__eq__('Condition.wait') returns True; no prior threading spec checks Condition method __qualname__ via threadingmethodqual90; new to extra90"]
    - [Condition_notify_qualname_eq_Condition_notify,
       Condition.notify.__qualname__.__eq__,
       ["Condition.notify"],
       true,
       "threading.Condition.notify.__qualname__.__eq__('Condition.notify') == True — Condition.notify is a pure-Python method in Lib/threading.py that wakes up one or more threads waiting on the condition; __qualname__ is 'Condition.notify'; str.__eq__('Condition.notify') returns True; new to extra90"]
    - [Condition_notify_all_qualname_eq_Condition_notify_all,
       Condition.notify_all.__qualname__.__eq__,
       ["Condition.notify_all"],
       true,
       "threading.Condition.notify_all.__qualname__.__eq__('Condition.notify_all') == True — Condition.notify_all is a pure-Python method in Lib/threading.py that wakes up all threads waiting on the condition; __qualname__ is 'Condition.notify_all'; str.__eq__('Condition.notify_all') returns True; new to extra90"]
    - [Condition_wait_for_qualname_eq_Condition_wait_for,
       Condition.wait_for.__qualname__.__eq__,
       ["Condition.wait_for"],
       true,
       "threading.Condition.wait_for.__qualname__.__eq__('Condition.wait_for') == True — Condition.wait_for is a pure-Python method in Lib/threading.py that blocks until a predicate is true; __qualname__ is 'Condition.wait_for'; str.__eq__('Condition.wait_for') returns True; new to extra90"]

# ---------------------------------------------------------------------------
# Event and Barrier method __qualname__ strings
#
# Wave 250 theme: threading class method __qualname__ string equality — Event and Barrier methods.
#
# threading.Event.wait.__qualname__.__eq__('Event.wait')     == True
# threading.Event.set.__qualname__.__eq__('Event.set')       == True
# threading.Event.clear.__qualname__.__eq__('Event.clear')   == True
# threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True
#
# No prior threading spec checks Event/Barrier method __qualname__ via threadingmethodqual90. New to extra90.
# ---------------------------------------------------------------------------

table threading_extra90.event_barrier_method_qualnames:
  description: "Event.wait/set/clear and Barrier.wait method __qualname__ strings; pure-Python methods in Lib/threading.py; wave 250; new to extra90"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmethodqual90

  columns: [id, function, args, expected, description]
  rows:
    - [Event_wait_qualname_eq_Event_wait,
       Event.wait.__qualname__.__eq__,
       ["Event.wait"],
       true,
       "threading.Event.wait.__qualname__.__eq__('Event.wait') == True — Event.wait is a pure-Python method in Lib/threading.py that blocks until the internal flag is true or the optional timeout occurs; __qualname__ is 'Event.wait'; str.__eq__('Event.wait') returns True; no prior threading spec checks Event method __qualname__ via threadingmethodqual90; new to extra90"]
    - [Event_set_qualname_eq_Event_set,
       Event.set.__qualname__.__eq__,
       ["Event.set"],
       true,
       "threading.Event.set.__qualname__.__eq__('Event.set') == True — Event.set is a pure-Python method in Lib/threading.py that sets the internal flag to true, waking all waiting threads; __qualname__ is 'Event.set'; str.__eq__('Event.set') returns True; new to extra90"]
    - [Event_clear_qualname_eq_Event_clear,
       Event.clear.__qualname__.__eq__,
       ["Event.clear"],
       true,
       "threading.Event.clear.__qualname__.__eq__('Event.clear') == True — Event.clear is a pure-Python method in Lib/threading.py that resets the internal flag to false; __qualname__ is 'Event.clear'; str.__eq__('Event.clear') returns True; new to extra90"]
    - [Barrier_wait_qualname_eq_Barrier_wait,
       Barrier.wait.__qualname__.__eq__,
       ["Barrier.wait"],
       true,
       "threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True — Barrier.wait is a pure-Python method in Lib/threading.py that blocks until the required number of threads have called wait(); __qualname__ is 'Barrier.wait'; str.__eq__('Barrier.wait') returns True; no prior threading spec checks Barrier method __qualname__ via threadingmethodqual90; new to extra90"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra90
# ---------------------------------------------------------------------------

invariant threading_extra90.Thread_start_qualname_eq_Thread_start:
  description: "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — Thread.start method __qualname__ is 'Thread.start'; wave 250; new to extra90"
  kind: python_call_eq
  function: Thread.start.__qualname__.__eq__
  args: ["Thread.start"]
  expected: true

invariant threading_extra90.Semaphore_acquire_qualname_eq_Semaphore_acquire:
  description: "threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') == True — Semaphore.acquire method __qualname__ is 'Semaphore.acquire'; wave 250; new to extra90"
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true

invariant threading_extra90.Condition_wait_qualname_eq_Condition_wait:
  description: "threading.Condition.wait.__qualname__.__eq__('Condition.wait') == True — Condition.wait method __qualname__ is 'Condition.wait'; wave 250; new to extra90"
  kind: python_call_eq
  function: Condition.wait.__qualname__.__eq__
  args: ["Condition.wait"]
  expected: true

invariant threading_extra90.Event_set_qualname_eq_Event_set:
  description: "threading.Event.set.__qualname__.__eq__('Event.set') == True — Event.set method __qualname__ is 'Event.set'; wave 250; new to extra90"
  kind: python_call_eq
  function: Event.set.__qualname__.__eq__
  args: ["Event.set"]
  expected: true

invariant threading_extra90.Barrier_wait_qualname_eq_Barrier_wait:
  description: "threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True — Barrier.wait method __qualname__ is 'Barrier.wait'; wave 250; new to extra90"
  kind: python_call_eq
  function: Barrier.wait.__qualname__.__eq__
  args: ["Barrier.wait"]
  expected: true
