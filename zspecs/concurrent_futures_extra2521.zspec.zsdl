spec: concurrent_futures_extra2521
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Theme: __bool__, __index__, __int__ dict-presence checks — truthiness, integer coercion, and indexing protocol."
    - "concurrent.futures.Future, ThreadPoolExecutor, and ProcessPoolExecutor define none of these dunder methods."
    - "__dict__.__contains__ returns False for __bool__, __index__, __int__ on all three classes."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future — bool/index/int dict-presence
# ---------------------------------------------------------------------------

table concurrent_futures_extra2521.future_bool_int_index:
  description: "concurrent.futures.Future.__dict__ contains no __bool__, __index__, or __int__; all __dict__.__contains__ calls return False; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_presence
  id_prefix: cf2521

  columns: [id, function, args, expected]
  rows:
    - ["cf2521001", concurrent.futures.Future.__dict__.__contains__, ["__bool__"], false]
    - ["cf2521002", concurrent.futures.Future.__dict__.__contains__, ["__index__"], false]
    - ["cf2521003", concurrent.futures.Future.__dict__.__contains__, ["__int__"], false]

