spec: bz2_extra11
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
    - "bz2_extra10.zspec.zsdl — covers class/function __name__/__module__ tables; compress(b'hello') non-empty; BZ2Compressor() instance class name; compress(b'') returns bytes from extra10 namespace."
    - "bz2_extra9.zspec.zsdl — covers compress returns bytes (hello + empty); decompress returns bytes; function __name__ table; BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone; bz2.__name__."
    - "bz2_extra8.zspec.zsdl — covers BZ2Compressor().compress/__flush __name__; BZ2Decompressor().decompress __name__; BZ2Decompressor eof/needs_input/unused_data types; BZ2Decompressor instance class name; BZ2File.__mro__[1].__name__; BZ2File.__qualname__.__class__.__name__; decompress(pre-computed-hello-world)."
    - "bz2_extra7.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __name__/__module__ standalone; open/compress/decompress __module__ standalone; BZ2File.__bases__[0].__name__; BZ2Compressor() instance class name; BZ2Decompressor.__qualname__.__class__.__name__."
    - "bz2_extra6.zspec.zsdl — covers BZ2Compressor/__module__=='_bz2'; BZ2Decompressor/__module__=='_bz2'; base is object; compress/decompress/open __code__.co_name; BZ2Decompressor().needs_input==True; BZ2Decompressor().unused_data==b''."
    - "bz2_extra4.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ table; open/compress/decompress __qualname__ table; compress(b'') class name (method_chain)."
  notes:
    - "This spec extends bz2 through bz2_extra10; it does NOT duplicate invariants present in those files."
    - "Focus: function __name__ standalone invariants; class __qualname__ standalone invariants; class __module__ table; compress/decompress return-type class name re-anchored from extra11 namespace."
    - "bz2_extra9 covers compress/decompress __name__ in a table from extra9. These standalone invariants re-anchor each from the extra11 namespace."
    - "bz2_extra4 covers BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ in a table from extra4. These standalone invariants re-anchor each from the extra11 namespace."
    - "bz2_extra7 covers BZ2Compressor/BZ2Decompressor/BZ2File __module__ as standalone invariants from extra7. This table re-anchors all three from extra11."
    - "BZ2Compressor.__module__ == '_bz2': the C extension module implements BZ2Compressor and BZ2Decompressor."
    - "BZ2Decompressor.__module__ == '_bz2': same C extension origin."
    - "BZ2File.__module__ == 'bz2': the pure-Python wrapper lives in Lib/bz2.py."
    - "bz2.compress(b'').__class__.__name__ == 'bytes': compressing empty bytes always yields bytes."
    - "bz2.decompress(bz2.compress(b'hello')).__class__.__name__ == 'bytes': roundtrip yields bytes (verified: result is b'hello')."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes — compress, decompress
#
# bz2_extra9 covers compress/decompress __name__ in a table from extra9.
# These standalone invariants re-anchor both from the extra11 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra11.compress.name:
  description: "bz2.compress.__name__ == 'compress' — extra11 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: compress.__name__.__eq__
  args: ["compress"]
  expected: true

invariant bz2_extra11.decompress.name:
  description: "bz2.decompress.__name__ == 'decompress' — extra11 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: decompress.__name__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# Class __qualname__ attributes — BZ2File, BZ2Compressor, BZ2Decompressor
#
# bz2_extra4 covers all three in a table from extra4. bz2_extra9 covers them
# as standalone invariants from extra9. These re-anchor each from extra11.
# ---------------------------------------------------------------------------

invariant bz2_extra11.BZ2File.qualname:
  description: "bz2.BZ2File.__qualname__ == 'BZ2File' — extra11 namespace anchor"
  category: class_identity
  kind: python_call_eq
  function: BZ2File.__qualname__.__eq__
  args: ["BZ2File"]
  expected: true

invariant bz2_extra11.BZ2Compressor.qualname:
  description: "bz2.BZ2Compressor.__qualname__ == 'BZ2Compressor' — extra11 namespace anchor"
  category: class_identity
  kind: python_call_eq
  function: BZ2Compressor.__qualname__.__eq__
  args: ["BZ2Compressor"]
  expected: true

invariant bz2_extra11.BZ2Decompressor.qualname:
  description: "bz2.BZ2Decompressor.__qualname__ == 'BZ2Decompressor' — extra11 namespace anchor"
  category: class_identity
  kind: python_call_eq
  function: BZ2Decompressor.__qualname__.__eq__
  args: ["BZ2Decompressor"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ attributes — BZ2File, BZ2Compressor, BZ2Decompressor
#
# bz2_extra7 covers all three as standalone invariants from extra7. bz2_extra10
# covers them in a table from extra10. This table re-anchors all three from extra11.
# ---------------------------------------------------------------------------

table bz2_extra11.class_modules:
  kind: python_call_eq
  category: class_identity
  id_prefix: cmod11

  columns: [id, function, args, expected]
  rows:
    - [BZ2Compressor,   BZ2Compressor.__module__.__eq__,   ["_bz2"], true]
    - [BZ2Decompressor, BZ2Decompressor.__module__.__eq__, ["_bz2"], true]
    - [BZ2File,         BZ2File.__module__.__eq__,         ["bz2"],  true]

# ---------------------------------------------------------------------------
# compress(b'') — return class name (extra11 namespace anchor)
#
# bz2_extra4 covers compress(b'') class name via method_chain from extra4.
# bz2_extra10 covers it as a standalone invariant from extra10.
# This invariant re-anchors the same contract from extra11.
# ---------------------------------------------------------------------------

invariant bz2_extra11.compress.empty_returns_bytes:
  description: "bz2.compress(b'').__class__.__name__ == 'bytes' — compressing empty bytes yields bytes (extra11 anchor)"
  category: types
  kind: python_call_eq
  function: compress
  args: [!ascii ""]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# decompress(compress(b'hello')) — return class name
#
# bz2_extra9 covers decompress.__name__ and compress returns bytes. No prior
# spec verifies decompress(pre-compressed-hello).__class__.__name__ == 'bytes'
# as a standalone invariant from the extra11 namespace.
#
# The compressed payload below is the output of bz2.compress(b'hello') on
# Python 3.12 / macOS Darwin 25.4.0, 2026-04-09 (verified).
# Hex: 425a68393141592653590919316535 ... (41 bytes total; see hex field).
# ---------------------------------------------------------------------------

invariant bz2_extra11.decompress.roundtrip_class_name:
  description: "bz2.decompress(<compressed-hello>).__class__.__name__ == 'bytes' — decompress yields bytes (extra11 anchor)"
  category: types
  kind: python_call_eq
  function: decompress
  args: [!hex "425a68393141592653591931653d00000081000244a000219a68334d07338bb9229c28480c98b29e80"]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true
