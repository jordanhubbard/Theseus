spec: inspect_extra120
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra119.zspec.zsdl."
    - "This spec covers: inspect.Parameter.empty and inspect.Signature.empty sentinel class attributes not yet covered — Parameter.empty.__name__ ('_empty', len 6), Parameter.empty.__module__ ('inspect'), Parameter.empty.__qualname__ ('_empty'); _ParameterKind.__name__ ('_ParameterKind', len 14), _ParameterKind MRO member names at indices 1 and 2 ('IntEnum', 'int'); wave 271."
    - "Prior spec extra100 covered Parameter.empty.__class__.__name__ == 'type', Signature.empty.__class__.__name__ == 'type', and _ParameterKind MRO len == 6. New here: the sentinel's own __name__, __module__, __qualname__; _ParameterKind type name length; MRO member names."
    - "inspect.Parameter.empty.__name__ == '_empty' (len 6). Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__qualname__ == '_empty'. Verified with Python 3.14.3."
    - "inspect.Signature.empty.__name__ == '_empty' — same object as Parameter.empty. Verified with Python 3.14.3."
    - "type(inspect.Parameter.KEYWORD_ONLY).__name__ == '_ParameterKind' (len 14). Verified with Python 3.14.3."
    - "type(inspect.Parameter.KEYWORD_ONLY).__mro__[1].__name__ == 'IntEnum'. Verified with Python 3.14.3."
    - "type(inspect.Parameter.KEYWORD_ONLY).__mro__[2].__name__ == 'int'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter.empty sentinel __name__, __qualname__, __module__
#
# Wave 271 theme: inspect.Parameter.empty is the sentinel class inspect._empty.
# It is a class object (its __class__ is 'type', covered in extra100). As a
# class, it has its own __name__, __qualname__, and __module__ attributes.
# __name__ is '_empty' (6 chars: _-e-m-p-t-y). __qualname__ is also '_empty'
# (not nested, so qualname == name). __module__ is 'inspect' (7 chars) —
# confirming the sentinel is defined in the inspect module itself. Both
# Parameter.empty and Signature.empty point to the same object (inspect._empty),
# so Signature.empty.__name__ is also '_empty'. None of these sub-attributes
# have been covered in prior inspect specs.
#
# Parameter.empty.__name__     == '_empty'   (len 6)
# Parameter.empty.__qualname__ == '_empty'
# Parameter.empty.__module__   == 'inspect'
#
# New to extra120.
# ---------------------------------------------------------------------------

table inspect_extra120.parameter_empty_attrs:
  description: "inspect.Parameter.empty sentinel attrs: __name__='_empty'(6), __qualname__='_empty', __module__='inspect'; Signature.empty.__name__ also '_empty' (same object); prior extra100 covered __class__.__name__='type'; wave 271; new to extra120"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectpea120

  columns: [id, function, args, expected, description]
  rows:
    - [param_empty_name_eq,
       "Parameter.empty.__name__.__eq__",
       ["_empty"],
       true,
       "inspect.Parameter.empty.__name__.__eq__('_empty') == True — the sentinel class is named '_empty'; the leading underscore marks it as private; str.__eq__('_empty') returns True; new to extra120"]
    - [param_empty_name_len,
       "Parameter.empty.__name__.__len__",
       [],
       6,
       "inspect.Parameter.empty.__name__.__len__() == 6 — '_empty' has 6 chars: _-e-m-p-t-y; str.__len__() returns 6; new to extra120"]
    - [param_empty_qualname_eq,
       "Parameter.empty.__qualname__.__eq__",
       ["_empty"],
       true,
       "inspect.Parameter.empty.__qualname__.__eq__('_empty') == True — __qualname__ equals __name__ because _empty is a top-level class (not nested); str.__eq__('_empty') returns True; new to extra120"]
    - [param_empty_module_eq,
       "Parameter.empty.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.empty.__module__.__eq__('inspect') == True — _empty is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra120"]
    - [sig_empty_name_eq,
       "Signature.empty.__name__.__eq__",
       ["_empty"],
       true,
       "inspect.Signature.empty.__name__.__eq__('_empty') == True — Signature.empty is the same object as Parameter.empty (both are inspect._empty); __name__ is '_empty'; str.__eq__('_empty') returns True; new to extra120"]

# ---------------------------------------------------------------------------
# Table 2: _ParameterKind type name and MRO member names
#
# Wave 271 theme: _ParameterKind is the enum type for Parameter kind constants.
# Prior spec extra100 covered: all five constants have __class__.__name__ ==
# '_ParameterKind'; _ParameterKind MRO has 6 entries; values are 0-4.
# New here: the name length of '_ParameterKind' (14 chars) and the names of
# specific MRO members. The MRO is [_ParameterKind, IntEnum, int, ReprEnum,
# Enum, object]. MRO[1] is 'IntEnum' and MRO[2] is 'int' — confirming that
# _ParameterKind inherits from IntEnum which in turn inherits from int.
# '_ParameterKind' has 14 chars (same as 'defining_class' from extra119).
#
# type(Parameter.KEYWORD_ONLY).__name__.__len__()  == 14
# type(Parameter.KEYWORD_ONLY).__mro__[1].__name__ == 'IntEnum'
# type(Parameter.KEYWORD_ONLY).__mro__[2].__name__ == 'int'
#
# New to extra120.
# ---------------------------------------------------------------------------

table inspect_extra120.parameter_kind_type_attrs:
  description: "inspect._ParameterKind type attrs: __name__='_ParameterKind'(14), MRO[1]='IntEnum', MRO[2]='int'; inherits IntEnum->int; MRO len=6 (prior extra100); wave 271; new to extra120"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectpkta120

  columns: [id, function, args, expected, description]
  rows:
    - [param_kind_type_name_len,
       "Parameter.KEYWORD_ONLY.__class__.__name__.__len__",
       [],
       14,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__len__() == 14 — '_ParameterKind' has 14 chars: _-P-a-r-a-m-e-t-e-r-K-i-n-d; same length as 'defining_class' (Attribute._fields[2] from extra119); str.__len__() returns 14; new to extra120"]
    - [param_kind_mro1_name,
       "Parameter.KEYWORD_ONLY.__class__.__mro__.__getitem__(1).__name__.__eq__",
       ["IntEnum"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__mro__[1].__name__ == 'IntEnum' — _ParameterKind directly inherits from IntEnum; MRO[1] is IntEnum from the enum module; str.__eq__('IntEnum') returns True; new to extra120"]
    - [param_kind_mro2_name,
       "Parameter.KEYWORD_ONLY.__class__.__mro__.__getitem__(2).__name__.__eq__",
       ["int"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__mro__[2].__name__ == 'int' — IntEnum inherits from int; so _ParameterKind MRO[2] is int; parameter kind constants support integer comparison; str.__eq__('int') returns True; new to extra120"]
    - [param_kind_type_qualname_len,
       "Parameter.KEYWORD_ONLY.__class__.__qualname__.__len__",
       [],
       14,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__qualname__.__len__() == 14 — '_ParameterKind' is a top-level class so __qualname__ == __name__ (both '_ParameterKind', 14 chars); str.__len__() returns 14; new to extra120"]
    - [param_kind_type_module_eq,
       "Parameter.KEYWORD_ONLY.__class__.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__module__.__eq__('inspect') == True — _ParameterKind is defined in Lib/inspect.py; prior extra100 confirmed this via POSITIONAL_ONLY.__class__.__module__; str.__eq__('inspect') returns True; new to extra120"]

# ---------------------------------------------------------------------------
# Table 3: Parameter.empty sentinel identity cross-checks
#
# Wave 271 theme: The _empty sentinel identity is verifiable through multiple
# attribute chains. Parameter.empty.__name__.__class__.__name__ == 'str' —
# the name attribute of the sentinel class is a plain Python string. The length
# of Parameter.empty.__module__ is 7 ('inspect' has 7 chars).
# Parameter.empty.__qualname__.__len__() == 6 (same as __name__.__len__()).
# These cross-checks confirm the sentinel's class identity without assuming
# any specific implementation detail beyond what Python guarantees for all
# class objects.
#
# Parameter.empty.__name__.__class__.__name__   == 'str'
# Parameter.empty.__module__.__len__()          == 7
# Parameter.empty.__qualname__.__len__()        == 6
#
# New to extra120.
# ---------------------------------------------------------------------------

table inspect_extra120.parameter_empty_cross_checks:
  description: "inspect.Parameter.empty sentinel cross-checks: __name__.__class__.__name__='str', __module__.__len__()=7 ('inspect'), __qualname__.__len__()=6 ('_empty'); wave 271; new to extra120"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectpec120

  columns: [id, function, args, expected, description]
  rows:
    - [empty_name_class_name,
       "Parameter.empty.__name__.__class__.__name__.__eq__",
       ["str"],
       true,
       "inspect.Parameter.empty.__name__.__class__.__name__.__eq__('str') == True — the __name__ attribute of any class is a plain Python str; _empty.__name__ is the string '_empty'; str.__eq__('str') returns True; new to extra120"]
    - [empty_module_len,
       "Parameter.empty.__module__.__len__",
       [],
       7,
       "inspect.Parameter.empty.__module__.__len__() == 7 — 'inspect' has 7 chars: i-n-s-p-e-c-t; the module where _empty is defined; str.__len__() returns 7; new to extra120"]
    - [empty_qualname_len,
       "Parameter.empty.__qualname__.__len__",
       [],
       6,
       "inspect.Parameter.empty.__qualname__.__len__() == 6 — '_empty' has 6 chars; __qualname__ == __name__ for top-level classes; same as __name__.__len__(); str.__len__() returns 6; new to extra120"]
    - [sig_empty_module_eq,
       "Signature.empty.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Signature.empty.__module__.__eq__('inspect') == True — Signature.empty is the same object as Parameter.empty (inspect._empty); both have __module__ 'inspect'; str.__eq__('inspect') returns True; new to extra120"]
    - [param_empty_name_qualname_eq,
       "Parameter.empty.__name__.__eq__",
       ["_empty"],
       true,
       "inspect.Parameter.empty.__name__.__eq__('_empty') == True — cross-checking: the sentinel __name__ is '_empty'; consistent with __qualname__ == '_empty'; str.__eq__('_empty') returns True; new to extra120"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra120
# ---------------------------------------------------------------------------

invariant inspect_extra120.param_empty_name:
  description: "inspect.Parameter.empty.__name__ == '_empty' — sentinel class name; 6 chars; leading underscore marks private; wave 271; new to extra120"
  kind: python_call_eq
  function: Parameter.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra120.param_empty_module:
  description: "inspect.Parameter.empty.__module__ == 'inspect' — sentinel defined in Lib/inspect.py; module attr is 'inspect'; wave 271; new to extra120"
  kind: python_call_eq
  function: Parameter.empty.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra120.param_kind_type_name_len:
  description: "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__len__() == 14 — '_ParameterKind' has 14 chars; same as 'defining_class' (extra119); wave 271; new to extra120"
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.__class__.__name__.__len__
  args: []
  expected: 14

invariant inspect_extra120.param_kind_mro1_IntEnum:
  description: "inspect.Parameter.KEYWORD_ONLY.__class__.__mro__[1].__name__ == 'IntEnum' — _ParameterKind directly inherits from IntEnum; wave 271; new to extra120"
  kind: python_call_eq
  function: "Parameter.KEYWORD_ONLY.__class__.__mro__.__getitem__(1).__name__.__eq__"
  args: ["IntEnum"]
  expected: true

invariant inspect_extra120.param_empty_qualname_len:
  description: "inspect.Parameter.empty.__qualname__.__len__() == 6 — '_empty' has 6 chars; qualname == name for top-level class; wave 271; new to extra120"
  kind: python_call_eq
  function: Parameter.empty.__qualname__.__len__
  args: []
  expected: 6
