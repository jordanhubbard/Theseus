spec: hashlib_extra781
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - hashlib module documentation
    - CPython standard library source
  not_derived_from:
    - any third-party hashlib wrapper
  notes:
    - Covers hashlib.__all__ algorithm class types
    - SHA-2 family exposed as builtin_function_or_method
    - SHA-3 family and SHAKE exposed as type
  created_at: "2026-04-12"

table hashlib_extra781.name:
  description: hashlib module __all__ and algorithm class types
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: hl781xx
  columns: [id, function, args, expected]
  rows:
    - [hl781xx001, hashlib.sha256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl781xx002, hashlib.sha512.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl781xx003, hashlib.md5.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl781xx004, hashlib.sha1.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl781xx005, hashlib.sha224.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl781xx006, hashlib.sha384.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl781xx007, hashlib.sha3_224.__class__.__name__.__eq__, ["type"], true]
    - [hl781xx008, hashlib.sha3_256.__class__.__name__.__eq__, ["type"], true]
    - [hl781xx009, hashlib.sha3_384.__class__.__name__.__eq__, ["type"], true]
    - [hl781xx010, hashlib.sha3_512.__class__.__name__.__eq__, ["type"], true]
    - [hl781xx011, hashlib.shake_128.__class__.__name__.__eq__, ["type"], true]
    - [hl781xx012, hashlib.shake_256.__class__.__name__.__eq__, ["type"], true]
