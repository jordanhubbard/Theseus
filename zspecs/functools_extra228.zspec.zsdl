spec: functools_extra228
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools class MRO and __class__.__name__ type identity contracts."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial inherits directly from object. Verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod inherits directly from object. Verified with Python 3.14.3."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object. Verified with Python 3.14.3."
    - "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a Python function. Verified with Python 3.14.3."
    - "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a Python function. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin. Verified with Python 3.14.3."
    - "functools.partial.__class__.__name__ == 'type' — partial is a C extension type. Verified with Python 3.14.3."
    - "functools.partialmethod.__class__.__name__ == 'type' — partialmethod is a Python class (type). Verified with Python 3.14.3."
    - "functools.cached_property.__class__.__name__ == 'type' — cached_property is a Python class (type). Verified with Python 3.14.3."
    - "functools.partial.__mro__.__len__() == 2 — partial MRO is [partial, object]. Verified with Python 3.14.3."
    - "functools.partialmethod.__mro__.__len__() == 2 — partialmethod MRO is [partialmethod, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools class __class__.__name__ type identity checks
#
# Verified with Python 3.14.3:
#   functools.partial.__class__.__name__ == 'type'
#   functools.partialmethod.__class__.__name__ == 'type'
#   functools.cached_property.__class__.__name__ == 'type'
#   functools.lru_cache.__class__.__name__ == 'function'
#   functools.singledispatch.__class__.__name__ == 'function'
#   functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table functools_extra228.class_type_names:
  description: "functools class __class__.__name__ type identity checks; new to extra228"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra228classtype

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_name_eq,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C extension type defined in Modules/_functoolsmodule.c; its metaclass is 'type'; str.__eq__('type') returns True; new to extra228"]
    - [partialmethod_class_name_eq,
       partialmethod.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partialmethod.__class__.__name__.__eq__('type') == True — partialmethod is a Python class defined in Lib/functools.py; its metaclass is 'type'; str.__eq__('type') returns True; new to extra228"]
    - [cached_property_class_name_eq,
       cached_property.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a Python class defined in Lib/functools.py; its metaclass is 'type'; str.__eq__('type') returns True; new to extra228"]
    - [lru_cache_class_name_eq,
       lru_cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a Python function defined in Lib/functools.py; its type is 'function'; str.__eq__('function') returns True; new to extra228"]
    - [singledispatch_class_name_eq,
       singledispatch.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a Python function defined in Lib/functools.py; its type is 'function'; str.__eq__('function') returns True; new to extra228"]
    - [reduce_class_name_eq,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin defined in Modules/_functoolsmodule.c; its type is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra228"]

# ---------------------------------------------------------------------------
# Table 2: functools class MRO length checks
#
# Verified with Python 3.14.3:
#   functools.partial.__mro__.__len__() == 2   ([partial, object])
#   functools.partialmethod.__mro__.__len__() == 2   ([partialmethod, object])
# ---------------------------------------------------------------------------

table functools_extra228.mro_lengths:
  description: "functools partial and partialmethod MRO length checks; new to extra228"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra228mrolen

  columns: [id, function, args, expected, description]
  rows:
    - [partial_mro_len_eq,
       partial.__mro__.__len__,
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — partial MRO is [partial, object]; partial is a C extension type with no intermediate base classes; tuple.__len__() returns 2; new to extra228"]
    - [partialmethod_mro_len_eq,
       partialmethod.__mro__.__len__,
       [],
       2,
       "functools.partialmethod.__mro__.__len__() == 2 — partialmethod MRO is [partialmethod, object]; partialmethod is a Python class with no intermediate base classes; tuple.__len__() returns 2; new to extra228"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra228
# ---------------------------------------------------------------------------

invariant functools_extra228.partial_bases_name:
  description: "functools.partial.__bases__[0].__name__ == 'object' — partial's sole base class is object; new to extra228"
  kind: python_call_eq
  function: partial.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant functools_extra228.partialmethod_bases_name:
  description: "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod's sole base class is object; new to extra228"
  kind: python_call_eq
  function: partialmethod.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant functools_extra228.cached_property_bases_name:
  description: "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property's sole base class is object; new to extra228"
  kind: python_call_eq
  function: cached_property.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant functools_extra228.partial_class_name:
  description: "functools.partial.__class__.__name__.__eq__('type') == True — partial is a type; new to extra228"
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra228.partialmethod_class_name:
  description: "functools.partialmethod.__class__.__name__.__eq__('type') == True — partialmethod is a type; new to extra228"
  kind: python_call_eq
  function: partialmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra228.cached_property_class_name:
  description: "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a type; new to extra228"
  kind: python_call_eq
  function: cached_property.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra228.lru_cache_class_name:
  description: "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a function; new to extra228"
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra228.singledispatch_class_name:
  description: "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a function; new to extra228"
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra228.reduce_class_name:
  description: "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin; new to extra228"
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra228.partial_mro_len:
  description: "functools.partial.__mro__.__len__() == 2 — partial MRO is [partial, object]; new to extra228"
  kind: python_call_eq
  function: partial.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra228.partialmethod_mro_len:
  description: "functools.partialmethod.__mro__.__len__() == 2 — partialmethod MRO is [partialmethod, object]; new to extra228"
  kind: python_call_eq
  function: partialmethod.__mro__.__len__
  args: []
  expected: 2
