spec: quopri_extra2
version: ">=3.9"
backend: python_module(quopri)

docs: https://docs.python.org/3/library/quopri.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/quopri.html — Python quopri documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/quopri.py"
  notes:
    - "This spec extends quopri.zspec.zsdl and quopri_extra.zspec.zsdl."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __name__ — the quopri module's own __name__ attribute
# ---------------------------------------------------------------------------

invariant quopri_extra2.module.name:
  description: "quopri.__name__ == 'quopri' — module identifies itself correctly"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["quopri"]
  expected: true

# ---------------------------------------------------------------------------
# encode.__module__ — encode is defined in the quopri module
# (quopri.zspec.zsdl covers encode.__module__; this is a no-op duplicate guard:
#  quopri_extra.zspec.zsdl already covers encode.__module__ and decode.__module__;
#  here we verify encodestring.__module__ and decodestring.__module__ via a
#  different assertion style — using __ne__ to confirm NOT from builtins)
# ---------------------------------------------------------------------------

invariant quopri_extra2.encodestring.module_not_builtins:
  description: "quopri.encodestring.__module__ != 'builtins' — encodestring is not a builtin"
  category: module
  kind: python_call_eq
  function: encodestring.__module__.__eq__
  args: ["builtins"]
  expected: false

invariant quopri_extra2.decodestring.module_not_builtins:
  description: "quopri.decodestring.__module__ != 'builtins' — decodestring is not a builtin"
  category: module
  kind: python_call_eq
  function: decodestring.__module__.__eq__
  args: ["builtins"]
  expected: false

# ---------------------------------------------------------------------------
# Function __qualname__ checks — all four public functions
# (quopri_extra.zspec.zsdl covers __name__; here we cover __qualname__)
# ---------------------------------------------------------------------------

invariant quopri_extra2.encode.qualname:
  description: "quopri.encode.__qualname__ == 'encode'"
  category: names
  kind: python_call_eq
  function: encode.__qualname__.__eq__
  args: ["encode"]
  expected: true

invariant quopri_extra2.decode.qualname:
  description: "quopri.decode.__qualname__ == 'decode'"
  category: names
  kind: python_call_eq
  function: decode.__qualname__.__eq__
  args: ["decode"]
  expected: true

invariant quopri_extra2.encodestring.qualname:
  description: "quopri.encodestring.__qualname__ == 'encodestring'"
  category: names
  kind: python_call_eq
  function: encodestring.__qualname__.__eq__
  args: ["encodestring"]
  expected: true

invariant quopri_extra2.decodestring.qualname:
  description: "quopri.decodestring.__qualname__ == 'decodestring'"
  category: names
  kind: python_call_eq
  function: decodestring.__qualname__.__eq__
  args: ["decodestring"]
  expected: true
