spec: builtins_extra5
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/builtins.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/builtins.html — Python builtins module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins.zspec.zsdl — covers __name__ for built-in functions and types"
    - "builtins_extra.zspec.zsdl — covers function call behavior for abs, all, any, bin, chr, ord, divmod, hex, oct, pow, round, sorted, sum, max, min, len, isinstance, issubclass"
    - "builtins_extra2.zspec.zsdl — covers exception class hierarchies"
    - "builtins_extra3.zspec.zsdl — covers __name__ for print, input, open, vars, dir, id, frozenset, memoryview, slice, staticmethod, classmethod, super; __module__ for built-in types; base class checks"
    - "builtins_extra4.zspec.zsdl — covers __qualname__ for abs through id (26 entries)"
  notes:
    - "This spec covers __qualname__ for the next 36 built-in functions and types (input through zip)."
    - "For built-in functions and types, __qualname__ == __name__ because they are top-level definitions."
    - "int, isinstance, issubclass, iter, len, list, locals, map, max, memoryview, min, next, object, oct, open, ord, pow, print, property, range, repr, reversed, round, set, setattr, slice, sorted, staticmethod, str, sum, super, tuple, type, vars, zip all have __qualname__ equal to their unqualified name."
    - "All __qualname__ values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — built-in functions and types, input through zip
#
# For all built-in functions and types, __qualname__ == __name__ because
# they are defined at module (top) level with no enclosing class or function.
# ---------------------------------------------------------------------------

table builtins_extra5.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [input,        input.__qualname__.__eq__,        ["input"],        true]
    - [int,          int.__qualname__.__eq__,          ["int"],          true]
    - [isinstance,   isinstance.__qualname__.__eq__,   ["isinstance"],   true]
    - [issubclass,   issubclass.__qualname__.__eq__,   ["issubclass"],   true]
    - [iter,         iter.__qualname__.__eq__,         ["iter"],         true]
    - [len,          len.__qualname__.__eq__,          ["len"],          true]
    - [list,         list.__qualname__.__eq__,         ["list"],         true]
    - [locals,       locals.__qualname__.__eq__,       ["locals"],       true]
    - [map,          map.__qualname__.__eq__,          ["map"],          true]
    - [max,          max.__qualname__.__eq__,          ["max"],          true]
    - [memoryview,   memoryview.__qualname__.__eq__,   ["memoryview"],   true]
    - [min,          min.__qualname__.__eq__,          ["min"],          true]
    - [next,         next.__qualname__.__eq__,         ["next"],         true]
    - [object,       object.__qualname__.__eq__,       ["object"],       true]
    - [oct,          oct.__qualname__.__eq__,          ["oct"],          true]
    - [open,         open.__qualname__.__eq__,         ["open"],         true]
    - [ord,          ord.__qualname__.__eq__,          ["ord"],          true]
    - [pow,          pow.__qualname__.__eq__,          ["pow"],          true]
    - [print,        print.__qualname__.__eq__,        ["print"],        true]
    - [property,     property.__qualname__.__eq__,     ["property"],     true]
    - [range,        range.__qualname__.__eq__,        ["range"],        true]
    - [repr,         repr.__qualname__.__eq__,         ["repr"],         true]
    - [reversed,     reversed.__qualname__.__eq__,     ["reversed"],     true]
    - [round,        round.__qualname__.__eq__,        ["round"],        true]
    - [set,          set.__qualname__.__eq__,          ["set"],          true]
    - [setattr,      setattr.__qualname__.__eq__,      ["setattr"],      true]
    - [slice,        slice.__qualname__.__eq__,        ["slice"],        true]
    - [sorted,       sorted.__qualname__.__eq__,       ["sorted"],       true]
    - [staticmethod, staticmethod.__qualname__.__eq__, ["staticmethod"], true]
    - [str,          str.__qualname__.__eq__,          ["str"],          true]
    - [sum,          sum.__qualname__.__eq__,          ["sum"],          true]
    - [super,        super.__qualname__.__eq__,        ["super"],        true]
    - [tuple,        tuple.__qualname__.__eq__,        ["tuple"],        true]
    - [type,         type.__qualname__.__eq__,         ["type"],         true]
    - [vars,         vars.__qualname__.__eq__,         ["vars"],         true]
    - [zip,          zip.__qualname__.__eq__,          ["zip"],          true]
