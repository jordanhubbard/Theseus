spec: theseus_configparser_cr
version: ">=3.9"
backend: python_cleanroom(theseus_configparser_cr)
blocks: configparser

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html"
  notes:
    - "Clean-room INI-file parser. Do NOT import configparser."
    - "ConfigParser: reads key=value pairs under [section] headers."
    - "read_string(s): parse from a string."
    - "get(section, option): return value as string."
    - "sections(): return list of section names (excluding DEFAULT)."
    - "configparser_get(): parse '[db]\\nhost=localhost', get('db','host') == 'localhost'."
    - "configparser_sections(): sections() returns ['db']."
    - "configparser_fallback(): get with fallback returns fallback when key absent."
    - "Export: ConfigParser class."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_configparser_cr.get:
  description: "get('db','host') == 'localhost' after parsing INI string"
  category: parse
  kind: python_call_eq
  function: configparser_get
  args: []
  expected: "localhost"

invariant theseus_configparser_cr.sections:
  description: "sections() == ['db'] after parsing [db] section"
  category: sections
  kind: python_call_eq
  function: configparser_sections
  args: []
  expected: ["db"]

invariant theseus_configparser_cr.fallback:
  description: "get with fallback returns fallback when key absent"
  category: fallback
  kind: python_call_eq
  function: configparser_fallback
  args: []
  expected: "default_val"
