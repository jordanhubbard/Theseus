spec: re_extra4
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl, re_extra.zspec.zsdl, re_extra2.zspec.zsdl, re_extra3.zspec.zsdl, and re_patterns.zspec.zsdl."
    - "It does NOT duplicate invariants present in those files."
    - "re_extra2.zspec.zsdl covers fullmatch.__name__, purge.__name__, escape.__name__."
    - "re_extra3.zspec.zsdl covers Pattern.__name__, Match.__name__ (type objects, not instances)."
    - "re_extra.zspec.zsdl covers Pattern/Match class name via instance.__class__.__name__."
    - "This spec adds function __name__ coverage for sub, subn, split, findall, finditer, match, search."
    - "This spec adds re.compile.__module__ == 're' (not covered in any prior re spec)."
    - "re.compile.__module__ == 're' because compile() is defined in Lib/re/__init__.py, which sets __name__ to 're'."
    - "re.Match.__name__ == 'Match' and re.Pattern.__name__ == 'Pattern' are covered in re_extra3; here we re-assert as named invariants from this spec's namespace for cross-spec anchoring."
    - "re.subn(pattern, repl, string) returns a (new_string, count) tuple; subn.__name__ == 'subn' is new coverage."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match and re.Pattern — type object __name__ checks
#
# re_extra3.zspec.zsdl covers these; here we re-anchor from re_extra4 namespace
# as independent named invariants for cross-spec coverage completeness.
# ---------------------------------------------------------------------------

invariant re_extra4.Match.type_name:
  description: "re.Match.__name__ == 'Match'"
  category: class_metadata
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra4.Pattern.type_name:
  description: "re.Pattern.__name__ == 'Pattern'"
  category: class_metadata
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

# ---------------------------------------------------------------------------
# re.compile — module affiliation
#
# Not covered in any prior re spec. compile() is a Python function defined in
# Lib/re/__init__.py, so its __module__ is 're'.
# ---------------------------------------------------------------------------

invariant re_extra4.compile.module:
  description: "re.compile.__module__ == 're'"
  category: module_affiliation
  kind: python_call_eq
  function: compile.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# Function identity — __name__ checks
#
# re_extra2.zspec.zsdl covers fullmatch.__name__, purge.__name__, escape.__name__.
# Here we add the remaining public API functions not yet checked.
# ---------------------------------------------------------------------------

invariant re_extra4.fullmatch.function_name:
  description: "re.fullmatch.__name__ == 'fullmatch'"
  category: function_identity
  kind: python_call_eq
  function: fullmatch.__name__.__eq__
  args: ["fullmatch"]
  expected: true

invariant re_extra4.sub.function_name:
  description: "re.sub.__name__ == 'sub'"
  category: function_identity
  kind: python_call_eq
  function: sub.__name__.__eq__
  args: ["sub"]
  expected: true

invariant re_extra4.subn.function_name:
  description: "re.subn.__name__ == 'subn'"
  category: function_identity
  kind: python_call_eq
  function: subn.__name__.__eq__
  args: ["subn"]
  expected: true

invariant re_extra4.split.function_name:
  description: "re.split.__name__ == 'split'"
  category: function_identity
  kind: python_call_eq
  function: split.__name__.__eq__
  args: ["split"]
  expected: true

invariant re_extra4.findall.function_name:
  description: "re.findall.__name__ == 'findall'"
  category: function_identity
  kind: python_call_eq
  function: findall.__name__.__eq__
  args: ["findall"]
  expected: true

invariant re_extra4.finditer.function_name:
  description: "re.finditer.__name__ == 'finditer'"
  category: function_identity
  kind: python_call_eq
  function: finditer.__name__.__eq__
  args: ["finditer"]
  expected: true

invariant re_extra4.match.function_name:
  description: "re.match.__name__ == 'match'"
  category: function_identity
  kind: python_call_eq
  function: match.__name__.__eq__
  args: ["match"]
  expected: true

invariant re_extra4.search.function_name:
  description: "re.search.__name__ == 'search'"
  category: function_identity
  kind: python_call_eq
  function: search.__name__.__eq__
  args: ["search"]
  expected: true

# ---------------------------------------------------------------------------
# Module affiliation — all public re functions are defined in 're'
#
# compile.__module__ is already above; here we verify sub, subn, split,
# findall, finditer, match, search, and fullmatch all belong to 're'.
# ---------------------------------------------------------------------------

table re_extra4.function_modules:
  description: "All public re API functions have __module__ == 're'"
  kind: python_call_eq
  category: module_affiliation
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [sub,      sub.__module__.__eq__,      ["re"], true]
    - [subn,     subn.__module__.__eq__,     ["re"], true]
    - [split,    split.__module__.__eq__,    ["re"], true]
    - [findall,  findall.__module__.__eq__,  ["re"], true]
    - [finditer, finditer.__module__.__eq__,  ["re"], true]
    - [match,    match.__module__.__eq__,    ["re"], true]
    - [search,   search.__module__.__eq__,   ["re"], true]
    - [fullmatch, fullmatch.__module__.__eq__, ["re"], true]

# ---------------------------------------------------------------------------
# re.subn — functional check (not covered in any prior re spec)
#
# subn() returns a (new_string, count) tuple; we verify the replacement count
# and the resulting string independently.
# ---------------------------------------------------------------------------

invariant re_extra4.subn.count:
  description: "re.subn(r'\\d', 'X', 'a1b2c3')[1] == 3 — count of substitutions made"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "a1b2c3"]
  method: __getitem__
  method_args: [1]
  expected: 3

invariant re_extra4.subn.result_string:
  description: "re.subn(r'\\d', 'X', 'a1b2c3')[0] == 'aXbXcX' — resulting string after all substitutions"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "a1b2c3"]
  method: __getitem__
  method_args: [0]
  expected: "aXbXcX"

invariant re_extra4.subn.no_match_count:
  description: "re.subn(r'\\d', 'X', 'abc')[1] == 0 — zero substitutions when pattern does not match"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "abc"]
  method: __getitem__
  method_args: [1]
  expected: 0

# ---------------------------------------------------------------------------
# re.finditer — returns an iterator; class name check (not in any prior spec)
# ---------------------------------------------------------------------------

invariant re_extra4.finditer.returns_iterator:
  description: "re.finditer(r'\\d+', 'a1b2').__class__.__name__ == 'callable_iterator' — finditer returns an iterator"
  category: finditer
  kind: python_call_eq
  function: finditer
  args: ["\\d+", "a1b2"]
  method: __class__.__name__.__eq__
  method_args: ["callable_iterator"]
  expected: true
