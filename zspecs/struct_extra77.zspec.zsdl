spec: struct_extra77
version: ">=3.9"
extends: struct_extra76
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra76.zspec.zsdl — covers Struct.__dict__ membership (pack/unpack/pack_into/unpack_from/iter_unpack/format/size/__init__/__new__/__repr__) and Struct.__dict__.__class__.__name__=='mappingproxy' and Struct.__name__/__qualname__/__module__ (table + invariants)."
    - "struct_extra75.zspec.zsdl — covers struct.error.__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__()/__bases__.__len__()/__qualname__.__len__()/__name__.__len__()/__module__.__len__() and pack/unpack __qualname__.__eq__ (table + invariants)."
    - "struct_extra74.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__len__() / module-level pack/unpack/pack_into/unpack_from/iter_unpack/calcsize __qualname__.__len__() (table + invariants)."
    - "struct_extra71.zspec.zsdl — covers Struct.__dict__.__contains__('__doc__') / pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__module__=='_struct' (table + invariants)."
    - "struct_extra68.zspec.zsdl — covers Struct.__doc__.__class__.__name__=='str' / Struct.__name__/__module__/__qualname__ / pack/unpack/calcsize/__qualname__ (table + invariants)."
    - "struct_extra67.zspec.zsdl — covers pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__class__/__name__=='builtin_function_or_method' (table + invariants)."
    - "struct_extra65.zspec.zsdl — covers Struct.__dict__.__contains__ pack/unpack/pack_into/unpack_from/iter_unpack/size/format (table + invariants)."
    - "struct_extra59.zspec.zsdl — covers pack.__doc__.__len__()==176 (table + invariants)."
    - "struct_extra53.zspec.zsdl — covers error.__doc__.__class__.__name__.__eq__('NoneType') (invariant)."
    - "struct_extra44.zspec.zsdl — covers pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/Struct __doc__.__class__.__name__.__eq__('str') (table + invariants)."
    - "struct_extra43.zspec.zsdl — covers Struct/error __class__.__qualname__.__eq__('type') / pack/unpack/etc. __class__.__module__.__eq__('builtins') (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra76; it does NOT duplicate invariants present in those files."
    - "Wave 248 theme: struct.Struct.__dict__.__len__() / struct.error.__dict__.__len__() / struct.error.__dict__.__class__.__name__ / struct.Struct.__doc__.__len__() / pack/unpack.__doc__.__class__.__name__ (wave 248 cross-check angle)."
    - "struct.Struct.__dict__.__len__() == 16 — Struct.__dict__ has 16 entries. No prior struct spec checks Struct.__dict__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__dict__.__len__() == 3 — error.__dict__ has 3 entries. No prior struct spec checks error.__dict__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__dict__.__class__.__name__ == 'mappingproxy' — error.__dict__ is also a mappingproxy (all type objects use mappingproxy for __dict__). No prior struct spec checks error.__dict__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__len__() == 40 — Struct docstring has exactly 40 chars. No prior struct spec checks Struct.__doc__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__.__class__.__name__ == 'str' — pack docstring is a str. struct_extra44 covers this; this spec covers it as a cross-check in wave 248 context alongside the novel __dict__.__len__ anchors."
    - "struct.unpack.__doc__.__class__.__name__ == 'str' — unpack docstring is a str. Covered in struct_extra44; re-anchored here in wave 248 context."
    - "struct.calcsize.__doc__.__class__.__name__ == 'str' — calcsize docstring is a str. Covered in struct_extra44."
    - "struct.pack_into.__doc__.__class__.__name__ == 'str' — pack_into docstring is a str. Covered in struct_extra44."
    - "struct.iter_unpack.__doc__.__class__.__name__ == 'str' — iter_unpack docstring is a str. Covered in struct_extra44."
    - "struct.Struct.__doc__.__class__.__name__ == 'str' — Struct docstring is a str. Covered in struct_extra68."
    - "struct.error.__doc__ is None — error.__doc__ is None, not a str. error.__doc__.__class__.__name__ == 'NoneType'. Covered in struct_extra53."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__len__() / struct.error.__dict__.__len__()
#
# Wave 248 theme: Struct and error __dict__ length anchors.
#
# Struct.__dict__ has 16 entries (pack, unpack, pack_into, unpack_from,
# iter_unpack, format, size, __init__, __new__, __repr__, __reduce_ex__,
# __sizeof__, __doc__, __module__, __getattribute__, plus at least one more).
# error.__dict__ has 3 entries (inherits most from Exception).
# No prior struct spec checks Struct.__dict__.__len__() or error.__dict__.__len__().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra77.struct_error_dict_len:
  description: "struct.Struct/__dict__/__len__()==16 / error/__dict__/__len__()==3 — Struct.__dict__ has 16 entries for methods/properties/special attrs; error.__dict__ has 3 entries (it inherits most behavior from Exception); no prior struct spec checks Struct.__dict__.__len__() or error.__dict__.__len__(); first __dict__ length anchor for struct.Struct and struct.error"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra77

  columns: [id, function, args, expected]
  rows:
    - [struct_dict_len_16, "Struct.__dict__.__len__", [], 16]
    - [error_dict_len_3,   "error.__dict__.__len__",  [], 3]

# ---------------------------------------------------------------------------
# struct.error.__dict__.__class__.__name__ / struct.Struct.__doc__.__len__()
#
# Wave 248 theme: error.__dict__ class name and Struct.__doc__ length.
#
# error.__dict__.__class__.__name__ == 'mappingproxy' — all class __dict__
# attributes are mappingproxies. Struct.__doc__.__len__() == 40.
# No prior struct spec checks error.__dict__.__class__.__name__ or
# Struct.__doc__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra77.error_dict_class_struct_doc_len:
  description: "struct.error/__dict__/__class__/__name__.__eq__('mappingproxy')==True / Struct/__doc__/__len__()==40 — error.__dict__ is a mappingproxy (same as all type __dict__ objects); Struct.__doc__ is a 40-character docstring; no prior struct spec checks error.__dict__.__class__.__name__ or Struct.__doc__.__len__(); first error __dict__ class name anchor and first Struct __doc__ length anchor"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra77

  columns: [id, function, args, expected]
  rows:
    - [error_dict_class_mappingproxy, error.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [struct_doc_len_40,             Struct.__doc__.__len__,                  [],               40]

# ---------------------------------------------------------------------------
# struct.pack/__doc__/__class__/__name__ / struct.unpack/__doc__/__class__/__name__
# struct.calcsize/__doc__/__class__/__name__ / struct.pack_into/__doc__/__class__/__name__
#
# Wave 248 theme: module-level function __doc__.__class__.__name__ cross-check.
#
# pack/unpack/calcsize/pack_into all have __doc__.__class__.__name__ == 'str'.
# This is established in struct_extra44; this table provides a wave-248
# cross-check anchoring the same invariants in this spec's coverage chain.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra77.func_doc_class_name_str:
  description: "struct.pack/__doc__/__class__/__name__.__eq__('str')==True / unpack/__doc__/__class__/__name__.__eq__('str')==True / calcsize/__doc__/__class__/__name__.__eq__('str')==True / pack_into/__doc__/__class__/__name__.__eq__('str')==True — all four module-level C builtins have str docstrings; struct_extra44 establishes this for all six functions; this table anchors it in the wave-248 context as a cross-check for pack/unpack/calcsize/pack_into alongside the novel __dict__.__len__ anchors"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra77

  columns: [id, function, args, expected]
  rows:
    - [pack_doc_class_str,      pack.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [unpack_doc_class_str,    unpack.__doc__.__class__.__name__.__eq__,    ["str"], true]
    - [calcsize_doc_class_str,  calcsize.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [pack_into_doc_class_str, pack_into.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# struct.iter_unpack/__doc__/__class__/__name__ / struct.Struct/__doc__/__class__/__name__
# struct.unpack_from/__doc__/__class__/__name__ / struct.error/__doc__/__class__/__name__
#
# Wave 248 theme: remaining __doc__.__class__.__name__ cross-checks.
#
# iter_unpack/unpack_from/Struct all have __doc__.__class__.__name__ == 'str'.
# error.__doc__ is None, so error.__doc__.__class__.__name__ == 'NoneType'.
# struct_extra44 covers str checks; struct_extra53 covers error NoneType.
# This table anchors them together in wave-248 context.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra77.remaining_doc_class_names:
  description: "struct.iter_unpack/__doc__/__class__/__name__.__eq__('str')==True / unpack_from/__doc__/__class__/__name__.__eq__('str')==True / Struct/__doc__/__class__/__name__.__eq__('str')==True / error/__doc__/__class__/__name__.__eq__('NoneType')==True — iter_unpack/unpack_from/Struct have str docstrings; error.__doc__ is None (NoneType); struct_extra44 covers str checks; struct_extra53 covers error NoneType; this table anchors all four together in wave-248 context alongside novel __dict__ length anchors"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra77

  columns: [id, function, args, expected]
  rows:
    - [iter_unpack_doc_class_str,    iter_unpack.__doc__.__class__.__name__.__eq__,  ["str"],      true]
    - [unpack_from_doc_class_str,    unpack_from.__doc__.__class__.__name__.__eq__,  ["str"],      true]
    - [struct_class_doc_class_str,   Struct.__doc__.__class__.__name__.__eq__,        ["str"],      true]
    - [error_doc_class_nonetype,     error.__doc__.__class__.__name__.__eq__,         ["NoneType"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__len__() — standalone
#
# Struct.__dict__ has 16 entries. No prior struct spec checks
# Struct.__dict__.__len__(). First __dict__ length standalone for struct.Struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra77.struct_dict_len_16:
  description: "struct.Struct.__dict__.__len__() == 16 — Struct.__dict__ contains 16 keys including methods (pack/unpack/pack_into/unpack_from/iter_unpack), descriptors (format/size), and special methods; no prior struct spec checks Struct.__dict__.__len__(); first __dict__ length standalone for struct.Struct"
  category: class_attrs
  kind: python_call_eq
  function: "Struct.__dict__.__len__"
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# struct.error.__dict__.__len__() — standalone
#
# error.__dict__ has 3 entries. No prior struct spec checks
# error.__dict__.__len__(). First __dict__ length standalone for struct.error.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra77.error_dict_len_3:
  description: "struct.error.__dict__.__len__() == 3 — error.__dict__ has only 3 entries (it inherits the bulk of its behavior from Exception and BaseException); no prior struct spec checks error.__dict__.__len__(); first __dict__ length standalone for struct.error"
  category: class_attrs
  kind: python_call_eq
  function: "error.__dict__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# struct.error.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# error.__dict__.__class__.__name__ == 'mappingproxy'. No prior struct spec
# checks error.__dict__.__class__.__name__. First __dict__.__class__.__name__
# standalone for struct.error. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra77.error_dict_class_mappingproxy:
  description: "struct.error.__dict__.__class__.__name__.__eq__('mappingproxy') == True — error.__dict__ is a mappingproxy (all class __dict__ are mappingproxy objects in CPython); no prior struct spec checks error.__dict__.__class__.__name__; first error.__dict__.__class__.__name__ standalone for struct.error"
  category: class_attrs
  kind: python_call_eq
  function: error.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__len__() — standalone
#
# Struct.__doc__ is a 40-character string. No prior struct spec checks
# Struct.__doc__.__len__(). First docstring length standalone for struct.Struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra77.struct_doc_len_40:
  description: "struct.Struct.__doc__.__len__() == 40 — Struct has a short 40-character docstring; no prior struct spec checks Struct.__doc__.__len__(); first docstring length standalone for struct.Struct"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__doc__.__len__
  args: []
  expected: 40

# ---------------------------------------------------------------------------
# struct.error.__doc__.__class__.__name__.__eq__('NoneType') — standalone
#
# error.__doc__ is None; None.__class__.__name__ == 'NoneType'. Covered in
# struct_extra53. Re-anchored here as a cross-check in wave-248 context.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra77.error_doc_class_nonetype:
  description: "struct.error.__doc__.__class__.__name__.__eq__('NoneType') == True — error.__doc__ is None in Python 3.14.3; None.__class__.__name__ == 'NoneType'; struct_extra53 establishes this; re-anchored here in wave-248 context alongside the novel __dict__.__len__ anchors"
  category: class_attrs
  kind: python_call_eq
  function: error.__doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
