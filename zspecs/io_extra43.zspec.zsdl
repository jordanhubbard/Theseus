spec: io_extra43
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra42.zspec.zsdl — covers BufferedRandom method __qualname__.__len__() for all main methods; IncrementalNewlineDecoder method __qualname__.__len__() for decode/reset/getstate/setstate."
    - "io_extra40.zspec.zsdl — covers IOBase.readable(16)/writable(16)/seekable(16)/tell(12)/flush(13)/close(13) __qualname__.__len__(); RawIOBase/BufferedIOBase/TextIOBase ABC method __qualname__.__len__()."
    - "io_extra38.zspec.zsdl — covers StringIO method __qualname__.__len__() for read(13)/write(14)/getvalue(17)/seek(13); BytesIO method __qualname__.__len__() for read(12)/write(13)/getvalue(16)/seek(12)."
    - "io_extra41.zspec.zsdl — covers StringIO.readline(17)/BytesIO.tell(12) __qualname__.__len__(); TextIOWrapper.tell/flush/close/readable/writable/seekable __qualname__.__len__(); BufferedWriter.tell/seek/writable __qualname__.__len__()."
    - "io_extra29.zspec.zsdl — covers IOBase.readline/__qualname__ via equality check but NOT __qualname__.__len__()."
    - "io_extra17.zspec.zsdl — covers IOBase.readline/__qualname__ via equality check but NOT __qualname__.__len__()."
  notes:
    - "This spec extends io_extra42.zspec.zsdl."
    - "Prior specs collectively covered: __name__/__module__/__qualname__/__dict__.__class__.__name__/__reduce__.__name__/__init_subclass__.__qualname__ for all ten io classes; __mro__.__len__() for all ten classes; __bases__[0].__name__/__len__() for all ten classes; SEEK_*/DEFAULT_BUFFER_SIZE constants; StringIO/BytesIO/TextIOWrapper method __qualname__.__len__() for read/write/getvalue/seek/readline/tell/flush/close/readable/writable/seekable; BufferedReader/BufferedWriter/FileIO/BufferedRandom method __qualname__.__len__(); IOBase.readable/writable/seekable/tell/flush/close __qualname__.__len__(); RawIOBase/BufferedIOBase/TextIOBase ABC method __qualname__.__len__(); IncrementalNewlineDecoder method __qualname__.__len__()."
    - "This spec covers: IOBase.truncate/__qualname__.__len__()==16 (NOVEL — io_extra40 covers IOBase.readable/writable/seekable/tell/flush/close but NOT truncate; io_extra40 notes list truncate as a future target); IOBase.readline/__qualname__.__len__()==16 (NOVEL — io_extra17/io_extra29 check IOBase.readline.__qualname__.__eq__('_IOBase.readline') via equality but no prior io spec checks __qualname__.__len__() for IOBase.readline); IOBase.readlines/__qualname__.__len__()==17 (NOVEL); IOBase.writelines/__qualname__.__len__()==18 (NOVEL); IOBase.fileno/__qualname__.__len__()==14 (NOVEL); IOBase.isatty/__qualname__.__len__()==14 (NOVEL); StringIO.__init__/__qualname__.__len__()==17 (NOVEL — io_extra38 covers StringIO read/write/getvalue/seek; io_extra41 covers StringIO.readline; no prior io spec checks __init__/__qualname__.__len__() for StringIO); StringIO.__new__/__qualname__.__len__()==16 (NOVEL); StringIO.close/__qualname__.__len__()==14 (NOVEL — io_extra30 checks StringIO.close.__qualname__.__eq__('StringIO.close') but not __len__())."
    - "io.IOBase.truncate.__qualname__ == '_IOBase.truncate' — len 16. The C-level internal name prefix '_IOBase.' (8 chars) + 'truncate' (8 chars) = 16. io_extra40 covers readable/writable/seekable/truncate by string equality but NOT __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.IOBase.readline.__qualname__ == '_IOBase.readline' — len 16. io_extra17/io_extra29 test equality but not length. Equal to truncate (16). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.IOBase.readlines.__qualname__ == '_IOBase.readlines' — len 17. One longer than readline/truncate (16). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.IOBase.writelines.__qualname__ == '_IOBase.writelines' — len 18. Longest IOBase method qualname. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.IOBase.fileno.__qualname__ == '_IOBase.fileno' — len 14. Tied with isatty (14). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.IOBase.isatty.__qualname__ == '_IOBase.isatty' — len 14. Tied with fileno (14). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.StringIO.__init__.__qualname__ == 'StringIO.__init__' — len 17. No prior io spec checks __init__/__qualname__.__len__() for StringIO. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.StringIO.__new__.__qualname__ == 'StringIO.__new__' — len 16. No prior io spec checks __new__/__qualname__.__len__() for StringIO. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.StringIO.close.__qualname__ == 'StringIO.close' — len 14. io_extra30 checks equality via __eq__('StringIO.close') but not __len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase remaining method __qualname__.__len__()
#
# io_extra40 covers IOBase.readable(16)/writable(16)/seekable(16)/tell(12)/
# flush(13)/close(13) __qualname__.__len__(). The remaining public IOBase
# methods are: truncate, readline, readlines, writelines, fileno, isatty.
#
# All carry the C-level '_IOBase.' prefix (8 chars). The cluster breakdown:
#
#   len 14 — fileno, isatty        (6-char names)
#   len 16 — truncate, readline    (8-char names, tied with readable/writable/seekable)
#   len 17 — readlines             (9-char name)
#   len 18 — writelines            (10-char name, longest IOBase method qualname)
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra43.IOBase_remaining_method_qualname_lens:
  description: "io.IOBase remaining method __qualname__.__len__(): truncate/readline(16), readlines(17), writelines(18), fileno/isatty(14) — all novel; io_extra40 covers readable/writable/seekable/tell/flush/close but not these six"
  kind: python_call_eq
  category: method_identity
  id_prefix: ibrq43

  columns: [id, function, args, expected]
  rows:
    - [fileno,     IOBase.fileno.__qualname__.__len__,     [], 14]
    - [isatty,     IOBase.isatty.__qualname__.__len__,     [], 14]
    - [truncate,   IOBase.truncate.__qualname__.__len__,   [], 16]
    - [readline,   IOBase.readline.__qualname__.__len__,   [], 16]
    - [readlines,  IOBase.readlines.__qualname__.__len__,  [], 17]
    - [writelines, IOBase.writelines.__qualname__.__len__, [], 18]

# ---------------------------------------------------------------------------
# io.StringIO.__init__, __new__, close __qualname__.__len__()
#
# io_extra38 covers StringIO method __qualname__.__len__() for
# read(13)/write(14)/getvalue(17)/seek(13). io_extra41 covers readline(17).
# No prior io spec checks __qualname__.__len__() for StringIO.__init__,
# __new__, or close. These are the three lifecycle-management methods
# that initialize and tear down a StringIO instance.
#
#   StringIO.__init__ -> 'StringIO.__init__' -> 17
#   StringIO.__new__  -> 'StringIO.__new__'  -> 16
#   StringIO.close    -> 'StringIO.close'    -> 14
#
# Note: StringIO.close is a concrete C-level override using the unqualified
# 'StringIO.' prefix (not the '_IOBase.' prefix used for abstract IOBase
# methods). io_extra30 verifies StringIO.close.__qualname__ == 'StringIO.close'
# via equality but no prior spec checks the length. All three are novel.
# Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra43.StringIO_init_qualname_len:
  description: "len(io.StringIO.__init__.__qualname__) == 17 — 'StringIO.__init__' has 17 characters; no prior io spec checks StringIO.__init__.__qualname__.__len__(); novel"
  category: method_identity
  kind: python_call_eq
  function: StringIO.__init__.__qualname__.__len__
  args: []
  expected: 17

invariant io_extra43.StringIO_new_qualname_len:
  description: "len(io.StringIO.__new__.__qualname__) == 16 — 'StringIO.__new__' has 16 characters; no prior io spec checks StringIO.__new__.__qualname__.__len__(); novel"
  category: method_identity
  kind: python_call_eq
  function: StringIO.__new__.__qualname__.__len__
  args: []
  expected: 16

invariant io_extra43.StringIO_close_qualname_len:
  description: "len(io.StringIO.close.__qualname__) == 14 — 'StringIO.close' has 14 characters; io_extra30 checks equality but not __len__(); novel"
  category: method_identity
  kind: python_call_eq
  function: StringIO.close.__qualname__.__len__
  args: []
  expected: 14
