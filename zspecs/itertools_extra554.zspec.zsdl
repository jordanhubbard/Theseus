spec: itertools_extra554
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers identity invariants for itertools public API members via __qualname__ and __doc__.__class__.__name__ checks"
    - "pairwise was added in Python 3.10; version guard applies"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra554.iterator_qualnames:
  description: "Verify __qualname__ strings for itertools iterator types"
  kind: python_call_eq
  category: identity
  id_prefix: iex554qn
  columns: [id, function, args, expected]
  rows:
    - [iex554qn001, itertools.combinations_with_replacement.__qualname__.__eq__, ["combinations_with_replacement"], true]
    - [iex554qn002, itertools.starmap.__qualname__.__eq__, ["starmap"], true]
    - [iex554qn003, itertools.takewhile.__qualname__.__eq__, ["takewhile"], true]
    - [iex554qn004, itertools.dropwhile.__qualname__.__eq__, ["dropwhile"], true]
    - [iex554qn005, itertools.zip_longest.__qualname__.__eq__, ["zip_longest"], true]
    - [iex554qn006, itertools.filterfalse.__qualname__.__eq__, ["filterfalse"], true]
    - [iex554qn007, itertools.tee.__qualname__.__eq__, ["tee"], true]

table itertools_extra554.iterator_doc_class:
  description: "Verify that itertools iterator types carry str docstrings"
  kind: python_call_eq
  category: identity
  id_prefix: iex554dc
  columns: [id, function, args, expected]
  rows:
    - [iex554dc001, itertools.tee.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [iex554dc002, itertools.zip_longest.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [iex554dc003, itertools.filterfalse.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [iex554dc004, itertools.dropwhile.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [iex554dc005, itertools.takewhile.__doc__.__class__.__name__.__eq__, ["str"], true]

invariant itertools_extra554.tee_has_qualname:
  description: "itertools.tee exposes a proper __qualname__ string"
  category: identity
  kind: python_call_eq
  function: itertools.tee.__qualname__.__eq__
  args: ["tee"]
  expected: true

invariant itertools_extra554.zip_longest_has_qualname:
  description: "itertools.zip_longest exposes a proper __qualname__ string"
  category: identity
  kind: python_call_eq
  function: itertools.zip_longest.__qualname__.__eq__
  args: ["zip_longest"]
  expected: true
