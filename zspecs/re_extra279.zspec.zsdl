spec: re_extra279
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re.zspec.zsdl covers: sub, findall, split, escape tables; error cases for compile."
    - "re_extra278 covers: Match class identity, match/fullmatch/search group(0) results."
    - "This spec focuses on re.sub, re.split, re.findall, and re.subn behavioral contracts."
    - "re.sub('x', 'y', 'xyz') == 'yyz' — all occurrences of 'x' are replaced."
    - "re.split(r'\\s+', 'a b c') == ['a', 'b', 'c'] — splits on any whitespace run."
    - "re.findall(r'\\d+', '1a2b3') == ['1', '2', '3'] — returns all digit runs."
    - "re.subn(r'\\d', 'X', 'a1b2c3') returns a tuple ('aXbXcX', 3) — result and count."
    - "re.subn result is a tuple; [0] is the substituted string, [1] is the substitution count."
    - "All function types are Python functions: __class__.__name__ == 'function'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.sub — pattern substitution
# re.zspec.zsdl covers whitespace→dash, digit→X, backreference, no-match, named group, empty.
# This table tests single-char literal replacement and count-limited substitution.
# ---------------------------------------------------------------------------

table re_extra279.sub:
  description: "re.sub behavioral contracts — literal replacement and count-limited substitution"
  kind: python_call_eq
  category: substitution
  id_prefix: sub
  function: sub

  columns: [id, args, expected, description]
  rows:
    - [x_to_y_in_xyz,  ["x", "y", "xyz"],              "yyz",          "re.sub('x','y','xyz') == 'yyz' — all 'x' replaced"]
    - [no_match_noop,  ["z", "Q", "abc"],               "abc",          "re.sub with no match returns input unchanged"]
    - [all_chars,      ["a", "X", "banana"],            "XbXnXnX",      "re.sub replaces every occurrence of 'a' in 'banana'"]
    - [digits_to_N,    ["\\d+", "N", "1a2b3"],          "NaNbN",        "re.sub('\\d+','N','1a2b3') replaces each digit run"]

# ---------------------------------------------------------------------------
# re.split — pattern splitting
# re.zspec.zsdl covers whitespace, comma, pipe, leading-delimiter.
# This table tests split with a literal char and capturing-group split.
# ---------------------------------------------------------------------------

table re_extra279.split:
  description: "re.split behavioral contracts — splitting on literal and multi-char delimiters"
  kind: python_call_eq
  category: split
  id_prefix: split
  function: split

  columns: [id, args, expected, description]
  rows:
    - [whitespace_abc,  ["\\s+", "a b c"],    ["a", "b", "c"],       "re.split(r'\\s+','a b c') == ['a','b','c']"]
    - [dot_delimiter,   ["\\.", "a.b.c"],     ["a", "b", "c"],       "re.split(r'\\.','a.b.c') splits on literal dots"]
    - [single_item,     ["\\s+", "hello"],    ["hello"],             "re.split on string with no delimiter gives one-element list"]

# ---------------------------------------------------------------------------
# re.findall — return all non-overlapping matches as a list
# re.zspec.zsdl covers digits_multiple, uppercase_letters, no_match, single_group, word_chars.
# This table adds distinct test vectors.
# ---------------------------------------------------------------------------

invariant re_extra279.findall.digits_simple:
  description: "re.findall(r'\\d+', '1a2b3') == ['1', '2', '3'] — each digit run becomes one element"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["\\d+", "1a2b3"]
  expected: ["1", "2", "3"]

invariant re_extra279.findall.no_match:
  description: "re.findall(r'\\d+', 'abc') == [] — empty list when pattern has no matches"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["\\d+", "abc"]
  expected: []

invariant re_extra279.findall.vowels:
  description: "re.findall(r'[aeiou]', 'hello') == ['e', 'o'] — each matching char is a separate element"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["[aeiou]", "hello"]
  expected: ["e", "o"]

# ---------------------------------------------------------------------------
# re.subn — like sub but returns (new_string, count) tuple
# ---------------------------------------------------------------------------

invariant re_extra279.subn.function_is_function:
  description: "re.subn.__class__.__name__ == 'function' — subn is a Python function (not a C builtin)"
  category: subn
  kind: python_call_eq
  function: subn.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra279.subn.substituted_string:
  description: "re.subn(r'\\d','X','a1b2c3')[0] == 'aXbXcX' — first element is the substituted string"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "a1b2c3"]
  method: __getitem__
  method_args: [0]
  expected: "aXbXcX"

invariant re_extra279.subn.substitution_count:
  description: "re.subn(r'\\d','X','a1b2c3')[1] == 3 — second element is the number of substitutions made"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "a1b2c3"]
  method: __getitem__
  method_args: [1]
  expected: 3

invariant re_extra279.subn.x_to_y_count:
  description: "re.subn('x','y','xyz')[1] == 1 — one substitution made when one 'x' in 'xyz'"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["x", "y", "xyz"]
  method: __getitem__
  method_args: [1]
  expected: 1

invariant re_extra279.subn.x_to_y_string:
  description: "re.subn('x','y','xyz')[0] == 'yyz' — substituted string from re.subn"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["x", "y", "xyz"]
  method: __getitem__
  method_args: [0]
  expected: "yyz"

invariant re_extra279.subn.no_match_count_zero:
  description: "re.subn(r'\\d','X','abc')[1] == 0 — count is zero when no substitutions made"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "abc"]
  method: __getitem__
  method_args: [1]
  expected: 0
