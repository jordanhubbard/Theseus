spec: th3511
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (th3511): __get__, __set__, __delete__ dict-presence checks for threading types."
    - "All values false — threading synchronization primitives and Thread do not implement the descriptor protocol."
    - "None of the threading types define __get__, __set__, or __delete__ in their own __dict__."
    - "threading.Condition, Semaphore, BoundedSemaphore, Lock, RLock, Barrier all implement context manager protocol (__enter__/__exit__) but NOT descriptor protocol."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table th3511.get:
  description: "threading types __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3511
  columns: [id, function, args, expected]
  rows:
    - ["th3511001", operator.contains, [threading.Thread.__dict__,           "__get__"], false]
    - ["th3511002", operator.contains, [threading.Event.__dict__,            "__get__"], false]
    - ["th3511003", operator.contains, [threading.Condition.__dict__,        "__get__"], false]
    - ["th3511004", operator.contains, [threading.Semaphore.__dict__,        "__get__"], false]
    - ["th3511005", operator.contains, [threading.BoundedSemaphore.__dict__, "__get__"], false]
    - ["th3511006", operator.contains, [threading.Timer.__dict__,            "__get__"], false]
    - ["th3511007", operator.contains, [threading.Barrier.__dict__,          "__get__"], false]
    - ["th3511008", operator.contains, [threading.local.__dict__,            "__get__"], false]
    - ["th3511009", operator.contains, [type(threading.Lock()).__dict__,     "__get__"], false]
    - ["th3511010", operator.contains, [type(threading.RLock()).__dict__,    "__get__"], false]

