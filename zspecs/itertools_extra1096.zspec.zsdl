table itertools_extra1096.tee_qualname_module_class:
  description: "itertools.tee function qualname, module, and class identity"
  kind: python_call_eq
  category: tee_identity
  id_prefix: it1096te
  columns: [id, function, args, expected]
  rows:
    - [it1096te001, itertools.tee.__qualname__.__eq__,                           ["tee"],                              true]
    - [it1096te002, itertools.tee.__module__.__eq__,                             ["itertools"],                        true]
    - [it1096te003, itertools.tee.__class__.__name__.__eq__,                     ["builtin_function_or_method"],        true]
    - [it1096te004, itertools.tee.__doc__.__class__.__name__.__eq__,             ["str"],                              true]
    - [it1096te005, itertools.zip_longest.__new__.__qualname__.__eq__,           ["zip_longest.__new__"],              true]
    - [it1096te006, itertools.zip_longest.__new__.__class__.__name__.__eq__,     ["builtin_function_or_method"],        true]
    - [it1096te007, itertools.zip_longest.__doc__.__class__.__name__.__eq__,     ["str"],                              true]
    - [it1096te008, itertools.zip_longest.__module__.__eq__,                     ["itertools"],                        true]

