spec: errno
version: ">=3.x"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/errno.html"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "POSIX-standardized errno values are identical on macOS and Linux: EPERM=1, ENOENT=2, ESRCH=3, EINTR=4, EIO=5, EBADF=9, ENOMEM=12, EACCES=13, EINVAL=22."
    - "Platform-specific codes (e.g. EAGAIN: macOS=35, Linux=11) are intentionally omitted from this spec."
    - "errno.errorcode is a dict mapping integer error numbers to their symbolic names as strings."
    - "All errno constants are plain Python int objects."
    - "ENOTSUP is available on macOS (errno 45) but may not be present on all Linux kernels; tested here only for its type."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "The errno module exposes read-only integer constants and the errorcode dict. No functions raise exceptions during normal use."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# POSIX-standardized errno constants (decimal values, portable across platforms)
# ---------------------------------------------------------------------------

table errno.posix_constants:
  kind: python_call_eq
  category: constants
  id_prefix: const

  columns: [id, function, args, expected]
  rows:
    - [EPERM,   "EPERM.__eq__",   [1],  true]
    - [ENOENT,  "ENOENT.__eq__",  [2],  true]
    - [ESRCH,   "ESRCH.__eq__",   [3],  true]
    - [EINTR,   "EINTR.__eq__",   [4],  true]
    - [EIO,     "EIO.__eq__",     [5],  true]
    - [EBADF,   "EBADF.__eq__",   [9],  true]
    - [ENOMEM,  "ENOMEM.__eq__",  [12], true]
    - [EACCES,  "EACCES.__eq__",  [13], true]
    - [EINVAL,  "EINVAL.__eq__",  [22], true]

# ---------------------------------------------------------------------------
# errno constants are ints — spot-check ENOTSUP
# ---------------------------------------------------------------------------

invariant errno.ENOTSUP.is_int:
  description: "ENOTSUP.__class__.__name__ == 'int' — all errno codes are plain Python ints"
  category: constants
  kind: python_call_eq
  function: "ENOTSUP.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# errorcode dict — type check and spot lookups
# ---------------------------------------------------------------------------

invariant errno.errorcode.is_dict:
  description: "errorcode.__class__.__name__ == 'dict' — errorcode is a plain dict"
  category: errorcode
  kind: python_call_eq
  function: "errorcode.__class__.__name__.__eq__"
  args: ["dict"]
  expected: true

invariant errno.errorcode.enoent_lookup:
  description: "errorcode[2] == 'ENOENT' — reverse-lookup of errno 2"
  category: errorcode
  kind: python_call_eq
  function: "errorcode.__getitem__"
  args: [2]
  expected: "ENOENT"

invariant errno.errorcode.eperm_lookup:
  description: "errorcode[1] == 'EPERM' — reverse-lookup of errno 1"
  category: errorcode
  kind: python_call_eq
  function: "errorcode.__getitem__"
  args: [1]
  expected: "EPERM"

invariant errno.errorcode.einval_lookup:
  description: "errorcode[22] == 'EINVAL' — reverse-lookup of errno 22"
  category: errorcode
  kind: python_call_eq
  function: "errorcode.__getitem__"
  args: [22]
  expected: "EINVAL"

