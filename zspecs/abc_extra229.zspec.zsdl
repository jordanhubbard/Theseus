spec: abc_extra229
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.ABC.__name__ == 'ABC' — 3 characters; module is 'abc'; verified with Python 3.14.3."
    - "abc.ABCMeta.__name__ == 'ABCMeta' — 7 characters; module is 'abc'; verified with Python 3.14.3."
    - "abc.abstractmethod.__name__ == 'abstractmethod' — 14 characters; module is 'abc'; verified with Python 3.14.3."
    - "abc.get_cache_token.__name__ == 'get_cache_token' — 15 characters; module is 'abc' (built-in function); verified with Python 3.14.3."
    - "abc.update_abstractmethods.__name__ == 'update_abstractmethods' — 22 characters; verified with Python 3.14.3."
    - "abc module has no __all__ attribute in Python 3.14.3 — contracts cover identity of exported names directly."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module class and function __name__ contracts — extra229 namespace
#
# abc.ABC.__name__ == 'ABC' (3 chars); module 'abc'.
# abc.ABCMeta.__name__ == 'ABCMeta' (7 chars); module 'abc'.
# abc.abstractmethod.__name__ == 'abstractmethod' (14 chars); module 'abc'.
# abc.get_cache_token.__name__ == 'get_cache_token' (15 chars); module 'abc'.
# ---------------------------------------------------------------------------

table abc_extra229.abc_member_names:
  description: "abc module class and function __name__ contracts in abc229mn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: abc229mn

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,          ABC.__name__.__eq__,                 ["ABC"],                true, "abc.ABC.__name__ == 'ABC'; verified with Python 3.14.3"]
    - [abc_name_len_3,       ABC.__name__.__len__,                [],                     3,    "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters; verified with Python 3.14.3"]
    - [abc_module_eq,        ABC.__module__.__eq__,               ["abc"],                true, "abc.ABC.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abcmeta_name_eq,      ABCMeta.__name__.__eq__,             ["ABCMeta"],            true, "abc.ABCMeta.__name__ == 'ABCMeta'; verified with Python 3.14.3"]
    - [abcmeta_name_len_7,   ABCMeta.__name__.__len__,            [],                     7,    "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters; verified with Python 3.14.3"]
    - [abcmeta_module_eq,    ABCMeta.__module__.__eq__,           ["abc"],                true, "abc.ABCMeta.__module__ == 'abc'; verified with Python 3.14.3"]
    - [am_name_eq,           abstractmethod.__name__.__eq__,      ["abstractmethod"],     true, "abc.abstractmethod.__name__ == 'abstractmethod'; verified with Python 3.14.3"]
    - [am_name_len_14,       abstractmethod.__name__.__len__,     [],                     14,   "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 characters; verified with Python 3.14.3"]
    - [am_module_eq,         abstractmethod.__module__.__eq__,    ["abc"],                true, "abc.abstractmethod.__module__ == 'abc'; verified with Python 3.14.3"]

