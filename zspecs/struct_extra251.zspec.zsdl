spec: struct_extra251
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 251 theme: struct.pack/unpack for signed integer formats — byte encoding and decoded values."
    - "struct.pack('b', 127) == b'\\x7f'. Max signed byte. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('b', -128) == b'\\x80'. Min signed byte (two's complement). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('b', b'\\x7f')[0] == 127. 0x7f is the maximum signed byte value. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('b', b'\\x80')[0] == -128. 0x80 is the minimum signed byte (two's complement MSB set). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('>h', 32767) == b'\\x7f\\xff'. Big-endian max signed short. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('>h', -32768) == b'\\x80\\x00'. Big-endian min signed short. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('>h', b'\\x7f\\xff')[0] == 32767. Big-endian decode of 0x7fff is 32767. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('>h', b'\\x80\\x00')[0] == -32768. Big-endian decode of 0x8000 is -32768. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('>i', -1) == b'\\xff\\xff\\xff\\xff'. Big-endian -1 as signed 32-bit. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('>i', 2147483647) == b'\\x7f\\xff\\xff\\xff'. Big-endian max signed 32-bit. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('>i', b'\\xff\\xff\\xff\\xff')[0] == -1. All bits set in two's complement is -1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('>i', b'\\x7f\\xff\\xff\\xff')[0] == 2147483647. Max signed 32-bit int. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack('>q', -1) == b'\\xff\\xff\\xff\\xff\\xff\\xff\\xff\\xff'. Big-endian -1 as signed 64-bit long long. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack('>q', b'\\xff\\xff\\xff\\xff\\xff\\xff\\xff\\xff')[0] == -1. Eight 0xff bytes decode to -1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('b') == 1. struct.calcsize('h') == 2. struct.calcsize('i') == 4. struct.calcsize('q') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: Format characters for signed integers: 'b' (1 byte, range -128..127), 'h' (2 bytes, range -32768..32767), 'i' (4 bytes, range -2147483648..2147483647), 'q' (8 bytes, range -9223372036854775808..9223372036854775807)."
    - "Note: Endianness markers: '>' big-endian (network byte order), '<' little-endian. No prefix uses native with alignment. This spec uses '>' for all multi-byte tests."
    - "Note: Two's complement encoding — most negative value has MSB set and all other bits clear: 'b' 0x80==-128, 'h' 0x8000==-32768, 'i' 0x80000000==-2147483648, 'q' 0x8000000000000000==-9223372036854775808. All bits set == -1 for all signed types."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack('b', 127) == b'\x7f'
# struct.pack('b', -128) == b'\x80'
#
# Wave 251 theme: struct.pack signed byte (8-bit) encoding.
#
# Format character 'b' is a signed 8-bit integer (C signed char, range
# -128..127). 127 == 0x7f is the maximum (all bits set except sign bit).
# -128 == 0x80 is the minimum (only sign bit set, all others clear).
# struct.pack returns a bytes object with the raw binary encoding.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra251.pack_signed_byte:
  description: "struct.pack signed byte encoding — 'b' format: 127->0x7f, -128->0x80 — 'b' is signed 8-bit (C signed char, range -128..127); 127==0x7f is max (all bits except sign bit set); -128==0x80 is min (only sign bit set); wave 251 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: pack_vector
  id_prefix: structsb251
  function: pack

  columns: [id, args, expected]
  rows:
    - [b_max,  ["b", 127],  !hex 7f]
    - [b_min,  ["b", -128], !hex 80]

# ---------------------------------------------------------------------------
# struct.pack('>h', 32767) == b'\x7f\xff'
# struct.pack('>h', -32768) == b'\x80\x00'
# struct.pack('>i', 2147483647) == b'\x7f\xff\xff\xff'
# struct.pack('>i', -1) == b'\xff\xff\xff\xff'
# struct.pack('>q', -1) == b'\xff\xff\xff\xff\xff\xff\xff\xff'
#
# Wave 251 theme: struct.pack big-endian signed multi-byte integer encoding.
#
# Big-endian format ('>') stores the most significant byte first. For signed
# short ('>h'): max 32767==0x7fff, min -32768==0x8000. For signed int ('>i'):
# max 2147483647==0x7fffffff, -1==0xffffffff (all bits set). For signed long
# long ('>q'): -1==0xffffffffffffffff (all 8 bytes 0xff).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra251.pack_signed_bigendian:
  description: "struct.pack big-endian signed multi-byte encoding — '>h': 32767->0x7fff, -32768->0x8000; '>i': 2147483647->0x7fffffff, -1->0xffffffff; '>q': -1->0xffffffffffffffff — big-endian stores MSB first; max has MSB clear, min has only sign bit set, -1 has all bits set; wave 251 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: pack_vector
  id_prefix: structsbig251
  function: pack

  columns: [id, args, expected]
  rows:
    - [h_max,   [">h", 32767],      !hex 7fff        ]
    - [h_min,   [">h", -32768],     !hex 8000        ]
    - [i_max,   [">i", 2147483647], !hex 7fffffff    ]
    - [i_neg1,  [">i", -1],         !hex ffffffff    ]
    - [q_neg1,  [">q", -1],         !hex ffffffffffffffff]

# ---------------------------------------------------------------------------
# struct.unpack('b', b'\x7f') == (127,)
# struct.unpack('b', b'\x80') == (-128,)
#
# Wave 251 theme: struct.unpack signed byte (8-bit) decoding.
#
# struct.unpack returns a tuple. For 'b' format: 0x7f decodes to 127 (max
# signed byte) and 0x80 decodes to -128 (min signed byte, two's complement
# sign extension). The expected list [127] represents the tuple (127,).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra251.unpack_signed_byte:
  description: "struct.unpack signed byte decoding — 'b' format: 0x7f->127, 0x80->-128 — unpack returns tuple; expected as list; 0x7f is max signed byte (MSB clear, all others set); 0x80 is min (only MSB set); two's complement sign extension; wave 251 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: unpack_vector
  id_prefix: structub251
  function: unpack

  columns: [id, args, expected]
  rows:
    - [b_max,  ["b", !hex 7f], [127] ]
    - [b_min,  ["b", !hex 80], [-128]]

# ---------------------------------------------------------------------------
# struct.unpack('>h', b'\x7f\xff') == (32767,)
# struct.unpack('>h', b'\x80\x00') == (-32768,)
# struct.unpack('>i', b'\xff\xff\xff\xff') == (-1,)
# struct.unpack('>i', b'\x7f\xff\xff\xff') == (2147483647,)
# struct.unpack('>q', b'\xff\xff\xff\xff\xff\xff\xff\xff') == (-1,)
#
# Wave 251 theme: struct.unpack big-endian signed multi-byte integer decoding.
#
# Big-endian decode: 0x7fff==32767 (max signed short), 0x8000==-32768 (min).
# 0xffffffff==-1 (signed 32-bit, all bits set), 0x7fffffff==2147483647 (max).
# 0xffffffffffffffff==-1 (signed 64-bit, all 8 bytes 0xff).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra251.unpack_signed_bigendian:
  description: "struct.unpack big-endian signed multi-byte decoding — '>h': 0x7fff->32767, 0x8000->-32768; '>i': 0xffffffff->-1, 0x7fffffff->2147483647; '>q': 0xffffffffffffffff->-1 — two's complement: all bits set==-1 for all signed types; MSB clear with all others set==max positive; wave 251 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: unpack_vector
  id_prefix: structubig251
  function: unpack

  columns: [id, args, expected]
  rows:
    - [h_max,   [">h", !hex 7fff],             [32767]     ]
    - [h_min,   [">h", !hex 8000],             [-32768]    ]
    - [i_neg1,  [">i", !hex ffffffff],         [-1]        ]
    - [i_max,   [">i", !hex 7fffffff],         [2147483647]]
    - [q_neg1,  [">q", !hex ffffffffffffffff], [-1]        ]

# ---------------------------------------------------------------------------
# struct.calcsize('b') == 1
# struct.calcsize('h') == 2
# struct.calcsize('i') == 4
# struct.calcsize('q') == 8
#
# Wave 251 theme: struct.calcsize for signed integer format characters.
#
# struct.calcsize(fmt) returns the number of bytes that struct.pack(fmt, ...)
# would produce. For signed integer formats: 'b'==1, 'h'==2, 'i'==4, 'q'==8.
# These are the standard C sizes for signed char, short, int, and long long.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra251.calcsize_signed:
  description: "struct.calcsize for signed integer formats — 'b'->1, 'h'->2, 'i'->4, 'q'->8 — calcsize returns byte count for format without packing data; sizes match standard C signed types: char (1B), short (2B), int (4B), long long (8B); wave 251 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: calcsize
  id_prefix: structcsz251
  function: calcsize

  columns: [id, args, expected]
  rows:
    - [b_size, ["b"], 1]
    - [h_size, ["h"], 2]
    - [i_size, ["i"], 4]
    - [q_size, ["q"], 8]

# ---------------------------------------------------------------------------
# struct.pack('b', 127) == b'\x7f' — standalone
#
# struct.pack('b', 127) returns b'\x7f'. Format character 'b' is a C signed
# char: an 8-bit two's complement signed integer with range -128..127. The
# value 127 (0x7f) is the maximum: all bits set except the sign bit (bit 7).
# struct.pack returns a bytes object with the raw binary encoding. For 'b'
# the output is always exactly 1 byte regardless of the value. This is the
# first standalone anchor for signed byte pack encoding under structsb251.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra251.pack_b_max:
  description: "struct.pack('b', 127) == b'\\x7f' — 'b' is C signed char (8-bit two's complement, range -128..127); 127==0x7f is max value (all bits set except sign bit); pack returns 1-byte bytes object; struct.zspec covers pack for unsigned 'B'; this is first anchor for signed 'b' max pack; first standalone under structsb251; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: pack_vector
  kind: python_call_eq
  function: pack
  args: ["b", 127]
  expected: !hex 7f

# ---------------------------------------------------------------------------
# struct.unpack('>h', b'\x7f\xff') == (32767,) — standalone
#
# struct.unpack('>h', b'\x7f\xff') returns (32767,). Format '>h' is big-endian
# signed short: 2-byte two's complement integer. The bytes b'\x7f\xff' have
# the most significant byte first (big-endian): 0x7f * 256 + 0xff = 32767.
# This is the maximum positive value for a signed 16-bit integer (all bits set
# except the MSB sign bit). struct.zspec covers unsigned '>H'; this is the first
# anchor for big-endian signed '>h' max value decode. The expected list [32767]
# represents the returned tuple (32767,). This is the first standalone anchor
# for '>h' max decode under structubig251.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra251.unpack_h_max:
  description: "struct.unpack('>h', b'\\x7f\\xff') == (32767,) — '>h' is big-endian signed short (2-byte two's complement); 0x7fff==32767==2**15-1 is max (MSB clear, all others set); 0x7f*256+0xff==32767; struct.zspec covers unsigned '>H'; first anchor for signed '>h' max decode; expected [32767] represents tuple (32767,); first standalone under structubig251; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: [">h", !hex 7fff]
  expected: [32767]

# ---------------------------------------------------------------------------
# struct.unpack('>i', b'\xff\xff\xff\xff') == (-1,) — standalone
#
# struct.unpack('>i', b'\xff\xff\xff\xff') returns (-1,). Format '>i' is
# big-endian signed int: a 4-byte two's complement integer. All bytes 0xff
# means all bits set. In two's complement, all bits set (0xffffffff) represents
# -1 for any width signed integer. This holds universally: 0xff==-1 for 'b',
# 0xffff==-1 for 'h', 0xffffffff==-1 for 'i', 0xffffffffffffffff==-1 for 'q'.
# struct.zspec covers signed '>q' -1 encoding (pack); this is the first anchor
# for signed '>i' -1 decode as a standalone under structubig251.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra251.unpack_i_neg1:
  description: "struct.unpack('>i', b'\\xff\\xff\\xff\\xff') == (-1,) — '>i' is big-endian signed int (4-byte two's complement); all bits set (0xffffffff) represents -1 in two's complement (universal: all-ones == -1 for any signed width); struct.zspec covers '>q' -1; first anchor for '>i' -1 decode as standalone; expected [-1] represents tuple (-1,); first standalone under structubig251; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: unpack_vector
  kind: python_call_eq
  function: unpack
  args: [">i", !hex ffffffff]
  expected: [-1]
