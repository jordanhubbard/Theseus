spec: glob_escape_rust
version: ">=3.9"
backend: rust_module(glob_escape_rust)

docs: https://docs.python.org/3/library/glob.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/glob.html — Python glob documentation"
  not_derived_from:
    - "CPython source: Lib/glob.py"
  notes:
    - "glob.escape(pathname) escapes glob special characters: *, ?, [ so they are treated as literals."
    - "Special chars *, ?, [ are replaced with [*], [?], [[[] respectively."
    - "escape('hello') == 'hello' — no special chars, returned unchanged."
    - "escape('*.txt') == '[*].txt' — * escaped to [*]."
    - "escape('file?.txt') == 'file[?].txt' — ? escaped to [?]."
    - "escape('[test]') == '[[]test]' — [ escaped to [[[], ] is not special alone."
    - "escape('') == '' — empty string."
    - "escape('no_specials') == 'no_specials'."
    - "All test vectors verified against Python 3.14.3 glob module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# escape — make pathname literal (no glob expansion)
table glob_escape_rust.escape.vectors:
  kind: python_call_eq
  category: escape
  id_prefix: ge_esc
  function: escape

  columns: [id, args, expected]
  rows:
    - [plain,        ["hello"],          "hello"]
    - [star,         ["*.txt"],          "[*].txt"]
    - [question,     ["file?.txt"],      "file[?].txt"]
    - [bracket,      ["[test]"],         "[[]test]"]
    - [empty,        [""],               ""]
    - [no_specials,  ["no_specials"],    "no_specials"]
    - [star_star,    ["**/*.py"],        "[*][*]/[*].py"]
    - [mixed,        ["foo*bar?baz"],    "foo[*]bar[?]baz"]

