spec: socket_extra188
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "socket.socket.__mro__ len == 3 — [socket.socket, _socket.socket, object]; Python wrapper extends C base."
    - "socket.socket.__doc__.__class__.__name__ == 'str' — socket.socket class has a str docstring."
    - "socket.socket.__class__.__name__ == 'type' — socket.socket is a regular class created by type."
    - "socket.socket.__module__ == 'socket' — defined in the Python Lib/socket.py wrapper."
    - "socket.socket.__qualname__ == 'socket' — simple unqualified name; len=6."
    - "socket.socket.__hash__.__name__ == '__hash__' — len=8; dunder method name."
    - "socket.socket.__repr__.__name__ == '__repr__' — len=8; dunder method name."
    - "socket.socket.__str__.__name__ == '__str__' — len=7; dunder method name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.socket class MRO identity
#
# socket.socket.__mro__.__len__()    == 3   ([socket.socket, _socket.socket, object])
# socket.socket.__class__.__name__   == 'type'
# socket.socket.__module__           == 'socket'
# socket.socket.__qualname__         == 'socket'
#
# socket.socket is a pure Python class in Lib/socket.py that subclasses
# the C-level _socket.socket.  Its MRO is therefore exactly 3 elements:
# [socket.socket, _socket.socket, object].  The metaclass is the built-in
# 'type'.  __module__ reflects the Python wrapper, not the C extension.
# ---------------------------------------------------------------------------

table socket_extra188.socket_class_mro:
  description: "socket.socket class MRO, metaclass, module, and qualname identity; new to extra188"
  kind: python_call_eq
  category: identity
  id_prefix: socketsocketmro188

  columns: [id, function, args, expected, description]
  rows:
    - [socket_mro_len,
       socket.socket.__mro__.__len__,
       [],
       3,
       "socket.socket.__mro__.__len__() == 3 — MRO is [socket.socket, _socket.socket, object]; new to extra188"]
    - [socket_class_name,
       socket.socket.__class__.__name__.__eq__,
       ["type"],
       true,
       "socket.socket.__class__.__name__.__eq__('type') == True — socket.socket metaclass is built-in type; new to extra188"]
    - [socket_module_eq,
       socket.socket.__module__.__eq__,
       ["socket"],
       true,
       "socket.socket.__module__.__eq__('socket') == True — defined in Lib/socket.py Python wrapper; new to extra188"]
    - [socket_qualname_eq,
       socket.socket.__qualname__.__eq__,
       ["socket"],
       true,
       "socket.socket.__qualname__.__eq__('socket') == True — simple unqualified name; len=6; new to extra188"]

# ---------------------------------------------------------------------------
# Table 2: socket.socket __doc__ and __qualname__ length identity
#
# socket.socket.__doc__.__class__.__name__  == 'str'
# socket.socket.__qualname__.__len__()      == 6
# socket.socket.__module__.__len__()        == 6
#
# socket.socket has a docstring of type str.  Both __qualname__ ('socket')
# and __module__ ('socket') are 6 characters long.
# ---------------------------------------------------------------------------

table socket_extra188.socket_doc_lengths:
  description: "socket.socket __doc__ class identity and attribute lengths; new to extra188"
  kind: python_call_eq
  category: identity
  id_prefix: socketsocketmro188

  columns: [id, function, args, expected, description]
  rows:
    - [socket_doc_class,
       socket.socket.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "socket.socket.__doc__.__class__.__name__.__eq__('str') == True — socket.socket has a str docstring; new to extra188"]
    - [socket_qualname_len,
       socket.socket.__qualname__.__len__,
       [],
       6,
       "socket.socket.__qualname__.__len__() == 6 — 'socket' has 6 characters; new to extra188"]
    - [socket_module_len,
       socket.socket.__module__.__len__,
       [],
       6,
       "socket.socket.__module__.__len__() == 6 — 'socket' has 6 characters; new to extra188"]
    - [socket_doc_class_len,
       socket.socket.__doc__.__class__.__name__.__len__,
       [],
       3,
       "socket.socket.__doc__.__class__.__name__.__len__() == 3 — 'str' has 3 characters; new to extra188"]

# ---------------------------------------------------------------------------
# Table 3: socket.socket dunder method __name__ identity
#
# socket.socket.__hash__.__name__  == '__hash__'  (len=8)
# socket.socket.__repr__.__name__  == '__repr__'  (len=8)
# socket.socket.__str__.__name__   == '__str__'   (len=7)
#
# These dunder methods are accessible as wrapper_descriptor or method-wrapper
# objects on socket.socket.  Their __name__ attributes reflect the canonical
# dunder name including double underscores.  __hash__ and __repr__ are both
# 8 characters; __str__ is 7 characters.
# ---------------------------------------------------------------------------

table socket_extra188.socket_dunder_names:
  description: "socket.socket dunder method __name__ identity; new to extra188"
  kind: python_call_eq
  category: identity
  id_prefix: socketsocketmro188

  columns: [id, function, args, expected, description]
  rows:
    - [hash_name_eq,
       socket.socket.__hash__.__name__.__eq__,
       ["__hash__"],
       true,
       "socket.socket.__hash__.__name__.__eq__('__hash__') == True — dunder method name; len=8; new to extra188"]
    - [hash_name_len,
       socket.socket.__hash__.__name__.__len__,
       [],
       8,
       "socket.socket.__hash__.__name__.__len__() == 8 — '__hash__' has 8 characters; new to extra188"]
    - [repr_name_eq,
       socket.socket.__repr__.__name__.__eq__,
