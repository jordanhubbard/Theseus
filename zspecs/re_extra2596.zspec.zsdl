spec: re_extra2596
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
  notes:
    - "Wave 2596 theme: __get__/__set__/__delete__ descriptor protocol dict-presence."
    - "Neither re.Pattern nor re.Match defines __get__, __set__, or __delete__ in its own __dict__."
    - "re.Pattern is a compiled regex object (C extension type); it exposes match/search/findall but NOT descriptor methods."
    - "re.Match is a match result object; it exposes group/start/end/span but NOT descriptor methods."
    - "C extension member descriptors (e.g., re.Pattern.pattern, re.Match.string) live IN the class __dict__ but the CLASS itself is not a descriptor."
    - "The question asked here is whether re.Pattern or re.Match defines __get__/__set__/__delete__ — they do not."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __get__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2596.no_get_in_re_classes:
  description: "__get__ is absent from re.Pattern and re.Match __dict__s — regex classes are not descriptors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2596

  columns: [id, function, args, expected]
  rows:
    - ["re2596001", "re.Pattern.__dict__.__contains__", ["__get__"], false]
    - ["re2596002", "re.Match.__dict__.__contains__",   ["__get__"], false]

# ---------------------------------------------------------------------------
# __set__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2596.no_set_in_re_classes:
  description: "__set__ is absent from re.Pattern and re.Match __dict__s — regex classes do not implement the data descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2596

  columns: [id, function, args, expected]
  rows:
    - ["re2596003", "re.Pattern.__dict__.__contains__", ["__set__"], false]
    - ["re2596004", "re.Match.__dict__.__contains__",   ["__set__"], false]

# ---------------------------------------------------------------------------
# __delete__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2596.no_delete_in_re_classes:
  description: "__delete__ is absent from re.Pattern and re.Match __dict__s — regex classes do not implement the deletion descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2596

  columns: [id, function, args, expected]
  rows:
    - ["re2596005", "re.Pattern.__dict__.__contains__", ["__delete__"], false]
    - ["re2596006", "re.Match.__dict__.__contains__",   ["__delete__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern HAS regex methods but NOT descriptor methods
# Confirms re.Pattern is a matching engine, not a descriptor
# ---------------------------------------------------------------------------

table re_extra2596.pattern_has_regex_methods_not_descriptor:
  description: "re.Pattern defines match/search/findall/pattern (regex engine) but NOT __get__/__set__/__delete__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2596

  columns: [id, function, args, expected]
  rows:
    - ["re2596007", "re.Pattern.__dict__.__contains__", ["match"],     true]
    - ["re2596008", "re.Pattern.__dict__.__contains__", ["search"],    true]
    - ["re2596009", "re.Pattern.__dict__.__contains__", ["findall"],   true]
    - ["re2596010", "re.Pattern.__dict__.__contains__", ["pattern"],   true]
    - ["re2596011", "re.Pattern.__dict__.__contains__", ["flags"],     true]
    - ["re2596012", "re.Pattern.__dict__.__contains__", ["__get__"],   false]
    - ["re2596013", "re.Pattern.__dict__.__contains__", ["__set__"],   false]
    - ["re2596014", "re.Pattern.__dict__.__contains__", ["__delete__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Match HAS match-result methods but NOT descriptor methods
# Confirms re.Match is a result container, not a descriptor
# ---------------------------------------------------------------------------

table re_extra2596.match_has_result_methods_not_descriptor:
  description: "re.Match defines group/start/end/span/string (match results) but NOT __get__/__set__/__delete__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2596

  columns: [id, function, args, expected]
  rows:
    - ["re2596015", "re.Match.__dict__.__contains__", ["group"],      true]
    - ["re2596016", "re.Match.__dict__.__contains__", ["start"],      true]
    - ["re2596017", "re.Match.__dict__.__contains__", ["span"],       true]
    - ["re2596018", "re.Match.__dict__.__contains__", ["string"],     true]
    - ["re2596019", "re.Match.__dict__.__contains__", ["re"],         true]
    - ["re2596020", "re.Match.__dict__.__contains__", ["__get__"],    false]
