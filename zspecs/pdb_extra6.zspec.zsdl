spec: pdb_extra6
version: ">=3.9"
backend: python_module(pdb)

docs: https://docs.python.org/3/library/pdb.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pdb.html — Python pdb documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pdb.py"
  notes:
    - "This spec extends pdb.zspec.zsdl through pdb_extra5.zspec.zsdl."
    - "pdb covers: Pdb/__name__, Restart/__name__, Pdb/__module__, run/runeval/runcall/set_trace/post_mortem/pm __name__ (table), Pdb().prompt, Pdb().use_rawinput."
    - "pdb_extra covers: Pdb/__name__/__module__/__bases__[0].__name__, run/runeval/runcall/set_trace/post_mortem/pm/help __name__."
    - "pdb_extra2 covers: Pdb/__name__/__module__/__qualname__, run/runcall/post_mortem/set_trace/pm __name__ and __module__."
    - "pdb_extra3 covers: runeval/__module__, help/__module__, Restart/__module__, Restart.__bases__[0]/__name__, Pdb.__bases__.__len__()==2, Pdb.__bases__[0]/__module__=='bdb', Pdb.__bases__[1]/__name__=='Cmd', Pdb.__bases__[1]/__module__=='cmd', function __qualname__ table."
    - "pdb_extra4 covers: Restart/__qualname__, Restart.__bases__.__len__()==1, Pdb.__bases__[0]/__qualname__=='Bdb', Pdb.__bases__[1]/__qualname__=='Cmd', Pdb.__bases__.__class__.__name__=='tuple', Pdb/__name__/__class__.__name__=='str', Restart/__name__/__class__.__name__=='str'."
    - "pdb_extra5 covers: Pdb command-method names (do_break/do_continue/do_step/do_next/do_quit/do_list), do_break.__module__, Pdb().__class__.__name__, Pdb().skip/nosigint defaults, run.__class__.__name__, Pdb.MAX_CHAINED_EXCEPTION_DEPTH."
    - "NEW in this spec: Pdb.__name__ identity via __eq__ predicate (expected: true form), Pdb.__module__ identity via __eq__ predicate, Pdb.__bases__[0].__name__=='Bdb' via __eq__ predicate, run/__name__/__eq__, pm/__name__/__eq__, runcall/__name__/__eq__, runeval/__name__/__eq__, set_trace/__name__/__eq__, post_mortem/__name__/__eq__, Restart.__name__/__eq__, Restart.__bases__[0].__name__=='Exception' via __eq__, pdb.line_prefix.__class__.__name__=='str'."
    - "pdb.Pdb inherits from bdb.Bdb and cmd.Cmd; __bases__[0].__name__ == 'Bdb'."
    - "pdb.Restart.__bases__[0].__name__ == 'Exception' — Restart is a direct subclass of Exception."
    - "pdb.line_prefix is a module-level string constant (a newline by default); its __class__.__name__ == 'str'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pdb class identity — __name__ and __module__ via __eq__ predicate form
#
# Prior specs confirm these values via direct expected strings or other
# structural forms.  These invariants use __eq__ with expected: true.
# ---------------------------------------------------------------------------

invariant pdb_extra6.Pdb.name_eq:
  description: "pdb.Pdb.__name__.__eq__('Pdb') == True"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__name__.__eq__
  args: ["Pdb"]
  expected: true

invariant pdb_extra6.Pdb.module_eq:
  description: "pdb.Pdb.__module__.__eq__('pdb') == True"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__module__.__eq__
  args: ["pdb"]
  expected: true

# ---------------------------------------------------------------------------
# Pdb.__bases__[0].__name__ == 'Bdb' — via __eq__ predicate
#
# pdb_extra confirms this as a direct-value invariant; this uses the __eq__
# form (expected: true) as a distinct structural variant.
# ---------------------------------------------------------------------------

invariant pdb_extra6.Pdb.base0_name_eq:
  description: "pdb.Pdb.__bases__[0].__name__.__eq__('Bdb') == True — Pdb inherits from bdb.Bdb"
  category: pdb_class
  kind: python_call_eq
  function: Pdb.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Bdb"]
  expected: true

# ---------------------------------------------------------------------------
# Public function __name__ identity checks — __eq__ predicate form
#
# Prior specs confirm these __name__ values via table rows with direct
# expected strings.  These invariants use __eq__ with expected: true.
# ---------------------------------------------------------------------------

invariant pdb_extra6.run.name_eq:
  description: "pdb.run.__name__.__eq__('run') == True"
  category: function_names
  kind: python_call_eq
  function: run.__name__.__eq__
  args: ["run"]
  expected: true

invariant pdb_extra6.pm.name_eq:
  description: "pdb.pm.__name__.__eq__('pm') == True"
  category: function_names
  kind: python_call_eq
  function: pm.__name__.__eq__
  args: ["pm"]
  expected: true

invariant pdb_extra6.runcall.name_eq:
  description: "pdb.runcall.__name__.__eq__('runcall') == True"
  category: function_names
  kind: python_call_eq
  function: runcall.__name__.__eq__
  args: ["runcall"]
  expected: true

invariant pdb_extra6.runeval.name_eq:
  description: "pdb.runeval.__name__.__eq__('runeval') == True"
  category: function_names
  kind: python_call_eq
  function: runeval.__name__.__eq__
  args: ["runeval"]
  expected: true

invariant pdb_extra6.set_trace.name_eq:
  description: "pdb.set_trace.__name__.__eq__('set_trace') == True"
  category: function_names
  kind: python_call_eq
  function: set_trace.__name__.__eq__
  args: ["set_trace"]
  expected: true

invariant pdb_extra6.post_mortem.name_eq:
  description: "pdb.post_mortem.__name__.__eq__('post_mortem') == True"
  category: function_names
  kind: python_call_eq
  function: post_mortem.__name__.__eq__
  args: ["post_mortem"]
  expected: true

# ---------------------------------------------------------------------------
# Restart exception class — name and base via __eq__ predicate
#
# pdb covers Restart.__name__ as a direct-value invariant.  pdb_extra3 covers
# Restart.__bases__[0].__name__ as a direct-value invariant.  The __eq__
# predicate form (expected: true) is new for both.
# ---------------------------------------------------------------------------

invariant pdb_extra6.Restart.name_eq:
  description: "pdb.Restart.__name__.__eq__('Restart') == True"
  category: restart_class
  kind: python_call_eq
  function: Restart.__name__.__eq__
  args: ["Restart"]
  expected: true

invariant pdb_extra6.Restart.base_is_Exception_eq:
  description: "pdb.Restart.__bases__[0].__name__.__eq__('Exception') == True — Restart is a direct subclass of Exception"
  category: restart_class
  kind: python_call_eq
  function: Restart.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# line_prefix — module-level string constant
#
# pdb.line_prefix is a module-level constant (a newline character by default)
# used to prefix pdb output lines.  No prior pdb spec covers it.
# Its __class__.__name__ == 'str' confirms it is a string.
# ---------------------------------------------------------------------------

invariant pdb_extra6.line_prefix.class_name_eq:
  description: "pdb.line_prefix.__class__.__name__.__eq__('str') == True — line_prefix is a string constant"
  category: module_constants
  kind: python_call_eq
  function: line_prefix.__class__.__name__.__eq__
  args: ["str"]
  expected: true
