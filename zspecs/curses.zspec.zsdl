spec: curses
version: ">=3.3"
backend: python_module(curses)

docs: https://docs.python.org/3/library/curses.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/curses.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "curses source: Lib/curses/__init__.py and Modules/_cursesmodule.c (PSF; source inspection permitted)"
  not_derived_from:
    - "curses internals: terminal interaction, window rendering, keyboard/mouse input"
  notes:
    - "curses provides an interface to the curses library for terminal text-UI programming."
    - "Interactive functions (initscr, wrapper, newwin) require a real terminal and are not tested here."
    - "curses.ERR is the integer -1, returned by many curses functions on failure."
    - "curses.OK is the integer 0, returned by many curses functions on success."
    - "curses.A_BOLD, A_UNDERLINE, and A_REVERSE are integer attribute bitmask constants."
    - "curses.error is the module-level exception class, a subclass of Exception."
    - "Function names (wrapper, initscr, endwin, etc.) are checked via __name__ only; calling them requires a terminal."
    - "All expected values verified by running Python 3.12 curses module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "curses functions raise curses.error on failure. initscr() and friends require a terminal or raise an error."
  stderr: "null"
  stickiness: "N/A — constant and name checks are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Integer constants
# ---------------------------------------------------------------------------

invariant curses.ERR_value:
  description: "curses.ERR == -1"
  category: constants
  kind: python_call_eq
  function: ERR.__eq__
  args: [-1]
  expected: true

invariant curses.OK_value:
  description: "curses.OK == 0"
  category: constants
  kind: python_call_eq
  function: OK.__eq__
  args: [0]
  expected: true

invariant curses.A_BOLD_is_int:
  description: "isinstance(curses.A_BOLD, int) — A_BOLD is an integer bitmask"
  category: constants
  kind: python_call_eq
  function: A_BOLD.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant curses.A_UNDERLINE_is_int:
  description: "isinstance(curses.A_UNDERLINE, int) — A_UNDERLINE is an integer bitmask"
  category: constants
  kind: python_call_eq
  function: A_UNDERLINE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant curses.A_REVERSE_is_int:
  description: "isinstance(curses.A_REVERSE, int) — A_REVERSE is an integer bitmask"
  category: constants
  kind: python_call_eq
  function: A_REVERSE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class checks
# ---------------------------------------------------------------------------

invariant curses.error_name:
  description: "curses.error.__name__ == 'error'"
  category: classnames
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant curses.error_base:
  description: "curses.error.__bases__[0].__name__ == 'Exception'"
  category: classnames
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Function name checks (no terminal required)
# ---------------------------------------------------------------------------

invariant curses.wrapper_name:
  description: "curses.wrapper.__name__ == 'wrapper'"
  category: functions
  kind: python_call_eq
  function: wrapper.__name__.__eq__
  args: ["wrapper"]
  expected: true

invariant curses.initscr_name:
  description: "curses.initscr.__name__ == 'initscr'"
  category: functions
  kind: python_call_eq
  function: initscr.__name__.__eq__
  args: ["initscr"]
  expected: true

invariant curses.endwin_name:
  description: "curses.endwin.__name__ == 'endwin'"
  category: functions
  kind: python_call_eq
  function: endwin.__name__.__eq__
  args: ["endwin"]
  expected: true

invariant curses.start_color_name:
  description: "curses.start_color.__name__ == 'start_color'"
  category: functions
  kind: python_call_eq
  function: start_color.__name__.__eq__
  args: ["start_color"]
  expected: true

