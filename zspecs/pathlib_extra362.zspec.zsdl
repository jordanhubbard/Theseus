spec: pathlib_extra362
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.Path('nonexistent_xyz123').stat() raises FileNotFoundError — stat requires the path to exist"
    - "pathlib.Path('nonexistent_xyz123').open() raises FileNotFoundError — open requires the path to exist"
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath directly subclasses PurePath"
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath directly subclasses PurePath"
    - "Both PurePosixPath and PureWindowsPath report __module__ == 'pathlib'"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib error behaviors — FileNotFoundError on nonexistent path
# ---------------------------------------------------------------------------

invariant pathlib_extra362.path_stat_nonexistent_raises:
  description: "pathlib.Path('nonexistent_xyz123').stat() raises FileNotFoundError — the path does not exist on the filesystem; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: "Path('nonexistent_xyz123').stat"
  args: []
  raises: FileNotFoundError

invariant pathlib_extra362.path_open_nonexistent_raises:
  description: "pathlib.Path('nonexistent_xyz123').open() raises FileNotFoundError — the path does not exist on the filesystem; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: "Path('nonexistent_xyz123').open"
  args: []
  raises: FileNotFoundError

# ---------------------------------------------------------------------------
# pathlib PurePosixPath class identity
# ---------------------------------------------------------------------------

table pathlib_extra362.pureposixpath_identity:
  description: "pathlib.PurePosixPath class identity — __name__, __module__, __bases__[0].__name__; PurePosixPath is a pure path class with POSIX semantics, available on all platforms; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pureposix362

  columns: [id, function, args, expected]
  rows:
    - [pureposixpath_name,   pathlib.PurePosixPath.__name__.__eq__,   ["PurePosixPath"], true]
    - [pureposixpath_module, pathlib.PurePosixPath.__module__.__eq__, ["pathlib"],        true]

invariant pathlib_extra362.pureposixpath_base:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath directly subclasses PurePath; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "pathlib.PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib PureWindowsPath class identity
# ---------------------------------------------------------------------------

table pathlib_extra362.purewindowspath_identity:
  description: "pathlib.PureWindowsPath class identity — __name__, __module__, __bases__[0].__name__; PureWindowsPath is available on all platforms for pure Windows-style path manipulation; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: purewinpath362

  columns: [id, function, args, expected]
  rows:
    - [purewindowspath_name,   pathlib.PureWindowsPath.__name__.__eq__,   ["PureWindowsPath"], true]
    - [purewindowspath_module, pathlib.PureWindowsPath.__module__.__eq__, ["pathlib"],          true]

invariant pathlib_extra362.purewindowspath_base:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath directly subclasses PurePath; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "pathlib.PureWindowsPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true
