spec: unescape_js
version: ">=1.1.4"
backend: node(unescape-js)

docs: https://www.npmjs.com/package/unescape-js

provenance:
  derived_from:
    - "unescape-js README — https://www.npmjs.com/package/unescape-js"
    - "Test vectors verified with unescape-js via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "unescape-js source"
  notes:
    - "unescape-js is an npm package. Install: npm install unescape-js"
    - "Converts JavaScript escape sequences (\\xHH, \\uHHHH) in a string to their character equivalents."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table unescape_js.unescapeJs:
  kind: node_module_call_eq
  function: ~
  category: decode
  id_prefix: unescjs

  columns: [id, args, expected]
  rows:
    - [hex_A,    ["\\x41"],      "A"]
    - [hex_HI,   ["\\x48\\x49"], "HI"]
    - [plain,    ["hello"],      "hello"]
    - [unicode,  ["\\u0041"],    "A"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:06:00Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
