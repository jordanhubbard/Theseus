spec: io_extra2281
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count, abstract method count, dict size."
    - "Subjects: io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper, io.IncrementalNewlineDecoder."
    - "io.IOBase.__mro__.__len__ == 3 (IOBase, _IOBase, object); __bases__.__len__ == 1; __abstractmethods__.__len__ == 0."
    - "io.RawIOBase.__mro__.__len__ == 5; io.BufferedIOBase.__mro__.__len__ == 5; io.TextIOBase.__mro__.__len__ == 5."
    - "Concrete classes (FileIO, BytesIO, StringIO, Buffered*, TextIOWrapper) have __mro__.__len__ == 4."
    - "io.IncrementalNewlineDecoder.__mro__.__len__ == 2 (direct object subclass)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

