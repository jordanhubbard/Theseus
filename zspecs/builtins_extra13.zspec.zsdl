spec: builtins_extra13
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/functions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functions.html — Python built-in functions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/bltinmodule.c"
    - "builtins_extra3.zspec.zsdl — covers __bases__[0].__name__ for int/bool/str/list/dict/tuple/set/frozenset/bytes/bytearray"
    - "builtins_extra8.zspec.zsdl — covers __name__ for int/float/complex/bool/bytes/frozenset and __qualname__ for int/str/list/tuple etc."
    - "builtins_extra9.zspec.zsdl — covers MRO lengths for dict/tuple/set/float/complex/range"
    - "builtins_extra11.zspec.zsdl — covers MRO lengths for int/bool/bytes/bytearray/frozenset/object"
    - "builtins_extra12.zspec.zsdl — covers list.__mro__.__len__; float/complex __bases__[0].__name__; MRO element access"
  notes:
    - "This spec extends builtins.zspec.zsdl and prior extras through builtins_extra12.zspec.zsdl."
    - "builtins_extra8 covers __name__ for int/float/complex/bool/bytes/frozenset but NOT str/list/dict/tuple/set."
    - "No prior builtins spec covers str.__name__ == 'str'."
    - "No prior builtins spec covers list.__name__ == 'list'."
    - "No prior builtins spec covers dict.__name__ == 'dict'."
    - "No prior builtins spec covers tuple.__name__ == 'tuple'."
    - "No prior builtins spec covers set.__name__ == 'set'."
    - "No prior builtins spec covers len.__name__ == 'len'."
    - "No prior builtins spec covers len.__class__.__name__ == 'builtin_function_or_method'."
    - "No prior builtins spec covers print.__class__.__name__ == 'builtin_function_or_method'."
    - "No prior builtins spec covers bool.__bases__.__len__() == 1 — bool has exactly one direct base (int)."
    - "No prior builtins spec covers int.__bases__.__len__() == 1 — int has exactly one direct base (object)."
    - "str.__name__ == 'str', list.__name__ == 'list', etc. — __name__ equals the Python-level attribute name."
    - "len and print are builtin_function_or_method instances — the C-level function type."
    - "bool.__bases__.__len__() == 1 — bool directly inherits only from int; single-element __bases__ tuple."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ for str, list, dict, tuple, set
#
# builtins_extra8 covers __name__ for int/float/complex/bool/bytes/frozenset.
# No prior builtins spec covers __name__ for str, list, dict, tuple, or set.
# For all built-in types, __name__ equals the unqualified type name.
# ---------------------------------------------------------------------------

table builtins_extra13.collection_type_names:
  description: "__name__ attribute for str, list, dict, tuple, and set built-in types"
  kind: python_call_eq
  category: type_names

  columns: [id, function, args, expected]
  rows:
    - [str,     str.__name__.__eq__,     ["str"],     true]
    - [list,    list.__name__.__eq__,    ["list"],    true]
    - [dict,    dict.__name__.__eq__,    ["dict"],    true]
    - [tuple,   tuple.__name__.__eq__,   ["tuple"],   true]
    - [set,     set.__name__.__eq__,     ["set"],     true]

# ---------------------------------------------------------------------------
# len.__name__ and len/__class__/__name__
#
# builtins_extra8 covers print.__name__.__eq__('print') via a table.
# No prior spec covers len.__name__ or len.__class__.__name__.
# len is a builtin_function_or_method (C-level function) in CPython.
# ---------------------------------------------------------------------------

invariant builtins_extra13.len.name:
  description: "len.__name__ == 'len' — the built-in function has its own name attribute"
  category: builtin_functions
  kind: python_call_eq
  function: len.__name__.__eq__
  args: ["len"]
  expected: true

invariant builtins_extra13.len.class_name:
  description: "len.__class__.__name__ == 'builtin_function_or_method' — len is a C-level built-in"
  category: builtin_functions
  kind: python_call_eq
  function: len.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# print.__class__.__name__
#
# builtins_extra8 covers print.__name__ == 'print' and print.__qualname__ == 'print'.
# No prior spec covers print.__class__.__name__. Like len, print is a
# builtin_function_or_method (C-level function) in CPython.
# ---------------------------------------------------------------------------

invariant builtins_extra13.print.class_name:
  description: "print.__class__.__name__ == 'builtin_function_or_method' — print is a C-level built-in"
  category: builtin_functions
  kind: python_call_eq
  function: print.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# bool.__bases__.__len__() and int.__bases__.__len__()
#
# builtins_extra3 covers bool.__bases__[0].__name__ == 'int'.
# No prior spec checks bool.__bases__.__len__() == 1 (single direct base).
# Similarly, int.__bases__.__len__() == 1 (only object is a direct base).
# The __bases__ tuple contains only the directly declared base classes.
# ---------------------------------------------------------------------------

invariant builtins_extra13.bool.bases_len:
  description: "bool.__bases__.__len__() == 1 — bool has exactly one direct base class (int)"
  category: bases_length
  kind: python_call_eq
  function: bool.__bases__.__len__
  args: []
  expected: 1

invariant builtins_extra13.int.bases_len:
  description: "int.__bases__.__len__() == 1 — int has exactly one direct base class (object)"
  category: bases_length
  kind: python_call_eq
  function: int.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# bool.__bases__[0].__name__ == 'int' and complex.__bases__[0].__name__ == 'object'
#
# builtins_extra3 covers these via the method: __name__ form (without __eq__).
# builtins_extra12 covers float.__bases__[0] and complex.__bases__[0] via getitem+method.
# No prior spec uses the method: __name__.__eq__ form for bool.__bases__[0].
# This provides the same fact via a new encoding axis.
# ---------------------------------------------------------------------------

invariant builtins_extra13.bool.base0_is_int:
  description: "bool.__bases__[0].__name__ == 'int' — bool directly subclasses int"
  category: bases
  kind: python_call_eq
  function: bool.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["int"]
  expected: true

invariant builtins_extra13.str.bases_len:
  description: "str.__bases__.__len__() == 1 — str has exactly one direct base class (object)"
  category: bases_length
  kind: python_call_eq
  function: str.__bases__.__len__
  args: []
  expected: 1
