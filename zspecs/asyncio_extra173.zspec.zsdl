spec: asyncio_extra173
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-future.html — asyncio.Future documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio.Task documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/mixins.py"
  notes:
    - "This spec covers: asyncio.__name__=='asyncio'; asyncio.__package__=='asyncio'; asyncio.__spec__.__class__.__name__=='ModuleSpec'; asyncio.Future.__mro__.__len__()==2 (Future > object — C type from _asyncio); asyncio.Task.__mro__.__len__()==3 (Task > Future > object — both C types); asyncio.Queue.__mro__.__len__()==3 (Queue > _LoopBoundMixin > object); asyncio.Lock.__mro__.__len__()==4 (Lock > _ContextManagerMixin > _LoopBoundMixin > object). KEY FINDINGS: asyncio.Future and asyncio.Task are C types from _asyncio (short MRO chains of 2 and 3); asyncio.Queue and asyncio.Lock are Python classes with mixin-based inheritance; asyncio.Lock.__mro__.__len__()==4 is the longest MRO chain in this spec; asyncio.__name__==asyncio.__package__=='asyncio' (both len=7). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Future.__mro__.__len__()==2: Future (from _asyncio C extension) directly inherits from object; no intermediate Python-level base classes; MRO: [_asyncio.Future, object]. Verified with Python 3.14.3."
    - "asyncio.Task.__mro__.__len__()==3: Task (C type) inherits from Future (C type) which inherits from object; MRO: [_asyncio.Task, _asyncio.Future, object]. Verified with Python 3.14.3."
    - "asyncio.Queue.__mro__.__len__()==3: Queue (Python class in asyncio.queues) inherits from _LoopBoundMixin (in asyncio.mixins) which inherits from object; MRO: [asyncio.queues.Queue, asyncio.mixins._LoopBoundMixin, object]. Verified with Python 3.14.3."
    - "asyncio.Lock.__mro__.__len__()==4: Lock (Python class in asyncio.locks) inherits from _ContextManagerMixin (asyncio.locks) then _LoopBoundMixin (asyncio.mixins) then object; MRO: [asyncio.locks.Lock, asyncio.locks._ContextManagerMixin, asyncio.mixins._LoopBoundMixin, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio module identity — extra173
#
# asyncio.__name__.__eq__('asyncio')                         == True
# asyncio.__package__.__eq__('asyncio')                     == True
# asyncio.__spec__.__class__.__name__.__eq__('ModuleSpec')  == True
# ---------------------------------------------------------------------------

table asyncio_extra173.asyncio_module_identity:
  description: "asyncio module __name__, __package__, and __spec__ class checks in asynciomodid173 namespace — asyncio.__name__.__eq__('asyncio')==True (asyncio.__name__=='asyncio' (len=7: 'asyncio'=7); the asyncio package's __name__ is its fully qualified dotted path; as a single-component top-level package, 'asyncio' has no dots); asyncio.__name__.__len__()==7 ('asyncio'=7; NEW CONTEXT: this length also appears as the prefix of all asyncio submodule paths: '_asyncio'=8='_'=1+'asyncio'=7; 'asyncio.tasks'=13='asyncio'=7+'.'=1+'tasks'=5=13; 'asyncio.events'=14; 'asyncio.runners'=15); asyncio.__package__.__eq__('asyncio')==True (asyncio.__package__=='asyncio' (len=7; equal to __name__); for a package module, __name__==__package__; asyncio is a package (has __init__.py and submodules); CONTRAST: abc.__package__=='' (empty — frozen, not a package) vs asyncio.__package__=='asyncio' (IS a package)); asyncio.__spec__.__class__.__name__.__eq__('ModuleSpec')==True ('ModuleSpec'=10: universal for importlib-loaded modules; asyncio is NOT frozen — it is loaded from Lib/asyncio/__init__.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciomodid173

  columns: [id, function, args, expected, description]
  rows:
    - [aio_name_eq,     asyncio.__name__.__eq__,                       ["asyncio"],     true,  "asyncio.__name__ == 'asyncio' (len=7; single-component package name); verified with Python 3.14.3"]
    - [aio_name_len,    asyncio.__name__.__len__,                      [],              7,     "asyncio.__name__.__len__() == 7 ('asyncio'=7; prefix of all asyncio submodule paths); verified with Python 3.14.3"]
    - [aio_pkg_eq,      asyncio.__package__.__eq__,                    ["asyncio"],     true,  "asyncio.__package__ == 'asyncio' (len=7; __name__==__package__ for package modules); verified with Python 3.14.3"]
    - [aio_spec_cls_eq, asyncio.__spec__.__class__.__name__.__eq__,    ["ModuleSpec"],  true,  "asyncio.__spec__.__class__.__name__ == 'ModuleSpec' (len=10; NOT frozen unlike abc); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Future MRO length — extra173
#
# asyncio.Future.__mro__.__len__() == 2
# MRO: [_asyncio.Future, object]
# ---------------------------------------------------------------------------

table asyncio_extra173.asyncio_future_mro_len:
  description: "asyncio.Future.__mro__.__len__ and MRO entry name checks in asynciofuturemro173 namespace — asyncio.Future.__mro__.__len__()==2 (asyncio.Future is implemented as a C type in the _asyncio extension module; its MRO has only 2 entries: [_asyncio.Future, object]; no intermediate Python-level base classes; Future.__mro__[0].__name__=='Future' (the class itself) and Future.__mro__[1].__name__=='object' (the universal base)); asyncio.Future.__mro__.__len__()==2 is the SHORTEST MRO chain among the four asyncio classes in this spec: Future(2) < Task(3) == Queue(3) < Lock(4); a 2-entry MRO is the minimum for any class (every class inherits from object); asyncio.Task.__mro__.__len__()==3 (cross-check: Task > Future > object — adding 1 entry for Task itself on top of Future's MRO chain); asyncio.Lock.__mro__.__len__()==4 (cross-check: longest MRO in this spec); KEY DESIGN: Future's short MRO (just Future > object) is because it is a C type — C extension types typically have minimal MRO chains because they implement all behavior directly in C rather than via Python mixins; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciofuturemro173

  columns: [id, function, args, expected, description]
  rows:
    - [fut_mro_len,     asyncio.Future.__mro__.__len__,           [],         2,     "Future.__mro__.__len__() == 2 (C type from _asyncio; MRO: Future > object; shortest in spec); verified with Python 3.14.3"]
    - [fut_mro0_name,   "asyncio.Future.__mro__[0].__name__.__eq__", ["Future"], true,  "Future.__mro__[0].__name__ == 'Future' (the class itself; entry 0 of 2); verified with Python 3.14.3"]
    - [fut_mro1_name,   "asyncio.Future.__mro__[1].__name__.__eq__", ["object"], true,  "Future.__mro__[1].__name__ == 'object' (universal base; entry 1 of 2; direct inheritance from object); verified with Python 3.14.3"]
    - [task_mro_xchk,   asyncio.Task.__mro__.__len__,             [],         3,     "Task.__mro__.__len__() == 3 (cross-check; Task > Future > object; one more than Future=2); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Task MRO length — extra173
#
# asyncio.Task.__mro__.__len__() == 3
# MRO: [_asyncio.Task, _asyncio.Future, object]
# ---------------------------------------------------------------------------

table asyncio_extra173.asyncio_task_mro_len:
  description: "asyncio.Task.__mro__.__len__ and MRO entry name checks in asynciotaskmro173 namespace — asyncio.Task.__mro__.__len__()==3 (asyncio.Task is a C type in the _asyncio module; it inherits from asyncio.Future (also a C type); its MRO has 3 entries: [_asyncio.Task, _asyncio.Future, object]); asyncio.Task.__mro__[0].__name__=='Task' (Task itself); asyncio.Task.__mro__[1].__name__=='Future' (the C Future class Task inherits from — same C type as asyncio.Future); asyncio.Task.__mro__[2].__name__=='object' (universal base); MRO LENGTH ORDERING: Future(2) < Task(3) == Queue(3) < Lock(4); Task and Queue both have MRO length 3 but via different inheritance chains (Task is a C subtype of Future; Queue is a Python class with one Python mixin); asyncio.Future.__mro__.__len__()==2 (cross-check: Future's MRO is Task's MRO minus the Task entry at index 0); asyncio.Queue.__mro__.__len__()==3 (cross-check: Queue also has 3-entry MRO; Queue > _LoopBoundMixin > object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotaskmro173

  columns: [id, function, args, expected, description]
  rows:
    - [task_mro_len,    asyncio.Task.__mro__.__len__,              [],         3,     "Task.__mro__.__len__() == 3 (C type; MRO: Task > Future > object; equals Queue MRO len); verified with Python 3.14.3"]
    - [task_mro0_name,  "asyncio.Task.__mro__[0].__name__.__eq__",   ["Task"],   true,  "Task.__mro__[0].__name__ == 'Task' (Task itself; C type from _asyncio); verified with Python 3.14.3"]
    - [task_mro1_name,  "asyncio.Task.__mro__[1].__name__.__eq__",   ["Future"], true,  "Task.__mro__[1].__name__ == 'Future' (the C Future type Task inherits from); verified with Python 3.14.3"]
    - [task_mro2_name,  "asyncio.Task.__mro__[2].__name__.__eq__",   ["object"], true,  "Task.__mro__[2].__name__ == 'object' (universal base; entry 2 of 3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Queue and asyncio.Lock MRO lengths — extra173
#
# asyncio.Queue.__mro__.__len__() == 3
# asyncio.Lock.__mro__.__len__()  == 4
# ---------------------------------------------------------------------------

table asyncio_extra173.asyncio_queue_and_lock_mro_len:
  description: "asyncio.Queue and asyncio.Lock MRO length checks in asyncioqlockmro173 namespace — asyncio.Queue.__mro__.__len__()==3 (asyncio.Queue is a Python class in asyncio.queues; it inherits from asyncio.mixins._LoopBoundMixin which inherits from object; MRO: [asyncio.queues.Queue, asyncio.mixins._LoopBoundMixin, object]; Queue.__mro__[0].__name__=='Queue'; Queue.__mro__[1].__name__=='_LoopBoundMixin'; Queue.__mro__[2].__name__=='object'; Queue's MRO length equals Task's MRO length (3) but via Python mixin rather than C type inheritance); asyncio.Lock.__mro__.__len__()==4 (asyncio.Lock is a Python class in asyncio.locks with TWO mixin bases: _ContextManagerMixin (asyncio.locks) and _LoopBoundMixin (asyncio.mixins); MRO: [asyncio.locks.Lock, asyncio.locks._ContextManagerMixin, asyncio.mixins._LoopBoundMixin, object]; Lock has the LONGEST MRO chain in this spec at 4 entries; Lock adds _ContextManagerMixin for async context manager support (async with lock:) on top of the _LoopBoundMixin shared with Queue); asyncio.Future.__mro__.__len__()==2 (cross-check; shortest); asyncio.Task.__mro__.__len__()==3 (cross-check; equals Queue); MRO ORDERING: Future(2) < Task(3) == Queue(3) < Lock(4); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqlockmro173

  columns: [id, function, args, expected, description]
  rows:
    - [queue_mro_len,   asyncio.Queue.__mro__.__len__,             [],                  3,     "Queue.__mro__.__len__() == 3 (Python class; MRO: Queue > _LoopBoundMixin > object; equals Task MRO len); verified with Python 3.14.3"]
    - [queue_mro1_name, "asyncio.Queue.__mro__[1].__name__.__eq__",  ["_LoopBoundMixin"], true,  "Queue.__mro__[1].__name__ == '_LoopBoundMixin' (Queue's one mixin base; shared with Lock); verified with Python 3.14.3"]
    - [lock_mro_len,    asyncio.Lock.__mro__.__len__,              [],                  4,     "Lock.__mro__.__len__() == 4 (Python class; MRO: Lock > _ContextManagerMixin > _LoopBoundMixin > object; longest in spec); verified with Python 3.14.3"]
    - [lock_mro1_name,  "asyncio.Lock.__mro__[1].__name__.__eq__",   ["_ContextManagerMixin"], true, "Lock.__mro__[1].__name__ == '_ContextManagerMixin' (Lock's context manager mixin; supports async with); verified with Python 3.14.3"]
    - [lock_mro2_name,  "asyncio.Lock.__mro__[2].__name__.__eq__",   ["_LoopBoundMixin"], true,  "Lock.__mro__[2].__name__ == '_LoopBoundMixin' (shared with Queue; loop-binding mixin); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# MRO cross-comparison table — extra173
#
# All four MRO lengths: Future(2), Task(3), Queue(3), Lock(4)
# ---------------------------------------------------------------------------

table asyncio_extra173.asyncio_mro_cross_comparison:
  description: "Cross-comparison of asyncio class MRO lengths in asynciomroxcmp173 namespace — asyncio.Future.__mro__.__len__()==2 (C type; Future > object; minimum possible MRO for a non-object class); asyncio.Task.__mro__.__len__()==3 (C type; Task > Future > object; extends Future's C MRO); asyncio.Queue.__mro__.__len__()==3 (Python class; Queue > _LoopBoundMixin > object; equal to Task but via Python mixin chain not C inheritance); asyncio.Lock.__mro__.__len__()==4 (Python class; Lock > _ContextManagerMixin > _LoopBoundMixin > object; longest chain — Lock adds the context manager protocol via _ContextManagerMixin on top of _LoopBoundMixin shared with Queue); KEY PATTERN: C types (Future, Task) have compact MRO chains built at the C level; Python mixin classes (Queue, Lock) use explicit Python mixin inheritance to compose behavior; Lock has the same _LoopBoundMixin as Queue at index 2 but adds _ContextManagerMixin at index 1 for 'async with' support; MRO ORDERING: Future(2) < Task(3) == Queue(3) < Lock(4); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciomroxcmp173

  columns: [id, function, args, expected, description]
  rows:
    - [fut_mro_xchk,   asyncio.Future.__mro__.__len__,  [],  2,  "Future.__mro__.__len__() == 2 (C type; shortest MRO in spec); verified with Python 3.14.3"]
    - [task_mro_xchk,  asyncio.Task.__mro__.__len__,    [],  3,  "Task.__mro__.__len__() == 3 (C type; middle MRO; equals Queue); verified with Python 3.14.3"]
    - [queue_mro_xchk, asyncio.Queue.__mro__.__len__,   [],  3,  "Queue.__mro__.__len__() == 3 (Python class + mixin; equals Task MRO len); verified with Python 3.14.3"]
    - [lock_mro_xchk,  asyncio.Lock.__mro__.__len__,    [],  4,  "Lock.__mro__.__len__() == 4 (Python class + 2 mixins; longest MRO in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra173
# ---------------------------------------------------------------------------

invariant asyncio_extra173.asyncio_name_eq:
  description: "asyncio.__name__.__eq__('asyncio') returns True — asyncio.__name__=='asyncio' (len=7: 'asyncio'=7); asyncio is the top-level package for Python's asynchronous I/O framework; as a package, its __name__ equals its dotted path which is just 'asyncio' (no dots — single-component); COMPARISON: asyncio.__name__=='asyncio' (len=7) vs asyncio.__package__=='asyncio' (len=7; equal to __name__ — both are 7 chars as expected for a package module); context from prior specs: '_asyncio'=8 (C extension — one char longer due to underscore prefix); 'asyncio.tasks'=13 (submodule from extra172); 'asyncio.events'=14 (from extra171); 'asyncio.runners'=15 (from extra171); the top-level package name 'asyncio'=7 is the root for all these submodule paths; NEW in extra173: first standalone asyncio.__name__ identity invariant in asynciomodid173 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.__name__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra173.asyncio_package_eq:
  description: "asyncio.__package__.__eq__('asyncio') returns True — asyncio.__package__=='asyncio' (len=7; equal to __name__='asyncio'=7); for a package module (directory with __init__.py), __package__ and __name__ are equal — both hold the fully qualified dotted path; asyncio IS a package (Lib/asyncio/__init__.py exists) with many submodules; CONTRAST: abc.__package__=='' (empty — abc is a frozen module, not a package; no submodules) vs asyncio.__package__=='asyncio' (IS a package with submodules like asyncio.tasks, asyncio.events, asyncio.runners, asyncio.locks, asyncio.queues, asyncio.mixins); the asyncio package re-exports from its C extension _asyncio (e.g., asyncio.Future is _asyncio.Future); __name__==__package__ is the defining property of a Python package-level module; NEW in extra173: first standalone asyncio.__package__ identity invariant in asynciomodid173 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.__package__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra173.asyncio_spec_class_is_ModuleSpec:
  description: "asyncio.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — asyncio.__spec__.__class__.__name__=='ModuleSpec' (len=10: 'Module'=6+'Spec'=4=10); asyncio is loaded from Lib/asyncio/__init__.py (not frozen like abc); its __spec__.origin is the file path to __init__.py; COMPARISON: abc.__spec__.__class__.__name__=='ModuleSpec' (frozen module also gets ModuleSpec; but abc.__spec__.origin=='frozen'); asyncio.__spec__.__class__.__name__=='ModuleSpec' (source module — __spec__.origin is a .py file path); both frozen and source modules use the same ModuleSpec type — the difference is in __spec__.origin and __spec__.loader; 'ModuleSpec'=10: 'Module'=6+'Spec'=4=10; NEW in extra173: first standalone asyncio.__spec__.__class__.__name__ invariant in asynciomodid173 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant asyncio_extra173.asyncio_future_mro_len:
  description: "asyncio.Future.__mro__.__len__() returns 2 — asyncio.Future.__mro__.__len__()==2; asyncio.Future is a C type implemented in the _asyncio CPython C extension (Modules/_asynciomodule.c); as a C type, it inherits directly from object without any intermediate Python mixin classes; MRO: [_asyncio.Future, object]; len=2 is the minimum possible MRO length for any non-object class (every class must include object in its MRO); COMPARISON: asyncio.Task.__mro__.__len__()==3 (Task is a C subtype of Future; adds one entry); asyncio.Queue.__mro__.__len__()==3 (Python class with one mixin); asyncio.Lock.__mro__.__len__()==4 (Python class with two mixins); MRO ORDERING: Future(2) < Task(3) == Queue(3) < Lock(4); the short MRO of Future reflects its nature as a C primitive — Future IS the foundation of the asyncio type system and has no Python base classes; NEW in extra173: first standalone asyncio.Future.__mro__.__len__ invariant in asynciofuturemro173 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.__mro__.__len__
  args: []
  expected: 2

invariant asyncio_extra173.asyncio_task_mro_len:
  description: "asyncio.Task.__mro__.__len__() returns 3 — asyncio.Task.__mro__.__len__()==3; asyncio.Task is a C type that subclasses asyncio.Future (also a C type); MRO: [_asyncio.Task, _asyncio.Future, object]; Task extends Future with coroutine-scheduling capability — a Task wraps a coroutine and drives it to completion by scheduling __step() calls on the event loop; Task.__mro__[1].__name__=='Future' confirms that Task IS-A Future (in the MRO / isinstance sense); this means asyncio.Task instances can be used anywhere an asyncio.Future is expected; CONTRAST: asyncio.Queue.__mro__.__len__()==3 as well (Queue also has a 3-entry MRO) but Queue > _LoopBoundMixin > object is a pure Python mixin chain, not C type inheritance; the two 3-entry MRO chains (Task and Queue) represent fundamentally different design patterns — C subtyping vs Python mixin composition; NEW in extra173: first standalone asyncio.Task.__mro__.__len__ invariant in asynciotaskmro173 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra173.asyncio_queue_mro_len:
  description: "asyncio.Queue.__mro__.__len__() returns 3 — asyncio.Queue.__mro__.__len__()==3; asyncio.Queue is a Python class in asyncio.queues; MRO: [asyncio.queues.Queue, asyncio.mixins._LoopBoundMixin, object]; _LoopBoundMixin ensures the queue is bound to the running event loop (raises RuntimeError if accessed from outside a running loop); asyncio.Queue.__mro__[1].__name__=='_LoopBoundMixin' — this mixin is shared by both Queue (and its subclasses LifoQueue, PriorityQueue) and by asyncio.Lock (at index 2 in Lock's 4-entry MRO); _LoopBoundMixin._get_loop() is the key method that retrieves and caches the event loop; Queue's MRO length (3) equals Task's MRO length (3) — one 3-entry chain is C type inheritance (Task > Future > object), the other is Python mixin inheritance (Queue > _LoopBoundMixin > object); NEW in extra173: first standalone asyncio.Queue.__mro__.__len__ invariant in asyncioqlockmro173 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra173.asyncio_lock_mro_len:
  description: "asyncio.Lock.__mro__.__len__() returns 4 — asyncio.Lock.__mro__.__len__()==4; asyncio.Lock is a Python class in asyncio.locks with the LONGEST MRO chain in this spec: [asyncio.locks.Lock, asyncio.locks._ContextManagerMixin, asyncio.mixins._LoopBoundMixin, object]; Lock adds TWO mixin bases: (1) _ContextManagerMixin at index 1 provides __aenter__ and __aexit__ for 'async with lock:' usage; (2) _LoopBoundMixin at index 2 (shared with Queue at index 1 in Queue's MRO) binds the lock to the running event loop; Lock's 4-entry MRO is 1 longer than Queue's 3-entry MRO precisely because Lock adds the _ContextManagerMixin layer that Queue omits (Queue also supports 'async with' but through a different mechanism); MRO ORDERING in this spec: Future(2) < Task(3) == Queue(3) < Lock(4); 4 is the longest MRO chain for any asyncio synchronization primitive covered in this spec series; NEW in extra173: first standalone asyncio.Lock.__mro__.__len__ invariant in asyncioqlockmro173 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.__mro__.__len__
  args: []
  expected: 4
