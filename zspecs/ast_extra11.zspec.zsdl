spec: ast_extra11
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
    - "ast.zspec.zsdl — covers literal_eval primitives/containers/tuple-access, error cases, literal_eval.__name__, arithmetic/statement node classnames (Add,Sub,Mult,Div,Module,Constant,Expr,Name,FunctionDef,ClassDef,If,For,Import,Call)"
    - "ast_extra.zspec.zsdl — covers parse/__name__/__module__/returns_module_node, dump/__name__, get_docstring/__name__, fix_missing_locations/__name__, NodeVisitor/__name__, NodeTransformer/__name__/__bases__[0], AST/__name__, literal_eval standalone round-trips"
    - "ast_extra2.zspec.zsdl — covers literal_eval value checks for int/str/list/dict/bool/None"
    - "ast_extra3.zspec.zsdl — covers __module__ for parse/dump/literal_eval/get_docstring/fix_missing_locations/walk/NodeVisitor/NodeTransformer/Module/FunctionDef/Constant/Name/AST/Expr/ClassDef"
    - "ast_extra4.zspec.zsdl — covers __qualname__ for literal_eval/get_docstring/dump/walk/fix_missing_locations/NodeVisitor/NodeTransformer/AST/Module/Constant/parse; literal_eval type checks"
    - "ast_extra5.zspec.zsdl — covers __qualname__ for FunctionDef/Expr/ClassDef/Name/If/For/Import/Call/Assign/Return/AsyncFunctionDef/AsyncFor/AsyncWith/With/Delete; unparse/__qualname__/__module__, copy_location/__qualname__/__module__, increment_lineno/__qualname__/__module__"
    - "ast_extra6.zspec.zsdl — covers __name__ for Module/Constant/Name/Expr/FunctionDef/ClassDef/If/Return/Assign/Call/Import/For (table); walk.__name__; NodeVisitor.__bases__[0]; AST.__bases__[0]; AsyncFunctionDef/__name__, With/__name__, Delete/__name__"
    - "ast_extra7.zspec.zsdl — covers abstract bases mod/stmt/expr/__name__; BinOp/While/Tuple/List/Try/Raise/Pass/Break/Continue __name__/__qualname__; BinOp/While/Tuple __module__; Module MRO[0]/MRO[2]; parse body __len__"
    - "ast_extra8.zspec.zsdl — covers operator/cmpop/boolop/unaryop/expr_context abstract base __name__; Add/Sub/Mult/Div/Mod/Pow/FloorDiv operator node __name__; Eq/NotEq/Lt/LtE/Gt/GtE cmpop node __name__; And/Or boolop __name__; Not/UAdd/USub unaryop __name__; PyCF_ONLY_AST value; NodeTransformer MRO[1].__name__; parse mode='eval' returns Expression"
    - "ast_extra9.zspec.zsdl — covers NodeVisitor/NodeTransformer __name__.__eq__; get_source_segment.__module__; BitAnd/BitOr/BitXor/LShift/RShift/MatMult/Invert bitwise operator __name__; Is/IsNot/In/NotIn cmpop __name__; Load/Store/Del expr_context __name__; parse/dump __module__.__eq__"
    - "ast_extra10.zspec.zsdl — covers helper node __name__ for arg/arguments/keyword/alias/withitem; Global/Nonlocal/Yield/YieldFrom/Await/Subscript/Attribute/Starred __name__; arg/alias __module__"
  notes:
    - "This spec covers __qualname__ for helper and access nodes not verified in any prior ast spec."
    - "ast.arg.__qualname__ == 'arg' — helper node qualname not covered in any prior spec."
    - "ast.arguments.__qualname__ == 'arguments' — helper node qualname not covered in any prior spec."
    - "ast.keyword.__qualname__ == 'keyword' — helper node qualname not covered in any prior spec."
    - "ast.alias.__qualname__ == 'alias' — helper node qualname not covered in any prior spec."
    - "ast.withitem.__qualname__ == 'withitem' — helper node qualname not covered in any prior spec."
    - "ast.Subscript.__qualname__ == 'Subscript' — access expression node qualname not covered in any prior spec."
    - "ast.Attribute.__qualname__ == 'Attribute' — attribute access node qualname not covered in any prior spec."
    - "ast.Starred.__qualname__ == 'Starred' — starred expression node qualname not covered in any prior spec."
    - "ast.Global.__qualname__ == 'Global' — statement node qualname not covered in any prior spec."
    - "ast.Nonlocal.__qualname__ == 'Nonlocal' — statement node qualname not covered in any prior spec."
    - "ast.Yield.__qualname__ == 'Yield' — expression node qualname not covered in any prior spec."
    - "ast.withitem.__module__ == 'ast' — helper node module not covered in any prior spec."
    - "ast.keyword.__module__ == 'ast' — helper node module not covered in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Helper node __qualname__ checks
# ast_extra10 covers __name__ for arg/arguments/keyword/alias/withitem.
# No prior ast spec checks __qualname__ for any of these helper nodes.
# ---------------------------------------------------------------------------

table ast_extra11.helper_node_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: hqname

  columns: [id, function, args, expected]
  rows:
    - [arg,      arg.__qualname__.__eq__,      ["arg"],      true]
    - [arguments, arguments.__qualname__.__eq__, ["arguments"], true]
    - [keyword,  keyword.__qualname__.__eq__,  ["keyword"],  true]
    - [alias,    alias.__qualname__.__eq__,    ["alias"],    true]
    - [withitem, withitem.__qualname__.__eq__, ["withitem"], true]

# ---------------------------------------------------------------------------
# Access/async expression node __qualname__ checks
# ast_extra10 covers Subscript/Attribute/Starred __name__.
# ast_extra10 covers Yield/YieldFrom/Await __name__.
# No prior ast spec checks __qualname__ for these nodes.
# ---------------------------------------------------------------------------

invariant ast_extra11.Subscript.qualname:
  description: "ast.Subscript.__qualname__ == 'Subscript' — subscript access expression node"
  category: class_qualnames
  kind: python_call_eq
  function: Subscript.__qualname__.__eq__
  args: ["Subscript"]
  expected: true

invariant ast_extra11.Attribute.qualname:
  description: "ast.Attribute.__qualname__ == 'Attribute' — attribute access expression node"
  category: class_qualnames
  kind: python_call_eq
  function: Attribute.__qualname__.__eq__
  args: ["Attribute"]
  expected: true

invariant ast_extra11.Starred.qualname:
  description: "ast.Starred.__qualname__ == 'Starred' — starred expression node"
  category: class_qualnames
  kind: python_call_eq
  function: Starred.__qualname__.__eq__
  args: ["Starred"]
  expected: true

invariant ast_extra11.Yield.qualname:
  description: "ast.Yield.__qualname__ == 'Yield' — yield expression node"
  category: class_qualnames
  kind: python_call_eq
  function: Yield.__qualname__.__eq__
  args: ["Yield"]
  expected: true

invariant ast_extra11.Global.qualname:
  description: "ast.Global.__qualname__ == 'Global' — global statement node"
  category: class_qualnames
  kind: python_call_eq
  function: Global.__qualname__.__eq__
  args: ["Global"]
  expected: true

invariant ast_extra11.Nonlocal.qualname:
  description: "ast.Nonlocal.__qualname__ == 'Nonlocal' — nonlocal statement node"
  category: class_qualnames
  kind: python_call_eq
  function: Nonlocal.__qualname__.__eq__
  args: ["Nonlocal"]
  expected: true

# ---------------------------------------------------------------------------
# Additional helper node __module__ checks
# ast_extra10 covers arg.__module__ and alias.__module__.
# withitem and keyword __module__ have not been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant ast_extra11.withitem.module:
  description: "ast.withitem.__module__ == 'ast' — withitem helper node is defined in the ast module"
  category: module_attrs
  kind: python_call_eq
  function: withitem.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra11.keyword.module:
  description: "ast.keyword.__module__ == 'ast' — keyword helper node is defined in the ast module"
  category: module_attrs
  kind: python_call_eq
  function: keyword.__module__.__eq__
  args: ["ast"]
  expected: true
