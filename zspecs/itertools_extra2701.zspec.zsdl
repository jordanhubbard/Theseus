spec: itertools_extra2701
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/itertools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 627 theme: __lshift__, __rshift__, and __invert__ dict-presence checks (bit-shift left/right and bitwise NOT)."
    - "All itertools iterator classes (chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations, combinations_with_replacement) are lazy iterators."
    - "Lazy iterators do not support bit-shift or bitwise NOT protocols such as __lshift__, __rshift__, or __invert__."
    - "itertools.repeat does have a __len__ for finite repeats, but still defines none of __lshift__, __rshift__, __invert__."
    - "None of the itertools classes define __lshift__, __rshift__, or __invert__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — absent from all itertools classes
# ---------------------------------------------------------------------------

table itertools_extra2701.lshift_protocol:
  description: "__lshift__ is absent from all itertools iterator class __dict__s — lazy iterators do not support bit-shift left"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2701

  columns: [id, function, args, expected]
  rows:
    - ["it2701001", "itertools.chain.__dict__.__contains__",                         ["__lshift__"], false]
    - ["it2701002", "itertools.count.__dict__.__contains__",                         ["__lshift__"], false]
    - ["it2701003", "itertools.repeat.__dict__.__contains__",                        ["__lshift__"], false]
    - ["it2701004", "itertools.cycle.__dict__.__contains__",                         ["__lshift__"], false]
    - ["it2701005", "itertools.islice.__dict__.__contains__",                        ["__lshift__"], false]
    - ["it2701006", "itertools.compress.__dict__.__contains__",                      ["__lshift__"], false]
    - ["it2701007", "itertools.dropwhile.__dict__.__contains__",                     ["__lshift__"], false]
    - ["it2701008", "itertools.takewhile.__dict__.__contains__",                     ["__lshift__"], false]
    - ["it2701009", "itertools.starmap.__dict__.__contains__",                       ["__lshift__"], false]
    - ["it2701010", "itertools.groupby.__dict__.__contains__",                       ["__lshift__"], false]
    - ["it2701011", "itertools.filterfalse.__dict__.__contains__",                   ["__lshift__"], false]
    - ["it2701012", "itertools.accumulate.__dict__.__contains__",                    ["__lshift__"], false]
    - ["it2701013", "itertools.zip_longest.__dict__.__contains__",                   ["__lshift__"], false]
    - ["it2701014", "itertools.pairwise.__dict__.__contains__",                      ["__lshift__"], false]
    - ["it2701015", "itertools.product.__dict__.__contains__",                       ["__lshift__"], false]
    - ["it2701016", "itertools.permutations.__dict__.__contains__",                  ["__lshift__"], false]
    - ["it2701017", "itertools.combinations.__dict__.__contains__",                  ["__lshift__"], false]
    - ["it2701018", "itertools.combinations_with_replacement.__dict__.__contains__",  ["__lshift__"], false]

