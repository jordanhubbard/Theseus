spec: abc_extra1396
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Abstract Base Classes"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method presence and type checks."
    - "abc.ABCMeta does NOT have __class_getitem__ in any of its MRO classes' __dict__ (ABCMeta, type, object do not define it)."
    - "abc.ABC does NOT have __class_getitem__ in its own __dict__ or MRO (no __class_getitem__ anywhere in ABC's MRO)."
    - "abc.ABCMeta and abc.ABC both have __init_subclass__ inherited from object — type is 'builtin_function_or_method', not in own __dict__."
    - "abc.abstractclassmethod (deprecated) inherits __class_getitem__ from classmethod — type is 'builtin_function_or_method', NOT in own __dict__."
    - "abc.abstractstaticmethod (deprecated) inherits __class_getitem__ from staticmethod — type is 'builtin_function_or_method', NOT in own __dict__."
    - "abc.abstractproperty (deprecated) does NOT have __class_getitem__ (property does not provide it)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1396.abcmeta_abc_class_getitem_absent:
  description: "abc.ABCMeta and abc.ABC do NOT have __class_getitem__ in their own __dict__; __init_subclass__ also absent from own __dict__"
  kind: python_call_eq
  category: class_getitem_dict_absent
  id_prefix: ab1396aa
  columns: [id, function, args, expected]
  rows:
    - [ab1396aa001, abc.ABCMeta.__dict__.__contains__, ["__class_getitem__"],  false]
    - [ab1396aa002, abc.ABCMeta.__dict__.__contains__, ["__init_subclass__"],  false]
    - [ab1396aa003, abc.ABC.__dict__.__contains__,     ["__class_getitem__"],  false]
    - [ab1396aa004, abc.ABC.__dict__.__contains__,     ["__init_subclass__"],  false]
    - [ab1396aa005, abc.ABCMeta.__name__.__eq__,        ["ABCMeta"],            true]
    - [ab1396aa006, abc.ABC.__class__.__name__.__eq__,  ["ABCMeta"],            true]

table abc_extra1396.init_subclass_type_checks:
  description: "abc.ABCMeta and abc.ABC have __init_subclass__ inherited from object as builtin_function_or_method"
  kind: python_call_eq
  category: init_subclass_check
  id_prefix: ab1396is
  columns: [id, function, args, expected]
  rows:
    - [ab1396is001, abc.ABCMeta.__init_subclass__.__class__.__name__.__eq__,                ["builtin_function_or_method"], true]
    - [ab1396is002, abc.ABC.__init_subclass__.__class__.__name__.__eq__,                    ["builtin_function_or_method"], true]
    - [ab1396is003, abc.abstractclassmethod.__init_subclass__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [ab1396is004, abc.abstractstaticmethod.__init_subclass__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [ab1396is005, abc.abstractclassmethod.__dict__.__contains__,                          ["__init_subclass__"],           false]
    - [ab1396is006, abc.abstractstaticmethod.__dict__.__contains__,                         ["__init_subclass__"],           false]

table abc_extra1396.deprecated_decorators_class_getitem_inheritance:
  description: "abc deprecated decorators abstractclassmethod and abstractstaticmethod inherit __class_getitem__ from classmethod/staticmethod; abstractproperty does not"
  kind: python_call_eq
  category: class_getitem_inheritance
  id_prefix: ab1396dd
  columns: [id, function, args, expected]
  rows:
    - [ab1396dd001, abc.abstractclassmethod.__class_getitem__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [ab1396dd002, abc.abstractclassmethod.__dict__.__contains__,                         ["__class_getitem__"],           false]
    - [ab1396dd003, abc.abstractstaticmethod.__class_getitem__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [ab1396dd004, abc.abstractstaticmethod.__dict__.__contains__,                        ["__class_getitem__"],           false]
    - [ab1396dd005, abc.abstractproperty.__dict__.__contains__,                            ["__class_getitem__"],           false]
    - [ab1396dd006, abc.abstractclassmethod.__dict__.__contains__,                         ["__class_getitem__"],           false]
