spec: decimal_extra1201
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal class __bases__.__len__ checks for Decimal, Context, DecimalException, Overflow, Underflow, InvalidOperation; __mro__.__len__ checks for Decimal, Context, DecimalException, Overflow"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.Decimal.__bases__.__len__, decimal.Context.__bases__.__len__, decimal.DecimalException.__bases__.__len__, decimal.Overflow.__bases__.__len__, decimal.Underflow.__bases__.__len__, decimal.InvalidOperation.__bases__.__len__; decimal.Decimal.__mro__.__len__, decimal.Context.__mro__.__len__, decimal.DecimalException.__mro__.__len__, decimal.Overflow.__mro__.__len__; _extra1186 covered __bases__.__class__.__name__ (tuple) but not __bases__.__len__ integer values; _extra1171 covered __all__/MAX_PREC/MAX_EMAX but not MRO depths"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra1201.bases_len_top_level_classes:
  description: "decimal top-level class __bases__.__len__ checks — Decimal and Context each inherit from object (1); DecimalException from ArithmeticError (1)"
  kind: python_call_eq
  category: bases_len_top_level_classes
  id_prefix: dc1201tl
  columns: [id, function, args, expected]
  rows:
    - [dc1201tl001, decimal.Decimal.__bases__.__len__,          [], 1]
    - [dc1201tl002, decimal.Context.__bases__.__len__,          [], 1]
    - [dc1201tl003, decimal.DecimalException.__bases__.__len__, [], 1]
    - [dc1201tl004, decimal.InvalidOperation.__bases__.__len__, [], 1]
    - [dc1201tl005, decimal.Decimal.__bases__.__len__.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [dc1201tl006, decimal.Context.__bases__.__len__.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [dc1201tl007, decimal.DecimalException.__bases__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [dc1201tl008, decimal.Decimal.__bases__.__len__.__class__.__name__.__eq__,          ["function"], false]

