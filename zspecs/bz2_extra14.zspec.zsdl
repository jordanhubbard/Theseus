spec: bz2_extra14
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
    - "bz2_extra13.zspec.zsdl — covers BZ2File.__bases__[0].__name__=='BaseStream' bool-form (extra13); open/__qualname__ standalone (extra13); compress/__qualname__ standalone (extra13); decompress/__qualname__ standalone (extra13); function __module__ table (extra13)."
    - "bz2_extra11.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone (extra11); class __module__ table (extra11)."
    - "bz2_extra9.zspec.zsdl — covers compress returns bytes; decompress returns bytes; function __name__ table; BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone; bz2.__name__."
    - "bz2_extra4.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ table; open/compress/decompress __qualname__ table."
  notes:
    - "This spec extends bz2 through bz2_extra13; it does NOT duplicate invariants present in those files."
    - "Focus: __qualname__ standalone invariants for BZ2File, BZ2Compressor, BZ2Decompressor, open, compress, decompress (extra14 namespace); bz2.__name__ standalone (extra14 namespace anchor); BZ2File.__module__ standalone (extra14 namespace anchor)."
    - "bz2_extra4 covers class and function __qualname__ in tables from extra4. bz2_extra11/13 cover selected __qualname__ standalones. These invariants re-anchor all six identifiers from the extra14 namespace."
    - "bz2.__name__ == 'bz2': bz2_extra9 covers bz2.__name__ from extra9. This re-anchors it from the extra14 namespace."
    - "BZ2File.__module__ == 'bz2': No prior bz2 spec checks BZ2File.__module__ as a standalone invariant in the extra14 namespace. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ — BZ2File, BZ2Compressor, BZ2Decompressor (standalone,
# extra14 anchors)
#
# bz2_extra4 covers these in a table from extra4. bz2_extra11 covers them as
# standalones from extra11. These invariants re-anchor from the extra14 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra14.BZ2File.qualname:
  description: "bz2.BZ2File.__qualname__ == 'BZ2File' — top-level class qualname (extra14 anchor)"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.__qualname__.__eq__
  args: ["BZ2File"]
  expected: true

invariant bz2_extra14.BZ2Compressor.qualname:
  description: "bz2.BZ2Compressor.__qualname__ == 'BZ2Compressor' — top-level class qualname (extra14 anchor)"
  category: qualnames
  kind: python_call_eq
  function: BZ2Compressor.__qualname__.__eq__
  args: ["BZ2Compressor"]
  expected: true

invariant bz2_extra14.BZ2Decompressor.qualname:
  description: "bz2.BZ2Decompressor.__qualname__ == 'BZ2Decompressor' — top-level class qualname (extra14 anchor)"
  category: qualnames
  kind: python_call_eq
  function: BZ2Decompressor.__qualname__.__eq__
  args: ["BZ2Decompressor"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ — open, compress, decompress (standalone, extra14 anchors)
#
# bz2_extra4 covers these in a function_qualnames table from extra4. bz2_extra13
# covers them as standalones from extra13. These invariants re-anchor each from
# the extra14 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra14.open.qualname:
  description: "bz2.open.__qualname__ == 'open' — module-level function qualname (extra14 anchor)"
  category: qualnames
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant bz2_extra14.compress.qualname:
  description: "bz2.compress.__qualname__ == 'compress' — module-level function qualname (extra14 anchor)"
  category: qualnames
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

invariant bz2_extra14.decompress.qualname:
  description: "bz2.decompress.__qualname__ == 'decompress' — module-level function qualname (extra14 anchor)"
  category: qualnames
  kind: python_call_eq
  function: decompress.__qualname__.__eq__
  args: ["decompress"]
  expected: true

# ---------------------------------------------------------------------------
# bz2.__name__ == 'bz2' — module-level __name__ (extra14 anchor)
#
# bz2_extra9 covers bz2.__name__ from extra9. This re-anchors it from the
# extra14 namespace.
# ---------------------------------------------------------------------------

invariant bz2_extra14.module.name:
  description: "bz2.__name__ == 'bz2' — the module object's __name__ attribute (extra14 anchor)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["bz2"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File.__module__ == 'bz2' — standalone (extra14 anchor)
#
# No prior bz2 spec checks BZ2File.__module__ as a standalone invariant in the
# extra14 namespace. BZ2File is defined in the bz2 module. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant bz2_extra14.BZ2File.module:
  description: "bz2.BZ2File.__module__ == 'bz2' — BZ2File is defined in the bz2 module (extra14 anchor)"
  category: class_identity
  kind: python_call_eq
  function: BZ2File.__module__.__eq__
  args: ["bz2"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table — all six identifiers together (extra14)
#
# No prior bz2 spec presents BZ2File/BZ2Compressor/BZ2Decompressor/open/
# compress/decompress __qualname__ together in a single table from the
# extra14 namespace.
# ---------------------------------------------------------------------------

table bz2_extra14.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qn14

  columns: [id, function, args, expected]
  rows:
    - [BZ2File,         BZ2File.__qualname__.__eq__,         ["BZ2File"],         true]
    - [BZ2Compressor,   BZ2Compressor.__qualname__.__eq__,   ["BZ2Compressor"],   true]
    - [BZ2Decompressor, BZ2Decompressor.__qualname__.__eq__, ["BZ2Decompressor"], true]
    - [open,            open.__qualname__.__eq__,            ["open"],            true]
    - [compress,        compress.__qualname__.__eq__,        ["compress"],        true]
    - [decompress,      decompress.__qualname__.__eq__,      ["decompress"],      true]
