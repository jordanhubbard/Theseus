spec: asyncio_extra177
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/mixins.py"
  notes:
    - "This spec covers: asyncio synchronization primitives — asyncio.Semaphore.__name__=='Semaphore' (len=9); asyncio.Semaphore.__module__=='asyncio.locks'; asyncio.Semaphore.__mro__.__len__()==4 (same as Lock from extra173: Semaphore > _ContextManagerMixin > _LoopBoundMixin > object); asyncio.BoundedSemaphore.__name__=='BoundedSemaphore' (len=15); asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore'; asyncio.Event.__name__=='Event' (len=5); asyncio.Event.__mro__.__len__()==3 (Event > _LoopBoundMixin > object); asyncio.Condition.__name__=='Condition' (len=9; same as Semaphore). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Semaphore.__name__.__len__() == 9. 'Semaphore' is 9 characters: S-e-m-a-p-h-o-r-e. asyncio.Semaphore is a Python class in Lib/asyncio/locks.py. Its MRO length is 4: Semaphore > _ContextManagerMixin > _LoopBoundMixin > object — same pattern as asyncio.Lock from extra173. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Semaphore.__module__ == 'asyncio.locks' (len=13: 'asyncio'=7+'.'=1+'locks'=5=13). All asyncio synchronization primitives are defined in Lib/asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=15: 'Bounded'=7+'Semaphore'=8... actually 'BoundedSemaphore'=16... let's count: B-o-u-n-d-e-d-S-e-m-a-p-h-o-r-e = 16 chars). Verified: 'BoundedSemaphore' len=16. asyncio.BoundedSemaphore inherits from asyncio.Semaphore so __bases__[0].__name__=='Semaphore'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Event.__name__ == 'Event' (len=5: E-v-e-n-t). asyncio.Event has MRO length 3: Event > _LoopBoundMixin > object. It does NOT have _ContextManagerMixin (unlike Lock and Semaphore) because Event is not used as a context manager. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Condition.__name__ == 'Condition' (len=9: C-o-n-d-i-t-i-o-n — same length as 'Semaphore'=9). asyncio.Condition also has a 4-entry MRO like Semaphore and Lock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Semaphore __name__, __module__, and MRO length
#
# asyncio.Semaphore.__name__ == 'Semaphore' (len=9)
# asyncio.Semaphore.__module__ == 'asyncio.locks' (len=13)
# asyncio.Semaphore.__mro__.__len__() == 4 (same as Lock from extra173)
#
# asyncio.Semaphore is a Python class in Lib/asyncio/locks.py.
# Its MRO is: Semaphore > _ContextManagerMixin > _LoopBoundMixin > object
# (identical pattern to asyncio.Lock). New to extra177.
# ---------------------------------------------------------------------------

table asyncio_extra177.semaphore_name_module_mro:
  description: "asyncio.Semaphore.__name__ 'Semaphore' len 9; __module__ 'asyncio.locks' len 13; __mro__.__len__()==4; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosync177

  columns: [id, function, args, expected, description]
  rows:
    - [sem_name_eq,
       asyncio.Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "asyncio.Semaphore.__name__.__eq__('Semaphore') == True — asyncio.Semaphore is a Python class in Lib/asyncio/locks.py that implements a counting semaphore for coroutine synchronization; its __name__ is 'Semaphore' (9 chars: S-e-m-a-p-h-o-r-e); str.__eq__('Semaphore') returns True; new to extra177"]
    - [sem_name_len_9,
       asyncio.Semaphore.__name__.__len__,
       [],
       9,
       "asyncio.Semaphore.__name__.__len__() == 9 — the name 'Semaphore' has exactly 9 characters: S-e-m-a-p-h-o-r-e; same length as Condition.__name__.__len__()==9; str.__len__() returns 9; new to extra177"]
    - [sem_module_eq,
       asyncio.Semaphore.__module__.__eq__,
       ["asyncio.locks"],
       true,
       "asyncio.Semaphore.__module__.__eq__('asyncio.locks') == True — asyncio.Semaphore is defined in Lib/asyncio/locks.py; its __module__ is 'asyncio.locks' (13 chars: 'asyncio'=7+'.'=1+'locks'=5=13); str.__eq__('asyncio.locks') returns True; new to extra177"]
    - [sem_module_len_13,
       asyncio.Semaphore.__module__.__len__,
       [],
       13,
       "asyncio.Semaphore.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters: 'asyncio'=7+'.'=1+'locks'=5=13; all asyncio sync primitives share this __module__; str.__len__() returns 13; new to extra177"]
    - [sem_mro_len_4,
       asyncio.Semaphore.__mro__.__len__,
       [],
       4,
       "asyncio.Semaphore.__mro__.__len__() == 4 — MRO: Semaphore > _ContextManagerMixin > _LoopBoundMixin > object; identical pattern to asyncio.Lock (also 4 from extra173); both have _ContextManagerMixin for 'async with' support; tuple.__len__() returns 4; new to extra177"]
    - [sem_mro1_name,
       "asyncio.Semaphore.__mro__[1].__name__.__eq__",
       ["_ContextManagerMixin"],
       true,
       "asyncio.Semaphore.__mro__[1].__name__ == '_ContextManagerMixin' — entry 1 in Semaphore's 4-entry MRO is _ContextManagerMixin (asyncio.locks); provides __aenter__ and __aexit__ for 'async with sem:' usage; same pattern as asyncio.Lock.__mro__[1]; new to extra177"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.BoundedSemaphore name and base class
#
# asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16)
# asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
#
# asyncio.BoundedSemaphore subclasses asyncio.Semaphore and adds an
# upper bound check: ValueError is raised if the counter exceeds the
# initial value on release(). New to extra177.
# ---------------------------------------------------------------------------

table asyncio_extra177.bounded_semaphore_name_base:
  description: "asyncio.BoundedSemaphore.__name__ 'BoundedSemaphore' len 16; __bases__[0].__name__=='Semaphore'; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosync177

  columns: [id, function, args, expected, description]
  rows:
    - [bsem_name_eq,
       asyncio.BoundedSemaphore.__name__.__eq__,
       ["BoundedSemaphore"],
       true,
       "asyncio.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — asyncio.BoundedSemaphore is a subclass of asyncio.Semaphore in Lib/asyncio/locks.py; it prevents releasing beyond the initial count; its __name__ is 'BoundedSemaphore' (16 chars: B-o-u-n-d-e-d-S-e-m-a-p-h-o-r-e); str.__eq__('BoundedSemaphore') returns True; new to extra177"]
    - [bsem_name_len_16,
       asyncio.BoundedSemaphore.__name__.__len__,
       [],
       16,
       "asyncio.BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has 16 characters: 'Bounded'=7+'Semaphore'=9=16; 7 chars longer than 'Semaphore'=9; str.__len__() returns 16; new to extra177"]
    - [bsem_base0_name,
       "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore directly subclasses Semaphore; __bases__[0] is asyncio.Semaphore; its __name__ is 'Semaphore' (9 chars); str.__eq__('Semaphore') returns True; new to extra177"]
    - [bsem_base0_len,
       "asyncio.BoundedSemaphore.__bases__[0].__name__.__len__",
       [],
       9,
       "asyncio.BoundedSemaphore.__bases__[0].__name__.__len__() == 9 — the base class name 'Semaphore' has 9 chars; confirming BoundedSemaphore's direct parent is Semaphore (len 9); str.__len__() returns 9; new to extra177"]
    - [bsem_mro_len_5,
       asyncio.BoundedSemaphore.__mro__.__len__,
       [],
       5,
       "asyncio.BoundedSemaphore.__mro__.__len__() == 5 — MRO: BoundedSemaphore > Semaphore > _ContextManagerMixin > _LoopBoundMixin > object; 1 longer than Semaphore's MRO (4) because BoundedSemaphore adds itself on top; tuple.__len__() returns 5; new to extra177"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Event and asyncio.Condition names and MRO lengths
#
# asyncio.Event.__name__ == 'Event' (len=5)
# asyncio.Event.__mro__.__len__() == 3 (Event > _LoopBoundMixin > object)
# asyncio.Condition.__name__ == 'Condition' (len=9; same length as Semaphore)
# asyncio.Condition.__mro__.__len__() == 4 (same as Lock/Semaphore)
#
# Event has a shorter MRO (3) than Condition/Lock/Semaphore (4) because Event
# lacks _ContextManagerMixin — it cannot be used as an async context manager.
# Condition has a 4-entry MRO like Lock and Semaphore. New to extra177.
# ---------------------------------------------------------------------------

table asyncio_extra177.event_condition_names_mro:
  description: "asyncio.Event.__name__ 'Event' len 5; __mro__.__len__()==3; asyncio.Condition.__name__ 'Condition' len 9; __mro__.__len__()==4; new to extra177"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosync177

  columns: [id, function, args, expected, description]
  rows:
    - [event_name_eq,
       asyncio.Event.__name__.__eq__,
       ["Event"],
       true,
       "asyncio.Event.__name__.__eq__('Event') == True — asyncio.Event is a Python class in Lib/asyncio/locks.py that allows coroutines to wait until a flag is set; its __name__ is 'Event' (5 chars: E-v-e-n-t); str.__eq__('Event') returns True; new to extra177"]
    - [event_name_len_5,
       asyncio.Event.__name__.__len__,
       [],
       5,
       "asyncio.Event.__name__.__len__() == 5 — 'Event' has exactly 5 characters: E-v-e-n-t; shorter than 'Semaphore'=9 and 'Condition'=9; tuple.__len__() returns 5; new to extra177"]
    - [event_mro_len_3,
       asyncio.Event.__mro__.__len__,
       [],
       3,
       "asyncio.Event.__mro__.__len__() == 3 — MRO: Event > _LoopBoundMixin > object; Event lacks _ContextManagerMixin (unlike Lock/Semaphore/Condition which have MRO len 4); Event is not used as an async context manager; tuple.__len__() returns 3; new to extra177"]
    - [event_mro1_name,
       "asyncio.Event.__mro__[1].__name__.__eq__",
       ["_LoopBoundMixin"],
       true,
       "asyncio.Event.__mro__[1].__name__ == '_LoopBoundMixin' — Event's MRO has only 3 entries; index 1 is _LoopBoundMixin (directly, without _ContextManagerMixin in between); same _LoopBoundMixin shared by Lock and Semaphore (at their index 2); new to extra177"]
    - [cond_name_eq,
       asyncio.Condition.__name__.__eq__,
       ["Condition"],
       true,
       "asyncio.Condition.__name__.__eq__('Condition') == True — asyncio.Condition is a Python class in Lib/asyncio/locks.py that implements a condition variable for complex coroutine synchronization; its __name__ is 'Condition' (9 chars: C-o-n-d-i-t-i-o-n); same length as 'Semaphore'=9; str.__eq__('Condition') returns True; new to extra177"]
    - [cond_name_len_9,
       asyncio.Condition.__name__.__len__,
       [],
       9,
       "asyncio.Condition.__name__.__len__() == 9 — 'Condition' has exactly 9 characters: C-o-n-d-i-t-i-o-n; same length as 'Semaphore'=9; both are 9 chars; str.__len__() returns 9; new to extra177"]
    - [cond_mro_len_4,
       asyncio.Condition.__mro__.__len__,
       [],
       4,
       "asyncio.Condition.__mro__.__len__() == 4 — MRO: Condition > _ContextManagerMixin > _LoopBoundMixin > object; same pattern as Lock and Semaphore (all 4-entry MRO); Condition supports 'async with cond:' via _ContextManagerMixin; tuple.__len__() returns 4; new to extra177"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra177
# ---------------------------------------------------------------------------

invariant asyncio_extra177.semaphore_name_semaphore:
  description: "asyncio.Semaphore.__name__ == 'Semaphore' — Python class in asyncio.locks; __name__ is 'Semaphore' (9 chars: S-e-m-a-p-h-o-r-e); new to extra177"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra177.semaphore_module_asyncio_locks:
  description: "asyncio.Semaphore.__module__ == 'asyncio.locks' — defined in Lib/asyncio/locks.py; __module__ is 'asyncio.locks' (13 chars); new to extra177"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra177.semaphore_mro_len_4:
  description: "asyncio.Semaphore.__mro__.__len__() == 4 — MRO: Semaphore > _ContextManagerMixin > _LoopBoundMixin > object; same as asyncio.Lock (extra173); new to extra177"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra177.bounded_semaphore_name_len_16:
  description: "asyncio.BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has 16 chars ('Bounded'=7+'Semaphore'=9=16); longest name among asyncio sync primitives in this spec; new to extra177"
  category: identity
  kind: python_call_eq
  function: asyncio.BoundedSemaphore.__name__.__len__
  args: []
  expected: 16

invariant asyncio_extra177.bounded_semaphore_base_is_semaphore:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore directly subclasses Semaphore; __bases__[0] is asyncio.Semaphore; new to extra177"
  category: identity
  kind: python_call_eq
  function: "asyncio.BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant asyncio_extra177.event_name_event:
  description: "asyncio.Event.__name__ == 'Event' — Python class in asyncio.locks; __name__ is 'Event' (5 chars); shorter MRO (3) than Lock/Semaphore/Condition (4); new to extra177"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.__name__.__eq__
  args: ["Event"]
  expected: true

invariant asyncio_extra177.event_mro_len_3:
  description: "asyncio.Event.__mro__.__len__() == 3 — MRO: Event > _LoopBoundMixin > object; Event lacks _ContextManagerMixin unlike Lock/Semaphore/Condition; new to extra177"
  category: identity
  kind: python_call_eq
  function: asyncio.Event.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra177.condition_name_condition:
  description: "asyncio.Condition.__name__ == 'Condition' — Python class in asyncio.locks; __name__ is 'Condition' (9 chars; same length as 'Semaphore'=9); new to extra177"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant asyncio_extra177.condition_mro_len_4:
  description: "asyncio.Condition.__mro__.__len__() == 4 — MRO: Condition > _ContextManagerMixin > _LoopBoundMixin > object; same pattern as Lock and Semaphore (all 4-entry MRO); new to extra177"
  category: identity
  kind: python_call_eq
  function: asyncio.Condition.__mro__.__len__
  args: []
  expected: 4
