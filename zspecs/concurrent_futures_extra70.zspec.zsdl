spec: concurrent_futures_extra70
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra69.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, exception identity and bases, submit/map/shutdown __qualname__, class __dict__/__mro__/__all__ metadata, method qualname/name equality and length tables, __loader__/__spec__/__file__/__cached__ class names, __spec__ attributes, code object attribute chains, __defaults__/__kwdefaults__ class names, doc content, ThreadPoolExecutor/Future __init__ code object attributes, ThreadPoolExecutor MRO entry names, exception __name__/__module__/__qualname__, Future.result/cancel code objects."
    - "This spec covers (cfmore70 namespace): wave 239 theme — concurrent.futures Executor method code attributes + as_completed/wait. NEW in extra70: Executor.map.__code__.co_name=='map'; Executor.map.__code__.co_argcount==2 (self + fn; *iterables is var-positional, not counted); Executor.submit.__code__.co_name=='submit'; Executor.submit.__code__.co_argcount==2 (self + fn; *args/**kwargs are var-positional/keyword); as_completed.__code__.co_name=='as_completed'; as_completed.__code__.co_argcount==2 (fs + timeout are both positional-or-keyword in Python 3.14); wait.__code__.co_name=='wait'; wait.__code__.co_argcount==3 (fs + timeout + return_when); ThreadPoolExecutor.__init__.__code__.co_varnames.__len__()==6."
    - "concurrent.futures.Executor.map.__code__.co_name == 'map'. Executor.map is a Python method in concurrent/futures/_base.py; its code object's co_name is 'map'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.map.__code__.co_argcount == 2. Executor.map signature is def map(self, fn, *iterables, timeout=None, chunksize=1): — co_argcount counts only positional-or-keyword parameters (self + fn = 2); *iterables is var-positional. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.submit.__code__.co_name == 'submit'. Executor.submit is a Python method (raises NotImplementedError but has __code__); co_name is 'submit'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.submit.__code__.co_argcount == 2. Executor.submit signature is def submit(self, fn, /, *args, **kwargs): — co_argcount is 2 (self + fn). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__code__.co_name == 'as_completed'. as_completed is a Python function in concurrent/futures/_base.py; co_name is 'as_completed'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__code__.co_argcount == 2. as_completed(fs, timeout=None) — both fs and timeout are positional-or-keyword in Python 3.14; co_argcount is 2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__code__.co_name == 'wait'. wait is a Python function in concurrent/futures/_base.py; co_name is 'wait'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__code__.co_argcount == 3. wait(fs, timeout=None, return_when=ALL_COMPLETED) — all three parameters are positional-or-keyword; co_argcount is 3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__len__() == 6. ThreadPoolExecutor.__init__ co_varnames are (self, max_workers, thread_name_prefix, initializer, initargs, ctxkwargs); length is 6. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Executor.map code object checks — extra70
#
# Wave 239 theme: Executor method code attributes + as_completed/wait.
#
# Executor.map.__code__.co_name == 'map'
# Executor.map.__code__.co_argcount == 2 (self + fn; *iterables is var-positional)
# ---------------------------------------------------------------------------

table concurrent_futures_extra70.Executor_map_code:
  description: "concurrent.futures Executor.map code object attribute checks in cfmore70 namespace — wave 239 theme: Executor method code attributes; Executor.map.__code__.co_name=='map'; Executor.map.__code__.co_argcount==2 (self + fn only; *iterables is var-positional, not counted in co_argcount); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore70

  columns: [id, function, args, expected, description]
  rows:
    - [executor_map_co_name,     Executor.map.__code__.co_name.__eq__,     ["map"], true, "Executor.map.__code__.co_name == 'map' — Python method in concurrent/futures/_base.py; verified with Python 3.14.3"]
    - [executor_map_co_argcount, Executor.map.__code__.co_argcount.__eq__, [2],     true, "Executor.map.__code__.co_argcount == 2 — self + fn only; *iterables is var-positional; verified with Python 3.14.3"]
    - [executor_submit_co_name,     Executor.submit.__code__.co_name.__eq__,     ["submit"], true, "Executor.submit.__code__.co_name == 'submit' — Python method raising NotImplementedError; co_name is 'submit'; verified with Python 3.14.3"]
    - [executor_submit_co_argcount, Executor.submit.__code__.co_argcount.__eq__, [2],        true, "Executor.submit.__code__.co_argcount == 2 — self + fn; *args/**kwargs are var-positional/keyword; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# as_completed code object checks — extra70
#
# as_completed.__code__.co_name == 'as_completed'
# as_completed.__code__.co_argcount == 2 (fs + timeout; both positional-or-keyword)
# ---------------------------------------------------------------------------

table concurrent_futures_extra70.as_completed_code:
  description: "concurrent.futures as_completed code object attribute checks in cfmore70 namespace — wave 239 theme: as_completed code attributes; as_completed.__code__.co_name=='as_completed'; as_completed.__code__.co_argcount==2 (fs and timeout are both positional-or-keyword in Python 3.14); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore70a

  columns: [id, function, args, expected, description]
  rows:
    - [as_completed_co_name,     as_completed.__code__.co_name.__eq__,     ["as_completed"], true, "as_completed.__code__.co_name == 'as_completed' — function in concurrent/futures/_base.py; verified with Python 3.14.3"]
    - [as_completed_co_argcount, as_completed.__code__.co_argcount.__eq__, [2],              true, "as_completed.__code__.co_argcount == 2 — fs and timeout are positional-or-keyword in Python 3.14; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# wait code object checks — extra70
#
# wait.__code__.co_name == 'wait'
# wait.__code__.co_argcount == 3 (fs + timeout + return_when)
# ---------------------------------------------------------------------------

table concurrent_futures_extra70.wait_code:
  description: "concurrent.futures wait code object attribute checks in cfmore70 namespace — wave 239 theme: wait code attributes; wait.__code__.co_name=='wait'; wait.__code__.co_argcount==3 (fs, timeout, return_when are all positional-or-keyword); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore70b

  columns: [id, function, args, expected, description]
  rows:
    - [wait_co_name,     wait.__code__.co_name.__eq__,     ["wait"], true, "wait.__code__.co_name == 'wait' — function in concurrent/futures/_base.py; verified with Python 3.14.3"]
    - [wait_co_argcount, wait.__code__.co_argcount.__eq__, [3],      true, "wait.__code__.co_argcount == 3 — fs, timeout, return_when are all positional-or-keyword; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ThreadPoolExecutor.__init__ co_varnames length — extra70
#
# ThreadPoolExecutor.__init__.__code__.co_varnames.__len__() == 6
# co_varnames: (self, max_workers, thread_name_prefix, initializer, initargs, ctxkwargs)
# ---------------------------------------------------------------------------

table concurrent_futures_extra70.ThreadPoolExecutor_init_varnames:
  description: "concurrent.futures ThreadPoolExecutor.__init__ co_varnames length checks in cfmore70 namespace — wave 239 theme: ThreadPoolExecutor.__init__ code object; co_varnames.__len__()==6 (self, max_workers, thread_name_prefix, initializer, initargs, ctxkwargs); co_name=='__init__'; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore70c

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_init_varnames_len, ThreadPoolExecutor.__init__.__code__.co_varnames.__len__, [], 6,          "ThreadPoolExecutor.__init__.__code__.co_varnames.__len__() == 6 — (self, max_workers, thread_name_prefix, initializer, initargs, ctxkwargs); verified with Python 3.14.3"]
    - [tpe_init_co_name,      ThreadPoolExecutor.__init__.__code__.co_name.__eq__,      ["__init__"], true, "ThreadPoolExecutor.__init__.__code__.co_name == '__init__'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra70
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra70.Executor_map_co_name:
  description: "concurrent.futures.Executor.map.__code__.co_name.__eq__('map') returns True — Executor.map is a Python method in concurrent/futures/_base.py; co_name is 'map'; NEW in extra70: first standalone co_name invariant for Executor.map in cfmore70 namespace; wave 239; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Executor.map.__code__.co_name.__eq__
  args: ["map"]
  expected: true

invariant concurrent_futures_extra70.Executor_map_co_argcount:
  description: "concurrent.futures.Executor.map.__code__.co_argcount.__eq__(2) returns True — self + fn only; *iterables is var-positional, not counted; co_argcount is 2; NEW in extra70: first standalone co_argcount invariant for Executor.map in cfmore70 namespace; wave 239; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Executor.map.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant concurrent_futures_extra70.as_completed_co_argcount:
  description: "concurrent.futures.as_completed.__code__.co_argcount.__eq__(2) returns True — fs and timeout are both positional-or-keyword in Python 3.14; co_argcount is 2; NEW in extra70: first standalone co_argcount invariant for as_completed in cfmore70 namespace; wave 239; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: as_completed.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant concurrent_futures_extra70.wait_co_name:
  description: "concurrent.futures.wait.__code__.co_name.__eq__('wait') returns True — wait is a Python function in concurrent/futures/_base.py; co_name is 'wait'; NEW in extra70: first standalone co_name invariant for wait in cfmore70 namespace; wave 239; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: wait.__code__.co_name.__eq__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra70.wait_co_argcount:
  description: "concurrent.futures.wait.__code__.co_argcount.__eq__(3) returns True — fs, timeout, return_when are all positional-or-keyword; co_argcount is 3; NEW in extra70: first standalone co_argcount invariant for wait in cfmore70 namespace; wave 239; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: wait.__code__.co_argcount.__eq__
  args: [3]
  expected: true
