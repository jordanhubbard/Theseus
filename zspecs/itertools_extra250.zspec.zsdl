spec: itertools_extra250
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.combinations, itertools.permutations, and itertools.combinations_with_replacement class identity and behavioral contracts."
    - "itertools.combinations.__class__.__name__ == 'type' — combinations is a C-level type (class); its __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools' — combinations is exposed in the itertools module namespace; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations.__name__ == 'combinations' — the type's __name__ is 'combinations'. Verified with Python 3.14.3."
    - "list(itertools.combinations([1,2,3], 2)) == [(1,2),(1,3),(2,3)] — 3 combinations of 2 from [1,2,3]. Verified with Python 3.14.3."
    - "itertools.permutations.__class__.__name__ == 'type' — permutations is a C-level type; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "itertools.permutations.__module__ == 'itertools' — permutations is exposed in the itertools module; __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.permutations.__name__ == 'permutations' — the type's __name__ is 'permutations'. Verified with Python 3.14.3."
    - "list(itertools.permutations([1,2], 2)) == [(1,2),(2,1)] — 2 permutations of 2 from [1,2]. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__name__ == 'combinations_with_replacement' — the type's __name__. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__class__.__name__ == 'type' — C-level type. Verified with Python 3.14.3."
    - "len(list(itertools.combinations([1,2,3], 2))) == 3 — C(3,2) = 3. Verified with Python 3.14.3."
    - "len(list(itertools.permutations([1,2,3], 2))) == 6 — P(3,2) = 6. Verified with Python 3.14.3."
    - "len(list(itertools.permutations([1,2,3], 3))) == 6 — P(3,3) = 6. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.combinations class identity
#
# itertools.combinations.__class__.__name__ == 'type'
# itertools.combinations.__module__ == 'itertools'
# itertools.combinations.__name__ == 'combinations'
#
# combinations is a C-level type. New to extra250.
# ---------------------------------------------------------------------------

table itertools_extra250.combinations_class_identity:
  description: "itertools.combinations class __name__, __module__, __class__.__name__ identity contracts; new to extra250"
  kind: python_call_eq
  category: identity
  id_prefix: comb250cls

  columns: [id, function, args, expected, description]
  rows:
    - [comb_name_eq,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations is a C-level iterator type; __name__ is 'combinations'; new to extra250"]
    - [comb_module_eq,
       combinations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is exposed in the itertools namespace; __module__ is 'itertools'; new to extra250"]
    - [comb_class_name_eq,
       combinations.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.combinations.__class__.__name__.__eq__('type') == True — combinations is a C-level type; __class__.__name__ is 'type'; new to extra250"]
    - [comb_name_len_12,
       combinations.__name__.__len__,
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — 'combinations' has 12 characters; new to extra250"]
    - [comb_module_len_9,
       combinations.__module__.__len__,
       [],
       9,
       "itertools.combinations.__module__.__len__() == 9 — 'itertools' has 9 characters; new to extra250"]

