spec: doctest_extra
version: ">=3.0"
backend: python_module(doctest)

docs: https://docs.python.org/3/library/doctest.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/doctest.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "doctest source: internal _doctest_output_checker implementation details"
  notes:
    - "This spec extends doctest.zspec.zsdl with additional identity invariants."
    - "DocTest, DocTestFinder, DocTestRunner, DocTestParser, Example — all live in 'doctest'."
    - "DocTestSuite and DocTestCase integrate doctest with the unittest framework."
    - "DocTestSuite.__name__ == 'DocTestSuite'; DocTestCase.__name__ == 'DocTestCase'."
    - "testmod, testfile, run_docstring_examples are the three primary public API functions."
    - "ELLIPSIS, NORMALIZE_WHITESPACE, IGNORE_EXCEPTION_DETAIL, FAIL_FAST are integer bitmasks."
    - "All expected values verified by running Python 3.12 doctest module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name and module identity
# ---------------------------------------------------------------------------

invariant doctest_extra.classes.DocTest_name:
  description: "doctest.DocTest.__name__ == 'DocTest'"
  category: classes
  kind: python_call_eq
  function: DocTest.__name__.__eq__
  args: ["DocTest"]
  expected: true

invariant doctest_extra.classes.DocTest_module:
  description: "doctest.DocTest.__module__ == 'doctest'"
  category: classes
  kind: python_call_eq
  function: DocTest.__module__.__eq__
  args: ["doctest"]
  expected: true

invariant doctest_extra.classes.DocTestFinder_name:
  description: "doctest.DocTestFinder.__name__ == 'DocTestFinder'"
  category: classes
  kind: python_call_eq
  function: DocTestFinder.__name__.__eq__
  args: ["DocTestFinder"]
  expected: true

invariant doctest_extra.classes.DocTestRunner_name:
  description: "doctest.DocTestRunner.__name__ == 'DocTestRunner'"
  category: classes
  kind: python_call_eq
  function: DocTestRunner.__name__.__eq__
  args: ["DocTestRunner"]
  expected: true

invariant doctest_extra.classes.DocTestSuite_name:
  description: "doctest.DocTestSuite.__name__ == 'DocTestSuite'"
  category: classes
  kind: python_call_eq
  function: DocTestSuite.__name__.__eq__
  args: ["DocTestSuite"]
  expected: true

invariant doctest_extra.classes.DocTestCase_name:
  description: "doctest.DocTestCase.__name__ == 'DocTestCase'"
  category: classes
  kind: python_call_eq
  function: DocTestCase.__name__.__eq__
  args: ["DocTestCase"]
  expected: true

invariant doctest_extra.classes.DocTestParser_name:
  description: "doctest.DocTestParser.__name__ == 'DocTestParser'"
  category: classes
  kind: python_call_eq
  function: DocTestParser.__name__.__eq__
  args: ["DocTestParser"]
  expected: true

invariant doctest_extra.classes.Example_name:
  description: "doctest.Example.__name__ == 'Example'"
  category: classes
  kind: python_call_eq
  function: Example.__name__.__eq__
  args: ["Example"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function name identity
# ---------------------------------------------------------------------------

invariant doctest_extra.functions.testmod_name:
  description: "doctest.testmod.__name__ == 'testmod'"
  category: functions
  kind: python_call_eq
  function: testmod.__name__.__eq__
  args: ["testmod"]
  expected: true

invariant doctest_extra.functions.testfile_name:
  description: "doctest.testfile.__name__ == 'testfile'"
  category: functions
  kind: python_call_eq
  function: testfile.__name__.__eq__
  args: ["testfile"]
  expected: true

invariant doctest_extra.functions.run_docstring_examples_name:
  description: "doctest.run_docstring_examples.__name__ == 'run_docstring_examples'"
  category: functions
  kind: python_call_eq
  function: run_docstring_examples.__name__.__eq__
  args: ["run_docstring_examples"]
  expected: true

# ---------------------------------------------------------------------------
# Option flag type checks — all are integer bitmasks
# ---------------------------------------------------------------------------

invariant doctest_extra.flags.ELLIPSIS_is_int:
  description: "doctest.ELLIPSIS.__class__.__name__ == 'int'"
  category: flags
  kind: python_call_eq
  function: ELLIPSIS.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant doctest_extra.flags.NORMALIZE_WHITESPACE_is_int:
  description: "doctest.NORMALIZE_WHITESPACE.__class__.__name__ == 'int'"
  category: flags
  kind: python_call_eq
  function: NORMALIZE_WHITESPACE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant doctest_extra.flags.IGNORE_EXCEPTION_DETAIL_is_int:
  description: "doctest.IGNORE_EXCEPTION_DETAIL.__class__.__name__ == 'int'"
  category: flags
  kind: python_call_eq
  function: IGNORE_EXCEPTION_DETAIL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant doctest_extra.flags.FAIL_FAST_is_int:
  description: "doctest.FAIL_FAST.__class__.__name__ == 'int'"
  category: flags
  kind: python_call_eq
  function: FAIL_FAST.__class__.__name__.__eq__
  args: ["int"]
  expected: true
