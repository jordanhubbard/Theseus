spec: functools_extra36
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra35.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key; __module__.__len__() for all major callables; __qualname__.__len__() for update_wrapper/partialmethod/singledispatchmethod/cache/total_ordering/singledispatch/cmp_to_key/cached_property/lru_cache; partial.__new__/__call__/__repr__/__reduce__ qualname lens; partialmethod.__get__ qualname len (21); cached_property.__get__ qualname len (23); partial/__mro__/partialmethod/__mro__/cached_property/__mro__ (all 2); partial.__setstate__ qualname len (20)."
    - "This spec covers: functools.__all__.__len__() (15) and .__class__.__name__.__len__() (4); partial.__dict__.__class__.__name__.__len__() (12) and partialmethod.__dict__.__class__.__name__.__len__() (12); singledispatchmethod.__dict__.__class__.__name__.__len__() (12) and cached_property.__dict__.__class__.__name__.__len__() (12); functools.reduce.__qualname__.__len__() (6) and .__module__.__len__() (10); WRAPPER_ASSIGNMENTS.__class__.__name__.__len__() (5) and .__len__() (6); WRAPPER_UPDATES.__class__.__name__.__len__() (5) and .__len__() (1); singledispatch.__qualname__.__len__() (14); singledispatchmethod.__mro__.__len__() (2)."
    - "Key findings: functools.__all__ has 15 entries (a list). WRAPPER_ASSIGNMENTS is a tuple of 6 items on Python 3.14 (includes __annotate__ and __type_params__ added in 3.12/3.13+, vs 5 items on older Python). WRAPPER_UPDATES is a tuple of 1 item. reduce.__module__ is '_functools' (len 10) — from the C extension, not the Python functools module. singledispatch is a plain function (not a class), but singledispatchmethod is a class."
    - "IMPORTANT: WRAPPER_ASSIGNMENTS.__len__() == 6 on Python 3.14 (not 5). Verified: ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() table — mappingproxy for functools classes
#
# functools.partial.__dict__.__class__.__name__ is 'mappingproxy' (12 chars).
# The same holds for functools.partialmethod, functools.singledispatchmethod,
# and functools.cached_property. All four key functools classes store their
# class namespace in a mappingproxy, consistent with CPython's standard behavior
# for all type objects. No prior functools spec records these four
# __dict__.__class__.__name__.__len__() values together in a combined table
# in the extra36 namespace.
# ---------------------------------------------------------------------------

table functools_extra36.class_dict_typename_lengths:
  description: "__dict__.__class__.__name__.__len__() for functools classes — all 12 ('mappingproxy')"
  kind: python_call_eq
  category: class_dict_types
  id_prefix: dict_type_len

  columns: [id, function, args, expected, description]
  rows:
    - [partial,
       partial.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(functools.partial.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [partialmethod,
       partialmethod.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(functools.partialmethod.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [singledispatchmethod,
       singledispatchmethod.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(functools.singledispatchmethod.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]
    - [cached_property,
       cached_property.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len(functools.cached_property.__dict__.__class__.__name__) == 12 — 'mappingproxy'"]

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES table — tuple metadata constants
#
# functools.WRAPPER_ASSIGNMENTS is a tuple (class name 'tuple', len 5).
# On Python 3.14 it has 6 items: ('__module__', '__name__', '__qualname__',
# '__doc__', '__annotate__', '__type_params__'). functools.WRAPPER_UPDATES is a
# tuple (class name 'tuple', len 5) with 1 item: ('__dict__',).
# No prior functools spec records these constant class name and length values
# together in a combined table in the extra36 namespace.
# ---------------------------------------------------------------------------

table functools_extra36.wrapper_constants_metadata:
  description: "WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES __class__.__name__.__len__() and __len__()"
  kind: python_call_eq
  category: module_constants
  id_prefix: const

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_ASSIGNMENTS_classname_len,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__len__,
       [],
       5,
       "len(functools.WRAPPER_ASSIGNMENTS.__class__.__name__) == 5 — 'tuple'"]
    - [WRAPPER_ASSIGNMENTS_len,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "len(functools.WRAPPER_ASSIGNMENTS) == 6 — 6 items on Python 3.14"]
    - [WRAPPER_UPDATES_classname_len,
       WRAPPER_UPDATES.__class__.__name__.__len__,
       [],
       5,
       "len(functools.WRAPPER_UPDATES.__class__.__name__) == 5 — 'tuple'"]
    - [WRAPPER_UPDATES_len,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "len(functools.WRAPPER_UPDATES) == 1 — ('__dict__',)"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — reduce, singledispatch, wraps, cache qualnames
#
# functools.reduce.__qualname__ is 'reduce' (6 chars) — reduce is a C-level
# function from _functools. functools.singledispatch.__qualname__ is
# 'singledispatch' (14 chars). functools.wraps.__qualname__ is 'wraps' (5 chars).
# functools.cache.__qualname__ is 'cache' (5 chars). No prior functools spec
# records these four __qualname__.__len__() values together in a combined table
# in the extra36 namespace.
# ---------------------------------------------------------------------------

table functools_extra36.function_qualname_lengths:
  description: "__qualname__.__len__() for functools module-level functions"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [reduce,
       reduce.__qualname__.__len__,
       [],
       6,
       "len(functools.reduce.__qualname__) == 6 — 'reduce'"]
    - [singledispatch,
       singledispatch.__qualname__.__len__,
       [],
       14,
       "len(functools.singledispatch.__qualname__) == 14 — 'singledispatch'"]
    - [wraps,
       wraps.__qualname__.__len__,
       [],
       5,
       "len(functools.wraps.__qualname__) == 5 — 'wraps'"]
    - [cache,
       cache.__qualname__.__len__,
       [],
       5,
       "len(functools.cache.__qualname__) == 5 — 'cache'"]

# ---------------------------------------------------------------------------
# functools.__all__.__len__() — standalone invariant
#
# functools.__all__ is a list of 15 public names on Python 3.14. This includes
# the newly added 'Placeholder'. No prior functools spec records
# functools.__all__.__len__() as a standalone in the extra36 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra36.all_len:
  description: "len(functools.__all__) == 15 — functools exports 15 public names on Python 3.14"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# functools.__all__.__class__.__name__.__len__() — standalone invariant
#
# functools.__all__.__class__.__name__ is 'list' (4 chars). Like inspect and
# operator, functools.__all__ is a plain Python list. No prior functools spec
# records __all__.__class__.__name__.__len__() as a standalone in the extra36
# namespace.
# ---------------------------------------------------------------------------

invariant functools_extra36.all_classname_len:
  description: "len(functools.__all__.__class__.__name__) == 4 — '__all__' is a 'list'"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# functools.reduce.__module__.__len__() — standalone invariant
#
# functools.reduce.__module__ is '_functools' (10 chars), not 'functools' (9).
# reduce is implemented in the C extension module _functools rather than in
# the Python functools.py file. This makes its __module__ length 10 (with
# leading underscore), different from all other functools callables whose
# __module__ is 'functools' (9 chars). No prior functools spec records
# reduce.__module__.__len__() as a standalone in the extra36 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra36.reduce_module_len:
  description: "len(functools.reduce.__module__) == 10 — '_functools' not 'functools'"
  category: module_metadata
  kind: python_call_eq
  function: reduce.__module__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# functools.singledispatchmethod.__mro__.__len__() — standalone invariant
#
# functools.singledispatchmethod.__mro__ has length 2: [singledispatchmethod,
# object]. singledispatchmethod is a direct subclass of object, like partial
# and partialmethod. Note that singledispatch (without 'method') is a plain
# function, not a class — it does not have __mro__. No prior functools spec
# records singledispatchmethod.__mro__.__len__() as a standalone in the extra36
# namespace.
# ---------------------------------------------------------------------------

invariant functools_extra36.singledispatchmethod_mro_len:
  description: "len(functools.singledispatchmethod.__mro__) == 2 — [singledispatchmethod, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: singledispatchmethod.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# functools.partial.__doc__.__class__.__name__.__len__() — standalone invariant
#
# functools.partial.__doc__.__class__.__name__ is 'str' (3 chars). The docstring
# of the partial class is a plain Python string. This follows the same pattern
# as itertools and operator module docstrings. No prior functools spec records
# partial.__doc__.__class__.__name__.__len__() as a standalone in the extra36
# namespace.
# ---------------------------------------------------------------------------

invariant functools_extra36.partial_doc_classname_len:
  description: "len(functools.partial.__doc__.__class__.__name__) == 3 — docstring is a 'str'"
  category: module_metadata
  kind: python_call_eq
  function: partial.__doc__.__class__.__name__.__len__
  args: []
  expected: 3
