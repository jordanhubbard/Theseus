spec: concurrent_futures_extra1966
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 578 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "concurrent.futures.Executor defines __enter__ and __exit__ directly — it is a synchronous context manager."
    - "ThreadPoolExecutor and ProcessPoolExecutor inherit __enter__/__exit__ from Executor; not in their own __dict__."
    - "concurrent.futures.Future does not define any context manager or finalizer protocol methods."
    - "No concurrent.futures class defines __aenter__, __aexit__, or __del__."
  created_at: "2026-04-12"
error_model: python_exceptions

table concurrent_futures_extra1966.sync_enter_protocol:
  description: "cf types __enter__ dict-presence — Executor defines it; subclasses and Future do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1966

  columns: [id, function, args, expected]
  rows:
    - ["cf1966001", "concurrent.futures.Executor.__dict__.__contains__",             ["__enter__"], true]
    - ["cf1966002", "concurrent.futures.Future.__dict__.__contains__",               ["__enter__"], false]
    - ["cf1966003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["__enter__"], false]
    - ["cf1966004", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",  ["__enter__"], false]
    - ["cf1966005", "concurrent.futures.CancelledError.__dict__.__contains__",       ["__enter__"], false]
    - ["cf1966006", "concurrent.futures.TimeoutError.__dict__.__contains__",         ["__enter__"], false]
    - ["cf1966007", "concurrent.futures.BrokenExecutor.__dict__.__contains__",       ["__enter__"], false]
    - ["cf1966008", "concurrent.futures.InvalidStateError.__dict__.__contains__",    ["__enter__"], false]

