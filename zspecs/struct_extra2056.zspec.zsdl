spec: struct_extra2056
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 584 (_extra2056): __getitem__/__setitem__/__delitem__, __len__, __getattr__/__setattr__/__delattr__ dict-presence checks."
    - "struct.Struct defines __setattr__ and __delattr__ in its own __dict__ (C type attribute guards). It defines none of the sequence/mapping protocol methods."
    - "struct.error is an Exception subclass; none of the sequence/mapping/attr-access protocol methods appear in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2056.getitem_protocol:
  description: "struct types __getitem__/__setitem__/__delitem__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2056

  columns: [id, function, args, expected]
  rows:
    - ["st2056001", "struct.Struct.__dict__.__contains__", ["__getitem__"], false]
    - ["st2056002", "struct.Struct.__dict__.__contains__", ["__setitem__"], false]
    - ["st2056003", "struct.Struct.__dict__.__contains__", ["__delitem__"], false]
    - ["st2056004", "struct.error.__dict__.__contains__",  ["__getitem__"], false]
    - ["st2056005", "struct.error.__dict__.__contains__",  ["__setitem__"], false]
    - ["st2056006", "struct.error.__dict__.__contains__",  ["__delitem__"], false]

