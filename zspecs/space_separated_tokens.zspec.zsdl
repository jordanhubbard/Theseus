spec: space_separated_tokens
version: ">=2.0.2"
backend: node(space-separated-tokens)

docs: https://www.npmjs.com/package/space-separated-tokens

provenance:
  derived_from:
    - "space-separated-tokens README — https://www.npmjs.com/package/space-separated-tokens"
    - "Test vectors verified with space-separated-tokens via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "space-separated-tokens source"
  notes:
    - "space-separated-tokens is an npm package. Install: npm install space-separated-tokens"
    - "Parses and stringifies space-separated token strings (as used in HTML class attributes)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array (parse) or string (stringify)."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table space_separated_tokens.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: sstparse

  columns: [id, args, expected]
  rows:
    - [three,    ["a b c"],   ["a", "b", "c"]]
    - [two,      ["foo bar"], ["foo", "bar"]]
    - [one,      ["hello"],   ["hello"]]

table space_separated_tokens.stringify:
  kind: node_module_call_eq
  function: stringify
  category: format
  id_prefix: sststringify

  columns: [id, args, expected]
  rows:
    - [three,  [["a", "b", "c"]],  "a b c"]
    - [two,    [["foo", "bar"]],   "foo bar"]
