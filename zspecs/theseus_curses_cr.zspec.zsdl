spec: theseus_curses_cr
version: ">=3.0"
backend: python_cleanroom(theseus_curses_cr)
blocks: curses

docs: https://docs.python.org/3/library/curses.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/curses.html"
  not_derived_from:
    - "CPython source: Lib/curses/__init__.py"
  notes:
    - "Clean-room curses module. Do NOT import curses."

error_model: python_exceptions

invariant theseus_curses_cr.curses2_constants:
  description: "curses attribute constants like A_BOLD are defined"
  category: behavior
  kind: python_call_eq
  function: curses2_constants
  args: []
  expected: true

invariant theseus_curses_cr.curses2_wrapper:
  description: "wrapper() function exists and is callable"
  category: behavior
  kind: python_call_eq
  function: curses2_wrapper
  args: []
  expected: true

invariant theseus_curses_cr.curses2_error:
  description: "error exception class exists"
  category: behavior
  kind: python_call_eq
  function: curses2_error
  args: []
  expected: true
