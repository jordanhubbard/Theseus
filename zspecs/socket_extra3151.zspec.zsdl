  rows:
    - ["sk3151001", operator.contains, [socket.socket.__dict__,        "__setitem__"], false]
    - ["sk3151002", operator.contains, [socket.AddressFamily.__dict__, "__setitem__"], false]
    - ["sk3151003", operator.contains, [socket.SocketKind.__dict__,    "__setitem__"], false]

