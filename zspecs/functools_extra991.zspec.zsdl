spec: functools_extra991
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools singledispatch method qualnames, lru_cache wrapper qualnames, and module identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra991.singledispatch_method_qualnames:
  description: "functools.singledispatch internal method __qualname__ identity"
  kind: python_call_eq
  category: singledispatch_qualnames
  id_prefix: ft991sd
  columns: [id, function, args, expected]
  rows:
    - [ft991sd001, functools.singledispatch.__qualname__.__eq__,                    ["singledispatch"],                    true]
    - [ft991sd002, functools.singledispatch.__init__.__qualname__.__eq__,           ["singledispatch.__init__"],           true]
    - [ft991sd003, functools.singledispatch.__call__.__qualname__.__eq__,           ["singledispatch.__call__"],           true]
    - [ft991sd004, functools.singledispatch.register.__qualname__.__eq__,           ["singledispatch.register"],           true]
    - [ft991sd005, functools.singledispatch.dispatch.__qualname__.__eq__,           ["singledispatch.dispatch"],           true]
    - [ft991sd006, functools.singledispatch.update_wrapper.__qualname__.__eq__,     ["singledispatch.update_wrapper"],     true]
    - [ft991sd007, functools.singledispatch.registry.__class__.__name__.__eq__,     ["mappingproxy"],                     true]

table functools_extra991.lru_cache_qualnames:
  description: "functools.lru_cache wrapper method __qualname__ identity"
  kind: python_call_eq
  category: lru_cache_qualnames
  id_prefix: ft991lc
  columns: [id, function, args, expected]
  rows:
    - [ft991lc001, functools.lru_cache.__qualname__.__eq__,                         ["lru_cache"],                        true]
    - [ft991lc002, functools.lru_cache.__class__.__name__.__eq__,                   ["function"],                         true]
    - [ft991lc003, functools.lru_cache.__module__.__eq__,                           ["functools"],                        true]
    - [ft991lc004, functools.lru_cache.__doc__.__class__.__name__.__eq__,           ["str"],                              true]
    - [ft991lc005, functools.lru_cache.__wrapped__.__class__.__name__.__eq__,       ["function"],                         true]

table functools_extra991.reduce_and_module_identity:
  description: "functools.reduce text signature and module __spec__ identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: ft991mi
  columns: [id, function, args, expected]
  rows:
    - [ft991mi001, functools.__spec__.name.__eq__,                                  ["functools"],                        true]
    - [ft991mi002, functools.__spec__.__class__.__name__.__eq__,                    ["ModuleSpec"],                       true]
    - [ft991mi003, functools.__name__.__eq__,                                       ["functools"],                        true]
    - [ft991mi004, functools.reduce.__class__.__name__.__eq__,                      ["builtin_function_or_method"],       true]
    - [ft991mi005, functools.reduce.__module__.__eq__,                              ["_functools"],                       true]
    - [ft991mi006, functools.update_wrapper.__qualname__.__eq__,                    ["update_wrapper"],                   true]
    - [ft991mi007, functools.wraps.__qualname__.__eq__,                             ["wraps"],                            true]
