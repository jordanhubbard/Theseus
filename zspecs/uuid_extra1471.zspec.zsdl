    - "uuid_extra1441.zspec.zsdl — covers __subclasshook__/__instancecheck__ for UUID"
    - "uuid_extra.zspec.zsdl — covers UUID construction, fields, int, hex, str, bytes attributes"
  notes:
    - "Wave 545 theme: __len__ and __getitem__ method presence and type checks."
    - "uuid.UUID is a pure-Python value type representing a 128-bit UUID; it is not a sequence."
    - "uuid.SafeUUID is an IntEnum subclass; __len__ and __getitem__ are NOT in SafeUUID.__dict__."
    - "uuid.UUID.__dict__ does not contain '__len__' — UUID is a scalar value type, not a sized container."
    - "uuid.UUID.__dict__ does not contain '__getitem__' — UUID does not support subscript indexing."
    - "uuid.SafeUUID.__dict__ does not contain '__len__' — SafeUUID enum members are not sequences."
    - "uuid.SafeUUID.__dict__ does not contain '__getitem__' — SafeUUID does not support subscript access."
    - "The int attribute of UUID stores the 128-bit integer value; UUID is a scalar, not a sequence."
    - "list.__len__.__class__.__name__ == 'wrapper_descriptor' — reference descriptor type for sequences."
    - "list.__getitem__.__class__.__name__ == 'method_descriptor' — reference descriptor type for indexing."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID — __len__ and __getitem__ absence checks
#
# uuid.UUID wraps a 128-bit integer. It exposes fields like .int, .hex,
# .bytes, .version, etc., but is not a sequence or mapping. Neither
# __len__ nor __getitem__ is defined in UUID.__dict__. The class does
# define __eq__, __hash__, __str__, and __int__ — it is a value type,
# not a container or sequence.
# ---------------------------------------------------------------------------

table uuid_extra1471.UUID_len_getitem:
  description: "uuid.UUID has no __len__ or __getitem__ — UUID is a scalar value type, not a sequence; neither method appears in UUID.__dict__; wave 545 __len__/__getitem__ absence theme; uu1471lg anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu1471lg

  columns: [id, function, args, expected, description]
  rows:
    - [uu1471lg001, "uuid.UUID.__dict__.__contains__", ["__len__"],     false, "uuid.UUID.__dict__ does not contain '__len__' — UUID is not a sized sequence"]
    - [uu1471lg002, "uuid.UUID.__dict__.__contains__", ["__getitem__"], false, "uuid.UUID.__dict__ does not contain '__getitem__' — UUID does not support subscript indexing"]
    - [uu1471lg003, "uuid.UUID.__dict__.__contains__", ["__eq__"],      true,  "uuid.UUID.__dict__ contains '__eq__' — confirms __dict__ lookup works correctly on UUID"]
    - [uu1471lg004, "uuid.UUID.__dict__.__contains__", ["__hash__"],    true,  "uuid.UUID.__dict__ contains '__hash__' — UUID is hashable (scalar value)"]
    - [uu1471lg005, "uuid.UUID.__dict__.__contains__", ["__str__"],     true,  "uuid.UUID.__dict__ contains '__str__' — UUID has a canonical string representation"]
    - [uu1471lg006, "uuid.UUID.__dict__.__contains__", ["__int__"],     true,  "uuid.UUID.__dict__ contains '__int__' — UUID exposes its 128-bit integer value via __int__"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID — __len__ and __getitem__ dict checks
#
# SafeUUID is an IntEnum. As an enum class it has members that are
# integer-valued, but the class itself does not define __len__ or __getitem__
# in its own __dict__. Those methods are not inherited from IntEnum either —
# SafeUUID is not a sequence and does not support item access by index.
# ---------------------------------------------------------------------------

table uuid_extra1471.SafeUUID_len_getitem:
  description: "uuid.SafeUUID.__dict__ has no __len__ or __getitem__ — SafeUUID is an IntEnum, not a sequence; neither method defined in SafeUUID.__dict__; wave 545 uu1471su anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu1471su

  columns: [id, function, args, expected, description]
  rows:
    - [uu1471su001, "uuid.SafeUUID.__dict__.__contains__", ["__len__"],     false, "uuid.SafeUUID.__dict__ does not contain '__len__' — SafeUUID enum is not a sized sequence"]
    - [uu1471su002, "uuid.SafeUUID.__dict__.__contains__", ["__getitem__"], false, "uuid.SafeUUID.__dict__ does not contain '__getitem__' — SafeUUID does not support subscript indexing"]
    - [uu1471su003, "uuid.SafeUUID.__name__.__eq__",       ["SafeUUID"],    true,  "uuid.SafeUUID.__name__ == 'SafeUUID' — confirms the enum class name"]
    - [uu1471su004, "uuid.SafeUUID.__module__.__eq__",     ["uuid"],        true,  "uuid.SafeUUID.__module__ == 'uuid' — SafeUUID is defined in the uuid module"]
    - [uu1471su005, "uuid.UUID.__dict__.__contains__",     ["__len__"],     false, "uuid.UUID.__dict__ does not contain '__len__' — duplicate anchor: UUID is not a sized type"]
    - [uu1471su006, "uuid.UUID.__dict__.__contains__",     ["__getitem__"], false, "uuid.UUID.__dict__ does not contain '__getitem__' — duplicate anchor: UUID is not a subscriptable type"]

# ---------------------------------------------------------------------------
# uuid.UUID vs list symmetry — UUID lacks sequence protocol that list has
#
# list defines both __len__ (wrapper_descriptor) and __getitem__
# (method_descriptor). uuid.UUID defines neither. This table anchors the
# contrast and also confirms UUID's class identity as a non-sequence type.
# ---------------------------------------------------------------------------

table uuid_extra1471.UUID_vs_list_protocol:
  description: "uuid.UUID lacks __len__/__getitem__ that list provides — list.__len__ is 'wrapper_descriptor', list.__getitem__ is 'method_descriptor'; UUID has neither; contrast confirms UUID is not a sequence; wave 545 uu1471vs anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uu1471vs

  columns: [id, function, args, expected, description]
  rows:
    - [uu1471vs001, "uuid.UUID.__dict__.__contains__",       ["__len__"],            false, "uuid.UUID.__dict__ does not contain '__len__' — contrast with list which defines __len__"]
    - [uu1471vs002, "uuid.UUID.__dict__.__contains__",       ["__getitem__"],        false, "uuid.UUID.__dict__ does not contain '__getitem__' — contrast with list which defines __getitem__"]
    - [uu1471vs003, "list.__len__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true,  "list.__len__.__class__.__name__ == 'wrapper_descriptor' — reference value that UUID does NOT have"]
    - [uu1471vs004, "list.__getitem__.__class__.__name__.__eq__", ["method_descriptor"], true,  "list.__getitem__.__class__.__name__ == 'method_descriptor' — reference value that UUID does NOT have"]
    - [uu1471vs005, "uuid.UUID.__name__.__eq__",             ["UUID"],               true,  "uuid.UUID.__name__ == 'UUID' — confirms the class is named UUID"]
    - [uu1471vs006, "uuid.UUID.__module__.__eq__",           ["uuid"],               true,  "uuid.UUID.__module__ == 'uuid' — UUID is defined in the uuid module"]
