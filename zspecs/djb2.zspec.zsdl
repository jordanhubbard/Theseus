spec: djb2
version: ">=0.0.2"
backend: node(djb2)

docs: https://www.npmjs.com/package/djb2

provenance:
  derived_from:
    - "djb2 README — https://www.npmjs.com/package/djb2"
    - "Test vectors verified with djb2 via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "djb2 source"
  notes:
    - "djb2 is an npm package. Install: npm install djb2"
    - "DJB2 non-cryptographic hash of a string. Seed is 5381."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table djb2.hash:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: djb2

  columns: [id, args, expected]
  rows:
    - [hello,  ["hello"], 261238937]
    - [world,  ["world"], 279393645]
    - [empty,  [""],      5381]
    - [single, ["a"],     177670]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:25:31Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
