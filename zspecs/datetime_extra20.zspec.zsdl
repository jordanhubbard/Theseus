spec: datetime_extra20
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra19.zspec.zsdl."
    - "datetime_extra19 covers: __bases__[0]/__name__ and __bases__[0]/__qualname__ for five classes; tzinfo type axes; date.__init__.__qualname__ == 'object.__init__'."
    - "datetime_extra16 covers: __qualname__ for date.today, date.fromisoformat, date.strftime, date.isoformat, datetime.now, datetime.strptime, time.isoformat, timedelta.__qualname__."
    - "datetime_extra12 covers: __qualname__ and __module__ for date, time, datetime, timedelta, timezone, tzinfo (all six classes)."
    - "Focus: __name__ for date/__init__, time/__init__, datetime/__init__, timedelta/__init__, timezone/__init__; __qualname__ for the remaining four __init__ methods (time/datetime/timedelta/timezone); date.today/__name__ and date.today/__qualname__; datetime.now/__name__ and datetime.now/__qualname__; datetime.utcnow/__name__; datetime.fromisoformat/__name__."
    - "No prior datetime spec checks date.__init__.__name__."
    - "No prior datetime spec checks time.__init__.__name__."
    - "No prior datetime spec checks time.__init__.__qualname__."
    - "No prior datetime spec checks datetime.__init__.__name__."
    - "No prior datetime spec checks datetime.__init__.__qualname__."
    - "No prior datetime spec checks timedelta.__init__.__name__."
    - "No prior datetime spec checks timedelta.__init__.__qualname__."
    - "No prior datetime spec checks timezone.__init__.__name__."
    - "No prior datetime spec checks timezone.__init__.__qualname__."
    - "No prior datetime spec checks date.today.__name__."
    - "No prior datetime spec checks datetime.now.__name__."
    - "No prior datetime spec checks datetime.utcnow.__name__."
    - "No prior datetime spec checks datetime.fromisoformat.__name__."
    - "datetime.date.__init__.__name__ == '__init__' — C wrapper_descriptor __name__ is always the bare dunder string."
    - "datetime.time.__init__.__name__ == '__init__' — C wrapper_descriptor __name__ is always the bare dunder string."
    - "datetime.datetime.__init__.__name__ == '__init__' — C wrapper_descriptor __name__ is always the bare dunder string."
    - "datetime.timedelta.__init__.__name__ == '__init__' — C wrapper_descriptor __name__ is always the bare dunder string."
    - "datetime.timezone.__init__.__name__ == '__init__' — C wrapper_descriptor __name__ is always the bare dunder string."
    - "datetime.time.__init__.__qualname__ == 'object.__init__' — time has no Python-level __init__; inherits from object."
    - "datetime.datetime.__init__.__qualname__ == 'object.__init__' — datetime has no Python-level __init__; inherits from object."
    - "datetime.timedelta.__init__.__qualname__ == 'object.__init__' — timedelta has no Python-level __init__; inherits from object."
    - "datetime.timezone.__init__.__qualname__ == 'object.__init__' — timezone has no Python-level __init__; inherits from object."
    - "datetime.date.today.__name__ == 'today' — classmethod descriptor __name__ is the bare method name."
    - "datetime.date.today.__qualname__ == 'date.today' — compound dotted qualname for a classmethod."
    - "datetime.datetime.now.__name__ == 'now' — classmethod descriptor __name__ is the bare method name."
    - "datetime.datetime.now.__qualname__ == 'datetime.now' — compound dotted qualname for a classmethod."
    - "datetime.datetime.utcnow.__name__ == 'utcnow' — classmethod descriptor __name__ is the bare method name."
    - "datetime.datetime.fromisoformat.__name__ == 'fromisoformat' — classmethod descriptor __name__ is the bare method name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __init__.__name__ for all five datetime classes
#
# datetime_extra19 checks date.__init__.__qualname__ == 'object.__init__' and
# establishes that all five C classes inherit __init__ from object.  No prior
# datetime spec checks the bare __name__ of any class's __init__.  All five
# classes are C types that do not define a Python-level __init__; they inherit
# object.__init__ whose __name__ is always '__init__'.
# ---------------------------------------------------------------------------

invariant datetime_extra20.date.__init__.name:
  description: "datetime.date.__init__.__name__ == '__init__' — C wrapper_descriptor bare name"
  category: method_attrs
  kind: python_call_eq
  function: "date.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

invariant datetime_extra20.time.__init__.name:
  description: "datetime.time.__init__.__name__ == '__init__' — C wrapper_descriptor bare name"
  category: method_attrs
  kind: python_call_eq
  function: "time.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

invariant datetime_extra20.datetime.__init__.name:
  description: "datetime.datetime.__init__.__name__ == '__init__' — C wrapper_descriptor bare name"
  category: method_attrs
  kind: python_call_eq
  function: "datetime.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

invariant datetime_extra20.timedelta.__init__.name:
  description: "datetime.timedelta.__init__.__name__ == '__init__' — C wrapper_descriptor bare name"
  category: method_attrs
  kind: python_call_eq
  function: "timedelta.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

invariant datetime_extra20.timezone.__init__.name:
  description: "datetime.timezone.__init__.__name__ == '__init__' — C wrapper_descriptor bare name"
  category: method_attrs
  kind: python_call_eq
  function: "timezone.__init__.__name__.__eq__"
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# __init__.__qualname__ for time, datetime, timedelta, timezone
#
# datetime_extra19 checks date.__init__.__qualname__ == 'object.__init__'.
# No prior datetime spec checks __init__.__qualname__ for time, datetime,
# timedelta, or timezone.  All four C types also inherit object.__init__, so
# their __init__.__qualname__ is 'object.__init__' for the same reason.
# ---------------------------------------------------------------------------

invariant datetime_extra20.time.__init__.qualname:
  description: "datetime.time.__init__.__qualname__ == 'object.__init__' — time inherits __init__ from object"
  category: method_qualnames
  kind: python_call_eq
  function: "time.__init__.__qualname__.__eq__"
  args: ["object.__init__"]
  expected: true

invariant datetime_extra20.datetime.__init__.qualname:
  description: "datetime.datetime.__init__.__qualname__ == 'object.__init__' — datetime inherits __init__ from object"
  category: method_qualnames
  kind: python_call_eq
  function: "datetime.__init__.__qualname__.__eq__"
  args: ["object.__init__"]
  expected: true

invariant datetime_extra20.timedelta.__init__.qualname:
  description: "datetime.timedelta.__init__.__qualname__ == 'object.__init__' — timedelta inherits __init__ from object"
  category: method_qualnames
  kind: python_call_eq
  function: "timedelta.__init__.__qualname__.__eq__"
  args: ["object.__init__"]
  expected: true

invariant datetime_extra20.timezone.__init__.qualname:
  description: "datetime.timezone.__init__.__qualname__ == 'object.__init__' — timezone inherits __init__ from object"
  category: method_qualnames
  kind: python_call_eq
  function: "timezone.__init__.__qualname__.__eq__"
  args: ["object.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# date.today and datetime.now — __name__ and __qualname__
#
# datetime_extra16 checks __qualname__ for date.today == 'date.today' and
# datetime.now == 'datetime.now'.  No prior datetime spec checks the bare
# __name__ of either classmethod.  For classmethods, __name__ is the plain
# identifier without the class prefix.
# ---------------------------------------------------------------------------

invariant datetime_extra20.date.today.name:
  description: "datetime.date.today.__name__ == 'today' — classmethod bare __name__ without class prefix"
  category: method_attrs
  kind: python_call_eq
  function: date.today.__name__.__eq__
  args: ["today"]
  expected: true

invariant datetime_extra20.date.today.qualname:
  description: "datetime.date.today.__qualname__ == 'date.today' — compound dotted qualname for classmethod"
  category: method_qualnames
  kind: python_call_eq
  function: date.today.__qualname__.__eq__
  args: ["date.today"]
  expected: true

invariant datetime_extra20.datetime.now.name:
  description: "datetime.datetime.now.__name__ == 'now' — classmethod bare __name__ without class prefix"
  category: method_attrs
  kind: python_call_eq
  function: datetime.now.__name__.__eq__
  args: ["now"]
  expected: true

invariant datetime_extra20.datetime.now.qualname:
  description: "datetime.datetime.now.__qualname__ == 'datetime.now' — compound dotted qualname for classmethod"
  category: method_qualnames
  kind: python_call_eq
  function: datetime.now.__qualname__.__eq__
  args: ["datetime.now"]
  expected: true

# ---------------------------------------------------------------------------
# datetime.utcnow and datetime.fromisoformat — __name__
#
# datetime_extra16 checks __qualname__ for datetime.fromisoformat (covered as
# 'datetime.fromisoformat').  No prior datetime spec checks the bare __name__
# of datetime.utcnow or datetime.fromisoformat.
# ---------------------------------------------------------------------------

invariant datetime_extra20.datetime.utcnow.name:
  description: "datetime.datetime.utcnow.__name__ == 'utcnow' — classmethod bare __name__ without class prefix"
  category: method_attrs
  kind: python_call_eq
  function: datetime.utcnow.__name__.__eq__
  args: ["utcnow"]
  expected: true

invariant datetime_extra20.datetime.fromisoformat.name:
  description: "datetime.datetime.fromisoformat.__name__ == 'fromisoformat' — classmethod bare __name__ without class prefix"
  category: method_attrs
  kind: python_call_eq
  function: datetime.fromisoformat.__name__.__eq__
  args: ["fromisoformat"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all fifteen new invariants
#
# All fifteen are first covered in this spec (datetime_extra20).
# ---------------------------------------------------------------------------

table datetime_extra20.init_names_qualnames_and_classmethod_attrs:
  description: "datetime five-class __init__.__name__, four-class __init__.__qualname__, date.today/datetime.now/utcnow/fromisoformat __name__ and __qualname__"
  kind: python_call_eq
  category: method_attrs
  id_prefix: dte20

  columns: [id, function, args, expected]
  rows:
    - [date_init_name,       "date.__init__.__name__.__eq__",      ["__init__"],       true]
    - [time_init_name,       "time.__init__.__name__.__eq__",      ["__init__"],       true]
    - [datetime_init_name,   "datetime.__init__.__name__.__eq__",  ["__init__"],       true]
    - [timedelta_init_name,  "timedelta.__init__.__name__.__eq__", ["__init__"],       true]
    - [timezone_init_name,   "timezone.__init__.__name__.__eq__",  ["__init__"],       true]
    - [time_init_qn,         "time.__init__.__qualname__.__eq__",     ["object.__init__"], true]
    - [datetime_init_qn,     "datetime.__init__.__qualname__.__eq__", ["object.__init__"], true]
    - [timedelta_init_qn,    "timedelta.__init__.__qualname__.__eq__", ["object.__init__"], true]
    - [timezone_init_qn,     "timezone.__init__.__qualname__.__eq__", ["object.__init__"], true]
    - [date_today_name,      date.today.__name__.__eq__,              ["today"],          true]
    - [date_today_qn,        date.today.__qualname__.__eq__,          ["date.today"],     true]
    - [datetime_now_name,    datetime.now.__name__.__eq__,            ["now"],            true]
    - [datetime_now_qn,      datetime.now.__qualname__.__eq__,        ["datetime.now"],   true]
    - [datetime_utcnow_name, datetime.utcnow.__name__.__eq__,         ["utcnow"],         true]
    - [datetime_fromisoformat_name, datetime.fromisoformat.__name__.__eq__, ["fromisoformat"], true]
