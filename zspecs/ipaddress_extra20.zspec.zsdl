spec: ipaddress_extra20
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress_extra5.zspec.zsdl — covers __qualname__.__eq__ for IPv4Address/IPv6Address/IPv4Network/IPv6Network/IPv4Interface/IPv6Interface and ip_address/ip_network/ip_interface factories, plus AddressValueError/NetmaskValueError."
    - "ipaddress_extra16.zspec.zsdl — covers __qualname__.__len__() for IPv4Address/IPv6Address/IPv4Network/IPv6Network (all == 11); standalone __qualname__.__eq__ for IPv4Address and IPv6Network."
    - "ipaddress_extra17.zspec.zsdl — covers __qualname__.__len__() for AddressValueError/NetmaskValueError (both 17); __name__.__eq__ for utility functions; module __name__ and __package__."
    - "ipaddress_extra18.zspec.zsdl — covers __qualname__.__eq__ for IPv4Network.subnets/supernet/overlaps (all _BaseNetwork mixin)."
    - "ipaddress_extra19.zspec.zsdl — covers __qualname__.__eq__ and __qualname__.__len__() for IPv4Address dunder methods (__str__/__repr__/__int__/__eq__/__hash__ all on _BaseAddress); IPv4Network.__contains__/__iter__ (both on _BaseNetwork)."
  notes:
    - "This spec extends the ipaddress chain through ipaddress_extra19; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__eq__ for IPv6Address dunder methods (__str__/__repr__/__int__) and IPv6Network dunder methods (__contains__/__iter__); AddressValueError/__qualname__.__eq__ and NetmaskValueError/__qualname__.__eq__ as standalone invariants (extra5 covers them in a table; standalone invariants add cross-namespace regression checkpoints)."
    - "IPv6Address.__str__.__qualname__ == 'IPv6Address.__str__' — unlike __repr__ and __int__, __str__ is defined directly on IPv6Address (not inherited from _BaseAddress). This is the mirror of the IPv4 case where __str__ is also defined on _BaseAddress. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv6Address.__repr__.__qualname__ == '_BaseAddress.__repr__' — inherited from the private _BaseAddress mixin; same qualname as the IPv4Address case covered in ipaddress_extra19. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv6Address.__int__.__qualname__ == '_BaseAddress.__int__' — inherited from the private _BaseAddress mixin. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv6Network.__contains__.__qualname__ == '_BaseNetwork.__contains__' — inherited from the private _BaseNetwork mixin; same qualname as the IPv4Network case in ipaddress_extra19. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "IPv6Network.__iter__.__qualname__ == '_BaseNetwork.__iter__' — inherited from the private _BaseNetwork mixin. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ipaddress.AddressValueError.__qualname__ == 'AddressValueError' — extra5 covers this in a table; standalone from extra20 namespace is a cross-namespace regression checkpoint."
    - "ipaddress.NetmaskValueError.__qualname__ == 'NetmaskValueError' — same rationale as AddressValueError."
    - "IPv6Address.__str__.__qualname__ length == 19 — len('IPv6Address.__str__') == 19. No prior spec checks this length."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IPv6Address dunder method __qualname__.__eq__ checks
#
# ipaddress_extra19 checks __qualname__ for IPv4Address dunders (__str__,
# __repr__, __int__, __eq__, __hash__). No prior spec checks __qualname__
# for any IPv6Address dunder method. IPv6Address.__str__ is defined directly
# on IPv6Address itself (qualname 'IPv6Address.__str__'), while __repr__ and
# __int__ are inherited from the _BaseAddress mixin.
# ---------------------------------------------------------------------------

table ipaddress_extra20.ipv6address_dunder_qualnames:
  description: "__qualname__.__eq__ for IPv6Address dunder methods — no prior spec checks IPv6Address method qualnames"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: a6dqn20

  columns: [id, function, args, expected]
  rows:
    - [str,  "IPv6Address.__str__.__qualname__.__eq__",  ["IPv6Address.__str__"],  true]
    - [repr, "IPv6Address.__repr__.__qualname__.__eq__", ["_BaseAddress.__repr__"], true]
    - [int,  "IPv6Address.__int__.__qualname__.__eq__",  ["_BaseAddress.__int__"],  true]

# ---------------------------------------------------------------------------
# IPv6Network dunder method __qualname__.__eq__ checks
#
# ipaddress_extra19 checks __qualname__ for IPv4Network.__contains__ and
# __iter__ (both on _BaseNetwork). No prior spec checks these dunders on
# IPv6Network. The qualnames are identical to the IPv4Network case because
# both classes inherit from _BaseNetwork.
# ---------------------------------------------------------------------------

table ipaddress_extra20.ipv6network_dunder_qualnames:
  description: "__qualname__.__eq__ for IPv6Network dunder methods (defined on _BaseNetwork)"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: n6dqn20

  columns: [id, function, args, expected]
  rows:
    - [contains, "IPv6Network.__contains__.__qualname__.__eq__", ["_BaseNetwork.__contains__"], true]
    - [iter,     "IPv6Network.__iter__.__qualname__.__eq__",     ["_BaseNetwork.__iter__"],     true]

# ---------------------------------------------------------------------------
# AddressValueError and NetmaskValueError __qualname__ standalone
#
# ipaddress_extra5 covers AddressValueError.__qualname__.__eq__ and
# NetmaskValueError.__qualname__.__eq__ in a table. These standalone
# invariants from the extra20 namespace provide cross-namespace regression
# checkpoints, following the same pattern used in extra16/extra18 for
# IPv4Address/IPv6Network/ip_network/ip_interface.
# ---------------------------------------------------------------------------

invariant ipaddress_extra20.AddressValueError.qualname:
  description: "ipaddress.AddressValueError.__qualname__ == 'AddressValueError' — standalone from extra20 namespace"
  category: class_qualnames
  kind: python_call_eq
  function: AddressValueError.__qualname__.__eq__
  args: ["AddressValueError"]
  expected: true

invariant ipaddress_extra20.NetmaskValueError.qualname:
  description: "ipaddress.NetmaskValueError.__qualname__ == 'NetmaskValueError' — standalone from extra20 namespace"
  category: class_qualnames
  kind: python_call_eq
  function: NetmaskValueError.__qualname__.__eq__
  args: ["NetmaskValueError"]
  expected: true

# ---------------------------------------------------------------------------
# IPv6Address.__str__.__qualname__ string length
#
# 'IPv6Address.__str__' has 19 characters. No prior spec checks the length
# of this qualname. (ipaddress_extra19 checks _BaseAddress/__str__ length
# for IPv4Address; that qualname is '_BaseAddress.__str__' == 20 chars.
# IPv6Address.__str__ is defined directly on IPv6Address, so its qualname
# is shorter and different.)
# ---------------------------------------------------------------------------

invariant ipaddress_extra20.IPv6Address.str_qualname_len:
  description: "IPv6Address.__str__.__qualname__.__len__() == 19 — len('IPv6Address.__str__') == 19"
  category: class_qualnames
  kind: python_call_eq
  function: IPv6Address.__str__.__qualname__.__len__
  args: []
  expected: 19
