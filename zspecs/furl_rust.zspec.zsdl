spec: furl_rust
version: ">=3.9"
backend: rust_module(furl_rust)

docs: https://github.com/gruns/furl

provenance:
  derived_from:
    - "https://github.com/gruns/furl — furl URL manipulation"
  notes:
    - "furl provides URL manipulation utilities."
    - "furl.furl('http://example.com/path').host == 'example.com'."
    - "furl.furl('http://example.com/path').path.segments == ['path']."
    - "furl.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant furl_rust.host_example:
  description: "furl('http://example.com/path').host == 'example.com'"
  category: parse
  kind: python_call_eq
  function: furl_host
  args: ["http://example.com/path"]
  expected: "example.com"

invariant furl_rust.has_furl_class:
  description: "furl module has furl class"
  category: presence
  kind: python_call_eq
  function: furl_has_class
  args: []
  expected: true

invariant furl_rust.version_nonempty:
  description: "furl.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: furl_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:35:13Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
