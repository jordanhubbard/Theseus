# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache __code__.co_varnames elements [0]-[4]
#
# Wave 275 theme: functools.lru_cache(maxsize=128, typed=False) is a pure-Python
# decorator factory defined in Lib/functools.py. Its co_varnames tuple has 5 entries:
#   co_varnames[0] == 'maxsize'             (7 chars) — declared param with default 128
#   co_varnames[1] == 'typed'               (5 chars) — declared param with default False
#   co_varnames[2] == 'user_function'      (13 chars) — internal local for the function being decorated
#   co_varnames[3] == 'wrapper'             (7 chars) — inner wrapper returned when called as @lru_cache
#   co_varnames[4] == 'decorating_function'(19 chars) — the inner decorator function
#
# co_argcount == 2: 'maxsize' and 'typed' are the two declared positional params.
# 'user_function', 'wrapper', and 'decorating_function' are internal locals.
#
# New to extra129.
# ---------------------------------------------------------------------------

table functools_extra129.lru_cache_co_varnames_elements:
  description: "functools.lru_cache co_varnames[0]='maxsize'(7), [1]='typed'(5), [2]='user_function'(13), [3]='wrapper'(7), [4]='decorating_function'(19); co_argcount=2; 2 declared params + 3 internal locals; wave 275; new to extra129"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolslrucv129

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cv0_eq,
       "lru_cache.__code__.co_varnames.__getitem__",
       [0],
       "maxsize",
       "functools.lru_cache.__code__.co_varnames[0] == 'maxsize' — first declared parameter of lru_cache(maxsize=128, typed=False); controls the maximum number of cached calls; tuple.__getitem__(0) returns 'maxsize'; new to extra129"]
    - [lru_cv0_len,
       "lru_cache.__code__.co_varnames.__getitem__(0).__len__",
       [],
       7,
       "functools.lru_cache.__code__.co_varnames[0].__len__() == 7 — 'maxsize' has 7 chars: m-a-x-s-i-z-e; same length as co_varnames[3] 'wrapper' (7); str.__len__() returns 7; new to extra129"]
    - [lru_cv1_eq,
       "lru_cache.__code__.co_varnames.__getitem__",
       [1],
       "typed",
       "functools.lru_cache.__code__.co_varnames[1] == 'typed' — second declared parameter; when True caches calls with different argument types separately; tuple.__getitem__(1) returns 'typed'; new to extra129"]
    - [lru_cv1_len,
       "lru_cache.__code__.co_varnames.__getitem__(1).__len__",
       [],
       5,
       "functools.lru_cache.__code__.co_varnames[1].__len__() == 5 — 'typed' has 5 chars: t-y-p-e-d; shorter than 'maxsize' (7) and 'user_function' (13); str.__len__() returns 5; new to extra129"]
    - [lru_cv2_eq,
       "lru_cache.__code__.co_varnames.__getitem__",
       [2],
       "user_function",
       "functools.lru_cache.__code__.co_varnames[2] == 'user_function' — internal local holding the function being wrapped when lru_cache is called as @lru_cache without args; tuple.__getitem__(2) returns 'user_function'; new to extra129"]
    - [lru_cv2_len,
       "lru_cache.__code__.co_varnames.__getitem__(2).__len__",
       [],
       13,
       "functools.lru_cache.__code__.co_varnames[2].__len__() == 13 — 'user_function' has 13 chars; the longest of the first 3 entries; same as functools.cache co_varnames[0] ('user_function'); str.__len__() returns 13; new to extra129"]
    - [lru_cv4_eq,
       "lru_cache.__code__.co_varnames.__getitem__",
       [4],
       "decorating_function",
       "functools.lru_cache.__code__.co_varnames[4] == 'decorating_function' — the longest co_varnames entry (19 chars); an inner function returned when lru_cache receives args like @lru_cache(maxsize=256); tuple.__getitem__(4) returns 'decorating_function'; new to extra129"]
    - [lru_cv4_len,
       "lru_cache.__code__.co_varnames.__getitem__(4).__len__",
       [],
       19,
       "functools.lru_cache.__code__.co_varnames[4].__len__() == 19 — 'decorating_function' has 19 chars; the longest entry in lru_cache co_varnames; 12 more chars than 'typed' (5); str.__len__() returns 19; new to extra129"]

# ---------------------------------------------------------------------------
# Table 2: functools.lru_cache __code__ length attrs (co_varnames, co_consts, co_freevars)
#
# Wave 275 theme: lru_cache code object length attributes.
#
# lru_cache.__code__.co_varnames.__len__() == 5
# lru_cache.__code__.co_consts.__len__() == 4
# lru_cache.__code__.co_freevars.__len__() == 0
# lru_cache.__code__.co_argcount == 2
# lru_cache.__code__.co_name == 'lru_cache'  (len 9)
#
# The 5 co_varnames entries are 2 declared params + 3 internal locals.
# co_consts has 4 entries: the docstring, a lambda code object, an error
# message string, and the decorating_function code object.
# co_freevars is 0 because lru_cache is module-level (no enclosing scope).
#
# New to extra129.
# ---------------------------------------------------------------------------

table functools_extra129.lru_cache_code_lengths:
  description: "functools.lru_cache co_varnames len=5, co_consts len=4, co_freevars len=0; co_argcount=2; co_name='lru_cache'(9); module-level function; wave 275; new to extra129"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolslrulen129

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cv_len_5,
       "lru_cache.__code__.co_varnames.__len__",
       [],
       5,
       "functools.lru_cache.__code__.co_varnames.__len__() == 5 — 5 entries: 'maxsize', 'typed', 'user_function', 'wrapper', 'decorating_function'; 2 declared params + 3 internal locals; tuple.__len__() returns 5; new to extra129"]
    - [lru_consts_len_4,
       "lru_cache.__code__.co_consts.__len__",
       [],
       4,
       "functools.lru_cache.__code__.co_consts.__len__() == 4 — 4 entries: docstring, a lambda code object, an error message string, and the decorating_function code object; tuple.__len__() returns 4; new to extra129"]
    - [lru_freevars_len_0,
       "lru_cache.__code__.co_freevars.__len__",
       [],
       0,
       "functools.lru_cache.__code__.co_freevars.__len__() == 0 — lru_cache is a module-level function with no enclosing scope; co_freevars is empty; tuple.__len__() returns 0; new to extra129"]
    - [lru_co_name_eq,
       "lru_cache.__code__.co_name.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__code__.co_name.__eq__('lru_cache') == True — co_name matches the def statement name in Lib/functools.py; str.__eq__('lru_cache') returns True; new to extra129"]
    - [lru_co_argcount_eq_2,
       "lru_cache.__code__.co_argcount.__eq__",
       [2],
       true,
       "functools.lru_cache.__code__.co_argcount.__eq__(2) == True — lru_cache declares 2 positional params: 'maxsize' and 'typed'; the 3 internal locals do not count toward co_argcount; int.__eq__(2) returns True; new to extra129"]

# ---------------------------------------------------------------------------
# Table 3: functools.cache code object attributes
#
# Wave 275 theme: functools.cache is a simpler decorator than lru_cache.
# cache(user_function) is equivalent to lru_cache(maxsize=None).
# Its co_varnames has only 1 entry: ('user_function',) — a single declared param.
# co_argcount == 1; co_consts.__len__() == 3; co_name == 'cache' (len 5).
# functools.cache was added in Python 3.9.
#
# cache.__code__.co_varnames[0] == 'user_function' (len 13)
# cache.__code__.co_varnames.__len__() == 1
# cache.__code__.co_consts.__len__() == 3
# cache.__code__.co_name == 'cache'
# cache.__code__.co_argcount == 1
#
# New to extra129.
# ---------------------------------------------------------------------------

table functools_extra129.cache_code_attrs:
  description: "functools.cache co_varnames[0]='user_function'(13); co_varnames len=1; co_consts len=3; co_argcount=1; co_name='cache'(5); simpler than lru_cache (co_varnames len=5); added in Python 3.9; wave 275; new to extra129"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscacheattr129

  columns: [id, function, args, expected, description]
  rows:
    - [cache_cv0_eq,
       "cache.__code__.co_varnames.__getitem__",
       [0],
       "user_function",
       "functools.cache.__code__.co_varnames[0] == 'user_function' — the sole declared parameter of cache(user_function); cache is a simplified lru_cache(maxsize=None) wrapper added in Python 3.9; tuple.__getitem__(0) returns 'user_function'; new to extra129"]
    - [cache_cv0_len,
       "cache.__code__.co_varnames.__getitem__(0).__len__",
       [],
       13,
       "functools.cache.__code__.co_varnames[0].__len__() == 13 — 'user_function' has 13 chars; same string as lru_cache co_varnames[2] (also 'user_function', 13 chars); str.__len__() returns 13; new to extra129"]
    - [cache_cv_len_1,
       "cache.__code__.co_varnames.__len__",
       [],
       1,
       "functools.cache.__code__.co_varnames.__len__() == 1 — cache has only 1 local variable: the single 'user_function' parameter; no internal locals; much simpler than lru_cache (len=5); tuple.__len__() returns 1; new to extra129"]
    - [cache_consts_len_3,
       "cache.__code__.co_consts.__len__",
       [],
       3,
       "functools.cache.__code__.co_consts.__len__() == 3 — cache co_consts has 3 entries; fewer than lru_cache (4) reflecting cache's simpler implementation as a thin wrapper; tuple.__len__() returns 3; new to extra129"]
    - [cache_co_argcount_eq_1,
       "cache.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.cache.__code__.co_argcount.__eq__(1) == True — cache takes exactly one positional argument: the function to be cached; co_argcount is 1; int.__eq__(1) returns True; new to extra129"]
    - [cache_co_name_eq,
       "cache.__code__.co_name.__eq__",
       ["cache"],
       true,
       "functools.cache.__code__.co_name.__eq__('cache') == True — co_name matches the def statement name in Lib/functools.py; 'cache' has 5 chars, shorter than 'lru_cache' (9); str.__eq__('cache') returns True; new to extra129"]

