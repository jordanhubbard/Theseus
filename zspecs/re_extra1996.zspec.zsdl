spec: re_extra1996
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py, Modules/_sre.c"
    - "re_extra1981.zspec.zsdl — covers __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence"
    - "any proprietary source"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "re.Pattern and re.Match are compiled-pattern and match-result types; not numeric."
    - "re.error is an exception class; not numeric."
    - "re.RegexFlag is an IntFlag (MRO: RegexFlag -> IntFlag -> int -> ReprEnum -> Flag -> Enum -> object)."
    - "Although re.RegexFlag values support int arithmetic, the numeric methods (__index__, __float__, __round__, __abs__) live in int.__dict__, not re.RegexFlag.__dict__. re.RegexFlag defines none of these in its own __dict__."
    - "__complex__ is absent from int.__dict__ too; complex(flag) is not natively supported without __complex__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __index__ dict-presence — re core types
# re.Pattern, re.Match, re.error: not numeric, no __index__.
# re.RegexFlag: IntFlag subclass; __index__ lives in int.__dict__, not
# re.RegexFlag.__dict__. RegexFlag does not override __index__ itself.
# ---------------------------------------------------------------------------

table re_extra1996.index_protocol:
  description: "re class __dict__.__contains__('__index__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1996

  columns: [id, function, args, expected]
  rows:
    - ["re1996001", "re.Pattern.__dict__.__contains__",    ["__index__"], false]
    - ["re1996002", "re.Match.__dict__.__contains__",      ["__index__"], false]
    - ["re1996003", "re.error.__dict__.__contains__",      ["__index__"], false]
    - ["re1996004", "re.RegexFlag.__dict__.__contains__",  ["__index__"], false]

# ---------------------------------------------------------------------------
# __complex__ dict-presence — re core types
# None of the re types define __complex__ in their own __dict__.
# re.RegexFlag is an IntFlag but int itself does not define __complex__
# (int -> complex conversion goes through __complex__ on complex, not on int).
# ---------------------------------------------------------------------------

table re_extra1996.complex_protocol:
  description: "re class __dict__.__contains__('__complex__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1996

  columns: [id, function, args, expected]
  rows:
    - ["re1996005", "re.Pattern.__dict__.__contains__",    ["__complex__"], false]
    - ["re1996006", "re.Match.__dict__.__contains__",      ["__complex__"], false]
    - ["re1996007", "re.error.__dict__.__contains__",      ["__complex__"], false]
    - ["re1996008", "re.RegexFlag.__dict__.__contains__",  ["__complex__"], false]

# ---------------------------------------------------------------------------
# __float__ dict-presence — re core types
# re.Pattern and re.Match are not numeric; no __float__.
# re.error is an exception; no __float__.
# re.RegexFlag: __float__ lives in int.__dict__ (inherited), not in
# re.RegexFlag.__dict__ directly.
# ---------------------------------------------------------------------------

table re_extra1996.float_protocol:
  description: "re class __dict__.__contains__('__float__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1996

  columns: [id, function, args, expected]
  rows:
    - ["re1996009", "re.Pattern.__dict__.__contains__",    ["__float__"], false]
    - ["re1996010", "re.Match.__dict__.__contains__",      ["__float__"], false]
    - ["re1996011", "re.error.__dict__.__contains__",      ["__float__"], false]
    - ["re1996012", "re.RegexFlag.__dict__.__contains__",  ["__float__"], false]

# ---------------------------------------------------------------------------
# __round__ dict-presence — re core types
# re.RegexFlag.__round__ is inherited from int (not defined in RegexFlag's own
# __dict__). All other re types are non-numeric; no __round__.
# ---------------------------------------------------------------------------

table re_extra1996.round_protocol:
  description: "re class __dict__.__contains__('__round__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1996

  columns: [id, function, args, expected]
  rows:
    - ["re1996013", "re.Pattern.__dict__.__contains__",    ["__round__"], false]
    - ["re1996014", "re.Match.__dict__.__contains__",      ["__round__"], false]
    - ["re1996015", "re.error.__dict__.__contains__",      ["__round__"], false]
    - ["re1996016", "re.RegexFlag.__dict__.__contains__",  ["__round__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — re core types
# re.RegexFlag.__abs__ is inherited from int (not defined in RegexFlag's own
# __dict__). All other re types are non-numeric; no __abs__.
# ---------------------------------------------------------------------------

table re_extra1996.abs_protocol:
  description: "re class __dict__.__contains__('__abs__') — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1996

  columns: [id, function, args, expected]
  rows:
    - ["re1996017", "re.Pattern.__dict__.__contains__",    ["__abs__"], false]
    - ["re1996018", "re.Match.__dict__.__contains__",      ["__abs__"], false]
    - ["re1996019", "re.error.__dict__.__contains__",      ["__abs__"], false]
    - ["re1996020", "re.RegexFlag.__dict__.__contains__",  ["__abs__"], false]

# ---------------------------------------------------------------------------
# Cross-protocol summary — re.RegexFlag: inherits numeric protocols from int
# re.RegexFlag is an IntFlag and functionally supports integer arithmetic, but
# it does not define __index__, __complex__, __float__, __round__, or __abs__
# in its own __dict__ — all of those live in int.__dict__ (or are absent
# entirely, as is the case for __complex__).
# ---------------------------------------------------------------------------

table re_extra1996.regexflag_numeric_summary:
  description: "re.RegexFlag: all five numeric protocol methods absent from its own __dict__ (inherited from int where applicable)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1996

  columns: [id, function, args, expected]
  rows:
    - ["re1996021", "re.RegexFlag.__dict__.__contains__", ["__index__"],   false]
    - ["re1996022", "re.RegexFlag.__dict__.__contains__", ["__complex__"], false]
    - ["re1996023", "re.RegexFlag.__dict__.__contains__", ["__float__"],   false]
    - ["re1996024", "re.RegexFlag.__dict__.__contains__", ["__round__"],   false]
    - ["re1996025", "re.RegexFlag.__dict__.__contains__", ["__abs__"],     false]
    - ["re1996026", "re.Pattern.__dict__.__contains__",   ["__index__"],   false]
    - ["re1996027", "re.Pattern.__dict__.__contains__",   ["__complex__"], false]
    - ["re1996028", "re.Pattern.__dict__.__contains__",   ["__float__"],   false]
    - ["re1996029", "re.Pattern.__dict__.__contains__",   ["__round__"],   false]
    - ["re1996030", "re.Pattern.__dict__.__contains__",   ["__abs__"],     false]
