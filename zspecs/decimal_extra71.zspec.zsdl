spec: decimal_extra71
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra70."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for arithmetic/conversion dunders; signal class hierarchy __bases__."
    - "decimal_extra70 covers Decimal.__dict__.__contains__ for __sub__/__neg__/__abs__/__bool__/__float__/__int__; Inexact/Rounded/Subnormal/Clamped __bases__[0].__name__."
    - "This spec covers: Decimal.__sub__/__neg__/__abs__/__bool__/__float__/__int__ __class__.__name__ == 'wrapper_descriptor'; Decimal.__sub__.__qualname__ length; Context.__qualname__ == 'Context'; Context.__bases__[0].__name__ == 'object'; Context.__mro__.__len__() == 2."
    - "decimal.Decimal.__sub__.__class__.__name__ == 'wrapper_descriptor' — C slot wrappers for Decimal are wrapper_descriptor objects."
    - "decimal.Decimal.__neg__.__class__.__name__ == 'wrapper_descriptor' — unary negation is a C slot wrapper."
    - "decimal.Decimal.__abs__.__class__.__name__ == 'wrapper_descriptor' — absolute value is a C slot wrapper."
    - "decimal.Decimal.__bool__.__class__.__name__ == 'wrapper_descriptor' — bool conversion is a C slot wrapper."
    - "decimal.Decimal.__float__.__class__.__name__ == 'wrapper_descriptor' — float conversion is a C slot wrapper."
    - "decimal.Decimal.__int__.__class__.__name__ == 'wrapper_descriptor' — int conversion is a C slot wrapper."
    - "decimal.Decimal.__sub__.__qualname__ == 'Decimal.__sub__' — C slot wrappers for _decimal use short qualnames (no module prefix)."
    - "decimal.Decimal.__sub__.__qualname__.__len__() == 15 — 'Decimal.__sub__' has 15 characters."
    - "decimal.Context.__qualname__ == 'Context' — simple unqualified class name."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context directly subclasses object."
    - "decimal.Context.__mro__.__len__() == 2 — MRO is [Context, object]."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal arithmetic dunder wrapper_descriptor identity
# __sub__, __neg__, __abs__ are C slot wrappers; their __class__.__name__
# is 'wrapper_descriptor' (same as __add__, __mul__, etc. verified earlier).
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra71.Decimal_arithmetic_wrapper_class:
  description: "Decimal.__sub__, __neg__, __abs__ __class__.__name__ == 'wrapper_descriptor'"
  kind: python_call_eq
  category: slot_wrappers
  id_prefix: decimalmore71

  columns: [id, function, args, expected]
  rows:
    - [sub_cls,  Decimal.__sub__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [neg_cls,  Decimal.__neg__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [abs_cls,  Decimal.__abs__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Decimal conversion dunder wrapper_descriptor identity
# __bool__, __float__, __int__ are also C slot wrappers on Decimal.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra71.Decimal_conversion_wrapper_class:
  description: "Decimal.__bool__, __float__, __int__ __class__.__name__ == 'wrapper_descriptor'"
  kind: python_call_eq
  category: slot_wrappers
  id_prefix: decimalmore71

  columns: [id, function, args, expected]
  rows:
    - [bool_cls,  Decimal.__bool__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [float_cls, Decimal.__float__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [int_cls,   Decimal.__int__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Decimal.__sub__ qualname and length
# For C extension types in _decimal, slot wrapper __qualname__ uses the short
# form 'Decimal.__sub__' (no module prefix), giving a length of 15.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra71.Decimal_sub_qualname:
  description: "Decimal.__sub__ __qualname__ value and length"
  kind: python_call_eq
  category: slot_wrappers
  id_prefix: decimalmore71

  columns: [id, function, args, expected]
  rows:
    - [sub_qualname,     Decimal.__sub__.__qualname__.__eq__,  ["Decimal.__sub__"], true]
    - [sub_qualname_len, Decimal.__sub__.__qualname__.__len__, [],                  15]

# ---------------------------------------------------------------------------
# Context class hierarchy
# Context directly subclasses object; its MRO is [Context, object] (length 2).
# Function values containing [ must be double-quoted.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra71.Context_hierarchy:
  description: "Context.__qualname__, __bases__[0].__name__, and __mro__.__len__()"
  kind: python_call_eq
  category: class_bases
  id_prefix: decimalmore71

  columns: [id, function, args, expected]
  rows:
    - [ctx_qualname, Context.__qualname__.__eq__,             ["Context"], true]
    - [ctx_base,     "Context.__bases__[0].__name__.__eq__",  ["object"],  true]
    - [ctx_mro_len,  Context.__mro__.__len__,                 [],          2]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra71.Decimal_sub.wrapper_descriptor:
  description: "decimal.Decimal.__sub__.__class__.__name__ == 'wrapper_descriptor'"
  category: slot_wrappers
  kind: python_call_eq
  function: Decimal.__sub__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra71.Decimal_neg.wrapper_descriptor:
  description: "decimal.Decimal.__neg__.__class__.__name__ == 'wrapper_descriptor'"
  category: slot_wrappers
  kind: python_call_eq
  function: Decimal.__neg__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra71.Decimal_sub.qualname_len:
  description: "decimal.Decimal.__sub__.__qualname__.__len__() == 15 ('Decimal.__sub__' = 15 chars)"
  category: slot_wrappers
  kind: python_call_eq
  function: Decimal.__sub__.__qualname__.__len__
  args: []
  expected: 15

invariant decimal_extra71.Context.qualname:
  description: "decimal.Context.__qualname__ == 'Context'"
  category: class_names
  kind: python_call_eq
  function: Context.__qualname__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra71.Context.mro_len:
  description: "decimal.Context.__mro__.__len__() == 2 — MRO is [Context, object]"
  category: class_bases
  kind: python_call_eq
  function: Context.__mro__.__len__
  args: []
  expected: 2
