spec: semver_compare
version: ">=1.0.0"
backend: node(semver-compare)

docs: https://www.npmjs.com/package/semver-compare

provenance:
  derived_from:
    - "semver-compare README — https://www.npmjs.com/package/semver-compare"
    - "Test vectors verified with semver-compare via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "semver-compare source"
  notes:
    - "semver-compare is an npm package. Install: npm install semver-compare"
    - "The module exports a single function: compare(a, b) returns -1, 0, or 1."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns -1, 0, or 1."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table semver_compare.compare:
  kind: node_module_call_eq
  function: ~
  category: compare
  id_prefix: semvcmp

  columns: [id, args, expected]
  rows:
    - [less,    ["1.2.3", "1.2.4"], -1]
    - [greater, ["2.0.0", "1.9.9"],  1]
    - [equal,   ["1.0.0", "1.0.0"],  0]
