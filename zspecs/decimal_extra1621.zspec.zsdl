spec: decimal_extra1621
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "decimal.Decimal and decimal.Context are C extension types (from _decimal); C types do not expose __weakref__ in their class dicts"
    - "decimal.DecimalException is a pure Python class (defined in Lib/_pydecimal.py); Python type machinery adds __weakref__ to its own class dict"
    - "decimal.DecimalException inherits from ArithmeticError (which inherits from Exception); as a Python class without __slots__ it has __weakref__ in its own class dict"
    - "Direct subclasses of decimal.DecimalException (e.g. InvalidOperation, DivisionByZero, Inexact, etc.) do NOT re-define __weakref__ in their own class dicts; __weakref__ support is inherited from DecimalException"
    - "Subclasses like Overflow, Underflow inherit from Inexact and Rounded respectively; they also lack __weakref__ in their own class dicts"
    - "decimal.FloatOperation inherits from both decimal.DecimalException and TypeError; it does not add __weakref__ to its own class dict"
    - "Instances of decimal.Decimal and decimal.Context cannot be weakly referenced (no __weakref__ support in C type)"
    - "Instances of all decimal exception classes CAN be weakly referenced (inherited from DecimalException which has __weakref__)"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: decimal.Decimal and decimal.Context — C types, no __weakref__
# ---------------------------------------------------------------------------

table decimal_extra1621.decimal_context_no_weakref:
  description: "decimal.Decimal and decimal.Context are C extension types — neither exposes __weakref__ in its own class dict; instances cannot be weakly referenced"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1621dc

  columns: [id, function, args, expected]
  rows:
    - ["dc1621dc001", decimal.Decimal.__dict__.__contains__,  ["__weakref__"], false]
    - ["dc1621dc002", decimal.Context.__dict__.__contains__,  ["__weakref__"], false]
    - ["dc1621dc003", decimal.Decimal.__dict__.__contains__,  ["__slots__"],   false]
    - ["dc1621dc004", decimal.Context.__dict__.__contains__,  ["__slots__"],   false]
    - ["dc1621dc005", decimal.Decimal.__dict__.__contains__,  ["__dict__"],    false]
