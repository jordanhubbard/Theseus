    - ["dc1621dc007", decimal.Decimal.__dict__.__contains__,  ["__repr__"],    true]
    - ["dc1621dc008", decimal.Decimal.__dict__.__contains__,  ["__str__"],     true]
    - ["dc1621dc009", decimal.Decimal.__dict__.__contains__,  ["__add__"],     true]
    - ["dc1621dc010", decimal.Decimal.__dict__.__contains__,  ["__sub__"],     true]
    - ["dc1621dc011", decimal.Decimal.__dict__.__contains__,  ["__mul__"],     true]
    - ["dc1621dc012", decimal.Decimal.__dict__.__contains__,  ["__truediv__"], true]
    - ["dc1621dc013", decimal.Decimal.__dict__.__contains__,  ["__hash__"],    true]
    - ["dc1621dc014", decimal.Decimal.__dict__.__contains__,  ["__eq__"],      true]
    - ["dc1621dc015", decimal.Decimal.__dict__.__contains__,  ["sqrt"],        true]
    - ["dc1621dc016", decimal.Decimal.__dict__.__contains__,  ["quantize"],    true]
    - ["dc1621dc017", decimal.Context.__dict__.__contains__,  ["prec"],        true]
    - ["dc1621dc018", decimal.Context.__dict__.__contains__,  ["rounding"],    true]
    - ["dc1621dc019", decimal.Context.__dict__.__contains__,  ["Emax"],        true]
    - ["dc1621dc020", decimal.Context.__dict__.__contains__,  ["Emin"],        true]
    - ["dc1621dc021", decimal.Context.__dict__.__contains__,  ["sqrt"],        true]
    - ["dc1621dc022", decimal.Context.__dict__.__contains__,  ["add"],         true]
    - ["dc1621dc023", decimal.Context.__dict__.__contains__,  ["__repr__"],    true]
    - ["dc1621dc024", decimal.Decimal.__dict__.__contains__,  ["is_nan"],      true]
    - ["dc1621dc025", decimal.Decimal.__dict__.__contains__,  ["is_finite"],   true]
    - ["dc1621dc026", decimal.Decimal.__dict__.__contains__,  ["is_zero"],     true]
    - ["dc1621dc027", decimal.Decimal.__dict__.__contains__,  ["normalize"],   true]
    - ["dc1621dc028", decimal.Context.__dict__.__contains__,  ["capitals"],    true]
    - ["dc1621dc029", decimal.Context.__dict__.__contains__,  ["clamp"],       true]
    - ["dc1621dc030", decimal.Context.__dict__.__contains__,  ["__module__"],  true]

# ---------------------------------------------------------------------------
# Table 2: decimal.DecimalException — Python class, has __weakref__
# ---------------------------------------------------------------------------

table decimal_extra1621.exception_base_weakref:
  description: "decimal.DecimalException is a pure Python exception class; Python type machinery adds __weakref__ to its own class dict; it also has __module__, __doc__, and __dict__ support"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1621eb

  columns: [id, function, args, expected]
  rows:
    - ["dc1621eb001", decimal.DecimalException.__dict__.__contains__,  ["__weakref__"], true]
    - ["dc1621eb002", decimal.DecimalException.__dict__.__contains__,  ["__slots__"],   false]
    - ["dc1621eb003", decimal.DecimalException.__dict__.__contains__,  ["__dict__"],    false]
    - ["dc1621eb004", decimal.DecimalException.__dict__.__contains__,  ["__module__"],  true]
    - ["dc1621eb005", decimal.DecimalException.__dict__.__contains__,  ["__doc__"],     true]
    - ["dc1621eb006", decimal.DecimalException.__dict__.__contains__,  ["handle"],      true]
    - ["dc1621eb007", decimal.DecimalException.__dict__.__contains__,  ["__repr__"],    false]
    - ["dc1621eb008", decimal.DecimalException.__dict__.__contains__,  ["__str__"],     false]
    - ["dc1621eb009", decimal.DecimalException.__dict__.__contains__,  ["__init__"],    false]
    - ["dc1621eb010", decimal.Decimal.__dict__.__contains__,           ["__weakref__"], false]
    - ["dc1621eb011", decimal.Context.__dict__.__contains__,           ["__weakref__"], false]
    - ["dc1621eb012", decimal.DecimalException.__dict__.__contains__,  ["__weakref__"], true]
    - ["dc1621eb013", decimal.DecimalException.__dict__.__contains__,  ["__qualname__"], true]
    - ["dc1621eb014", decimal.DecimalException.__dict__.__contains__,  ["handle"],      true]
    - ["dc1621eb015", decimal.DecimalException.__dict__.__contains__,  ["__hash__"],    false]

