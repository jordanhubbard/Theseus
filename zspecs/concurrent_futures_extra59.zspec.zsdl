spec: concurrent_futures_extra59
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#annotations — Python __annotations__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra58.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__/__qualname__ tables, wait/__name__=='wait', as_completed/__name__=='as_completed', wait/__qualname__.__len__()==4, as_completed/__qualname__.__len__()==12 (extra51), class __class__.__name__/__qualname__ equality (extra44/extra45), wait/__class__.__module__=='builtins' and ThreadPoolExecutor/__class__.__module__=='builtins' (extra45), class __doc__/__class__/__module__=='builtins' tables (extra47/extra49), ProcessPoolExecutor/Future/Executor __class__.__module__.__eq__('builtins') (extra52), as_completed/__class__.__module__.__eq__('builtins') (extra52), ThreadPoolExecutor/ProcessPoolExecutor/Future __init__.__class__.__name__.__eq__('function') (extra52), class __repr__.__class__.__name__ tables (extra53), class __weakref__.__class__.__name__ tables (extra53), exception __repr__.__class__.__name__ tables (extra53), cf.__all__.__class__.__name__.__eq__('list') (extra54), cf.__all__.__len__()==14 (extra54), __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra54), cf.__all__.__contains__ membership checks (extra55), cf.__package__.__eq__('concurrent.futures') (extra55), Future/Executor __doc__.__class__.__name__.__eq__('str') (extra55), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra56), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra57), Future/__init__ and ThreadPoolExecutor/__init__ and Future.result/done/cancel/exception and ThreadPoolExecutor.submit/shutdown __qualname__.__eq__ (extra58)."
    - "This spec covers (cfann59 namespace): wave 228 theme — __annotations__ class identity + __globals__ dict keys + __doc__.__contains__ content checks. NEW in extra59: wait/__annotations__.__class__.__name__.__eq__('dict') and as_completed/__annotations__.__class__.__name__.__eq__('dict') — no prior cf spec has checked __annotations__.__class__.__name__ via __eq__ for these functions; wait/__globals__.__class__.__name__.__eq__('dict') — no prior cf spec has checked the __globals__ dict class name via __eq__; wait/__globals__.__contains__('wait') — no prior cf spec has used __contains__ on wait.__globals__; Future/__doc__.__contains__('Represents') — Future.__doc__ is 'Represents the result of an asynchronous computation.' and does NOT contain 'Future' but does contain 'Represents'; ThreadPoolExecutor/__doc__ is None (__class__.__name__ == 'NoneType') as confirmed in wave 224b."
    - "concurrent.futures.wait.__annotations__.__class__.__name__ == 'dict'. wait is a pure-Python function defined in Lib/concurrent/futures/_base.py. Its __annotations__ attribute is an empty dict ({}). The __class__.__name__ of that dict is 'dict'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__annotations__.__class__.__name__ == 'dict'. as_completed is a pure-Python generator function defined in Lib/concurrent/futures/_base.py. Its __annotations__ attribute is an empty dict ({}). The __class__.__name__ of that dict is 'dict'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__globals__.__class__.__name__ == 'dict'. The __globals__ of any pure-Python function is the module-level namespace dict of its defining module (Lib/concurrent/futures/_base.py). The type of that namespace is dict, so __class__.__name__ is 'dict'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__globals__.__contains__('wait') returns True. 'wait' is a key in wait's module globals (Lib/concurrent/futures/_base.py) because wait is defined at module level in that file. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__doc__.__contains__('Represents') returns True. Future.__doc__ is 'Represents the result of an asynchronous computation.' — the word 'Represents' appears at the start. NOTE: Future.__doc__ does NOT contain 'Future' (verified); the task description requested checking for 'Future' but the actual docstring does not contain that substring. This spec uses 'Represents' as the content check substring, which is verified True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__doc__ is None. type(None).__name__ == 'NoneType'. ThreadPoolExecutor has no docstring; its __doc__ attribute is the None singleton. Confirmed in wave 224b. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures function __annotations__ class identity — extra59
#
# Wave 228 theme: __annotations__ class identity checks.
#
# wait and as_completed are pure-Python functions. Their __annotations__
# attribute is always an empty dict ({}). The __class__.__name__ of that
# dict is 'dict'.
#
# NEW: no prior cf spec has used __eq__ to verify __annotations__.__class__.__name__
# for these functions.
# ---------------------------------------------------------------------------

table concurrent_futures_extra59.function_annotations_class_name:
  description: "concurrent.futures function __annotations__.__class__.__name__.__eq__('dict') checks in cfann59 namespace — wave 228 theme: __annotations__ class identity; wait and as_completed are pure-Python functions; their __annotations__ attribute is an empty dict ({}); __class__.__name__ of that dict is 'dict'; NEW in extra59: no prior cf spec has verified __annotations__.__class__.__name__ via __eq__ for these functions; verified with Python 3.14.3"
  kind: python_call_eq
  category: annotations
  id_prefix: cfann59

  columns: [id, function, args, expected, description]
  rows:
    - [wait_ann_class,         wait.__annotations__.__class__.__name__.__eq__,         ["dict"], true, "wait.__annotations__.__class__.__name__ == 'dict' — wait is a pure-Python function (Lib/concurrent/futures/_base.py); its __annotations__ attribute is an empty dict ({}); the type of any dict is dict itself, so __class__.__name__ is 'dict'; NEW in extra59: first __annotations__.__class__.__name__.__eq__ check for wait in any cf spec; verified with Python 3.14.3"]
    - [as_completed_ann_class, as_completed.__annotations__.__class__.__name__.__eq__, ["dict"], true, "as_completed.__annotations__.__class__.__name__ == 'dict' — as_completed is a pure-Python generator function (Lib/concurrent/futures/_base.py); its __annotations__ attribute is an empty dict ({}); __class__.__name__ is 'dict'; NEW in extra59: first __annotations__.__class__.__name__.__eq__ check for as_completed in any cf spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures wait.__globals__ class identity and key membership — extra59
#
# Wave 228 theme: __globals__ dict keys.
#
# wait.__globals__ is the module-level namespace dict of
# Lib/concurrent/futures/_base.py. Its type is dict.
# 'wait' is a key in that dict because wait is defined at module level.
# ---------------------------------------------------------------------------

table concurrent_futures_extra59.globals_class_and_contains:
  description: "concurrent.futures wait.__globals__ class identity and key membership checks in cfann59 namespace — wave 228 theme: __globals__ dict keys; wait.__globals__ is the module-level namespace dict of Lib/concurrent/futures/_base.py; its __class__.__name__ is 'dict' and it contains 'wait' as a key; NEW in extra59: no prior cf spec has checked wait.__globals__.__class__.__name__ via __eq__ or used __contains__ on wait.__globals__; verified with Python 3.14.3"
  kind: python_call_eq
  category: globals
  id_prefix: cfann59g

  columns: [id, function, args, expected, description]
  rows:
    - [wait_globals_class,    wait.__globals__.__class__.__name__.__eq__, ["dict"], true, "wait.__globals__.__class__.__name__ == 'dict' — the __globals__ of any pure-Python function is the module-level namespace dict of its defining module (Lib/concurrent/futures/_base.py); the type of that namespace is dict, so __class__.__name__ is 'dict'; NEW in extra59: first __globals__.__class__.__name__.__eq__ check for any cf function in any cf spec; verified with Python 3.14.3"]
    - [wait_globals_contains, wait.__globals__.__contains__,              ["wait"], true, "wait.__globals__.__contains__('wait') returns True — 'wait' is a key in wait's module globals (Lib/concurrent/futures/_base.py) since wait is defined at module level in that file; dict.__contains__ checks key membership; NEW in extra59: first __globals__.__contains__ check for wait in any cf spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures Future.__doc__ content check — extra59
#
# Wave 228 theme: __doc__.__contains__ content checks.
#
# Future.__doc__ == 'Represents the result of an asynchronous computation.'
# NOTE: This docstring does NOT contain 'Future'. It does contain 'Represents'.
# The task requested checking for 'Future' — but that substring is absent.
# This spec uses 'Represents' as the verified-True content check.
# ---------------------------------------------------------------------------

table concurrent_futures_extra59.future_doc_contains:
  description: "concurrent.futures Future.__doc__.__contains__ content check in cfann59 namespace — wave 228 theme: __doc__.__contains__ content checks; Future.__doc__ is 'Represents the result of an asynchronous computation.'; NOTE: this docstring does NOT contain the word 'Future' (verified); it does contain 'Represents' at the start; str.__contains__ returns True for 'Represents'; NEW in extra59: no prior cf spec has used __contains__ to test docstring content for Future; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: cfann59d

  columns: [id, function, args, expected, description]
  rows:
    - [future_doc_contains_represents, Future.__doc__.__contains__, ["Represents"], true, "Future.__doc__.__contains__('Represents') returns True — cf.Future.__doc__ is 'Represents the result of an asynchronous computation.'; the word 'Represents' appears at the start of the docstring; str.__contains__ returns True when the substring is present; NOTE: 'Future' does NOT appear in this docstring (verified with Python 3.14.3); 'Represents' is the correct content check substring; NEW in extra59: first __doc__.__contains__ content check for cf.Future in any cf spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures ThreadPoolExecutor.__doc__ class identity — extra59
#
# Wave 228 theme: class identity checks.
#
# ThreadPoolExecutor has no docstring. Its __doc__ attribute is the None
# singleton. type(None).__name__ == 'NoneType'.
# Confirmed in wave 224b.
# ---------------------------------------------------------------------------

table concurrent_futures_extra59.tpe_doc_class_name:
  description: "concurrent.futures ThreadPoolExecutor.__doc__.__class__.__name__.__eq__('NoneType') check in cfann59 namespace — wave 228 theme: class identity; ThreadPoolExecutor has no docstring; its __doc__ attribute is the None singleton; type(None).__name__ == 'NoneType'; confirmed in wave 224b; NEW in extra59: no prior cf spec has verified ThreadPoolExecutor.__doc__.__class__.__name__ via __eq__; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: cfann59tpe

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_doc_class_none, ThreadPoolExecutor.__doc__.__class__.__name__.__eq__, ["NoneType"], true, "ThreadPoolExecutor.__doc__.__class__.__name__ == 'NoneType' — ThreadPoolExecutor defines no docstring; its __doc__ attribute is the None singleton; type(None).__name__ is 'NoneType'; confirmed in wave 224b; NEW in extra59: first __doc__.__class__.__name__.__eq__ check for ThreadPoolExecutor using 'NoneType' in any cf spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra59
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra59.wait_annotations_class_name_eq:
  description: "concurrent.futures.wait.__annotations__.__class__.__name__.__eq__('dict') returns True — wait is a pure-Python function defined in Lib/concurrent/futures/_base.py; its __annotations__ attribute is an empty dict ({}); the __class__.__name__ of that dict is 'dict'; NEW in extra59: no prior cf spec has verified wait.__annotations__.__class__.__name__ via __eq__; wave 228 first __annotations__ class identity invariant for wait in any cf spec; verified with Python 3.14.3"
  category: annotations
  kind: python_call_eq
  function: wait.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant concurrent_futures_extra59.as_completed_annotations_class_name_eq:
  description: "concurrent.futures.as_completed.__annotations__.__class__.__name__.__eq__('dict') returns True — as_completed is a pure-Python generator function defined in Lib/concurrent/futures/_base.py; its __annotations__ attribute is an empty dict ({}); the __class__.__name__ of that dict is 'dict'; NEW in extra59: no prior cf spec has verified as_completed.__annotations__.__class__.__name__ via __eq__; wave 228 invariant alongside wait annotation check; verified with Python 3.14.3"
  category: annotations
  kind: python_call_eq
  function: as_completed.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant concurrent_futures_extra59.wait_globals_class_name_eq:
  description: "concurrent.futures.wait.__globals__.__class__.__name__.__eq__('dict') returns True — wait.__globals__ is the module-level namespace dict of Lib/concurrent/futures/_base.py; the type of any module namespace is dict, so __class__.__name__ is 'dict'; NEW in extra59: no prior cf spec has checked wait.__globals__.__class__.__name__ via __eq__; wave 228 first __globals__ class identity invariant for any cf function; verified with Python 3.14.3"
  category: globals
  kind: python_call_eq
  function: wait.__globals__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant concurrent_futures_extra59.wait_globals_contains_wait:
  description: "concurrent.futures.wait.__globals__.__contains__('wait') returns True — 'wait' is a key in the module-level namespace dict of Lib/concurrent/futures/_base.py where wait is defined; dict.__contains__ checks for key membership; NEW in extra59: no prior cf spec has used __contains__ on wait.__globals__; wave 228 first __globals__.__contains__ invariant for wait; verified with Python 3.14.3"
  category: globals
  kind: python_call_eq
  function: wait.__globals__.__contains__
  args: ["wait"]
  expected: true

invariant concurrent_futures_extra59.tpe_doc_class_name_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__name__.__eq__('NoneType') returns True — ThreadPoolExecutor defines no docstring; its __doc__ attribute is the None singleton; type(None).__name__ is 'NoneType'; confirmed in wave 224b; NEW in extra59: no prior cf spec has verified ThreadPoolExecutor.__doc__.__class__.__name__ via __eq__ using 'NoneType'; wave 228 class identity invariant for ThreadPoolExecutor.__doc__; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: ThreadPoolExecutor.__doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
