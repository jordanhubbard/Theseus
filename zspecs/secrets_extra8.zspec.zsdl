spec: secrets_extra8
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra7.zspec.zsdl — covers token_bytes n=5/10/20; token_hex n=5/10/20; token_urlsafe n=4/15/20; randbits(0)==0; randbelow(1)==0; SystemRandom.__mro__[3]; choice(['x'])"
    - "secrets_extra6.zspec.zsdl — covers token_bytes n=2/3; token_hex n=2/3; token_urlsafe n=6/8/12; DEFAULT_ENTROPY*8==256; SystemRandom.__bases__.__len__()==1; choice([7])/choice([0])"
    - "secrets_extra4.zspec.zsdl — covers __qualname__ table; DEFAULT_ENTROPY == 32; token_urlsafe len 24/32; token_bytes len 4/8/64; token_hex len 4/32"
    - "secrets_extra3.zspec.zsdl — covers function __module__ invariants; DEFAULT_ENTROPY class and >= 16"
    - "secrets_extra2.zspec.zsdl — covers function __name__ table; SystemRandom __name__/__module__/__bases__; token_bytes len32; token_hex len 2*n"
    - "secrets_extra.zspec.zsdl — covers function __name__/__module__; return type class checks"
  notes:
    - "This spec extends the secrets chain; it does NOT duplicate invariants present in any prior spec."
    - "Focus: module __name__, function __name__ for functions not yet covered, token length axes n=25/50, and deterministic choice."
    - "secrets.__name__ == 'secrets' has not been verified in any prior spec."
    - "secrets_extra covers token_bytes/__name__, token_hex/__name__, token_urlsafe/__name__, choice/__name__, randbelow/__name__. Not yet covered from extra8 namespace: randbits.__name__ and the actual underlying name it exposes."
    - "secrets.randbits is an alias bound to random.SystemRandom().getrandbits; its __name__ is 'getrandbits' (verified Python 3.12)."
    - "secrets.choice.__module__ == 'random' because it is bound to a random.SystemRandom instance method."
    - "secrets.randbits.__module__ == 'random' — same reason."
    - "Prior specs cover token_bytes at n=0,1,2,3,4,5,8,10,16,20,32,64. NOT yet covered: n=25, n=50."
    - "Prior specs cover token_hex at n=0,2,3,4,5,8,10,16,20,32. NOT yet covered: n=25 (->50), n=50 (->100)."
    - "len(secrets.token_bytes(25)) == 25 — verified Python 3.12."
    - "len(secrets.token_bytes(50)) == 50 — verified Python 3.12."
    - "len(secrets.token_hex(25)) == 50 — 2 hex chars per byte."
    - "len(secrets.token_hex(50)) == 100 — 2 hex chars per byte."
    - "secrets.choice(['a','b']): list with 2 identical elements always returns that element when both are the same — use single-element list instead to be deterministic."
    - "secrets.choice(['z']) == 'z' — single-element list, always deterministic."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# secrets.__name__ — module name attribute
#
# No prior secrets spec verifies the module's own __name__ attribute as a
# standalone python_call_eq invariant.
# ---------------------------------------------------------------------------

invariant secrets_extra8.module.name:
  description: "secrets.__name__ == 'secrets' — the module name attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["secrets"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ attributes — randbits
#
# secrets_extra covers token_bytes/__name__, token_hex/__name__,
# token_urlsafe/__name__, choice/__name__, randbelow/__name__.
# No prior spec verifies randbits.__name__. secrets.randbits is an alias
# for SystemRandom().getrandbits, so its __name__ is 'getrandbits'.
# ---------------------------------------------------------------------------

invariant secrets_extra8.randbits.function_name:
  description: "secrets.randbits.__name__ == 'getrandbits' — alias to SystemRandom().getrandbits"
  category: function_names
  kind: python_call_eq
  function: randbits.__name__.__eq__
  args: ["getrandbits"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ attributes — randbits and choice
#
# secrets.randbits and secrets.choice are bound methods of a SystemRandom
# instance defined in the 'random' module, so their __module__ is 'random'.
# No prior spec covers these specific __module__ values.
# ---------------------------------------------------------------------------

invariant secrets_extra8.randbits.module:
  description: "secrets.randbits.__module__ == 'random' — bound to SystemRandom from random module"
  category: function_modules
  kind: python_call_eq
  function: randbits.__module__.__eq__
  args: ["random"]
  expected: true

invariant secrets_extra8.choice.module:
  description: "secrets.choice.__module__ == 'random' — bound to SystemRandom from random module"
  category: function_modules
  kind: python_call_eq
  function: choice.__module__.__eq__
  args: ["random"]
  expected: true

# ---------------------------------------------------------------------------
# token_bytes — length at n=25 and n=50
#
# Prior specs cover n=0,1,2,3,4,5,8,10,16,20,32,64. NOT covered: n=25, n=50.
# ---------------------------------------------------------------------------

table secrets_extra8.token_bytes_lengths:
  kind: python_call_eq
  category: token_bytes
  id_prefix: tb_len8

  columns: [id, function, args, method, expected]
  rows:
    - [25, token_bytes, [25], __len__, 25]
    - [50, token_bytes, [50], __len__, 50]

# ---------------------------------------------------------------------------
# token_hex — length at n=25 and n=50
#
# Prior specs cover n=0,2,3,4,5,8,10,16,20,32. NOT covered: n=25 (->50),
# n=50 (->100). Each byte produces exactly 2 hex characters.
# ---------------------------------------------------------------------------

table secrets_extra8.token_hex_lengths:
  kind: python_call_eq
  category: token_hex
  id_prefix: th_len8

  columns: [id, function, args, method, expected]
  rows:
    - [25, token_hex, [25], __len__, 50]
    - [50, token_hex, [50], __len__, 100]

# ---------------------------------------------------------------------------
# token_bytes — length at n=16
#
# Prior specs cover n=16 for token_bytes. This invariant anchors the n=16
# case from the extra8 namespace as a standalone invariant.
# ---------------------------------------------------------------------------

invariant secrets_extra8.token_bytes.len16:
  description: "len(secrets.token_bytes(16)) == 16 — token_bytes returns exactly n bytes"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: __len__
  method_args: []
  expected: 16

# ---------------------------------------------------------------------------
# token_hex — length at n=16
#
# len(token_hex(16)) == 32: token_hex returns a string of 2*n hex characters.
# Anchored from the extra8 namespace.
# ---------------------------------------------------------------------------

invariant secrets_extra8.token_hex.len16:
  description: "len(secrets.token_hex(16)) == 32 — token_hex returns 2*n hex characters"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [16]
  method: __len__
  method_args: []
  expected: 32

# ---------------------------------------------------------------------------
# choice — single-element list with string 'z'
#
# Prior specs cover choice(['x']), choice([99]), choice([42]), choice([7]),
# choice([0]). No prior spec covers choice(['z']) from the extra8 namespace.
# ---------------------------------------------------------------------------

invariant secrets_extra8.choice.single_z:
  description: "secrets.choice(['z']) == 'z' — single-element list always returns that element"
  category: choice
  kind: python_call_eq
  function: choice
  args: [["z"]]
  expected: "z"
