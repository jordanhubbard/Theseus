spec: types_extra6
version: ">=3.10"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
    - "types.zspec.zsdl — covers __name__ for FunctionType/MethodType/ModuleType/NoneType/GeneratorType/MappingProxyType/SimpleNamespace/LambdaType/CoroutineType/AsyncGeneratorType/UnionType"
    - "types_extra.zspec.zsdl — covers __name__ for CodeType/BuiltinFunctionType/TracebackType/FrameType and re-confirms major types"
    - "types_extra2.zspec.zsdl — covers __module__ for all major types; __bases__[0].__name__ for FunctionType/GeneratorType/CoroutineType/AsyncGeneratorType/CodeType/FrameType/TracebackType/ModuleType/MethodType/SimpleNamespace"
    - "types_extra3.zspec.zsdl — covers EllipsisType/__name__/__module__/__bases__; NotImplementedType/__name__/__module__/__bases__; NoneType/__name__/__module__/__bases__; MappingProxyType/__name__/__module__; SimpleNamespace/__module__/__name__; class_modules table"
    - "types_extra4.zspec.zsdl — covers __name__ for FunctionType/CodeType/FrameType/TracebackType/ModuleType/MethodType/BuiltinFunctionType/MappingProxyType/CellType/NoneType (table); __module__ for FunctionType/CodeType/ModuleType/MappingProxyType/NoneType (table); SimpleNamespace __name__/__module__/instance; ModuleType/MappingProxyType instances"
    - "types_extra5.zspec.zsdl — covers __qualname__ for FunctionType/MethodType/GeneratorType/CoroutineType/ModuleType (table); BuiltinFunctionType/__qualname__; AsyncGeneratorType/__qualname__; LambdaType/__qualname__; SimpleNamespace/__qualname__; MappingProxyType/__qualname__; DynamicClassAttribute/__qualname__"
  notes:
    - "This spec adds: __qualname__ for types not yet covered in types_extra5 (CellType, CodeType, FrameType, TracebackType, NoneType, EllipsisType, NotImplementedType); __bases__[0].__name__ for types missing from types_extra2 table (BuiltinFunctionType, LambdaType, MethodType, MappingProxyType, NoneType already in extra3, CellType)."
    - "types_extra2 __bases__ table covers FunctionType/GeneratorType/CoroutineType/AsyncGeneratorType/CodeType/FrameType/TracebackType/ModuleType/MethodType/SimpleNamespace but NOT BuiltinFunctionType, LambdaType, MappingProxyType, CellType."
    - "types.CellType.__qualname__ == 'cell' — same as __name__; C-level type."
    - "types.CodeType.__qualname__ == 'code' — same as __name__; C-level type."
    - "types.FrameType.__qualname__ == 'frame' — same as __name__; C-level type."
    - "types.TracebackType.__qualname__ == 'traceback' — same as __name__; C-level type."
    - "types.NoneType.__qualname__ == 'NoneType' — same as __name__; C-level type."
    - "types.EllipsisType.__qualname__ == 'ellipsis' — same as __name__; C-level type."
    - "types.NotImplementedType.__qualname__ == 'NotImplementedType' — same as __name__; C-level type."
    - "types.BuiltinFunctionType.__bases__[0].__name__ == 'object'."
    - "types.LambdaType.__bases__[0].__name__ == 'object' — same as FunctionType, which is not in extra2 table."
    - "types.MappingProxyType.__bases__[0].__name__ == 'object'."
    - "types.CellType.__bases__[0].__name__ == 'object'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for types not covered in types_extra5
# types_extra5 covers FunctionType/MethodType/GeneratorType/CoroutineType/
# ModuleType (table) + BuiltinFunctionType/AsyncGeneratorType/LambdaType/
# SimpleNamespace/MappingProxyType/DynamicClassAttribute (standalone).
# New: CellType, CodeType, FrameType, TracebackType, NoneType,
#      EllipsisType, NotImplementedType.
# ---------------------------------------------------------------------------

table types_extra6.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [CellType,            CellType.__qualname__.__eq__,            ["cell"],                true]
    - [CodeType,            CodeType.__qualname__.__eq__,            ["code"],                true]
    - [FrameType,           FrameType.__qualname__.__eq__,           ["frame"],               true]
    - [TracebackType,       TracebackType.__qualname__.__eq__,       ["traceback"],           true]
    - [NoneType,            NoneType.__qualname__.__eq__,            ["NoneType"],            true]
    - [EllipsisType,        EllipsisType.__qualname__.__eq__,        ["ellipsis"],            true]
    - [NotImplementedType,  NotImplementedType.__qualname__.__eq__,  ["NotImplementedType"],  true]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ for types missing from types_extra2 table
# types_extra2 table covers: FunctionType, GeneratorType, CoroutineType,
# AsyncGeneratorType, CodeType, FrameType, TracebackType, ModuleType,
# MethodType, SimpleNamespace.
# Missing: BuiltinFunctionType, LambdaType, MappingProxyType, CellType.
# ---------------------------------------------------------------------------

invariant types_extra6.BuiltinFunctionType.base_is_object:
  description: "types.BuiltinFunctionType.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: BuiltinFunctionType.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant types_extra6.LambdaType.base_is_object:
  description: "types.LambdaType.__bases__[0].__name__ == 'object' — LambdaType aliases FunctionType"
  category: hierarchy
  kind: python_call_eq
  function: LambdaType.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant types_extra6.MappingProxyType.base_is_object:
  description: "types.MappingProxyType.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: MappingProxyType.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

invariant types_extra6.CellType.base_is_object:
  description: "types.CellType.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: CellType.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# CellType.__module__ == 'builtins'
# types_extra2 and types_extra3 do not cover CellType.__module__.
# CellType is a C-level type; its __module__ is 'builtins'.
# ---------------------------------------------------------------------------

invariant types_extra6.CellType.module:
  description: "types.CellType.__module__ == 'builtins' — CellType is a C-level builtin type"
  category: class_modules
  kind: python_call_eq
  function: CellType.__module__.__eq__
  args: ["builtins"]
  expected: true
