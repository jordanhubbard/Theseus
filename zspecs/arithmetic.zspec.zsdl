spec: arithmetic
version: ">=1.0.1"
backend: node(arithmetic)

docs: https://www.npmjs.com/package/arithmetic

provenance:
  derived_from:
    - "arithmetic README — https://www.npmjs.com/package/arithmetic"
    - "Test vectors verified with arithmetic via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "arithmetic source"
  notes:
    - "arithmetic is an npm package. Install: npm install arithmetic"
    - "Basic arithmetic functions: add, subtract, multiply, etc."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table arithmetic.add:
  kind: node_module_call_eq
  function: add
  category: math
  id_prefix: arith

  columns: [id, args, expected]
  rows:
    - [two,     [1, 2],   3]
    - [large,   [10, 20], 30]
    - [zeros,   [0, 0],   0]

