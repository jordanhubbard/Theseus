spec: inspect_extra231
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.ismethod, inspect.isfunction, inspect.ismodule, inspect.isclass, and inspect.isbuiltin predicate contracts with real arguments."
    - "inspect.ismethod.__name__ == 'ismethod' — top-level function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismethod.__module__ == 'inspect' — defined in the inspect module. Verified with Python 3.14.3."
    - "inspect.isfunction.__name__ == 'isfunction' — top-level function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismodule.__name__ == 'ismodule' — top-level function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isclass.__name__ == 'isclass' — top-level function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__name__ == 'isbuiltin' — top-level function in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.ismethod(None) == False — None is not a bound method. Verified with Python 3.14.3."
    - "inspect.isfunction(None) == False — None is not a Python function. Verified with Python 3.14.3."
    - "inspect.ismodule(None) == False — None is not a module. Verified with Python 3.14.3."
    - "inspect.isclass(None) == False — None is not a class. Verified with Python 3.14.3."
    - "inspect.isbuiltin(None) == False — None is not a built-in function. Verified with Python 3.14.3."
    - "inspect.isfunction(inspect.isfunction) == True — isfunction itself is a Python function. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.ismethod and inspect.isfunction identity contracts
#
# inspect.ismethod.__name__ == 'ismethod'
# inspect.ismethod.__module__ == 'inspect'
# inspect.ismethod.__qualname__ == 'ismethod'
# inspect.isfunction.__name__ == 'isfunction'
# inspect.isfunction.__module__ == 'inspect'
#
# New to extra231.
# ---------------------------------------------------------------------------

table inspect_extra231.ismethod_isfunction_identity:
  description: "inspect.ismethod and isfunction identity contracts: __name__, __module__, __qualname__, name lengths; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra231ismethisfuncid

  columns: [id, function, args, expected, description]
  rows:
    - [ismethod_name_eq,
       ismethod.__name__.__eq__,
       ["ismethod"],
       true,
       "inspect.ismethod.__name__ == 'ismethod' — ismethod is a top-level predicate function in Lib/inspect.py that returns True for bound methods; __name__.__eq__('ismethod') returns True; new to extra231"]
    - [ismethod_module_eq,
       ismethod.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismethod.__module__ == 'inspect' — ismethod is defined in the Python inspect module (Lib/inspect.py); __module__.__eq__('inspect') returns True; new to extra231"]
    - [ismethod_name_len_8,
       ismethod.__name__.__len__,
       [],
       8,
       "inspect.ismethod.__name__.__len__() == 8 — 'ismethod' has exactly 8 characters (i-s-m-e-t-h-o-d); __len__() returns 8; new to extra231"]
    - [isfunction_name_eq,
       isfunction.__name__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__name__ == 'isfunction' — isfunction is a top-level predicate function in Lib/inspect.py that returns True for Python functions; __name__.__eq__('isfunction') returns True; new to extra231"]
    - [isfunction_name_len_10,
       isfunction.__name__.__len__,
       [],
       10,
       "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has exactly 10 characters (i-s-f-u-n-c-t-i-o-n); __len__() returns 10; new to extra231"]

# ---------------------------------------------------------------------------
# Table 2: inspect.ismodule, inspect.isclass, inspect.isbuiltin identity contracts
#
# inspect.ismodule.__name__ == 'ismodule'
# inspect.ismodule.__module__ == 'inspect'
# inspect.isclass.__name__ == 'isclass'
# inspect.isbuiltin.__name__ == 'isbuiltin'
# inspect.isbuiltin.__name__.__len__() == 9
#
# New to extra231.
# ---------------------------------------------------------------------------

table inspect_extra231.ismodule_isclass_isbuiltin_identity:
  description: "inspect.ismodule, isclass, isbuiltin identity contracts: __name__, __module__, name lengths; new to extra231"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra231ismodclassbuiltid

  columns: [id, function, args, expected, description]
  rows:
    - [ismodule_name_eq,
       ismodule.__name__.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__name__ == 'ismodule' — ismodule is a top-level predicate function in Lib/inspect.py that returns True for module objects; __name__.__eq__('ismodule') returns True; new to extra231"]
    - [ismodule_module_eq,
       ismodule.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.ismodule.__module__ == 'inspect' — ismodule is defined in the Python inspect module (Lib/inspect.py); __module__.__eq__('inspect') returns True; new to extra231"]
    - [isclass_name_eq,
       isclass.__name__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__name__ == 'isclass' — isclass is a top-level predicate function in Lib/inspect.py that returns True for class objects; __name__.__eq__('isclass') returns True; new to extra231"]
    - [isbuiltin_name_eq,
       isbuiltin.__name__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__name__ == 'isbuiltin' — isbuiltin is a top-level predicate function in Lib/inspect.py that returns True for built-in functions; __name__.__eq__('isbuiltin') returns True; new to extra231"]
    - [isbuiltin_name_len_9,
       isbuiltin.__name__.__len__,
       [],
       9,
       "inspect.isbuiltin.__name__.__len__() == 9 — 'isbuiltin' has exactly 9 characters (i-s-b-u-i-l-t-i-n); __len__() returns 9; new to extra231"]

# ---------------------------------------------------------------------------
# Table 3: inspect predicate contracts with None argument (all return False)
#
# inspect.ismethod(None) == False
# inspect.isfunction(None) == False
# inspect.ismodule(None) == False
# inspect.isclass(None) == False
# inspect.isbuiltin(None) == False
#
# New to extra231.
# ---------------------------------------------------------------------------

table inspect_extra231.predicates_none_false:
  description: "inspect predicates all return False when called with None; new to extra231"
  kind: python_call_eq
  category: predicate
  id_prefix: inspectextra231prednone

  columns: [id, function, args, expected, description]
  rows:
    - [ismethod_none_false,
       ismethod,
       [null],
       false,
       "inspect.ismethod(None) == False — None is not a bound method; ismethod returns False for None; new to extra231"]
    - [isfunction_none_false,
       isfunction,
       [null],
       false,
       "inspect.isfunction(None) == False — None is not a Python function; isfunction returns False for None; new to extra231"]
    - [ismodule_none_false,
       ismodule,
       [null],
       false,
       "inspect.ismodule(None) == False — None is not a module object; ismodule returns False for None; new to extra231"]
    - [isclass_none_false,
       isclass,
       [null],
       false,
       "inspect.isclass(None) == False — None is not a class; isclass returns False for None; new to extra231"]
    - [isbuiltin_none_false,
       isbuiltin,
       [null],
       false,
       "inspect.isbuiltin(None) == False — None is not a built-in function; isbuiltin returns False for None; new to extra231"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra231
# ---------------------------------------------------------------------------

invariant inspect_extra231.ismethod_name_eq:
  description: "inspect.ismethod.__name__ == 'ismethod'; new to extra231"
  kind: python_call_eq
  function: ismethod.__name__.__eq__
  args: ["ismethod"]
  expected: true

invariant inspect_extra231.ismethod_module_eq:
  description: "inspect.ismethod.__module__ == 'inspect'; new to extra231"
  kind: python_call_eq
  function: ismethod.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra231.ismethod_name_len_8:
  description: "inspect.ismethod.__name__.__len__() == 8 — 'ismethod' has 8 characters; new to extra231"
  kind: python_call_eq
  function: ismethod.__name__.__len__
  args: []
  expected: 8

invariant inspect_extra231.isfunction_name_eq:
  description: "inspect.isfunction.__name__ == 'isfunction'; new to extra231"
  kind: python_call_eq
  function: isfunction.__name__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra231.isfunction_name_len_10:
  description: "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' has 10 characters; new to extra231"
  kind: python_call_eq
  function: isfunction.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra231.ismodule_name_eq:
  description: "inspect.ismodule.__name__ == 'ismodule'; new to extra231"
  kind: python_call_eq
  function: ismodule.__name__.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra231.ismodule_module_eq:
  description: "inspect.ismodule.__module__ == 'inspect'; new to extra231"
  kind: python_call_eq
  function: ismodule.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra231.isclass_name_eq:
  description: "inspect.isclass.__name__ == 'isclass'; new to extra231"
  kind: python_call_eq
  function: isclass.__name__.__eq__
  args: ["isclass"]
  expected: true

invariant inspect_extra231.isbuiltin_name_eq:
  description: "inspect.isbuiltin.__name__ == 'isbuiltin'; new to extra231"
  kind: python_call_eq
  function: isbuiltin.__name__.__eq__
  args: ["isbuiltin"]
  expected: true

invariant inspect_extra231.isbuiltin_name_len_9:
  description: "inspect.isbuiltin.__name__.__len__() == 9 — 'isbuiltin' has 9 characters; new to extra231"
  kind: python_call_eq
  function: isbuiltin.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra231.ismethod_none_false:
  description: "inspect.ismethod(None) == False — None is not a bound method; new to extra231"
  kind: python_call_eq
  function: ismethod
  args: [null]
  expected: false

invariant inspect_extra231.isfunction_none_false:
  description: "inspect.isfunction(None) == False — None is not a Python function; new to extra231"
  kind: python_call_eq
  function: isfunction
  args: [null]
  expected: false

invariant inspect_extra231.ismodule_none_false:
  description: "inspect.ismodule(None) == False — None is not a module; new to extra231"
  kind: python_call_eq
  function: ismodule
  args: [null]
  expected: false

invariant inspect_extra231.isclass_none_false:
  description: "inspect.isclass(None) == False — None is not a class; new to extra231"
  kind: python_call_eq
  function: isclass
  args: [null]
  expected: false

invariant inspect_extra231.isbuiltin_none_false:
  description: "inspect.isbuiltin(None) == False — None is not a built-in function; new to extra231"
  kind: python_call_eq
  function: isbuiltin
  args: [null]
  expected: false
