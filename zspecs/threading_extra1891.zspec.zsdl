spec: threading_extra1891
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "threading module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party threading extensions"
  notes:
    - "Tests unary arithmetic protocol and async iteration protocol membership in threading types"
    - "None of the threading types implement unary arithmetic dunder methods"
    - "None of the threading types implement async iteration protocol methods"
    - "Lock is a factory function returning _thread.lock; acquire/release/locked are on the underlying C type"
    - "acquire_lock and release_lock are aliases present on _thread.lock"
    - "RLock._is_owned is an internal method used by Condition"
    - "Condition.wait_for and Condition.notify_all are public API added in Python 3.2"
  created_at: "2026-04-12"

table threading_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["th1891-ua-001", "threading.Thread.__dict__.__contains__", ["__abs__"], false]
    - ["th1891-ua-002", "threading.Thread.__dict__.__contains__", ["__neg__"], false]
    - ["th1891-ua-003", "threading.Thread.__dict__.__contains__", ["__pos__"], false]
    - ["th1891-ua-004", "threading.Event.__dict__.__contains__", ["__abs__"], false]
    - ["th1891-ua-005", "threading.Condition.__dict__.__contains__", ["__abs__"], false]
    - ["th1891-ua-006", "threading.Semaphore.__dict__.__contains__", ["__abs__"], false]
    - ["th1891-ua-007", "threading.Barrier.__dict__.__contains__", ["__abs__"], false]
    - ["th1891-ua-008", "threading.Timer.__dict__.__contains__", ["__abs__"], false]

table threading_extra1891.async_iteration_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["th1891-ai-001", "threading.Thread.__dict__.__contains__", ["__aiter__"], false]
    - ["th1891-ai-002", "threading.Thread.__dict__.__contains__", ["__anext__"], false]
    - ["th1891-ai-003", "threading.Event.__dict__.__contains__", ["__aiter__"], false]
    - ["th1891-ai-004", "threading.Condition.__dict__.__contains__", ["__aiter__"], false]
    - ["th1891-ai-005", "threading.Semaphore.__dict__.__contains__", ["__aiter__"], false]
    - ["th1891-ai-006", "threading.Barrier.__dict__.__contains__", ["__aiter__"], false]
    - ["th1891-ai-007", "threading.local.__dict__.__contains__", ["__aiter__"], false]
    - ["th1891-ai-008", "threading.Timer.__dict__.__contains__", ["__aiter__"], false]

table threading_extra1891.threading_lock_acquire_release:
  columns: [id, function, args, expected]
  rows:
    - ["th1891-la-001", "threading.Lock.__class__.__dict__.__contains__", ["acquire"], true]
    - ["th1891-la-002", "threading.Lock.__class__.__dict__.__contains__", ["release"], true]
    - ["th1891-la-003", "threading.Lock.__class__.__dict__.__contains__", ["locked"], true]
    - ["th1891-la-004", "threading.Lock.__class__.__dict__.__contains__", ["acquire_lock"], true]
    - ["th1891-la-005", "threading.Lock.__class__.__dict__.__contains__", ["release_lock"], true]
    - ["th1891-la-006", "threading.RLock.__class__.__dict__.__contains__", ["acquire"], true]
    - ["th1891-la-007", "threading.RLock.__class__.__dict__.__contains__", ["release"], true]
    - ["th1891-la-008", "threading.RLock.__class__.__dict__.__contains__", ["_is_owned"], true]
    - ["th1891-la-009", "threading.Condition.__dict__.__contains__", ["wait_for"], true]
    - ["th1891-la-010", "threading.Condition.__dict__.__contains__", ["notify_all"], true]
