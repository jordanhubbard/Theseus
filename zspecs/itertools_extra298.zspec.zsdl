spec: itertools_extra298
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class identity — __name__, __module__, __bases__[0].__name__
#
# All itertools classes are C-level types. Their base is object.
# __module__ == 'itertools' for all of them.
# ---------------------------------------------------------------------------

invariant itertools_extra298.chain.name:
  description: "chain.__name__ == 'chain'"
  category: chain
  kind: python_call_eq
  function: chain.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra298.chain.module:
  description: "chain.__module__ == 'itertools'"
  category: chain
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra298.chain.base_is_object:
  description: "chain.__bases__[0].__name__ == 'object'"
  category: chain
  kind: python_call_eq
  function: chain.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant itertools_extra298.count.name:
  description: "count.__name__ == 'count'"
  category: count
  kind: python_call_eq
  function: count.__name__.__eq__
  args: ["count"]
