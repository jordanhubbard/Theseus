# ---------------------------------------------------------------------------
# module-level identity
#
# itertools.__name__ == 'itertools'
# itertools.__spec__.name == 'itertools'
# ---------------------------------------------------------------------------

invariant itertools_extra298.module.name:
  description: "itertools.__name__ == 'itertools'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra298.module.spec_name:
  description: "itertools.__spec__.name == 'itertools'"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["itertools"]
  expected: true
