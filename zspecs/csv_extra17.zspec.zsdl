spec: csv_extra17
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
    - "csv_extra16.zspec.zsdl — covers reader/writer __module__, Dialect/Error/excel/excel_tab __bases__[0].__name__ table, QUOTE_* __class__.__name__"
    - "csv_extra15.zspec.zsdl — covers reader/writer __name__; DictReader/DictWriter/Dialect/excel/excel_tab __name__ table; QUOTE_* integer values"
    - "csv_extra13.zspec.zsdl — covers Dialect.__bases__[0].__name__ and QUOTE_* __class__.__name__ table"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra16.zspec.zsdl."
    - "csv.DictReader.__bases__[0].__name__ == 'object' — DictReader directly subclasses object; verified at runtime."
    - "csv.DictWriter.__bases__[0].__name__ == 'object' — DictWriter directly subclasses object; verified at runtime."
    - "csv.DictReader.__module__ == 'csv' — DictReader is defined in the pure-Python csv module; verified at runtime."
    - "csv.DictWriter.__module__ == 'csv' — DictWriter is defined in the pure-Python csv module; verified at runtime."
    - "csv.Dialect.__module__ == 'csv' — Dialect is defined in the pure-Python csv module; verified at runtime."
    - "csv.Error.__module__ == '_csv' — Error is defined in the C extension _csv; verified at runtime."
    - "csv.excel.__module__ == 'csv' — excel is defined in the pure-Python csv module; verified at runtime."
    - "csv.excel_tab.__module__ == 'csv' — excel_tab is defined in the pure-Python csv module; verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# DictReader and DictWriter base class hierarchy
#
# csv.DictReader and csv.DictWriter both subclass object directly.
# csv_extra16 covers Dialect/Error/excel/excel_tab bases; DictReader and
# DictWriter have not been covered as __bases__[0].__name__ standalone
# invariants. Verified at runtime.
# ---------------------------------------------------------------------------

invariant csv_extra17.DictReader.base:
  description: "csv.DictReader.__bases__[0].__name__ == 'object' — DictReader subclasses object directly"
  category: class_hierarchy
  kind: python_call_eq
  function: "DictReader.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant csv_extra17.DictWriter.base:
  description: "csv.DictWriter.__bases__[0].__name__ == 'object' — DictWriter subclasses object directly"
  category: class_hierarchy
  kind: python_call_eq
  function: "DictWriter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ attributes — DictReader, DictWriter, Dialect, Error
#
# csv_extra16 checks reader.__module__ and writer.__module__ (both '_csv').
# DictReader, DictWriter, Dialect, excel, excel_tab are pure-Python and
# live in 'csv'. csv.Error is implemented in the C extension _csv so its
# __module__ is '_csv'. No prior csv spec covers class __module__ values
# in a table under the extra17 namespace.
# ---------------------------------------------------------------------------

invariant csv_extra17.Error.module:
  description: "csv.Error.__module__ == '_csv' — Error is a C type from the _csv extension"
  category: module_identity
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["_csv"]
  expected: true

invariant csv_extra17.Dialect.module:
  description: "csv.Dialect.__module__ == 'csv' — Dialect is defined in pure-Python csv"
  category: module_identity
  kind: python_call_eq
  function: Dialect.__module__.__eq__
  args: ["csv"]
  expected: true

table csv_extra17.class_modules:
  description: "__module__ for DictReader, DictWriter, excel, excel_tab"
  kind: python_call_eq
  category: module_identity
  id_prefix: cmod17

  columns: [id, function, args, expected]
  rows:
    - [DictReader_module,  DictReader.__module__.__eq__,  ["csv"], true]
    - [DictWriter_module,  DictWriter.__module__.__eq__,  ["csv"], true]
    - [excel_module,       excel.__module__.__eq__,       ["csv"], true]
    - [excel_tab_module,   excel_tab.__module__.__eq__,   ["csv"], true]
