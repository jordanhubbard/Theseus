spec: theseus_re_cr5
version: ">=3.9"
backend: python_cleanroom(theseus_re_cr5)
blocks: re

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html"
  notes:
    - "Clean-room extended regex utilities. Do NOT import re."
    - "compile(pattern, flags=0): return compiled regex pattern object."
    - "Pattern.sub(repl, string): substitute matches in string."
    - "Pattern.findall(string): return all non-overlapping matches."
    - "re5_compile_match(): compile('[0-9]+').match('123abc').group() == '123'."
    - "re5_compile_findall(): compile('\\w+').findall('hello world') == ['hello', 'world']."
    - "re5_compile_sub(): compile('\\d').sub('X', 'a1b2') == 'aXbX'."
    - "Zero-arg invariant signatures — def re5_compile_match(): return hardcoded_result"
    - "compile: return a Pattern object with match, search, findall, sub, split methods."
    - "Pattern.match: anchored at start of string; returns Match or None."
    - "Pattern.sub: replace each match with repl string."
    - "Export: compile, match, search, findall, sub, split, fullmatch, escape, Pattern, Match."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_re_cr5.compile_match:
  description: "compile('[0-9]+').match('123abc').group() == '123'"
  category: compile
  kind: python_call_eq
  function: re5_compile_match
  args: []
  expected: "123"

invariant theseus_re_cr5.compile_findall:
  description: "compile('\\w+').findall('hello world') == ['hello', 'world']"
  category: findall
  kind: python_call_eq
  function: re5_compile_findall
  args: []
  expected: ["hello", "world"]

invariant theseus_re_cr5.compile_sub:
  description: "compile('\\d').sub('X', 'a1b2') == 'aXbX'"
  category: sub
  kind: python_call_eq
  function: re5_compile_sub
  args: []
  expected: "aXbX"
