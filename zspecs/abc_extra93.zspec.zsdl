spec: abc_extra93
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra92

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra92.zspec.zsdl."
    - "This spec covers: wave 254 theme — abc ABCMeta.__subclasscheck__ and __instancecheck__ class names + abc.update_abstractmethods and get_cache_token identity. NEW in extra93: ABCMeta.__subclasscheck__.__class__.__name__=='function' (Python function, not wrapper_descriptor as in extra92 for __getattribute__/__call__); ABCMeta.__instancecheck__.__class__.__name__=='function'; ABCMeta.__new__.__class__.__name__=='function'; ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25); ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25); ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15); ABCMeta.__subclasscheck__.__code__.co_argcount==2; ABCMeta.__instancecheck__.__code__.co_argcount==2; ABCMeta.__new__.__code__.co_argcount==4; abc.update_abstractmethods.__module__=='abc'; abc.update_abstractmethods.__qualname__=='update_abstractmethods' (len=22); abc.get_cache_token.__module__=='_abc'; abc.get_cache_token.__class__.__name__=='builtin_function_or_method'; ABC.__subclasshook__.__class__.__name__=='builtin_function_or_method'; ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20); ABC.__doc__.__len__()==78. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__subclasscheck__.__class__.__name__ == 'function'. __subclasscheck__ and __instancecheck__ are Python functions defined in Lib/abc.py (not C-level wrapper_descriptors like __call__ or __getattribute__ which are inherited from type). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__module__ == '_abc'. get_cache_token is implemented in the C extension _abc, not Lib/abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "ABC.__doc__.__len__() == 78. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta.__subclasscheck__ and __instancecheck__ class names — extra93
#
# Wave 254 theme: ABCMeta.__subclasscheck__ / __instancecheck__ identity.
#
# ABCMeta.__subclasscheck__.__class__.__name__ == 'function'  (Python func, not C)
# ABCMeta.__instancecheck__.__class__.__name__ == 'function'
# ABCMeta.__new__.__class__.__name__ == 'function'
# ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25)
# ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25)
# ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15)
# ---------------------------------------------------------------------------

table abc_extra93.abcmeta_check_class_names:
  description: "ABCMeta.__subclasscheck__, __instancecheck__, and __new__ class name checks in abcmetacheck93 namespace — wave 254 theme: ABCMeta Python-defined dunder class names; ABCMeta.__subclasscheck__ and ABCMeta.__instancecheck__ are Python functions defined in Lib/abc.py (unlike __getattribute__ and __call__ which are C-level wrapper_descriptors inherited from type as checked in extra92); ABCMeta.__subclasscheck__.__class__.__name__.__eq__('function')==True; ABCMeta.__instancecheck__.__class__.__name__.__eq__('function')==True; ABCMeta.__new__.__class__.__name__.__eq__('function')==True; all three are Python-level functions in abc.py with __module__=='abc'; __subclasscheck__ and __instancecheck__ each take 2 args (cls, subclass/instance); __new__ takes 4 args (mcs, name, bases, namespace); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacheck93

  columns: [id, function, args, expected, description]
  rows:
    - [subclscheck_cls,  "ABCMeta.__subclasscheck__.__class__.__name__.__eq__", ["function"], true, "ABCMeta.__subclasscheck__.__class__.__name__ == 'function' — Python function in abc.py; not a C wrapper_descriptor; verified with Python 3.14.3"]
    - [instcheck_cls,    "ABCMeta.__instancecheck__.__class__.__name__.__eq__", ["function"], true, "ABCMeta.__instancecheck__.__class__.__name__ == 'function' — Python function in abc.py; verified with Python 3.14.3"]
    - [abcmeta_new_cls,  "ABCMeta.__new__.__class__.__name__.__eq__",           ["function"], true, "ABCMeta.__new__.__class__.__name__ == 'function' — Python function in abc.py; verified with Python 3.14.3"]
    - [subclscheck_mod,  "ABCMeta.__subclasscheck__.__module__.__eq__",         ["abc"],      true, "ABCMeta.__subclasscheck__.__module__ == 'abc'; defined in Lib/abc.py; verified with Python 3.14.3"]
    - [instcheck_mod,    "ABCMeta.__instancecheck__.__module__.__eq__",         ["abc"],      true, "ABCMeta.__instancecheck__.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abcmeta_new_mod,  "ABCMeta.__new__.__module__.__eq__",                   ["abc"],      true, "ABCMeta.__new__.__module__ == 'abc'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABCMeta check method __qualname__ equality — extra93
#
# ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25)
# ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25)
# ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15)
# ABCMeta.__subclasscheck__.__code__.co_argcount == 2
# ABCMeta.__instancecheck__.__code__.co_argcount == 2
# ABCMeta.__new__.__code__.co_argcount == 4
# ---------------------------------------------------------------------------

table abc_extra93.abcmeta_check_method_qualnames:
  description: "ABCMeta check method __qualname__ and co_argcount checks in abcmetacheck93 namespace — wave 254 theme: ABCMeta.__subclasscheck__ and __instancecheck__ are Python methods with full qualnames; ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__')==True (len=25; 'ABCMeta.' prefix 8 chars + '__subclasscheck__' 17 chars); ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__')==True (len=25, same length as __subclasscheck__); ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__')==True (len=15; much shorter: 'ABCMeta.__new__' = 8+7); __subclasscheck__ and __instancecheck__ each take 2 args (cls, C); __new__ takes 4 args (mcs, name, bases, namespace); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacheck93a

  columns: [id, function, args, expected, description]
  rows:
    - [subclscheck_qeq,   "ABCMeta.__subclasscheck__.__qualname__.__eq__",         ["ABCMeta.__subclasscheck__"], true, "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' (len=25); verified with Python 3.14.3"]
    - [subclscheck_qlen,  "ABCMeta.__subclasscheck__.__qualname__.__len__",         [],                           25,   "ABCMeta.__subclasscheck__.__qualname__.__len__() == 25; verified with Python 3.14.3"]
    - [instcheck_qeq,     "ABCMeta.__instancecheck__.__qualname__.__eq__",         ["ABCMeta.__instancecheck__"], true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' (len=25); verified with Python 3.14.3"]
    - [instcheck_qlen,    "ABCMeta.__instancecheck__.__qualname__.__len__",         [],                           25,   "ABCMeta.__instancecheck__.__qualname__.__len__() == 25 (same as __subclasscheck__); verified with Python 3.14.3"]
    - [abcmeta_new_qeq,   "ABCMeta.__new__.__qualname__.__eq__",                   ["ABCMeta.__new__"],           true, "ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15); verified with Python 3.14.3"]
    - [abcmeta_new_qlen,  "ABCMeta.__new__.__qualname__.__len__",                  [],                           15,   "ABCMeta.__new__.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [subclscheck_argc,  "ABCMeta.__subclasscheck__.__code__.co_argcount.__eq__", [2],                          true, "ABCMeta.__subclasscheck__.__code__.co_argcount == 2 (cls, C); verified with Python 3.14.3"]
    - [instcheck_argc,    "ABCMeta.__instancecheck__.__code__.co_argcount.__eq__", [2],                          true, "ABCMeta.__instancecheck__.__code__.co_argcount == 2 (cls, instance); verified with Python 3.14.3"]
    - [abcmeta_new_argc,  "ABCMeta.__new__.__code__.co_argcount.__eq__",           [4],                          true, "ABCMeta.__new__.__code__.co_argcount == 4 (mcs, name, bases, namespace); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.update_abstractmethods and get_cache_token identity — extra93
#
# abc.update_abstractmethods.__module__ == 'abc'
# abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' (len=22)
# abc.get_cache_token.__module__ == '_abc'
# abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'
# abc.get_cache_token.__qualname__ == 'get_cache_token' (len=15)
# ---------------------------------------------------------------------------

table abc_extra93.abc_utility_function_identity:
  description: "abc.update_abstractmethods and abc.get_cache_token identity checks in abcmetacheck93 namespace — wave 254 theme: abc utility function identity; abc.update_abstractmethods is a Python function in Lib/abc.py (added in Python 3.10); update_abstractmethods.__module__.__eq__('abc')==True; update_abstractmethods.__qualname__.__eq__('update_abstractmethods')==True (len=22, a module-level function so qualname equals name); abc.get_cache_token is implemented in the C extension Modules/_abc.c; get_cache_token.__module__.__eq__('_abc')==True (note: underscore prefix, the C extension module); get_cache_token.__class__.__name__.__eq__('builtin_function_or_method')==True (C-level function); get_cache_token.__qualname__.__eq__('get_cache_token')==True (len=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacheck93b

  columns: [id, function, args, expected, description]
  rows:
    - [updabs_module,   "abc.update_abstractmethods.__module__.__eq__",   ["abc"],                      true, "abc.update_abstractmethods.__module__ == 'abc'; Python function in Lib/abc.py; verified with Python 3.14.3"]
    - [updabs_qualname, "abc.update_abstractmethods.__qualname__.__eq__", ["update_abstractmethods"],   true, "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods' (len=22); verified with Python 3.14.3"]
    - [updabs_qlen,     "abc.update_abstractmethods.__qualname__.__len__", [],                          22,   "abc.update_abstractmethods.__qualname__.__len__() == 22; verified with Python 3.14.3"]
    - [token_module,    "abc.get_cache_token.__module__.__eq__",          ["_abc"],                     true, "abc.get_cache_token.__module__ == '_abc' — C extension module (note underscore prefix); verified with Python 3.14.3"]
    - [token_cls,       "abc.get_cache_token.__class__.__name__.__eq__",  ["builtin_function_or_method"], true, "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' — C-level function; verified with Python 3.14.3"]
    - [token_qualname,  "abc.get_cache_token.__qualname__.__eq__",        ["get_cache_token"],          true, "abc.get_cache_token.__qualname__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABC.__subclasshook__ and __doc__ attrs — extra93
#
# ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'
# ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20)
# ABC.__doc__.__len__() == 78
# ABCMeta.__doc__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table abc_extra93.abc_class_doc_attrs:
  description: "ABC.__subclasshook__ and doc attrs checks in abcmetacheck93 namespace — wave 254 theme: ABC.__subclasshook__ identity and docstring attrs; ABC.__subclasshook__ is a class method inherited from object (or abc.ABC definition), implemented at the C level; ABC.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==True; ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__')==True (len=20: 'ABC.' 4 chars + '__subclasshook__' 16 chars); ABC.__doc__.__len__()==78 (the ABC class docstring is 78 chars: 'Helper class that provides a standard way to create an ABC using\ninheritance.\n'); ABCMeta.__doc__.__class__.__name__.__eq__('str')==True (ABCMeta has a docstring which is a str object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacheck93c

  columns: [id, function, args, expected, description]
  rows:
    - [subhook_cls,      "ABC.__subclasshook__.__class__.__name__.__eq__",   ["builtin_function_or_method"], true, "ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C-level class method; verified with Python 3.14.3"]
    - [subhook_qeq,      "ABC.__subclasshook__.__qualname__.__eq__",         ["ABC.__subclasshook__"],       true, "ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20); verified with Python 3.14.3"]
    - [subhook_qlen,     "ABC.__subclasshook__.__qualname__.__len__",        [],                             20,   "ABC.__subclasshook__.__qualname__.__len__() == 20; verified with Python 3.14.3"]
    - [abc_doc_len,      "ABC.__doc__.__len__",                              [],                             78,   "ABC.__doc__.__len__() == 78 — ABC docstring is 78 chars; verified with Python 3.14.3"]
    - [abcmeta_doc_cls,  "ABCMeta.__doc__.__class__.__name__.__eq__",        ["str"],                        true, "ABCMeta.__doc__.__class__.__name__ == 'str' — ABCMeta has a string docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra93
# ---------------------------------------------------------------------------

invariant abc_extra93.ABCMeta_subclasscheck_is_python_function:
  description: "abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__('function') returns True — ABCMeta.__subclasscheck__ is a Python function defined in Lib/abc.py, NOT a C-level wrapper_descriptor; this distinguishes it from ABCMeta.__call__ and ABCMeta.__getattribute__ (checked in extra92) which ARE wrapper_descriptors inherited from type; __subclasscheck__ is called by Python's issubclass() builtin to dispatch to ABCMeta's custom logic; it takes 2 args (cls, C) where C is the potential subclass; its __qualname__ is 'ABCMeta.__subclasscheck__' (len=25); __module__ is 'abc'; NEW in extra93: first standalone ABCMeta.__subclasscheck__ class name invariant in abcmetacheck93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__subclasscheck__.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

invariant abc_extra93.ABCMeta_instancecheck_is_python_function:
  description: "abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__('function') returns True — ABCMeta.__instancecheck__ is a Python function defined in Lib/abc.py, called by Python's isinstance() builtin to implement virtual subclass checking; __instancecheck__ checks both real subclassing and virtual subclassing (via __subclasshook__); it takes 2 args (cls, instance); its __qualname__ is 'ABCMeta.__instancecheck__' (len=25, same length as ABCMeta.__subclasscheck__.__qualname__); both __subclasscheck__ and __instancecheck__ have the same qualname length reflecting symmetric design; NEW in extra93: first standalone ABCMeta.__instancecheck__ class name invariant in abcmetacheck93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__instancecheck__.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

invariant abc_extra93.get_cache_token_module_is_c_abc:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — abc.get_cache_token is implemented in the C extension module Modules/_abc.c (module name '_abc', with underscore prefix), not in Lib/abc.py; this distinguishes it from abstractmethod, update_abstractmethods, and ABCMeta which have __module__=='abc'; get_cache_token.__class__.__name__ is 'builtin_function_or_method' (a C-level function); get_cache_token returns an opaque token that changes each time the set of abstract classes is modified; NEW in extra93: first standalone get_cache_token module invariant in abcmetacheck93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abc.get_cache_token.__module__.__eq__"
  args: ["_abc"]
  expected: true

invariant abc_extra93.update_abstractmethods_qualname_eq:
  description: "abc.update_abstractmethods.__qualname__.__eq__('update_abstractmethods') returns True — update_abstractmethods is a module-level Python function in Lib/abc.py; for module-level functions, __qualname__ equals __name__ (both are 'update_abstractmethods'); the qualname length is 22 — one of the longer qualnames in the abc module; update_abstractmethods recalculates a class's __abstractmethods__ attribute and was added in Python 3.10 to support dataclass-like post-init decoration patterns; its __module__ is 'abc' (not '_abc'); contrast with get_cache_token which has module '_abc'; NEW in extra93: first standalone update_abstractmethods qualname invariant in abcmetacheck93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abc.update_abstractmethods.__qualname__.__eq__"
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra93.ABC_doc_len_is_78:
  description: "abc.ABC.__doc__.__len__() == 78 — ABC's docstring is exactly 78 characters: 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'; this docstring describes the purpose of ABC as a convenience class that uses ABCMeta as its metaclass; ABC was added in Python 3.4 to simplify creating abstract base classes via inheritance rather than metaclass= parameter; the docstring length 78 is a stable behavioral invariant of the abc.ABC class across Python versions; NEW in extra93: first standalone ABC.__doc__.__len__ invariant in abcmetacheck93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABC.__doc__.__len__"
  args: []
  expected: 78
