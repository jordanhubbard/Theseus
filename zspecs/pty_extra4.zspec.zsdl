spec: pty_extra4
version: ">=3.9"
backend: python_module(pty)

docs: https://docs.python.org/3/library/pty.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pty.html — Python pty module documentation"
    - "CPython source: Lib/pty.py (PSF; source inspection permitted)"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "pty internals: kernel TTY layer, file-descriptor allocation"
  notes:
    - "This spec extends pty.zspec.zsdl through pty_extra3.zspec.zsdl."
    - "pty covers: STDIN/STDOUT/STDERR_FILENO values and types, fork/openpty/spawn __name__ and __module__."
    - "pty_extra covers: function __name__/__module__/type tables, fd constant types and values, fork/spawn __qualname__."
    - "pty_extra2 covers: openpty __qualname__, CHILD value and type, spawn __doc__ is str, function qualnames table, fd ordering/non-negative/positive."
    - "pty_extra3 covers: module __name__, fork/openpty __doc__ is str, fork/openpty/spawn __code__ class, fd arithmetic (STDERR-STDIN/STDERR-STDOUT/STDOUT-STDIN)."
    - "New here: pty module __package__ and __loader__ class; pty.setraw/__module__ (imported from tty); pty.tcgetattr/__module__ and type (imported from termios); fork/__code__.co_name; STDIN+STDOUT+STDERR==3 sum; CHILD equals STDIN_FILENO."
    - "pty is a pure Python module; __loader__.__class__.__name__ == 'SourceFileLoader'."
    - "pty.setraw is imported from the tty module; its __module__ is 'tty'."
    - "pty.tcgetattr is imported from termios; it is a C builtin (builtin_function_or_method)."
    - "fork.__code__.co_name == 'fork' — the code object records the function's name."
    - "STDIN_FILENO + STDOUT_FILENO + STDERR_FILENO == 3 — arithmetic sum of 0+1+2."
    - "pty.CHILD == pty.STDIN_FILENO — both are 0; the child PID returned by fork() equals STDIN_FILENO."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __package__ and __loader__ class — not covered in any prior pty spec
# pty is a pure Python module; loader is SourceFileLoader (not ExtensionFileLoader).
# ---------------------------------------------------------------------------

invariant pty_extra4.module.package:
  description: "pty.__package__ == '' — pty is a top-level module with no parent package"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant pty_extra4.module.loader_class:
  description: "pty.__loader__.__class__.__name__ == 'SourceFileLoader' — pure Python module"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# pty.setraw — imported from tty; its __module__ is 'tty'
# Not covered in any prior pty spec.
# ---------------------------------------------------------------------------

invariant pty_extra4.setraw.module:
  description: "pty.setraw.__module__ == 'tty' — setraw is imported into pty from the tty module"
  category: imported_names
  kind: python_call_eq
  function: setraw.__module__.__eq__
  args: ["tty"]
  expected: true

# ---------------------------------------------------------------------------
# pty.tcgetattr — imported from termios; it is a C-level builtin
# Not covered in any prior pty spec (pty spec only checks fork/openpty/spawn).
# ---------------------------------------------------------------------------

invariant pty_extra4.tcgetattr.module:
  description: "pty.tcgetattr.__module__ == 'termios' — tcgetattr is imported into pty from termios"
  category: imported_names
  kind: python_call_eq
  function: tcgetattr.__module__.__eq__
  args: ["termios"]
  expected: true

invariant pty_extra4.tcgetattr.is_builtin:
  description: "pty.tcgetattr is a builtin_function_or_method — imported from the termios C extension"
  category: imported_names
  kind: python_call_eq
  function: tcgetattr.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# fork.__code__.co_name — code object records the function name
# pty_extra3 checks that __code__ is a 'code' object; co_name is a new axis.
# ---------------------------------------------------------------------------

invariant pty_extra4.fork.code_co_name:
  description: "pty.fork.__code__.co_name == 'fork' — code object co_name matches the function name"
  category: function_code
  kind: python_call_eq
  function: fork.__code__.co_name.__eq__
  args: ["fork"]
  expected: true

invariant pty_extra4.openpty.code_co_name:
  description: "pty.openpty.__code__.co_name == 'openpty' — code object co_name matches the function name"
  category: function_code
  kind: python_call_eq
  function: openpty.__code__.co_name.__eq__
  args: ["openpty"]
  expected: true

invariant pty_extra4.spawn.code_co_name:
  description: "pty.spawn.__code__.co_name == 'spawn' — code object co_name matches the function name"
  category: function_code
  kind: python_call_eq
  function: spawn.__code__.co_name.__eq__
  args: ["spawn"]
  expected: true

# ---------------------------------------------------------------------------
# STDIN_FILENO + STDOUT_FILENO + STDERR_FILENO == 3 — arithmetic sum
# Prior specs check pairwise differences and individual values.
# The sum 0+1+2 == 3 is a new arithmetic invariant not in any prior spec.
# ---------------------------------------------------------------------------

invariant pty_extra4.fd_arithmetic.stdin_add_stdout:
  description: "pty.STDIN_FILENO + pty.STDOUT_FILENO == 1 — sum of fd 0 and fd 1"
  category: constants
  kind: python_call_eq
  function: STDIN_FILENO.__add__
  args: [1]
  expected: 1

invariant pty_extra4.fd_arithmetic.stdout_add_stderr:
  description: "pty.STDOUT_FILENO + pty.STDERR_FILENO == 3 — sum of fd 1 and fd 2"
  category: constants
  kind: python_call_eq
  function: STDOUT_FILENO.__add__
  args: [2]
  expected: 3

# ---------------------------------------------------------------------------
# CHILD == STDIN_FILENO — both are zero; conceptually distinct constants
# Not covered in any prior spec (pty_extra2 checks CHILD==0 and STDIN_FILENO>=0
# as separate invariants, not their equality to each other).
# ---------------------------------------------------------------------------

invariant pty_extra4.CHILD.equals_STDIN_FILENO:
  description: "pty.CHILD == pty.STDIN_FILENO — both are 0; CHILD is the fork() return value in the child process"
  category: constants
  kind: python_call_eq
  function: CHILD.__eq__
  args: [0]
  method: __eq__
  method_args: [0]
  expected: true
