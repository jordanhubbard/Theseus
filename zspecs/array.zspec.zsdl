spec: array
version: ">=3.2"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "Python array documentation — https://docs.python.org/3/library/array.html"
    - "Test vectors verified by running Python 3.14.3 array module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
  notes:
    - "array.array(typecode, initializer) creates a typed array. Typecodes: b, B, h, H, i, I, l, L, q, Q, f, d."
    - "itemsize is the storage size of one element in bytes (platform-dependent for some typecodes)."
    - "'b' (signed char) itemsize=1, 'B' (unsigned char) itemsize=1, 'h' (short) itemsize=2."
    - "'i' (signed int) itemsize=4, 'd' (double) itemsize=8, 'f' (float) itemsize=4."
    - "'q' (long long) itemsize=8."
    - "tolist() converts the array to a plain Python list."
    - "count(x) returns the number of occurrences of x in the array."
    - "index(x) returns the index of the first occurrence of x."
    - "tobytes() returns a bytes object; not JSON-serializable so not tested here."
    - "All invariants call the array constructor via function: array with the class acting as a callable."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Signed int array ('i') — typecode, itemsize, element access, length, tolist
# ---------------------------------------------------------------------------

invariant array.int.typecode:
  description: "array.array('i', [1,2,3]).typecode == 'i'"
  category: int_array
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: typecode
  expected: "i"

invariant array.int.itemsize:
  description: "array.array('i', [1,2,3]).itemsize == 4 — signed int is 4 bytes"
  category: int_array
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: itemsize
  expected: 4

invariant array.int.len:
  description: "len(array.array('i', [1,2,3])) == 3"
  category: int_array
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: __len__
  method_args: []
  expected: 3

invariant array.int.getitem_first:
  description: "array.array('i', [1,2,3])[0] == 1"
  category: int_array
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3]]
  method: __getitem__
  method_args: [0]
  expected: 1

invariant array.int.getitem_last:
  description: "array.array('i', [10,20,30,40,50])[4] == 50"
  category: int_array
  kind: python_call_eq
  function: array
  args: ["i", [10, 20, 30, 40, 50]]
  method: __getitem__
  method_args: [4]
  expected: 50

invariant array.int.tolist:
  description: "array.array('i', [10,20,30]).tolist() == [10, 20, 30]"
  category: int_array
  kind: python_call_eq
  function: array
  args: ["i", [10, 20, 30]]
  method: tolist
  method_args: []
  expected: [10, 20, 30]

invariant array.int.count_single:
  description: "array.array('i', [1,2,3,4,5]).count(1) == 1"
  category: int_array
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3, 4, 5]]
  method: count
  method_args: [1]
  expected: 1

invariant array.int.count_duplicates:
  description: "array.array('i', [1,2,3,2,1]).count(2) == 2"
  category: int_array
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3, 2, 1]]
  method: count
  method_args: [2]
  expected: 2

invariant array.int.index:
  description: "array.array('i', [1,2,3,4,5]).index(3) == 2 — first occurrence of 3 is at position 2"
  category: int_array
  kind: python_call_eq
  function: array
  args: ["i", [1, 2, 3, 4, 5]]
  method: index
  method_args: [3]
  expected: 2

# ---------------------------------------------------------------------------
# Double array ('d') — typecode, itemsize, element access, tolist
# ---------------------------------------------------------------------------

invariant array.double.typecode:
  description: "array.array('d', [1.0, 2.5, 3.14]).typecode == 'd'"
  category: double_array
  kind: python_call_eq
  function: array
  args: ["d", [1.0, 2.5, 3.14]]
  method: typecode
  expected: "d"

invariant array.double.itemsize:
  description: "array.array('d', [1.0]).itemsize == 8 — double is 8 bytes"
  category: double_array
  kind: python_call_eq
  function: array
  args: ["d", [1.0]]
  method: itemsize
  expected: 8

invariant array.double.len:
  description: "len(array.array('d', [1.0, 2.5, 3.14])) == 3"
  category: double_array
  kind: python_call_eq
  function: array
  args: ["d", [1.0, 2.5, 3.14]]
  method: __len__
  method_args: []
  expected: 3

invariant array.double.getitem:
  description: "array.array('d', [1.0, 2.5, 3.14])[1] == 2.5"
  category: double_array
  kind: python_call_eq
  function: array
  args: ["d", [1.0, 2.5, 3.14]]
  method: __getitem__
  method_args: [1]
  expected: 2.5

# ---------------------------------------------------------------------------
# Signed char array ('b') — edge values: 127 (max), -128 (min), 0
# ---------------------------------------------------------------------------

invariant array.signed_char.typecode:
  description: "array.array('b', [127, -128, 0]).typecode == 'b'"
  category: signed_char_array
  kind: python_call_eq
  function: array
  args: ["b", [127, -128, 0]]
  method: typecode
  expected: "b"

invariant array.signed_char.itemsize:
  description: "array.array('b', [127]).itemsize == 1 — signed char is 1 byte"
  category: signed_char_array
  kind: python_call_eq
  function: array
  args: ["b", [127]]
  method: itemsize
  expected: 1

invariant array.signed_char.max_value:
  description: "array.array('b', [127, -128, 0])[0] == 127 — max signed char value"
  category: signed_char_array
  kind: python_call_eq
  function: array
  args: ["b", [127, -128, 0]]
  method: __getitem__
  method_args: [0]
  expected: 127

invariant array.signed_char.min_value:
  description: "array.array('b', [127, -128, 0])[1] == -128 — min signed char value"
  category: signed_char_array
  kind: python_call_eq
  function: array
  args: ["b", [127, -128, 0]]
  method: __getitem__
  method_args: [1]
  expected: -128

# ---------------------------------------------------------------------------
# Unsigned char array ('B') — values 0–255
# ---------------------------------------------------------------------------

invariant array.unsigned_char.typecode:
  description: "array.array('B', [65, 66, 67]).typecode == 'B'"
  category: unsigned_char_array
  kind: python_call_eq
  function: array
  args: ["B", [65, 66, 67]]
  method: typecode
  expected: "B"

invariant array.unsigned_char.itemsize:
  description: "array.array('B', [65]).itemsize == 1 — unsigned char is 1 byte"
  category: unsigned_char_array
  kind: python_call_eq
  function: array
  args: ["B", [65]]
  method: itemsize
  expected: 1

invariant array.unsigned_char.getitem:
  description: "array.array('B', [65, 66, 67])[0] == 65"
  category: unsigned_char_array
  kind: python_call_eq
  function: array
  args: ["B", [65, 66, 67]]
  method: __getitem__
  method_args: [0]
  expected: 65

invariant array.unsigned_char.tolist:
  description: "array.array('B', [65, 66, 67]).tolist() == [65, 66, 67]"
  category: unsigned_char_array
  kind: python_call_eq
  function: array
  args: ["B", [65, 66, 67]]
  method: tolist
  method_args: []
  expected: [65, 66, 67]

# ---------------------------------------------------------------------------
# Short array ('h') — typecode, itemsize, negative value
# ---------------------------------------------------------------------------

invariant array.short.typecode:
  description: "array.array('h', [100, 200, -1]).typecode == 'h'"
  category: short_array
  kind: python_call_eq
  function: array
  args: ["h", [100, 200, -1]]
  method: typecode
  expected: "h"

invariant array.short.itemsize:
  description: "array.array('h', [100]).itemsize == 2 — short is 2 bytes"
  category: short_array
  kind: python_call_eq
  function: array
  args: ["h", [100]]
  method: itemsize
  expected: 2

invariant array.short.negative_value:
  description: "array.array('h', [100, 200, -1])[2] == -1 — negative short value preserved"
  category: short_array
  kind: python_call_eq
  function: array
  args: ["h", [100, 200, -1]]
  method: __getitem__
  method_args: [2]
  expected: -1

# ---------------------------------------------------------------------------
# Long long array ('q') — typecode, itemsize, large integer
# ---------------------------------------------------------------------------

invariant array.longlong.typecode:
  description: "array.array('q', [9000000000]).typecode == 'q'"
  category: longlong_array
  kind: python_call_eq
  function: array
  args: ["q", [9000000000]]
  method: typecode
  expected: "q"

invariant array.longlong.itemsize:
  description: "array.array('q', [9000000000]).itemsize == 8 — long long is 8 bytes"
  category: longlong_array
  kind: python_call_eq
  function: array
  args: ["q", [9000000000]]
  method: itemsize
  expected: 8

invariant array.longlong.large_value:
  description: "array.array('q', [9000000000])[0] == 9000000000 — large int preserved in 64-bit slot"
  category: longlong_array
  kind: python_call_eq
  function: array
  args: ["q", [9000000000]]
  method: __getitem__
  method_args: [0]
  expected: 9000000000

# ---------------------------------------------------------------------------
# Float array ('f') — typecode, itemsize, tolist
# ---------------------------------------------------------------------------

invariant array.float.typecode:
  description: "array.array('f', [1.5, 2.5]).typecode == 'f'"
  category: float_array
  kind: python_call_eq
  function: array
  args: ["f", [1.5, 2.5]]
  method: typecode
  expected: "f"

invariant array.float.itemsize:
  description: "array.array('f', [1.5]).itemsize == 4 — single-precision float is 4 bytes"
  category: float_array
  kind: python_call_eq
  function: array
  args: ["f", [1.5]]
  method: itemsize
  expected: 4

invariant array.float.tolist:
  description: "array.array('f', [1.5, 2.5]).tolist() == [1.5, 2.5]"
  category: float_array
  kind: python_call_eq
  function: array
  args: ["f", [1.5, 2.5]]
  method: tolist
  method_args: []
  expected: [1.5, 2.5]
