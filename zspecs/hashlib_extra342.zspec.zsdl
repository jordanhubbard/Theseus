spec: hashlib_extra342
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "hashlib.__name__ == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__package__ == '' (empty string — hashlib is a top-level module, not a package). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.name == 'hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__class__.__name__ == 'tuple' (not 'list' — hashlib.__all__ is a tuple of 19 names). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__len__() == 19 (md5, sha1, sha224, sha256, sha384, sha512, blake2b, blake2s, sha3_224, sha3_256, sha3_384, sha3_512, shake_128, shake_256, new, algorithms_guaranteed, algorithms_available, file_digest, pbkdf2_hmac). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__('md5') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__contains__('sha256') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.__all__ is a tuple, not a list. This is unusual — most Python modules that define __all__ use a list. hashlib uses a tuple."
    - "Note: algorithms_guaranteed contains exactly 14 algorithms (confirmed): blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256."
    - "Note: algorithms_available is a set (not a tuple or list) — it may vary across platforms and OpenSSL builds, but always contains at minimum the algorithms_guaranteed set."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__name__.__eq__('hashlib')
# hashlib.__package__.__eq__('')
# hashlib.__spec__.name.__eq__('hashlib')
# hashlib.__doc__.__class__.__name__.__eq__('str')
#
# Wave 342 theme: hashlib module-level identity attributes.
#
# hashlib.__name__ is 'hashlib' — the canonical module name. hashlib.__package__
# is '' (empty string) confirming hashlib is a top-level module, not a subpackage.
# hashlib.__spec__.name is 'hashlib' — the ModuleSpec name matches __name__.
# hashlib.__doc__.__class__.__name__ is 'str' confirming the module has a docstring.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra342.module_identity_attrs:
  description: "hashlib.__name__.__eq__('hashlib')==True / __package__.__eq__('')==True / __spec__.name.__eq__('hashlib')==True / __doc__.__class__.__name__.__eq__('str')==True — hashlib is a top-level module (__package__==''); __spec__.name matches __name__; __doc__ is a str object confirming the module has a docstring; first hashlibid342 anchor for module identity attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibid342

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,          "__name__.__eq__",               ["hashlib"], true, "hashlib.__name__ is 'hashlib' — canonical module name"]
    - [package_eq,       "__package__.__eq__",            [""],        true, "hashlib.__package__ is '' (empty string) — hashlib is a top-level module, not a subpackage"]
    - [spec_name_eq,     "__spec__.name.__eq__",          ["hashlib"], true, "hashlib.__spec__.name is 'hashlib' — ModuleSpec name matches __name__"]
    - [doc_class_eq,     "__doc__.__class__.__name__.__eq__", ["str"], true, "hashlib.__doc__.__class__.__name__ is 'str' — module has a docstring"]

# ---------------------------------------------------------------------------
# hashlib.__all__.__class__.__name__.__eq__('tuple')
# hashlib.__all__.__len__()==19
#
# Wave 342 theme: hashlib.__all__ is a tuple of 19 entries.
#
# hashlib.__all__ is a tuple (not a list). It contains 19 names: the 14 hash
# constructor names (md5, sha1, sha224, sha256, sha384, sha512, blake2b,
# blake2s, sha3_224, sha3_256, sha3_384, sha3_512, shake_128, shake_256)
# plus new, algorithms_guaranteed, algorithms_available, file_digest,
# pbkdf2_hmac. Using a tuple for __all__ is unusual but valid in Python.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra342.all_tuple_attrs:
  description: "hashlib.__all__.__class__.__name__.__eq__('tuple')==True / __all__.__len__()==19 — hashlib.__all__ is a tuple (not a list), unusual for __all__ which is typically a list; contains 19 names including 14 hash constructors plus new/algorithms_guaranteed/algorithms_available/file_digest/pbkdf2_hmac; first hashlibid342 anchor for __all__ attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibid342

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_eq,  "__all__.__class__.__name__.__eq__", ["tuple"], true, "hashlib.__all__.__class__.__name__ is 'tuple' — hashlib uses a tuple for __all__ (unusual but valid)"]
    - [all_len,       "__all__.__len__",                   [],        19,   "hashlib.__all__ has 19 entries (14 hash constructors + new/algorithms_guaranteed/algorithms_available/file_digest/pbkdf2_hmac)"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__()==14
# hashlib.algorithms_available.__class__.__name__.__eq__('set')
# hashlib.algorithms_available.__contains__('md5')==True
# hashlib.algorithms_available.__contains__('sha256')==True
#
# Wave 342 theme: hashlib algorithm set attributes.
#
# algorithms_guaranteed is a frozenset (or set) with exactly 14 algorithms
# that every Python 3.9+ installation guarantees to have available.
# algorithms_available is a set that includes platform-specific extras from
# OpenSSL; it always contains at least the guaranteed set. Both 'md5' and
# 'sha256' are guaranteed members and therefore always available.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra342.algorithms_attrs:
  description: "hashlib.algorithms_guaranteed/__len__()==14 / algorithms_available/__class__.__name__.__eq__('set')==True / algorithms_available/__contains__('md5')==True / algorithms_available/__contains__('sha256')==True — algorithms_guaranteed has exactly 14 entries (the portable SHA-2, SHA-3, BLAKE2 and legacy MD5/SHA-1 suite); algorithms_available is a set that varies by platform/OpenSSL but always contains md5 and sha256; first hashlibid342 anchor for algorithm set attributes"
  kind: python_call_eq
  category: algorithm_sets
  id_prefix: hashlibid342

  columns: [id, function, args, expected, description]
  rows:
    - [guaranteed_len,       algorithms_guaranteed.__len__,                    [],         14,   "algorithms_guaranteed has 14 entries (portable SHA-2/SHA-3/BLAKE2/legacy suite)"]
    - [available_class_eq,   "algorithms_available.__class__.__name__.__eq__", ["set"],    true, "algorithms_available.__class__.__name__ is 'set' (mutable set, platform-specific)"]
    - [available_has_md5,    "algorithms_available.__contains__",              ["md5"],    true, "algorithms_available contains 'md5' (always present; guaranteed algorithm)"]
    - [available_has_sha256, "algorithms_available.__contains__",              ["sha256"], true, "algorithms_available contains 'sha256' (always present; guaranteed algorithm)"]

# ---------------------------------------------------------------------------
# hashlib.__name__.__eq__('hashlib') — standalone
#
# hashlib.__name__ is 'hashlib'. This is the canonical module name as assigned
# by the Python import system. For a standard library module like hashlib,
# __name__ equals the module's filename stem and its ModuleSpec name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra342.name_is_hashlib:
  description: "hashlib.__name__.__eq__('hashlib') == True — hashlib.__name__ is the canonical module name 'hashlib', matching its filename stem and ModuleSpec name; first standalone for hashlib.__name__ under hashlibid342"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__package__.__eq__('') — standalone
#
# hashlib.__package__ is '' (empty string). This confirms hashlib is a
# top-level module rather than a subpackage. For top-level modules,
# __package__ is the empty string; for subpackages it would contain the
# parent package name (e.g., 'email' for email.mime.text).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra342.package_is_empty:
  description: "hashlib.__package__.__eq__('') == True — hashlib.__package__ is the empty string confirming hashlib is a top-level module (not a subpackage); contrast with subpackage modules where __package__ names the parent; first standalone for hashlib.__package__ under hashlibid342"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__len__()==14 — standalone
#
# hashlib.algorithms_guaranteed.__len__() is 14. The 14 guaranteed algorithms
# are: blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224,
# sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256. These are
# guaranteed to be present in every Python 3.9+ implementation regardless
# of platform or OpenSSL version.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra342.algorithms_guaranteed_len_14:
  description: "hashlib.algorithms_guaranteed.__len__() == 14 — exactly 14 algorithms are guaranteed (blake2b, blake2s, md5, sha1, sha224, sha256, sha384, sha3_224, sha3_256, sha3_384, sha3_512, sha512, shake_128, shake_256); guaranteed across all Python 3.9+ implementations; first standalone for algorithms_guaranteed.__len__() under hashlibid342"
  category: algorithm_sets
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  expected: 14
