spec: threading_extra242
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra241.zspec.zsdl — covers Timer and main_thread identity"
    - "threading_extra240.zspec.zsdl — covers RLock factory function and _RLock.acquire/_RLock.release method identity"
    - "threading_extra2.zspec.zsdl — covers class __name__ checks for Thread/Lock/RLock/Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier"
    - "threading_extra.zspec.zsdl — covers module checks for synchronization primitives, local, get_ident, TIMEOUT_MAX, stack_size"
  notes:
    - "This spec covers threading.Semaphore and threading.BoundedSemaphore class identity contracts."
    - "threading.Semaphore.__name__ == 'Semaphore' (len=9) — Semaphore is a class in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading' (len=9) — Semaphore is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits directly from object. Verified with Python 3.14.3."
    - "threading.Semaphore.__class__.__name__ == 'type' — Semaphore is a class; its metaclass is type. Verified with Python 3.14.3."
    - "threading.Semaphore.__qualname__ == 'Semaphore' (len=9) — same as __name__ for top-level class. Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__name__ == 'acquire' (len=7) — acquire is a Python method of Semaphore. Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len=17) — acquire is a method of Semaphore class. Verified with Python 3.14.3."
    - "threading.Semaphore.release.__name__ == 'release' (len=7) — release is a Python method of Semaphore. Verified with Python 3.14.3."
    - "threading.Semaphore.release.__qualname__ == 'Semaphore.release' (len=17) — release is a method of Semaphore class. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16) — BoundedSemaphore is a class in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__module__ == 'threading' (len=9) — BoundedSemaphore is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore inherits from Semaphore. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__class__.__name__ == 'type' — BoundedSemaphore is a class; its metaclass is type. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.release.__qualname__ == 'BoundedSemaphore.release' (len=24) — BoundedSemaphore overrides release. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.acquire inherits from Semaphore: acquire.__qualname__ == 'Semaphore.acquire'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Semaphore identity contracts
#
# threading.Semaphore.__name__ == 'Semaphore' (len=9)
# threading.Semaphore.__module__ == 'threading' (len=9)
# threading.Semaphore.__bases__[0].__name__ == 'object'
# threading.Semaphore.__class__.__name__ == 'type'
# threading.Semaphore.__qualname__ == 'Semaphore' (len=9)
#
# Semaphore is a class in Lib/threading.py. New to extra242.
# ---------------------------------------------------------------------------

table threading_extra242.sem242_identity:
  description: "threading.Semaphore identity: name, module, bases, class, qualname; new to extra242"
  kind: python_call_eq
  category: identity
  id_prefix: sem242

  columns: [id, function, args, expected, description]
  rows:
    - [sem_name_eq,
       Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is a class in Lib/threading.py; __name__ is 'Semaphore' (len=9); new to extra242"]
    - [sem_name_len_9,
       Semaphore.__name__.__len__,
       [],
       9,
       "threading.Semaphore.__name__.__len__() == 9 — 'Semaphore' has exactly 9 characters; str.__len__() returns 9; new to extra242"]
    - [sem_module_eq,
       Semaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra242"]
    - [sem_module_len_9,
       Semaphore.__module__.__len__,
       [],
       9,
       "threading.Semaphore.__module__.__len__() == 9 — 'threading' has exactly 9 characters; str.__len__() returns 9; new to extra242"]
    - [sem_bases_0_is_object,
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — Semaphore inherits directly from object; __bases__[0] is object; new to extra242"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore class, qualname, doc contracts
#
# threading.Semaphore.__class__.__name__ == 'type'
# threading.Semaphore.__qualname__ == 'Semaphore' (len=9)
# threading.Semaphore.__doc__.__contains__('semaphore') == True
# threading.Semaphore.__qualname__.__len__() == 9
# threading.Semaphore.__module__.__contains__('threading') == True
#
# New to extra242.
# ---------------------------------------------------------------------------

table threading_extra242.sem242_class:
  description: "threading.Semaphore class, qualname, doc checks; new to extra242"
  kind: python_call_eq
  category: identity
  id_prefix: sem242cls

  columns: [id, function, args, expected, description]
  rows:
    - [sem_class_is_type,
       Semaphore.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Semaphore.__class__.__name__.__eq__('type') == True — Semaphore is a class; its metaclass is the built-in type; new to extra242"]
    - [sem_qualname_eq,
       Semaphore.__qualname__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__qualname__.__eq__('Semaphore') == True — __qualname__ is 'Semaphore' (len=9); same as __name__ for top-level class; new to extra242"]
    - [sem_qualname_len_9,
       Semaphore.__qualname__.__len__,
       [],
       9,
       "threading.Semaphore.__qualname__.__len__() == 9 — 'Semaphore' has exactly 9 characters; str.__len__() returns 9; new to extra242"]
    - [sem_doc_contains_semaphore,
       Semaphore.__doc__.__contains__,
       ["semaphore"],
       true,
       "threading.Semaphore.__doc__.__contains__('semaphore') == True — docstring says 'This class implements semaphore objects'; new to extra242"]
    - [sem_module_contains_threading,
       Semaphore.__module__.__contains__,
       ["threading"],
       true,
       "threading.Semaphore.__module__.__contains__('threading') == True — 'threading' contains the substring 'threading'; new to extra242"]

# ---------------------------------------------------------------------------
# Table 3: threading.Semaphore acquire/release method identity contracts
#
# threading.Semaphore.acquire.__name__ == 'acquire' (len=7)
# threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len=17)
# threading.Semaphore.release.__name__ == 'release' (len=7)
# threading.Semaphore.release.__qualname__ == 'Semaphore.release' (len=17)
# threading.Semaphore.acquire.__class__.__name__ == 'function'
#
# New to extra242.
# ---------------------------------------------------------------------------

table threading_extra242.sem242m_identity:
  description: "threading.Semaphore.acquire and release method identity; new to extra242"
  kind: python_call_eq
  category: identity
  id_prefix: sem242m

  columns: [id, function, args, expected, description]
  rows:
    - [acquire_name_eq,
       Semaphore.acquire.__name__.__eq__,
       ["acquire"],
       true,
       "threading.Semaphore.acquire.__name__.__eq__('acquire') == True — acquire is a Python method of Semaphore in Lib/threading.py; __name__ is 'acquire' (len=7); new to extra242"]
    - [acquire_qualname_eq,
       Semaphore.acquire.__qualname__.__eq__,
       ["Semaphore.acquire"],
       true,
       "threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') == True — acquire is a method of Semaphore; __qualname__ is 'Semaphore.acquire' (len=17); new to extra242"]
    - [release_name_eq,
       Semaphore.release.__name__.__eq__,
       ["release"],
       true,
       "threading.Semaphore.release.__name__.__eq__('release') == True — release is a Python method of Semaphore in Lib/threading.py; __name__ is 'release' (len=7); new to extra242"]
    - [release_qualname_eq,
       Semaphore.release.__qualname__.__eq__,
       ["Semaphore.release"],
       true,
       "threading.Semaphore.release.__qualname__.__eq__('Semaphore.release') == True — release is a method of Semaphore; __qualname__ is 'Semaphore.release' (len=17); new to extra242"]
    - [acquire_class_is_function,
       Semaphore.acquire.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Semaphore.acquire.__class__.__name__.__eq__('function') == True — acquire is a Python function; its __class__ is the built-in function type; new to extra242"]

# ---------------------------------------------------------------------------
# Table 4: threading.BoundedSemaphore identity contracts
#
# threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16)
# threading.BoundedSemaphore.__module__ == 'threading' (len=9)
# threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
# threading.BoundedSemaphore.__class__.__name__ == 'type'
# threading.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' (len=16)
#
# BoundedSemaphore is a class in Lib/threading.py that inherits from Semaphore. New to extra242.
# ---------------------------------------------------------------------------

table threading_extra242.bsem242_identity:
  description: "threading.BoundedSemaphore identity: name, module, bases, class, qualname; new to extra242"
  kind: python_call_eq
  category: identity
  id_prefix: bsem242

  columns: [id, function, args, expected, description]
  rows:
    - [bsem_name_eq,
       BoundedSemaphore.__name__.__eq__,
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — BoundedSemaphore is a class in Lib/threading.py; __name__ is 'BoundedSemaphore' (len=16); new to extra242"]
    - [bsem_name_len_16,
       BoundedSemaphore.__name__.__len__,
       [],
       16,
       "threading.BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has exactly 16 characters; str.__len__() returns 16; new to extra242"]
    - [bsem_module_eq,
       BoundedSemaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.BoundedSemaphore.__module__.__eq__('threading') == True — BoundedSemaphore is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra242"]
    - [bsem_bases_0_is_semaphore,
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore inherits from Semaphore; __bases__[0].__name__ is 'Semaphore'; new to extra242"]
    - [bsem_class_is_type,
       BoundedSemaphore.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.BoundedSemaphore.__class__.__name__.__eq__('type') == True — BoundedSemaphore is a class; its metaclass is the built-in type; new to extra242"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra242
# ---------------------------------------------------------------------------

invariant threading_extra242.sem_name_eq:
  description: "threading.Semaphore.__name__ == 'Semaphore' (len=9); new to extra242"
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra242.sem_name_len_9:
  description: "threading.Semaphore.__name__.__len__() == 9 — 'Semaphore' has 9 characters; new to extra242"
  kind: python_call_eq
  function: Semaphore.__name__.__len__
  args: []
  expected: 9

invariant threading_extra242.sem_module_eq:
  description: "threading.Semaphore.__module__ == 'threading' — defined in Lib/threading.py; new to extra242"
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra242.sem_module_len_9:
  description: "threading.Semaphore.__module__.__len__() == 9 — 'threading' has 9 characters; new to extra242"
  kind: python_call_eq
  function: Semaphore.__module__.__len__
  args: []
  expected: 9

invariant threading_extra242.sem_bases_0_is_object:
  description: "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits from object; new to extra242"
  kind: python_call_eq
  function: "Semaphore.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra242.sem_class_is_type:
  description: "threading.Semaphore.__class__.__name__ == 'type'; new to extra242"
  kind: python_call_eq
  function: Semaphore.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra242.sem_qualname_eq:
  description: "threading.Semaphore.__qualname__ == 'Semaphore' (len=9); new to extra242"
  kind: python_call_eq
  function: Semaphore.__qualname__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra242.acquire_name_eq:
  description: "threading.Semaphore.acquire.__name__ == 'acquire' (len=7); new to extra242"
  kind: python_call_eq
  function: Semaphore.acquire.__name__.__eq__
  args: ["acquire"]
  expected: true

invariant threading_extra242.acquire_qualname_eq:
  description: "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire' (len=17); new to extra242"
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true

invariant threading_extra242.acquire_qualname_len_17:
  description: "threading.Semaphore.acquire.__qualname__.__len__() == 17 — 'Semaphore.acquire' has 17 characters; new to extra242"
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__len__
  args: []
  expected: 17

invariant threading_extra242.release_name_eq:
  description: "threading.Semaphore.release.__name__ == 'release' (len=7); new to extra242"
  kind: python_call_eq
  function: Semaphore.release.__name__.__eq__
  args: ["release"]
  expected: true

invariant threading_extra242.release_qualname_eq:
  description: "threading.Semaphore.release.__qualname__ == 'Semaphore.release' (len=17); new to extra242"
  kind: python_call_eq
  function: Semaphore.release.__qualname__.__eq__
  args: ["Semaphore.release"]
  expected: true

invariant threading_extra242.bsem_name_eq:
  description: "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len=16); new to extra242"
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant threading_extra242.bsem_name_len_16:
  description: "threading.BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has 16 characters; new to extra242"
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__len__
  args: []
  expected: 16

invariant threading_extra242.bsem_module_eq:
  description: "threading.BoundedSemaphore.__module__ == 'threading' — defined in Lib/threading.py; new to extra242"
  kind: python_call_eq
  function: BoundedSemaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra242.bsem_bases_0_is_semaphore:
  description: "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'; new to extra242"
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant threading_extra242.bsem_class_is_type:
  description: "threading.BoundedSemaphore.__class__.__name__ == 'type'; new to extra242"
  kind: python_call_eq
  function: BoundedSemaphore.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra242.bsem_release_qualname_eq:
  description: "threading.BoundedSemaphore.release.__qualname__ == 'BoundedSemaphore.release' (len=24); new to extra242"
  kind: python_call_eq
  function: BoundedSemaphore.release.__qualname__.__eq__
  args: ["BoundedSemaphore.release"]
  expected: true

invariant threading_extra242.bsem_acquire_qualname_eq:
  description: "threading.BoundedSemaphore.acquire.__qualname__ == 'Semaphore.acquire' — inherits from Semaphore; new to extra242"
  kind: python_call_eq
  function: BoundedSemaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true
