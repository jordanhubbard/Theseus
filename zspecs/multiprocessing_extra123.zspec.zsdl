spec: multiprocessing_extra123
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers: wave 256 theme — multiprocessing.Process class identity and method qualnames. NEW in extra123: multiprocessing.Process.__class__.__name__=='type'; Process.__name__=='Process' (len=7); Process.__qualname__=='Process' (len=7); Process.__module__=='multiprocessing.context'; Process.__bases__[0].__name__=='BaseProcess'; Process.__mro__.__len__()==3; Process.start.__qualname__=='BaseProcess.start' (len=17, inherited); Process.run.__qualname__=='BaseProcess.run' (len=15, shortest); Process.join.__qualname__=='BaseProcess.join' (len=16, tied with kill); Process.terminate.__qualname__=='BaseProcess.terminate' (len=21, longest); Process.kill.__qualname__=='BaseProcess.kill' (len=16, tied with join); Process.is_alive.__qualname__=='BaseProcess.is_alive' (len=20, tied with __init__); Process.__init__.__qualname__=='BaseProcess.__init__' (len=20, all methods are class='function' in multiprocessing.process module). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context'. Process is defined in Lib/multiprocessing/context.py (not process.py); the actual method implementations are in BaseProcess (defined in process.py). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All Process methods use 'BaseProcess.' qualname prefix (len=12). Process inherits all core methods from BaseProcess; the qualname reflects the defining class (BaseProcess), not the accessing class (Process). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Process.__init__.__qualname__ == 'BaseProcess.__init__' (len=20, tied with is_alive). __init__ is also defined in BaseProcess, not Process itself. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process class identity — extra123
#
# Wave 256 theme: multiprocessing.Process class identity and method qualnames.
#
# Process.__class__.__name__       == 'type'
# Process.__name__                 == 'Process'     (len=7)
# Process.__qualname__             == 'Process'     (len=7)
# Process.__module__               == 'multiprocessing.context'
# Process.__bases__[0].__name__    == 'BaseProcess'
# Process.__mro__.__len__()        == 3
# ---------------------------------------------------------------------------

table multiprocessing_extra123.mp_process_class_identity:
  description: "multiprocessing.Process class identity checks in mpprocident123 namespace — wave 256 theme: multiprocessing.Process is a class (metaclass is type); Process.__class__.__name__.__eq__('type')==True (Process is a class, not a bound method — contrast with multiprocessing.Queue which is class='method'); Process.__name__.__eq__('Process')==True (len=7: 'Process'=7); Process.__name__.__len__()==7; Process.__qualname__.__eq__('Process')==True (len=7, qualname equals name for module-level classes); Process.__qualname__.__len__()==7; Process.__module__.__eq__('multiprocessing.context')==True (defined in Lib/multiprocessing/context.py, not process.py where the actual implementations live); Process.__bases__[0].__name__.__eq__('BaseProcess')==True (Process directly inherits from BaseProcess defined in Lib/multiprocessing/process.py); Process.__mro__.__len__()==3 ([Process, BaseProcess, object]: 3-element MRO with BaseProcess as intermediate); BaseProcess.__name__ is 'BaseProcess' (len=11) and BaseProcess.__mro__.__len__()==2 ([BaseProcess, object]); all Process methods are class='function' (pure-Python in process.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocident123

  columns: [id, function, args, expected, description]
  rows:
    - [proc_cls,      multiprocessing.Process.__class__.__name__.__eq__,    ["type"],                       true, "Process.__class__.__name__ == 'type' (metaclass is type, Process is a class); verified with Python 3.14.3"]
    - [proc_nm_eq,    multiprocessing.Process.__name__.__eq__,               ["Process"],                    true, "Process.__name__ == 'Process' (len=7); verified with Python 3.14.3"]
    - [proc_nm_len,   multiprocessing.Process.__name__.__len__,              [],                             7,    "Process.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [proc_qn_eq,    multiprocessing.Process.__qualname__.__eq__,           ["Process"],                    true, "Process.__qualname__ == 'Process' (len=7, qualname equals name); verified with Python 3.14.3"]
    - [proc_qn_len,   multiprocessing.Process.__qualname__.__len__,          [],                             7,    "Process.__qualname__.__len__() == 7; verified with Python 3.14.3"]
    - [proc_mod_eq,   multiprocessing.Process.__module__.__eq__,             ["multiprocessing.context"],    true, "Process.__module__ == 'multiprocessing.context' (defined in context.py); verified with Python 3.14.3"]
    - [proc_base0,    "multiprocessing.Process.__bases__[0].__name__.__eq__", ["BaseProcess"],                true, "Process.__bases__[0].__name__ == 'BaseProcess' (inherits from BaseProcess); verified with Python 3.14.3"]
    - [proc_mro_len,  multiprocessing.Process.__mro__.__len__,               [],                             3,    "Process.__mro__.__len__() == 3 ([Process, BaseProcess, object]); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Process method qualnames — extra123
#
# Process.start.__qualname__     == 'BaseProcess.start'     (len=17)
# Process.run.__qualname__       == 'BaseProcess.run'       (len=15, shortest)
# Process.join.__qualname__      == 'BaseProcess.join'      (len=16)
# Process.terminate.__qualname__ == 'BaseProcess.terminate' (len=21, longest)
# Process.kill.__qualname__      == 'BaseProcess.kill'      (len=16, tied with join)
# Process.is_alive.__qualname__  == 'BaseProcess.is_alive'  (len=20)
# Process.__init__.__qualname__  == 'BaseProcess.__init__'  (len=20, tied with is_alive)
# All methods have class='function' and module='multiprocessing.process'
# ---------------------------------------------------------------------------

table multiprocessing_extra123.mp_process_method_qualnames:
  description: "multiprocessing.Process method __qualname__ checks in mpprocident123 namespace — wave 256 theme: all Process core methods are inherited from BaseProcess and use 'BaseProcess.' qualname prefix (len=12); Process.start.__qualname__.__eq__('BaseProcess.start')==True (len=17: 'BaseProcess.'=12+'start'=5); Process.start.__qualname__.__len__()==17; Process.run.__qualname__.__eq__('BaseProcess.run')==True (len=15: 'BaseProcess.'=12+'run'=3, shortest method qualname in spec); Process.run.__qualname__.__len__()==15; Process.join.__qualname__.__eq__('BaseProcess.join')==True (len=16: 'BaseProcess.'=12+'join'=4); Process.terminate.__qualname__.__eq__('BaseProcess.terminate')==True (len=21: 'BaseProcess.'=12+'terminate'=9, longest method qualname in spec); Process.terminate.__qualname__.__len__()==21; Process.kill.__qualname__.__eq__('BaseProcess.kill')==True (len=16: tied with join: 'BaseProcess.'=12+'kill'=4); Process.is_alive.__qualname__.__eq__('BaseProcess.is_alive')==True (len=20: 'BaseProcess.'=12+'is_alive'=8, tied with __init__); Process.is_alive.__qualname__.__len__()==20; Process.__init__.__qualname__.__eq__('BaseProcess.__init__')==True (len=20: 'BaseProcess.'=12+'__init__'=8, tied with is_alive; __init__ is defined in BaseProcess, not Process); all methods have class='function' and __module__='multiprocessing.process'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocident123a

  columns: [id, function, args, expected, description]
  rows:
    - [proc_start_qeq,  multiprocessing.Process.start.__qualname__.__eq__,     ["BaseProcess.start"],     true, "Process.start.__qualname__ == 'BaseProcess.start' (len=17, inherited from BaseProcess); verified with Python 3.14.3"]
    - [proc_start_qlen, multiprocessing.Process.start.__qualname__.__len__,    [],                        17,   "Process.start.__qualname__.__len__() == 17 ('BaseProcess.'=12+'start'=5); verified with Python 3.14.3"]
    - [proc_run_qeq,    multiprocessing.Process.run.__qualname__.__eq__,       ["BaseProcess.run"],       true, "Process.run.__qualname__ == 'BaseProcess.run' (len=15, shortest in spec); verified with Python 3.14.3"]
    - [proc_run_qlen,   multiprocessing.Process.run.__qualname__.__len__,      [],                        15,   "Process.run.__qualname__.__len__() == 15 ('BaseProcess.'=12+'run'=3); verified with Python 3.14.3"]
    - [proc_join_qeq,   multiprocessing.Process.join.__qualname__.__eq__,      ["BaseProcess.join"],      true, "Process.join.__qualname__ == 'BaseProcess.join' (len=16, tied with kill); verified with Python 3.14.3"]
    - [proc_join_qlen,  multiprocessing.Process.join.__qualname__.__len__,     [],                        16,   "Process.join.__qualname__.__len__() == 16 ('BaseProcess.'=12+'join'=4); verified with Python 3.14.3"]
    - [proc_term_qeq,   multiprocessing.Process.terminate.__qualname__.__eq__,  ["BaseProcess.terminate"], true, "Process.terminate.__qualname__ == 'BaseProcess.terminate' (len=21, longest in spec); verified with Python 3.14.3"]
    - [proc_term_qlen,  multiprocessing.Process.terminate.__qualname__.__len__, [],                        21,   "Process.terminate.__qualname__.__len__() == 21 ('BaseProcess.'=12+'terminate'=9); verified with Python 3.14.3"]
    - [proc_kill_qeq,   multiprocessing.Process.kill.__qualname__.__eq__,      ["BaseProcess.kill"],      true, "Process.kill.__qualname__ == 'BaseProcess.kill' (len=16, tied with join); verified with Python 3.14.3"]
    - [proc_alive_qeq,  multiprocessing.Process.is_alive.__qualname__.__eq__,  ["BaseProcess.is_alive"],  true, "Process.is_alive.__qualname__ == 'BaseProcess.is_alive' (len=20, tied with __init__); verified with Python 3.14.3"]
    - [proc_alive_qlen, multiprocessing.Process.is_alive.__qualname__.__len__, [],                        20,   "Process.is_alive.__qualname__.__len__() == 20 ('BaseProcess.'=12+'is_alive'=8); verified with Python 3.14.3"]
    - [proc_init_qeq,   multiprocessing.Process.__init__.__qualname__.__eq__,  ["BaseProcess.__init__"],  true, "Process.__init__.__qualname__ == 'BaseProcess.__init__' (len=20, __init__ defined in BaseProcess, not Process); verified with Python 3.14.3"]
    - [proc_init_qlen,  multiprocessing.Process.__init__.__qualname__.__len__, [],                        20,   "Process.__init__.__qualname__.__len__() == 20 ('BaseProcess.'=12+'__init__'=8, tied with is_alive); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Process method class names and modules — extra123
#
# All inherited methods have class='function' (pure-Python)
# All inherited methods have __module__='multiprocessing.process'
# Process.start.__class__.__name__ == 'function'
# Process.terminate.__class__.__name__ == 'function'
# Process.start.__module__ == 'multiprocessing.process'
# Process.terminate.__module__ == 'multiprocessing.process'
# ---------------------------------------------------------------------------

table multiprocessing_extra123.mp_process_method_class_names:
  description: "multiprocessing.Process method class names and __module__ checks in mpprocident123 namespace — wave 256 theme: all Process methods are pure-Python functions (class='function') defined in Lib/multiprocessing/process.py; Process.start.__class__.__name__.__eq__('function')==True (pure-Python method inherited from BaseProcess); Process.terminate.__class__.__name__.__eq__('function')==True (same pattern); Process.kill.__class__.__name__.__eq__('function')==True; Process.is_alive.__class__.__name__.__eq__('function')==True; Process.start.__module__.__eq__('multiprocessing.process')==True (the module where BaseProcess and its methods are defined, even though Process itself is in multiprocessing.context); Process.terminate.__module__.__eq__('multiprocessing.process')==True (same defining module for all inherited methods); contrast with asyncio.Task methods which are C-level 'method_descriptor' (not 'function') because Task is a C extension class; all six method class names are 'function' and all modules are 'multiprocessing.process'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpprocident123b

  columns: [id, function, args, expected, description]
  rows:
    - [start_cls,   multiprocessing.Process.start.__class__.__name__.__eq__,    ["function"],                   true, "Process.start.__class__.__name__ == 'function' (pure-Python, inherited from BaseProcess); verified with Python 3.14.3"]
    - [term_cls,    multiprocessing.Process.terminate.__class__.__name__.__eq__, ["function"],                   true, "Process.terminate.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [kill_cls,    multiprocessing.Process.kill.__class__.__name__.__eq__,      ["function"],                   true, "Process.kill.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [alive_cls,   multiprocessing.Process.is_alive.__class__.__name__.__eq__,  ["function"],                   true, "Process.is_alive.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [start_mod,   multiprocessing.Process.start.__module__.__eq__,             ["multiprocessing.process"],    true, "Process.start.__module__ == 'multiprocessing.process' (BaseProcess defined in process.py); verified with Python 3.14.3"]
    - [term_mod,    multiprocessing.Process.terminate.__module__.__eq__,          ["multiprocessing.process"],    true, "Process.terminate.__module__ == 'multiprocessing.process'; verified with Python 3.14.3"]
    - [run_cls,     multiprocessing.Process.run.__class__.__name__.__eq__,       ["function"],                   true, "Process.run.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [join_mod,    multiprocessing.Process.join.__module__.__eq__,              ["multiprocessing.process"],    true, "Process.join.__module__ == 'multiprocessing.process'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra123
# ---------------------------------------------------------------------------

invariant multiprocessing_extra123.Process_mro_len_3:
  description: "multiprocessing.Process.__mro__.__len__() == 3 — Process.__mro__ is [Process, BaseProcess, object] (3 elements); the intermediate BaseProcess class is between Process and object; Process is defined in Lib/multiprocessing/context.py while BaseProcess is defined in Lib/multiprocessing/process.py; all Process core methods (start, run, join, terminate, kill, is_alive, __init__) are defined in BaseProcess and inherit with 'BaseProcess.' qualname prefix; contrast with BaseProcess.__mro__.__len__()==2 ([BaseProcess, object]); Process.__class__.__name__ is 'type'; Process.__name__ is 'Process' (len=7); NEW in extra123: first standalone Process MRO length invariant in mpprocident123 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra123.Process_terminate_qualname_len_21:
  description: "multiprocessing.Process.terminate.__qualname__.__len__() == 21 — Process.terminate.__qualname__ is 'BaseProcess.terminate' (21 chars: 'BaseProcess.'=12+'terminate'=9); this is the longest Process method qualname in this spec; compare all seven method qualname lengths: run=15, join=16, kill=16, start=17, is_alive=20, __init__=20, terminate=21; 'terminate' at 9 chars is the longest method name suffix; Process.terminate.__class__.__name__ is 'function'; Process.terminate.__module__ is 'multiprocessing.process'; terminate() immediately terminates the process using SIGTERM on Unix or TerminateProcess() on Windows; NEW in extra123: first standalone Process.terminate qualname length invariant in mpprocident123 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.terminate.__qualname__.__len__
  args: []
  expected: 21

invariant multiprocessing_extra123.Process_init_qualname_is_BaseProcess_init:
  description: "multiprocessing.Process.__init__.__qualname__.__eq__('BaseProcess.__init__') returns True — Process.__init__.__qualname__ is 'BaseProcess.__init__' (len=20: 'BaseProcess.'=12+'__init__'=8); __init__ is defined in BaseProcess (Lib/multiprocessing/process.py), not in the Process class itself (Lib/multiprocessing/context.py); this means Process.__init__ is truly inherited from BaseProcess and not overridden; Process.__init__.__class__.__name__ is 'function'; Process.__init__.__module__ is 'multiprocessing.process'; __init__ qualname length (20) is tied with is_alive (20) and less than terminate (21); __init__.__qualname__='BaseProcess.__init__' demonstrates the qualname-uses-defining-class pattern just like all other inherited Process methods; NEW in extra123: first standalone Process.__init__ qualname invariant in mpprocident123 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__qualname__.__eq__
  args: ["BaseProcess.__init__"]
  expected: true

invariant multiprocessing_extra123.Process_name_len_7:
  description: "multiprocessing.Process.__name__.__len__() == 7 — Process.__name__ is 'Process' (7 chars); Process.__qualname__ is also 'Process' (len=7, qualname equals name for module-level classes); Process.__module__ is 'multiprocessing.context'; compare class name lengths: Process=7, BaseProcess=11 (BaseProcess.__name__.__len__()==11); BaseProcess.__mro__.__len__()==2 while Process.__mro__.__len__()==3; Process.__bases__[0].__name__ is 'BaseProcess' (len=11); Process.__class__.__name__ is 'type'; NEW in extra123: first standalone Process name length invariant in mpprocident123 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.__name__.__len__
  args: []
  expected: 7

invariant multiprocessing_extra123.Process_run_qualname_len_15:
  description: "multiprocessing.Process.run.__qualname__.__len__() == 15 — Process.run.__qualname__ is 'BaseProcess.run' (15 chars: 'BaseProcess.'=12+'run'=3); this is the shortest Process method qualname in this spec (run=15 < join=16 = kill=16 < start=17 < is_alive=20 = __init__=20 < terminate=21); 'run' is a 3-char method name; Process.run() is the method that users override to specify process activity — the default implementation raises NotImplementedError; Process.run.__class__.__name__ is 'function'; Process.run.__module__ is 'multiprocessing.process'; NEW in extra123: first standalone Process.run qualname length invariant in mpprocident123 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Process.run.__qualname__.__len__
  args: []
  expected: 15
