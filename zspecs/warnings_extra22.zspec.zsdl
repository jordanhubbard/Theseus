spec: warnings_extra22
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
  notes:
    - "This spec extends warnings_extra21.zspec.zsdl."
    - "Prior specs covered: warnings.__name__/__package__, warn/__name__/__module__, warn_explicit/__name__/__module__, simplefilter/__name__/__module__, filterwarnings/__name__/__module__, resetwarnings/__name__/__module__, catch_warnings.__name__/__module__/__qualname__, DeprecationWarning/UserWarning classes, warnings.filters.__class__.__name__, catch_warnings.__bases__[0].__name__, warn/__qualname__, warn_explicit/__qualname__, simplefilter/__qualname__, filterwarnings/__qualname__, resetwarnings/__qualname__, catch_warnings.__init__.__qualname__, WarningMessage/__module__, catch_warnings/__module__, WarningMessage.__init__.__qualname__, PendingDeprecationWarning/__qualname__, DeprecationWarning/__qualname__, ResourceWarning/__qualname__, SyntaxWarning/__qualname__, ResourceWarning.__bases__[0].__name__, warn/__class__.__name__, warn_explicit/__class__.__name__, filterwarnings/__class__.__name__, simplefilter/__class__.__name__, resetwarnings/__class__.__name__."
    - "This spec covers: warn.__qualname__ (extra22 anchor), warn_explicit.__qualname__ (extra22 anchor), simplefilter.__qualname__ (extra22 anchor), filterwarnings.__qualname__ (extra22 anchor), resetwarnings.__qualname__ (extra22 anchor), warn.__module__ (extra22 anchor; '_warnings'), warn_explicit.__module__ (extra22 anchor; '_warnings'), simplefilter.__module__ (extra22 anchor; '_py_warnings'), filterwarnings.__module__ (extra22 anchor; '_py_warnings'), resetwarnings.__module__ (extra22 anchor; '_py_warnings'), catch_warnings.__init__.__name__ (new standalone invariant)."
    - "warnings.warn.__qualname__ == 'warn' — C builtin; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.warn_explicit.__qualname__ == 'warn_explicit' — C builtin; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.simplefilter.__qualname__ == 'simplefilter' — pure-Python function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.filterwarnings.__qualname__ == 'filterwarnings' — pure-Python function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.resetwarnings.__qualname__ == 'resetwarnings' — pure-Python function; qualname equals simple name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.warn.__module__ == '_warnings' — implemented in the _warnings C extension. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.warn_explicit.__module__ == '_warnings' — implemented in the _warnings C extension. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.simplefilter.__module__ == '_py_warnings' — pure-Python fallback layer. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.filterwarnings.__module__ == '_py_warnings' — pure-Python fallback layer. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.resetwarnings.__module__ == '_py_warnings' — pure-Python fallback layer. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "warnings.catch_warnings.__init__.__name__ == '__init__' — standard dunder method name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# warn and warn_explicit __qualname__ (extra22-namespace anchors)
#
# warnings_extra18 records warn.__qualname__ == 'warn' and
# warn_explicit.__qualname__ == 'warn_explicit' in the extra18 namespace.
# This spec provides fresh extra22-namespace standalone anchors.
# warn and warn_explicit are C builtins; their __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant warnings_extra22.warn.qualname:
  description: "warnings.warn.__qualname__ == 'warn' — C builtin; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: warn.__qualname__.__eq__
  args: ["warn"]
  expected: true

invariant warnings_extra22.warn_explicit.qualname:
  description: "warnings.warn_explicit.__qualname__ == 'warn_explicit' — C builtin; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: warn_explicit.__qualname__.__eq__
  args: ["warn_explicit"]
  expected: true

# ---------------------------------------------------------------------------
# simplefilter, filterwarnings, resetwarnings __qualname__ (extra22 anchors)
#
# warnings_extra18 records these three __qualname__ values in the extra18
# namespace. This spec provides extra22-namespace standalone anchors.
# All three are pure-Python functions; their __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant warnings_extra22.simplefilter.qualname:
  description: "warnings.simplefilter.__qualname__ == 'simplefilter' — pure-Python function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: simplefilter.__qualname__.__eq__
  args: ["simplefilter"]
  expected: true

invariant warnings_extra22.filterwarnings.qualname:
  description: "warnings.filterwarnings.__qualname__ == 'filterwarnings' — pure-Python function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: filterwarnings.__qualname__.__eq__
  args: ["filterwarnings"]
  expected: true

invariant warnings_extra22.resetwarnings.qualname:
  description: "warnings.resetwarnings.__qualname__ == 'resetwarnings' — pure-Python function; qualname equals simple name"
  category: function_qualname
  kind: python_call_eq
  function: resetwarnings.__qualname__.__eq__
  args: ["resetwarnings"]
  expected: true

# ---------------------------------------------------------------------------
# warn and warn_explicit __module__ (extra22-namespace anchors)
#
# warnings_extra (the first extra spec) records warn.__module__ == '_warnings'.
# warnings_extra2, extra10, extra11, extra15 record warn_explicit.__module__
# == '_warnings'. This spec provides extra22-namespace standalone anchors for
# both. The C extension module is '_warnings', not 'warnings'.
# ---------------------------------------------------------------------------

invariant warnings_extra22.warn.module:
  description: "warnings.warn.__module__ == '_warnings' — implemented in the _warnings C extension"
  category: function_module
  kind: python_call_eq
  function: warn.__module__.__eq__
  args: ["_warnings"]
  expected: true

invariant warnings_extra22.warn_explicit.module:
  description: "warnings.warn_explicit.__module__ == '_warnings' — implemented in the _warnings C extension"
  category: function_module
  kind: python_call_eq
  function: warn_explicit.__module__.__eq__
  args: ["_warnings"]
  expected: true

# ---------------------------------------------------------------------------
# simplefilter, filterwarnings, resetwarnings __module__ (extra22 anchors)
#
# warnings_extra14 records simplefilter.__module__ and filterwarnings.__module__
# == '_py_warnings'. warnings_extra15 records resetwarnings.__module__ ==
# '_py_warnings'. This spec provides extra22-namespace standalone anchors.
# ---------------------------------------------------------------------------

invariant warnings_extra22.simplefilter.module:
  description: "warnings.simplefilter.__module__ == '_py_warnings' — pure-Python fallback layer"
  category: function_module
  kind: python_call_eq
  function: simplefilter.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

invariant warnings_extra22.filterwarnings.module:
  description: "warnings.filterwarnings.__module__ == '_py_warnings' — pure-Python fallback layer"
  category: function_module
  kind: python_call_eq
  function: filterwarnings.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

invariant warnings_extra22.resetwarnings.module:
  description: "warnings.resetwarnings.__module__ == '_py_warnings' — pure-Python fallback layer"
  category: function_module
  kind: python_call_eq
  function: resetwarnings.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

# ---------------------------------------------------------------------------
# catch_warnings.__init__.__name__
#
# warnings_extra20 records catch_warnings.__init__.__qualname__. No prior
# warnings spec records catch_warnings.__init__.__name__ as a standalone
# named invariant. For any class __init__, __name__ is always '__init__'.
# ---------------------------------------------------------------------------

invariant warnings_extra22.catch_warnings.__init__.name:
  description: "warnings.catch_warnings.__init__.__name__ == '__init__' — standard dunder method name"
  category: method_name
  kind: python_call_eq
  function: catch_warnings.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all eleven invariants
#
# Covers warn/warn_explicit __qualname__ (2), simplefilter/filterwarnings/
# resetwarnings __qualname__ (3), warn/warn_explicit __module__ (2),
# simplefilter/filterwarnings/resetwarnings __module__ (3), and
# catch_warnings.__init__.__name__ (1).
# ---------------------------------------------------------------------------

table warnings_extra22.qualnames_modules_and_init_name:
  description: "Function __qualname__/__module__ values and catch_warnings.__init__.__name__"
  kind: python_call_eq
  category: function_qualname

  columns: [id, function, args, expected]
  rows:
    - [warn_qualname,            warn.__qualname__.__eq__,            ["warn"],                  true]
    - [warn_explicit_qualname,   warn_explicit.__qualname__.__eq__,   ["warn_explicit"],         true]
    - [simplefilter_qualname,    simplefilter.__qualname__.__eq__,    ["simplefilter"],           true]
    - [filterwarnings_qualname,  filterwarnings.__qualname__.__eq__,  ["filterwarnings"],         true]
    - [resetwarnings_qualname,   resetwarnings.__qualname__.__eq__,   ["resetwarnings"],          true]
    - [warn_module,              warn.__module__.__eq__,              ["_warnings"],              true]
    - [warn_explicit_module,     warn_explicit.__module__.__eq__,     ["_warnings"],              true]
    - [simplefilter_module,      simplefilter.__module__.__eq__,      ["_py_warnings"],           true]
    - [filterwarnings_module,    filterwarnings.__module__.__eq__,    ["_py_warnings"],           true]
    - [resetwarnings_module,     resetwarnings.__module__.__eq__,     ["_py_warnings"],           true]
    - [catch_warnings_init_name, catch_warnings.__init__.__name__.__eq__, ["__init__"],           true]
