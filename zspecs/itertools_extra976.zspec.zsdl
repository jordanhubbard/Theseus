docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks that itertools iterator classes are type objects (instances of 'type') via __class__.__name__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra976.finite_iterator_class_identity:
  description: "Finite itertools classes are type objects"
  kind: python_call_eq
  category: class_identity
  id_prefix: it976fi
  columns: [id, function, args, expected]
  rows:
    - [it976fi001, itertools.chain.__class__.__name__.__eq__,                    ["type"], true]
    - [it976fi002, itertools.combinations.__class__.__name__.__eq__,             ["type"], true]
    - [it976fi003, itertools.combinations_with_replacement.__class__.__name__.__eq__, ["type"], true]
    - [it976fi004, itertools.permutations.__class__.__name__.__eq__,             ["type"], true]
    - [it976fi005, itertools.compress.__class__.__name__.__eq__,                 ["type"], true]
    - [it976fi006, itertools.dropwhile.__class__.__name__.__eq__,                ["type"], true]
    - [it976fi007, itertools.filterfalse.__class__.__name__.__eq__,              ["type"], true]

