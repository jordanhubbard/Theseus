spec: lodash_toarray
version: ">=4.0.0"
backend: node(lodash.toarray)

docs: https://lodash.com/docs/#toArray

provenance:
  derived_from:
    - "lodash.toarray README — https://www.npmjs.com/package/lodash.toarray"
    - "Test vectors verified with lodash.toarray@4.4.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.toarray exports the _.toArray function directly as module.exports."
    - "toArray converts value to an array."
    - "Strings become arrays of characters."
    - "Objects become arrays of their values."
    - "Arrays are returned as-is (cloned)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array from value."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_toarray.toarray:
  kind: node_module_call_eq
  function: ~
  category: toarray
  id_prefix: lta

  columns: [id, args, expected]
  rows:
    - [string,  ["abc"],          ["a", "b", "c"]]
    - [object,  [{"a": 1, "b": 2}], [1, 2]]
    - [array,   [[1, 2, 3]],      [1, 2, 3]]
    - [null_v,  [null],           []]
