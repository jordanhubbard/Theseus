spec: hashlib_extra1786
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python hashlib documentation — https://docs.python.org/3/library/hashlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "hashlib_extra.zspec.zsdl — covers algorithms_guaranteed, new(), HASH attributes"
    - "hashlib_extra2.zspec.zsdl — covers additional hash algorithm and API checks"
    - "hashlib_extra1771.zspec.zsdl — covers async protocol dict-presence checks for hashlib._hashlib.HASH (__aenter__/__aexit__/__aiter__/__anext__/__await__ all False) and complementary HASH.__dict__ checks (digest_size, block_size, update, digest, hexdigest, copy)."
  notes:
    - "Wave 566 (_extra1786): __class_getitem__ and __init_subclass__ class creation hooks dict-presence checks."
    - "Theme: which hashlib stdlib types define __class_getitem__ and __init_subclass__ in their own __dict__."
    - "hashlib._hashlib.HASH: the C-level hash object type returned by hashlib.sha256() etc. It is a C extension type and does not support generic-alias syntax (HASH[T] is not meaningful) -> __class_getitem__ False."
    - "__init_subclass__ is a classmethod added to all Python classes by the type machinery; for C extension types it is typically inherited from object, not defined in the type's own __dict__ -> False."
    - "Rationale: hashlib types implement the cryptographic hash protocol (update/digest/hexdigest/copy/name/digest_size/block_size), not parameterised generics or subclass hooks."
    - "Complementary checks: HASH.__dict__.__contains__('hexdigest') -> True (hexdigest is a C-level method defined on HASH); HASH.__dict__.__contains__('name') -> True (name is a C-level descriptor); algorithms_guaranteed.__contains__('sha256') -> True; algorithms_guaranteed.__contains__('md5') -> True."
    - "hashlib._hashlib.HASH.__dict__.__contains__('__class_getitem__') -> False — HASH is a C extension type; it does not expose generic-alias support via __class_getitem__."
    - "hashlib._hashlib.HASH.__dict__.__contains__('__init_subclass__') -> False — __init_subclass__ is inherited from object for C extension types; it is not redefined in HASH.__dict__."
    - "hashlib._hashlib.HASH.__dict__.__contains__('hexdigest') -> True — hexdigest is a C-level method defined directly on HASH."
    - "hashlib._hashlib.HASH.__dict__.__contains__('name') -> True — name is a C-level read-only descriptor defined directly on HASH."
    - "All expected values verified by running Python 3.14 hashlib module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ and __init_subclass__ dict-presence checks
#          for hashlib._hashlib.HASH
#
# Wave 566 theme: which hashlib types define __class_getitem__ and
# __init_subclass__ in their own __dict__.
#
# hashlib._hashlib.HASH: the C-level hash object type. It is not a generic
# type and does not redefine __init_subclass__, so both checks return False.
# ---------------------------------------------------------------------------

table hashlib_extra1786.class_creation_hooks:
  description: "hashlib._hashlib.HASH __class_getitem__ and __init_subclass__ dict-presence checks — all False — wave 566 _extra1786"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1786

  columns: [id, function, args, expected]
  rows:
    - ["hl1786001", "hashlib._hashlib.HASH.__dict__.__contains__", ["__class_getitem__"],   false]
    - ["hl1786002", "hashlib._hashlib.HASH.__dict__.__contains__", ["__init_subclass__"],   false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for hashlib module
#
# The class-creation-hooks theme is all-False for hashlib._hashlib.HASH.
# Complementary checks confirm genuine hashlib-specific structural properties:
# - HASH.__dict__ contains 'hexdigest' and 'name' (C-level attributes)
# - HASH.__dict__ does NOT contain '__class_getitem__' (already in table 1)
# - algorithms_guaranteed contains 'sha256' and 'md5' (always guaranteed)
# - hashlib.new.__class__.__name__ is 'builtin_function_or_method'
# - hashlib.sha256.__class__.__name__ is 'builtin_function_or_method'
# - HASH.__dict__.__contains__('digest_size') -> True
# - HASH.__dict__.__contains__('block_size') -> True
# - HASH.__dict__.__contains__('copy') -> True
# - HASH.__dict__.__contains__('update') -> True
# - HASH.__name__.__eq__('HASH') -> True
# - HASH.__module__.__eq__('_hashlib') -> True
# - algorithms_guaranteed.__class__.__name__.__eq__('set') -> True
# ---------------------------------------------------------------------------

table hashlib_extra1786.complementary_checks:
  description: "hashlib structural property checks — wave 566 _extra1786"
  kind: python_call_eq
  category: complementary
  id_prefix: hl1786

  columns: [id, function, args, expected]
  rows:
    - ["hl1786003", "hashlib._hashlib.HASH.__dict__.__contains__",              ["hexdigest"],                  true]
    - ["hl1786004", "hashlib._hashlib.HASH.__dict__.__contains__",              ["name"],                       true]
    - ["hl1786005", "hashlib._hashlib.HASH.__dict__.__contains__",              ["digest_size"],                true]
    - ["hl1786006", "hashlib._hashlib.HASH.__dict__.__contains__",              ["block_size"],                 true]
    - ["hl1786007", "hashlib._hashlib.HASH.__dict__.__contains__",              ["copy"],                       true]
    - ["hl1786008", "hashlib._hashlib.HASH.__dict__.__contains__",              ["update"],                     true]
    - ["hl1786009", "hashlib._hashlib.HASH.__name__.__eq__",                    ["HASH"],                       true]
    - ["hl1786010", "hashlib._hashlib.HASH.__module__.__eq__",                  ["_hashlib"],                   true]
    - ["hl1786011", "hashlib.algorithms_guaranteed.__contains__",               ["sha256"],                     true]
    - ["hl1786012", "hashlib.algorithms_guaranteed.__contains__",               ["md5"],                        true]
    - ["hl1786013", "hashlib.algorithms_guaranteed.__class__.__name__.__eq__",  ["set"],                        true]
    - ["hl1786014", "hashlib.new.__class__.__name__.__eq__",                    ["builtin_function_or_method"], true]
    - ["hl1786015", "hashlib.sha256.__class__.__name__.__eq__",                 ["builtin_function_or_method"], true]
    - ["hl1786016", "hashlib.algorithms_available.__contains__",                ["sha256"],                     true]
    - ["hl1786017", "hashlib.algorithms_available.__class__.__name__.__eq__",   ["set"],                        true]
    - ["hl1786018", "hashlib._hashlib.HASH.__dict__.__contains__",              ["digest"],                     true]
    - ["hl1786019", "hashlib._hashlib.HASH.__dict__.__contains__",              ["__reduce__"],                 false]
    - ["hl1786020", "hashlib.algorithms_guaranteed.__contains__",               ["sha512"],                     true]
    - ["hl1786021", "hashlib.algorithms_guaranteed.__contains__",               ["sha1"],                       true]
    - ["hl1786022", "hashlib._hashlib.HASH.__dict__.__contains__",              ["__sizeof__"],                 false]
    - ["hl1786023", "hashlib._hashlib.HASH.__bases__[0].__name__.__eq__",       ["object"],                     true]
