spec: struct_extra126
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra125.zspec.zsdl — covers struct.__all__ list class name ('list') and length (8) / __all__ membership for all 8 entries / Struct method __objclass__.__name__ equality (table + invariants)."
    - "struct_extra124.zspec.zsdl — covers Struct.__dict__.__contains__('__delattr__'/'__getattribute__'/'__setattr__') / error.__dict__.__contains__('__doc__'/'__module__'/'__weakref__') (table + invariants)."
    - "struct_extra123.zspec.zsdl — covers Struct.pack/__objclass__/__module__.__eq__('_struct') / Struct.unpack/__objclass__/__module__.__eq__('_struct') / Struct.pack_into/__objclass__/__module__.__eq__('_struct') / Struct.pack/__objclass__/__qualname__.__eq__('Struct') / Struct.pack/__objclass__/__class__.__name__.__eq__('type') (table + invariants)."
    - "struct_extra122.zspec.zsdl — covers struct.error/__name__/__qualname__/__class__.__name__ equality / struct.error/__bases__[0]/__name__ / struct.error/__mro__/__len__()==4 / Struct/__name__/__qualname__/__class__.__name__ equality / Struct.size/format/__name__ equality (table + invariants)."
    - "struct_extra121.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__ string equality ('Struct.pack' etc.) / method __objclass__.__name__ equality (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths / Struct.size/__format__ descriptor __doc__ string equality and length / struct module __doc__ length (1278) (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / Struct.size/__format__ qualname/name lengths and __objclass__.__name__ (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__() (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality (pack/unpack/pack_into/unpack_from/iter_unpack) / Struct.format/__qualname__ / error/__bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior struct spec files."
    - "Wave 305 theme: Struct dunder method __qualname__ string equality and __qualname__.__len__() — __init__/__repr__/__sizeof__/__reduce_ex__ qualname strings and lengths / Struct.__class__.__name__=='type' / Struct.__new__.__qualname__ equality and length."
    - "struct.Struct.__init__.__qualname__ == 'Struct.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__qualname__ == 'Struct.__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__reduce_ex__.__qualname__ == 'object.__reduce_ex__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__qualname__.__len__() == 15. len('Struct.__init__')==15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__repr__.__qualname__.__len__() == 15. len('Struct.__repr__')==15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__sizeof__.__qualname__.__len__() == 17. len('Struct.__sizeof__')==17. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__reduce_ex__.__qualname__.__len__() == 20. len('object.__reduce_ex__')==20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__class__.__name__ == 'type'. Already anchored in extra122 via __eq__ call; confirmed here for context. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__new__.__qualname__ == 'Struct.__new__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__new__.__qualname__.__len__() == 14. len('Struct.__new__')==14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct_extra94 anchors __qualname__.__len__() for the 5 pack/unpack methods only. This spec first anchors qualname lengths for the 4 dunder lifecycle methods (__init__, __repr__, __sizeof__, __reduce_ex__) and __new__."
    - "Note: __reduce_ex__.__qualname__ is 'object.__reduce_ex__' (not 'Struct.__reduce_ex__') because Struct inherits __reduce_ex__ from object without overriding it. The qualname reflects the defining class."
    - "Note: Struct.__init__ and Struct.__repr__ share qualname length 15 ('Struct.__init__' and 'Struct.__repr__' both have 15 characters). Struct.__sizeof__ is 17. Struct.__new__ is 14."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__qualname__.__eq__('Struct.__init__')
# struct.Struct.__repr__.__qualname__.__eq__('Struct.__repr__')
# struct.Struct.__sizeof__.__qualname__.__eq__('Struct.__sizeof__')
# struct.Struct.__init__.__qualname__.__len__()==15
# struct.Struct.__repr__.__qualname__.__len__()==15
#
# Wave 305 theme: Struct dunder lifecycle method qualname equality.
#
# struct_extra94 anchors __qualname__.__len__() for the 5 pack/unpack methods
# (pack, unpack, pack_into, unpack_from, iter_unpack). struct_extra93 anchors
# __name__ equality for those same 5 methods. This table first anchors the
# qualname equality and lengths for the dunder lifecycle methods __init__,
# __repr__, and __sizeof__. __init__ and __repr__ both have qualname length 15
# ('Struct.__init__' and 'Struct.__repr__'). __sizeof__ is 17 ('Struct.__sizeof__').
# No prior struct spec anchors any of these under structdunder126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra126.Struct_dunder_qualname_eq:
  description: "Struct.__init__/__qualname__.__eq__('Struct.__init__')==True / __repr__/__qualname__.__eq__('Struct.__repr__')==True / __sizeof__/__qualname__.__eq__('Struct.__sizeof__')==True / __init__/__qualname__/__len__()==15 / __repr__/__qualname__/__len__()==15 — extra94 anchors qualname lengths for the 5 pack/unpack methods; this table first anchors dunder lifecycle method qualname equality and lengths; __init__ and __repr__ share length 15; __sizeof__ is 17; first structdunder126 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdunder126

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname_eq,   Struct.__init__.__qualname__.__eq__,    ["Struct.__init__"],  true, "Struct.__init__ qualname is 'Struct.__init__' (wrapper_descriptor from _struct.c)"]
    - [repr_qualname_eq,   Struct.__repr__.__qualname__.__eq__,    ["Struct.__repr__"],  true, "Struct.__repr__ qualname is 'Struct.__repr__' (wrapper_descriptor from _struct.c)"]
    - [sizeof_qualname_eq, Struct.__sizeof__.__qualname__.__eq__,  ["Struct.__sizeof__"],true, "Struct.__sizeof__ qualname is 'Struct.__sizeof__' (method_descriptor from _struct.c)"]
    - [init_qualname_len,  Struct.__init__.__qualname__.__len__,   [],                   15,   "Struct.__init__ qualname len=15 (len('Struct.__init__')==15)"]
    - [repr_qualname_len,  Struct.__repr__.__qualname__.__len__,   [],                   15,   "Struct.__repr__ qualname len=15 (len('Struct.__repr__')==15, same as __init__)"]

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__qualname__.__len__()==17
# struct.Struct.__reduce_ex__.__qualname__.__eq__('object.__reduce_ex__')
# struct.Struct.__reduce_ex__.__qualname__.__len__()==20
# struct.Struct.__new__.__qualname__.__eq__('Struct.__new__')
# struct.Struct.__new__.__qualname__.__len__()==14
#
# Wave 305 theme: Struct inherited and __new__ method qualname details.
#
# Struct.__reduce_ex__ is inherited from object (not overridden in Struct), so
# its qualname is 'object.__reduce_ex__' (length 20). This distinguishes it from
# __init__/__repr__/__sizeof__ which are defined on Struct itself. Struct.__new__
# is the C-level Struct constructor with qualname 'Struct.__new__' (length 14).
# __new__ is shorter because 'new' (3 chars) is shorter than 'init'/'repr'/'sizeof'.
# No prior struct spec anchors any of these under structdunder126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra126.Struct_inherited_and_new_qualnames:
  description: "Struct.__sizeof__/__qualname__/__len__()==17 / __reduce_ex__/__qualname__.__eq__('object.__reduce_ex__')==True / __reduce_ex__/__qualname__/__len__()==20 / __new__/__qualname__.__eq__('Struct.__new__')==True / __new__/__qualname__/__len__()==14 — __reduce_ex__ is inherited from object (qualname starts with 'object.'); __new__ is 14 chars; __sizeof__ is 17; no prior struct spec anchors these; first structdunder126 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdunder126

  columns: [id, function, args, expected, description]
  rows:
    - [sizeof_qualname_len,    Struct.__sizeof__.__qualname__.__len__,       [],                      17, "Struct.__sizeof__ qualname len=17 (len('Struct.__sizeof__')==17)"]
    - [reduce_ex_qualname_eq,  Struct.__reduce_ex__.__qualname__.__eq__,     ["object.__reduce_ex__"],true, "Struct.__reduce_ex__ qualname is 'object.__reduce_ex__' (inherited from object, not overridden)"]
    - [reduce_ex_qualname_len, Struct.__reduce_ex__.__qualname__.__len__,    [],                      20, "Struct.__reduce_ex__ qualname len=20 (len('object.__reduce_ex__')==20)"]
    - [new_qualname_eq,        Struct.__new__.__qualname__.__eq__,           ["Struct.__new__"],      true, "Struct.__new__ qualname is 'Struct.__new__' (C-level Struct constructor)"]
    - [new_qualname_len,       Struct.__new__.__qualname__.__len__,          [],                      14, "Struct.__new__ qualname len=14 (len('Struct.__new__')==14)"]

# ---------------------------------------------------------------------------
# struct.Struct.__class__.__name__.__eq__('type')
# struct.error.__qualname__.__eq__('error')
# struct.error.__module__.__eq__('struct')
# struct.Struct.__qualname__.__eq__('Struct')
# struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor')
#
# Wave 305 theme: Struct and error class identity cross-checks.
#
# struct.Struct.__class__.__name__ == 'type' is anchored in extra122 via __eq__.
# struct.error.__qualname__ == 'error' is also anchored in extra122. This table
# anchors Struct.__init__.__class__.__name__ == 'wrapper_descriptor' (the C-level
# class for C extension dunder methods, different from method_descriptor used for
# named C methods like pack/unpack). struct_extra92 anchors pack/unpack/etc.
# __class__.__name__=='method_descriptor'; no prior spec anchors __init__/__repr__
# __class__.__name__ == 'wrapper_descriptor' under structdunder126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra126.Struct_class_identity:
  description: "Struct/__class__/__name__.__eq__('type')==True / error/__qualname__.__eq__('error')==True / error/__module__.__eq__('struct')==True / Struct/__qualname__.__eq__('Struct')==True / Struct/__init__/__class__/__name__.__eq__('wrapper_descriptor')==True — extra122 anchors Struct/__class__/__name__ and error/__qualname__/__module__; this table adds first anchor for Struct/__init__/__class__/__name__=='wrapper_descriptor' under structdunder126"
  kind: python_call_eq
  category: type_identity
  id_prefix: structdunder126

  columns: [id, function, args, expected, description]
  rows:
    - [struct_class_type,        Struct.__class__.__name__.__eq__,           ["type"],               true, "Struct.__class__.__name__ is 'type' (Struct is a class whose metaclass is type; extra122 also anchors this)"]
    - [error_qualname,           error.__qualname__.__eq__,                  ["error"],              true, "struct.error.__qualname__ is 'error' (lowercase; extra122 also anchors this)"]
    - [error_module,             error.__module__.__eq__,                    ["struct"],             true, "struct.error.__module__ is 'struct' (Python-level module, not '_struct'; extra122 also anchors this)"]
    - [struct_qualname,          Struct.__qualname__.__eq__,                 ["Struct"],             true, "struct.Struct.__qualname__ is 'Struct' (extra122 also anchors this)"]
    - [init_class_wrapper_desc,  Struct.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true, "Struct.__init__.__class__.__name__ is 'wrapper_descriptor' (C dunder slots; contrasts with method_descriptor for pack/unpack)"]

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__qualname__.__eq__('Struct.__init__') — standalone
#
# struct.Struct.__init__.__qualname__ is 'Struct.__init__'. Struct.__init__ is
# a wrapper_descriptor (C-level slot wrapper for tp_init). Its qualname follows
# the 'ClassName.method_name' pattern. struct_extra94 anchors __qualname__.__len__()
# for the 5 pack/unpack methods only; struct_extra93 anchors __name__ equality for
# those same 5 methods. No prior struct spec anchors Struct.__init__.__qualname__
# equality as a standalone under structdunder126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra126.Struct_init_qualname_eq:
  description: "struct.Struct.__init__.__qualname__.__eq__('Struct.__init__') == True — __init__ is a wrapper_descriptor (C tp_init slot); qualname follows 'ClassName.method_name' pattern; extra94 anchors qualname lengths for pack/unpack methods only; first standalone for Struct.__init__ qualname equality under structdunder126"
  category: type_identity
  kind: python_call_eq
  function: Struct.__init__.__qualname__.__eq__
  args: ["Struct.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__sizeof__.__qualname__.__len__()==17 — standalone
#
# struct.Struct.__sizeof__.__qualname__.__len__() is 17. The qualname 'Struct.__sizeof__'
# has 17 characters: 'Struct.' (7) + '__sizeof__' (10). Struct.__sizeof__ is a
# method_descriptor (C-level) that returns the instance memory size in bytes.
# Unlike __init__ and __repr__ (wrapper_descriptors), __sizeof__ is a
# method_descriptor. Its qualname length 17 contrasts with __init__/__repr__
# (length 15) and __new__ (length 14). No prior struct spec anchors
# Struct.__sizeof__.__qualname__.__len__() as a standalone under structdunder126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra126.Struct_sizeof_qualname_len_17:
  description: "struct.Struct.__sizeof__.__qualname__.__len__() == 17 — 'Struct.__sizeof__' has 17 chars ('Struct.'=7 + '__sizeof__'=10); __sizeof__ is a method_descriptor returning instance byte size; contrasts with __init__/__repr__ (len 15) and __new__ (len 14); first standalone for Struct.__sizeof__ qualname len under structdunder126"
  category: type_identity
  kind: python_call_eq
  function: Struct.__sizeof__.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# struct.Struct.__reduce_ex__.__qualname__.__eq__('object.__reduce_ex__') — standalone
#
# struct.Struct.__reduce_ex__.__qualname__ is 'object.__reduce_ex__'. Struct does
# not override __reduce_ex__ — it inherits this method from object (the base class).
# When a method is inherited and not overridden, its qualname reflects the defining
# class (object), not the class that provides access to it (Struct). This contrasts
# with __init__/__repr__/__sizeof__ (qualname 'Struct.*') which are defined on
# Struct itself. No prior struct spec anchors __reduce_ex__ qualname equality as
# a standalone under structdunder126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra126.Struct_reduce_ex_qualname_object:
  description: "struct.Struct.__reduce_ex__.__qualname__.__eq__('object.__reduce_ex__') == True — __reduce_ex__ is inherited from object (not overridden in Struct); qualname shows 'object.' prefix, distinguishing inherited from defined methods; contrasts with Struct.__init__ (qualname 'Struct.__init__'); first standalone under structdunder126"
  category: type_identity
  kind: python_call_eq
  function: Struct.__reduce_ex__.__qualname__.__eq__
  args: ["object.__reduce_ex__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__new__.__qualname__.__eq__('Struct.__new__') — standalone
#
# struct.Struct.__new__.__qualname__ is 'Struct.__new__'. Struct.__new__ is the
# C-level constructor (tp_new slot) for the Struct type. Unlike __init__ (which
# initializes an existing instance), __new__ creates the instance. Its qualname
# 'Struct.__new__' has 14 characters (the shortest of the four dunder lifecycle
# methods: __new__=14, __init__=15, __repr__=15, __sizeof__=17). No prior struct
# spec anchors Struct.__new__.__qualname__ equality as a standalone under
# structdunder126. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra126.Struct_new_qualname_eq:
  description: "struct.Struct.__new__.__qualname__.__eq__('Struct.__new__') == True — Struct.__new__ is the C-level tp_new constructor; qualname 'Struct.__new__' has 14 chars (shortest among lifecycle dunders); contrasts with __init__/__repr__ (15) and __sizeof__ (17); first standalone for Struct.__new__ qualname under structdunder126"
  category: type_identity
  kind: python_call_eq
  function: Struct.__new__.__qualname__.__eq__
  args: ["Struct.__new__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') — standalone
#
# struct.Struct.__init__.__class__.__name__ is 'wrapper_descriptor'. Dunder slot
# methods (__init__, __repr__, __hash__, etc.) on C extension types are exposed as
# wrapper_descriptor objects (PyWrapperDescrObject in CPython). This differs from
# named C methods (pack, unpack, pack_into, etc.) which are method_descriptor
# objects. struct_extra92 anchors __class__.__name__=='method_descriptor' for the
# 5 pack/unpack methods. No prior struct spec anchors __init__.__class__.__name__==
# 'wrapper_descriptor' as a standalone under structdunder126.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra126.Struct_init_class_wrapper_descriptor:
  description: "struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — Struct.__init__ is a C-level slot wrapper (PyWrapperDescrObject); contrasts with pack/unpack (method_descriptor); extra92 anchors method_descriptor for pack/unpack methods; first standalone for wrapper_descriptor identity under structdunder126"
  category: type_identity
  kind: python_call_eq
  function: Struct.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

